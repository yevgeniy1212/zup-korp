		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ДАТАВРЕМЯ(1, 1, 1) КАК Период,
	ЗНАЧЕНИЕ(Справочник.Сценарии.ПустаяСсылка) КАК Сценарий,
	ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка) КАК Подразделение,
	ЗНАЧЕНИЕ(Справочник.ПозицииКадровогоПлана.ПустаяСсылка) КАК Позиция,
	ЗНАЧЕНИЕ(Справочник.ФизическиеЛица.ПустаяСсылка) КАК ФизическоеЛицо,
	ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка) КАК Сотрудник,
	ЗНАЧЕНИЕ(Справочник.ПоказателиКадровогоПланирования.ПустаяСсылка) КАК Показатель,
	0 КАК Значение,
	ЛОЖЬ КАК ЗависимаяВакансия
ПОМЕСТИТЬ Представления_ПоказателиКадровогоПлана
ГДЕ
	"ТолькоРазрешенные" = ИСТИНА
	И "НачалоПериода" = &amp;НачалоПериода
	И "КонецПериода" = &amp;КонецПериода
	И "Сценарий" = &amp;Сценарий
	И "СценарийОбязателен" = ИСТИНА
	И "Подразделение" = &amp;Подразделение
;

