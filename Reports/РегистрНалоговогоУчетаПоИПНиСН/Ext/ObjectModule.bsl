					Если СтрокаФизЛица.СуммаДохода = 0
						И СтрокаФизЛица.СуммаВОСМС = 0
						И СтрокаФизЛица.СуммаПениВОСМС = 0
						И СтрокаФизЛица.СуммаВОСМСПеречисленный = 0
                        И СтрокаФизЛица.СуммаОблагаемогоДоходаВОСМС = 0 Тогда
						
						Продолжить;
						
					КонецЕсли;
						                                                                                               
					ЗаполнитьЗначенияСвойств(Макеты.Шапка.Параметры, СтрокаФизЛица);
					Макеты.Шапка.Параметры.ДатаПодписи		= ТекущаяДатаСеанса();
					Макеты.Шапка.Параметры.Фамилия			= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаФизЛица.ФизическоеЛицо, "Фамилия");
					Макеты.Шапка.Параметры.Имя 				= ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаФизЛица.ФизическоеЛицо, "Имя");
