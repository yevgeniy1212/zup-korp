				КадровыеДанныеФизическихЛиц = КадровыйУчет.КадровыеДанныеФизическихЛиц(Истина, СписокФизлицРуководства, "ФИОПолные");
				
				ПараметрыОтветственныхЛиц = Новый Структура ("Руководитель, ФИОРуководитель, ГлавныйБухгалтер, ФИОГлавныйБухгалтер, Исполнитель, ФИОИсполнитель");
				
				Если ЗначениеЗаполнено(ЗаполняемыеЗначения.Руководитель) Тогда
					ФИО = КадровыеДанныеФизическихЛиц.Найти(ЗаполняемыеЗначения.Руководитель, "ФизическоеЛицо");
					ПараметрыОтветственныхЛиц.ФИОРуководитель = ?(ФИО <> Неопределено, ФИО.ФИОПолные,"");
				КонецЕсли;
				Если ЗначениеЗаполнено(ЗаполняемыеЗначения.ГлавныйБухгалтер) Тогда
					ФИО = КадровыеДанныеФизическихЛиц.Найти(ЗаполняемыеЗначения.ГлавныйБухгалтер, "ФизическоеЛицо");
					ПараметрыОтветственныхЛиц.ФИОГлавныйБухгалтер = ?(ФИО <> Неопределено, ФИО.ФИОПолные,"");
				КонецЕсли;
				
