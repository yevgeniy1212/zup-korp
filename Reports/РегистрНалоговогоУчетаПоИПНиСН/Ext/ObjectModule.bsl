					Макеты.Шапка.Параметры.БИННалогоплательщика = ИННЮЛ;
					Макеты.Шапка.Параметры.АдресОрганизации = ПолныйАдрЮР;
					ДокументРезультат.Вывести(Макеты.Шапка);
					ДокументРезультат.Вывести(Макеты.ШапкаТЧ);
					
					КоличествоМесяцев = 0;
					
					ВыводимыйГод = Дата(1, 1, 1);
					
					ИтогоСуммаДохода = 0;
					ИтогоСуммаВОСМС = 0;
					ИтогоСуммаВОСМСПеречисленный = 0;
					ИтогоСуммаПениВОСМС = 0;
                    ИтогоСуммаОблагаемогоДоходаВОСМС = 0;
					
					Для Каждого СтрокаМесяцев Из СтрокаФизЛица.Строки Цикл
						
						Если НЕ Год(СтрокаМесяцев.МесяцНалоговогоПериода) = Год(ВыводимыйГод) Тогда
							
							// выведем итог по году
							Если НЕ ВыводимыйГод = Дата(1, 1, 1) Тогда
								
								Макеты.ПодвалТЧ.Параметры.Год = Год(ВыводимыйГод);
								Макеты.ПодвалТЧ.Параметры.СуммаДохода = ИтогоСуммаДохода;
								Макеты.ПодвалТЧ.Параметры.СуммаВОСМС	  = ИтогоСуммаВОСМС + ИтогоСуммаПениВОСМС;
								Макеты.ПодвалТЧ.Параметры.СуммаВОСМСПеречисленный = ИтогоСуммаВОСМСПеречисленный;
								Макеты.ПодвалТЧ.Параметры.СуммаПениВОСМС = ИтогоСуммаПениВОСМС;
								Макеты.ПодвалТЧ.Параметры.СуммаОблагаемогоДоходаВОСМС = ИтогоСуммаОблагаемогоДоходаВОСМС;
								
								Если НЕ ДокументРезультат.ПроверитьВывод(Макеты.ПодвалТЧ) Тогда
									ДокументРезультат.ВывестиГоризонтальныйРазделительСтраниц();
								КонецЕсли;
								
								ДокументРезультат.Вывести(Макеты.ПодвалТЧ);
								
								ВыводимыйГод = СтрокаМесяцев.МесяцНалоговогоПериода;
								
							Иначе
								
								ВыводимыйГод = СтрокаМесяцев.МесяцНалоговогоПериода;
								
							КонецЕсли;
							
							ИтогоСуммаДохода = СтрокаМесяцев.СуммаДохода;
							ИтогоСуммаВОСМСПеречисленный = СтрокаМесяцев.СуммаВОСМСПеречисленный;
							ИтогоСуммаПениВОСМС = СтрокаМесяцев.СуммаПениВОСМС;
							ИтогоСуммаВОСМС = СтрокаМесяцев.СуммаВОСМС + СтрокаМесяцев.СуммаПениВОСМС;
                            ИтогоСуммаОблагаемогоДоходаВОСМС = СтрокаМесяцев.СуммаОблагаемогоДоходаВОСМС;
							
						Иначе
						
							ИтогоСуммаДохода = ИтогоСуммаДохода + СтрокаМесяцев.СуммаДохода;
							ИтогоСуммаВОСМС = ИтогоСуммаВОСМС + СтрокаМесяцев.СуммаВОСМС;
							ИтогоСуммаВОСМСПеречисленный = ИтогоСуммаВОСМСПеречисленный + СтрокаМесяцев.СуммаВОСМСПеречисленный;
							ИтогоСуммаПениВОСМС = ИтогоСуммаПениВОСМС + СтрокаМесяцев.СуммаПениВОСМС;
                            ИтогоСуммаОблагаемогоДоходаВОСМС = ИтогоСуммаОблагаемогоДоходаВОСМС + СтрокаМесяцев.СуммаОблагаемогоДоходаВОСМС;
						
						КонецЕсли;
						
						ЗаполнитьЗначенияСвойств(Макеты.СтрокаТЧ.Параметры, СтрокаМесяцев);
						
						// учтем ситуации, когда вся сумма была сторнирована (возврат)
						Если НЕ СтрокаМесяцев.СуммаВОСМСПеречисленный = 0
							И (ЗначениеЗаполнено(СтрокаМесяцев.ДатаПлатежногоДокумента)
							ИЛИ ЗначениеЗаполнено(СтрокаМесяцев.НомерПлатежногоДокумента)
							ИЛИ ЗначениеЗаполнено(СтрокаМесяцев.ПеречисленоЗаПериод)) Тогда
							
							Макеты.СтрокаТЧ.Параметры.РеквизитыПлатежногоДокумента = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = '%1, %2, %3'"),
														Формат(СтрокаМесяцев.ДатаПлатежногоДокумента, "ДФ=dd.MM.yyyy"), СтрокаМесяцев.НомерПлатежногоДокумента, Формат(СтрокаМесяцев.ПеречисленоЗаПериод, "ДФ='ММММ гггг'"));
														
						Иначе
							Макеты.СтрокаТЧ.Параметры.РеквизитыПлатежногоДокумента = "";
						КонецЕсли;								
						
						Макеты.СтрокаТЧ.Параметры.СуммаВОСМС = СтрокаМесяцев.СуммаВОСМС + СтрокаМесяцев.СуммаПениВОСМС;
						
						Если НЕ ДокументРезультат.ПроверитьВывод(Макеты.СтрокаТЧ) Тогда
							ДокументРезультат.ВывестиГоризонтальныйРазделительСтраниц();
							ДокументРезультат.Вывести(Макеты.ШапкаТЧ);
						КонецЕсли;
						
						ДокументРезультат.Вывести(Макеты.СтрокаТЧ);
						КоличествоМесяцев = КоличествоМесяцев + 1;
						
					КонецЦикла;
												
					Макеты.ПодвалТЧ.Параметры.Год = Год(ВыводимыйГод);
					Макеты.ПодвалТЧ.Параметры.СуммаДохода = ИтогоСуммаДохода;
					Макеты.ПодвалТЧ.Параметры.СуммаВОСМС	  = ИтогоСуммаВОСМС + ИтогоСуммаПениВОСМС;
					Макеты.ПодвалТЧ.Параметры.СуммаВОСМСПеречисленный = ИтогоСуммаВОСМСПеречисленный;
					Макеты.ПодвалТЧ.Параметры.СуммаПениВОСМС = ИтогоСуммаПениВОСМС;
					Макеты.ПодвалТЧ.Параметры.СуммаОблагаемогоДоходаВОСМС = ИтогоСуммаОблагаемогоДоходаВОСМС;
					
					Если НЕ ДокументРезультат.ПроверитьВывод(Макеты.ПодвалТЧ) Тогда
						ДокументРезультат.ВывестиГоризонтальныйРазделительСтраниц();
					КонецЕсли;
					
					ДокументРезультат.Вывести(Макеты.ПодвалТЧ);
					
					ЗаполнитьЗначенияСвойств(Макеты.Подвал.Параметры, ПараметрыОтветственныхЛиц);
					Макеты.Подвал.Параметры.КоличествоМесяцев = КоличествоМесяцев;
					Макеты.Подвал.Параметры.ИтогоСумма = Строка(СтрокаФизЛица.СуммаДохода) + " (" + СокрЛП(РаботаСКурсамиВалют.СформироватьСуммуПрописью(
						СтрокаФизЛица.СуммаДохода, ЗарплатаКадры.ВалютаУчетаЗаработнойПлаты())) + ")";
					
					ДокументРезультат.Вывести(Макеты.Подвал);
					
					ДокументРезультат.ВывестиГоризонтальныйРазделительСтраниц();
					
				КонецЦикла;
				
			КонецЦикла;
			
		Иначе
			
			Для Каждого СтрокаОрганизации Из ДанныеОтчета.Строки Цикл
				
				Если ЕстьГруппировкаПоОрганизации Тогда
					
					Макеты.Группировка.Параметры.НазваниеПараметра = НСтр("ru='Организация'");
					Макеты.Группировка.Параметры.Значение = СтрокаОрганизации.Организация;
					
					ДокументРезультат.Вывести(Макеты.Группировка);
					Организация = СтрокаОрганизации.Организация;
					
				КонецЕсли;
				
				//ОрганизацияНаименование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаОрганизации.Организация, "НаименованиеПолное");
				//ОрганизацияБИН = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаОрганизации.Организация, "ИНН");
				СтрокаСведений = "ИННЮЛ, НаимЮЛПол, ПолныйАдрЮР";
				СведенияОбОрганизации = РегламентированнаяОтчетностьРК.ПолучитьСведенияОбОрганизации(СтрокаОрганизации.Организация,ТекущаяДатаСеанса(),СтрокаСведений);
				РеквизитыОрганизации = "";
				
				Если ЗначениеЗаполнено(СведенияОбОрганизации.ПолныйАдрЮР) Тогда
					РеквизитыОрганизации = РеквизитыОрганизации 
						+ ?(ЗначениеЗаполнено(РеквизитыОрганизации), "; ", "") + СокрЛП(СведенияОбОрганизации.ПолныйАдрЮР);
				КонецЕсли;
				Если ЗначениеЗаполнено(СведенияОбОрганизации.ИННЮЛ) Тогда
					РеквизитыОрганизации = РеквизитыОрганизации 
						+ ?(ЗначениеЗаполнено(РеквизитыОрганизации), "; ", "") + НСтр("ru = 'БИН: '") + СокрЛП(СведенияОбОрганизации.ИННЮЛ);
				КонецЕсли;
				
				ЗаполняемыеЗначения = Новый Структура("Организация,Руководитель,ГлавныйБухгалтер,ДолжностьРуководителя ", СтрокаОрганизации.Организация);
				ЗарплатаКадры.ПолучитьЗначенияПоУмолчанию(ЗаполняемыеЗначения);
				
				СписокФизлицРуководства = Новый Массив;
				Если ЗначениеЗаполнено(ЗаполняемыеЗначения.Руководитель) Тогда
					СписокФизлицРуководства.Добавить(ЗаполняемыеЗначения.Руководитель);
				КонецЕсли;
				Если ЗначениеЗаполнено(ЗаполняемыеЗначения.ГлавныйБухгалтер) Тогда
					СписокФизлицРуководства.Добавить(ЗаполняемыеЗначения.ГлавныйБухгалтер);
				КонецЕсли;
				
				КадровыеДанныеФизическихЛиц = КадровыйУчет.КадровыеДанныеФизическихЛиц(Истина, СписокФизлицРуководства, "ФамилияИО");
				
				ПараметрыОтветственныхЛиц = Новый Структура ("Руководитель, ФИОРуководитель, ГлавныйБухгалтер, ФИОГлавныйБухгалтер, Исполнитель, ФИОИсполнитель");
				
				Если ЗначениеЗаполнено(ЗаполняемыеЗначения.Руководитель) Тогда
					ФИО = КадровыеДанныеФизическихЛиц.Найти(ЗаполняемыеЗначения.Руководитель, "ФизическоеЛицо");
					ПараметрыОтветственныхЛиц.ФИОРуководитель = ?(ФИО <> Неопределено, ФИО.ФамилияИО,"");
					ПараметрыОтветственныхЛиц.Руководитель = ЗаполняемыеЗначения.ДолжностьРуководителя;
				КонецЕсли;
				Если ЗначениеЗаполнено(ЗаполняемыеЗначения.ГлавныйБухгалтер) Тогда
					ФИО = КадровыеДанныеФизическихЛиц.Найти(ЗаполняемыеЗначения.ГлавныйБухгалтер, "ФизическоеЛицо");
					ПараметрыОтветственныхЛиц.ФИОГлавныйБухгалтер = ?(ФИО <> Неопределено, ФИО.ФамилияИО,"");
					ПараметрыОтветственныхЛиц.ГлавныйБухгалтер = ЗаполняемыеЗначения.ГлавныйБухгалтер;
				КонецЕсли;
				
				Для Каждого СтрокаФизЛица Из СтрокаОрганизации.Строки Цикл
					
					ЗаполнитьЗначенияСвойств(Макеты.Шапка.Параметры,СтрокаФизЛица);
					Макеты.Шапка.Параметры.ИИН = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаФизЛица.ФизическоеЛицо, "ИНН");
					Макеты.Шапка.Параметры.Организация = СведенияОбОрганизации.НаимЮЛПол;
					Макеты.Шапка.Параметры.РеквизитыОрганизации = РеквизитыОрганизации;
					ДокументРезультат.Вывести(Макеты.Шапка);
					ДокументРезультат.Вывести(Макеты.ШапкаТЧ);
					
					КоличествоМесяцев = 0;
					
					Для Каждого СтрокаМесяцев Из СтрокаФизЛица.Строки Цикл
						
						Если СтрокаМесяцев.ОбъектИсчисленияСО = 0
							И СтрокаМесяцев.СуммаСО = 0
							И СтрокаМесяцев.СуммаСОУплаченная = 0 Тогда
								Продолжить;
						КонецЕсли;
						
						ЗаполнитьЗначенияСвойств(Макеты.СтрокаТЧ.Параметры,СтрокаМесяцев);
						Макеты.СтрокаТЧ.Параметры.Период = СтрокаМесяцев.МесяцНалоговогоПериода;
						
						Если НЕ ДокументРезультат.ПроверитьВывод(Макеты.СтрокаТЧ) Тогда
							ДокументРезультат.ВывестиГоризонтальныйРазделительСтраниц();
							ДокументРезультат.Вывести(Макеты.ШапкаТЧ);
						КонецЕсли;
						
						ДокументРезультат.Вывести(Макеты.СтрокаТЧ);
						КоличествоМесяцев = КоличествоМесяцев + 1;
						
					КонецЦикла;
					
					Если НЕ ДокументРезультат.ПроверитьВывод(Макеты.ПодвалТЧ) Тогда
						ДокументРезультат.ВывестиГоризонтальныйРазделительСтраниц();
						ДокументРезультат.Вывести(Макеты.ШапкаТЧ);
					КонецЕсли;
					
					ЗаполнитьЗначенияСвойств(Макеты.ПодвалТЧ.Параметры,СтрокаФизЛица);
					ДокументРезультат.Вывести(Макеты.ПодвалТЧ);
					
					Если НЕ ДокументРезультат.ПроверитьВывод(Макеты.Подвал) Тогда
						ДокументРезультат.ВывестиГоризонтальныйРазделительСтраниц();
					КонецЕсли;
					
					ЗаполнитьЗначенияСвойств(Макеты.Подвал.Параметры, ПараметрыОтветственныхЛиц);
					Макеты.Подвал.Параметры.ТекущаяДата = ТекущаяДатаСеанса();
					Макеты.Подвал.Параметры.СуммаДохода = СтрокаФизЛица.ОбъектИсчисленияСО;
					Макеты.Подвал.Параметры.СуммаДоходаПрописью = СокрЛП(РаботаСКурсамиВалют.СформироватьСуммуПрописью(
						СтрокаФизЛица.ОбъектИсчисленияСО,ЗарплатаКадры.ВалютаУчетаЗаработнойПлаты(),Истина));
					Макеты.Подвал.Параметры.КоличествоМесяцев = КоличествоМесяцев;
					
					ДокументРезультат.Вывести(Макеты.Подвал);
					
					ДокументРезультат.ВывестиГоризонтальныйРазделительСтраниц();
					
				КонецЦикла;
				
			КонецЦикла;
			
		КонецЕсли;
			
		
		ДопСвойства = КомпоновщикНастроек.ПользовательскиеНастройки.ДополнительныеСвойства;
		ДопСвойства.Вставить("ОтчетПустой", ДанныеОтчета.Строки.Количество() = 0);
		
	Исключение
		
		Инфо = ИнформацияОбОшибке();
		ВызватьИсключение НСтр("ru = 'В настройку отчета "+
			?(СправкаОЗаработнойПлате,"""Справка о заработной плате""","""Справка с места работы перед наступлением социального риска""")
			+" внесены критичные изменения. Отчет не будет сформирован.'")
			+ ""
			+ КраткоеПредставлениеОшибки(Инфо);
		
	КонецПопытки;
	
КонецПроцедуры

Функция НайтиПоИмени(Структура, Имя)
    
    Группировка = Неопределено;
	Для каждого Элемент Из Структура Цикл
		Если ТипЗнч(Элемент) = Тип("ТаблицаКомпоновкиДанных") Тогда
			Если Элемент.Имя = Имя Тогда
				Возврат Элемент;
			КонецЕсли;	
		Иначе
			Если Элемент.Имя = Имя Тогда
				Возврат Элемент;
			КонецЕсли;	
			Для каждого Поле Из Элемент.ПоляГруппировки.Элементы Цикл
				Если Не ТипЗнч(Поле) = Тип("АвтоПолеГруппировкиКомпоновкиДанных") Тогда
					Если Поле.Поле = Новый ПолеКомпоновкиДанных(Имя) Тогда
						Возврат Элемент;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
			Если Элемент.Структура.Количество() = 0 Тогда
				Продолжить;
			Иначе
				Группировка = НайтиПоИмени(Элемент.Структура, Имя);
				Если Не Группировка = Неопределено Тогда
					Возврат	Группировка;
				КонецЕсли;	
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Возврат Группировка;
	
КонецФункции

Функция ЗаполнитьОтветсвенныеЛицаОрганизации (ОтветственныеЛицаОрганизации, ПериодОтчета, Ответственный, ДолжностьОтветственного)
    
    ДатаОтчета = ?(ЗначениеЗаполнено(ПериодОтчета.ДатаОкончания), ПериодОтчета.ДатаОкончания, ТекущаяДата()) ;
    
    Запрос = Новый Запрос;
    Запрос.Текст = 
    "ВЫБРАТЬ РАЗРЕШЕННЫЕ
    |   Организации.Ссылка КАК Организация
    |ИЗ
    |   Справочник.Организации КАК Организации";
    
    Выборка = Запрос.Выполнить().Выбрать();
    
    Пока Выборка.Следующий() Цикл
        НоваяСтрока = ОтветственныеЛицаОрганизации.Добавить();
        ОтветственныеЛица = Новый Структура("Организация,Руководитель,ДолжностьРуководителя,ГлавныйБухгалтер,ДолжностьГлавногоБухгалтера", Выборка.Организация);
        ЗарплатаКадры.ПолучитьЗначенияПоУмолчанию(ОтветственныеЛица, ДатаОтчета);
        
        НоваяСтрока.Организация = Выборка.Организация;
        МассивФизЛиц = Новый Массив;
        МассивФизЛиц.Добавить(ОтветственныеЛица.Руководитель);
        МассивФизЛиц.Добавить(ОтветственныеЛица.ГлавныйБухгалтер);
        Если ЗначениеЗаполнено(Ответственный) Тогда
            МассивФизЛиц.Добавить(Ответственный);
        КонецЕсли;
        
        ФИОФизЛиц = ЗарплатаКадры.СоответствиеФИОФизЛицСсылкам(ДатаОтчета, МассивФизЛиц);
        ФИОРуководителя = ФИОФизЛиц[ОтветственныеЛица.Руководитель];
        НоваяСтрока.ДолжностьРуководителя = ?(ОтветственныеЛица.ДолжностьРуководителя = Неопределено, "", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОтветственныеЛица.ДолжностьРуководителя, "Наименование"));
        
        Если ФИОРуководителя <> Неопределено Тогда
            НоваяСтрока.Руководитель	= ФизическиеЛицаЗарплатаКадры.РасшифровкаПодписи(ФИОРуководителя);
        Иначе	
            НоваяСтрока.Руководитель	= "";
        КонецЕсли;	
        
        ФИООтветственногоСтрокой = "";
        Если ЗначениеЗаполнено(Ответственный) Тогда
            СписокФизЛиц = Новый Массив;
            СписокФизЛиц.Добавить(Ответственный);
            ОсновныеСотрудникиФизическихЛиц = КадровыйУчет.ОсновныеСотрудникиФизическихЛиц(СписокФизЛиц, Истина, Выборка.Организация, ДатаОтчета);
            
            ФИООтветственного = ФИОФизЛиц[Ответственный];
            НоваяСтрока.Ответственный = ФизическиеЛицаЗарплатаКадры.РасшифровкаПодписи(ФИООтветственного);
            Если ЗначениеЗаполнено(ДолжностьОтветственного) Тогда
                НоваяСтрока.ДолжностьОтветственного = ДолжностьОтветственного;
            Иначе
                Если ОсновныеСотрудникиФизическихЛиц.Количество() > 0  Тогда
                    СписокСотрудников = Новый Массив;
                    СписокСотрудников.Добавить(ОсновныеСотрудникиФизическихЛиц[0].Сотрудник);	
                    
                    КадровыеДанные = КадровыйУчет.КадровыеДанныеСотрудников(Истина, СписокСотрудников, "Должность", ДатаОтчета);
                    
                    Если КадровыеДанные.Количество() > 0 Тогда
                        Если ЗначениеЗаполнено(КадровыеДанные[0].Должность) Тогда
                            НоваяСтрока.ДолжностьОтветственного = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(КадровыеДанные[0].Должность, "Наименование");
                        Иначе
                            НоваяСтрока.ДолжностьОтветственного = "";
                        КонецЕсли; 
                    Иначе
                        НоваяСтрока.ДолжностьОтветственного = "";
                    КонецЕсли;
                Иначе
                    НоваяСтрока.ДолжностьОтветственного = "";
                КонецЕсли;	
            КонецЕсли;
        КонецЕсли;		
        
        ФИОГлавногоБухгалтера = ФИОФизЛиц[ОтветственныеЛица.ГлавныйБухгалтер];
        ДолжностьГлавногоБухгалтера = НСтр("ru = 'Главный бухгалтер'");
        Если ФИОГлавногоБухгалтера <> Неопределено Тогда 
            НоваяСтрока.ГлавныйБухгалтер = ФизическиеЛицаЗарплатаКадры.РасшифровкаПодписи(ФИОГлавногоБухгалтера);
        Иначе	
            НоваяСтрока.ГлавныйБухгалтер = "";
        КонецЕсли;	
        
        Если ОтветственныеЛица.ГлавныйБухгалтер = Ответственный Тогда
            НоваяСтрока.ДолжностьГлавногоБухгалтера = ?(ЗначениеЗаполнено(ДолжностьОтветственного), ДолжностьОтветственного, ДолжностьГлавногоБухгалтера);
        Иначе	
            Если ЗначениеЗаполнено(ОтветственныеЛица.ГлавныйБухгалтер) Тогда
                СписокФизЛиц = Новый Массив;
                СписокФизЛиц.Добавить(ОтветственныеЛица.ГлавныйБухгалтер);
                ОсновныеСотрудникиФизическихЛиц = КадровыйУчет.ОсновныеСотрудникиФизическихЛиц(СписокФизЛиц, Истина, Выборка.Организация, ДатаОтчета);
                
                Если ОсновныеСотрудникиФизическихЛиц.Количество() > 0  Тогда
                    
                    СписокСотрудников = Новый Массив;
                    СписокСотрудников.Добавить(ОсновныеСотрудникиФизическихЛиц[0].Сотрудник);	
                    
                    КадровыеДанные = КадровыйУчет.КадровыеДанныеСотрудников(Истина, СписокСотрудников, "Должность", ДатаОтчета);
                    
                    Если КадровыеДанные.Количество() > 0 Тогда
                        Если ЗначениеЗаполнено(КадровыеДанные[0].Должность) Тогда
                            НоваяСтрока.ДолжностьГлавногоБухгалтера = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(КадровыеДанные[0].Должность, "Наименование");	
                        Иначе
                            НоваяСтрока.ДолжностьГлавногоБухгалтера = "";
                        КонецЕсли; 
                    Иначе
                        НоваяСтрока.ДолжностьГлавногоБухгалтера = "";
                    КонецЕсли;
                Иначе
                    НоваяСтрока.ДолжностьГлавногоБухгалтера = "";
                КонецЕсли;
            Иначе
                НоваяСтрока.ДолжностьГлавногоБухгалтера = "";
            КонецЕсли;
        КонецЕсли;
    КонецЦикла;
    
    Возврат ОтветственныеЛицаОрганизации;
    
КонецФункции

Функция ПолучитьСписокНачисленийДоходВНатуральнойФорме()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Начисления.Ссылка КАК Начисление
		|ИЗ
		|	ПланВидовРасчета.Начисления КАК Начисления
		|ГДЕ
		|	Начисления.КатегорияНачисленияИлиНеоплаченногоВремени = ЗНАЧЕНИЕ(Перечисление.КатегорииНачисленийИНеоплаченногоВремени.ДоходВНатуральнойФорме)";
	
	Результат = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Начисление");
	
	Если Результат.Количество() = 0 Тогда
		Возврат Неопределено;
	Иначе
		Возврат Результат;
	КонецЕсли;
	
КонецФункции

Процедура ИзменениеПараметраМакетаСогласноНастройкеКомпоновщика(Выражение, ПараметрМакета, НастройкиКомпоновщика)
	
	ВыражениеГруппировки = НайтиВыражениеВСтруктуреКомпоновщика(Выражение, НастройкиКомпоновщика);
	
	Если ВыражениеГруппировки <> "" Тогда
		Для Каждого Макет Из СхемаКомпоновкиДанных.Макеты Цикл
			Если Макет.Параметры.Найти(ПараметрМакета) <> Неопределено Тогда
				Макет.Параметры[ПараметрМакета].Выражение = ВыражениеГруппировки;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Функция НайтиВыражениеВСтруктуреКомпоновщика(Выражение, НастройкиКомпоновщика)
	
	ПолеСтрокой = ПолучитьПолеСтруктурыКомпоновщика(НастройкиКомпоновщика.Структура);
	Если Найти(ПолеСтрокой, Выражение) > 0 Тогда
		Возврат ПолеСтрокой;
	Иначе
		Для Каждого СтруктураКомпоновщика Из НастройкиКомпоновщика.Структура Цикл
			Если СтруктураКомпоновщика.Использование Тогда
				ПолеСтрокой = ПолучитьПолеСтруктурыКомпоновщика(СтруктураКомпоновщика.Структура);
				Если Найти(ПолеСтрокой, Выражение) > 0 Тогда
					Возврат ПолеСтрокой;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Процедура ПроверкаСтруктурыДанныхКомпоновщикаДляШапкиИПодписей(НастройкиКомпоновщика, НастройкиПоУмолчанию)
	
	Поле = ПолучитьПолеСтруктурыКомпоновщика(НастройкиКомпоновщика.Структура);
	ПолеПоУмолчанию = ПолучитьПолеСтруктурыКомпоновщика(НастройкиПоУмолчанию.Структура);
	
	Если Найти(Поле, ПолеПоУмолчанию) > 0 Тогда
		Поле = ПолучитьПолеСтруктурыКомпоновщика(НастройкиКомпоновщика.Структура[0].Структура);
		ПолеПоУмолчанию = ПолучитьПолеСтруктурыКомпоновщика(НастройкиПоУмолчанию.Структура[0].Структура);
		
		Если Найти(Поле, ПолеПоУмолчанию) = 0 Тогда
			ОтключениеШапкиИПодписей("Организация");
		КонецЕсли;
	Иначе
		ОтключениеШапкиИПодписей("Организация");
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьПолеСтруктурыКомпоновщика(СтруктураКомпоновщика)
	
	Для Каждого СтруктураГруппировки Из СтруктураКомпоновщика Цикл
		Если СтруктураГруппировки.Использование И ТипЗнч(СтруктураГруппировки) = Тип("ГруппировкаКомпоновкиДанных") Тогда
			Для Каждого ПолеГруппировки Из СтруктураГруппировки.ПоляГруппировки.Элементы Цикл
				Если ПолеГруппировки.Использование Тогда
					Возврат Строка(ПолеГруппировки.Поле);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

Процедура ОтключениеШапкиИПодписей(ИмяГруппировки)
	
	УдаляемыеМакеты = Новый Массив;
	Для Каждого МакетГруппировки Из СхемаКомпоновкиДанных.МакетыГруппировок Цикл
		Если МакетГруппировки.ИмяГруппировки = ИмяГруппировки Тогда
			УдаляемыеМакеты.Добавить(МакетГруппировки);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого УдаляемыйМакет Из УдаляемыеМакеты Цикл
		СхемаКомпоновкиДанных.МакетыГруппировок.Удалить(УдаляемыйМакет);
	КонецЦикла;
	
КонецПроцедуры

