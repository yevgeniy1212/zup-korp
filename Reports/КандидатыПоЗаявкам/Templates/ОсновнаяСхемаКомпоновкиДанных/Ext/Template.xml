		<field xsi:type="DataSetFieldField">
			<dataPath>КандидатыПоЗаявкам.Заявка</dataPath>
			<field>Заявка</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Заявка</v8:content>
				</v8:item>
			</title>
			<presentationExpression>КандидатыПоЗаявкам.Заявка.Номер + " от " + Формат(КандидатыПоЗаявкам.Заявка.Дата, "ДФ=dd.MM.yyyy")</presentationExpression>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КандидатыПоЗаявкам.Кандидат</dataPath>
			<field>Кандидат</field>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Кандидат</v8:content>
				</v8:item>
			</title>
			<role>
				<dcscom:ignoreNullValues>true</dcscom:ignoreNullValues>
			</role>
		</field>
		<field xsi:type="DataSetFieldFolder">
			<dataPath>КандидатыПоЗаявкам</dataPath>
			<title xsi:type="v8:LocalStringType">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Кандидаты по заявкам</v8:content>
				</v8:item>
			</title>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Вакансия</dataPath>
			<field>Вакансия</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ОткрытыеВакансииДоПериода.Вакансия КАК Вакансия
ПОМЕСТИТЬ ВТОткрытыеВакансииДоПериода
ИЗ
	РегистрСведений.СостоянияВакансий.СрезПоследних(&amp;НачалоПериода, ) КАК ОткрытыеВакансииДоПериода
ГДЕ
	НЕ ОткрытыеВакансииДоПериода.Состояние В (ЗНАЧЕНИЕ(Перечисление.СостоянияВакансии.Закрыта), ЗНАЧЕНИЕ(Перечисление.СостоянияВакансии.Отменена))
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ЗаявкаНаПодборПерсонала.Ссылка КАК Заявка
ПОМЕСТИТЬ ВТЗаявкиНаПодборПерсонала
ИЗ
	Документ.ЗаявкаНаПодборПерсонала КАК ЗаявкаНаПодборПерсонала
		ЛЕВОЕ СОЕДИНЕНИЕ ВТОткрытыеВакансииДоПериода КАК ОткрытыеВакансииДоПериода
		ПО ЗаявкаНаПодборПерсонала.Ссылка = ОткрытыеВакансииДоПериода.Вакансия.Основание
ГДЕ
	НЕ ОткрытыеВакансииДоПериода.Вакансия ЕСТЬ NULL
	И ЗаявкаНаПодборПерсонала.Проведен
	И НЕ ЗаявкаНаПодборПерсонала.ПометкаУдаления

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ЗаявкаНаПодборПерсонала.Ссылка
ИЗ
	Документ.ЗаявкаНаПодборПерсонала КАК ЗаявкаНаПодборПерсонала
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияВакансий КАК ОткрытыеВакансии
		ПО ЗаявкаНаПодборПерсонала.Ссылка = ОткрытыеВакансии.Вакансия.Основание
			И (НЕ ОткрытыеВакансии.Состояние В (ЗНАЧЕНИЕ(Перечисление.СостоянияВакансии.Закрыта), ЗНАЧЕНИЕ(Перечисление.СостоянияВакансии.Отменена)))
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияВакансий КАК ЗакрытыеВакансии
		ПО (ОткрытыеВакансии.Вакансия = ЗакрытыеВакансии.Вакансия)
			И (ЗакрытыеВакансии.Состояние В (ЗНАЧЕНИЕ(Перечисление.СостоянияВакансии.Закрыта), ЗНАЧЕНИЕ(Перечисление.СостоянияВакансии.Отменена)))
ГДЕ
	ЗаявкаНаПодборПерсонала.Дата &gt;= &amp;НачалоПериода
	И (ЗакрытыеВакансии.Период &lt;= &amp;ОкончаниеПериода
			ИЛИ ЗакрытыеВакансии.Период ЕСТЬ NULL)
	И ЗаявкаНаПодборПерсонала.Проведен
	И НЕ ЗаявкаНаПодборПерсонала.ПометкаУдаления

СГРУППИРОВАТЬ ПО
	ЗаявкаНаПодборПерсонала.Ссылка
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ЗаявкиНаПодборПерсонала.Заявка КАК Заявка,
	Кандидаты.Ссылка КАК Кандидат
ИЗ
	ВТЗаявкиНаПодборПерсонала КАК ЗаявкиНаПодборПерсонала
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Кандидаты КАК Кандидаты
		ПО ЗаявкиНаПодборПерсонала.Заявка = Кандидаты.Вакансия.Основание
			И (НЕ Кандидаты.ПометкаУдаления)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СогласованиеВакансий КАК СогласованиеВакансий
		ПО ЗаявкиНаПодборПерсонала.Заявка = СогласованиеВакансий.Вакансия
ГДЕ
	СогласованиеВакансий.СостояниеСогласования &lt;&gt; ЗНАЧЕНИЕ(Перечисление.СостоянияСогласования.Отклонено)</query>
	</dataSet>
	<dataSet xsi:type="DataSetQuery">
