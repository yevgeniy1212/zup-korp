		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ИндивидуальныйПланРазвития.Ссылка КАК ИПР,
	ИндивидуальныйПланРазвития.Владелец КАК ФизическоеЛицо,
	ИндивидуальныйПланРазвития.ДатаНачала КАК ДатаНачала,
	ИндивидуальныйПланРазвития.ДатаОкончания КАК ДатаОкончания
ПОМЕСТИТЬ ВТИндивидуальныеПланыРазвития
ИЗ
	Справочник.ИндивидуальныйПланРазвития КАК ИндивидуальныйПланРазвития
ГДЕ
	ИндивидуальныйПланРазвития.ДатаНачала &lt;= &amp;ОкончаниеПериода
	И ИндивидуальныйПланРазвития.ДатаОкончания &gt;= &amp;НачалоПериода
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ОсновныеСотрудники.Сотрудник КАК Сотрудник,
	ИндивидуальныйПланРазвития.ДатаОкончания КАК Период
ПОМЕСТИТЬ ВТСотрудники
ИЗ
	РегистрСведений.ОсновныеСотрудникиФизическихЛиц КАК ОсновныеСотрудники
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТИндивидуальныеПланыРазвития КАК ИндивидуальныйПланРазвития
		ПО (ИндивидуальныйПланРазвития.ФизическоеЛицо = ОсновныеСотрудники.ФизическоеЛицо)
			И (ИндивидуальныйПланРазвития.ДатаОкончания МЕЖДУ ОсновныеСотрудники.ДатаНачала И КОНЕЦПЕРИОДА(ОсновныеСотрудники.ДатаОкончания, ДЕНЬ))
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ДАТАВРЕМЯ(1, 1, 1) КАК Период,
	ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка) КАК Сотрудник,
	ЗНАЧЕНИЕ(Справочник.ФизическиеЛица.ПустаяСсылка) КАК ФизическоеЛицо,
	ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка) КАК Организация,
	ЗНАЧЕНИЕ(Справочник.ШтатноеРасписание.ПустаяСсылка) КАК ДолжностьПоШтатномуРасписанию,
	ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка) КАК МестоВСтруктуреПредприятия,
	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаПриема,
	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаУвольнения
ПОМЕСТИТЬ Представления_КадровыеДанныеСотрудников
ИЗ
	ВТСотрудники КАК Сотрудники
ГДЕ
	"ТолькоРазрешенные" = ИСТИНА
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	КадровыеДанные.Период КАК Период,
	КадровыеДанные.Сотрудник КАК Сотрудник,
	КадровыеДанные.ФизическоеЛицо КАК ФизическоеЛицо,
	КадровыеДанные.Организация КАК Организация,
	КадровыеДанные.ДолжностьПоШтатномуРасписанию КАК ДолжностьПоШтатномуРасписанию,
	КадровыеДанные.МестоВСтруктуреПредприятия КАК МестоВСтруктуреПредприятия,
	КадровыеДанные.ДатаПриема КАК ДатаПриема,
	КадровыеДанные.ДатаУвольнения КАК ДатаУвольнения,
	ИндивидуальныеПланыРазвития.ИПР КАК ИПР,
	ПрограммаОбучения.Мероприятие КАК Мероприятие,
	ПрограммаОбучения.ДатаНачала КАК ДатаНачала,
	ПрограммаОбучения.ДатаОкончания КАК ДатаОкончания,
	ПрограммаОбучения.Ответственный КАК Ответственный,
	ПрограммаОбучения.РезультатВыполнения КАК РезультатВыполнения,
	РезультатыОбучения.Регистратор КАК ДокументОбучения,
	РезультатыОбучения.ДатаНачала КАК ДатаНачалаФакт,
	РезультатыОбучения.ДатаОкончания КАК ДатаОкончанияФакт,
	РезультатыОбучения.Оценка КАК Оценка,
	РезультатыОбучения.КомментарийКОценке КАК КомментарийКОценке,
	Свидетельство.Ссылка КАК Свидетельство
ИЗ
	Представления_КадровыеДанныеСотрудников КАК КадровыеДанные
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТИндивидуальныеПланыРазвития КАК ИндивидуальныеПланыРазвития
		ПО (ИндивидуальныеПланыРазвития.ФизическоеЛицо = КадровыеДанные.ФизическоеЛицо)
			И (ИндивидуальныеПланыРазвития.ДатаОкончания = КадровыеДанные.Период)
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ИндивидуальныйПланРазвития.Мероприятия КАК ПрограммаОбучения
		ПО (ПрограммаОбучения.Ссылка = ИндивидуальныеПланыРазвития.ИПР)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОбучениеСотрудников КАК РезультатыОбучения
		ПО (РезультатыОбучения.ФизическоеЛицо = ПрограммаОбучения.Ссылка.Владелец)
			И (РезультатыОбучения.Мероприятие = ПрограммаОбучения.Мероприятие)
			И (РезультатыОбучения.ДатаНачала &lt;= ПрограммаОбучения.ДатаОкончания)
			И (РезультатыОбучения.ДатаОкончания &gt;= ПрограммаОбучения.ДатаНачала)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОбразованиеФизическихЛицОснования КАК ЗаписиОбразования
		ПО (ЗаписиОбразования.Обучение = РезультатыОбучения.Регистратор)
			И (ЗаписиОбразования.ОбъектСсылка.Владелец = РезультатыОбучения.ФизическоеЛицо)
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ОбразованиеФизическихЛиц КАК Свидетельство
		ПО (Свидетельство.Ссылка = ЗаписиОбразования.ОбъектСсылка)
			И (ЗаписиОбразования.ОбъектСсылка.Владелец = ПрограммаОбучения.Ссылка.Владелец)</query>
	</dataSet>
	<calculatedField>
		<dataPath>МестоРаботы.Состояние</dataPath>
		<expression>ВЫБОР КОГДА МестоРаботы.ДатаУвольнения = ДАТАВРЕМЯ(1,1,1) ТОГДА &amp;Работает ИНАЧЕ &amp;Уволен КОНЕЦ</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Состояние</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<parameter>
		<name>ОкончаниеПериода</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Окончание периода</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>Date</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:nil="true"/>
		<useRestriction>true</useRestriction>
		<expression>&amp;ПериодОтчета.ДатаОкончания</expression>
		<availableAsField>false</availableAsField>
		<use>Always</use>
	</parameter>
	<parameter>
		<name>НачалоПериода</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Начало периода</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:dateTime</v8:Type>
			<v8:DateQualifiers>
				<v8:DateFractions>Date</v8:DateFractions>
			</v8:DateQualifiers>
		</valueType>
		<value xsi:nil="true"/>
		<useRestriction>true</useRestriction>
		<expression>&amp;ПериодОтчета.ДатаНачала</expression>
		<availableAsField>false</availableAsField>
		<use>Always</use>
	</parameter>
	<parameter>
		<name>ПериодОтчета</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>За период</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>v8:StandardPeriod</v8:Type>
		</valueType>
		<value xsi:type="v8:StandardPeriod">
			<v8:variant xsi:type="v8:StandardPeriodVariant">Custom</v8:variant>
			<v8:startDate>0001-01-01T00:00:00</v8:startDate>
			<v8:endDate>0001-01-01T00:00:00</v8:endDate>
		</value>
		<useRestriction>false</useRestriction>
		<use>Always</use>
	</parameter>
	<parameter>
		<name>Работает</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Работает</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:string</v8:Type>
			<v8:StringQualifiers>
				<v8:Length>0</v8:Length>
				<v8:AllowedLength>Variable</v8:AllowedLength>
			</v8:StringQualifiers>
		</valueType>
		<value xsi:type="xs:string">работает</value>
		<useRestriction>true</useRestriction>
		<availableAsField>false</availableAsField>
		<use>Always</use>
	</parameter>
	<parameter>
		<name>Уволен</name>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Уволен</v8:content>
			</v8:item>
		</title>
		<valueType>
			<v8:Type>xs:string</v8:Type>
			<v8:StringQualifiers>
				<v8:Length>0</v8:Length>
				<v8:AllowedLength>Variable</v8:AllowedLength>
			</v8:StringQualifiers>
		</valueType>
		<value xsi:type="xs:string">уволен</value>
		<useRestriction>true</useRestriction>
		<availableAsField>false</availableAsField>
		<use>Always</use>
	</parameter>
	<settingsVariant>
		<dcsset:name>ИндивидуальныеПланыРазвития</dcsset:name>
		<dcsset:presentation xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Индивидуальные планы развития</v8:content>
			</v8:item>
		</dcsset:presentation>
		<dcsset:settings xmlns:style="http://v8.1c.ru/8.1/data/ui/style" xmlns:sys="http://v8.1c.ru/8.1/data/ui/fonts/system" xmlns:web="http://v8.1c.ru/8.1/data/ui/colors/web" xmlns:win="http://v8.1c.ru/8.1/data/ui/colors/windows">
			<dcsset:selection>
				<dcsset:item xsi:type="dcsset:SelectedItemField">
