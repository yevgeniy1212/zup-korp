КонецФункции

Функция СформироватьСписокЛистовФорма2021_1(Объект) Экспорт
	СписокИспользуемыхМакетов = УведомлениеОСпецрежимахНалогообложения.ЗагрузитьМакетыИзАрхива(Объект, "БланкиПечати_");
	Листы = Новый СписокЗначений;
	
	СтруктураПараметров = Объект.Ссылка.ДанныеУведомления.Получить();
	ИННКПП = Новый Структура();
	ИННКПП.Вставить("ИНН", СтруктураПараметров.ДанныеУведомления.Форма2021_1_Титульная.ИННШапка);
	ИННКПП.Вставить("ПервыйЛист");
	
	НомСтр = 1;
	ПечатнаяФорма = УведомлениеОСпецрежимахНалогообложения.НовыйПустойЛист();
	ПечатнаяФорма.Вывести(УведомлениеОСпецрежимахНалогообложения.ПустойМакетИзСписка(Объект, СписокИспользуемыхМакетов, "Печать_Форма2021_1_Титульная"));
	НапечататьЛистТитульный_Форма2021_1(Объект, СтруктураПараметров.ДанныеУведомления.Форма2021_1_Титульная, Листы, ПечатнаяФорма, НомСтр, ИННКПП);
	
	ПечатнаяФорма = УведомлениеОСпецрежимахНалогообложения.НовыйПустойЛист();
	ПечатнаяФорма.Вывести(УведомлениеОСпецрежимахНалогообложения.ПустойМакетИзСписка(Объект, СписокИспользуемыхМакетов, "Печать_Форма2021_1_Лист2"));
	НапечататьЛист2_Форма2021_1(Объект, СтруктураПараметров.ДанныеУведомления.Форма2021_1_Лист2, Листы, ПечатнаяФорма, НомСтр, ИННКПП);
	
	ЛистыА = ДанныеМногостраничногоРазделаВТЗ(СтруктураПараметров.ДанныеМногостраничныхРазделов.Форма2021_1_ЛистА);
	ЛистыАСвернутые = ДанныеМногостраничногоРазделаВТЗ(СтруктураПараметров.ДанныеМногостраничныхРазделов.Форма2021_1_ЛистА)
		.Скопировать(, "КодРегион,КодНОУчет");
	ЛистыАСвернутые.Свернуть("КодРегион,КодНОУчет");
	ПечатнаяФорма = УведомлениеОСпецрежимахНалогообложения.НовыйПустойЛист();
	ПечатнаяФорма.Вывести(УведомлениеОСпецрежимахНалогообложения.ПустойМакетИзСписка(Объект, СписокИспользуемыхМакетов, "Печать_Форма2021_1_ЛистА"));
	ИННКПП.ПервыйЛист = Истина;
	Для Каждого Стр Из ЛистыАСвернутые Цикл 
		Если Не ЗначениеЗаполнено(Стр.КодРегион) Тогда 
			Продолжить;
		КонецЕсли;
		
		ОтборСтроки = ЛистыА.НайтиСтроки(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр));
		Индекс = 1;
		Для Каждого Данные Из ОтборСтроки Цикл
			НапечататьЛистА_Форма2021_1(Объект, ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Данные), Индекс, Листы, ПечатнаяФорма, НомСтр, ИННКПП, СписокИспользуемыхМакетов);
		КонецЦикла;
	КонецЦикла;
	
	ЛистыБ = ДанныеМногостраничногоРазделаВТЗ(СтруктураПараметров.ДанныеМногостраничныхРазделов.Форма2021_1_ЛистБ);
	ЛистыБСвернутые = ДанныеМногостраничногоРазделаВТЗ(СтруктураПараметров.ДанныеМногостраничныхРазделов.Форма2021_1_ЛистБ).Скопировать(, "КодРегион,КодНОУчет,КодТС");
	ЛистыБСвернутые.Свернуть("КодРегион,КодНОУчет,КодТС");
	ПечатнаяФорма = УведомлениеОСпецрежимахНалогообложения.НовыйПустойЛист();
	ПечатнаяФорма.Вывести(УведомлениеОСпецрежимахНалогообложения.ПустойМакетИзСписка(Объект, СписокИспользуемыхМакетов, "Печать_Форма2021_1_ЛистБ"));
	ИННКПП.ПервыйЛист = Истина;
	Для Каждого Стр Из ЛистыБСвернутые Цикл 
		Если Не ЗначениеЗаполнено(Стр.КодРегион) Или Не ЗначениеЗаполнено(Стр.КодТС) Тогда 
			Продолжить;
		КонецЕсли;
		
		ОтборСтроки = ЛистыБ.НайтиСтроки(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр));
		Индекс = 1;
		Для Каждого Данные Из ОтборСтроки Цикл
			НапечататьЛистБ_Форма2021_1(Объект, ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Данные), Индекс, Листы, ПечатнаяФорма, НомСтр, ИННКПП, СписокИспользуемыхМакетов);
		КонецЦикла;
		Если Индекс <> 1 Тогда
			Для Каждого Обл Из ПечатнаяФорма.Области Цикл 
				Если Обл.ТипОбласти = ТипОбластиЯчеекТабличногоДокумента.Прямоугольник
					И Не ЗначениеЗаполнено(Обл.Текст) Тогда 
					
					Обл.Текст = "-";
				КонецЕсли;
			КонецЦикла;
			УведомлениеОСпецрежимахНалогообложения.ПоложитьПФВСписокЛистов(Объект, Листы, ПечатнаяФорма, НомСтр, Ложь);
			НомСтр = НомСтр + 1;
			ПечатнаяФорма.Вывести(УведомлениеОСпецрежимахНалогообложения.ПустойМакетИзСписка(Объект, СписокИспользуемыхМакетов, "Печать_Форма2021_1_ЛистБ"));
		КонецЕсли;
	КонецЦикла;
	
	ЛистыВ = ДанныеМногостраничногоРазделаВТЗ(СтруктураПараметров.ДанныеМногостраничныхРазделов.Форма2021_1_ЛистВ);
	ПечатнаяФорма = УведомлениеОСпецрежимахНалогообложения.НовыйПустойЛист();
	ПечатнаяФорма.Вывести(УведомлениеОСпецрежимахНалогообложения.ПустойМакетИзСписка(Объект, СписокИспользуемыхМакетов, "Печать_Форма2021_1_ЛистВ"));
	ИННКПП.ПервыйЛист = Истина;
	Для Каждого Стр Из ЛистыВ Цикл
		Если Не ЗначениеЗаполнено(Стр.КодРегион) Тогда 
			Продолжить;
		КонецЕсли;
		НапечататьЛистВ_Форма2021_1(Объект, ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Стр), Листы, ПечатнаяФорма, НомСтр, ИННКПП, СписокИспользуемыхМакетов);
	КонецЦикла;
	
	Возврат Листы;
КонецФункции

