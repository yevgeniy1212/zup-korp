	СоответствиеПоказателей.Вставить("Аддр_МуниципРайонНаим", "МуниципальныйРайон");
	
	СоответствиеПоказателей.Вставить("Аддр_ГородСелПоселенВидКод", "ПоселениеВид");
	СоответствиеПоказателей.Вставить("Аддр_ГородСелПоселенНаим", "Поселение");
	
