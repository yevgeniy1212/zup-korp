	Возврат Листы;
КонецФункции

Функция НапечататьЛистА_Форма2021_1(Объект, Данные, Индекс, Листы, ПечатнаяФорма, НомСтр, ИННКПП, СписокИспользуемыхМакетов)
	Если ИННКПП.ПервыйЛист Тогда 
		ИННКПП.ПервыйЛист = Ложь;
	Иначе
		Данные["КодРегион"] = "";
		Данные["КодНОУчет"] = "";
	КонецЕсли;
	ПостФикс = "_" + Индекс;
	УведомлениеОСпецрежимахНалогообложения.ВывестиСтрокуНаПечать(ИННКПП.ИНН, "ИННШапка", ПечатнаяФорма.Области, "-");
