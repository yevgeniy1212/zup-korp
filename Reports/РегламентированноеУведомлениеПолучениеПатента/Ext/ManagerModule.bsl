	СоответствиеПоказателей.Вставить("Аддр_НаселенПунктНаим", "НаселенныйПункт");
	
	СоответствиеПоказателей.Вставить("Аддр_ЗемелУчасток", "ЗемелУчасток");
	
	СоответствиеПоказателей.Вставить("Аддр_ЭлПланСтруктурТип", "ТерриторияТип");
	СоответствиеПоказателей.Вставить("Аддр_ЭлПланСтруктурНаим", "Территория");
	
	СоответствиеПоказателей.Вставить("Аддр_ЭлУлДорСетиТип", "УлицаТип");
	СоответствиеПоказателей.Вставить("Аддр_ЭлУлДорСетиНаим", "Улица");
	
	СоответствиеПоказателей.Вставить("Аддр_ПомещЗданияТип", "ПомещениеВЗданииТип");
	СоответствиеПоказателей.Вставить("Аддр_ПомещЗданияНомер", "ПомещениеВЗданииНомер");
	
	СоответствиеПоказателей.Вставить("Аддр_ПомещКвартирыТип", "ПомещениеВКвартиреТип");
	СоответствиеПоказателей.Вставить("Аддр_ПомещКвартирыНомер", "ПомещениеВКвартиреНомер");
	
	Здания = Новый Массив;
	
	Для Инд = 1 По 3 Цикл
		Здания.Добавить(Новый Структура(СтрШаблон("Аддр_ЗданиеТип%1, Аддр_ЗданиеНомер%1", Инд), "ЗданиеТип", "ЗданиеНомер"));
	КонецЦикла;
	
	СоответствиеПоказателей.Вставить("Здания", Здания);
КонецПроцедуры

#КонецОбласти

#Область СозданиеЗаполненногоУведомления
Функция СформироватьНовоеУведомление_2021_1(Данные) Экспорт 
	
	Попытка
		
		Если Данные.Свойство("СсылкаНаДокумент")
			И ТипЗнч(Данные.СсылкаНаДокумент) = Тип("ДокументСсылка.УведомлениеОСпецрежимахНалогообложения") Тогда
			
			ДокОбъект = Данные.СсылкаНаДокумент.ПолучитьОбъект();
		Иначе
			ДокОбъект = Документы.УведомлениеОСпецрежимахНалогообложения.СоздатьДокумент();
		КонецЕсли;
		
		ДокОбъект.ВидУведомления = Перечисления.ВидыУведомленийОСпецрежимахНалогообложения.ЗаявлениеНаПолучениеПатентаРекомендованнаяФорма;
		Данные.Свойство("Организация", ДокОбъект.Организация);
		ДокОбъект.ИмяФормы = "Форма2021_1";
		ДокОбъект.ИмяОтчета = "РегламентированноеУведомлениеПолучениеПатента";
		ДокОбъект.ДатаПодписи = ТекущаяДатаСеанса();
		ДокОбъект.Дата = ТекущаяДатаСеанса();
		Данные.Свойство("ПодписантИмя",      ДокОбъект.ПодписантИмя);
		Данные.Свойство("ПодписантФамилия",  ДокОбъект.ПодписантФамилия);
		Данные.Свойство("ПодписантОтчество", ДокОбъект.ПодписантОтчество);
		Данные.Свойство("РегистрацияВИФНС",  ДокОбъект.РегистрацияВИФНС);
		
		СтруктураПараметров = Новый Структура;
		
		ДанныеУведомления = Новый Структура;
		ДанныеМногостраничныхРазделов = Новый Структура;
		ИдентификаторыОбычныхСтраниц = Новый Структура;
		
		СтруктураПараметров.Вставить("ДеревоСтраниц", СформироватьДеревоСтраницПоДанным_2021_1(Данные));
		ПараметрыИнициализацииФормы = Новый Структура;
		ПараметрыИнициализацииФормы.Вставить("ДанныеУведомления");
		ПараметрыИнициализацииФормы.Вставить("ДанныеМногостраничныхРазделов");
		ПараметрыИнициализацииФормы.Вставить("ДанныеДопСтрок");
		ПараметрыИнициализацииФормы.Вставить("ДанныеДопСтрокСтраницы");
		ПараметрыИнициализацииФормы.Вставить("ИдентификаторыОбычныхСтраниц");
		ПараметрыИнициализацииФормы.Вставить("ИмяФормы", "Отчет.РегламентированноеУведомлениеПолучениеПатента.Форма.Форма2021_1");
		ПараметрыИнициализацииФормы.Вставить("ИмяОтчета", "РегламентированноеУведомлениеПолучениеПатента");
		ПараметрыИнициализацииФормы.Вставить("ДеревоСтраниц", СтруктураПараметров.ДеревоСтраниц);
		ПараметрыИнициализацииФормы.Вставить("Объект", Новый Структура("ИмяОтчета, ИмяФормы", "РегламентированноеУведомлениеПолучениеПатента", "Форма2021_1"));
		ПараметрыИнициализацииФормы.Вставить("ИмяМакетаАрхиваТабличныхДокументов", "ЭкранныеФормы21");
		ПараметрыИнициализацииФормы.Вставить("АдресВХранилищеЭкранныеФормы");
		ПараметрыИнициализацииФормы.Вставить("УникальныйИдентификатор", Новый УникальныйИдентификатор);
		УведомлениеОСпецрежимахНалогообложения.СформироватьСтруктуруДанныхУведомленияНовогоОбразца(ПараметрыИнициализацииФормы);
		
		Пока ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["Форма2021_1_ЛистА"].Количество() < Данные.ЛистыА.Количество() Цикл 
			СтруктураСтраницы = ОбщегоНазначенияКлиентСервер.СкопироватьСтруктуру(ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["Форма2021_1_ЛистА"][0].Значение);
			ДобавитьДополнительныеПоляАдреса(СтруктураСтраницы);
			ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["Форма2021_1_ЛистА"].Добавить(СтруктураСтраницы);
		КонецЦикла;
		Для Инд = 0 По Данные.ЛистыА.Количество() - 1 Цикл 
			ЛистаА = Данные.ЛистыА[Инд];
			ДобавитьДополнительныеПоляАдреса(ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["Форма2021_1_ЛистА"][Инд].Значение);
			ЗаполнитьЗначенияСвойств(ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["Форма2021_1_ЛистА"][Инд].Значение, ЛистаА);
			ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["Форма2021_1_ЛистА"][Инд].Значение.УИД = СтруктураПараметров.ДеревоСтраниц.Строки[2].Строки[Инд].УИД;
		КонецЦикла;
		
		Пока ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["Форма2021_1_ЛистБ"].Количество() < Данные.ЛистыБ.Количество() Цикл 
			СтруктураСтраницы = ОбщегоНазначения.СкопироватьРекурсивно(ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["Форма2021_1_ЛистБ"][0].Значение);
			ДобавитьДополнительныеПоляАдреса(СтруктураСтраницы);
			ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["Форма2021_1_ЛистБ"].Добавить(СтруктураСтраницы);
		КонецЦикла;
		Для Инд = 0 По Данные.ЛистыБ.Количество() - 1 Цикл 
			ЛистаБ = Данные.ЛистыБ[Инд];
			ЗаполнитьЗначенияСвойств(ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["Форма2021_1_ЛистБ"][Инд].Значение, ЛистаБ);
			ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["Форма2021_1_ЛистБ"][Инд].Значение.УИД = СтруктураПараметров.ДеревоСтраниц.Строки[3].Строки[Инд].УИД;
		КонецЦикла;
		
		Пока ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["Форма2021_1_ЛистВ"].Количество() < Данные.ЛистыВ.Количество() Цикл 
			СтруктураСтраницы = ОбщегоНазначения.СкопироватьРекурсивно(ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["Форма2021_1_ЛистВ"][0].Значение);
			ДобавитьДополнительныеПоляАдреса(СтруктураСтраницы);
			ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["Форма2021_1_ЛистВ"].Добавить(СтруктураСтраницы);
		КонецЦикла;
		Для Инд = 0 По Данные.ЛистыВ.Количество() - 1 Цикл 
			ЛистаВ = Данные.ЛистыВ[Инд];
			ДобавитьДополнительныеПоляАдреса(ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["Форма2021_1_ЛистВ"][Инд].Значение);
			ЗаполнитьЗначенияСвойств(ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["Форма2021_1_ЛистВ"][Инд].Значение, ЛистаВ);
			ПараметрыИнициализацииФормы.ДанныеМногостраничныхРазделов["Форма2021_1_ЛистВ"][Инд].Значение.УИД = СтруктураПараметров.ДеревоСтраниц.Строки[4].Строки[Инд].УИД;
		КонецЦикла;
		
		ДобавитьДополнительныеПоляАдреса(ПараметрыИнициализацииФормы.ДанныеУведомления["Форма2021_1_Титульная"]);
		ЗаполнитьЗначенияСвойств(ПараметрыИнициализацииФормы.ДанныеУведомления["Форма2021_1_Титульная"], Данные.Стр01);
		ЗаполнитьЗначенияСвойств(ПараметрыИнициализацииФормы.ДанныеУведомления["Форма2021_1_Лист2"], Данные.Стр02);
		
