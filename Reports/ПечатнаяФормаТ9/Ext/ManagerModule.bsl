#Область СлужебныеПроцедурыИФункции

Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	ЗарплатаКадрыОтчеты.ВывестиВКоллекциюПечатнуюФорму("Отчет.ПечатнаяФормаТ9",
	// ЗУПК - постраничная печать списка сотрудников
		МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода, ВнешниеНаборыДанных(МассивОбъектов));
	// ЗУПК
	
КонецПроцедуры

Процедура Сформировать(ДокументРезультат, РезультатКомпоновки, ОбъектыПечати = Неопределено, ПараметрыПечати = Неопределено) Экспорт
	
	Если РезультатКомпоновки.ОтчетПустой Тогда
		Возврат;
	КонецЕсли;
	
	Если РезультатКомпоновки.КлючВарианта = "Т9" Тогда
		ВывестиНаПечатьТ9(ДокументРезультат, РезультатКомпоновки, ОбъектыПечати);
	ИначеЕсли РезультатКомпоновки.КлючВарианта = "Т10" Тогда
		ВывестиНаПечатьТ10(ДокументРезультат, РезультатКомпоновки, ОбъектыПечати);
	ИначеЕсли РезультатКомпоновки.КлючВарианта = "Т10а" Тогда
		ВывестиНаПечатьТ10а(ДокументРезультат, РезультатКомпоновки, ОбъектыПечати);
	// ЗУПК
	ИначеЕсли РезультатКомпоновки.КлючВарианта = "Т9_ПоПравиламВеденияДО" Тогда
		ВывестиНаПечатьТ9(ДокументРезультат, РезультатКомпоновки, ОбъектыПечати);
	// ЗУПК
	КонецЕсли;
	
КонецПроцедуры

// ЗУПК
Функция ВнешниеНаборыДанных(МассивОбъектов = Неопределено) Экспорт
	
	ВнешниеНаборы = Новый Структура;
	
	Запрос = Новый Запрос;
	
	Если МассивОбъектов = Неопределено Тогда
		Запрос.УстановитьПараметр("МассивОбъектов", Новый Массив);
	Иначе
		Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	КонецЕсли;
	
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Командировка.Ссылка КАК СсылкаНаОбъект,
		|	Командировка.Сотрудник КАК Сотрудник,
		|	Командировка.Дата КАК ДатаГруппы,
		|	Командировка.Номер КАК НомерГруппы,
		|	Командировка.ДатаПервичногоДокумента КАК ДатаПервичногоДокументаГруппы,
		|	Командировка.НомерПервичногоДокумента КАК НомерПервичногоДокументаГруппы,
		|	Командировка.ДатаНачала КАК ДатаНачалаГруппы,
		|	Командировка.ДатаОкончания КАК ДатаОкончанияГруппы,
		|	Командировка.МестоНазначения КАК МестоНазначенияГруппы,
		|	Командировка.ОрганизацияНазначения КАК ОрганизацияНазначенияГруппы,
		|	Командировка.Цель КАК ЦельГруппы,
		|	Командировка.КомандировкаЗаСчетСредств КАК КомандировкаЗаСчетСредствГруппы,
		|	Командировка.ДнейВПути КАК ДнейВПутиГруппа,
		|	РАЗНОСТЬДАТ(Командировка.ДатаНачала, Командировка.ДатаОкончания, ДЕНЬ) + 1 КАК ДнейВКомандировке
		|ИЗ
		|	Документ.Командировка КАК Командировка
		|ГДЕ
		|	Командировка.Ссылка В(&МассивОбъектов)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Командировки.Ссылка,
		|	КомандировкиСотрудников.Сотрудник,
		|	КомандировкаСотрудника.Дата,
		|	КомандировкаСотрудника.Номер,
		|	КомандировкаСотрудника.ДатаПервичногоДокумента,
		|	КомандировкаСотрудника.НомерПервичногоДокумента,
		|	КомандировкиСотрудников.ДатаНачала,
		|	КомандировкиСотрудников.ДатаОкончания,
		|	КомандировкиСотрудников.МестоНазначения,
		|	КомандировкиСотрудников.ОрганизацияНазначения,
		|	КомандировкиСотрудников.Цель,
		|	КомандировкиСотрудников.КомандировкаЗаСчетСредств,
		|	КомандировкиСотрудников.ДнейВПути,
		|	РАЗНОСТЬДАТ(КомандировкиСотрудников.ДатаНачала, КомандировкиСотрудников.ДатаОкончания, ДЕНЬ) + 1
		|ИЗ
		|	Документ.КомандировкиСотрудников КАК Командировки
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.КомандировкиСотрудников.Сотрудники КАК КомандировкиСотрудников
		|		ПО Командировки.Ссылка = КомандировкиСотрудников.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Командировка КАК КомандировкаСотрудника
		|		ПО (КомандировкиСотрудников.Командировка = КомандировкаСотрудника.Ссылка)
		|ГДЕ
		|	Командировки.Ссылка В(&МассивОбъектов)";
	
	ВнешниеНаборы.Вставить("КомандировкиСотрудников", Запрос.Выполнить().Выгрузить());
	
	Возврат ВнешниеНаборы;
	
КонецФункции
// ЗУПК

Процедура ВывестиНаПечатьТ9(ДокументРезультат, РезультатКомпоновки, ОбъектыПечати)
	
	ДокументРезультат.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_Командировка_Т9";
	ДокументРезультат.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ДокументРезультат.АвтоМасштаб = Истина;
	
	Для Каждого ДанныеНаПечать Из РезультатКомпоновки.ДанныеОтчета.Строки Цикл
		
		Если ДокументРезультат.ВысотаТаблицы > 0 Тогда
			ДокументРезультат.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПерваяСтрокаПечатнойФормы = ДокументРезультат.ВысотаТаблицы + 1;
		
		// ЗУПК
		ФормированиеПечатныхФормПоПравиламВеденияДО.ЗаполнениеРеквизитовШапки(РезультатКомпоновки.МакетПечатнойФормы, ДанныеНаПечать, "СсылкаНаОбъектДата", "РаботаОрганизация", "РаботаОрганизацияНаименованиеПолное");
		// ЗУПК
		
		Для Каждого ДанныеДетальныхЗаписей Из ДанныеНаПечать.Строки Цикл
			
			// ЗУПК
			Если ДокументРезультат.ВысотаТаблицы > 0 Тогда
				ДокументРезультат.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;
			// ЗУПК
			
			ДанныеПользовательскихПолей = ЗарплатаКадрыОтчеты.ЗначенияЗаполненияПользовательскихПолей(РезультатКомпоновки.ИдентификаторыМакета, ДанныеДетальныхЗаписей);
			
			ЗарплатаКадрыОтчеты.ВывестиВДокументРезультатОбластиМакета(
				ДокументРезультат,
				РезультатКомпоновки.МакетПечатнойФормы,
				"Приказ",
				ДанныеНаПечать,
				ДанныеДетальныхЗаписей,
				ДанныеПользовательскихПолей);
			
		КонецЦикла;
		
		Если ОбъектыПечати <> Неопределено Тогда
			УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ДокументРезультат, ПерваяСтрокаПечатнойФормы, ОбъектыПечати, ДанныеНаПечать.СсылкаНаОбъект);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

