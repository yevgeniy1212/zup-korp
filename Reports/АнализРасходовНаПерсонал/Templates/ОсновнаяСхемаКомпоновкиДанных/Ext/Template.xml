	НАЧАЛОПЕРИОДА(ДанныеПроизводственногоКалендаря.Дата, МЕСЯЦ) КАК Месяц,
	НАЧАЛОПЕРИОДА(ДанныеПроизводственногоКалендаря.Дата, КВАРТАЛ) КАК Квартал,
	НАЧАЛОПЕРИОДА(ДанныеПроизводственногоКалендаря.Дата, ГОД) КАК Год
ПОМЕСТИТЬ Календарь
ИЗ
	РегистрСведений.ДанныеПроизводственногоКалендаря КАК ДанныеПроизводственногоКалендаря
ГДЕ
	ДанныеПроизводственногоКалендаря.Дата МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ОтражениеВФинансовомУчете.Подразделение,
	ОтражениеВФинансовомУчете.СтатьяРасходов,
	ОтражениеВФинансовомУчете.КатегорияРасходов,
	ОтражениеВФинансовомУчете.АналитикаРасходов,
	ОтражениеВФинансовомУчете.НаправлениеДеятельности,
	ЗНАЧЕНИЕ(Справочник.Сценарии.ПустаяСсылка) КАК Сценарий,
	ОтражениеВФинансовомУчете.Сумма КАК СуммаРасходов,
	Календарь.Месяц,
	Календарь.Квартал,
	Календарь.Год
ПОМЕСТИТЬ ДанныеФакт
ИЗ
	Календарь КАК Календарь
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ОтражениеРасходовНаПерсонал КАК ОтражениеВФинансовомУчете
		ПО Календарь.Дата = ОтражениеВФинансовомУчете.Период
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ПланируемыеРасходыНаПерсонал.Подразделение,
	ПланируемыеРасходыНаПерсонал.СтатьяРасходов,
	ПланируемыеРасходыНаПерсонал.КатегорияРасходов,
	ПланируемыеРасходыНаПерсонал.АналитикаРасходов,
	ПланируемыеРасходыНаПерсонал.НаправлениеДеятельности,
	ПланируемыеРасходыНаПерсонал.Сценарий КАК Сценарий,
	ПланируемыеРасходыНаПерсонал.СуммаРасходов КАК СуммаРасходов,
	Календарь.Месяц,
	Календарь.Квартал,
	Календарь.Год
ПОМЕСТИТЬ ДанныеПлан
ИЗ
	Календарь КАК Календарь
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ПланируемыеРасходыНаПерсонал КАК ПланируемыеРасходыНаПерсонал
		ПО Календарь.Дата = ПланируемыеРасходыНаПерсонал.Период
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ДанныеПлан.Подразделение КАК Подразделение,
	ДанныеПлан.СтатьяРасходов КАК СтатьяРасходов,
	ДанныеПлан.КатегорияРасходов КАК КатегорияРасходов,
	ДанныеПлан.АналитикаРасходов КАК АналитикаРасходов,
	ДанныеПлан.НаправлениеДеятельности КАК НаправлениеДеятельности,
	ДанныеПлан.Сценарий КАК Сценарий,
	ДанныеПлан.СуммаРасходов КАК СуммаРасходов,
	ДанныеПлан.Месяц КАК Месяц,
	ДанныеПлан.Квартал КАК Квартал,
	ДанныеПлан.Год КАК Год,
	ДанныеПлан.СуммаРасходов - ЕСТЬNULL(ДанныеФакт.СуммаРасходов, 0) КАК Отклонение
ИЗ
	ДанныеПлан КАК ДанныеПлан
		ЛЕВОЕ СОЕДИНЕНИЕ ДанныеФакт КАК ДанныеФакт
		ПО ДанныеПлан.Подразделение = ДанныеФакт.Подразделение
		И ДанныеПлан.СтатьяРасходов = ДанныеФакт.СтатьяРасходов
		И ДанныеПлан.КатегорияРасходов = ДанныеФакт.КатегорияРасходов
		И ДанныеПлан.АналитикаРасходов = ДанныеФакт.АналитикаРасходов
		И ДанныеПлан.НаправлениеДеятельности = ДанныеФакт.НаправлениеДеятельности
		И ДанныеПлан.Месяц = ДанныеФакт.Месяц
		И ДанныеПлан.Квартал = ДанныеФакт.Квартал
		И ДанныеПлан.Год = ДанныеФакт.Год

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	ДанныеФакт.Подразделение,
	ДанныеФакт.СтатьяРасходов,
	ДанныеФакт.КатегорияРасходов,
	ДанныеФакт.АналитикаРасходов,
	ДанныеФакт.НаправлениеДеятельности,
	ДанныеФакт.Сценарий,
	ДанныеФакт.СуммаРасходов,
	ДанныеФакт.Месяц,
	ДанныеФакт.Квартал,
	ДанныеФакт.Год,
	0
ИЗ
	ДанныеФакт КАК ДанныеФакт
{ГДЕ
	ДанныеФакт.Подразделение.*,
	ДанныеФакт.СтатьяРасходов.*,
	ДанныеФакт.АналитикаРасходов.*,
	ДанныеФакт.НаправлениеДеятельности.*,
	ДанныеФакт.Сценарий.*,
	ДанныеФакт.СуммаРасходов,
	ДанныеФакт.Месяц,
	ДанныеФакт.Квартал,
	ДанныеФакт.Год,
	(0) КАК Отклонение}</query>
	</dataSet>
	<calculatedField>
		<dataPath>Процент</dataPath>
		<expression>Отклонение / СуммаРасходов</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>%</v8:content>
			</v8:item>
		</title>
		<appearance>
			<dcscor:item xsi:type="dcsset:SettingsParameterValue">
				<dcscor:parameter>Формат</dcscor:parameter>
				<dcscor:value xsi:type="xs:string">ЧДЦ=2</dcscor:value>
			</dcscor:item>
		</appearance>
	</calculatedField>
	<totalField>
		<dataPath>Процент</dataPath>
		<expression>Сумма(Отклонение)/Сумма(СуммаРасходов) * 100</expression>
	</totalField>
	<totalField>
		<dataPath>СуммаРасходов</dataPath>
		<expression>Сумма(СуммаРасходов)</expression>
	</totalField>
	<totalField>
		<dataPath>Отклонение</dataPath>
		<expression>Сумма(Отклонение)</expression>
	</totalField>
