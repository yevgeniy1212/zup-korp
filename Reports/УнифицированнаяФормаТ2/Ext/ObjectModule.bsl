			ПерваяСтраницаТ2.Параметры.ГодОкончанияУчилища	 	= ?(ПерваяСтраницаТ2.Параметры.ГодОкончанияУчилища <> "", ПерваяСтраницаТ2.Параметры.ГодОкончанияУчилища + "; ", "") + ДанныеОбразование.ОкончаниеУчилище;
