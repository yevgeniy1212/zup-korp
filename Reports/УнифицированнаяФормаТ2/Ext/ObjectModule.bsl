			ПерваяСтраницаТ2.Параметры.ДатаДиплома 			 	= ?(ПерваяСтраницаТ2.Параметры.ДатаДиплома <> "", ПерваяСтраницаТ2.Параметры.ДатаДиплома + "; ", "") + ?(ЗначениеЗаполнено(ДанныеОбразование.ДатаВыдачи),"«"+ Строка(Формат(ДанныеОбразование.ДатаВыдачи, "ДФ=дд"))
																			+"» " + МесяцДиплома + " «"+Формат(ДанныеОбразование.ДатаВыдачи, "ДФ=гггг")+НСтр("ru = '» года'"), НСтр("ru = '«____» ____________ «________» года'"));
																			
			Если ДанныеОбразование.ФормаОбучения = Перечисления.ФормыОбученияФизическихЛиц.ОчноеОбучение Тогда
				ОчноеОбучение = Истина;
			ИначеЕсли ДанныеОбразование.ФормаОбучения = Перечисления.ФормыОбученияФизическихЛиц.ЗаочноеОбучение 
