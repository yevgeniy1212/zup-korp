			Специальности										= ?(Специальности <> "", Специальности + "; ", "") + ДанныеОбразование.Специальность;
			ПерваяСтраницаТ2.Параметры.НомерДиплома 			= ?(ПерваяСтраницаТ2.Параметры.НомерДиплома <> "", ПерваяСтраницаТ2.Параметры.НомерДиплома + "; ", "") + ДанныеОбразование.Номер;
