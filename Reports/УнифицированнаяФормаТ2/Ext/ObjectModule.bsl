		КонецЕсли;
		
		//Последнее место работы
		
		ПерваяСтраницаТ2.Параметры.ПоследнееМестоРаботы = ?(ЗначениеЗаполнено(СтрокаДанных.ЛичныеДанныеПоследнееМестоРаботыОрганизация), СтрокаДанных.ЛичныеДанныеПоследнееМестоРаботыОрганизация+", "+ СтрокаДанных.ЛичныеДанныеПоследнееМестоРаботыДолжность, ""); 
		
		// Состав семьи
		ДанныеЗаполнения = ДополнительныеСведения.Получить("ДанныеЗаполненияСоставСемьи");
