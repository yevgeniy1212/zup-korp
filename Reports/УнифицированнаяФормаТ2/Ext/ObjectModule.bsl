			ПерваяСтраницаТ2.Параметры.Образование 			 	= ?(ПерваяСтраницаТ2.Параметры.Образование <> "", ПерваяСтраницаТ2.Параметры.Образование + "; ", "") + ДанныеОбразование.Образование;
