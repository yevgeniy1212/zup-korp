					ПерваяСтраницаТ2.Параметры["ЧленСемьи"+НомерСтроки] = Строка(ТекСтрока.СтепеньРодства) +" "+ТекСтрока.ФИОРодственника+","+ТекСтрока.ГодРожденияРодственника;
