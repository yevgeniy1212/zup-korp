////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ДАТАВРЕМЯ(1, 1, 1) КАК Период,
	ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка) КАК Сотрудник,
	ЗНАЧЕНИЕ(Справочник.ФизическиеЛица.ПустаяСсылка) КАК ФизическоеЛицо,
	"" КАК Возраст,
	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаПриема,
	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаУвольнения,
	ЗНАЧЕНИЕ(Справочник.Должности.ПустаяСсылка) КАК Должность,
	ЗНАЧЕНИЕ(Справочник.РабочиеМестаОхраныТруда.ПустаяСсылка) КАК РабочееМестоОхраныТруда,
	ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка) КАК ГоловнаяОрганизация,
	ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка) КАК Организация,
	ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка) КАК Подразделение,
	ЗНАЧЕНИЕ(Перечисление.ВидыЗанятости.ПустаяСсылка) КАК ВидЗанятости
ПОМЕСТИТЬ Представления_СотрудникиОрганизации
ИЗ
	ВТФизическиеЛица КАК ФизическиеЛица
ГДЕ
	"ТолькоРазрешенные" = ИСТИНА
	И "ОтбиратьПоГоловнойОрганизации" = ЛОЖЬ
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	ВредныеПозиции.ВидОсмотра КАК ВидОсмотра,
	ПериодическиеОсмотры.РабочееМесто КАК РабочееМесто,
	ПериодическиеОсмотры.ГоловнаяОрганизация КАК ГоловнаяОрганизация,
	ПериодическиеОсмотры.ФизическоеЛицо КАК ФизическоеЛицо,
	ПериодическиеОсмотры.ДатаСледующегоОсмотра КАК ДатаСледующегоОсмотра,
	ПериодическиеОсмотры.РезультатОсмотра КАК РезультатОсмотра,
	ПериодическиеОсмотры.ДатаПройденногоОсмотра КАК ДатаПройденногоОсмотра,
	ПериодическиеОсмотры.Направление КАК Направление,
	ПериодическиеОсмотры.Заключение КАК Заключение,
	ВредныеПозиции.ПредставлениеПериодичностиОсмотра КАК ПредставлениеПериодичностиОсмотра,
	ВредныеПозиции.ВредныеФакторыПолноеПредставление КАК ВредныеФакторыПолноеПредставление,
	ВредныеПозиции.ВидыРаботПолноеПредставление КАК ВидыРаботПолноеПредставление,
	ВредныеПозиции.ВредныеФакторыКодыПредставление КАК ВредныеФакторыКодыПредставление,
	ВредныеПозиции.ВидыРаботКодыПредставление КАК ВидыРаботКодыПредставление
ПОМЕСТИТЬ ВТВредныеРабочиеМеста
ИЗ
	РегистрСведений.ПериодичностьМедицинскихОсмотровРабочихМест КАК ВредныеПозиции
		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПериодическиеМедицинскиеОсмотры КАК ПериодическиеОсмотры
		ПО ВредныеПозиции.РабочееМесто = ПериодическиеОсмотры.РабочееМесто
			И ВредныеПозиции.ВидОсмотра = ПериодическиеОсмотры.ВидОсмотра}
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ РАЗРЕШЕННЫЕ
	Представления_СотрудникиОрганизации.Период КАК Период,
	Представления_СотрудникиОрганизации.Сотрудник КАК Сотрудник,
	Представления_СотрудникиОрганизации.ФизическоеЛицо КАК ФизическоеЛицо,
	Представления_СотрудникиОрганизации.Возраст КАК Возраст,
	Представления_СотрудникиОрганизации.РабочееМестоОхраныТруда КАК РабочееМесто,
	Представления_СотрудникиОрганизации.Организация КАК Организация,
	Представления_СотрудникиОрганизации.Подразделение КАК Подразделение,
	Представления_СотрудникиОрганизации.Должность КАК Должность,
	Представления_СотрудникиОрганизации.ДатаУвольнения КАК ДатаУвольнения,
	Представления_СотрудникиОрганизации.ВидЗанятости КАК ВидЗанятости,
	ВредныеРабочиеМеста.ВидОсмотра КАК ВидОсмотра,
	ВредныеРабочиеМеста.ДатаСледующегоОсмотра КАК ДатаСледующегоОсмотра,
	ВЫБОР
		КОГДА ВредныеРабочиеМеста.ДатаСледующегоОсмотра МЕЖДУ &amp;ДатаНачала И &amp;ДатаОкончания
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК СледующийОсмотрВВыбранномПериоде,
	ВредныеРабочиеМеста.РезультатОсмотра КАК РезультатОсмотра,
	ВредныеРабочиеМеста.ДатаПройденногоОсмотра КАК ДатаПройденногоОсмотра,
	ВредныеРабочиеМеста.Направление КАК Направление,
	ВредныеРабочиеМеста.Заключение КАК Заключение,
	ВредныеРабочиеМеста.ПредставлениеПериодичностиОсмотра КАК ПредставлениеПериодичностиОсмотра,
	ВЫБОР
		КОГДА Представления_СотрудникиОрганизации.Сотрудник ЕСТЬ НЕ NULL 
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК СотрудникВыбран,
	ВредныеРабочиеМеста.ВредныеФакторыПолноеПредставление КАК ВредныеФакторыПолноеПредставление,
	ВредныеРабочиеМеста.ВидыРаботПолноеПредставление КАК ВидыРаботПолноеПредставление,
	ВредныеРабочиеМеста.ВредныеФакторыКодыПредставление КАК ВредныеФакторыКодыПредставление,
	ВредныеРабочиеМеста.ВидыРаботКодыПредставление КАК ВидыРаботКодыПредставление
ИЗ
	ВТВредныеРабочиеМеста КАК ВредныеРабочиеМеста
		{ЛЕВОЕ СОЕДИНЕНИЕ Представления_СотрудникиОрганизации КАК Представления_СотрудникиОрганизации
		ПО ВредныеРабочиеМеста.РабочееМесто = Представления_СотрудникиОрганизации.РабочееМестоОхраныТруда
			И ВредныеРабочиеМеста.ФизическоеЛицо = Представления_СотрудникиОрганизации.ФизическоеЛицо
			И ВредныеРабочиеМеста.ГоловнаяОрганизация = Представления_СотрудникиОрганизации.ГоловнаяОрганизация}</query>
	</dataSet>
