КонецФункции

&НаСервере
Функция СформироватьИмяФайла()
	
	Перем ПолученноеЗначение;
	
	ИмяФайлаXML = "Форма200_"+ Прав(Этаформа.ИмяФормы,7)+ "_" + СтрЗаменить(СтрЗаменить(Строка(ТекущаяДата())," ","_"),":","-") + ".xml";
	
	Возврат ИмяФайлаXML;
	
КонецФункции

&НаКлиенте
Функция СформироватьМногострочнуюСтруктуруДляВыгрузки (ТекущееИмяФормы) Экспорт
	
	Возврат СформироватьМногострочнуюСтруктуруДляВыгрузкиНаСервере(ТекущееИмяФормы);	
	
КонецФункции

&НаСервере
Функция СформироватьМногострочнуюСтруктуруДляВыгрузкиНаСервере(ТекущееИмяФормы) Экспорт
	
	Перем ТаблицаСтраницРаздела;
	
	Если ТекущееИмяФормы = Неопределено тогда
		ТекущееИмяФормы = "Форма200_02";
	КонецЕсли;	
	
	Если ЭтаФорма["ТаблицаСтраницы"+ТекущееИмяФормы] = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	мСтруктураФорма200_02Страница1и2.Свойство("Форма200_02", ТаблицаСтраницРаздела);
	ТаблицаСтраницРаздела = ЭтаФорма[ТаблицаСтраницРаздела];
	
	КоличествоСтраниц = 0;
	Для каждого ЭлементДерева из мСписокФормБезИерархии.ПолучитьЭлементы() Цикл
		
		Если ЭлементДерева.КодФормы = ТекущееИмяФормы Тогда
			КоличествоСтраниц = ЭлементДерева.КоличествоСтраницПриложения;
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	МногострочнаяСтруктура = Новый Структура;
	
	Для Ном = 1 По КоличествоСтраниц Цикл
		
		ДанныеСтраницы = Новый Структура;
		
		ДанныеСтраницы.Вставить("ШапкаИПодвал", Новый ТаблицаЗначений);
		
		ТаблицаЗначений = Новый ТаблицаЗначений;
		
		Для каждого СтрокаСписка из ТаблицаСтраницРаздела.Выгрузить(,("Страница"+Ном)) Цикл
			
			НоваяСтрокаТЗ = ТаблицаЗначений.Добавить();
			
			СтруктураСтраницы = СтрокаСписка["Страница"+Ном][0].Значение;
			
			Для Каждого ЭлементСтрутуры из СтруктураСтраницы Цикл
				
				Если ТаблицаЗначений.Колонки.Найти(ЭлементСтрутуры.Ключ) = Неопределено Тогда
					ТипКолонки = Новый Массив;
					ТипКолонки.Добавить(ТипЗнч(ЭлементСтрутуры.Значение));
					ТаблицаЗначений.Колонки.Добавить(ЭлементСтрутуры.Ключ, Новый ОписаниеТипов(ТипКолонки));
				КонецЕсли;
				
				НоваяСтрокаТЗ[ЭлементСтрутуры.Ключ] = ЭлементСтрутуры.Значение;
				
			КонецЦикла;
			
		КонецЦикла;
		
		ДанныеСтраницы.Вставить("Строки",      ТаблицаЗначений);
		
		МногострочнаяСтруктура.Вставить("Страница"+Ном, ДанныеСтраницы);
		
	КонецЦикла;
		
	Возврат МногострочнаяСтруктура;

КонецФункции

&НаСервере
Процедура СформироватьСписокФормБезИерархии()
	
	мСписокФормБезИерархии.ПолучитьЭлементы().Очистить();
	
	МакетПоказателей = Отчеты[Сред(Лев(ЭтотОбъект.ИмяФормы, СтрНайти(ЭтотОбъект.ИмяФормы, ".Форма.") - 1), 7)].ПолучитьМакет("Показатели");
	Префикс = Прав(ЭтаФорма.СтруктураРеквизитовФормы.мВыбраннаяФорма,7);
	
	ОбластьПоказателей = МакетПоказателей.Область("Форма200_" + Префикс);
	
	Для Ном = ОбластьПоказателей.Верх По ОбластьПоказателей.Низ Цикл
		
		НоваяСтрока = мСписокФормБезИерархии.ПолучитьЭлементы().Добавить();
		НоваяСтрока.ИмяФормы			= СокрП(МакетПоказателей.Область(Ном, 1).Текст);
		НоваяСтрока.Выгружать			= ?(СокрП(МакетПоказателей.Область(Ном, 2).Текст)= "1",Истина,Ложь);
		НоваяСтрока.Многострочность		= ?(СокрП(МакетПоказателей.Область(Ном, 3).Текст)= "1",Истина,Ложь);
		НоваяСтрока.КодФормы			= СокрП(МакетПоказателей.Область(Ном, 4).Текст);
		НоваяСтрока.КоличествоНаЛисте	= Число(СокрП(МакетПоказателей.Область(Ном, 5).Текст));
		НоваяСтрока.КоличествоСтраницПриложения = Число(СокрП(МакетПоказателей.Область(Ном, 6).Текст));
		
		Если НоваяСтрока.Многострочность <> Истина Тогда
			Для КолСтр = 1 По НоваяСтрока.КоличествоСтраницПриложения  Цикл
				Для Каждого Элемент Из ЭтаФорма["СтруктураДанных"+ НоваяСтрока.КодФормы + "Страница" + КолСтр] Цикл
					НовыйЭлемент = НоваяСтрока.Значение.Добавить();
					НовыйЭлемент.ИмяОбласти = Элемент.Ключ;
					НовыйЭлемент.Значение = Элемент.Значение;
				КонецЦикла;
			КонецЦикла;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

