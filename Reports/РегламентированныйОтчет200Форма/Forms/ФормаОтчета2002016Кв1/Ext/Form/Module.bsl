			КонецЕсли;
			
			Если Форма.СтруктураРеквизитовФормы.НаимТекущегоРаздела = "Форма200_02Страница2" Тогда
				ОкрП000220005301 = РегламентированнаяОтчетностьКлиентСервер.ОкруглитьЧислоПоФормату(Форма, Форма.ТабличныйДокумент.Области.П000220005301.Значение);
			ИначеЕсли СтрТаблицаСтраницы[0].Страница2[0].Значение.Свойство("П000220005301") Тогда
				ОкрП000220005301 = РегламентированнаяОтчетностьКлиентСервер.ОкруглитьЧислоПоФормату(Форма, СтрТаблицаСтраницы[0].Страница2[0].Значение.П000220005301);
			КонецЕсли;
			
			П000220005401 = ОкрП000220005101 + ОкрП000220005201 + ОкрП000220005301;
			
			СтрТаблицаСтраницы[0].Страница2[0].Значение.Вставить("П000220005401",П000220005401);
			
			Если Форма.СтруктураРеквизитовФормы.НаимТекущегоРаздела = "Форма200_02Страница2" Тогда
				Форма.ТабличныйДокумент.Области.П000220005401.Значение = П000220005401;
			КонецЕсли;
			
		КонецЕсли;
		
	//Авторасчет
	ИначеЕсли ИмяСтраницыПанели = "" Тогда
		
		Расчет(Форма,"Форма200Страница1", "");
		Расчет(Форма,"Форма200Страница2", "");
		Расчет(Форма,"Форма200Страница3", "");
		Расчет(Форма,"Форма200_01Страница1", "");
		Расчет(Форма,"Форма200_01Страница2", "");
		Форма.мСтруктураФорма200_02Страница1и2.Свойство("Форма200_02", ТаблицаСтраницРаздела);
		ТаблицаСтраницРаздела = Форма[ТаблицаСтраницРаздела];
		Для Каждого СтрокаТЗ из ТаблицаСтраницРаздела Цикл
			СтрокаТЗ.АктивнаяСтраница = Истина;
			Расчет(Форма,"Форма200_02Страница1", "");
			Расчет(Форма,"Форма200_02Страница2", "");
			СтрокаТЗ.АктивнаяСтраница = Ложь;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

