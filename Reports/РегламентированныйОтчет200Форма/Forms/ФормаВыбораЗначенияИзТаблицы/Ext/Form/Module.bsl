
#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура Выбрать(Команда)
	
	// ЗУПК
	Если Элементы.ТаблицаЗначенийОтметкаЗаполнения.Видимость Тогда
		
		Если Элементы.ТаблицаЗначенийСумма.Видимость Тогда
		
			ВозвращаемоеЗначение = ТаблицаЗначений;
			
		Иначе
			
			ВозвращаемоеЗначение = Новый СписокЗначений;
			
			Для Каждого СтрокаТаблицаЗначений Из ТаблицаЗначений Цикл
				
				Если СтрокаТаблицаЗначений.ОтметкаЗаполнения Тогда
					ВозвращаемоеЗначение.Добавить(СтрокаТаблицаЗначений.Код, СтрокаТаблицаЗначений.Код);
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
	Иначе
		
	// ЗУПК
	Если Элементы.ТаблицаЗначений.ТекущиеДанные = Неопределено Тогда
		
		Возврат;
		
	КонецЕсли;
	
	ВозвращаемоеЗначение = Новый Структура;
	ВозвращаемоеЗначение.Вставить("Код",               ?(ИспользуетсяПроизвольноеЗначение, ПроизвольноеЗначение, Элементы.ТаблицаЗначений.ТекущиеДанные.Код));
	ВозвращаемоеЗначение.Вставить("Название",          Элементы.ТаблицаЗначений.ТекущиеДанные.Название);
	ВозвращаемоеЗначение.Вставить("БазоваяДоходность", Элементы.ТаблицаЗначений.ТекущиеДанные.БазоваяДоходность);
	ВозвращаемоеЗначение.Вставить("Кратко",            Элементы.ТаблицаЗначений.ТекущиеДанные.Кратко);
	
	КонецЕсли;
	
	Закрыть(ВозвращаемоеЗначение);

КонецПроцедуры

&НаКлиенте
Процедура ТаблицаЗначенийВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	// ЗУПК
	Если Элементы.ТаблицаЗначенийОтметкаЗаполнения.Видимость Тогда
		
		Если НЕ Поле.Имя = "ТаблицаЗначенийСумма" Тогда
			Элементы.ТаблицаЗначений.ТекущиеДанные.ОтметкаЗаполнения = НЕ Элементы.ТаблицаЗначений.ТекущиеДанные.ОтметкаЗаполнения;
		КонецЕсли;
		
	Иначе
		
		ВозвращаемоеЗначение = Новый Структура;
		ВозвращаемоеЗначение.Вставить("Код",               Элементы.ТаблицаЗначений.ТекущиеДанные.Код);
		ВозвращаемоеЗначение.Вставить("Название",          Элементы.ТаблицаЗначений.ТекущиеДанные.Название);
		ВозвращаемоеЗначение.Вставить("БазоваяДоходность", Элементы.ТаблицаЗначений.ТекущиеДанные.БазоваяДоходность);
		ВозвращаемоеЗначение.Вставить("Кратко",            Элементы.ТаблицаЗначений.ТекущиеДанные.Кратко);
		
		Закрыть(ВозвращаемоеЗначение);
		
	КонецЕсли;
	// ЗУПК
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Пропускаем инициализацию, чтобы гарантировать получение формы при передаче параметра "АвтоТест".
	Если Параметры.Свойство("АвтоТест") Тогда
		Возврат;
	КонецЕсли;
	
	Заголовок = Параметры.Заголовок;
		
	Если Параметры.ПараметрыДляЗаполненияТаблицыЗначений <> Неопределено Тогда
		
		ПараметрыДляЗаполненияТаблицыЗначений = Параметры.ПараметрыДляЗаполненияТаблицыЗначений;
		
		Если ПараметрыДляЗаполненияТаблицыЗначений.ЗаполнятьТаблицуЗначенийИзМакета Тогда
		
			ЗначениеДляДобавленияСтрокиВТаблицу = ПараметрыДляЗаполненияТаблицыЗначений.ЗначениеДляДобавленияСтрокиВТаблицу;
			ИмяМакета = ПараметрыДляЗаполненияТаблицыЗначений.ИмяМакета;
			ИмяОтчета = ПараметрыДляЗаполненияТаблицыЗначений.ИмяОтчета;
			
			Если ИмяОтчета = "РегламентированныйОтчетЕдиныйНалогНаВмененныйДоход" Тогда
				
				Если ПараметрыДляЗаполненияТаблицыЗначений.ДатаКонцаПериодаОтчета >= '2014-01-01' Тогда	
					ИмяСекцииВидаУслуг = "ВидыУслуг2014";
				ИначеЕсли ПараметрыДляЗаполненияТаблицыЗначений.ДатаКонцаПериодаОтчета >= '2013-01-01' Тогда	
					ИмяСекцииВидаУслуг = "ВидыУслуг2013";
				Иначе
					ИмяСекцииВидаУслуг = "ВидыУслуг";
				КонецЕсли;
				
			КонецЕсли;
			
			МакетСоставаПоказателей = Отчеты[ИмяОтчета].ПолучитьМакет(ИмяМакета).ПолучитьОбласть(ИмяСекцииВидаУслуг);
						
			Для Каждого Область Из МакетСоставаПоказателей.Области Цикл
				Если Область.ТипОбласти = ТипОбластиЯчеекТабличногоДокумента.Строки Тогда
					ВерхОбласти = Область.Верх;
					НизОбласти = Область.Низ;
					Для НомСтр = ВерхОбласти По НизОбласти Цикл
						КодПоказателя = СокрП(МакетСоставаПоказателей.Область(НомСтр, 1).Текст);
						Если КодПоказателя <> "###" Тогда
							Если (МакетСоставаПоказателей.Область(НомСтр, 3).Текст) = ЗначениеДляДобавленияСтрокиВТаблицу Тогда
								Показатель = ТаблицаЗначений.Добавить();
								Показатель.Код = КодПоказателя;
								Показатель.Название = СокрП(МакетСоставаПоказателей.Область(НомСтр, 2).Текст);
							КонецЕсли;
						КонецЕсли;
					КонецЦикла;
				КонецЕсли;
			КонецЦикла;
			
		КонецЕсли;
		
	Иначе
		
		КопироватьДанныеФормы(Параметры.ТаблицаЗначений, ТаблицаЗначений);
		
	КонецЕсли;
	
	ВыборИзСпискаЗначений = Ложь;
	ВыборИзТаблицыЗначений = Ложь;
	ВыборИзСтроки = Ложь;
	
	Если ТипЗнч(Параметры.СтруктураДляПоиска) = Тип("ДанныеФормыКоллекция") Тогда
		ВыборИзТаблицыЗначений = Истина;
		ИсходнаяСтрока = ДанныеФормыВЗначение(Параметры.СтруктураДляПоиска, Тип("ТаблицаЗначений"));
	Иначе
		Если ТипЗнч(Параметры.СтруктураДляПоиска.Код) = Тип("СписокЗначений") Тогда
			ВыборИзСпискаЗначений = Истина;
		Иначе
		    ВыборИзСтроки = Истина;
		КонецЕсли;
		ИсходнаяСтрока = ТаблицаЗначений.НайтиСтроки(Параметры.СтруктураДляПоиска);
	КонецЕсли;
	
	Если ВыборИзСтроки И ИсходнаяСтрока.Количество() > 0 Тогда
		Элементы.ТаблицаЗначений.ТекущаяСтрока = ИсходнаяСтрока[0].ПолучитьИдентификатор();
	КонецЕсли;
	
	Элементы.ТаблицаЗначений.Шапка = НЕ Параметры.ОтключитьВидимостьШапкиТаблицы;
	
	Если ЗначениеЗаполнено(Параметры.НаимКолонкиКод) Тогда
		
		Элементы.ТаблицаЗначенийКод.Заголовок = Параметры.НаимКолонкиКод;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.НаимКолонкиНазвание) Тогда
		
		Элементы.ТаблицаЗначенийНазвание.Заголовок = Параметры.НаимКолонкиНазвание;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Параметры.НаимКолонкиКратко) Тогда
		
		Элементы.ТаблицаЗначенийКратко.Заголовок = Параметры.НаимКолонкиКратко;
		
	КонецЕсли;
	
	// ЗУПК
	Элементы.ТаблицаЗначенийОтметкаЗаполнения.Видимость = ВыборИзСпискаЗначений ИЛИ ВыборИзТаблицыЗначений;
	
	Если ВыборИзСпискаЗначений Тогда
		
		Для Каждого СтрокаСписка Из Параметры.СтруктураДляПоиска.Код Цикл
			
			ИсходнаяСтрока = ТаблицаЗначений.НайтиСтроки(Новый Структура("Код", СтрокаСписка.Значение));
			
			Если ИсходнаяСтрока.Количество() > 0 Тогда
				ИсходнаяСтрока[0].ОтметкаЗаполнения = Истина;
			КонецЕсли;
			
		КонецЦикла;
		
	ИначеЕсли ВыборИзТаблицыЗначений Тогда
		
		СтруктураПоиска = Новый Структура("Код");
		
		Для Каждого СтрокаПоиска Из ИсходнаяСтрока Цикл
			
			СтруктураПоиска.Код = СтрокаПоиска.КодСтроки;
			СтрокиДляОбработки = ТаблицаЗначений.НайтиСтроки(СтруктураПоиска);
			
			Для Каждого СтрокаДляОтметки Из СтрокиДляОбработки Цикл
				СтрокаДляОтметки.ОтметкаЗаполнения = Истина;
				СтрокаДляОтметки.Сумма = СтрокаПоиска.Сумма;
			КонецЦикла;
			
		КонецЦикла;
		
	ИначеЕсли ВыборИзСтроки Тогда
	
		СтрокаДляОбработки = СтрЗаменить(Параметры.СтруктураДляПоиска.Код, " ", "");
		МассивДляОбработки = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивСлов(СтрокаДляОбработки, ";");
		ОбщегоНазначенияКлиентСервер.СвернутьМассив(МассивДляОбработки);
		
		Для Каждого СтрокаМассива Из МассивДляОбработки Цикл
			
			ИсходнаяСтрока = ТаблицаЗначений.НайтиСтроки(Новый Структура("Код", СтрокаМассива));
			
			Если ИсходнаяСтрока.Количество() > 0 Тогда
				Элементы.ТаблицаЗначений.ТекущаяСтрока = ИсходнаяСтрока[0].ПолучитьИдентификатор();
			Иначе
				ПроизвольноеЗначение = Параметры.СтруктураДляПоиска.Код;
				ИспользуетсяПроизвольноеЗначение = ЗначениеЗаполнено(ПроизвольноеЗначение);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	// ЗУПК
	
	Элементы.ГруппаПроизвольноеЗначение.Видимость = ВыборИзСтроки;
	Элементы.ТаблицаЗначенийКод.Видимость      = НЕ Параметры.ОтключитьВидимостьКолонкиКод;
	Элементы.ТаблицаЗначенийНазвание.Видимость = НЕ Параметры.ОтключитьВидимостьКолонкиНазвание;
	Элементы.ТаблицаЗначенийКратко.Видимость   = Параметры.ВключитьВидимостьКолонкиКратко;
	Элементы.ТаблицаЗначенийСумма.Видимость    = Параметры.ВключитьВидимостьКолонкиСумма ИЛИ ВыборИзТаблицыЗначений;
	
	Если Параметры.ОтключитьВидимостьКолонкиКод = Истина
		И Параметры.ОтключитьВидимостьКолонкиНазвание = Ложь
		И Параметры.ВключитьВидимостьКолонкиКратко = Ложь Тогда
		
		Элементы.ТаблицаЗначенийНазвание.АвтоМаксимальнаяШирина = Ложь;
		Элементы.ТаблицаЗначенийНазвание.Ширина = 200;
		Элементы.ТаблицаЗначенийНазвание.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Лево;
		
	ИначеЕсли Параметры.ОтключитьВидимостьКолонкиКод = Ложь
		И Параметры.ОтключитьВидимостьКолонкиНазвание = Истина
		И Параметры.ВключитьВидимостьКолонкиКратко = Ложь Тогда
		
		Элементы.ТаблицаЗначенийКод.АвтоМаксимальнаяШирина = Ложь;
		Элементы.ТаблицаЗначенийКод.Ширина = 200;
		Элементы.ТаблицаЗначенийКод.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Лево;
		
	КонецЕсли;
	
	Элементы.ТаблицаЗначений.Подвал = Элементы.ТаблицаЗначенийСумма.Видимость;
	СуммаПоСтроке = ТаблицаЗначений.Итог("Сумма");

КонецПроцедуры

&НаКлиенте
Процедура ТаблицаЗначенийСуммаПриИзменении(Элемент)
	
	Элементы.ТаблицаЗначений.ТекущиеДанные.ОтметкаЗаполнения = НЕ Элементы.ТаблицаЗначений.ТекущиеДанные.Сумма = 0;
	СуммаПоСтроке = ТаблицаЗначений.Итог("Сумма");
	
КонецПроцедуры

&НаКлиенте
Процедура ПроизвольноеЗначениеПриИзменении(Элемент)
	
	Если ЗначениеЗаполнено(ПроизвольноеЗначение) И НЕ ИспользуетсяПроизвольноеЗначение Тогда
		ИспользуетсяПроизвольноеЗначение = Истина;
	ИначеЕсли НЕ ЗначениеЗаполнено(ПроизвольноеЗначение) И ИспользуетсяПроизвольноеЗначение Тогда
		ИспользуетсяПроизвольноеЗначение = Ложь;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти