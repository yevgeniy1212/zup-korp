КонецПроцедуры

&НаКлиенте
Процедура ДобавитьСтраницу(Команда)
	
	СохранитьДанныеРаздела(СтруктураРеквизитовФормы.НаимТекущегоРаздела, Ложь);
	
	Модифицированность = Истина;
	
	ОбластьИмя = "";
	Если СтруктураРеквизитовФормы.НаимТекущегоРаздела = "Форма200_03Страница1" Тогда
		
		ДобавитьЛистВФорму200_03НаСервере();
		
	ИначеЕсли СтруктураРеквизитовФормы.НаимТекущегоРаздела = "Форма200_06Страница1" Тогда
		
		ДобавитьЛистВФорму200_06НаСервере();
		ОбластьИмя = "ТекущийЛист";
		
	КонецЕсли;
	
	Обл = ТабличныйДокумент.Области["УдалитьСтраницуЗначок"];
	Обл.Гиперссылка = Истина;
	Обл.Текст = "х";
	Обл = ТабличныйДокумент.Области["УдалитьСтраницу"];
	Обл.Гиперссылка = Истина;
	Обл.Текст = "Удалить Лист";
	
	РасчетНаКлиенте(СтруктураРеквизитовФормы.НаимТекущегоРаздела, ОбластьИмя);
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьЛистВФорму200_03НаСервере()
	
	ВставитьДопЛистФорма200_03НаСервере("Форма200_03Страница1");
	СохранитьАктивнуюФорму200_03НаСервере("Форма200_03Страница1");
	ОчиститьТабличноеПолеНаСервере("Форма200_03Страница2");
	СохранитьАктивнуюФорму200_03НаСервере("Форма200_03Страница2");
	
КонецПроцедуры

&НаСервере
Процедура ВставитьДопЛистФорма200_03НаСервере(ИмяТекущейСтраницыПанели)
	
	ВставитьЛистВФорму200_03(ЭтаФорма, ИмяТекущейСтраницыПанели);
	ПослеВставкиДополнительногоЛистаВФорму200_03НаСервере(ИмяТекущейСтраницыПанели);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ВставитьЛистВФорму200_03(Форма, ИмяТекущейСтраницыПанели)

	Перем ТаблицаСтраницРаздела;
	Перем ТаблицаСтраница1;

	Если Не Форма.мСтруктураФорма200_03Страница1и2.Свойство("Форма200_03", ТаблицаСтраницРаздела) Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаЛистовРаздела = Форма[ТаблицаСтраницРаздела];
	
	ТекТабличноеПоле     = Форма.ТабличныйДокумент;
	// находим активную страницу
	ТекущийЛист = ТаблицаЛистовРаздела.НайтиСтроки(Новый Структура("АктивнаяСтраница", Истина));
	
	Если ИмяТекущейСтраницыПанели = "Форма200_03Страница1" Тогда
		
		СтруктураДанныхТекущейТаблицы = СобратьДанныеТекущегоТаблПоля(Форма, "ТабличныйДокумент");
		ТекущийЛист[0].АктивнаяСтраница = Ложь;
		
		НовыйЛист = ТаблицаЛистовРаздела.Добавить();
		НовыйЛист.Представление      = "";
		НовыйЛист.АктивнаяСтраница   = Истина; // Активная страница
		
		СтруктураДанных = Новый Структура;
		НовыйЛист.Страница2.Добавить(СтруктураДанных);
		
		ОчиститьТабличноеПоле(Форма, ИмяТекущейСтраницыПанели);
		
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Процедура ПослеВставкиДополнительногоЛистаВФорму200_03НаСервере(ИмяТекущейСтраницыПанели, ПерейтиНаВставленныйЛист = Истина)
	
	ПослеВставкиДополнительногоЛистаВФорму200_03(ЭтаФорма, ИмяТекущейСтраницыПанели, ПерейтиНаВставленныйЛист);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ПослеВставкиДополнительногоЛистаВФорму200_03(Форма, ИмяТекущейСтраницыПанели, ПерейтиНаВставленныйЛист)
	
	ТекущийЭлемент = Форма.РазделыОтчета.НайтиПоИдентификатору(Форма.Элементы.РазделыОтчета.ТекущаяСтрока);
	
	Родитель = ТекущийЭлемент.ПолучитьРодителя();

	Если НЕ Родитель = Неопределено Тогда
		
		РодительРодителя = Родитель.ПолучитьРодителя();
		
		Если Не РодительРодителя = Неопределено Тогда 
			
			ТекущийЭлемент = РодительРодителя;
			
		Иначе
			
			ТекущийЭлемент = Родитель;
			
		КонецЕсли;
		
		
	КонецЕсли;
	
	НомерДобавляемойСтраницы = ТекущийЭлемент.ПолучитьЭлементы().Количество() + 1;
	
	ДобавляемаяСтраница = ТекущийЭлемент.ПолучитьЭлементы().Добавить();
	
	ДобавляемаяСтраница.КолонкаРазделыОтчета              = "Форма 200.03 Лист " + НомерДобавляемойСтраницы;
	ДобавляемаяСтраница.КолонкаРазделыОтчетаСокрНаим      = ТекущийЭлемент.КолонкаРазделыОтчетаСокрНаим;
	ДобавляемаяСтраница.КолонкаНомерСтраницыРазделаОтчета = НомерДобавляемойСтраницы;
	ДобавляемаяСтраница.РазделМногостраничный             = ТекущийЭлемент.РазделМногостраничный;
	
	ИдентификаторДобавляемойСтраницы = ДобавляемаяСтраница.ПолучитьИдентификатор();
	
	ТекущийЭлемент = ДобавляемаяСтраница;
	
	ДобавляемаяПодСтраница1 = ТекущийЭлемент.ПолучитьЭлементы().Добавить();
	
	ДобавляемаяПодСтраница1.КолонкаРазделыОтчета              = "Форма 200.03 Страница 1";
	ДобавляемаяПодСтраница1.КолонкаРазделыОтчетаСокрНаим      = "Форма200_03Страница1";
	ДобавляемаяПодСтраница1.КолонкаНомерСтраницыРазделаОтчета = НомерДобавляемойСтраницы;
	ДобавляемаяПодСтраница1.РазделМногостраничный             = Истина;
	
	ДобавляемаяПодСтраница2 = ТекущийЭлемент.ПолучитьЭлементы().Добавить();
	
	ДобавляемаяПодСтраница2.КолонкаРазделыОтчета              = "Форма 200.03 Страница 2";
	ДобавляемаяПодСтраница2.КолонкаРазделыОтчетаСокрНаим      = "Форма200_03Страница2";
	ДобавляемаяПодСтраница2.КолонкаНомерСтраницыРазделаОтчета = НомерДобавляемойСтраницы;
	ДобавляемаяПодСтраница2.РазделМногостраничный             = Истина;
	
	
	Если НЕ ИмяТекущейСтраницыПанели = "Форма200_03Страница1" Тогда
		ИдентификаторДобавляемойСтраницы = ДобавляемаяСтраница.ПолучитьИдентификатор();
	КонецЕсли;
	
	Если ПерейтиНаВставленныйЛист Тогда
		Форма.Элементы.РазделыОтчета.ТекущаяСтрока = ИдентификаторДобавляемойСтраницы;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьЛистВФорму200_06НаСервере()
	
	ВставитьДопЛистФорма200_06НаСервере("Форма200_06Страница1");
	
