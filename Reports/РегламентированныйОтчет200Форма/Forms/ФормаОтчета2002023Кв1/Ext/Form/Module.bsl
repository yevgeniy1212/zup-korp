// В данной процедуре указываются дополнительные реквизиты, передаваемые
// При выгрузке и отправке формы, которых нет на форме.
//
// Возвращаемое значение:
//   Структура - вспомогательные параметры:
//       * Ключ - имя реквизита из структуры JSON
//       * Значение - соответствующее значение реквизита
Функция ЗаполнитьСлужебныеРеквизитыФормыОтчетность1С() Экспорт
	СлужебныеРеквизитыФормы = Новый Структура;
	
	// В структуре ф. 200.00 за 2025 год требуется указать МЗП
	мМЗП = Отчетность1ССервер.ПолучитьЗначениеРасчетногоПоказателя("РазмерМЗП", НачалоГода(СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета));
	
	СлужебныеРеквизитыФормы.Вставить("minimumWage", мМЗП);
	
	Возврат СлужебныеРеквизитыФормы;
КонецФункции

// Список форм, которые необходимо выгружать в любом случае
// Возвращаемое значение:
//   Массив - вспомогательные параметры:
//       * Строка - имя формы из макета "Показатели"
Функция СписокОбязательныхПриложений() Экспорт
	
	СписокОбязательныхПриложений = Новый Массив;
	СписокОбязательныхПриложений.Добавить("form200_01");
	
	Возврат СписокОбязательныхПриложений;
	
КонецФункции 

&НаСервере
// Формирует структуру дополнительных реквизитов, используемых при проверке контрольных соотношений (ФЛК) отчетности.
//
// Возвращаемое значение:
//  Структура – содержит дополнительные данные, необходимые для корректной проверки отчетности.
Функция ПолучитьДополнительныеРеквизитыКПроверкеФЛКОтчетность1С() Экспорт
	СтруктураДобавляемыхПриПроверкеДанных = Новый Структура;
	
	мМРП = Отчетность1ССервер.ПолучитьЗначениеРасчетногоПоказателя("РазмерМРП", НачалоГода(СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета));
	СтруктураДобавляемыхПриПроверкеДанных.Вставить("мМРП", мМРП);
	ЭтоИП = Отчетность1ССервер.ЭтоИП(Налогоплательщик);
	СтруктураДобавляемыхПриПроверкеДанных.Вставить("ЭтоИП", ЭтоИП);
	
	Возврат СтруктураДобавляемыхПриПроверкеДанных;
КонецФункции

&НаКлиенте
// Возвращает период, за который доступна выгрузка/отправка формы отчета
Функция ГодФормированияОтчетность1С()            	
	Возврат 2026;		
КонецФункции

#КонецОбласти

#Область ВыгрузкаВJSON

&НаКлиенте
// Обработчик команды формы, требующей контекстного вызова сервера.
// Производит проверку соответствия периода выгрузки для формы отчета.
// Нужно отслеживать период формирования и менять, в случае необходимости.
Процедура Подключаемый_ВыгрузитьВJSONОтчетность1С(Команда)
	ТипДействия = Отчетность1СКлиентСервер.ТипЗапроса_ВыгрузкаВJSON();
	
	ОтправкаРазрешена = Отчетность1СКлиент.ПроверитьУсловияОтправки(ЭтаФорма, ГодФормированияОтчетность1С(), ТипДействия);
	
	Если НЕ ОтправкаРазрешена Тогда
		Возврат;
	КонецЕсли;
	
	ПередВыгрузкойВJSON();
	
	РезультатВыгрузки = ВыгрузитьВJSONНаСервере(ТипДействия);

	ДополнительныеПараметрыВыгрузкиJSON = Новый Структура;
	ДополнительныеПараметрыВыгрузкиJSON.Вставить("СтруктураРеквизитовФормы", СтруктураРеквизитовФормы);
	ДополнительныеПараметрыВыгрузкиJSON.Вставить("РезультатВыгрузки", РезультатВыгрузки);

	Отчетность1СКлиент.ВыгрузитьВJSONОтчетность1С(ДополнительныеПараметрыВыгрузкиJSON);

КонецПроцедуры 

&НаСервере
// Формирует структуру JSON.
// Возвращаемое значение:
//   АдресВременногоХранилища - Строка - адрес хранилища, содержащего готовый текст формы в формате JSON.
Функция ВыгрузитьВJSONНаСервере(ТипДействия)

	СтруктураПараметровОтчетность1С = Отчетность1ССервер.СформироватьСтруктуруПараметров(ЭтотОбъект, ТипДействия);
	ДанныеВыгрузки = Отчетность1ССервер.ВыгрузитьОтчетВJSONДляИСНА(СтруктураПараметровОтчетность1С, ТипДействия);	
	  
	Возврат ДанныеВыгрузки;

КонецФункции

#КонецОбласти

#Область ПроверкаФЛК

&НаКлиенте
// см. Отчетность1СКлиент.ПроверитьЗаполнение()
Функция Подключаемый_ПроверитьЗаполнениеОтчетность1С() Экспорт	
	Отчетность1СКлиент.ПроверитьЗаполнение(Ложь, ЭтотОбъект);
КонецФункции 

&НаКлиенте
// см. ПолучитьСтруктуруПараметровОтчетность1СНаСервере()
Функция ПолучитьСтруктуруПараметровОтчетность1С(ТипДействия) Экспорт	
	ПередВыгрузкойВJSON();
	Возврат ПолучитьСтруктуруПараметровОтчетность1СНаСервере(ТипДействия);	
КонецФункции

&НаСервере
// Формирует структуру параметров для различных действий с формой регламентированной отчетности.
// Возвращаемая структура используется при последующих операциях проверки, выгрузки, 
// отправки или обновления статуса отчетных форм.
//
// Параметры:
//  ТипДействия – Строка – определяет выполняемое действие. 
//   Возможные значения:
//    * "ПроверкаФЛК" – формирование структуры параметров для проверки контрольных соотношений (ФЛК);
//    * "Отправка" – формирование структуры параметров для отправки отчета;
//    * "ОбновитьСтатус" – формирование структуры параметров для обновления статуса отправленного отчета.
//
// Возвращаемое значение:
//  Структура – Сформированные параметры для выбранного действия.
Функция ПолучитьСтруктуруПараметровОтчетность1СНаСервере(ТипДействия) Экспорт	
	Если ТипДействия = Отчетность1СКлиентСервер.ТипЗапроса_ПроверкаФЛК() Тогда	
		СтруктураПараметровОтчетность1С = Отчетность1ССервер.СформироватьСтруктуруПараметров(ЭтотОбъект, ТипДействия);
		СтруктураПараметров = Отчетность1ССервер.ПолучитьСтруктуруКВыгрузке(СтруктураПараметровОтчетность1С);
	ИначеЕсли ТипДействия = Отчетность1СКлиентСервер.ТипЗапроса_ОтправитьФорму() ИЛИ ТипДействия = Отчетность1СКлиентСервер.ТипЗапроса_ОбновитьСтатус() Тогда
		СтруктураПараметров = Отчетность1ССервер.СформироватьСтруктуруПараметров_Отправка(ЭтотОбъект);
	КонецЕсли;
	
	Возврат СтруктураПараметров;
КонецФункции

&НаКлиенте
// см. Отчетность1СКлиент.ПолучениеРезультатаОтправкиНаВалидацию()
Процедура ПолучениеРезультатаОтправкиНаВалидациюОтчетность1С(СтруктураРезультата, ДополнительныеПараметры = Неопределено) Экспорт
	Отчетность1СКлиент.ПолучениеРезультатаОтправкиНаВалидацию(ЭтаФорма, СтруктураРезультата,ДополнительныеПараметры);
КонецПроцедуры

&НаКлиенте
