&НаКлиентеНаСервереБезКонтекста
Процедура СохранитьАктивнуюФорму200_03(Форма, ИмяСтраницы)
	Перем ТаблицаСтраницРаздела;
	
	Если Не Форма.мСтруктураФорма200_03Страница1и2.Свойство("Форма200_03", ТаблицаСтраницРаздела) Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаСтраницРаздела = Форма[ТаблицаСтраницРаздела];
	
	ТекТабличноеПоле      = Форма.ТабличныйДокумент;
	
	СтрТаблицаСтраницы    = ТаблицаСтраницРаздела.НайтиСтроки(Новый Структура("АктивнаяСтраница", Истина));
	
	Если СтрТаблицаСтраницы.Количество() > 0 Тогда
		
		СтрТаблицаСтраницы = СтрТаблицаСтраницы[0];

		СтруктураДанныхТекущейТаблицы = СобратьДанныеТекущегоТаблПоля(Форма, "ТабличныйДокумент");
		
		Если ИмяСтраницы = "Форма200_03Страница2" Тогда
			
			Если СтрТаблицаСтраницы.Страница2.Количество() > 0 Тогда
				
				Если СтрТаблицаСтраницы.Страница2[0].Значение.Свойство("РегистрацияВНО") Тогда
					РегистрацияВНО = СтрТаблицаСтраницы.Страница1[0].Значение.РегистрацияВНО;
				Иначе
					РегистрацияВНО = Неопределено
				КонецЕсли;

				Если СтрТаблицаСтраницы.Страница2[0].Значение.Свойство("ОрганизацияФилиала") Тогда
					ОрганизацияФилиала = СтрТаблицаСтраницы.Страница2[0].Значение.ОрганизацияФилиала;
				Иначе
					ОрганизацияФилиала = Неопределено
				КонецЕсли;
				
				СтрТаблицаСтраницы.Страница2[0].Значение = СтруктураДанныхТекущейТаблицы;
				
				СтрТаблицаСтраницы.Страница2[0].Значение.Вставить("РегистрацияВНО", РегистрацияВНО);
				СтрТаблицаСтраницы.Страница2[0].Значение.Вставить("ОрганизацияФилиала", ОрганизацияФилиала);
				
			Иначе
				СтрТаблицаСтраницы.Страница2.Добавить(СтруктураДанныхТекущейТаблицы);
			КонецЕсли;	
				
		КонецЕсли;
		
		Если ИмяСтраницы = "Форма200_03Страница1" Тогда
			
			Если СтрТаблицаСтраницы.Страница1.Количество() > 0 Тогда
				
				Если СтрТаблицаСтраницы.Страница1[0].Значение.Свойство("РегистрацияВНО") Тогда
					РегистрацияВНО = СтрТаблицаСтраницы.Страница1[0].Значение.РегистрацияВНО;
				Иначе
					РегистрацияВНО = Неопределено
				КонецЕсли;

				Если СтрТаблицаСтраницы.Страница1[0].Значение.Свойство("ОрганизацияФилиала") Тогда
					ОрганизацияФилиала = СтрТаблицаСтраницы.Страница1[0].Значение.ОрганизацияФилиала;
				Иначе
					ОрганизацияФилиала = Неопределено
				КонецЕсли;

				СтрТаблицаСтраницы.Страница1[0].Значение = СтруктураДанныхТекущейТаблицы;
				
				СтрТаблицаСтраницы.Страница1[0].Значение.Вставить("РегистрацияВНО", РегистрацияВНО);
				СтрТаблицаСтраницы.Страница1[0].Значение.Вставить("ОрганизацияФилиала", ОрганизацияФилиала);
				
			Иначе
				СтрТаблицаСтраницы.Страница1.Добавить(СтруктураДанныхТекущейТаблицы);
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ОбновитьСтруктуруМногострочногоРазделаНаСервере(ИмяГруппы) Экспорт
	
	Перем СтруктураГруппы;
	
	ОбновитьСтруктуруМногострочногоРаздела(ЭтаФорма, ИмяГруппы);
	
КонецПроцедуры

Процедура ОбновитьСтруктуруМногострочногоРаздела(Форма, ИмяГруппы) Экспорт
	Перем СтруктураГруппы;
    	
	Форма.мСтруктураМногострочныхРазделов.Свойство(ИмяГруппы, СтруктураГруппы);
	
	СтруктураГруппы = Форма[СтруктураГруппы];
	
	ТекТабличноеПолеИмя = "ТабличныйДокумент";
	
	ТекТабличноеПоле = Форма[ТекТабличноеПолеИмя];
	
	Для НСтр = 1 По СтруктураГруппы.Количество() Цикл
		ТекСтрокаТаблицы = СтруктураГруппы[НСтр - 1];
		НСтрСтр = Формат(НСтр, "ЧГ=0");
		
		Для НомерГрафы = 1 По Форма.мСтруктураКолвоКолонокРазделов[ИмяГруппы] Цикл
		
		    ИмяКолонки = ИмяГруппы + Формат(НомерГрафы, "ЧЦ=2; ЧВН=");
		
			Если СтруктураГруппы[0].Свойство(ИмяКолонки) Тогда
				
				ИмяЯчейки     = ИмяКолонки + "_" + НСтрСтр;
				ОбластьЯчейки = ТекТабличноеПоле.Области[ИмяЯчейки];
				
				Если ОбластьЯчейки.СодержитЗначение = Истина Тогда
					ЗначениеЯчейки = ОбластьЯчейки.Значение;
					Если ЗначениеЗаполнено(ОбластьЯчейки.Расшифровка) Тогда
						
						ТекСтрокаТаблицы[ИмяКолонки + "Ссылка"] = ОбластьЯчейки.Расшифровка;
						
					КонецЕсли;
				Иначе
					ЗначениеЯчейки = ОбластьЯчейки.Текст;
				КонецЕсли;
				
				ТекСтрокаТаблицы[ИмяКолонки] = ЗначениеЯчейки;
				
			КонецЕсли;
				
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСтруктуруМногострочногоРаздела200_06НаСервере(ИмяГруппы) Экспорт
	
	ОбновитьСтруктуруМногострочногоРаздела200_06(ЭтаФорма, ИмяГруппы);
	
КонецПроцедуры

Процедура ОбновитьСтруктуруМногострочногоРаздела200_06(Форма, ИмяГруппы) Экспорт
	Перем СтруктураГруппы;
	
	Форма.мСтруктураМногострочныхРазделов.Свойство(ИмяГруппы, СтруктураГруппы);
	
	СтруктураГруппы = ПолучитьСтруктуруМногостраничногоПриложения(Форма, СтруктураГруппы);
	
	ТекТабличноеПолеИмя = "ТабличныйДокумент";
	
	ТекТабличноеПоле = Форма[ТекТабличноеПолеИмя];
	
	Для НСтр = 1 По СтруктураГруппы.Количество() Цикл
		ТекСтрокаТаблицы = СтруктураГруппы[НСтр - 1];
		НСтрСтр = Формат(НСтр, "ЧГ=0");
		
		Для НомерГрафы = 1 По Форма.мСтруктураКолвоКолонокРазделов[ИмяГруппы] Цикл
		
			ИмяКолонки = ИмяГруппы + Формат(НомерГрафы, "ЧЦ=2; ЧВН=");
		
			Если (ТипЗнч(СтруктураГруппы[0]) = Тип("ЭлементСпискаЗначений") И СтруктураГруппы[0].Значение.Свойство(ИмяКолонки)) Тогда
				
				ИмяЯчейки     = ИмяКолонки + "_" + НСтрСтр;
				ОбластьЯчейки = ТекТабличноеПоле.Области[ИмяЯчейки];
				
				Если ОбластьЯчейки.СодержитЗначение = Истина Тогда
					ЗначениеЯчейки = ОбластьЯчейки.Значение;
					Если ЗначениеЗаполнено(ОбластьЯчейки.Расшифровка) Тогда
						
						ТекСтрокаТаблицы.Значение[ИмяКолонки + "Ссылка"] = ОбластьЯчейки.Расшифровка;
						
					КонецЕсли;
				Иначе
					ЗначениеЯчейки = ОбластьЯчейки.Текст;
				КонецЕсли;
				
				ТекСтрокаТаблицы.Значение[ИмяКолонки] = ЗначениеЯчейки;
				
			КонецЕсли;
				
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ТабличныйДокументПриИзмененииСодержимогоОбласти(Элемент, Область)
	
	Модифицированность = Истина;
	
	ИмяРаздела = Элементы.РазделыОтчета.ТекущиеДанные.КолонкаРазделыОтчетаСокрНаим;
	
	РасчетНаКлиенте(ИмяРаздела,Область.Имя);
	
КонецПроцедуры

&НаКлиенте
Процедура РасчетНаКлиенте(ИмяСтраницыПанели = "", ОбластьИмя = "") Экспорт

	Расчет(ЭтаФорма, ИмяСтраницыПанели, ОбластьИмя);
	
	Если ИмяСтраницыПанели = "Форма200_02Страница4" 
		ИЛИ ИмяСтраницыПанели = "Форма200_02Страница5"
		ИЛИ ИмяСтраницыПанели = "Форма200_02Страница8" Тогда
		//0000000AG
		Если СтрЧислоВхождений(ЭтаФорма.СтруктураЗависимыхЯчеекДляАвторасчета.П000280000203, Лев(ОбластьИмя,13)) > 0 Тогда
			
			Префикс = Сред(ОбластьИмя,Найти(ОбластьИмя,"_"),СтрДлина(ОбластьИмя) - (Найти(ОбластьИмя,"_")-1));
			Индекс = Число(Прав(Префикс,СтрДлина(Префикс)-1)) - 1;
			
			ОкрП000240000202 = 0;
			ОкрП000250000202 = 0;
			ОкрП000250000203 = 0;
			ОкрП000280000202 = 0;
			
			// P Начислено
			Если ЭтаФорма.СтруктураРеквизитовФормы.НаимТекущегоРаздела = "Форма200_02Страница4" Тогда
				ОкрП000240000202 = РегламентированнаяОтчетностьКлиентСервер.ОкруглитьЧислоПоФормату(ЭтаФорма, ЭтаФорма.ТабличныйДокумент.Области["П000240000202" + Префикс].Значение);
			Иначе
				ОкрП000240000202 = РегламентированнаяОтчетностьКлиентСервер.ОкруглитьЧислоПоФормату(ЭтаФорма, ЭтаФорма.П0002400002[Индекс].П000240000202);
			КонецЕсли;
			
			// T ОПВ
			Если ЭтаФорма.СтруктураРеквизитовФормы.НаимТекущегоРаздела = "Форма200_02Страница5" Тогда
				ОкрП000250000202 = РегламентированнаяОтчетностьКлиентСервер.ОкруглитьЧислоПоФормату(ЭтаФорма, ЭтаФорма.ТабличныйДокумент.Области["П000250000202" + Префикс].Значение);
			Иначе
				ОкрП000250000202 = РегламентированнаяОтчетностьКлиентСервер.ОкруглитьЧислоПоФормату(ЭтаФорма, ЭтаФорма.П0002500002[Индекс].П000250000202);
			КонецЕсли;
			
			// U ВОСМС
			Если ЭтаФорма.СтруктураРеквизитовФормы.НаимТекущегоРаздела = "Форма200_02Страница5" Тогда
				ОкрП000250000203 = РегламентированнаяОтчетностьКлиентСервер.ОкруглитьЧислоПоФормату(ЭтаФорма, ЭтаФорма.ТабличныйДокумент.Области["П000250000203" + Префикс].Значение);
			Иначе
				ОкрП000250000203 = РегламентированнаяОтчетностьКлиентСервер.ОкруглитьЧислоПоФормату(ЭтаФорма, ЭтаФорма.П0002500002[Индекс].П000250000203);
			КонецЕсли;
			
			// AF доходы, не облагаемые СН
			Если ЭтаФорма.СтруктураРеквизитовФормы.НаимТекущегоРаздела = "Форма200_02Страница8" Тогда
				ОкрП000280000202 = РегламентированнаяОтчетностьКлиентСервер.ОкруглитьЧислоПоФормату(ЭтаФорма, ЭтаФорма.ТабличныйДокумент.Области["П000280000202" + Префикс].Значение);
			Иначе
				ОкрП000280000202 = РегламентированнаяОтчетностьКлиентСервер.ОкруглитьЧислоПоФормату(ЭтаФорма, ЭтаФорма.П0002800002[Индекс].П000280000202);
			КонецЕсли;
			
			П000280000203 = ОкрП000240000202 - ОкрП000250000202 - ОкрП000250000203 - ОкрП000280000202;
			
			ЭтаФорма.СтруктураДанныхФорма200_02Страница8.Вставить("П000280000203" + Префикс, П000280000203);
			
			ЭтаФорма.П0002800002[Индекс].П000280000203 = П000280000203;
			
			Если ЭтаФорма.СтруктураРеквизитовФормы.НаимТекущегоРаздела = "Форма200_02Страница8" Тогда
				ЭтаФорма.ТабличныйДокумент.Области["П000280000203" + Префикс].Значение = П000280000203;
			КонецЕсли;
			
			Расчет(ЭтаФорма, "Форма200_02Страница8", "П000280000203");  //перерасчет 8й стр. форма 200.02
			
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура РасчетНаСервере(ИмяСтраницыПанели = "", ОбластьИмя = "") Экспорт

	Расчет(ЭтаФорма, ИмяСтраницыПанели, ОбластьИмя);

