					ПодстраницаРазделаОтчет1.КолонкаРазделыОтчетаСокрНаим      = "Форма200_06Страница1";
					ПодстраницаРазделаОтчет1.КолонкаНомерСтраницыРазделаОтчета = НомерСтраницы;
					ПодстраницаРазделаОтчет1.РазделМногостраничный             = ЭлементРазделовОтчета.РазделМногостраничный;
					ПодстраницаРазделаОтчет1.РазделМногострочный               = ЭлементРазделовОтчета.РазделМногострочный;
					
					ПодстраницаРазделаОтчет2 = СтраницаРазделаОтчета.ПолучитьЭлементы().Добавить();
					
					ПодстраницаРазделаОтчет2.КолонкаРазделыОтчета      = "Форма 200.06 Страница 2";
					ПодстраницаРазделаОтчет2.КолонкаРазделыОтчетаСокрНаим      = "Форма200_06Страница2";
					ПодстраницаРазделаОтчет2.КолонкаНомерСтраницыРазделаОтчета = НомерСтраницы;
					ПодстраницаРазделаОтчет2.РазделМногостраничный             = ЭлементРазделовОтчета.РазделМногостраничный;
					ПодстраницаРазделаОтчет2.РазделМногострочный               = ЭлементРазделовОтчета.РазделМногострочный;
					
					ПодстраницаРазделаОтчет3 = СтраницаРазделаОтчета.ПолучитьЭлементы().Добавить();
					
					ПодстраницаРазделаОтчет3.КолонкаРазделыОтчета      = "Форма 200.06 Страница 3";
					ПодстраницаРазделаОтчет3.КолонкаРазделыОтчетаСокрНаим      = "Форма200_06Страница3";
					ПодстраницаРазделаОтчет3.КолонкаНомерСтраницыРазделаОтчета = НомерСтраницы;
					ПодстраницаРазделаОтчет3.РазделМногостраничный             = ЭлементРазделовОтчета.РазделМногостраничный;
					ПодстраницаРазделаОтчет3.РазделМногострочный               = ЭлементРазделовОтчета.РазделМногострочный;
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьСпискиВыбора()
	
	МакетСоставаПоказателей = Отчеты[ИмяОтчета(ЭтаФорма.ИмяФормы)].ПолучитьМакет("СпискиВыбора2021Кв1");
	
	КоллекцияСписковВыбора = Новый Соответствие;
	Для Каждого Область Из МакетСоставаПоказателей.Области Цикл
		Если Область.ТипОбласти = ТипОбластиЯчеекТабличногоДокумента.Строки Тогда
			ВерхОбласти = Область.Верх;
			НизОбласти = Область.Низ;
			ТаблСписка = Новый ТаблицаЗначений;
			ТаблСписка.Колонки.Добавить(
				"Код",,, МакетСоставаПоказателей.Область(ВерхОбласти, 1, ВерхОбласти, 1).ШиринаКолонки);
			ТаблСписка.Колонки.Добавить(
				"Название",,, МакетСоставаПоказателей.Область(ВерхОбласти, 2, ВерхОбласти, 2).ШиринаКолонки);
			Для НомСтр = ВерхОбласти По НизОбласти Цикл
				КодПоказателя = СокрП(МакетСоставаПоказателей.Область(НомСтр, 1).Текст);
				Если КодПоказателя <> "###" Тогда
					НовСтрока = ТаблСписка.Добавить();
					НовСтрока.Код = КодПоказателя;
					НовСтрока.Название = СокрП(МакетСоставаПоказателей.Область(НомСтр, 2).Текст);
				КонецЕсли;
			КонецЦикла;
			КоллекцияСписковВыбора.Вставить(Область.Имя, ТаблСписка);
		КонецЕсли;
	КонецЦикла;
	
	СвойстваПоказателей.Очистить();
	
	РегламентированнаяОтчетность.ДобавитьСтрокуОписанияВвода(СвойстваПоказателей, "СтандартныеНалоговыеВычеты2021", 1, ,
		"Стандартные налоговые вычеты", КоллекцияСписковВыбора["СтандартныеНалоговыеВычеты2021"]);
	
	Если СтруктураРеквизитовФормы.мДатаНачалаПериодаОтчета >= Дата('20250101') Тогда
		РегламентированнаяОтчетность.ДобавитьСтрокуОписанияВвода(СвойстваПоказателей, "ПрочиеНалоговыеВычеты2025", 1, ,
			"Прочие налоговые вычеты", КоллекцияСписковВыбора["ПрочиеНалоговыеВычеты2025"]);
	Иначе
		РегламентированнаяОтчетность.ДобавитьСтрокуОписанияВвода(СвойстваПоказателей, "ПрочиеНалоговыеВычеты2021", 1, ,
			"Прочие налоговые вычеты", КоллекцияСписковВыбора["ПрочиеНалоговыеВычеты2021"]);
    КонецЕсли;
		
	РегламентированнаяОтчетность.ДобавитьСтрокуОписанияВвода(СвойстваПоказателей, "ДоходыНеПодлежащиеНалогообложению2021", 1, ,
		"Доходы, не подлежащие налогообложению", КоллекцияСписковВыбора["ДоходыНеПодлежащиеНалогообложению2021"]);
			
	РегламентированнаяОтчетность.ДобавитьСтрокуОписанияВвода(СвойстваПоказателей, "ДоходыНеПодлежащиеНалогообложению2025", 1, ,
		"Доходы, не подлежащие налогообложению", КоллекцияСписковВыбора["ДоходыНеПодлежащиеНалогообложению2025"]);
			
	РегламентированнаяОтчетность.ДобавитьСтрокуОписанияВвода(СвойстваПоказателей, "СтатусФизическогоЛица2021", 1, ,
		"Статус физического лица", КоллекцияСписковВыбора["СтатусФизическогоЛица2021"]);
			
	РегламентированнаяОтчетность.ДобавитьСтрокуОписанияВвода(СвойстваПоказателей, "КатегорияФизическогоЛица2021", 1, ,
		"Категории физического лица", КоллекцияСписковВыбора["КатегорияФизическогоЛица2021"]);
	
	РегламентированнаяОтчетность.ДобавитьСтрокуОписанияВвода(СвойстваПоказателей, "КодВидовДохода2021", 1, ,
		"Код видов дохода", КоллекцияСписковВыбора["КодВидовДохода2021"]);
	
	РегламентированнаяОтчетность.ДобавитьСтрокуОписанияВвода(СвойстваПоказателей, "КодировкаВидовМеждународныхДоговоров2021", 1, ,
		"Кодировка видов международных договоров", КоллекцияСписковВыбора["КодировкаВидовМеждународныхДоговоров2021"]);
	
КонецПроцедуры

&НаКлиенте
Процедура ВвестиПоказатель(Элемент, Область, КодПоказателя, Знач ЭтоСумма, Знач ТекстВыбора, ТаблицаВыбора, СтандартнаяОбработка, КолонкаПоиска = "Код") Экспорт
	
	Если ТаблицаВыбора = Неопределено Тогда //ИЛИ СтруктураРеквизитовФормы.мАвтоВыборКодов Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	Если Область.Имя = КодПоказателя Тогда
		ИсходноеЗначение = ?(ТипЗнч(Область.Значение) = Тип("Строка"), СокрЛП(Область.Значение), Область.Значение);
	Иначе
		Разделитель = ?(Лев(Область.Имя, СтрДлина(КодПоказателя) + 1) = КодПоказателя + "_", "_", "");
		ИндексОбласти = 1;
		ИсходноеЗначение = "";
		Пока ЭтаФорма[ТекущийЭлемент.Имя].Области.Найти(
			КодПоказателя + Разделитель + Формат(ИндексОбласти, "ЧГ=")) <> Неопределено Цикл
			ИсходноеЗначение = ИсходноеЗначение + Строка(
				ЭтаФорма[ТекущийЭлемент.Имя].Области[КодПоказателя + Разделитель + Формат(ИндексОбласти, "ЧГ=")].Значение);
			ИндексОбласти = ИндексОбласти + 1;
		КонецЦикла;
		ИсходноеЗначение = СокрЛП(ИсходноеЗначение);
	КонецЕсли;
	

	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Заголовок",          ТекстВыбора);
	ПараметрыФормы.Вставить("ТаблицаЗначений",    ТаблицаВыбора);
	
    Если СтрНайти(КодПоказателя, "П000510000205") > 0 
        ИЛИ СтрНайти(КодПоказателя, "П000610000204") > 0  Тогда
		
		ПараметрыФормы.Вставить("СтруктураДляПоиска", Новый Структура(КолонкаПоиска, ИсходноеЗначение));
		
	Иначе
		
		ПараметрыФормы.Вставить("СтруктураДляПоиска", Новый Структура(КолонкаПоиска, Строка(ИсходноеЗначение)));

	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура("ИндексОбласти, КодПоказателя, КолонкаПоиска, Область, Разделитель", ИндексОбласти, КодПоказателя, КолонкаПоиска, Область, Разделитель);
	ОписаниеОповещения = Новый ОписаниеОповещения("ВвестиПоказательЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	ОткрытьФорму("Отчет.РегламентированныйОтчет200Форма.Форма.ФормаВыбораЗначенияИзТаблицы", ПараметрыФормы, ЭтаФорма,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ВвестиПоказательЗавершение(РезультатВыбора, ДополнительныеПараметры) Экспорт
	
	ИндексОбласти = ДополнительныеПараметры.ИндексОбласти;
	КодПоказателя = ДополнительныеПараметры.КодПоказателя;
	КолонкаПоиска = ДополнительныеПараметры.КолонкаПоиска;
	Область       = ДополнительныеПараметры.Область;
	Разделитель   = ДополнительныеПараметры.Разделитель;
	ИмяРаздела    = Элементы.РазделыОтчета.ТекущиеДанные.КолонкаРазделыОтчетаСокрНаим;
	
	ВыборИзСпискаЗначений = Ложь;
	ВыборИзТаблицыЗначений = Ложь;
	ВыборИзСтроки = Ложь;
	
	Если РезультатВыбора = Неопределено Тогда
		Возврат;
	ИначеЕсли ТипЗнч(РезультатВыбора) = Тип("СписокЗначений") Тогда
		ВыборИзСпискаЗначений = Истина;
	ИначеЕсли ТипЗнч(РезультатВыбора) = Тип("ДанныеФормыКоллекция") Тогда
		ВыборИзТаблицыЗначений = Истина;
	Иначе
		ВыборИзСтроки = Истина;
	КонецЕсли;
	
	Если Область.Имя = КодПоказателя
		ИЛИ РегламентированнаяОтчетностьКлиентСервер.ПоказательВходитВМногострочнуюЧасть(ЭтаФорма, КодПоказателя) > 0 Тогда
		
		ОбластьИмя = Область.Имя;
		// Изменить сумму зависимой ячейки
		НомерСтроки = ПолучитьЧастьИмени(Область.Имя, "НомерСтроки");
		
		Если ВыборИзСтроки Тогда
			
			Область.Значение = РезультатВыбора[КолонкаПоиска];
			
		ИначеЕсли ВыборИзСпискаЗначений Тогда
			
			Область.Значение = РезультатВыбора;
			
		Иначе
			
			СоставноеЗначение = Новый СписокЗначений;
			
			Для Каждого СтрокаТаблицы Из РезультатВыбора Цикл
				
				Если СтрокаТаблицы.ОтметкаЗаполнения Тогда
					
					СоставноеЗначение.Добавить(СтрокаТаблицы.Код);	
					
				КонецЕсли;
				
			КонецЦикла;
			
			Если СтрНайти(КодПоказателя, "П000540000202") = 0 Тогда
				Область.Значение = СоставноеЗначение;
			Иначе
				ЭтаФорма["П0005300002"][Число(НомерСтроки) - 1]["П000530000205"] = СоставноеЗначение;
			КонецЕсли;
			
			ИмяТаблицы  = ПолучитьЧастьИмени(ОбластьИмя, "ИмяТаблицы");
			ИмяТаблицыСНомеромКолонки = ПолучитьЧастьИмени(ОбластьИмя, "ИмяТаблицыСНомеромКолонки");
			
			ИмяСвязаннойЯчейки = Неопределено;
			СтруктураЗависимыхЯчеекДляАвторасчета.Свойство(ИмяТаблицыСНомеромКолонки, ИмяСвязаннойЯчейки);
			
			ЗависимаяТаблица = ЭтаФорма[ИмяТаблицы][Число(НомерСтроки) - 1][ИмяТаблицыСНомеромКолонки + "ТаблицаЗначений"];
			ЗависимаяТаблица.Очистить();
			
			Для Каждого СтрокаТаблицы Из РезультатВыбора Цикл
				Если СтрокаТаблицы.ОтметкаЗаполнения Тогда
					СтрокаЗависимойТаблицы = ЗависимаяТаблица.Добавить();
					СтрокаЗависимойТаблицы.КодСтроки = СтрокаТаблицы.Код;
					СтрокаЗависимойТаблицы.Сумма = СтрокаТаблицы.Сумма;
				КонецЕсли;
			КонецЦикла;
				
			Если НЕ ИмяСвязаннойЯчейки = Неопределено Тогда
				
				Если СтрНайти(ИмяСвязаннойЯчейки, "П000240000204") = 0 Тогда
					
					ИмяТаблицыЗависимойЯчейки = Сред(ИмяСвязаннойЯчейки, 0, СтрДлина(ИмяСвязаннойЯчейки) - 2);
					ИтоговаяСумма = ЗависимаяТаблица.Итог("Сумма");
					ЭтаФорма[ИмяТаблицыЗависимойЯчейки][Число(НомерСтроки) - 1][ИмяСвязаннойЯчейки] = ИтоговаяСумма;
					
					НомерПриложения = ПолучитьЧастьИмени(ИмяСвязаннойЯчейки + "_" + НомерСтроки, "НомерПриложения");
					НомерЛиста = ПолучитьЧастьИмени(ИмяСвязаннойЯчейки + "_" + НомерСтроки, "НомерЛиста");
					РазделЗависимойЯчейки = "Форма200_0" + НомерПриложения + "Страница" + НомерЛиста;
					
					Если СтруктураРеквизитовФормы.НаимТекущегоРаздела = РазделЗависимойЯчейки Тогда	
						ЭтотОбъект.ТабличныйДокумент.Области[ИмяСвязаннойЯчейки + "_" + НомерСтроки].Значение = ИтоговаяСумма;
						Расчет(ЭтаФорма, РазделЗависимойЯчейки, ИмяСвязаннойЯчейки);
					Иначе
						Расчет(ЭтаФорма, РазделЗависимойЯчейки, ИмяСвязаннойЯчейки);
					КонецЕсли;
					
				Иначе
					
					ИмяСвязаннойЯчейки1 = "П000240000204";
					СуммаЯчейки1 = 0;
					
					Для Каждого СтрокаЗависимаяТаблица Из ЗависимаяТаблица Цикл
						
						// условие разделения ячеек
                        Если СтрНайти(СтрокаЗависимаяТаблица.КодСтроки, "341") > 0
                            ИЛИ СтрНайти(СтрокаЗависимаяТаблица.КодСтроки, "654") > 0 Тогда
							СуммаЯчейки1 = СуммаЯчейки1 + СтрокаЗависимаяТаблица.Сумма;	
						КонецЕсли;							
						
					КонецЦикла;
					
					НомерПриложения = ПолучитьЧастьИмени(ИмяСвязаннойЯчейки1 + "_" + НомерСтроки, "НомерПриложения");
					НомерЛиста = ПолучитьЧастьИмени(ИмяСвязаннойЯчейки1 + "_" + НомерСтроки, "НомерЛиста");
					РазделЗависимойЯчейки = "Форма200_0" + НомерПриложения + "Страница" + НомерЛиста;
					
					Если СтруктураРеквизитовФормы.НаимТекущегоРаздела = РазделЗависимойЯчейки Тогда	
						ЭтотОбъект.ТабличныйДокумент.Области[ИмяСвязаннойЯчейки1 + "_" + НомерСтроки].Значение = СуммаЯчейки1;
						Расчет(ЭтаФорма, РазделЗависимойЯчейки, ИмяСвязаннойЯчейки1);
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если Найти(Область.Имя, "П000230000103") > 0 Тогда
			
			ИмяСвязаннойЯчейки = "П000230000104" + Сред(Область.Имя, 14);			
			СтруктураДанныхФорма200_02Страница3.Вставить(Область.Имя, РезультатВыбора.Код);
			СтруктураДанныхФорма200_02Страница3.Вставить(ИмяСвязаннойЯчейки, РезультатВыбора.Название);
			
			Если СтруктураРеквизитовФормы.НаимТекущегоРаздела = "Форма200_02Страница3" Тогда	
				ЭтотОбъект.ТабличныйДокумент.Области[Область.Имя].Значение = РезультатВыбора.Код;
				ЭтотОбъект.ТабличныйДокумент.Области[ИмяСвязаннойЯчейки].Значение = РезультатВыбора.Название;
			КонецЕсли;
	
		ИначеЕсли Найти(Область.Имя, "П000230000104") > 0 Тогда
			
			ИмяСвязаннойЯчейки = "П000230000103" + Сред(Область.Имя, 14);
			СтруктураДанныхФорма200_02Страница3.Вставить(Область.Имя, РезультатВыбора.Код);
			СтруктураДанныхФорма200_02Страница3.Вставить(ИмяСвязаннойЯчейки, РезультатВыбора.Название);
			
			Если СтруктураРеквизитовФормы.НаимТекущегоРаздела = "Форма200_02Страница3" Тогда
				ЭтотОбъект.ТабличныйДокумент.Области[ИмяСвязаннойЯчейки].Значение = РезультатВыбора.Код;
				ЭтотОбъект.ТабличныйДокумент.Области[Область.Имя].Значение = РезультатВыбора.Название;
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе
		СтрокаРезультатВыбора = Строка(РезультатВыбора[КолонкаПоиска]);
		Для Инд = СтрДлина(СтрокаРезультатВыбора) + 1 По ИндексОбласти - 1 Цикл
			СтрокаРезультатВыбора = " " + РезультатВыбора[КолонкаПоиска];
		КонецЦикла;
		Для Инд = 1 По ИндексОбласти - 1 Цикл
			ЭтаФорма[ТекущийЭлемент.Имя].Области[КодПоказателя + Разделитель + Формат(Инд, "ЧГ=")].Значение
				= СокрЛП(Сред(РезультатВыбора[КолонкаПоиска], Инд, 1));
		КонецЦикла;
	КонецЕсли;
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьЧастьИмени(ОбластьИмя, Данные = "ИмяТаблицы")
	
	Если Данные = "НомерСтроки" Тогда
		Возврат	Сред(ОбластьИмя, СтрНайти(ОбластьИмя, "_") + 1, СтрДлина(ОбластьИмя));
	ИначеЕсли Данные = "ИмяТаблицы" Тогда 
		Возврат	Сред(ОбластьИмя, 0, СтрНайти(ОбластьИмя, "_") - 3);
	ИначеЕсли Данные = "ИмяТаблицыСНомеромКолонки" Тогда
		Возврат Сред(ОбластьИмя, 0, СтрНайти(ОбластьИмя, "_") - 1);
	ИначеЕсли Данные = "НомерПриложения" Тогда
		Возврат Сред(ОбластьИмя, 5, 1);
	ИначеЕсли Данные = "НомерЛиста" Тогда
		Возврат Сред(ОбластьИмя, 6, 1);
	Иначе
		Возврат "";
	КонецЕсли;		
	
КонецФункции
	
&НаКлиентеНаСервереБезКонтекста
Функция ЭтоРазделРодитель(ИмяРаздела)
	
	Результат = (ИмяРаздела = "Форма200Страница1")
			Или (ИмяРаздела = "Форма200_01Страница1")
			ИЛИ (ИмяРаздела = "Форма200_02Страница1")
			ИЛИ (ИмяРаздела = "Форма200_05Страница1");
	
	Возврат Результат;
	
КонецФункции

