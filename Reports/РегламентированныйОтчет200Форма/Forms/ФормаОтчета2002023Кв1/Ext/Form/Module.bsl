&НаКлиенте
Процедура ТабличныйДокументВыбор(Элемент, Область, СтандартнаяОбработка)
	
	ИмяЯчейки = Область.Имя;
	
	ПараметрВводаПоля = СвойстваПоказателей.НайтиСтроки(Новый Структура("Показатель", Область.Имя));
	
	Если ПараметрВводаПоля.Количество() = 0 Тогда
		
		ПараметрВводаПоля = Неопределено;
		
		Если СтрНайти(Область.Имя, "П000250000204") > 0
			ИЛИ СтрНайти(Область.Имя, "П000530000203") > 0 Тогда
			
			ОбластьСписка = "СтандартныеНалоговыеВычеты2021";
			
		ИначеЕсли СтруктураРеквизитовФормы.мДатаНачалаПериодаОтчета >= Дата('20250101')
			И (СтрНайти(Область.Имя, "П000260000202") > 0
			ИЛИ СтрНайти(Область.Имя, "П000530000205") > 0) Тогда
			
			ОбластьСписка = "ПрочиеНалоговыеВычеты2025";
			
		ИначеЕсли (СтрНайти(Область.Имя, "П000260000202") > 0
			ИЛИ СтрНайти(Область.Имя, "П000530000205") > 0) Тогда
			
			ОбластьСписка = "ПрочиеНалоговыеВычеты2021";
			
		// доходы, не подлежащие налогообложению	
		ИначеЕсли СтруктураРеквизитовФормы.мДатаНачалаПериодаОтчета >= Дата('20250101')
			И (СтрНайти(Область.Имя, "П000240000203") > 0
			ИЛИ СтрНайти(Область.Имя, "П000520000203") > 0) Тогда
			
			ОбластьСписка = "ДоходыНеПодлежащиеНалогообложению2025";
			
		ИначеЕсли СтрНайти(Область.Имя, "П000240000203") > 0
			ИЛИ СтрНайти(Область.Имя, "П000520000203") > 0 Тогда
			
			ОбластьСписка = "ДоходыНеПодлежащиеНалогообложению2021";
			
		ИначеЕсли СтрНайти(Область.Имя, "П000510000204") > 0 Тогда
			
			ОбластьСписка = "СтатусФизическогоЛица2021";
			
        ИначеЕсли СтрНайти(Область.Имя, "П000510000205") > 0 
            ИЛИ СтрНайти(Область.Имя, "П000610000204") > 0 Тогда
			
			ОбластьСписка = "КатегорияФизическогоЛица2021";
			
		ИначеЕсли СтрНайти(Область.Имя, "П000230000102") > 0 Тогда
			
			ОбластьСписка = "КодВидовДохода2021";
			
		ИначеЕсли (Найти(ИмяЯчейки, "П000230000103") > 0
			ИЛИ Найти(ИмяЯчейки, "П000230000104") > 0)  Тогда

			ОбластьСписка = "КодировкаВидовМеждународныхДоговоров2021";
			
		Иначе
			
			ОбластьСписка = Область.Имя;
			
		КонецЕсли;
		
		Для Каждого Стр из СвойстваПоказателей Цикл
			Если ОбластьСписка = Стр.Показатель Тогда
				ПараметрВводаПоля = Стр;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	Иначе
		ПараметрВводаПоля = ПараметрВводаПоля[0];
	КонецЕсли;
	
	Если ПараметрВводаПоля <> Неопределено И ПараметрВводаПоля.ТаблицаЗначений.Количество() > 0 Тогда
		ВвестиПоказатель(Элемент, Область, Область.Имя, Ложь, ПараметрВводаПоля.ТекстПриВыборе, ПараметрВводаПоля.ТаблицаЗначений, СтандартнаяОбработка);
	КонецЕсли;

	ОбработкаВыбораВПолеТабличногоДокумента(Элемент, Область, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнятьДанные200_05ПриИзменении(Элемент)
    Перем ТаблицаСтраницРаздела;
    
    ВидДекларацииПервоначальная = "";
    ВидДекларацииОчередная =      "";
    ВидДекларацииДополнительная = "";
    ВидДекларацииПоУведомлению =  "";
    ВидДекларацииЛиквидационная = "";
    
    Если Ликвидационная Тогда
        ВидДекларацииЛиквидационная = "Х"; 
        ВидДекларацииПервоначальная = "";
        ВидДекларацииОчередная =      "";
        ВидДекларацииДополнительная = "";
        ВидДекларацииПоУведомлению =  "";
    Иначе 
        ВидДекларацииЛиквидационная = "";
        ВидДекларацииОчередная =      "Х";
        ВидДекларацииПервоначальная = "";
        ВидДекларацииДополнительная = "";
        ВидДекларацииПоУведомлению =  "";
    КонецЕсли;  
    
    Если ЭтаФорма.СтруктураРеквизитовФормы.НаимТекущегоРаздела = "Форма200Страница1" Тогда
        ЭтаФорма.ТабличныйДокумент.Области.Ликвидационная.Значение = ВидДекларацииЛиквидационная;
        ЭтаФорма.ТабличныйДокумент.Области.Очередная.Значение      = ВидДекларацииОчередная;
        ЭтаФорма.ТабличныйДокумент.Области.Дополнительная.Значение = ВидДекларацииДополнительная;
        ЭтаФорма.ТабличныйДокумент.Области.Первоначальная.Значение = ВидДекларацииПервоначальная;
    Иначе
        ЭтаФорма.СтруктураДанныхФорма200Страница1.Вставить("Первоначальная", ВидДекларацииПервоначальная);
        ЭтаФорма.СтруктураДанныхФорма200Страница1.Вставить("Очередная",      ВидДекларацииОчередная);
        ЭтаФорма.СтруктураДанныхФорма200Страница1.Вставить("Дополнительная", ВидДекларацииДополнительная);
        ЭтаФорма.СтруктураДанныхФорма200Страница1.Вставить("ПоУведомлению",  ВидДекларацииПоУведомлению);
        ЭтаФорма.СтруктураДанныхФорма200Страница1.Вставить("Ликвидационная", ВидДекларацииЛиквидационная);
    КонецЕсли;
    
    ЭтаФорма.мСтруктураФорма200_03Страница1и2.Свойство("Форма200_03", ТаблицаСтраницРаздела);
    ТаблицаСтраницРаздела = ЭтаФорма[ТаблицаСтраницРаздела];
    Для Каждого СтрокаТЗ из ТаблицаСтраницРаздела Цикл
        СтрокаТЗ.АктивнаяСтраница = Истина;
        СтрокаТЗ.Страница1[0].Значение.Вставить("Ликвидационная", ВидДекларацииЛиквидационная);
        СтрокаТЗ.Страница1[0].Значение.Вставить("Первоначальная", ВидДекларацииПервоначальная);
        СтрокаТЗ.Страница1[0].Значение.Вставить("ОчереднаяПрил3",  	   ВидДекларацииОчередная);
        СтрокаТЗ.Страница1[0].Значение.Вставить("Дополнительная", ВидДекларацииДополнительная);
        СтрокаТЗ.Страница1[0].Значение.Вставить("ПоУведомлению",   ВидДекларацииПоУведомлению);
        СтрокаТЗ.АктивнаяСтраница = Ложь;
    Конеццикла;
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбораВПолеТабличногоДокумента(Элемент, Область, СтандартнаяОбработка)
	
	Если СтрЧислоВхождений(Область.Имя, "ДобавитьСтраницу") > 0 Тогда
		ДобавитьСтраницу("");
	ИначеЕсли СтрЧислоВхождений(Область.Имя, "УдалитьСтраницу") > 0 И Область.Гиперссылка Тогда
		УдалитьСтраницу("");
	ИначеЕсли СтрЧислоВхождений(Область.Имя, "ДобавитьСтроку") > 0 Тогда
		ДобавитьСтроку("");
	ИначеЕсли СтрЧислоВхождений(Область.Имя, "УдалитьСтроку") > 0 И Область.Гиперссылка Тогда
		УдалитьСтроку("");
	ИначеЕсли СтрЧислоВхождений(Область.Имя, "ДобавитьСтраницу") > 0 И Область.Текст <> "" Тогда
		ДобавитьСтраницу("");
	ИначеЕсли СтрЧислоВхождений(Область.Имя, "УдалитьСтраницу") > 0 И Область.Текст <> "" Тогда
		УдалитьСтраницу("");
    ИначеЕсли Найти(Область.Имя, "П000210000102") > 0 
                ИЛИ Найти(Область.Имя, "П000510000202")> 0 
                ИЛИ Найти(Область.Имя, "П000610000202")> 0 Тогда
		
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("ИмяЯчейки", Область.Имя);
	
		НачЗначение = Область.Значение;
		
		ЗначениеРасшифровки = Область.Расшифровка;
		
		Если ЗначениеЗаполнено(Область.Расшифровка) Тогда
			ОткрытьФорму("Справочник.ФизическиеЛица.ФормаОбъекта", Новый Структура("Ключ", Область.Расшифровка), ЭтаФорма);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(НачЗначение) ИЛИ ЗначениеЗаполнено(ЗначениеРасшифровки) Тогда
			Возврат;
		КонецЕсли; 	 
		
		ПараметрыОткрытияФормы = Новый Структура;
		СтруктураОтбора = Новый Структура;
		
		ПараметрыОткрытияФормы.Вставить("РежимВыбора", Истина);
		ПараметрыОткрытияФормы.Вставить("МножественныйВыбор", Ложь);
		ПараметрыОткрытияФормы.Вставить("ЗакрыватьПриВыборе", Истина);

		ОписаниеОповещения = Новый ОписаниеОповещения("ОбработкаВыбораЗначений", ЭтотОбъект, ПараметрыОповещения);
		ОткрытьФорму("Справочник.ФизическиеЛица.ФормаВыбора", ПараметрыОткрытияФормы, ЭтаФорма,,,, ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	КонецЕсли;
	
	ИмяЯчейки = Область.Имя;
	
	Если (Найти(ИмяЯчейки, "Первоначальная") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "Очередная") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "ОчереднаяПрил3") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "Дополнительная") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "ПоУведомлению") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "Ликвидационная") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "Признак7A") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "Признак7B") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "Признак7C") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "Признак7D") > 0) 
	 ИЛИ (Найти(ИмяЯчейки, "Признак7E") > 0) 
	 ИЛИ (Найти(ИмяЯчейки, "Признак7F") > 0) 
	 ИЛИ (Найти(ИмяЯчейки, "УчастникМФЦА") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "Приложение1") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "Приложение2") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "Приложение3") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "Приложение5") > 0)
     ИЛИ (Найти(ИмяЯчейки, "Приложение6") > 0)
     ИЛИ (Найти(ИмяЯчейки, "Резидент") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "Нерезидент") > 0) 
	 ИЛИ (Найти(ИмяЯчейки, "СтруктурныеПодразделенияИмеются") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "П000230000106") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "П000230000107") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "П000510000204") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "П000510000205") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "П000510000206") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "П000510000207") > 0) 
     ИЛИ (Найти(ИмяЯчейки, "П000610000204") > 0)
	 ИЛИ (Найти(ИмяЯчейки, "П000630000207") > 0) Тогда
		РасчетНаКлиенте(СтруктураРеквизитовФормы.НаимТекущегоРаздела,ИмяЯчейки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьСтраницу(Команда)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("УдалитьСтраницуЗавершение", ЭтотОбъект);
	ТекстВопроса = НСтр("ru='Удалить текущий Лист?'");
	ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет, 60, КодВозвратаДиалога.Да);
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьСтраницуЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элементы.РазделыОтчета.ТекущиеДанные;
	
	НомерУдаляемойСтраницы = ТекущиеДанные.КолонкаНомерСтраницыРазделаОтчета;
	
	Если ТекущиеДанные.ПолучитьРодителя() <> Неопределено Тогда
		ТекущиеДанные = ТекущиеДанные.ПолучитьРодителя();
	КонецЕсли;
	
	Если ТекущиеДанные.ПолучитьРодителя() <> Неопределено Тогда
		ТекущиеДанные = ТекущиеДанные.ПолучитьРодителя();
	КонецЕсли;
	
	Если ТекущиеДанные.ПолучитьЭлементы().Количество() = 1 Тогда
		Возврат;
	КонецЕсли;
	
	ЭлементыДанныхФормыДерево = ТекущиеДанные.ПолучитьЭлементы();
	ЭлементДереваПослеУдаления = ЭлементыДанныхФормыДерево.Получить(?(НомерУдаляемойСтраницы-1 = 0,1,НомерУдаляемойСтраницы-1) - 1).ПолучитьИдентификатор();
	УдаляемыйЛистДерева = ЭлементыДанныхФормыДерево.Получить(НомерУдаляемойСтраницы - 1);
	
	НаименованиеФормы = "";
	Если Элементы.РазделыОтчета.ТекущиеДанные.КолонкаРазделыОтчетаСокрНаим = "Форма200_03Страница1" Тогда
		УдалитьДопЛистФорма200_03НаСервере("Форма200_03Страница1");
		НаименованиеФормы = "Форма 200.03 ";
	ИначеЕсли Элементы.РазделыОтчета.ТекущиеДанные.КолонкаРазделыОтчетаСокрНаим = "Форма200_06Страница1" Тогда
		УдалитьДопЛистФорма200_06НаСервере("Форма200_06Страница1");
		НаименованиеФормы = "Форма 200.06 ";
	КонецЕсли;
	
	ТекущиеДанные.ПолучитьЭлементы().Удалить(ТекущиеДанные.ПолучитьЭлементы().Индекс(УдаляемыйЛистДерева));
	
	Элементы.РазделыОтчета.ТекущаяСтрока = ЭлементДереваПослеУдаления;
	НомерСтраницы = 1;
	Для Каждого СтраницаРаздела Из ТекущиеДанные.ПолучитьЭлементы() Цикл
		
		СтраницаРаздела.КолонкаРазделыОтчета = НаименованиеФормы + "Лист " + НомерСтраницы;
		СтраницаРаздела.КолонкаНомерСтраницыРазделаОтчета = НомерСтраницы;
		
		Для Каждого ПодСтраницаРаздела Из СтраницаРаздела.ПолучитьЭлементы() Цикл
			
			Если ПодСтраницаРаздела.КолонкаРазделыОтчетаСокрНаим = "Форма200_03Страница1" Тогда
				
				ПодСтраницаРаздела.КолонкаНомерСтраницыРазделаОтчета = НомерСтраницы;
				
			Иначе
				
				ПодСтраницаРаздела.КолонкаНомерСтраницыРазделаОтчета = НомерСтраницы;
				
			КонецЕсли;
			
		КонецЦикла;
		
		НомерСтраницы = НомерСтраницы + 1;
		
	КонецЦикла;
	
	РасчетНаКлиенте("Форма200_03Страница1","УдалитьСтраницу");
	
	ВывестиМакетСтраницыВТабличныйДокументНаСервере(СтруктураРеквизитовФормы.НаимТекущегоРаздела, СтруктураРеквизитовФормы.НомерСтраницыТекущегоРаздела);
	
КонецПроцедуры

&НаСервере
Процедура УдалитьДопЛистФорма200_03НаСервере(ИмяТекущейСтраницыПанели = Неопределено)
	
	УдалитьДопЛистФорма200_03(ЭтаФорма, ИмяТекущейСтраницыПанели);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УдалитьДопЛистФорма200_03(Форма, ИмяТекущейСтраницыПанели)
	
	Перем ТаблицаСтраницРаздела;
	
	Если Не Форма.мСтруктураФорма200_03Страница1и2.Свойство("Форма200_03", ТаблицаСтраницРаздела) Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаСтраницРаздела = Форма[ТаблицаСтраницРаздела];
	
	ИмяТекТабличногоПоля     = "ТабличныйДокумент";
	ТекТабличноеПоле         = Форма[ИмяТекТабличногоПоля];
	ТаблицаСтраницы = ТаблицаСтраницРаздела.НайтиСтроки(Новый Структура("АктивнаяСтраница", Истина));
	
	Если ТаблицаСтраницы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СтрТаблицаСтраницы = ТаблицаСтраницы[0];
	
	ИндексТекСтрока = ТаблицаСтраницРаздела.Индекс(СтрТаблицаСтраницы);
	
	Если СтрТаблицаСтраницы <> Неопределено Тогда
		
		Если ИмяТекущейСтраницыПанели = "Форма200_03Страница1" Тогда
			
			Если ТаблицаСтраницРаздела.Количество() <= 1 Тогда
				Возврат;
			КонецЕсли;
			
			ИндексТекСтрока = ТаблицаСтраницРаздела.Индекс(СтрТаблицаСтраницы);
			ТаблицаСтраницРаздела.Удалить(СтрТаблицаСтраницы);
			
		КонецЕсли;
		
		// очищаем редактируемые ячейки удаляемой страницы
		ОчиститьТабличноеПоле(Форма, ИмяТекущейСтраницыПанели);
		
	КонецЕсли;
	
	Форма.Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
Процедура УдалитьДопЛистФорма200_06НаСервере(ИмяТекущейСтраницыПанели = Неопределено)
	
	УдалитьДопЛистФорма200_06(ЭтаФорма, ИмяТекущейСтраницыПанели);
	
КонецПроцедуры

