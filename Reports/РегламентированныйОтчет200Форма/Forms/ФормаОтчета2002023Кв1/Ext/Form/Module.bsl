&НаСервере
Процедура Инициализация(БезОткрытияФормы = Ложь) Экспорт
	
	ФормироватьСтруктуруСтраницОтчета();
	ФормироватьСтруктуруСвойствСтраниц();
	СформироватьДеревоРазделовОтчетаНаСервере();
	ЗаполнитьСтруктуруЗависимыхЯчеекДляАвторасчета();
	
	СтруктураРеквизитовФормы.мРежимПечати = Ложь;
	СтруктураРеквизитовФормы.мИзменятьАктивнуюСтраницу = Истина;
	
	Если СтруктураРеквизитовФормы.мСохраненныйДок = Неопределено Тогда
        ЗаполнитьПустыеСтруктурыДанных();
		ЗаполнитьСведенияОбОрганизацииНаСервере();
		НачальныеОперацииСМногострочнымиБлоками();
		СтруктураРеквизитовФормы.ЕдиницаИзмерения = Перечисления.ПорядкиОкругленияОтчетности.Окр1;
		СтруктураРеквизитовФормы.ТочностьЕдиницыИзмерения = 0;
		КопироватьДанныеФормы(мДеревоСтраницОтчета, мДеревоВыбранныхСтраниц);
		РасчетНаСервере("Форма200Страница1",?(Ликвидационная, "Ликвидационная","Очередная"));
		// удалить в следующей форме заполнение Форма200_01Страница2
		РасчетНаСервере("Форма200_01Страница2");
		Модифицированность = Истина;
	Иначе
		ВосстановитьСохраненныеДанные();
		ВывестиМакетСтраницыВТабличныйДокументНаСервере("Форма200Страница1");
	КонецЕсли;
	
	Элементы.ЗаполнятьДанные200_05.Видимость = Год(СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета) >= 2025;
	
	Если НЕ БезОткрытияФормы Тогда
		СформироватьСпискиВыбора();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСведенияОбОрганизацииНаСервере()
	
	ЗаполнитьСведенияОбОрганизации(ЭтаФорма);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСведенияОбОрганизации(Форма)
	
	СтрокаСведений = "ИННЮЛ, НаимЮЛПол, ФИОРук,КБЕ";
	СведенияОбОрганизации = РегламентированнаяОтчетностьРК.ПолучитьСведенияОбОрганизации(СтруктураРеквизитовФормы.Организация,,СтрокаСведений);
	ОтметкаПриложение3 = Ложь;
	
	Если Форма.СтруктураДанныхФорма200Страница1.Свойство("Приложение3") Тогда
		ОтметкаПриложение3 = ?(ЗначениеЗаполнено(Форма.СтруктураДанныхФорма200Страница1["Приложение3"]), Истина, Ложь);
	КонецЕсли;

	Если Не ЗначениеЗаполнено(ТабличныйДокумент.Области["ИИН_БИН"].Значение) Тогда
		ТабличныйДокумент.Области["ИИН_БИН"].Значение = СведенияОбОрганизации.ИННЮЛ;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТабличныйДокумент.Области["Квартал"].Значение) Тогда
		ТабличныйДокумент.Области["Квартал"].Значение = СтруктураРеквизитовФормы.мКвартал;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТабличныйДокумент.Области["Год"].Значение) Тогда
		ТабличныйДокумент.Области["Год"].Значение = СтруктураРеквизитовФормы.мГод;
	КонецЕсли;
	
	Если ТабличныйДокумент.Области.Найти("ОргНазв") <> Неопределено Тогда
		ТабличныйДокумент.Области["ОргНазв"].Значение = СведенияОбОрганизации.НаимЮЛПол;
		Если ТабличныйДокумент.Области.Найти("ОргНазв3") <> Неопределено Тогда
			НачПозиция = 1;
			Для Шаг = 1 По 3 Цикл
				ДлинаСтроки = ТабличныйДокумент.Области["ОргНазв" + Шаг].ТипЗначения.КвалификаторыСтроки.Длина;
				НазОрганизации = Сред(СведенияОбОрганизации.НаимЮЛПол, НачПозиция, ДлинаСтроки); 
				ТабличныйДокумент.Области["ОргНазв" + Шаг].Значение = НазОрганизации;
				НачПозиция =НачПозиция + ДлинаСтроки;
			КонецЦикла
		Иначе
			НачПозиция = 1;
			Для Шаг = 1 По 2 Цикл
				ДлинаСтроки = ТабличныйДокумент.Области["ОргНазв" + Шаг].ТипЗначения.КвалификаторыСтроки.Длина;
				НазОрганизации = Сред(СведенияОбОрганизации.НаимЮЛПол, НачПозиция, ДлинаСтроки); 
				ТабличныйДокумент.Области["ОргНазв" + Шаг].Значение = НазОрганизации;
				НачПозиция =НачПозиция + ДлинаСтроки;
			КонецЦикла
		КонецЕсли;
	КонецЕсли;
	
	Если ТабличныйДокумент.Области.Найти("Руководитель") <> Неопределено
			И Не ЗначениеЗаполнено(ТабличныйДокумент.Области["Руководитель"].Значение) Тогда
		ТабличныйДокумент.Области["Руководитель"].Значение = СведенияОбОрганизации.ФИОРук;
	КонецЕсли;
	
	Если ТабличныйДокумент.Области.Найти("РуководительПрил3") <> Неопределено
		И Не ЗначениеЗаполнено(ТабличныйДокумент.Области["РуководительПрил3"].Значение) Тогда
		
		ТабличныйДокумент.Области["РуководительПрил3"].Значение = ?(ОтметкаПриложение3, СведенияОбОрганизации.ФИОРук, "");
		
	КонецЕсли;

	Резидент = ?(Лев(СведенияОбОрганизации.КБе,1) = "2", Ложь, Истина);
	
	Если ТабличныйДокумент.Области.Найти("Резидент") <> Неопределено
			И Не ЗначениеЗаполнено(ТабличныйДокумент.Области["Резидент"].Значение) Тогда
		ТабличныйДокумент.Области["Резидент"].Значение = ?(Резидент,    "Х", "");
	КонецЕсли;
	
	Если ТабличныйДокумент.Области.Найти("Нерезидент") <> Неопределено
			И Не ЗначениеЗаполнено(ТабличныйДокумент.Области["Нерезидент"].Значение) Тогда
		ТабличныйДокумент.Области["Нерезидент"].Значение = ?(НЕ Резидент, "Х", "");
	КонецЕсли;
	
	Если ТабличныйДокумент.Области.Найти("ПоУведомлению") <> Неопределено Тогда
        
        Если ТабличныйДокумент.Области["ПоУведомлению"].Значение = "Х" Тогда
            ТабличныйДокумент.Области.НомерУведомления.Защита = Ложь;
            ТабличныйДокумент.Области.ДатаУведомления.Защита = Ложь;
        Иначе  
            Если НЕ Ликвидационная Тогда
                Если ТабличныйДокумент.Области.Найти("Очередная") <> Неопределено И
                    ТабличныйДокумент.Области["Очередная"].Значение = "" И
                    ТабличныйДокумент.Области["Дополнительная"].Значение = "" И
                    ТабличныйДокумент.Области["Ликвидационная"].Значение = "" И
                    ТабличныйДокумент.Области["Первоначальная"].Значение = "" Тогда
                    ТабличныйДокумент.Области["Очередная"].Значение = "Х";                   
                КонецЕсли;
                
                Если ТабличныйДокумент.Области.Найти("ОчереднаяПрил3") <> Неопределено И
                    ТабличныйДокумент.Области["ОчереднаяПрил3"].Значение = "" И
                    ТабличныйДокумент.Области["Дополнительная"].Значение = "" И 
                    ТабличныйДокумент.Области["Ликвидационная"].Значение = "" И
                    ТабличныйДокумент.Области["Первоначальная"].Значение = "" Тогда
                    ТабличныйДокумент.Области["ОчереднаяПрил3"].Значение = ?(ОтметкаПриложение3, "Х", "");
                КонецЕсли;
            Иначе
                Если ТабличныйДокумент.Области.Найти("Очередная") <> Неопределено И
                    ТабличныйДокумент.Области["Очередная"].Значение = "" И
                    ТабличныйДокумент.Области["Дополнительная"].Значение = "" И
                    ТабличныйДокумент.Области["Ликвидационная"].Значение = "" И
                    ТабличныйДокумент.Области["Первоначальная"].Значение = "" Тогда
                    ТабличныйДокумент.Области["Ликвидационная"].Значение = "Х";                   
                КонецЕсли;
                
                Если ТабличныйДокумент.Области.Найти("ОчереднаяПрил3") <> Неопределено И
                    ТабличныйДокумент.Области["ОчереднаяПрил3"].Значение = "" И
                    ТабличныйДокумент.Области["Дополнительная"].Значение = "" И 
                    ТабличныйДокумент.Области["Ликвидационная"].Значение = "" И
                    ТабличныйДокумент.Области["Первоначальная"].Значение = "" Тогда
                    ТабличныйДокумент.Области["Ликвидационная"].Значение = ?(ОтметкаПриложение3, "Х", "");
                КонецЕсли;
            КонецЕсли;
        КонецЕсли;
    КонецЕсли;
	
	Если ТабличныйДокумент.Области.Найти("КодНалоговогоОрганаИПН") <> Неопределено И ТабличныйДокумент.Области.Найти("КодНалоговогоОрганаОПВиСО") <> Неопределено 
																				   И СтруктураРеквизитовФормы.НаимТекущегоРаздела ="Форма200Страница3" Тогда
		КодНалоговогоОргана = ?(СтруктураРеквизитовФормы.Организация.РегистрацияВНалоговомОргане = Неопределено,"",СтруктураРеквизитовФормы.Организация.РегистрацияВНалоговомОргане.Код);
		Если Не ЗначениеЗаполнено(ТабличныйДокумент.Области["КодНалоговогоОрганаИПН"].Значение) Тогда
			ТабличныйДокумент.Области["КодНалоговогоОрганаИПН"].Значение = КодНалоговогоОргана;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(ТабличныйДокумент.Области["КодНалоговогоОрганаОПВиСО"].Значение) Тогда
			ТабличныйДокумент.Области["КодНалоговогоОрганаОПВиСО"].Значение = КодНалоговогоОргана;
		КонецЕсли;
	КонецЕсли;

	Если ТабличныйДокумент.Области.Найти("КодВалюты") <> Неопределено Тогда
		ТабличныйДокумент.Области.КодВалюты.Значение = "KZT";
	КонецЕсли;
	
	Если ТабличныйДокумент.Области.Найти("ДатаПодачи") <> Неопределено
			И Не ЗначениеЗаполнено(ТабличныйДокумент.Области["ДатаПодачи"].Значение) Тогда
		ТабличныйДокумент.Области.ДатаПодачи.Значение = ТекущаяДата();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВосстановитьСохраненныеДанные()
	
	Перем ДанныеМногострочныхРазделов;
	Перем ПоказателиОтчета;
	Перем СтруктураФорма200_03;
	Перем СтруктураФорма200_06;
	Перем СписокСтруктурныхЕдиниц;
	Перем СписокРегистраций;
	Перем НалоговыйКомитет;
		
	// восстанавливаем сохраненные данные отчета
	СписокСохранения = СтруктураРеквизитовФормы.мСохраненныйДок.ДанныеОтчета.Получить();
	
	// восстановим сохраненные данные редактируемых ячеек
	СписокСохранения.Свойство("ПоказателиОтчета", ПоказателиОтчета);
	СписокСохранения.Свойство("СписокСтруктурныхЕдиниц", СписокСтруктурныхЕдиниц);
	СписокСохранения.Свойство("СписокРегистраций", СписокРегистраций);
	СписокСохранения.Свойство("НалоговыйКомитет", НалоговыйКомитет);
	СписокСохранения.Свойство("ПорядокОбложенияДоходовРаботников", ПорядокОбложенияДоходовРаботников);
	
	Если СписокСохранения.Свойство( "ДанныеМногострочныхРазделов", ДанныеМногострочныхРазделов) Тогда
		
		Для Каждого ЭлементСтруктуры Из ДанныеМногострочныхРазделов Цикл
			
			НайденноеЗначение = Неопределено;
			мСтруктураМногострочныхРазделов.Свойство(ЭлементСтруктуры.Ключ, НайденноеЗначение);
			
			// поддержим новую колонку в сохраненных отчетах
			Если ЭлементСтруктуры.Ключ = "П0002100001"
				ИЛИ ЭлементСтруктуры.Ключ = "П0005100002"
                ИЛИ ЭлементСтруктуры.Ключ = "П0006100002" Тогда
				
				Если ЭлементСтруктуры.Значение.Колонки.Найти(ЭлементСтруктуры.Ключ + "02Ссылка") = Неопределено Тогда
					ЭлементСтруктуры.Значение.Колонки.Добавить(ЭлементСтруктуры.Ключ + "02Ссылка", 	Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));	
				КонецЕсли;
				
			КонецЕсли;
			
			Если НЕ НайденноеЗначение = Неопределено Тогда
				ЗначениеВДанныеФормы(ЭлементСтруктуры.Значение, ЭтаФорма[НайденноеЗначение]);
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли;	

	Префикс = "ПолеТабличногоДокумента";
	
	Для Каждого Раздел Из мДеревоСтраницОтчета.ПолучитьЭлементы() Цикл
		
		Если Раздел.ИмяСтраницы = "Форма200_03Страница1"
			ИЛИ Раздел.ИмяСтраницы = "Форма200_03Страница2"
			ИЛИ Раздел.ИмяСтраницы = "Форма200_06Страница1"
			ИЛИ Раздел.ИмяСтраницы = "Форма200_06Страница2"
			ИЛИ Раздел.ИмяСтраницы = "Форма200_06Страница3" Тогда
			
			Продолжить;
			
		КонецЕсли;
		
		ЭтаФорма["СтруктураДанных" + Раздел.ИмяСтраницы] = ПоказателиОтчета[Префикс + Раздел.ИмяСтраницы];
	КонецЦикла;
	
	СтруктураФорма200_03 = Новый Структура;
	Если СписокСохранения.Свойство("Форма200_03", СтруктураФорма200_03) Тогда
		
		Для Каждого ЭлементСтруктуры Из СтруктураФорма200_03 Цикл
			
			Если ЭлементСтруктуры.Ключ = "Форма200_03" Тогда
				
				Для Каждого ЭлементФорма200_03 Из ЭлементСтруктуры.Значение Цикл
					
					Страница1 = Новый СписокЗначений;
					
					Страница1.Добавить(ЭлементФорма200_03.Страница1);
					
					ЭлементФорма200_03.Страница1 = Страница1;
					
					Страница2 = Новый СписокЗначений;
					
					Страница2.Добавить(ЭлементФорма200_03.Страница2);
					
					ЭлементФорма200_03.Страница2 = Страница2;
					
				КонецЦикла;
				
				ТаблСтрФорма200_03 = ЭтаФорма["ТаблицаСтраницыФорма200_03"];
				
				ЗначениеВДанныеФормы(ЭлементСтруктуры.Значение, ТаблСтрФорма200_03);
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	СтруктураФорма200_06 = Новый Структура;
	Если СписокСохранения.Свойство("Форма200_06", СтруктураФорма200_06) Тогда
		
		Для Каждого ЭлементСтруктуры Из СтруктураФорма200_06 Цикл
			
			Если ЭлементСтруктуры.Ключ = "Форма200_06" Тогда
				
				ТаблСтрФорма200_06 = ЭтаФорма["ТаблицаСтраницыФорма200_06"];
				
				ЗначениеВДанныеФормы(ЭлементСтруктуры.Значение, ТаблСтрФорма200_06);
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
	СписокСохранения.Свойство("Ликвидационная", Ликвидационная);
	
	СформироватьДеревоРазделовОтчетаНаСервере();
	
	Комментарий = СтруктураРеквизитовФормы.мСохраненныйДок.Комментарий;
	СтруктураРеквизитовФормы.ЕдиницаИзмерения = СтруктураРеквизитовФормы.мСохраненныйДок.ЕдиницаИзмерения;
	СтруктураРеквизитовФормы.ТочностьЕдиницыИзмерения = СтруктураРеквизитовФормы.мСохраненныйДок.ТочностьЕдиницыИзмерения;
	
	мСписокСтруктурныхЕдиниц = СписокСтруктурныхЕдиниц;
	НалоговыйКомитетФорма = НалоговыйКомитет;
	РегламентированнаяОтчетность.ОперацииПриВосстановленииРегламентированногоОтчета(ЭтаФорма);
	
	КопироватьДанныеФормы(мДеревоСтраницОтчета, мДеревоВыбранныхСтраниц);
	
КонецПроцедуры

&НаСервере
Процедура НачальныеОперацииСМногострочнымиБлоками()
	Перем ИсходноеКоличествоСтрокГруппы;

	// создаем исходную структуру многострочных разделов
	Для Каждого ЭлементСтруктуры Из мСтруктураМногострочныхРазделов Цикл
		ИмяГруппы = ЭлементСтруктуры.Ключ;
		Если ТипЗнч(ЭлементСтруктуры.Значение) = Тип("Структура") Тогда // многостраничный раздел
			СтруктураГруппы = ПолучитьСтруктуруМногостраничногоПриложения(ЭтаФорма, ЭлементСтруктуры.Значение, 0);
		Иначе
			СтруктураГруппы = ЭтаФорма[ЭлементСтруктуры.Значение];
		КонецЕсли;
		
		мСтруктураИсхКолвоСтрокРазделов.Свойство(ИмяГруппы, ИсходноеКоличествоСтрокГруппы);

		Если ИсходноеКоличествоСтрокГруппы > СтруктураГруппы.Количество() Тогда 
			Для НСтр = 1 По ИсходноеКоличествоСтрокГруппы Цикл
				СтруктураГруппы.Добавить();
			КонецЦикла;
		КонецЕсли;

	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура РазделыОтчетаПриАктивизацииСтроки(Элемент)
	
	ДоступнаВыгрузкаПриложений = СтрНайти(Элемент.ТекущиеДанные.КолонкаРазделыОтчета, "200.03") > 0 ;
	Элементы.ВыгрузитьВXMLПриложение20003.Видимость = ДоступнаВыгрузкаПриложений;
	
	Если Элемент.ТекущиеДанные = Неопределено
		ИЛИ (Элемент.ТекущиеДанные.КолонкаРазделыОтчетаСокрНаим = СтруктураРеквизитовФормы.НаимТекущегоРаздела
		И Элемент.ТекущиеДанные.КолонкаНомерСтраницыРазделаОтчета = СтруктураРеквизитовФормы.НомерСтраницыТекущегоРаздела) Тогда
		Возврат;
	КонецЕсли;
	
	Элементы.ОчиститьТекущуюСтраницу.Видимость = НЕ Элемент.ТекущиеДанные.РазделМногостраничный;
	
	СохранитьДанныеРаздела(СтруктураРеквизитовФормы.НаимТекущегоРаздела);
	ВывестиМакетСтраницыВТабличныйДокументНаСервере(Элемент.ТекущиеДанные.КолонкаРазделыОтчетаСокрНаим, Элемент.ТекущиеДанные.КолонкаНомерСтраницыРазделаОтчета);
	Элементы.ТабличныйДокумент.ТекущаяОбласть = ТабличныйДокумент.Область(1, 1);
	ЗаполнитьСведенияОбОрганизацииНаСервере();
	
	ДоступнаРасшифровкаПоФизЛицу = СтрНайти(Элемент.ТекущиеДанные.КолонкаРазделыОтчета, "200.02") > 0 
                                    ИЛИ СтрНайти(Элемент.ТекущиеДанные.КолонкаРазделыОтчета, "200.05") > 0
                                    ИЛИ СтрНайти(Элемент.ТекущиеДанные.КолонкаРазделыОтчета, "200.06") > 0;
	Элементы.РасшифроватьПоФизЛицу.Видимость = ДоступнаРасшифровкаПоФизЛицу;	
	Элементы.Расшифровать.Видимость  = НЕ ДоступнаРасшифровкаПоФизЛицу;	
    
КонецПроцедуры

&НаСервере
Процедура ВывестиМакетСтраницыВТабличныйДокументНаСервере(ИмяТекРаздела,НомерСтраницыРазделаОтчета = 1)
	
	ВывестиМакетВТаблДокНаСервере(ИмяТекРаздела,НомерСтраницыРазделаОтчета) ;
	СтруктураРеквизитовФормы.НаимТекущегоРаздела  = ИмяТекРаздела;
	СтруктураРеквизитовФормы.НомерСтраницыТекущегоРаздела = НомерСтраницыРазделаОтчета;
	
КонецПроцедуры

&НаСервере
Процедура ВывестиМакетВТаблДокНаСервере(ИмяТекРаздела,НомерСтраницыРазделаОтчета)
	
	ТабличныйДокумент.Очистить();
	ТабличныйДокумент.Вывести(Отчеты[ИмяОтчета(ЭтаФорма.ИмяФормы)].ПолучитьМакет(СтрЗаменить(Сред(
		ЭтаФорма.ИмяФормы, СтрНайти(ЭтаФорма.ИмяФормы, "ФормаОтчета")), "Кв4", "Кв1") + "_" + ИмяТекРаздела));
		
	//многострочные разделы
	Если ИмяТекРаздела = "Форма200_02Страница1"
		ИЛИ ИмяТекРаздела = "Форма200_02Страница2"
		ИЛИ ИмяТекРаздела = "Форма200_02Страница3"
		ИЛИ ИмяТекРаздела = "Форма200_02Страница4"
		ИЛИ ИмяТекРаздела = "Форма200_02Страница5"
		ИЛИ ИмяТекРаздела = "Форма200_02Страница6"
		ИЛИ ИмяТекРаздела = "Форма200_02Страница7"
		ИЛИ ИмяТекРаздела = "Форма200_02Страница8"
		ИЛИ ИмяТекРаздела = "Форма200_02Страница9"
		ИЛИ ИмяТекРаздела = "Форма200_05Страница1"
		ИЛИ ИмяТекРаздела = "Форма200_05Страница2"
		ИЛИ ИмяТекРаздела = "Форма200_05Страница3"
		ИЛИ ИмяТекРаздела = "Форма200_05Страница4"
		ИЛИ ИмяТекРаздела = "Форма200_05Страница5"
		ИЛИ ИмяТекРаздела = "Форма200_05Страница6"
		ИЛИ ИмяТекРаздела = "Форма200_05Страница7" Тогда
		
		СтруктураДанныхРаздела = ЭтаФорма["СтруктураДанных" + ИмяТекРаздела];
		
		Для Каждого ЭлСтруктуры Из СтруктураДанныхРаздела Цикл
			Попытка
				ТабличныйДокумент.Области[ЭлСтруктуры.Ключ].Значение = ЭлСтруктуры.Значение;
			Исключение
			КонецПопытки;
		КонецЦикла;
		
		ТекТабличноеПоле = ЭтаФорма.ТабличныйДокумент;
		
		ИмяГруппы = ОпределитьИдМногострочногоРазделаПоАктивнойСтраницеНаСервере(ИмяТекРаздела);
		
		СтруктураГруппы = Неопределено;
		
		мСтруктураМногострочныхРазделов.Свойство(ИмяГруппы, СтруктураГруппы);
		
		СтруктураГруппы = ЭтаФорма[СтруктураГруппы];
		
		ВывестиРазделВТабличныйДокумент(ЭтаФорма, ИмяГруппы, СтруктураГруппы);
		
		ВывестиКнопкиУдалитьСтроку(ТекТабличноеПоле);
		
	ИначеЕсли ИмяТекРаздела = "Форма200_03Страница1" Тогда
		
		Если ЭтаФорма[мСтруктураФорма200_03Страница1и2.Форма200_03].Количество() = 0 Тогда
			ПостроениеПервоначальнойСтруктурыНаСервере(Истина, ИмяТекРаздела);
		КонецЕсли;
		
		ТаблицаСтраницРаздела = Неопределено;
		
		мСтруктураФорма200_03Страница1и2.Свойство("Форма200_03", ТаблицаСтраницРаздела);
		
		ТаблицаСтраницРаздела = ЭтаФорма[ТаблицаСтраницРаздела];
		
		СтрСледующаяСтраница = ТаблицаСтраницРаздела[НомерСтраницыРазделаОтчета - 1];
		
		СтрСледующаяСтраница.АктивнаяСтраница = Истина;
		
		СтруктураДанныхСледующаяСтраница = СтрСледующаяСтраница.Страница1[0].Значение;
		
		Если СтруктураДанныхСледующаяСтраница <> Неопределено Тогда
			Для Каждого Элемент Из СтруктураДанныхСледующаяСтраница Цикл
				ИмяПоказателя      = Элемент.Ключ;
				ЗначениеПоказателя = Элемент.Значение;
												
				Попытка
					ТабличныйДокумент.Области[ИмяПоказателя].Значение = ЗначениеПоказателя;
				Исключение
				КонецПопытки;
			КонецЦикла;
		КонецЕсли;
		
		УстановитьДоступностьКнопкиУдалитьСтраницу(ТаблицаСтраницРаздела);
		
	ИначеЕсли ИмяТекРаздела = "Форма200_03Страница2" Тогда
		
		Если ЭтаФорма[мСтруктураФорма200_03Страница1и2.Форма200_03].Количество() = 0 Тогда
			ПостроениеПервоначальнойСтруктурыНаСервере(Истина, ИмяТекРаздела);
			НомерСтраницыФорма200_03Страница2Отчета = 1;
		КонецЕсли;
		
		ТаблицаСтраницРаздела = Неопределено;
		
		мСтруктураФорма200_03Страница1и2.Свойство("Форма200_03", ТаблицаСтраницРаздела);
		
		ТаблицаСтраницРаздела = ЭтаФорма[ТаблицаСтраницРаздела];
		
		СтрТаблицаСтраницы = ТаблицаСтраницРаздела[НомерСтраницыРазделаОтчета - 1];
		
		СтрСледующаяСтраница = СтрТаблицаСтраницы.Страница2[0].Значение;
		
		СтрТаблицаСтраницы.АктивнаяСтраница = Истина;
		
		Если СтрСледующаяСтраница <> Неопределено Тогда
			Для Каждого Элемент Из СтрСледующаяСтраница Цикл
				ИмяПоказателя      = Элемент.Ключ;
				ЗначениеПоказателя = Элемент.Значение;
					
				Попытка
					ТабличныйДокумент.Области[ИмяПоказателя].Значение = ЗначениеПоказателя;
				Исключение
				КонецПопытки;
				
			КонецЦикла;
		КонецЕсли;
		
	ИначеЕсли ИмяТекРаздела = "Форма200_06Страница1" Тогда
		
		Если ЭтаФорма[мСтруктураФорма200_06Страницы.Форма200_06].Количество() = 0 Тогда
			ПостроениеПервоначальнойСтруктурыНаСервере(Истина, ИмяТекРаздела);
		КонецЕсли;
		
		ТаблицаСтраницРаздела = Неопределено;
		
		мСтруктураФорма200_06Страницы.Свойство("Форма200_06", ТаблицаСтраницРаздела);
		
		ТаблицаСтраницРаздела = ЭтаФорма[ТаблицаСтраницРаздела];
		
		СтрСледующаяСтраница = ТаблицаСтраницРаздела[НомерСтраницыРазделаОтчета - 1];
		
		Если НЕ СтруктураРеквизитовФормы.мРежимПечати Тогда
			СтрСледующаяСтраница.АктивнаяСтраница = Истина;
		КонецЕсли;
		
		ВывестиШапкуВТабличныйДокумент200_06(ТабличныйДокумент, СтрСледующаяСтраница, НомерСтраницыРазделаОтчета);
		
		ВывестиРазделВТабличныйДокумент200_06(ЭтаФорма, ОпределитьИдМногострочногоРазделаПоАктивнойСтраницеНаСервере(ИмяТекРаздела), СтрСледующаяСтраница.Страница1, СтрСледующаяСтраница.Страница1Итоги);
		
		УстановитьДоступностьКнопкиУдалитьСтраницу(ТаблицаСтраницРаздела);
		
		ВывестиКнопкиУдалитьСтроку(ЭтаФорма.ТабличныйДокумент);
		
	ИначеЕсли ИмяТекРаздела = "Форма200_06Страница2" Тогда
		
		Если ЭтаФорма[мСтруктураФорма200_06Страницы.Форма200_06].Количество() = 0 Тогда
			ПостроениеПервоначальнойСтруктурыНаСервере(Истина, ИмяТекРаздела);
		КонецЕсли;
		
		ТаблицаСтраницРаздела = Неопределено;
		
		мСтруктураФорма200_06Страницы.Свойство("Форма200_06", ТаблицаСтраницРаздела);
		
		ТаблицаСтраницРаздела = ЭтаФорма[ТаблицаСтраницРаздела];
		
		СтрСледующаяСтраница = ТаблицаСтраницРаздела[НомерСтраницыРазделаОтчета - 1];
		
		Если НЕ СтруктураРеквизитовФормы.мРежимПечати Тогда
			СтрСледующаяСтраница.АктивнаяСтраница = Истина;
		КонецЕсли;
		
		ВывестиШапкуВТабличныйДокумент200_06(ТабличныйДокумент, СтрСледующаяСтраница, НомерСтраницыРазделаОтчета);
		
		ВывестиРазделВТабличныйДокумент200_06(ЭтаФорма, ОпределитьИдМногострочногоРазделаПоАктивнойСтраницеНаСервере(ИмяТекРаздела), СтрСледующаяСтраница.Страница2, СтрСледующаяСтраница.Страница2Итоги);
		
		УстановитьДоступностьКнопкиУдалитьСтраницу(ТаблицаСтраницРаздела);
		
		ВывестиКнопкиУдалитьСтроку(ЭтаФорма.ТабличныйДокумент);
		
	ИначеЕсли ИмяТекРаздела = "Форма200_06Страница3" Тогда
		
		Если ЭтаФорма[мСтруктураФорма200_06Страницы.Форма200_06].Количество() = 0 Тогда
			ПостроениеПервоначальнойСтруктурыНаСервере(Истина, ИмяТекРаздела);
		КонецЕсли;
		
		ТаблицаСтраницРаздела = Неопределено;
		
		мСтруктураФорма200_06Страницы.Свойство("Форма200_06", ТаблицаСтраницРаздела);
		
		ТаблицаСтраницРаздела = ЭтаФорма[ТаблицаСтраницРаздела];
		
		СтрСледующаяСтраница = ТаблицаСтраницРаздела[НомерСтраницыРазделаОтчета - 1];
		
		Если НЕ СтруктураРеквизитовФормы.мРежимПечати Тогда
			СтрСледующаяСтраница.АктивнаяСтраница = Истина;
		КонецЕсли;
		
		ВывестиШапкуВТабличныйДокумент200_06(ТабличныйДокумент, СтрСледующаяСтраница, НомерСтраницыРазделаОтчета);
		
		ВывестиРазделВТабличныйДокумент200_06(ЭтаФорма, ОпределитьИдМногострочногоРазделаПоАктивнойСтраницеНаСервере(ИмяТекРаздела), СтрСледующаяСтраница.Страница3, СтрСледующаяСтраница.Страница3Итоги);
		
		УстановитьДоступностьКнопкиУдалитьСтраницу(ТаблицаСтраницРаздела);
		
		ВывестиКнопкиУдалитьСтроку(ЭтаФорма.ТабличныйДокумент);
		
	ИначеЕсли ЭтаФорма["СтруктураДанных" + ИмяТекРаздела]<> Неопределено Тогда
		
		Для Каждого ЭлСтруктуры Из ЭтаФорма["СтруктураДанных" + ИмяТекРаздела] Цикл
			Попытка
				ТабличныйДокумент.Области[ЭлСтруктуры.Ключ].Значение = ЭлСтруктуры.Значение;
			Исключение
			КонецПопытки;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ВывестиКнопкиУдалитьСтроку(ТекТабличноеПоле)
	
	ЕстьДопСтроки = Ложь;
	
	Для Каждого ОбластьТД Из ТекТабличноеПоле.Области Цикл
		Если СтрЧислоВхождений(ОбластьТД.Имя, "_2") > 0 Тогда
			ЕстьДопСтроки = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если ЕстьДопСтроки Тогда
		Для Каждого ОбластьТД Из ТекТабличноеПоле.Области Цикл
			Если СтрЧислоВхождений(ОбластьТД.Имя, "УдалитьСтроку") > 0 Тогда
				ОбластьТД.Гиперссылка = Истина;
				ОбластьТД.Текст = "х";
			КонецЕсли;
		КонецЦикла;
	Иначе
		Для Каждого ОбластьТД Из ТекТабличноеПоле.Области Цикл
			Если СтрЧислоВхождений(ОбластьТД.Имя, "УдалитьСтроку") > 0 Тогда
				ОбластьТД.Гиперссылка = Ложь;
				ОбластьТД.Текст = "";
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ВывестиШапкуВТабличныйДокумент200_06(ТабличныйДокумент, СтрСледующаяСтраница, НомерСтраницыРазделаОтчета)
	
