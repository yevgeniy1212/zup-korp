&НаКлиенте
Процедура ОткрытьФормуРасшифровки(ИмяЯчейки, ИмяКоманды)
	
	ПараметрыОтчета = Новый Структура();
	НомерФормы = Сред(ИмяЯчейки,5,1);
	НомерМесяца = Сред(ИмяЯчейки,11,1);
	НомерСтроки = ПолучитьНомерСтрокиПоЯчейке(ИмяЯчейки);
	НомерСтраницы = Сред(ИмяЯчейки,6,1);
	
	Если НомерФормы = "2" ИЛИ (НомерФормы = "5" И Число(СтруктураРеквизитовФормы.мГод) < 2025) ИЛИ НомерФормы = "6" Тогда
		ДатаНачала = СтруктураРеквизитовФормы.мДатаНачалаПериодаОтчета;
		ДатаОкончания = СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета;
	ИначеЕсли НомерФормы = "5" Тогда
		ДатаНачала = НачалоГода(СтруктураРеквизитовФормы.мДатаНачалаПериодаОтчета);
		ДатаОкончания = СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета;
	ИначеЕсли НомерМесяца = "1" Тогда // месяц 1
		ДатаНачала = СтруктураРеквизитовФормы.мДатаНачалаПериодаОтчета;
		ДатаОкончания = КонецМесяца(ДатаНачала);
	ИначеЕсли НомерМесяца = "2" Тогда // месяц 2
		ДатаНачала = ДобавитьМесяц(СтруктураРеквизитовФормы.мДатаНачалаПериодаОтчета,1);
		ДатаОкончания = КонецМесяца(ДатаНачала);
	ИначеЕсли НомерМесяца = "3" Тогда // месяц 3
		ДатаНачала = ДобавитьМесяц(СтруктураРеквизитовФормы.мДатаНачалаПериодаОтчета,2);
		ДатаОкончания = КонецМесяца(ДатаНачала);
	Иначе // итог или другие ячейки
		ДатаНачала = СтруктураРеквизитовФормы.мДатаНачалаПериодаОтчета;
		ДатаОкончания = СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета;
	КонецЕсли;

	ПараметрыОтчета.Вставить("Организация",              СтруктураРеквизитовФормы.Организация);
	ПараметрыОтчета.Вставить("ДатаНачалаПериодаОтчета",  ДатаНачала);
	ПараметрыОтчета.Вставить("ДатаКонцаПериодаОтчета",   ДатаОкончания);
	ПараметрыОтчета.Вставить("СписокСтруктурныхЕдиниц",  мСписокСтруктурныхЕдиниц);
	ПараметрыОтчета.Вставить("НалоговыйКомитет",         СтруктураРеквизитовФормы.НалоговыйКомитет);
	ПараметрыОтчета.Вставить("Форма",                    НомерФормы);
	
	ПараметрыОтчета.Вставить("ЗаголовокРасшифровки",     "Расшифровка ""Регламентированный отчет форма 200.0" + НомерФормы + """");
	
	Если РегламентированнаяОтчетностьРК.ИндивидуальныйПредприниматель(СтруктураРеквизитовФормы.Организация) Тогда
		ПараметрыОтчета.Вставить("ИндивидуальныйПредприниматель", Истина);
	Иначе
		ПараметрыОтчета.Вставить("ИндивидуальныйПредприниматель", Ложь);
	КонецЕсли;
	
	ДанныеИПИСотрудников = ДанныеИПИСотрудников();
	ДанныеИндивидуальногоПредпринимателя = ДанныеИндивидуальногоПредпринимателя();
	
	Если НЕ ДанныеИПИСотрудников.Найти(ИмяЯчейки) = Неопределено Тогда
		ПараметрыОтчета.Вставить("ЭтоРасшиврофкаИП", Неопределено);
	ИначеЕсли ДанныеИндивидуальногоПредпринимателя.Найти(ИмяЯчейки) = Неопределено Тогда
		ПараметрыОтчета.Вставить("ЭтоРасшиврофкаИП", Ложь);
	Иначе
		ПараметрыОтчета.Вставить("ЭтоРасшиврофкаИП", Истина);
	КонецЕсли;
	
	Если НомерФормы = "0" Тогда
		
		Если СтруктураДанныхФорма200Страница1.Свойство("РегистрацияВНО") Тогда
			Если ЗначениеЗаполнено(СтруктураДанныхФорма200Страница1.РегистрацияВНО) Тогда
				ПараметрыОтчета.Вставить("РегистрацияВНО", СтруктураДанныхФорма200Страница1.РегистрацияВНО);
			КонецЕсли;
		КонецЕсли;
		
		Если ПорядокОбложенияДоходовРаботников = ПредопределенноеЗначение("Перечисление.ПорядокОбложенияДоходовРаботников.ЕдиныйПлатеж") Тогда
			МассивПриложений = Новый Массив;
			Если Лев(ИмяЯчейки,10) = "П000030014" Тогда // поле единого платежа
				ПараметрыОтчета.Вставить("СписокФизическихЛиц", ПолучитьСписокФизическихЛицПриложения200_06("П0006100002"));
			ИначеЕсли НЕ (Лев(ИмяЯчейки,10) = "П000020003"
				ИЛИ Лев(ИмяЯчейки,10) = "П000020005" // поля общих доходов
				ИЛИ Лев(ИмяЯчейки,10) = "П000020004"
				ИЛИ Лев(ИмяЯчейки,10) = "П000020009"
				ИЛИ Лев(ИмяЯчейки,10) = "П000030012") Тогда // поля ИП
				МассивПриложений.Добавить("П0002100001");
				МассивПриложений.Добавить("П0005100002");
				ПараметрыОтчета.Вставить("СписокФизическихЛиц", ПолучитьСписокФизическихЛицПриложения(МассивПриложений));
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли НомерФормы = "3" Тогда
		
		Для Каждого СтрокаТаблицы200_03 Из ТаблицаСтраницыФорма200_03 Цикл
			
			Если СтрокаТаблицы200_03.АктивнаяСтраница Тогда
				
				Если СтрокаТаблицы200_03.Страница1[0].Значение.Свойство("РегистрацияВНО") Тогда
					Если ЗначениеЗаполнено(СтрокаТаблицы200_03.Страница1[0].Значение.РегистрацияВНО) Тогда
						ПараметрыОтчета.Вставить("РегистрацияВНО", СтрокаТаблицы200_03.Страница1[0].Значение.РегистрацияВНО);
					КонецЕсли;						
				КонецЕсли;
				Если СтрокаТаблицы200_03.Страница1[0].Значение.Свойство("ОрганизацияФилиала") Тогда
					Если ЗначениеЗаполнено(СтрокаТаблицы200_03.Страница1[0].Значение.ОрганизацияФилиала) Тогда
						ПараметрыОтчета.Вставить("Организация", СтрокаТаблицы200_03.Страница1[0].Значение.ОрганизацияФилиала);
					КонецЕсли;						
				КонецЕсли;
				Если ПорядокОбложенияДоходовРаботников = ПредопределенноеЗначение("Перечисление.ПорядокОбложенияДоходовРаботников.ЕдиныйПлатеж") И Лев(ИмяЯчейки,10) = "П000320009" Тогда
					ИИН_БИНФилиала = 0;
					Если СтрокаТаблицы200_03.Страница1[0].Значение.Свойство("ИИН_БИНФилиала") Тогда
						Если ЗначениеЗаполнено(СтрокаТаблицы200_03.Страница1[0].Значение.ИИН_БИНФилиала) Тогда
							ИИН_БИНФилиала = Число(СтрокаТаблицы200_03.Страница1[0].Значение.ИИН_БИНФилиала);
						КонецЕсли;
					КонецЕсли;
					ПараметрыОтчета.Вставить("СписокФизическихЛиц", ПолучитьСписокФизическихЛицПриложения200_06("П0006100002", ИИН_БИНФилиала));
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если ПорядокОбложенияДоходовРаботников = ПредопределенноеЗначение("Перечисление.ПорядокОбложенияДоходовРаботников.ЕдиныйПлатеж") Тогда
			МассивПриложений = Новый Массив;
			Если НЕ (Лев(ИмяЯчейки,10) = "П000310003" ИЛИ Лев(ИмяЯчейки,10) = "П000320004" // поля общих доходов
				ИЛИ Лев(ИмяЯчейки,10) = "П000320009") Тогда // поле единого платежа
				МассивПриложений.Добавить("П0002100001");
				МассивПриложений.Добавить("П0005100002");
				ПараметрыОтчета.Вставить("СписокФизическихЛиц", ПолучитьСписокФизическихЛицПриложения(МассивПриложений));
			КонецЕсли;
		КонецЕсли;
		
	ИначеЕсли НомерФормы = "1" И ПорядокОбложенияДоходовРаботников = ПредопределенноеЗначение("Перечисление.ПорядокОбложенияДоходовРаботников.ЕдиныйПлатеж") Тогда
		
		Если НЕ (Лев(ИмяЯчейки,10) = "П000110010"
			ИЛИ Лев(ИмяЯчейки,10) = "П000120016" // поля общих доходов
			ИЛИ Лев(ИмяЯчейки,10) = "П000120018"
			ИЛИ Лев(ИмяЯчейки,10) = "П000130021") Тогда // поля ИП
				МассивПриложений = Новый Массив;
				МассивПриложений.Добавить("П0002100001");
				МассивПриложений.Добавить("П0005100002");
				ПараметрыОтчета.Вставить("СписокФизическихЛиц", ПолучитьСписокФизическихЛицПриложения(МассивПриложений));
		КонецЕсли;
			
	КонецЕсли;	
		
	ИДИменПоказателей = Новый Массив();
	ИДИменПоказателей.Добавить(ИмяЯчейки);
	
	Если ИмяКоманды = "РасшифроватьПоРаботнику" Тогда
		
		Если НомерФормы = "2" Тогда
			ПараметрыОтчета.Вставить("ФизическоеЛицо", П0002100001[НомерСтроки - 1].П000210000102Ссылка);
		ИначеЕсли НомерФормы = "5" Тогда
			ПараметрыОтчета.Вставить("ФизическоеЛицо", П0005100002[НомерСтроки - 1].П000510000202Ссылка);
		ИначеЕсли НомерФормы = "6" Тогда
			ПараметрыОтчета.Вставить("ФизическоеЛицо", ТаблицаСтраницыФорма200_06[Элементы.РазделыОтчета.ТекущиеДанные.КолонкаНомерСтраницыРазделаОтчета - 1].Страница1[НомерСтроки - 1].Значение.П000610000202Ссылка);
		КонецЕсли;
		
	ИначеЕсли ИмяКоманды = "РасшифроватьОбщая" И ПорядокОбложенияДоходовРаботников = ПредопределенноеЗначение("Перечисление.ПорядокОбложенияДоходовРаботников.ЕдиныйПлатеж") Тогда
		
		МассивПриложений = Новый Массив;
		Если НомерФормы = "2" Тогда
			МассивПриложений.Добавить("П0002100001");
			ПараметрыОтчета.Вставить("СписокФизическихЛиц", ПолучитьСписокФизическихЛицПриложения(МассивПриложений));
		ИначеЕсли НомерФормы = "5" Тогда
			МассивПриложений.Добавить("П0005100002");
			ПараметрыОтчета.Вставить("СписокФизическихЛиц", ПолучитьСписокФизическихЛицПриложения(МассивПриложений));
		КонецЕсли;
		
	КонецЕсли;
	
    Если НомерФормы = "6" И (НомерСтраницы = "2" ИЛИ НомерСтраницы = "3") Тогда   
        ПараметрыОтчета.Вставить("РегистрацияВНО",  НалоговыйКомитетФорма);
        ПараметрыОтчета.Вставить("ИмяОтчетаРасшифровки","СтруктураЗадолженностиВзносовИОтчислений");
    Иначе
		ПараметрыОтчета.Вставить("ИмяОтчетаРасшифровки","РегистрНалоговогоУчетаПоИПНиСН");
	КонецЕсли;
	ПараметрыОтчета.Вставить("ИДИменПоказателей",ИДИменПоказателей);
	ПараметрыОтчета.Вставить("ИмяСКД","ОсновнаяСхемаКомпоновкиДанных");
		
	ФормаРасшифровки = ПолучитьФорму("ОбщаяФорма.РасшифровкаРегламентированногоОтчетаЗарплата", ПараметрыОтчета);
	
	Если ФормаРасшифровки = Неопределено Тогда
		ПоказатьПредупреждение(, НСтр("ru='Для выбранной ячейки расшифровка не существует.'"),,
		НСтр("ru = 'Расшифровка регламентированных отчетов'"));
	Иначе
		ФормаРасшифровки.Открыть();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСписокФизическихЛицПриложения(НомераТаблицЗначений)
	
	СписокФизическихЛиц = Новый Массив;
	Для Каждого НомерТаблицыЗначений Из НомераТаблицЗначений Цикл
		НаименованиеКолонкиЗначений = НомерТаблицыЗначений+"02Ссылка";
		ТаблицаЗначенийПриложения = РеквизитФормыВЗначение(НомерТаблицыЗначений);
		ТаблицаЗначенийПриложения.Свернуть(НаименованиеКолонкиЗначений);
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СписокФизическихЛиц, ТаблицаЗначенийПриложения.ВыгрузитьКолонку(НаименованиеКолонкиЗначений), Истина);
	КонецЦикла;
	
	Возврат СписокФизическихЛиц;
	
КонецФункции

&НаСервере
Функция ПолучитьСписокФизическихЛицПриложения200_06(НомерТаблицыЗначений, ИИН_БИНФилиала = 0)
	
	НаименованиеКолонкиЗначений = НомерТаблицыЗначений+"02Ссылка";
	СписокФизическихЛиц = Новый Массив;
	Для Каждого Лист Из ТаблицаСтраницыФорма200_06 Цикл
		Если ЗначениеЗаполнено(ИИН_БИНФилиала) И Лист.ИИН_БИНФилиала <> ИИН_БИНФилиала Тогда
			Продолжить;
		КонецЕсли;
		Для Каждого СтрокаСтраницы Из Лист.Страница1 Цикл
			ФизическоеЛицо = СтрокаСтраницы.Значение[НаименованиеКолонкиЗначений];
			Если СписокФизическихЛиц.Найти(ФизическоеЛицо) = Неопределено Тогда
				СписокФизическихЛиц.Добавить(ФизическоеЛицо);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Возврат СписокФизическихЛиц;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьНомерСтрокиПоЯчейке(ИмяЯчейки, ДлинаНаименованияДоСпецСимвола = 15)
	
	Возврат Сред(ИмяЯчейки, ДлинаНаименованияДоСпецСимвола, СтрДлина(ИмяЯчейки));
	
КонецФункции
	
	
&НаКлиенте
Процедура ОбработкаВыбораЗначений(Результат, ПараметрыВыбора) экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОбработкаВыбораЗначенийНаСервере(Результат, ПараметрыВыбора.ИмяЯчейки);

КонецПроцедуры

&НаСервере
Процедура ОбработкаВыбораЗначенийНаСервере(Результат, ИмяЯчейки) экспорт
	
	Если ТипЗнч(Результат) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
		
		ТаблицаДанных = КадровыйУчет.КадровыеДанныеФизическихЛиц(
			Истина, 
			ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Результат), 
			"ИНН, Фамилия, Имя, Отчество, Страна, СтатусНалогоплательщика, Страна, ИННВСтранеГражданства, ДокументВид, ДокументСерия, ДокументНомер, ДокументДатаВыдачи", 
			СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета);
			
		Если ТаблицаДанных.Количество() > 0 Тогда
			ДанныеФизическогоЛица = ТаблицаДанных[0];	
		Иначе
			Возврат;
		КонецЕсли;
			
		Если Найти(ИмяЯчейки, "П000210000102") > 0 Тогда
			
			НомерСтрокиПоЯчейке = ПолучитьНомерСтрокиПоЯчейке(ИмяЯчейки);
			
			Если ЗначениеЗаполнено(ДанныеФизическогоЛица.СтатусНалогоплательщика) Тогда
				ПризнакНерезидентства = (НЕ ДанныеФизическогоЛица.СтатусНалогоплательщика = Перечисления.СтатусыФизическихЛицНалогоплательщиков.Резидент);
			Иначе
				ПризнакНерезидентства = Истина;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ДанныеФизическогоЛица.Страна) Тогда
				КодСтраны = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеФизическогоЛица.Страна, "КодАльфа2");
				КодСтраныГражданства = ?(ДанныеФизическогоЛица.Страна = Справочники.СтраныМира.Казахстан, "", КодСтраны);
				КодСтраны            = ?(ПризнакНерезидентства, КодСтраны, "KZ");
			Иначе
				КодСтраны = "KZ";
				КодСтраныГражданства = "00";
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ДанныеФизическогоЛица.ДокументВид) Тогда
				КодДокумента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеФизическогоЛица.ДокументВид, "КодМВД");
			Иначе
				КодДокумента = "";
			КонецЕсли;
			
			ЭтотОбъект.ТабличныйДокумент.Области["П000210000103_" + НомерСтрокиПоЯчейке].Значение = ДанныеФизическогоЛица.ИНН;
			
			ЭтотОбъект.ТабличныйДокумент.Области["П000210000105_" + НомерСтрокиПоЯчейке].Значение = ?(ПризнакНерезидентства, "2", "1");
			
			// код страны гражданства
			ЭтотОбъект.ТабличныйДокумент.Области["П000210000104_" + НомерСтрокиПоЯчейке].Значение = КодСтраныГражданства;
			// код страны резидентства
			ЭтотОбъект.ТабличныйДокумент.Области["П000210000106_" + НомерСтрокиПоЯчейке].Значение = КодСтраны;
			
			ЭтаФорма.СтруктураДанныхФорма200_02Страница2.Вставить(СтрЗаменить(ИмяЯчейки, "_", "Ссылка_"), Результат);
			// ИИН в стране гражданства
			ЭтаФорма.П0002200001[НомерСтрокиПоЯчейке - 1]["П000220000102"] = ДанныеФизическогоЛица.ИННВСтранеГражданства;
			// вид докумнента
			ЭтаФорма.П0002200001[НомерСтрокиПоЯчейке - 1]["П000220000103"] = КодДокумента;
			// номер докумнента
			ЭтаФорма.П0002200001[НомерСтрокиПоЯчейке - 1]["П000220000104"] = ?(ЗначениеЗаполнено(ДанныеФизическогоЛица.ДокументСерия), ДанныеФизическогоЛица.ДокументСерия + " ", "") + ДанныеФизическогоЛица.ДокументНомер;
			// дата выдачи докумнента
			ЭтаФорма.П0002200001[НомерСтрокиПоЯчейке - 1]["П000220000105"] = ДанныеФизическогоЛица.ДокументДатаВыдачи;
			ЭтаФорма.П0002300001[НомерСтрокиПоЯчейке - 1]["П000230000102"] =  1200;
			ЭтаФорма.П0002300001[НомерСтрокиПоЯчейке - 1]["П000230000108"] = 10;
			
		ИначеЕсли Найти(ИмяЯчейки, "П000510000202") > 0 Тогда
			
			НомерСтрокиПоЯчейке = ПолучитьНомерСтрокиПоЯчейке(ИмяЯчейки);
			
			ЭтаФорма.СтруктураДанныхФорма200_05Страница1.Вставить(СтрЗаменить(ИмяЯчейки, "_", "Ссылка_"), Результат); 
			
			ЭтотОбъект.ТабличныйДокумент.Области["П000510000203_" + НомерСтрокиПоЯчейке].Значение = ДанныеФизическогоЛица.ИНН;
			
		ИначеЕсли Найти(ИмяЯчейки, "П000610000202") > 0 Тогда
			
			НомерСтрокиПоЯчейке = ПолучитьНомерСтрокиПоЯчейке(ИмяЯчейки);
			
			СтруктураГруппы = ПолучитьСтруктуруМногостраничногоПриложения(ЭтаФорма, мСтруктураМногострочныхРазделов.П0006100002);
			СтруктураГруппы[НомерСтрокиПоЯчейке-1].Значение.Вставить(СтрЗаменить(ИмяЯчейки, "_"+НомерСтрокиПоЯчейке, "Ссылка"), Результат);
			
			ЭтотОбъект.ТабличныйДокумент.Области["П000610000203_" + НомерСтрокиПоЯчейке].Значение = ДанныеФизическогоЛица.ИНН;

			КодСтраны = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеФизическогоЛица.Страна, "КодАльфа2");
			КодСтраныГражданства = ?(ЗначениеЗаполнено(КодСтраны), ?(КодСтраны = "KZ", "KZ", КодСтраны), "00");

			АктивнаяСтраница = ЭтотОбъект.ТаблицаСтраницыФорма200_06.НайтиСтроки(Новый Структура("АктивнаяСтраница", Истина));
			Если АктивнаяСтраница <> Неопределено Тогда
				АктивнаяСтраница[0].Страница3[НомерСтрокиПоЯчейке - 1].Значение.П000630000206 = КодСтраныГражданства;
				АктивнаяСтраница[0].Страница3[НомерСтрокиПоЯчейке - 1].Значение.П000630000207 = "Х";
			КонецЕсли;

		КонецЕсли;
		
		ЭтотОбъект.ТабличныйДокумент.Области[ИмяЯчейки].Значение = СокрЛП(СокрЛП(ДанныеФизическогоЛица.Фамилия) + " " + СокрЛП(ДанныеФизическогоЛица.Имя) + " " + СокрЛП(ДанныеФизическогоЛица.Отчество));
		ЭтотОбъект.ТабличныйДокумент.Области[ИмяЯчейки].Расшифровка = Результат;

	КонецЕсли;
	
	ЭтаФорма.Модифицированность = Истина;
	
КонецПроцедуры

