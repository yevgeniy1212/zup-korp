&НаКлиенте
Процедура ПечатьЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Печать(ДополнительныеПараметры.ВидПечати);
	
КонецПроцедуры

&НаКлиенте
Процедура Расшифровать(Команда)
	
	Если Команда.Имя = "РасшифроватьОбщая" Тогда
		
		ТекущийРазделОтчета = Элементы.РазделыОтчета.ТекущиеДанные.КолонкаРазделыОтчета;
		Если СтрНайти(ТекущийРазделОтчета, "200.02") > 1 Тогда
			ИмяЯчейки = "П000210000102_1";
		ИначеЕсли СтрНайти(ТекущийРазделОтчета, "200.05") > 1 Тогда
			ИмяЯчейки = "П000510000202_1";
		ИначеЕсли СтрНайти(ТекущийРазделОтчета, "200.06") > 1 Тогда
			Если СтрНайти(ТекущийРазделОтчета, "Страница") > 1 Тогда
				НомерСтраницы = Прав(ТекущийРазделОтчета,1);
				Если НомерСтраницы = "1" Тогда
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Для первой страницы поддерживается расшифровка только по физическому лицу.'"));
					Возврат;
				КонецЕсли;
				ИмяЯчейки = "П0006"+НомерСтраницы+"0000202_1";
			Иначе
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Для первой страницы поддерживается расшифровка только по физическому лицу.'"));
				Возврат;
			КонецЕсли;
		КонецЕсли;
		
	Иначе
		
		Попытка
			ИмяЯчейки = ЭтотОбъект.ТекущийЭлемент.ТекущаяОбласть.Имя;
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Активизируйте нужную ячейку отчета для расшифровки.'"));
			Возврат;
		КонецПопытки;
		
	КонецЕсли;
	
	ЦветРасшифровки = Новый Цвет(225, 253, 253);
	Если ЭтотОбъект.ТекущийЭлемент.Имя = "ТабличныйДокумент"
		И ЭтотОбъект.ТекущийЭлемент.ТекущаяОбласть.ЦветФона = ЦветРасшифровки Тогда 
		
		Если РегламентированнаяОтчетностьРК.ИндивидуальныйПредприниматель(СтруктураРеквизитовФормы.Организация) Тогда
			
			Если Лев(ИмяЯчейки,10) =  "П000020005"
				ИЛИ Лев(ИмяЯчейки,10)= "П000120015" Тогда
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Расшифровка данной ячейки поддерживается только для юридических лиц.'"));
					Возврат;
			КонецЕсли;
			
		ИначеЕсли РегламентированнаяОтчетностьРК.ЮридическоеЛицо(СтруктураРеквизитовФормы.Организация) Тогда
			
			Если Лев(ИмяЯчейки,10)= "П000020004"
				ИЛИ Лев(ИмяЯчейки,10)= "П000020007"
				ИЛИ Лев(ИмяЯчейки,10)= "П000020009"
				ИЛИ Лев(ИмяЯчейки,10)= "П000030012"
				ИЛИ Лев(ИмяЯчейки,10)= "П000120012"
				ИЛИ Лев(ИмяЯчейки,10)= "П000120018"
				ИЛИ Лев(ИмяЯчейки,10)= "П000130021" Тогда
					ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Расшифровка данной ячейки поддерживается только для индивидуального предпринимателя.'"));
					Возврат;
			КонецЕсли;
			
		КонецЕсли;
		
		ОткрытьФормуРасшифровки(ИмяЯчейки, Команда.Имя);
		
	ИначеЕсли Команда.Имя = "РасшифроватьОбщая" Тогда
		
		ОткрытьФормуРасшифровки(ИмяЯчейки, Команда.Имя);
		
	Иначе
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Расшифровка данной ячейки не поддерживается.'"));
		
	КонецЕсли;
	
КонецПроцедуры

