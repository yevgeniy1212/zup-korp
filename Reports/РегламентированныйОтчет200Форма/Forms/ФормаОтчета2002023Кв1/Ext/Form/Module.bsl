&НаКлиентеНаСервереБезКонтекста
Процедура Расчет(Форма, ИмяСтраницыПанели = "", ОбластьИмя = "")
	Перем ТаблицаСтраницРаздела;
	
	Если Форма.СтруктураРеквизитовФормы.мРежимПечати Тогда
		Возврат;
	КонецЕсли;
	
	ЕстьДанныеПриложение2 = Форма.П0002100001.Количество() > 1 ИЛИ (Форма.П0002100001.Количество() > 0 И Форма.П0002100001[0].П000210000101 > 0);
	ЕстьДанныеПриложение5 = Форма.П0005100002.Количество() > 1 ИЛИ (Форма.П0005100002.Количество() > 0 И Форма.П0005100002[0].П000510000201 > 0);
	СтруктураГруппы = ПолучитьСтруктуруМногостраничногоПриложения(Форма, Форма.мСтруктураМногострочныхРазделов.П0006100002, 0);

	Если ИмяСтраницыПанели = "Форма200Страница1" Тогда
		
		Если ОбластьИмя = "УчастникМФЦА" Тогда
			
			Если Форма.СтруктураРеквизитовФормы.НаимТекущегоРаздела = "Форма200Страница1" Тогда
				УчастникМФЦА = Форма.ТабличныйДокумент.Области.УчастникМФЦА.Значение;
			ИначеЕсли Форма.СтруктураДанныхФорма200Страница1.Свойство("УчастникМФЦА") Тогда
				УчастникМФЦА = Форма.СтруктураДанныхФорма200Страница1.УчастникМФЦА;
			КонецЕсли;
			
			УчастникМФЦА = ?(УчастникМФЦА = "Х","","Х");
			
			Форма.СтруктураДанныхФорма200Страница1.Вставить("УчастникМФЦА", УчастникМФЦА);
			Если Форма.СтруктураРеквизитовФормы.НаимТекущегоРаздела = "Форма200Страница1" Тогда
				Форма.ТабличныйДокумент.Области.УчастникМФЦА.Значение = УчастникМФЦА;
			КонецЕсли;
			
		КонецЕсли;
		
		Если СтрЧислоВхождений(ОбластьИмя, "СтруктурныеПодразделенияИмеются") > 0 Тогда
			
			СтруктурныеПодразделенияИмеютсяНет = "";
			СтруктурныеПодразделенияИмеютсяДа = "";
			
