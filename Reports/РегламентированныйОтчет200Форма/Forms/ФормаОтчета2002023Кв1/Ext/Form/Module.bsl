		Для Индекс = ИндексПересчета по СтруктураГруппы.Количество()-1 Цикл
			СтруктураГруппы[Индекс].П000510000201 = Индекс + 2;
		КонецЦикла;
		
		СтруктураГруппы = Форма["П0005200002"];
		Для Индекс = ИндексПересчета по СтруктураГруппы.Количество()-1 Цикл
			СтруктураГруппы[Индекс].П000520000201 = Индекс + 2;
		КонецЦикла;
		
		СтруктураГруппы = Форма["П0005300002"];
		Для Индекс = ИндексПересчета по СтруктураГруппы.Количество()-1 Цикл
			СтруктураГруппы[Индекс].П000530000201 = Индекс + 2;
		КонецЦикла;

		СтруктураГруппы = Форма["П0005400002"];
		Для Индекс = ИндексПересчета по СтруктураГруппы.Количество()-1 Цикл
			СтруктураГруппы[Индекс].П000540000201 = Индекс + 2;
		КонецЦикла;

		СтруктураГруппы = Форма["П0005500002"];
		Для Индекс = ИндексПересчета по СтруктураГруппы.Количество()-1 Цикл
			СтруктураГруппы[Индекс].П000550000201 = Индекс + 2;
		КонецЦикла;
	
		СтруктураГруппы = Форма["П0005600002"];
		Для Индекс = ИндексПересчета по СтруктураГруппы.Количество()-1 Цикл
			СтруктураГруппы[Индекс].П000560000201 = Индекс + 2;
		КонецЦикла;
	
		СтруктураГруппы = Форма["П0005700002"];
		Для Индекс = ИндексПересчета по СтруктураГруппы.Количество()-1 Цикл
			СтруктураГруппы[Индекс].П000570000201 = Индекс + 2;
		КонецЦикла;
	
	ИначеЕсли Число(Сред(ИмяГруппы,5,1)) = 6 Тогда
		
		СтруктураГруппы = ПолучитьСтруктуруМногостраничногоПриложения(Форма, Форма.мСтруктураМногострочныхРазделов.П0006100002);
		Для Индекс = ИндексПересчета по СтруктураГруппы.Количество()-1 Цикл
			СтруктураГруппы[Индекс].Значение.П000610000201 = Индекс + 2;
		КонецЦикла;
		
		СтруктураГруппы = ПолучитьСтруктуруМногостраничногоПриложения(Форма, Форма.мСтруктураМногострочныхРазделов.П0006200002);
		Для Индекс = ИндексПересчета по СтруктураГруппы.Количество()-1 Цикл
			СтруктураГруппы[Индекс].Значение.П000620000201 = Индекс + 2;
		КонецЦикла;
		
		СтруктураГруппы = ПолучитьСтруктуруМногостраничногоПриложения(Форма, Форма.мСтруктураМногострочныхРазделов.П0006300002);
		Для Индекс = ИндексПересчета по СтруктураГруппы.Количество()-1 Цикл
			СтруктураГруппы[Индекс].Значение.П000630000201 = Индекс + 2;
		КонецЦикла;
        
    КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
