#КонецОбласти

#Область Отправка

&НаКлиенте
// Выполняет отправку формы регламентированной отчетности в формате JSON,
// предварительно выполняя необходимые проверки и подготовку данных.
//
// Параметры:
//  ДанныеJSONДляОтправки – Строка (необязательный) – JSON-данные, подготовленные для отправки.
Процедура Подключаемый_ОтправитьОтчетность1С(ДанныеJSONДляОтправки = "") Экспорт
	ТипДействия = Отчетность1СКлиентСервер.ТипЗапроса_ОтправитьФорму();
	
	ОтправкаРазрешена = Отчетность1СКлиент.ПроверитьУсловияОтправки(ЭтаФорма, ГодФормированияОтчетность1С(), ТипДействия);
	
	Если НЕ ОтправкаРазрешена Тогда
		Возврат;
	КонецЕсли;	
	
	Если ТипЗнч(ДанныеJSONДляОтправки) = Тип("КомандаФормы") Тогда
		ПередВыгрузкойВJSON();
		ДанныеJSONДляОтправки = "";
	КонецЕсли;
		
	Если НЕ ПроверитьДатуПодачиОтчетность1С() Тогда
		ДополнительныеПараметры = Новый Структура();
		ДополнительныеПараметры.Вставить("ДанныеJSONДляОтправки", ДанныеJSONДляОтправки);
		Оповещание = Новый ОписаниеОповещения("ПроверитьДатуПодачиОтчетность1С_ОбработкаВыбораПользователя", ЭтотОбъект, ДополнительныеПараметры);
		ТекстВопросаРус = НСтр("ru='Установить текущую дату как Дату подачи декларации?'");
		ТекстВопросаКаз = ТекстВопросаРус;
		ТекстВопроса = Отчетность1СКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = '%1'"), ТекстВопросаРус);
		ПоказатьВопрос(Оповещание, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	Иначе
		ОбработатьОповещениеОтчетность1СНаКлиенте(Новый Структура("ОтправитьИзИсточника", ДанныеJSONДляОтправки));
	КонецЕсли;
КонецПроцедуры

&НаСервере
// см. Отчетность1ССервер.ПроверитьДатуПодачи()
Функция ПроверитьДатуПодачиОтчетность1С() Экспорт
	Возврат Отчетность1ССервер.ПроверитьДатуПодачи(ЭтотОбъект);
КонецФункции

&НаКлиенте
// Обрабатывает выбор пользователя при подтверждении установки текущей даты как даты подачи отчетности.
//
// Параметры:
//  РезультатВопроса – Число – код возврата диалога (значение перечисления КодВозвратаДиалога).
//   * КодВозвратаДиалога.Да – пользователь подтвердил установку текущей даты;
//   * Иные значения – пользователь отказался.
//
//  ДополнительныеПараметры – Структура – содержит дополнительные данные,
//   передаваемые при вызове процедуры. Ожидается, что в структуре присутствует элемент:
//   * ДанныеJSONДляОтправки – Строка, содержащая JSON-данные для отправки отчетности.
Процедура ПроверитьДатуПодачиОтчетность1С_ОбработкаВыбораПользователя(РезультатВопроса, ДополнительныеПараметры) Экспорт
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ОбработатьОповещениеОтчетность1СНаСервере(Новый Структура("ЗаменитьДатуПодачиНаТекущую", Истина));
	КонецЕсли;
	
	ОбработатьОповещениеОтчетность1СНаКлиенте(Новый Структура("ОтправитьИзИсточника", ДополнительныеПараметры.ДанныеJSONДляОтправки));
КонецПроцедуры
																			  
&НаСервере
// Обрабатывает структуру оповещений, поступающих с клиентской стороны,
// и выполняет соответствующие действия на сервере в зависимости от переданных параметров.
//
//  Процедура используется для централизованной обработки серверных действий,
//  инициированных с клиентской стороны.
//
// Параметры:
//  СтруктураОповещений – Структура – содержит параметры, определяющие требуемые операции.
Процедура ОбработатьОповещениеОтчетность1СНаСервере(СтруктураОповещений)		
	Если СтруктураОповещений.Свойство("ДеревоОшибокОтчетность1СВыбор") Тогда
		Отчетность1ССервер.ДеревоОшибокВыбор(ЭтотОбъект, СтруктураОповещений.ДеревоОшибокОтчетность1СВыбор);
	КонецЕсли;
	
	Если СтруктураОповещений.Свойство("ЗаменитьДатуПодачиНаТекущую") И СтруктураОповещений.ЗаменитьДатуПодачиНаТекущую Тогда
		Отчетность1ССервер.ЗаменитьДатуПодачиНаТекущую(ЭтотОбъект);	
	КонецЕсли;
		
	Если СтруктураОповещений.Свойство("СформироватьДеревоОшибокСоШлюза") Тогда
		Отчетность1ССервер.СформироватьДеревоОшибокСоШлюза(ЭтотОбъект,, СтруктураОповещений.СформироватьДеревоОшибокСоШлюза);	
	КонецЕсли; 
	
	Если СтруктураОповещений.Свойство("ЗаполнитьТаблицуФЛКОтчета") Тогда
		Отчетность1ССервер.ЗаполнитьТаблицуФЛКОтчета(ЭтотОбъект, СтруктураОповещений.ЗаполнитьТаблицуФЛКОтчета);	
	КонецЕсли;
		
	Если СтруктураОповещений.Свойство("ОбновитьДеревоОшибок") Тогда
		Отчетность1ССервер.СформироватьДеревоОшибок(ЭтотОбъект, СтруктураОповещений.ОбновитьДеревоОшибок);	
	КонецЕсли;
	
	Если СтруктураОповещений.Свойство("ОбновитьСтатусПриема") И СтруктураОповещений.ОбновитьСтатусПриема Тогда
		Отчетность1ССервер.ОбновитьСтатусПриемаОтчетность1С(ЭтотОбъект);	
	КонецЕсли;
	
	Если СтруктураОповещений.Свойство("УстановитьВидимостьДоступностьРеквизитов") И СтруктураОповещений.УстановитьВидимостьДоступностьРеквизитов Тогда
		Отчетность1ССервер.УстановитьВидимостьДоступностьРеквизитовОтчетность1С(ЭтотОбъект);	
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
// Обрабатывает клиентские оповещения, выполняя соответствующие действия.
//
// Параметры:
//  СтруктураОповещений – Структура – содержит параметры, определяющие требуемые операции.
Процедура ОбработатьОповещениеОтчетность1СНаКлиенте(СтруктураОповещений) Экспорт		
	
	ОбработатьОповещениеОтчетность1СНаСервере(СтруктураОповещений);
	
	Если СтруктураОповещений.Свойство("Отправить") Тогда
		Подключаемый_ОтправитьОтчетность1С(ВыгрузитьВJSONНаСервере(Отчетность1СКлиентСервер.ТипЗапроса_ОтправитьФорму()));	
	КонецЕсли;
	
	Если СтруктураОповещений.Свойство("ОтправитьИзИсточника") Тогда
		СтруктураПараметровОтправка = ПолучитьСтруктуруПараметровОтчетность1С(Отчетность1СКлиентСервер.ТипЗапроса_ОтправитьФорму());
		Отчетность1СКлиент.ОтправитьИзИсточника(ЭтотОбъект, СтруктураПараметровОтправка, СтруктураОповещений.ОтправитьИзИсточника);	
	КонецЕсли;
	
	Если СтруктураОповещений.Свойство("Сохранить") И СтруктураОповещений.Сохранить Тогда
		СохранитьОтчетность1С();	
	КонецЕсли;
		
КонецПроцедуры

#КонецОбласти

#Область ОбновитьСтатус

&НаКлиенте
// Обновляет статус отправленной отчетности по нажатию на кнопку.
Процедура Подключаемый_ОбновитьСтатусОтчетность1С()
	СтруктураПараметровОтправка = ПолучитьСтруктуруПараметровОтчетность1С(Отчетность1СКлиентСервер.ТипЗапроса_ОбновитьСтатус());
	Отчетность1СКлиент.ОбновитьСтатус(СтруктураПараметровОтправка);
КонецПроцедуры

&НаКлиенте
// Ожидает результат обновления статуса отчетности.
Функция ЖдатьРезультатОбновленияСтатусаОтчетность1С() Экспорт
	СтруктураПараметровОтправка = ПолучитьСтруктуруПараметровОтчетность1С(Отчетность1СКлиентСервер.ТипЗапроса_ОбновитьСтатус());
	Отчетность1СКлиент.ЖдатьРезультатОбновленияСтатуса(ЭтотОбъект, СтруктураПараметровОтправка);
КонецФункции

#КонецОбласти

#Область ОбработчикиЭлементовФормы

&НаКлиенте
// см. Отчетность1ССервер.ДеревоОшибокВыбор()
Процедура Подключаемый_ДеревоОшибокОтчетность1СВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ТД = Элементы.ДеревоОшибокОтчетность1С.ТекущиеДанные;
	Если ЗначениеЗаполнено(ТД.Реквизит) Тогда
		ДеревоОшибокТекущиеДанные = Новый Структура;
		ДеревоОшибокТекущиеДанные.Вставить("ИндексВТаблицеОшибок", ТД.ИндексВТаблицеОшибок);	
		ДеревоОшибокТекущиеДанные.Вставить("НомерСтроки", ТД.НомерСтроки);
		ДеревоОшибокТекущиеДанные.Вставить("Реквизит", ТД.Реквизит);
		ДеревоОшибокТекущиеДанные.Вставить("НомерЛиста", ТД.НомерЛиста);     
		ДеревоОшибокТекущиеДанные.Вставить("КодФормы", ТД.Форма);
		ДеревоОшибокТекущиеДанные.Вставить("Страница", СтрЗаменить(ТД.Страница, " ", ""));
		ОбработатьОповещениеОтчетность1СНаСервере(Новый Структура("ДеревоОшибокОтчетность1СВыбор", ДеревоОшибокТекущиеДанные));
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
// см. Отчетность1ССервер.СформироватьДеревоОшибок()
Процедура Подключаемый_ДеревоОшибокПоказыватьВсеОшибкиПриИзмененииОтчетность1С(Элемент)
	ОбработатьОповещениеОтчетность1СНаСервере(Новый Структура("ОбновитьДеревоОшибок", НЕ ЭтотОбъект.ПоказыватьВсеОшибкиОтчетность1С));
КонецПроцедуры

