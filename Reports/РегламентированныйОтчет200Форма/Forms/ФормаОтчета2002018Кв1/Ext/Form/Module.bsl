		СтруктураГруппы = Форма["П0002300001"];
		Для Индекс = ИндексПересчета по СтруктураГруппы.Количество()-1 Цикл
			СтруктураГруппы[Индекс].П000230000101 = Индекс + 2;
		КонецЦикла;
		
		СтруктураГруппы = Форма["П0002400002"];
		Для Индекс = ИндексПересчета по СтруктураГруппы.Количество()-1 Цикл
			СтруктураГруппы[Индекс].П000240000201 = Индекс + 2;
		КонецЦикла;
		
		СтруктураГруппы = Форма["П0002500002"];
		Для Индекс = ИндексПересчета по СтруктураГруппы.Количество()-1 Цикл
			СтруктураГруппы[Индекс].П000250000201 = Индекс + 2;
		КонецЦикла;
		
		СтруктураГруппы = Форма["П0002600002"];
		Для Индекс = ИндексПересчета по СтруктураГруппы.Количество()-1 Цикл
			СтруктураГруппы[Индекс].П000260000201 = Индекс + 2;
		КонецЦикла;
		
		СтруктураГруппы = Форма["П0002700002"];
		Для Индекс = ИндексПересчета по СтруктураГруппы.Количество()-1 Цикл
			СтруктураГруппы[Индекс].П000270000201 = Индекс + 2;
		КонецЦикла;
		
		СтруктураГруппы = Форма["П0002800002"];
		Для Индекс = ИндексПересчета по СтруктураГруппы.Количество()-1 Цикл
			СтруктураГруппы[Индекс].П000280000201 = Индекс + 2;
		КонецЦикла;
		
	КонецЕсли;
	
