&НаКлиенте
Функция ЭтоОбластьОКСМ(Область)
	Если ТекущееИДНаименования = "СведИСБезЮЛ" 
		Или ТекущееИДНаименования = "СвИСУчрИО" 
		Или ТекущееИДНаименования = "СвИСУчИО" Тогда
		
		Возврат (Область.Имя = "СтранаУчрИС");
	ИначеЕсли ТекущееИДНаименования = "СвИОУчрИC" 
		Или ТекущееИДНаименования = "СвИОУчИО" Тогда 
		
		Возврат (Область.Имя = "СтрРег");
	ИначеЕсли ТекущееИДНаименования = "СвФЛУчрИО" 
		Или ТекущееИДНаименования = "СвФЛУчИО" Тогда 
		
		Возврат (Область.Имя = "ОКСМ" Или Область.Имя = "ОКСМИно");
	КонецЕсли;
	
	Возврат Ложь;
КонецФункции

&НаКлиенте
Функция ЭтоОбластьДоля(Область)
	Возврат (Область.Имя = "ДоляУчКосвИт")
		Или (Область.Имя = "ДоляКосвПослИт")
		Или (Область.Имя = "ДоляУч")
		Или СтрНачинаетсяС(Область.Имя, "ДоляУчПрям_")
		Или СтрНачинаетсяС(Область.Имя, "ДоляУчКосв_");
КонецФункции

