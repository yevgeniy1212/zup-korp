		Если ТабличныйДокумент.Области.Найти("АдрЮР") <> Неопределено
			И Не ЗначениеЗаполнено(ТабличныйДокумент.Области["АдрЮР"].Значение) Тогда
			ТабличныйДокумент.Области["АдрЮР"].Значение = СведенияОбОрганизации.ПолныйАдрЮР;
		КонецЕсли;
		
		Если ТабличныйДокумент.Области.Найти("ТелОрганизации") <> Неопределено
			И Не ЗначениеЗаполнено(ТабличныйДокумент.Области["ТелОрганизации"].Значение) Тогда
			ТабличныйДокумент.Области["ТелОрганизации"].Значение = СведенияОбОрганизации.ТелОрганизации;
		КонецЕсли;
		
		Если ТабличныйДокумент.Области.Найти("ЭлПочта") <> Неопределено
			И Не ЗначениеЗаполнено(ТабличныйДокумент.Области["ЭлПочта"].Значение) Тогда
