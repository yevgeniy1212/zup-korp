&НаСервере
Процедура ОчиститьНаСервере() Экспорт
	
	СтруктураДанныхФорма1ТСтраница1.Очистить();
	СтруктураДанныхФорма1ТСтраница2.Очистить();
	СтруктураДанныхФорма1ТСтраница3.Очистить();
	СтруктураДанныхФорма1ТСтраница4.Очистить();
	
	ЗаполнитьПустыеСтруктурыДанных();
	
	ОчиститьТабличноеПолеНаСервере(СтруктураРеквизитовФормы.НаимТекущегоРаздела);
	
	ВывестиМакетСтраницыВТабличныйДокументНаСервере("Форма1ТСтраница1", 1);
	
	Модифицированность = Истина;
	
КонецПроцедуры

