#Область ОбработчикиСобытий

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	Если ОбщегоНазначенияКлиент.ПодсистемаСуществует("ЗарплатаКадрыКорпоративнаяПодсистемы.СинхронизацияMSExchange") Тогда
		
		ПараметрыФормы = Новый Структура("Пользователь", ПользователиКлиент.ТекущийПользователь());
		КлючФормы = КлючФормы();
		
		Если КлючФормы <> Неопределено Тогда
			ПараметрыФормы.Вставить("Ключ", КлючФормы);
		КонецЕсли; 
		
		ОткрытьФорму("РегистрСведений.НастройкиСинхронизацииMSExchange.Форма.ФормаЗаписи", ПараметрыФормы);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция КлючФормы()

	Ключ = Неопределено;
	
	ТипСинхронизации = ПредопределенноеЗначение("Перечисление.ТипыСинхронизацииКалендарей.MSExchange");
	
	Узел = ПланыОбмена.СинхронизацияКалендарей.УзелПользователя(Пользователи.ТекущийПользователь(), ТипСинхронизации);
	
	МенеджерЗаписи = РегистрыСведений.НастройкиСинхронизацииMSExchange.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Узел = Узел;
	МенеджерЗаписи.Прочитать();
	
	Если МенеджерЗаписи.Выбран() Тогда
		Ключ = РегистрыСведений.НастройкиСинхронизацииMSExchange.СоздатьКлючЗаписи(Новый Структура("Узел", Узел));
	КонецЕсли; 
	
	Возврат Ключ;

КонецФункции

#КонецОбласти 
