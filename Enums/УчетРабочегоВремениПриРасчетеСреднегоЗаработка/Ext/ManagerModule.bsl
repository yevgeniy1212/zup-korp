#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

Процедура ОбработкаПолученияДанныхВыбора(ДанныеВыбора, Параметры, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ПорядокОплатыСуммированногоУчет = Параметры.Свойство("ПорядокОплатыСуммированногоУчет") И Параметры.ПорядокОплатыСуммированногоУчет;
	
	ДанныеВыбора = Новый СписокЗначений;
	
	Если НЕ ПорядокОплатыСуммированногоУчет Тогда
		ДанныеВыбора.Добавить(Перечисления.УчетРабочегоВремениПриРасчетеСреднегоЗаработка.ПоФактическомуГрафику);
	КонецЕсли;
	
	ДанныеВыбора.Добавить(Перечисления.УчетРабочегоВремениПриРасчетеСреднегоЗаработка.ПоПятидневнойНеделе);
	ДанныеВыбора.Добавить(Перечисления.УчетРабочегоВремениПриРасчетеСреднегоЗаработка.ПоШестидневнойНеделе);
	
	Если ПорядокОплатыСуммированногоУчет Тогда
		ДанныеВыбора.Добавить(Перечисления.УчетРабочегоВремениПриРасчетеСреднегоЗаработка.ПоПятидневнойНеделе36);	
		ДанныеВыбора.Добавить(Перечисления.УчетРабочегоВремениПриРасчетеСреднегоЗаработка.ПоШестидневнойНеделе36);	
	КонецЕсли;
	
КонецПроцедуры

