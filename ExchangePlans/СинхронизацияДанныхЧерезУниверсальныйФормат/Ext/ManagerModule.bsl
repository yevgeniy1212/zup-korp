        //ЗУПК
        ИмяКонфигурацииКорреспондента          = НСтр("ru = 'УправлениеПредприятиемДляКазахстана'");
		НаименованиеКонфигурацииКорреспондента = НСтр("ru = '1С:ERP Управление предприятием 2 для Казахстана / Комплексная автоматизация для Казахстана, редакция 2'");
		
		КраткаяИнформацияПоОбмену = НСтр("ru = 'Данная настройка позволит синхронизировать данные между программами ""Зарплата и управление персоналом для Казахстана, редакция 3.1""
		|и ""1С:ERP Управление предприятием 2 для Казахстана / Комплексная автоматизация для Казахстана, редакция 2"". В синхронизации участвуют документы и нормативно-справочная информация.'");
		
		ЗаголовокКоманды   = НСтр("ru = '1С:ERP Управление предприятием 2 для Казахстана / Комплексная автоматизация для Казахстана, редакция 2'");
		ЗаголовокПомощника = НСтр("ru = 'Настройка синхронизации с программой ""1С:ERP Управление предприятием 2 для Казахстана / Комплексная автоматизация для Казахстана, редакция 2""'");
		ЗаголовокУзла      = НСтр("ru = 'Синхронизация с программой ""1С:ERP Управление предприятием 2 для Казахстана / Комплексная автоматизация для Казахстана, редакция 2""'");
		
	ИначеЕсли ИдентификаторНастройки = "ОбменЗУП31БП" Тогда
		
