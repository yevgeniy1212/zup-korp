#Область ПодключаемыеКоманды

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаСервере
Процедура Подключаемый_ВыполнитьКомандуНаСервере(Контекст, Результат) Экспорт
	ПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, Контекст, Объект, Результат);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

#КонецОбласти

&НаСервере
Функция ВыполняетсяНачальнаяНастройкаПрограммы()
	Возврат НачальнаяНастройкаПрограммы.ВыполняетсяНачальнаяНастройкаПрограммы();
КонецФункции

&НаСервере
Процедура ЗавершитьНастройкуСинхронизацииДанных(ТекущийОбъект, Отказ = Ложь)
	
	Если СинхронизацияДанныхЗарплатаКадрыСервер.СинхронизацияРазрешена(ТекущийОбъект) Тогда
		ОбменДаннымиСервер.ФормаУзлаПриЗаписиНаСервере(ТекущийОбъект, Отказ);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьКомандуЗаписать(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ЗакрыватьПослеЗаписи = Ложь;
	ПроизводитсяЗаполнениеДанных = Истина;
	
	ПодключитьОбработчикОжидания("ОтложеннаяОбработкаПрогресс", 0.2, Истина);
	
	Записать();
	
КонецПроцедуры

&НаКлиенте
Процедура ВключитьОтключитьВсеЭлементыВТаблице(Включить, ИмяТаблицы)
	
	Для Каждого ЭлементКоллекции Из ЭтаФорма[ИмяТаблицы] Цикл
		ЭлементКоллекции.Использовать = Включить;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВключитьОтключитьВсеЭлементыВДеревеЗначений(Включить, Строки)
	
	Для Каждого ЭлементКоллекции Из Строки Цикл
		ЭлементКоллекции.Использовать = Включить;
		ВключитьОтключитьВсеЭлементыВДеревеЗначений(Включить, ЭлементКоллекции.ПолучитьЭлементы());
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ОтметитьВыбранныеЭлементыТаблицы(ИмяТаблицы, ИмяРеквизита)
	
	Для Каждого СтрокаТаблицы Из Объект[ИмяТаблицы] Цикл
		Строки = ЭтаФорма[ИмяТаблицы].НайтиСтроки(Новый Структура(ИмяРеквизита, СтрокаТаблицы[ИмяРеквизита]));
		
		Для Каждого НайденнаяСтрока Из Строки Цикл
			НайденнаяСтрока.Использовать = Истина;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура РежимСинхронизацииОрганизацийПриИзмененииЗначения()
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Организации", "Доступность", 
		РежимСинхронизацииОрганизаций = "СинхронизироватьДанныеТолькоПоВыбраннымОрганизациям"
			И Объект.СинхронизироватьДанныеПоОрганизациям);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РежимСинхронизацииОрганизаций",
		"Доступность", Объект.СинхронизироватьДанныеПоОрганизациям);
	
	Если Не Объект.СинхронизироватьДанныеПоОрганизациям Тогда
		РежимСинхронизацииОрганизаций = "СинхронизироватьДанныеПоВсемОрганизациям";
		Для Каждого Организация Из Организации Цикл
			Если Организация.Использовать Тогда
				Организация.Использовать = Ложь;
			КонецЕсли;
		КонецЦикла;
	ИначеЕсли РежимСинхронизацииОрганизаций = "СинхронизироватьДанныеПоВсемОрганизациям" Тогда
		Для Каждого Организация Из Организации Цикл
			Если Не Организация.Использовать Тогда
				Организация.Использовать = Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РежимСинхронизацииПодразделенийПриИзмененииЗначения()
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Подразделения", "Доступность", 
		РежимСинхронизацииПодразделений = "СинхронизироватьДанныеТолькоПоВыбраннымПодразделениям"
			И Объект.СинхронизироватьДанныеПоПодразделениям);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РежимСинхронизацииПодразделений",
		"Доступность", Объект.СинхронизироватьДанныеПоПодразделениям);
	
	Если Не Объект.СинхронизироватьДанныеПоПодразделениям Тогда
		РежимСинхронизацииПодразделений = "СинхронизироватьДанныеПоВсемПодразделениям";
		УстановитьИспользованиеОбъектов(Подразделения.ПолучитьЭлементы(), Ложь);
	ИначеЕсли РежимСинхронизацииПодразделений = "СинхронизироватьДанныеПоВсемПодразделениям" Тогда
		УстановитьИспользованиеОбъектов(Подразделения.ПолучитьЭлементы(), Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РежимСинхронизацииРазделовПриИзмененииЗначения()
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РазделыДанных", "Доступность", 
		РежимСинхронизацииРазделов = "СинхронизироватьДанныеТолькоПоВыбраннымРазделам"
			И Объект.СинхронизироватьДанныеПоПодразделениям);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РежимСинхронизацииРазделов",
		"Доступность", Объект.СинхронизироватьДанныеПоПодразделениям);
	
	Если Не Объект.СинхронизироватьДанныеПоПодразделениям Тогда
		РежимСинхронизацииРазделов = "СинхронизироватьДанныеПоВсемРазделам";
		УстановитьИспользованиеОбъектов(РазделыДанных.ПолучитьЭлементы(), Ложь);
	ИначеЕсли РежимСинхронизацииРазделов = "СинхронизироватьДанныеПоВсемРазделам" Тогда
		УстановитьИспользованиеОбъектов(РазделыДанных.ПолучитьЭлементы(), Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПодразделенияИспользоватьПриИзмененииНаСервере(Подразделение, Использование)
	
	МассивПодразделений = Новый Массив;
	Если Подразделение = Справочники.СтруктураПредприятия.ПустаяСсылка() Тогда
		МассивПодразделений.Добавить(Подразделение);
	ИначеЕсли ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.ОрганизационнаяСтруктура") Тогда
		Модуль = ОбщегоНазначения.ОбщийМодуль("ОрганизационнаяСтруктура");
		МассивПодразделений = Модуль.ПодчиненныеПодразделения(Подразделение);
	КонецЕсли;
	
	УстановитьИспользованиеОбъекта(Подразделения.ПолучитьЭлементы(), МассивПодразделений, "Подразделение", Использование);
	
КонецПроцедуры

&НаСервере
Процедура РазделыДанныхИспользоватьПриИзмененииНаСервере(Идентификатор, Использование)
	
	РазделыДанныхТаблица = СинхронизацияДанныхЗарплатаКадрыСервер.РазделыДанных(Идентификатор);
	МассивРазделов = ОбщегоНазначения.ВыгрузитьКолонку(РазделыДанныхТаблица, "Идентификатор");
	
	УстановитьИспользованиеОбъекта(РазделыДанных.ПолучитьЭлементы(), МассивРазделов, "Идентификатор", Использование);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьИспользованиеУРодителей(ТекущиеДанные, Значение)
	
	Родитель = ТекущиеДанные.ПолучитьРодителя();
	Если Родитель <> Неопределено Тогда
		Родитель.Использовать = Значение;
		УстановитьИспользованиеУРодителей(Родитель, Значение);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьИспользованиеОбъектов(Коллекция, Использовать)
	
	Для Каждого ЭлементКоллекции Из Коллекция Цикл
		Если ЭлементКоллекции.Использовать <> Использовать Тогда
			ЭлементКоллекции.Использовать = Использовать;
		КонецЕсли;
		УстановитьИспользованиеОбъектов(ЭлементКоллекции.ПолучитьЭлементы(), Использовать);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьИспользованиеОбъекта(ЭлементыДерева, МассивОбъектов, ИмяКолонки, Использование)
	
	Для Каждого СтрокаДерева Из ЭлементыДерева Цикл
		Если МассивОбъектов.Найти(СтрокаДерева[ИмяКолонки]) <> Неопределено Тогда
			СтрокаДерева.Использовать = Использование;
		КонецЕсли;
		УстановитьИспользованиеОбъекта(СтрокаДерева.ПолучитьЭлементы(), МассивОбъектов, ИмяКолонки, Использование);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьЭлементов()
	
	ВидимостьГруппыНастройкиПоПодразделениям =
		ПолучитьФункциональнуюОпцию("ИспользоватьЗарплатаКадрыКорпоративнаяПодсистемы");
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
		"ГруппаНастройкиВыгрузкиДанныхПоПодразделениям", "Видимость", ВидимостьГруппыНастройкиПоПодразделениям);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
		"ГруппаНастройкиВыгрузкиДанныхПоРазделам", "Видимость", ВидимостьГруппыНастройкиПоПодразделениям
		И Объект.СинхронизироватьДанныеПоПодразделениям);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
		"СинхронизироватьДанныеПоОрганизациям", "Видимость", ВидимостьГруппыНастройкиПоПодразделениям);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
		"ГруппаЗаполнениеДанных", "Видимость", ПроизводитсяЗаполнениеДанных);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
		"ПроцентВыполненияПоОрганизациям", "Видимость", ПроизводитсяЗаполнениеДанных);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
		"ПроцентВыполненияПоПодразделениям", "Видимость", ПроизводитсяЗаполнениеДанных);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
		"ОбщаяКомандаВыполнитьОбменДанными", "Доступность", Не ПроизводитсяЗаполнениеДанных);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы,
		"СозданиеНачальногоОбраза", "Доступность", Не ПроизводитсяЗаполнениеДанных);
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьВыполнениеОтложеннойОбработки()
	
	ПроизводитсяЗаполнениеДанных = 
		СинхронизацияДанныхЗарплатаКадрыСервер.ОрганизацииФизическихЛицЗаполняются()
		Или СинхронизацияДанныхЗарплатаКадрыСервер.ПодразделенияФизическихЛицЗаполняются()
		Или ПроизводитсяЗаполнениеДанных
		Или СинхронизацияДанныхЗарплатаКадрыСервер.ОрганизацииСотрудниковЗаполняются()
		Или СинхронизацияДанныхЗарплатаКадрыСервер.ПодразделенияСотрудниковЗаполняются();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтложеннаяОбработкаПрогресс()
	
	Если ПроизводитсяЗаполнениеДанных Или Не СинхронизацияРазрешена() Тогда
		ОтложеннаяОбработкаПрогрессНаСервере();
		ИнтервалВызоваМетода = ?(ПолучитьСкоростьКлиентскогоСоединения() = СкоростьКлиентскогоСоединения.Низкая, 4, 0.8);
		ПодключитьОбработчикОжидания("ОтложеннаяОбработкаПрогресс", ИнтервалВызоваМетода, Истина);
	Иначе
		ОтключитьОбработчикОжидания("ОтложеннаяОбработкаПрогресс");
		ЗавершитьНастройкуСинхронизацииДанных(Объект.Ссылка);
		Если ЗакрыватьПослеЗаписи Тогда
			Закрыть();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СинхронизацияРазрешена()
	Возврат СинхронизацияДанныхЗарплатаКадрыСервер.СинхронизацияРазрешена(Объект.Ссылка);
КонецФункции

&НаСервере
Процедура ОтложеннаяОбработкаПрогрессНаСервере()
	
	ПроизводитсяЗаполнениеДанных = Ложь;
	ПроцентВыполненияПоОрганизациям = 0;
	ПроцентВыполненияПоПодразделениям = 0;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(МАКСИМУМ(НастройкиОрганизаций.ЗаполнениеПроизводится), ЛОЖЬ) КАК ЗаполнениеПроизводится,
	|	ЕСТЬNULL(СУММА(НастройкиОрганизаций.ОбъектовКОбработке), 0) КАК ОбъектовКОбработке,
	|	ЕСТЬNULL(СУММА(НастройкиОрганизаций.ОбъектовОбработано), 0) КАК ОбъектовОбработано
	|ИЗ
	|	(ВЫБРАТЬ
	|		НастройкиОрганизацийФизическихЛиц.ЗаполнениеПроизводится КАК ЗаполнениеПроизводится,
	|		НастройкиОрганизацийФизическихЛиц.ФизическихЛицКОбработке КАК ОбъектовКОбработке,
	|		НастройкиОрганизацийФизическихЛиц.ФизическихЛицОбработано КАК ОбъектовОбработано
	|	ИЗ
	|		РегистрСведений.НастройкиОрганизацийФизическихЛиц КАК НастройкиОрганизацийФизическихЛиц
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		НастройкиОрганизацийСотрудников.ЗаполнениеПроизводится,
	|		НастройкиОрганизацийСотрудников.СотрудниковКОбработке,
	|		НастройкиОрганизацийСотрудников.СотрудниковОбработано
	|	ИЗ
	|		РегистрСведений.НастройкиОрганизацийСотрудников КАК НастройкиОрганизацийСотрудников) КАК НастройкиОрганизаций";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ПроизводитсяЗаполнениеДанных = ПроизводитсяЗаполнениеДанных Или Выборка.ЗаполнениеПроизводится;
		Если Выборка.ОбъектовКОбработке <> 0 Тогда
			ПроцентВыполненияПоОрганизациям = 100 * Выборка.ОбъектовОбработано / Выборка.ОбъектовКОбработке;
		Иначе
			ПроцентВыполненияПоОрганизациям = 0;
		КонецЕсли;
	КонецЕсли;
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(МАКСИМУМ(НастройкиПодразделений.ЗаполнениеПроизводится), ЛОЖЬ) КАК ЗаполнениеПроизводится,
	|	ЕСТЬNULL(СУММА(НастройкиПодразделений.ОбъектовКОбработке), 0) КАК ОбъектовКОбработке,
	|	ЕСТЬNULL(СУММА(НастройкиПодразделений.ОбъектовОбработано), 0) КАК ОбъектовОбработано
	|ИЗ
	|	(ВЫБРАТЬ
	|		НастройкиПодразделенийФизическихЛиц.ЗаполнениеПроизводится КАК ЗаполнениеПроизводится,
	|		НастройкиПодразделенийФизическихЛиц.ФизическихЛицКОбработке КАК ОбъектовКОбработке,
	|		НастройкиПодразделенийФизическихЛиц.ФизическихЛицОбработано КАК ОбъектовОбработано
	|	ИЗ
	|		РегистрСведений.НастройкиПодразделенийФизическихЛиц КАК НастройкиПодразделенийФизическихЛиц
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		НастройкиПодразделенийСотрудников.ЗаполнениеПроизводится,
	|		НастройкиПодразделенийСотрудников.СотрудниковКОбработке,
	|		НастройкиПодразделенийСотрудников.СотрудниковОбработано
	|	ИЗ
	|		РегистрСведений.НастройкиПодразделенийСотрудников КАК НастройкиПодразделенийСотрудников) КАК НастройкиПодразделений";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ПроизводитсяЗаполнениеДанных = ПроизводитсяЗаполнениеДанных Или Выборка.ЗаполнениеПроизводится;
		Если Выборка.ОбъектовКОбработке <> 0 Тогда
			ПроцентВыполненияПоПодразделениям = 100 * Выборка.ОбъектовОбработано / Выборка.ОбъектовКОбработке;
		Иначе
			ПроцентВыполненияПоПодразделениям = 0;
		КонецЕсли;
	КонецЕсли;
	
	УстановитьВидимостьЭлементов();
	
	ПредыдущийПроцентВыполненияПоОрганизациям = ПроцентВыполненияПоОрганизациям;
	ПредыдущийПроцентВыполненияПоПодразделениям = ПроцентВыполненияПоПодразделениям;
	
КонецПроцедуры

&НаСервере
Функция ЭтоЗаписьПервогоУзлаСОтбором()
	
	Если (Не СинхронизацияДанныхЗарплатаКадрыСервер.ИспользуютсяУзлыРИБСОтборомПоОрганизациям(Объект.Ссылка) 
			И РежимСинхронизацииОрганизаций = "СинхронизироватьДанныеТолькоПоВыбраннымОрганизациям"
			И Объект.СинхронизироватьДанныеПоОрганизациям)
		Или (Не СинхронизацияДанныхЗарплатаКадрыСервер.ИспользуютсяУзлыРИБСОтборомПоПодразделениям(Объект.Ссылка)
			И РежимСинхронизацииПодразделений = "СинхронизироватьДанныеТолькоПоВыбраннымПодразделениям"
			И Объект.СинхронизироватьДанныеПоПодразделениям) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь
	
КонецФункции

&НаСервере
Функция ВыбранныеРазделыДанных()

	ВыбранныеРазделы = Новый Массив;
	
	РазделыДерево = РеквизитФормыВЗначение("РазделыДанных");
	НайденныеСтроки = РазделыДерево.Строки.НайтиСтроки(Новый Структура("Использовать", Истина), Истина);
	Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
		ВыбранныеРазделы.Добавить(НайденнаяСтрока.Идентификатор);
	КонецЦикла;
	
	Возврат ВыбранныеРазделы;
	
КонецФункции

&НаКлиенте
Процедура СформироватьОтчетМигрирующиеОбъектыРИБ(КлючВарианта, Уникальность, ВыбранныеРазделы)
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("КлючВарианта", КлючВарианта);
	ПараметрыОткрытия.Вставить("КлючПараметровПечати", Уникальность);
	ПараметрыОткрытия.Вставить("КлючСохраненияПоложенияОкна", Уникальность);
	ПараметрыОткрытия.Вставить("СформироватьПриОткрытии", Истина);
	ПараметрыОткрытия.Вставить("ТолькоОбъектыИнтерфейсныхПодсистем", Истина);
	ПараметрыОткрытия.Вставить("ИмяПланаОбмена", "ОбменВРаспределеннойИнформационнойБазе");

	Отбор = Новый Структура;
	Отбор.Вставить("РазделДанныхОбъектаИдентификатор", ВыбранныеРазделы);
	ПараметрыОткрытия.Вставить("Отбор", Отбор);
	
	ОткрытьФорму("Отчет.МигрирующиеОбъектыРИБ.Форма", ПараметрыОткрытия, ЭтаФорма, Уникальность);
	
КонецПроцедуры

&НаСервере
Функция УправленческиеРазделыДанных()
	Возврат СинхронизацияДанныхЗарплатаКадрыСервер.РазделыДанных("УправленческиеДанные").ВыгрузитьКолонку("Идентификатор");
КонецФункции

&НаСервере
Процедура ЗаполнитьДеревоПодразделений()
	
	ВсеПодразделенияПриложения = СинхронизацияДанныхЗарплатаКадрыСервер.ВсеПодразделенияПриложения();
	
	Если ВсеПодразделенияПриложения <> Неопределено Тогда
		НаименованияПодразделений = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(
			ВсеПодразделенияПриложения.ВыгрузитьКолонку("Подразделение"), "Наименование");
		ВсеПодразделенияПриложения.Колонки.Добавить("Представление", Новый ОписаниеТипов("Строка"));
		
		Для Каждого ТекущаяСтрока Из ВсеПодразделенияПриложения Цикл
			ТекущаяСтрока.Представление = НаименованияПодразделений[ТекущаяСтрока.Подразделение];
		КонецЦикла;
		НоваяСтрока = ВсеПодразделенияПриложения.Добавить();
		НоваяСтрока.Подразделение = Справочники.СтруктураПредприятия.ПустаяСсылка();
		НоваяСтрока.Представление = "Незаполненное подразделение";
		
		ПодразделенияДерево = РеквизитФормыВЗначение("Подразделения");
		
		ЗаполнитьДерево(ПодразделенияДерево, ВсеПодразделенияПриложения, Объект.Подразделения, "Подразделение",
			"ПодразделениеРодитель");
		СтрокаДерева = ПодразделенияДерево.Строки.Найти(Справочники.СтруктураПредприятия.ПустаяСсылка(),
			"Подразделение", Ложь);
		ПодразделенияДерево.Строки.Сдвинуть(ПодразделенияДерево.Строки.Индекс(СтрокаДерева),
			ПодразделенияДерево.Строки.Количество() - 1);
		
		ЗначениеВРеквизитФормы(ПодразделенияДерево, "Подразделения");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДеревоРазделовДанных()
	
	Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.ОрганизационнаяСтруктура") Тогда
		РазделыДанныхТаблица = СинхронизацияДанныхЗарплатаКадрыСервер.РазделыДанных(
			СинхронизацияДанныхЗарплатаКадрыСервер.ИдентификаторыРазделовДанных().УправленческиеДанные);
		РазделыДерево = РеквизитФормыВЗначение("РазделыДанных");
		ЗаполнитьДерево(РазделыДерево, РазделыДанныхТаблица, Объект.РазделыДанных, "Идентификатор", "Родитель");
		ЗначениеВРеквизитФормы(РазделыДерево, "РазделыДанных");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДерево(Дерево, ТаблицаДанных, ТабличнаяЧасть, ИмяРеквизита, ИмяРеквизитаРодитель)
	
	Для Каждого СтрокаТаблицы Из ТаблицаДанных Цикл
		СтрокаРодителя = Дерево.Строки.Найти(СтрокаТаблицы[ИмяРеквизитаРодитель], ИмяРеквизита, Истина);
		Если СтрокаРодителя = Неопределено Тогда
			СтрокаДерева = Дерево.Строки.Добавить();
		Иначе
			СтрокаДерева = СтрокаРодителя.Строки.Добавить();
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(СтрокаДерева, СтрокаТаблицы);
		Если ТаблицаДанных.Колонки.Найти("Картинка") <> Неопределено Тогда
			СтрокаДерева.Картинка = СтрокаТаблицы.Картинка;
		КонецЕсли;
	КонецЦикла;
	Дерево.Строки.Сортировать(ИмяРеквизита, Истина);
	
	// Отметим выбранные элементы
	Для Каждого СтрокаТаблицы Из ТабличнаяЧасть Цикл
		НайденнаяСтрока = Дерево.Строки.Найти(СтрокаТаблицы[ИмяРеквизита], ИмяРеквизита, Истина);
		Если НайденнаяСтрока <> Неопределено Тогда
			НайденнаяСтрока.Использовать = Истина;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти
