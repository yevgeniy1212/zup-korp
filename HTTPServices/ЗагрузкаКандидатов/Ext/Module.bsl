Функция ОперацииЗагрузкиПолучитьОперацииЗагрузки(Запрос)

	Результат = ИдентифицированныйПользователь(Запрос);
	Если Результат.Пользователь = Неопределено Тогда
		Возврат Результат.Ответ;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	Возврат НовыйHTTPСервисОтвет(Запрос, КодыОтветов().ОК_200, 
		ЗагрузкаКандидатовИзИнтернета.СписокОперацийЗагрузкиJSON(Результат.Пользователь));
	
КонецФункции

Функция ОперацииЗагрузкиСоздатьОперациюЗагрузки(Запрос)

	Результат = ИдентифицированныйПользователь(Запрос);
	Если Результат.Пользователь = Неопределено Тогда
		Возврат Результат.Ответ;
	КонецЕсли;
	
	Пользователь = Результат.Пользователь;

	ДанныеJSON = JSONВДанные(Запрос.ПолучитьТелоКакСтроку());
	
	ОбязательныеПоля = Новый Массив;
	ОбязательныеПоля.Добавить("url");
	ОбязательныеПоля.Добавить("vacancyID");
	Если ПолучитьФункциональнуюОпцию("ОграничиватьДоступНаУровнеЗаписейФизическиеЛица") Тогда
		ОбязательныеПоля.Добавить("accessGroupID");
	КонецЕсли;
	
	Результат = ПроверитьОбязательныеПоля(ДанныеJSON, ОбязательныеПоля, Запрос);
	Если Не Результат.ОК Тогда
		Возврат Результат.Ответ;
	КонецЕсли;

	СостояниеСписка = Запрос.Заголовки.Получить("If-Match");
	РезультатПроверки = Проверить(СостояниеСписка <> Неопределено, 
		Запрос, КодыОтветов().ОшибкаЗапроса_400, ОшибкаОбязательныйЗаголовок("If-Match"));
	Если Не РезультатПроверки.ОК Тогда
		Возврат РезультатПроверки.Ответ;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	Результат = ЗагрузкаКандидатовИзИнтернета.СоздатьОперациюЗагрузкиКандидата(Пользователь, ДанныеJSON, СостояниеСписка);
	УстановитьПривилегированныйРежим(Ложь);

	Если Не Результат.ОК Тогда
		Если Результат.Ошибка = ЗагрузкаКандидатовИзИнтернета.ВидыОшибок().СостояниеНеактуально Тогда
			Возврат НовыйHTTPСервисОтвет(Запрос, КодыОтветов().УсловиеЛожно_412);
		ИначеЕсли Результат.Ошибка = ЗагрузкаКандидатовИзИнтернета.ВидыОшибок().ОбъектНеНайден Тогда 
			Возврат НовыйHTTPСервисОтвет(Запрос, КодыОтветов().ОшибкаЗапроса_400, 
				ОшибкаЗапроса(КодыОшибок().ОбъектНеНайден, Результат.Поле));
		ИначеЕсли Результат.Ошибка = ЗагрузкаКандидатовИзИнтернета.ВидыОшибок().НеверныйИдентификатор Тогда 
			Возврат НовыйHTTPСервисОтвет(Запрос, КодыОтветов().ОшибкаЗапроса_400, 
				ОшибкаЗапроса(КодыОшибок().НеверноеЗначение, Результат.Поле));
		ИначеЕсли Результат.Ошибка = ЗагрузкаКандидатовИзИнтернета.ВидыОшибок().КонфликтПриЗаписи Тогда 
			Возврат НовыйHTTPСервисОтвет(Запрос, КодыОтветов().КонфликтПриЗаписи_409, 
				ОшибкаЗапроса(КодыОшибок().НеУдалосьЗаписать));
		Иначе
			ОбщегоНазначенияКлиентСервер.Проверить(Ложь, 
				НСтр("ru = 'Неизвестный вид ошибки'"), "ОперацииЗагрузкиСоздатьОперациюЗагрузки");
		КонецЕсли;
	КонецЕсли;

	Возврат НовыйHTTPСервисОтвет(Запрос, КодыОтветов().Создано_201, Результат.Результат);

КонецФункции

