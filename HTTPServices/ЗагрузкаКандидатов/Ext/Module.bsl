#Область ОперацияЗагрузки

Функция ОперацияЗагрузкиПолучитьОперациюЗагрузки(Запрос)

	Результат = ИдентифицированныйПользователь(Запрос);
	Если Результат.Пользователь = Неопределено Тогда
		Возврат Результат.Ответ;
	КонецЕсли;

	ОперацияID = Запрос.ПараметрыURL.Получить("ID");
	РезультатПроверки = Проверить(ОперацияID <> Неопределено, 
		Запрос, КодыОтветов().ОшибкаЗапроса_400, ОшибкаОбязательныйПараметрURL("ID"));
	Если Не РезультатПроверки.ОК Тогда
		Возврат РезультатПроверки.Ответ;
	КонецЕсли;

	Попытка
		ИдентификаторЗагрузки = Новый УникальныйИдентификатор(ОперацияID);
	Исключение
		РезультатПроверки = Проверить(Ложь, 
			Запрос, КодыОтветов().ОшибкаЗапроса_400, ОшибкаЗапроса(КодыОшибок().НеверноеЗначение, "ID"));
		Возврат РезультатПроверки.Ответ;
	КонецПопытки;

	УстановитьПривилегированныйРежим(Истина);
	ОперацияJSON = ЗагрузкаКандидатовИзИнтернета.ОперацияЗагрузкиКандидатаJSON(ИдентификаторЗагрузки);
	УстановитьПривилегированныйРежим(Ложь);
	
	Если ОперацияJSON = Неопределено Тогда
		Возврат НовыйHTTPСервисОтвет(Запрос, КодыОтветов().НеНайдено_404);
	КонецЕсли;
	
	Возврат НовыйHTTPСервисОтвет(Запрос, КодыОтветов().ОК_200, ОперацияJSON);
	
КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ИдентифицированныйПользователь(ЗапросHttp)
	
	Результат = Новый Структура();
	Результат.Вставить("Пользователь");
	Результат.Вставить("Ответ");
	
	Токен = ЗапросHttp.Заголовки.Получить("Token");
	Если Токен = Неопределено Тогда
		Результат.Ответ = НовыйHTTPСервисОтвет(ЗапросHttp, КодыОтветов().НеАвторизован_401);
		Возврат Результат;
	КонецЕсли;
	
	Пользователь = ЗагрузкаКандидатовИзИнтернета.ПользовательПоТокену(Токен);

	Если Пользователь = Неопределено Тогда
		Результат.Ответ = НовыйHTTPСервисОтвет(ЗапросHttp, КодыОтветов().НеАвторизован_401);
		Возврат Результат;
	КонецЕсли;
	
	Результат.Пользователь = Пользователь;
	Возврат Результат;
	
КонецФункции

Функция ДанныеВJSON(СтруктураДанных)
	
	ЗаписьJSON = Новый ЗаписьJSON;
	ЗаписьJSON.УстановитьСтроку();
	ЗаписатьJSON(ЗаписьJSON, СтруктураДанных);
	
	Возврат ЗаписьJSON.Закрыть();
	
КонецФункции

Функция JSONВДанные(СообщениеJSON)
	
	Если Не ЗначениеЗаполнено(СообщениеJSON) Тогда
		Возврат Новый Структура;
	КонецЕсли;

	ЧтениеJSON = Новый ЧтениеJSON;
	ЧтениеJSON.УстановитьСтроку(СообщениеJSON);
	СтруктураДанных = ПрочитатьJSON(ЧтениеJSON);
	ЧтениеJSON.Закрыть();
	
	Возврат СтруктураДанных;
	
КонецФункции

Функция КодыОтветов()
	Коды = Новый Структура();
	Коды.Вставить("ОК_200", 200);
	Коды.Вставить("Создано_201", 201);
	Коды.Вставить("НетСодержимого_204", 204);
	Коды.Вставить("Редирект_303", 303);
	Коды.Вставить("ОшибкаЗапроса_400", 400);
	Коды.Вставить("НеАвторизован_401", 401);
	Коды.Вставить("НетДоступа_403", 403);
	Коды.Вставить("НеНайдено_404", 404);
	Коды.Вставить("НеРазрешено_405", 405);
	Коды.Вставить("КонфликтПриЗаписи_409", 409);
	Коды.Вставить("УсловиеЛожно_412", 412);
	Возврат Коды;
КонецФункции

Функция НовыйHTTPСервисОтвет(HTTPСервисЗапрос, КодОтвета, ДанныеОтвета = Неопределено)
	
	Ответ = Новый HTTPСервисОтвет(КодОтвета);

	Если ДанныеОтвета <> Неопределено Тогда
		Ответ.УстановитьТелоИзСтроки(ДанныеВJSON(ДанныеОтвета));
	КонецЕсли;
	
	Возврат Ответ;
	
КонецФункции

Функция НовыйHTTPСервисРедирект(HTTPСервисЗапрос, Направление, ДанныеОтвета = Неопределено)
	Ответ = НовыйHTTPСервисОтвет(HTTPСервисЗапрос, КодыОтветов().Редирект_303, ДанныеОтвета);
	Ответ.Заголовки.Вставить("Location", "/hs/applicants" + Направление);
	Возврат Ответ;
КонецФункции

Функция Проверить(Условие, Запрос, КодОтвета, ДанныеОтвета = "")
	
	Результат = Новый Структура();
	Результат.Вставить("ОК", Истина);
	Результат.Вставить("Ответ", Неопределено);
	
	Попытка
		ОбщегоНазначенияКлиентСервер.Проверить(Условие);
	Исключение
		Результат.ОК = Ложь;
		Результат.Ответ = НовыйHTTPСервисОтвет(Запрос, КодОтвета);
		Если ДанныеОтвета <> Неопределено Тогда
			Результат.Ответ.УстановитьТелоИзСтроки(ДанныеВJSON(ДанныеОтвета));
		КонецЕсли;
		Возврат Результат;
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

Функция ПроверитьОбязательныеПоля(ДанныеJSON, ИменаПолей, Запрос)
	
	ИменаПолейМассив = ИменаПолей;
	Если ТипЗнч(ИменаПолей) = Тип("Строка") Тогда
		ИменаПолейМассив = СтрРазделить(ИменаПолей, ",");
	КонецЕсли;
	
	Для Каждого ИмяПоля Из ИменаПолейМассив Цикл
		Результат = Проверить(ОбъектСодержит(ДанныеJSON, ИмяПоля), Запрос, 
			КодыОтветов().ОшибкаЗапроса_400, ОшибкаОбязательноеПоле(ИмяПоля));
		Если Не Результат.ОК Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ОбъектСодержит(Объект, ИмяПоля)
	
	Если ТипЗнч(Объект) = Тип("Структура") Тогда
		Возврат Объект.Свойство(ИмяПоля);
	ИначеЕсли ТипЗнч(Объект) = Тип("Соответствие") Тогда
		Возврат Объект.Получить(ИмяПоля) <> Неопределено;
	КонецЕсли;
	
КонецФункции

Функция ОшибкаОбязательноеПоле(ИмяПоля)
	Возврат ОшибкаЗапроса(КодыОшибок().ПропущеноПоле, ИмяПоля);
КонецФункции

Функция ОшибкаОбязательныйПараметрURL(ИмяПараметра)
	Возврат ОшибкаЗапроса(КодыОшибок().ПропущенПараметрURL, ИмяПараметра);
КонецФункции

Функция ОшибкаОбязательныйЗаголовок(ИмяЗаголовка)
	Возврат ОшибкаЗапроса(КодыОшибок().ПропущенЗаголовок, ИмяЗаголовка);
КонецФункции

Функция ОшибкаЗапроса(КодОшибки, Значение = "")
	
	ОписаниеОшибки = Новый Структура();
	ОписаниеОшибки.Вставить("code", КодОшибки);
	ОписаниеОшибки.Вставить("value", Значение);
	
	Возврат Новый Структура("error", ОписаниеОшибки);
	
КонецФункции

Функция КодыОшибок()
	
	Коды = Новый Структура();
	Коды.Вставить("ПропущеноПоле", "missingRequired");
	Коды.Вставить("ПропущенПараметрURL", "missingUrlParameter");
	Коды.Вставить("ПропущенЗаголовок", "missingHeader");
	Коды.Вставить("ОбъектНеНайден", "objectNotFound");
	Коды.Вставить("НеверноеЗначение", "incorrectValue");
	Коды.Вставить("НеУдалосьЗаписать", "couldNotWriteObject");
	Возврат Коды;
	
КонецФункции

#КонецОбласти