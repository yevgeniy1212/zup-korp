#Область ОбработчикиСобытий

#Область Кандидаты

Функция КандидатыПолучениеДанныхКандидата(Запрос)

	Результат = ИдентифицированныйПользователь(Запрос);
	Если Результат.Пользователь = Неопределено Тогда
		Возврат Результат.Ответ;
	КонецЕсли;

	UrlРезюме = Запрос.ПараметрыЗапроса.Получить("url");
	РезультатПроверки = Проверить(UrlРезюме <> Неопределено, 
		Запрос, КодыОтветов().ОшибкаЗапроса_400, ОшибкаОбязательныйПараметрURL("url"));
	Если Не РезультатПроверки.ОК Тогда
		Возврат РезультатПроверки.Ответ;
	КонецЕсли;

	UrlРезюме = РаскодироватьСтроку(UrlРезюме, СпособКодированияСтроки.КодировкаURL);
	
	УстановитьПривилегированныйРежим(Истина);
	ЗависшиеЗагрузки = ЗагрузкаКандидатовИзИнтернета.ЗависшиеОперацииЗагрузкиПоUrlJSON(UrlРезюме);
	УстановитьПривилегированныйРежим(Ложь);
	
	Если ЗависшиеЗагрузки.Количество() > 0 Тогда
		Возврат НовыйHTTPСервисРедирект(Запрос, "/import-operations/" + ЗависшиеЗагрузки[0].ID);
	КонецЕсли;

	УстановитьПривилегированныйРежим(Истина);
	ДанныеКандидатовJSON = ЗагрузкаКандидатовИзИнтернета.КандидатыПоURLJSON(UrlРезюме);
	УстановитьПривилегированныйРежим(Ложь);
	
	Если ДанныеКандидатовJSON.Количество() = 0 Тогда
		Возврат НовыйHTTPСервисОтвет(Запрос, КодыОтветов().НетСодержимого_204);
	КонецЕсли;
	
	Возврат НовыйHTTPСервисОтвет(Запрос, КодыОтветов().ОК_200, ДанныеКандидатовJSON);

КонецФункции

