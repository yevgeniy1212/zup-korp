						Справочники.ТеорияЭлектронныхКурсов.ЕдинственныйЭлемент(РедактируемаяСтрока.СсылкаНаЭлемент)
					);
					
					Если НЕ ЗначениеЗаполнено(ВидеоЭлементРесурса) Тогда
						ВызватьИсключение НСтр("ru = 'Элемент ресурса с видео не найден'");
					КонецЕсли;
					
					ВидеоЭлементРесурсаОбъект = ВидеоЭлементРесурса.ПолучитьОбъект();					
					
					ВидеоЭлементРесурсаОбъект.Описание = Новый ХранилищеЗначения(НастройкиВидеоОписание);
					ВидеоЭлементРесурсаОбъект.ПроигрыватьАвтоматически = НастройкиВидеоПроигрыватьАвтоматически;
					
					ВидеоЭлементРесурсаОбъект.ДополнительныеСвойства.Вставить("ОбновлятьВладельца", Ложь);
					
				КонецЕсли;					
				
				ВидеоЭлементРесурсаОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
				ВидеоЭлементРесурсаОбъект.Записать();				
				
			КонецЕсли;
			
			// Презентация PowerPoint и Impress (для учебников)
			//			
			
			Если РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.ПрезентацияPowerPoint
				ИЛИ РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.ПрезентацияImpress Тогда
				
				Если ЭтоНовыйЭлемент Тогда
					
					// Формируем новое наименование элемента			

					Если ЗначениеЗаполнено(НаименованиеНовогоЭлемента) Тогда
						РедактируемаяСтрока.Наименование = НаименованиеНовогоЭлемента;
					КонецЕсли;					
					
					// Создаем ресурс для хранения презентации и слайдов
					
					РесурсПрезентацииОбъект = Справочники.ЭлектронныеРесурсы.СоздатьЭлемент();
					РесурсПрезентацииОбъект.Наименование = РедактируемаяСтрока.Наименование;
					РесурсПрезентацииОбъект.Родитель = Справочники.ЭлектронныеКурсы.ГруппаДляХраненияПодчиненныхЭлементов(ЭлектронныйКурс, Тип("СправочникСсылка.ЭлектронныеРесурсы"));
					
					РазработкаЭлектронныхКурсовСлужебный.УстановитьПредпочитаемогоПоставщика(РесурсПрезентацииОбъект);
					
					РесурсПрезентацииОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
					РесурсПрезентацииОбъект.Записать();
					
					РесурсПрезентации = РесурсПрезентацииОбъект.Ссылка;							
					
					// Создаем теорию
					
					ТеорияЭлемента = СоздатьТеориюДляРазмещенияЭлементаКурса(РедактируемаяСтрока.Наименование, РедактируемаяСтрока.ТипЭлемента);
					РедактируемаяСтрока.СсылкаНаЭлемент = ТеорияЭлемента; // Запоминаем
					
					// Фиксируем ссылку на ресурс в теории
					
					ТеорияЭлементаОбъект = ТеорияЭлемента.ПолучитьОбъект();
					ТеорияЭлементаОбъект.Презентация = РесурсПрезентации;
					ТеорияЭлементаОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
					ТеорияЭлементаОбъект.Записать();
					
					// Помещаем теорию в курс
					
					ПоместитьНовыйЭлементВКурс(ТеорияЭлементаОбъект.Ссылка, РедактируемаяСтрока, ЭлементаСодержанияДляЗаписи);			
					
				Иначе
					
					РесурсПрезентации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РедактируемаяСтрока.СсылкаНаЭлемент, "Презентация");
					ТеорияЭлемента = РедактируемаяСтрока.СсылкаНаЭлемент;
					
				КонецЕсли;
				
				// Сохраняем файлы презентации в ресурс
				
				СвойстваВладельца = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ПустаяСтруктураСвойствВладельцаЗагружаемыхФайлов();
				СвойстваВладельца.ИмяВладельцаФайлов = "ЭлектронныйКурс";
				СвойстваВладельца.ЭлектронныйКурс = ЭлектронныйКурс;
				СвойстваВладельца.Теория = Неопределено;
				СвойстваВладельца.НаборФайлов = РесурсПрезентации;
				СвойстваВладельца.ЭлементСодержания = Неопределено;
				СвойстваВладельца.СтраницаТеории = Неопределено;
							
				РазработкаЭлектронныхКурсовСлужебный.ПоместитьФайлВБазу(СвойстваФайла, СвойстваВладельца);					
				
				// Формируем страницы теории (слайды презентации)
				
				ТаблицаСуществующихСтраниц = Справочники.СтраницыЭлементовЭлектронныхКурсов.ВсеЭлементы(ТеорияЭлемента);				
				ТаблицаСуществующихСтраниц.Колонки.Добавить("Идентификатор");
				Для каждого Строка Из ТаблицаСуществующихСтраниц Цикл
					Строка.Идентификатор = Лев(Строка.ПараметрыЗапуска, СтрДлина(Строка.ПараметрыЗапуска) - СтрДлина(".png"));
					Строка.Идентификатор = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(Строка.Идентификатор);
				КонецЦикла;
				
				НомерСлайда = 0;
				КодЭлемента = 0;
				МассивЗаписанныхСтраниц = Новый Массив;
				
				Для каждого СвойстваСлайда Из СвойстваФайла.НастройкиКартинок.Слайды Цикл 
					
					НомерСлайда = НомерСлайда + 1;
					КодЭлемента = КодЭлемента + 10;
					
					СуществующаяСтрока = ТаблицаСуществующихСтраниц.Найти(СвойстваСлайда.Идентификатор, "Идентификатор");
					
					Если СуществующаяСтрока = Неопределено Тогда						
						СтраницаОбъект = Справочники.СтраницыЭлементовЭлектронныхКурсов.СоздатьЭлемент();
						СтраницаОбъект.Владелец = ТеорияЭлемента;						
					Иначе						
						СтраницаОбъект = СуществующаяСтрока.Ссылка.ПолучитьОбъект();
					КонецЕсли;
					
					СтраницаОбъект.ДополнительныеСвойства.Вставить("ОтменитьУстановкуКода", Истина);					
					
					СтраницаОбъект.Наименование = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Слайд %1'"), НомерСлайда);
					СтраницаОбъект.Код = КодЭлемента;
					СтраницаОбъект.ПараметрыЗапуска = ЭлектронноеОбучениеСлужебныйКлиентСервер.ЧислоВСтроку(СвойстваСлайда.Идентификатор) + ".png";
					СтраницаОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
					СтраницаОбъект.Записать();
					
					МассивЗаписанныхСтраниц.Добавить(СтраницаОбъект.Ссылка);
					
				КонецЦикла;				

				Для каждого Строка Из ТаблицаСуществующихСтраниц Цикл
					
					// Удаляем элементы содержания слайдов
					
					Если МассивЗаписанныхСтраниц.Найти(Строка.Ссылка) = Неопределено Тогда
						 СтраницаОбъект = Строка.Ссылка.ПолучитьОбъект();
						 СтраницаОбъект.ДополнительныеСвойства.Вставить("ПомечатьПодчиненные", Ложь);
						 СтраницаОбъект.УстановитьПометкуУдаления(Истина, Истина);
					КонецЕсли;
					
				КонецЦикла;				
				
			КонецЕсли;
			
			// Статичные файлы (PDF, ZIP, HTML и картинки)
			//			
			
			Если РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.PDF
				ИЛИ РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.Архив
				ИЛИ РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.HTML
				ИЛИ РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.Картинка Тогда
				
				Если ЭтоНовыйЭлемент Тогда
					
					// Формируем новое наименование элемента			

					Если ЗначениеЗаполнено(НаименованиеНовогоЭлемента) Тогда
						РедактируемаяСтрока.Наименование = НаименованиеНовогоЭлемента;
					КонецЕсли;					
					
					// Создаем ресурс для хранения файлов
					
					РесурсФайлаОбъект = Справочники.ЭлектронныеРесурсы.СоздатьЭлемент();
					РесурсФайлаОбъект.Наименование = РедактируемаяСтрока.Наименование;
					РесурсФайлаОбъект.Родитель = Справочники.ЭлектронныеКурсы.ГруппаДляХраненияПодчиненныхЭлементов(ЭлектронныйКурс, Тип("СправочникСсылка.ЭлектронныеРесурсы"));
					
					РазработкаЭлектронныхКурсовСлужебный.УстановитьПредпочитаемогоПоставщика(РесурсФайлаОбъект);
					
					РесурсФайлаОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
					РесурсФайлаОбъект.Записать();
					
					РесурсФайла = РесурсФайлаОбъект.Ссылка;							
					
					// Создаем теорию
					
					ТеорияЭлемента = СоздатьТеориюДляРазмещенияЭлементаКурса(РедактируемаяСтрока.Наименование, РедактируемаяСтрока.ТипЭлемента);
					РедактируемаяСтрока.СсылкаНаЭлемент = ТеорияЭлемента; // Запоминаем
					
					// Помещаем ресурс в теорию
					
					СоздатьСтраницуТеории(ТеорияЭлемента, РесурсФайла, Неопределено);
					
					// Помещаем теорию в курс
					
					ПоместитьНовыйЭлементВКурс(ТеорияЭлемента, РедактируемаяСтрока, ЭлементаСодержанияДляЗаписи);			
					
					// Помещаем файл в базу
					
					СвойстваВладельца = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ПустаяСтруктураСвойствВладельцаЗагружаемыхФайлов();
					СвойстваВладельца.ИмяВладельцаФайлов = "ЭлектронныйКурс";
					СвойстваВладельца.ЭлектронныйКурс = ЭлектронныйКурс;
					СвойстваВладельца.Теория = РедактируемаяСтрока.СсылкаНаЭлемент;
					СвойстваВладельца.НаборФайлов = РесурсФайла;
					СвойстваВладельца.ЭлементСодержания = РедактируемаяСтрока.Ссылка;
					СвойстваВладельца.СтраницаТеории = Неопределено;
								
					РазработкаЭлектронныхКурсовСлужебный.ПоместитьФайлВБазу(СвойстваФайла, СвойстваВладельца);										
					
				Иначе
					
					// Находим единственный набор элементов теории
					
					СтатичныйФайлРесурс = Справочники.ТеорияЭлектронныхКурсов.ЕдинственныйЭлемент(РедактируемаяСтрока.СсылкаНаЭлемент);
					СтатичныйФайлЭлементРесурса = Справочники.ЭлектронныеРесурсы.ЕдинственныйЭлемент(СтатичныйФайлРесурс);
					
					Если НЕ ЗначениеЗаполнено(СтатичныйФайлЭлементРесурса) Тогда
						ВызватьИсключение НСтр("ru = 'Элемент ресурса с файлом не найден'");
					КонецЕсли;
					
					СтатичныйФайлЭлементРесурсаОбъект = СтатичныйФайлЭлементРесурса.ПолучитьОбъект();
					
					СтатичныйФайлЭлементРесурсаОбъект.Описание = Новый ХранилищеЗначения(НастройкиАрхиваОписание);					
					
					Если СвойстваФайла <> Неопределено
						И СвойстваФайла.Свойство("СписокФайлов")
						И СвойстваФайла.Свойство("СтруктураФайлов")
						И СвойстваФайла.СписокФайлов.Количество() = 1 Тогда
						
						// Помещаем новый файл
						
						ДвоичныеДанныеФайла = ПолучитьИзВременногоХранилища(СвойстваФайла.СписокФайлов[0].Хранение);				
						РасширениеФайла = СвойстваФайла.СтруктураФайлов[0].Расширение;
						
						Если РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.HTML Тогда
							СтатичныйФайлЭлементРесурсаОбъект.ЗаполнитьДанныеЭлементаПриЗаписи(ДвоичныеДанныеФайла, "HTML", "zip");
						Иначе							
							СтатичныйФайлЭлементРесурсаОбъект.ЗаполнитьДанныеЭлементаПриЗаписи(ДвоичныеДанныеФайла, "ДвоичныеДанные", РасширениеФайла);
						КонецЕсли;
						
						// Обновляем владельца, чтобы обновился файл в выгрузке
						СтатичныйФайлЭлементРесурсаОбъект.ДополнительныеСвойства.Вставить("ОбновлятьВладельца", Истина);						
						
						Если РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.Картинка Тогда
							ТекущаяСтруктураИмениФайла = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(СтатичныйФайлЭлементРесурсаОбъект.ИмяФайла);
							ТекущееРасширениеЭлемента = ТекущаяСтруктураИмениФайла.Расширение;
							Если НРег(ТекущееРасширениеЭлемента) <> НРег(РасширениеФайла) Тогда
								СтатичныйФайлЭлементРесурсаОбъект.ИмяФайла = ТекущаяСтруктураИмениФайла.ИмяБезРасширения + РасширениеФайла;
							КонецЕсли;
						КонецЕсли;
						
					Иначе
						
						// Не обновляем владельца, так как повторно выгружать видео не надо.
						СтатичныйФайлЭлементРесурсаОбъект.ДополнительныеСвойства.Вставить("ОбновлятьВладельца", Ложь);														
						
					КонецЕсли;												
					
					СтатичныйФайлЭлементРесурсаОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
					СтатичныйФайлЭлементРесурсаОбъект.Записать();
					
				КонецЕсли;
				
				
			КонецЕсли;
			
			// Начало (электронный курс)
			//
			
			Если РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.Начало Тогда
				
				// Сохраняем стартовую страницу
				
				ТребуемыеДанныеЭК = Новый Структура();
				ТребуемыеДанныеЭК.Вставить("СтартоваяСтраница", "СтартоваяСтраница");
				ТребуемыеДанныеЭК.Вставить("ФинальнаяСтраница", "ФинальнаяСтраница");
				ТребуемыеДанныеЭК.Вставить("Наименование", "Наименование");
				ТребуемыеДанныеЭК.Вставить("СтартоваяСтраницаЭлемент", "СтартоваяСтраница.ЕдинственныйЭлемент");
				ТребуемыеДанныеЭК.Вставить("ФинальнаяСтраницаЭлемент", "ФинальнаяСтраница.ЕдинственныйЭлемент");
				ТребуемыеДанныеЭК.Вставить("Глоссарий", "Глоссарий");
				
				ДанныеЭлектронногоКурса = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЭлектронныйКурс, ТребуемыеДанныеЭК);
				
				// Стартовая страница
				
				Если НЕ ЗначениеЗаполнено(ДанныеЭлектронногоКурса.СтартоваяСтраница) Тогда
					
					// Создаем ресурс
					
					СтартовыйРесурсОбъект = Справочники.ЭлектронныеРесурсы.СоздатьЭлемент();
					СтартовыйРесурсОбъект.Наименование = ДанныеЭлектронногоКурса.Наименование;
					СтартовыйРесурсОбъект.Родитель = Справочники.ЭлектронныеКурсы.ГруппаДляХраненияПодчиненныхЭлементов(ЭлектронныйКурс, "СправочникСсылка.ЭлектронныеРесурсы");
					
					РазработкаЭлектронныхКурсовСлужебный.УстановитьПредпочитаемогоПоставщика(СтартовыйРесурсОбъект);
					
					СтартовыйРесурсОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
					СтартовыйРесурсОбъект.Записать();

					СтартовыйРесурс = СтартовыйРесурсОбъект.Ссылка;
					
					// Создаем элемент ресурса
					
					ЭлементСтартовогоРесурсаОбъект = Справочники.ЭлементыЭлектронныхРесурсов.СоздатьЭлемент(); // Запись элемента ресурса будет ниже
					ЭлементСтартовогоРесурсаОбъект.Владелец = СтартовыйРесурс;
					ЭлементСтартовогоРесурсаОбъект.Наименование = ДанныеЭлектронногоКурса.Наименование;
					
					РазработкаЭлектронныхКурсовСлужебный.УстановитьПредпочитаемогоПоставщика(ЭлементСтартовогоРесурсаОбъект);
					
					ЭлементСтартовогоРесурсаОбъект.Тип = Перечисления.ТипыЭлементовЭлектронныхРесурсов.Text;
					ЭлементСтартовогоРесурсаОбъект.ИмяФайла = "index.html";		
					
					// Помещаем стартовую страницу в курс
				
					ЭлектронныйКурсОбъект = ЭлектронныйКурс.ПолучитьОбъект();
					ЭлектронныйКурсОбъект.СтартоваяСтраница = СтартовыйРесурс;
					ЭлектронныйКурсОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
					ЭлектронныйКурсОбъект.Записать();
					
				Иначе			
					
					ЭлементСтартовогоРесурсаОбъект =  ДанныеЭлектронногоКурса.СтартоваяСтраницаЭлемент.ПолучитьОбъект();			
					
				КонецЕсли;
				
				ЭлементСтартовогоРесурсаОбъект.ЗаполнитьДанныеЭлементаПриЗаписи(ДанныеСтартовойСтраницы, "ТекстСтраницы", "html");	
				ЭлементСтартовогоРесурсаОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
				ЭлементСтартовогоРесурсаОбъект.Записать();				
				
				// Финальная страница
				
				Если НЕ ЗначениеЗаполнено(ДанныеЭлектронногоКурса.ФинальнаяСтраница) Тогда
					
					// Создаем ресурс
					
					ФинальныйРесурсОбъект = Справочники.ЭлектронныеРесурсы.СоздатьЭлемент();
					ФинальныйРесурсОбъект.Наименование = ДанныеЭлектронногоКурса.Наименование;
					ФинальныйРесурсОбъект.Родитель = Справочники.ЭлектронныеКурсы.ГруппаДляХраненияПодчиненныхЭлементов(ЭлектронныйКурс, "СправочникСсылка.ЭлектронныеРесурсы");
					
					РазработкаЭлектронныхКурсовСлужебный.УстановитьПредпочитаемогоПоставщика(ФинальныйРесурсОбъект);
					
					ФинальныйРесурсОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
					ФинальныйРесурсОбъект.Записать();

					ФинальныйРесурс = ФинальныйРесурсОбъект.Ссылка;
					
					// Создаем элемент ресурса
					
					ЭлементФинальногоРесурсаОбъект = Справочники.ЭлементыЭлектронныхРесурсов.СоздатьЭлемент(); // Запись элемента ресурса будет ниже
					ЭлементФинальногоРесурсаОбъект.Владелец = ФинальныйРесурс;
					ЭлементФинальногоРесурсаОбъект.Наименование = ДанныеЭлектронногоКурса.Наименование;
					
					РазработкаЭлектронныхКурсовСлужебный.УстановитьПредпочитаемогоПоставщика(ЭлементФинальногоРесурсаОбъект);
					
					ЭлементФинальногоРесурсаОбъект.Тип = Перечисления.ТипыЭлементовЭлектронныхРесурсов.Text;
					ЭлементФинальногоРесурсаОбъект.ИмяФайла = "index.html";		
					
					// Помещаем стартовую страницу в курс
				
					ЭлектронныйКурсОбъект = ЭлектронныйКурс.ПолучитьОбъект();
					ЭлектронныйКурсОбъект.ФинальнаяСтраница = ФинальныйРесурс;
					ЭлектронныйКурсОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
					ЭлектронныйКурсОбъект.Записать();
					
				Иначе
					
					ЭлементФинальногоРесурсаОбъект =  ДанныеЭлектронногоКурса.ФинальнаяСтраницаЭлемент.ПолучитьОбъект();			
					
				КонецЕсли;
				
				ЭлементФинальногоРесурсаОбъект.ЗаполнитьДанныеЭлементаПриЗаписи(ДанныеФинальнойСтраницы, "ТекстСтраницы", "html");	
				ЭлементФинальногоРесурсаОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
				ЭлементФинальногоРесурсаОбъект.Записать();
				
				// Глоссарий
				
				Если ЗначениеЗаполнено(ДанныеЭлектронногоКурса.Глоссарий) Тогда
					
					ГлоссарийОбъект = ДанныеЭлектронногоКурса.Глоссарий.ПолучитьОбъект();
					ГлоссарийОбъект.ПоказыватьКоманду = ПоказыватьКомандуГлоссария;
					ГлоссарийОбъект.СоздаватьСсылки = СоздаватьСсылкиНаТерминыГлоссария;
					
					Для каждого СтрокаТТ Из ТерминыГлоссария Цикл					
						СтрокаТЧ = ГлоссарийОбъект.Термины.Найти(СтрокаТТ.Термин, "Термин");						
						Если СтрокаТЧ <> Неопределено Тогда
							ЗаполнитьЗначенияСвойств(СтрокаТЧ, СтрокаТТ, "СоздаватьСсылки, КоличествоСсылок"); 
						КонецЕсли;						
					КонецЦикла;
					
					ГлоссарийОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
					ГлоссарийОбъект.Записать();
					
					Элементы.ГруппаНастройкиГлоссария.Доступность = Истина;
					
				КонецЕсли;
				
				// Обновляем наименование курса
						
				Если ДанныеЭлектронногоКурса.Наименование <> ТекущееНаименованиеКурса() Тогда
					
					ЭлектронныйКурсОбъект = ЭлектронныйКурс.ПолучитьОбъект();
					ЭлектронныйКурсОбъект.Наименование = ТекущееНаименованиеКурса();
					ЭлектронныйКурсОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
					ЭлектронныйКурсОбъект.Записать();
					
				КонецЕсли;
				
				// Обновляем переменные формы
						
				ЗаполнитьРеквизитыЭлектронногоКурса();
				
			КонецЕсли;
			
			Если ЭтоНовыйЭлемент 
				И ИдентификаторРедактируемойСтрокиНавигационногоДерева > -1
				И РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.Тест Тогда
				
				НачатьРедактироватьЭлементКурса(); // Чтобы установить отборы вопросов в режиме редактирования теста
				
			КонецЕсли;			
			
		КонецЕсли;
		
		// Обновляем дату элемента содержания и заполняем табличную часть Гиперссылки.
		// Это делается после сохранения самого элемента, так как до этого
		// элемента содержания еще может не быть, если это новый элемент.
		//
		
		Если РедактируемаяСтрока <> Неопределено
			И ЗначениеЗаполнено(РедактируемаяСтрока.Ссылка)
			И ТипЗнч(РедактируемаяСтрока.Ссылка) = Тип("СправочникСсылка.СодержаниеЭлектронныхКурсов") Тогда
			
			ЭлементСодержанияОбъект = РедактируемаяСтрока.Ссылка.ПолучитьОбъект();				
			
			ЭлементСодержанияОбъект.Гиперссылки.Очистить();
			
			Если СвойстваФайла <> Неопределено
				И СвойстваФайла.Свойство("ВнутренниеГиперссылки")
				И ТипЗнч(СвойстваФайла.ВнутренниеГиперссылки) = Тип("Соответствие") Тогда
				
				Для каждого ЭлементСоответствия Из СвойстваФайла.ВнутренниеГиперссылки Цикл
					НоваяСтрокаТЧ = ЭлементСодержанияОбъект.Гиперссылки.Добавить();
					НоваяСтрокаТЧ.Привязка = ЭлементСоответствия.Значение;
					НоваяСтрокаТЧ.АдресВДокументе = ЭлементСоответствия.Ключ;			
				КонецЦикла;					
				
			КонецЕсли;
			
			ЭлементСодержанияОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
			ЭлементСодержанияОбъект.Записать();
			
		КонецЕсли;		
		
		// Обновляем дату курса (если курс не записывался ранее)
		//
		
		Если ЭлектронныйКурсОбъект = Неопределено Тогда
			ЭлектронныйКурсОбъект = ЭлектронныйКурс.ПолучитьОбъект();
			ЭлектронныйКурсОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);			
			ЭлектронныйКурсОбъект.Записать();
		КонецЕсли;		
		
		// Завершаем
		//
		
		ЗафиксироватьТранзакцию();
		
	Исключение
 
 		ОтменитьТранзакцию();
		ЭлектронноеОбучениеСлужебный.ЗаписатьОшибкуВЖурналРегистрации(ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		Если ЭтоПерваяЗаписьЭлектронногоКурса = Истина Тогда
			ЭлектронныйКурс = Неопределено; // Убираем заполненность реквизита в реквизите формы
		КонецЕсли;
		
		Если ЭтоНовыйЭлемент = Истина И РедактируемаяСтрока <> Неопределено Тогда
			РедактируемаяСтрока.Ссылка = Неопределено;
			РедактируемаяСтрока.СсылкаНаЭлемент = Неопределено;
		КонецЕсли;
		
		ЗаполнитьРеквизитыЭлектронногоКурса();
		
		ВызватьИсключение;
		
	КонецПопытки;		
	
	Модифицированность = Ложь;
	
КонецПроцедуры

&НаСервере
Процедура СохранитьНовуюГруппуЭлементовНаСервере(НомерРедактируемойСтроки)
	
	Если НЕ ЗначениеЗаполнено(ЭлектронныйКурс) Тогда
		ЗаписатьНовыйЭлектронныйКурс();
	КонецЕсли;
	
	РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(НомерРедактируемойСтроки);
	
	НоваяГруппаОбъект = Справочники.СодержаниеЭлектронныхКурсов.СоздатьГруппу();
	НоваяГруппаОбъект.Владелец = ЭлектронныйКурс;
	НоваяГруппаОбъект.Наименование = РедактируемаяСтрока.Наименование;
	
	РодительскаяСтрока = РедактируемаяСтрока.ПолучитьРодителя();
	
	Если РодительскаяСтрока <> Неопределено
		И РодительскаяСтрока.ЭтоГруппа
		И ЗначениеЗаполнено(РодительскаяСтрока.Ссылка)
		И ТипЗнч(РодительскаяСтрока.Ссылка) = Тип("СправочникСсылка.СодержаниеЭлектронныхКурсов") Тогда
		
		НоваяГруппаОбъект.Родитель = РодительскаяСтрока.Ссылка;
		
	КонецЕсли;
	
	НоваяГруппаОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
	НоваяГруппаОбъект.Записать();
	
	РедактируемаяСтрока.Ссылка = НоваяГруппаОбъект.Ссылка;
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьНовыйЭлектронныйКурс()
	
	Если ЗначениеЗаполнено(ЭлектронныйКурс) Тогда
		Возврат;
	КонецЕсли;
	
	ЭлектронныйКурс = Справочники.ЭлектронныеКурсы.СоздатьЭлектронныйКурс(ТекущееНаименованиеКурса(), ТипЭлектронногоКурса, Неопределено, Параметры.КонтекстРедактирования); 
	
	// Обновляем реквизиты формы
	
	ЗаполнитьРеквизитыЭлектронногоКурса(); // Заполняем переменные формы по новому курсу
	
	КореньДерева = НавигационноеДерево.НайтиПоИдентификатору(0);
	КореньДерева.Ссылка = ЭлектронныйКурс;
	КореньДерева.СсылкаНаЭлемент = ЭлектронныйКурс;						
	
КонецПроцедуры

&НаСервере
Процедура ПоместитьНовыйЭлементВКурс(СсылкаНаЭлемент, РедактируемаяСтрока, ЭлементаСодержанияДляЗаписи = Неопределено)
	
	// Записываем элемент содержания
			
	РодительРедактируемойСтроки = РедактируемаяСтрока.ПолучитьРодителя().Ссылка;

	Если ТипЗнч(РодительРедактируемойСтроки) <> Тип("СправочникСсылка.СодержаниеЭлектронныхКурсов") Тогда
		РодительРедактируемойСтроки = Справочники.СодержаниеЭлектронныхКурсов.ПустаяСсылка();
	КонецЕсли;

	Если НЕ ЗначениеЗаполнено(РедактируемаяСтрока.Ссылка) Тогда		
		СсылкаНаЭлементСодержанияДляУстановки = Неопределено;
		Если ЗначениеЗаполнено(ЭлементаСодержанияДляЗаписи)
			И ТипЗнч(ЭлементаСодержанияДляЗаписи) = Тип("УникальныйИдентификатор") Тогда
			СсылкаНаЭлементСодержанияДляУстановки = Справочники.СодержаниеЭлектронныхКурсов.ПолучитьСсылку(ЭлементаСодержанияДляЗаписи);
		КонецЕсли;
		Если ЗначениеЗаполнено(ЭлементаСодержанияДляЗаписи)
			И ТипЗнч(ЭлементаСодержанияДляЗаписи) = Тип("СправочникСсылка.СодержаниеЭлектронныхКурсов") Тогда
			СсылкаНаЭлементСодержанияДляУстановки = ЭлементаСодержанияДляЗаписи;
		КонецЕсли;		
		НовыйЭлементСодержания = Справочники.ЭлектронныеКурсы.ДобавитьЭлементСодержания(ЭлектронныйКурс, СсылкаНаЭлемент, РодительРедактируемойСтроки, Ложь, РедактируемаяСтрока.Наименование, РедактируемаяСтрока.ТипЭлемента, СсылкаНаЭлементСодержанияДляУстановки, Параметры.КонтекстРедактирования);
		РедактируемаяСтрока.Ссылка = НовыйЭлементСодержания; // Запоминаем		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СоздатьТеориюДляРазмещенияЭлементаКурса(Наименование, ТипЭлемента)	    
			
	ТеорияКурсаОбъект = Справочники.ТеорияЭлектронныхКурсов.СоздатьЭлемент();
	ТеорияКурсаОбъект.Наименование = Наименование;
	ТеорияКурсаОбъект.Родитель = Справочники.ЭлектронныеКурсы.ГруппаДляХраненияПодчиненныхЭлементов(ЭлектронныйКурс, "СправочникСсылка.ТеорияЭлектронныхКурсов");
	
	РазработкаЭлектронныхКурсовСлужебный.УстановитьПредпочитаемогоПоставщика(ТеорияКурсаОбъект);	
	
	ТеорияКурсаОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
	ТеорияКурсаОбъект.Записать();
	
	Возврат ТеорияКурсаОбъект.Ссылка;
	
КонецФункции

&НаСервере
Функция СоздатьСтраницуТеории(Знач ТеорияИлиТест, Знач ЭлементСтраницы, Знач ГруппаСтраниц, Знач ВесВопроса = 1)
	
	СозданнаяСтраница = Неопределено;
	
	Если ЗначениеЗаполнено(ЭлементСтраницы) И ТипЗнч(ЭлементСтраницы) = Тип("СправочникСсылка.ЭлементыЭлектронныхРесурсов") Тогда
		ЭлементСтраницы = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлементСтраницы, "Владелец"); // Прикрепляем ресурс, а не файл
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭлементСтраницы) Тогда
		СозданнаяСтраница = Справочники.СтраницыЭлементовЭлектронныхКурсов.ДобавитьСтраницу(ТеорияИлиТест, ЭлементСтраницы, ГруппаСтраниц, Параметры.КонтекстРедактирования, ВесВопроса);
	КонецЕсли;
	
	Если ТипЗнч(ТеорияИлиТест) = Тип("СправочникСсылка.ЭлектронныеТесты") Тогда
		Элементы.СтраницыТеста.Обновить();
		УстановитьМаксимальноеКоличествоВопросовВНастройкеТеста(ТеорияИлиТест);
		УстановитьДоступностьНастроекТестирования(ЭтотОбъект);		
	КонецЕсли;	
	
	Возврат СозданнаяСтраница;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимостьЭлементовРедактораКурса(ВидимостьРедактора, Форма)
	
	// Убираем видимость команд редактора.
	// Она будет установлена для каждого типа элемента 
	// отдельно в процедуре НачатьРедактироватьЭлементКурса.
	
	Форма.Элементы.КомандыМастераСозданияЭлемента.Видимость = Ложь;
	Форма.Элементы.КомандыТеста.Видимость = Ложь;
	Форма.Элементы.КомандыДокумента.Видимость = Ложь;
	Форма.Элементы.КомандыДокументаWord.Видимость = Ложь;
	Форма.Элементы.КомандыДокументаOpenOffice.Видимость = Ложь;
	Форма.Элементы.КомандыПрезентации.Видимость = Ложь;
	Форма.Элементы.КомандыАрхив.Видимость = Ложь;
	Форма.Элементы.КомандыВидео.Видимость = Ложь;
	Форма.Элементы.КомандыYouTube.Видимость = Ложь;
	Форма.Элементы.КомандыЗвук.Видимость = Ложь;
	Форма.Элементы.КомандыНачало.Видимость = Ложь;
	
	Если ВидимостьРедактора Тогда		
		
		Форма.Элементы.СтраницыРедактора.Видимость = Истина;				
		Форма.Элементы.КомандыПросмотра.Видимость = Ложь;
		
		Форма.Элементы.КомандыРедактированияНавигационногоДерева.Доступность = Ложь;
		Форма.Элементы.НавигационноеДерево.ИзменятьСоставСтрок = Ложь;
		
	Иначе		
		
		Форма.Элементы.СтраницыРедактора.Видимость = Ложь;
		Форма.Элементы.КомандыПросмотра.Видимость = Истина;
		
		Форма.Элементы.КомандыРедактированияНавигационногоДерева.Доступность = Истина;
		Форма.Элементы.НавигационноеДерево.ИзменятьСоставСтрок = Истина;
		Форма.Элементы.НавигационноеДерево.Доступность = Истина;
		
		// Показываем область просмотра
		
		Форма.Элементы.ОбластьПросмотра.Видимость = Истина;		
		
		// Очищаем данные при выходе из редактора
		
		Форма.ДанныеХраненияВнешнегоДокумента = Неопределено; // Именно Неопределено
		Форма.ДанныеДокумента = "";
		Форма.ДанныеСтартовойСтраницы = "";
		Форма.ДанныеФинальнойСтраницы = "";

		Форма.НастройкиВидеоОписание = Неопределено;
		Форма.НастройкиВидеоПроигрыватьАвтоматически = Ложь;
		
		Форма.ИдентификаторРедактируемойСтрокиНавигационногоДерева = -1;
		
		ЭлектронноеОбучениеСлужебныйКлиентСервер.УстановитьОтборЭлементовДинамическогоСписка(Форма.СтраницыЭлементов, Неопределено);		

	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Функция ВыполняетсяРедактированиеЭлемента()

	Если НЕ РежимРедактирования Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если ИдентификаторРедактируемойСтрокиНаКлиенте() > -1 Тогда
		Возврат Истина;
	Иначе		
		Возврат Ложь;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура ВыйтиИзРежимаРедактирования(СпроситьОСохранении = Истина, ПерваяЗаписьКурса = Ложь)

	РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());	
	
	Если РедактируемаяСтрока = Неопределено Тогда
		ЗакрытьРедакторЭлемента();
		Возврат;
	КонецЕсли;
	
	Если НЕ Модифицированность
		И РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ДокументWord")
		И РазработкаЭлектронныхКурсовСлужебныйКлиент.ДокументWordМодифицирован(ПриложениеWord) Тогда
		
		Модифицированность = Истина;
		
	КонецЕсли;
			
	Если СпроситьОСохранении И Модифицированность Тогда		
		ОписаниеОповещения = Новый ОписаниеОповещения("СпроситьОЗавершенииРедактированияЭлементаПродолжение", ЭтотОбъект);			
		ПоказатьВопрос(ОписаниеОповещения, НСтр("ru = 'Записать изменения?'"), РежимДиалогаВопрос.ДаНет, 0);		
	Иначе		
		ЗакрытьРедакторЭлемента();
		Если ИдентификаторЕдинственнойСтрокиНавигационногоДерева > -1 Тогда
			ПодключитьОбработчикОжидания("АктивироватьЭлементСодержанияЧерезОбработчик", 0.01, Истина); //Web-client 404 bug
			// При наличии дерева содержания событие ПриАктивацииСтроки дерева будет вызвано платформой автоматически
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОтменитьСозданиеСлайда()
	
	РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());	
	
	Если РедактируемаяСтрока = Неопределено Тогда
		ЗакрытьРедакторЭлемента();
		Возврат;
	КонецЕсли;
	
	РедактируемаяСтрока.ПолучитьРодителя().ПолучитьЭлементы().Удалить(РедактируемаяСтрока);
	ЗакрытьРедакторЭлемента();
	
КонецПроцедуры

&НаКлиенте
Процедура СпроситьОЗавершенииРедактированияЭлементаПродолжение(Ответ, ДополнительныеПараметры) Экспорт

	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		СохранитьЭлементКурса();
		
		ПриРедактировании();
		
	Иначе
		
		РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());
			
		Если НЕ ЗначениеЗаполнено(РедактируемаяСтрока.СсылкаНаЭлемент) Тогда
			РедактируемаяСтрока.ПолучитьРодителя().ПолучитьЭлементы().Удалить(РедактируемаяСтрока);	
		КонецЕсли;
		
	КонецЕсли;

	ЗакрытьРедакторЭлемента();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьРедакторЭлемента()
	
	Если РазработкаЭлектронныхКурсовСлужебныйКлиент.ПрезентацияPowerPointДоступна(ПриложениеPowerPoint) Тогда		
		ЗакрытьПрезентациюPowerPoint(Ложь);	
	КонецЕсли;
	
	Если РазработкаЭлектронныхКурсовСлужебныйКлиент.ПрезентацияImpressДоступна(ПриложениеImpress) Тогда		
		ЗакрытьПрезентациюOpenOffice(Ложь, Ложь);	
	КонецЕсли;	
	
	Если РазработкаЭлектронныхКурсовСлужебныйКлиент.ДокументWordДоступен(ПриложениеWord) Тогда		
		ЗакрытьДокументWord();	
	КонецЕсли;
	
	РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());
	
	Если РедактируемаяСтрока <> Неопределено Тогда
		
		РедактируемаяСтрока.Картинка = КартинкаЭлементаСодержания(РедактируемаяСтрока, ТипЭлектронногоКурса);
		
		Если РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ПрезентацияPowerPoint")
			ИЛИ РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.СлайдПрезентацииPowerPoint") Тогда
			
			Если ОбщегоНазначенияКлиент.ЭтоOSXКлиент() Тогда
				
				ПутьКФайлуПрограммыКонвертации = ПриложениеPowerPoint.Скрытое + "closePresentations.scpt";
				ПараметрыЗапускаПрограммы = ФайловаяСистемаКлиент.ПараметрыЗапускаПрограммы();			
				ПараметрыЗапускаПрограммы.ДождатьсяЗавершения = Истина;						
				ФайловаяСистемаКлиент.ЗапуститьПрограмму("osascript """ + ПутьКФайлуПрограммыКонвертации + """", ПараметрыЗапускаПрограммы);		
				
				// Под windows такой ситуации не возникает,
				// так как при закрытии презентации редактирование
				// завершается автоматически. Под macOS пользователь
				// может вручную нажать команду.
				
			КонецЕсли;				
			
		КонецЕсли;
		
		Если РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ДокументOpenOffice") Тогда				
			ЗакрытьДокументOpenOffice();				
		КонецЕсли;		
		
		Если РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ПрезентацияPowerPoint") Тогда						
			УстановитьЭлементДляПросмотра(ТекущийЭлементСодержания());				
		КонецЕсли;
		
	КонецЕсли;
	
	УстановитьВидимостьЭлементовРедактораКурса(Ложь, ЭтотОбъект);	
	
	Модифицированность = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ПросмотретьСтраницуЭлементаКурса(ТаблицаЭлементов = Неопределено)
	
	Если ТаблицаЭлементов = Неопределено Тогда
		ТаблицаЭлементов = ТаблицаРедактируемогоНабораЭлементов();
	КонецЕсли;
	
	Если ТаблицаЭлементов = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаЭлементов.Обновить();
	
	ТекущиеДанные = ТаблицаЭлементов.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущиеДанные = Неопределено
		ИЛИ ТекущиеДанные.ЭтоГруппа Тогда
		
		УстановитьЭлементДляПросмотра(Неопределено); // Пустая страница
		
	Иначе
		
		УстановитьЭлементДляПросмотра(ТекущиеДанные.Ссылка); // Элемент подборки
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ТаблицаРедактируемогоНабораЭлементов()
	
	Если НЕ ВыполняетсяРедактированиеЭлемента() Тогда
		Возврат Неопределено;
	КонецЕсли;	
	
	РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());	
		
	Если ТипЗнч(РедактируемаяСтрока.СсылкаНаЭлемент) = Тип("СправочникСсылка.ЭлектронныеТесты") Тогда
		Возврат Элементы.СтраницыТеста;
	Иначе
		ВызватьИсключение НСтр("ru = 'Неизвестный тип элемента набора'");
	КонецЕсли;
	
КонецФункции

&НаСервереБезКонтекста
Процедура ЗаписатьНовоеНаименованиеЭлемента(ЭлементСодержания, СсылкаНаЭлемент,  НовоеНаименование, ЭтоГруппа, КонтекстРедактирования)
	
	НачатьТранзакцию();
	
	Попытка
		
		Если НЕ ЭтоГруппа И ЗначениеЗаполнено(СсылкаНаЭлемент) Тогда
			
			БлокировкаДанных = Новый БлокировкаДанных;
		    ЭлементБлокировкиДанных = БлокировкаДанных.Добавить(ОбщегоНазначения.ИмяТаблицыПоСсылке(СсылкаНаЭлемент));
		    ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", СсылкаНаЭлемент);
		    ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
		    БлокировкаДанных.Заблокировать();
				
			СсылкаНаЭлементОбъект = СсылкаНаЭлемент.ПолучитьОбъект();
			СсылкаНаЭлементОбъект.Наименование = НовоеНаименование;
			СсылкаНаЭлементОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", КонтекстРедактирования);
			СсылкаНаЭлементОбъект.Записать();

		КонецЕсли;
			
		Если ЭлементСодержания <> СсылкаНаЭлемент Тогда // Равенство возможно для корня
			
			БлокировкаДанных = Новый БлокировкаДанных;
		    ЭлементБлокировкиДанных = БлокировкаДанных.Добавить(ОбщегоНазначения.ИмяТаблицыПоСсылке(ЭлементСодержания));
		    ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", ЭлементСодержания);
		    ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
		    БлокировкаДанных.Заблокировать();
			
			ЭлементСодержанияОбъект = ЭлементСодержания.ПолучитьОбъект();
			ЭлементСодержанияОбъект.Наименование = НовоеНаименование;
			ЭлементСодержанияОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", КонтекстРедактирования);
			ЭлементСодержанияОбъект.Записать();
			
		КонецЕсли;
		
		Если ЗначениеЗаполнено(СсылкаНаЭлемент)
			И ТипЗнч(СсылкаНаЭлемент) = Тип("СправочникСсылка.ТеорияЭлектронныхКурсов") Тогда
			
			ЕдинственныйЭлемент = Справочники.ТеорияЭлектронныхКурсов.ЕдинственныйЭлемент(СсылкаНаЭлемент);
			
			Если ЗначениеЗаполнено(ЕдинственныйЭлемент) Тогда
				
				// Обновляем наименование элемента
				
	  			БлокировкаДанных = Новый БлокировкаДанных;
			    ЭлементБлокировкиДанных = БлокировкаДанных.Добавить(ОбщегоНазначения.ИмяТаблицыПоСсылке(ЕдинственныйЭлемент));
			    ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", ЕдинственныйЭлемент);
			    ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
			    БлокировкаДанных.Заблокировать();			
				
				ЕдинственныйЭлементОбъект = ЕдинственныйЭлемент.ПолучитьОбъект();
				ЕдинственныйЭлементОбъект.Наименование = НовоеНаименование;
				ЕдинственныйЭлементОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", КонтекстРедактирования);
				ЕдинственныйЭлементОбъект.Записать();
				
				Если ТипЗнч(ЕдинственныйЭлемент) = Тип("СправочникСсылка.ЭлектронныеРесурсы") Тогда
					
					ЕдинственныйЭлементРесурса = Справочники.ЭлектронныеРесурсы.ЕдинственныйЭлемент(ЕдинственныйЭлемент);
					
					Если ЗначениеЗаполнено(ЕдинственныйЭлементРесурса) Тогда
						
						БлокировкаДанных = Новый БлокировкаДанных;
					    ЭлементБлокировкиДанных = БлокировкаДанных.Добавить(ОбщегоНазначения.ИмяТаблицыПоСсылке(ЕдинственныйЭлементРесурса));
					    ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", ЕдинственныйЭлементРесурса);
					    ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
					    БлокировкаДанных.Заблокировать();					
						
						ЕдинственныйЭлементРесурсаОбъект = ЕдинственныйЭлементРесурса.ПолучитьОбъект();
						ЕдинственныйЭлементРесурсаОбъект.Наименование = НовоеНаименование;
						ЕдинственныйЭлементРесурсаОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", КонтекстРедактирования);
						ЕдинственныйЭлементРесурсаОбъект.Записать();					
						
					КонецЕсли;
					
				КонецЕсли;
					
				// Обновляем наименование страниц
		
				Запрос = Новый Запрос;
				Запрос.Текст = 
					"ВЫБРАТЬ
					|	СтраницыЭлементовЭлектронныхКурсов.Ссылка
					|ИЗ
					|	Справочник.СтраницыЭлементовЭлектронныхКурсов КАК СтраницыЭлементовЭлектронныхКурсов
					|ГДЕ
					|	СтраницыЭлементовЭлектронныхКурсов.Владелец = &Теория
					|	И СтраницыЭлементовЭлектронныхКурсов.СсылкаНаЭлементКурса = &СсылкаНаЭлемент";
				
				Запрос.УстановитьПараметр("СсылкаНаЭлемент", ЕдинственныйЭлемент);
				Запрос.УстановитьПараметр("Теория", СсылкаНаЭлемент);
				
				РезультатЗапроса = Запрос.Выполнить();
				
				ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
				
				Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
					
					БлокировкаДанных = Новый БлокировкаДанных;
				    ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Справочник.СтраницыЭлементовЭлектронныхКурсов");
				    ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", ВыборкаДетальныеЗаписи.Ссылка);
				    ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
				    БлокировкаДанных.Заблокировать();				
					
					СтраницаОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
					СтраницаОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", КонтекстРедактирования);
					СтраницаОбъект.Записать();
					
				КонецЦикла;
				
			КонецЕсли;		
			
		КонецЕсли;		
		
		ЗафиксироватьТранзакцию();
	
	Исключение
	
	 	ОтменитьТранзакцию();
		ЭлектронноеОбучениеСлужебный.ЗаписатьОшибкуВЖурналРегистрации(ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ВызватьИсключение;
		
	КонецПопытки;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция УстановитьСнятьОтметкуСкрытияЭлементаСодержания(Знач ЭлементСодержания, Знач ЭтоГруппа, Знач Скрыть, Знач КонтекстРедактирования)	
	
	Если НЕ ЗначениеЗаполнено(ЭлементСодержания) Тогда
		ВызватьИсключение НСтр("ru = 'Элемент содержания не найден'");
	КонецЕсли;	
	
	Если ЭтоГруппа Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	СодержаниеЭлектронныхКурсов.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.СодержаниеЭлектронныхКурсов КАК СодержаниеЭлектронныхКурсов
			|ГДЕ
			|	СодержаниеЭлектронныхКурсов.ПометкаУдаления = ЛОЖЬ
			|	И СодержаниеЭлектронныхКурсов.Ссылка В ИЕРАРХИИ(&ЭлементСодержания)";
		
		Запрос.УстановитьПараметр("ЭлементСодержания", ЭлементСодержания);		
		ЭлементыСодержанияДляСкрытия = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");		
				
	Иначе		
		
		ЭлементыСодержанияДляСкрытия = Новый Массив;
		ЭлементыСодержанияДляСкрытия.Добавить(ЭлементСодержания);		
		
	КонецЕсли;
	
	НачатьТранзакцию();
	
	Попытка
		
		БлокировкаДанных = Новый БлокировкаДанных;
		
		Для каждого ЭлементСодержанияДляСкрытия Из ЭлементыСодержанияДляСкрытия Цикл
		    ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Справочник.СодержаниеЭлектронныхКурсов");
		    ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", ЭлементСодержанияДляСкрытия);
			ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
		КонецЦикла;		
		
		БлокировкаДанных.Заблокировать();
		
		Для каждого ЭлементСодержанияДляСкрытия Из ЭлементыСодержанияДляСкрытия Цикл		
			ЭлементСодержанияОбъект = ЭлементСодержанияДляСкрытия.ПолучитьОбъект();
			ЭлементСодержанияОбъект.Скрытый = Скрыть;
			ЭлементСодержанияОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", КонтекстРедактирования);
			ЭлементСодержанияОбъект.Записать();		
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
	
	Исключение
	
	 	ОтменитьТранзакцию();
		ЭлектронноеОбучениеСлужебный.ЗаписатьОшибкуВЖурналРегистрации(ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ВызватьИсключение;
		
	КонецПопытки;	
	
	Возврат Новый ФиксированныйМассив(ЭлементыСодержанияДляСкрытия);
	
КонецФункции

&НаКлиенте
Процедура ПриРедактировании()
	
	Если НЕ Отредактирован Тогда
		ЗафиксироватьРедактирование(ЭлектронныйКурс, Ложь, УникальныйИдентификатор, Параметры.КонтекстРедактирования);
	КонецЕсли;
	
	Отредактирован = Истина;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗафиксироватьРедактирование(Знач ЭлектронныйКурс, Знач Публиковать, Знач ИдентификаторФормы, Знач КонтекстРедактирования)
	
	ПараметрыЗадания = РазработкаЭлектронныхКурсов.ЗафиксироватьРедактированиеЭлектронногоКурса(ЭлектронныйКурс, Публиковать, ИдентификаторФормы, КонтекстРедактирования);
	
	Если ПараметрыЗадания = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ПараметрыЗадания.ИдентификаторЗадания
	
КонецФункции

#КонецОбласти

#Область ЗагрузкаФайлов

&НаКлиенте
Процедура ЗагрузитьФайлы(ТипЭлементаРесурса = Неопределено)
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ЗагрузитьФайлыПродолжение", ЭтотОбъект);
	
	МассивТиповВыбора = Новый Массив;
	
	Если ТипЭлементаРесурса = Неопределено Тогда
	
		МассивТиповВыбора.Добавить(ПредопределенноеЗначение("Перечисление.ТипыЭлементовЭлектронныхРесурсов.Video"));
		МассивТиповВыбора.Добавить(ПредопределенноеЗначение("Перечисление.ТипыЭлементовЭлектронныхРесурсов.Audio"));	
		МассивТиповВыбора.Добавить(ПредопределенноеЗначение("Перечисление.ТипыЭлементовЭлектронныхРесурсов.Document"));	
		МассивТиповВыбора.Добавить(ПредопределенноеЗначение("Перечисление.ТипыЭлементовЭлектронныхРесурсов.Presentation"));	
		МассивТиповВыбора.Добавить(ПредопределенноеЗначение("Перечисление.ТипыЭлементовЭлектронныхРесурсов.Table"));
		МассивТиповВыбора.Добавить(ПредопределенноеЗначение("Перечисление.ТипыЭлементовЭлектронныхРесурсов.Image"));
		МассивТиповВыбора.Добавить("html");
		МассивТиповВыбора.Добавить("htm");
		МассивТиповВыбора.Добавить("url");
		МассивТиповВыбора.Добавить("zip");
		МассивТиповВыбора.Добавить("pdf");
		
	Иначе
		
		МассивТиповВыбора.Добавить(ТипЭлементаРесурса);
		
	КонецЕсли;
		
	ДиалогВыбораФайлов = РазработкаЭлектронныхКурсовСлужебныйКлиент.ДиалогВыбораФайлаПоТипу(
		МассивТиповВыбора,
		НСтр("ru = 'Выберите файлы для загрузки'"),
		НСтр("ru = 'Файлы для загрузки'"));
	
	ДиалогВыбораФайлов.МножественныйВыбор = Истина;
	ДиалогВыбораФайлов.Показать(ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьФайлыПродолжение(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	
	#Если НЕ ВебКлиент И НЕ МобильныйКлиент Тогда

	Если ВыбранныеФайлы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	МассивФайлов = Новый Массив;	
	Для каждого ВыбранныйФайл Из ВыбранныеФайлы Цикл	
		МассивФайлов.Добавить(Новый Файл(ВыбранныйФайл));	
	КонецЦикла;		
	ЗаполнитьПеременнуюФайлыДляЗагрузки(МассивФайлов); // Заполняем переменную модуля ФайлыДляЗагрузки
	ПодключитьОбработчикОжидания("Подключаемый_ЗагрузитьФайлыСДискаВБазу", 0.5, Истина);
	
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьКаталог()
	
	#Если НЕ ВебКлиент И НЕ МобильныйКлиент Тогда
		
	ДиалогОткрытияФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
	ДиалогОткрытияФайла.МножественныйВыбор = Ложь;
	ДиалогОткрытияФайла.Заголовок = НСтр("ru = 'Выберите каталог для загрузки'");
	
	Если ДиалогОткрытияФайла.Выбрать() Тогда
		ПутьККаталогуСФайлами = ДиалогОткрытияФайла.Каталог;			
		ПутьККаталогуСФайлами = ЭлектронноеОбучениеСлужебныйКлиентСервер.ДобавитьКонечныйРазделительПути(ПутьККаталогуСФайлами);
		ЗагрузитьФайлыИзКаталога(ПутьККаталогуСФайлами);
	КонецЕсли;		
	
	#КонецЕсли	
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ЗагрузитьФайлыСДискаВБазу()
	ЗагрузитьФайлыСДискаВБазу();
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьФайлыСДискаВБазуПриОткрытииФормы()
	
	СтруктураИмениКаталога = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(Параметры.ПутьККаталогуСФайламиКурса);
	НаименованиеКурса = СтруктураИмениКаталога.Имя;
	ИзменитьНаименованиеКурса();
	ЗагрузитьФайлыИзКаталога(Параметры.ПутьККаталогуСФайламиКурса);	
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьФайлыИзКаталога(ПутьККаталогуСФайлами)
	
	МассивФайлов = ЭлектронноеОбучениеСлужебныйКлиентСервер.ИскатьФайлы(ПутьККаталогуСФайлами, "*", Ложь);	
	ЗаполнитьПеременнуюФайлыДляЗагрузки(МассивФайлов); // Заполняем переменную модуля ФайлыДляЗагрузки	
	ЗагрузитьФайлыСДискаВБазу();	
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьФайлыСДискаВБазу()
	
	#Если НЕ ВебКлиент И НЕ МобильныйКлиент Тогда
		
	КоличествоФайлов = ФайлыДляЗагрузки.Количество();
	
	Если КоличествоФайлов = 0  Тогда
		Возврат;
	КонецЕсли;	
	
	РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());	
	ИдентификаторРодительскойСтроки = Неопределено;
	Если РедактируемаяСтрока <> Неопределено
		И НЕ РедактируемаяСтрока.ЭтоКорень Тогда
		ИдентификаторРодительскойСтроки = ИдентификаторСтрокиНавигационногоДереваПоСсылкеНаЭлемент(РедактируемаяСтрока.ПолучитьРодителя().Ссылка)
	КонецЕсли;
	
	ОтменитьСозданиеСлайда();
	
	ПерваяЗаписьКурса = НЕ ЗначениеЗаполнено(ЭлектронныйКурс);
	
	ВыйтиИзРежимаРедактирования(,ПерваяЗаписьКурса);
	
	Если Модифицированность Тогда
		Возврат; // Еще не сохранили текущие изменения
	КонецЕсли;	
			
	// Примечание: массив ФайлыДляЗагрузки уже содержит только те файлы и каталоги,
	// которые поддерживаются текущим типом курса. Они фильтруются в процедуре
	// ЗаполнитьПеременнуюФайлыДляЗагрузки.
		
	ПерваяЗаписьКурса = НЕ ЗначениеЗаполнено(ЭлектронныйКурс);
	ЗагруженоФайлов = 0;	
	ВидеоФайлыДляКонвертирования = Новый Массив;
	
	// Заполняем массив с полными путями скрытых каталогов и файлов внутри их
	
	ПутиКСкрытымФайламиИКаталогам = Новый Массив;
	Для каждого Файл Из ФайлыДляЗагрузки Цикл	
		КаталогСкрытыхРесурсов = НайтиКаталогСкрытыхРесурсов(Файл);
		Если КаталогСкрытыхРесурсов <> Неопределено Тогда			
			ПутиКСкрытымФайламиИКаталогам.Добавить(КаталогСкрытыхРесурсов.ПолноеИмя);
			Для каждого ФайлСкрытогоКаталога Из ФайлыДляЗагрузки Цикл
				Если СтрНайти(ФайлСкрытогоКаталога.ПолноеИмя, КаталогСкрытыхРесурсов.ПолноеИмя) > 0
					И ФайлСкрытогоКаталога.ПолноеИмя <> Файл.ПолноеИмя
					И ПутиКСкрытымФайламиИКаталогам.Найти(ФайлСкрытогоКаталога.ПолноеИмя) = Неопределено Тогда
					
					ПутиКСкрытымФайламиИКаталогам.Добавить(ФайлСкрытогоКаталога.ПолноеИмя);
					
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	КоличествоФайлов = ФайлыДляЗагрузки.Количество() - ПутиКСкрытымФайламиИКаталогам.Количество();
	
	// Заполняем список элементов содержания, которые будут записаны в базу.
	// Это делается для того, чтобы сразу заменять гиперссылки до реальной записи
	// элементов в базу.
	
	БудущиеЭлементыСодержания = Новый Соответствие;
	
	Для каждого Файл Из ФайлыДляЗагрузки Цикл
	
		Если ПутиКСкрытымФайламиИКаталогам.Найти(Файл.ПолноеИмя) <> Неопределено Тогда
			Продолжить; // Это скрытый файл или каталог (он будет загружен внутрь элемента)
		КонецЕсли;		
		
		МассивПараметровК = Новый Массив;
		МассивПараметровК.Добавить(Новый УникальныйИдентификатор());
		БудущийЭлементСодержания = Новый(Тип("СправочникСсылка.СодержаниеЭлектронныхКурсов"), МассивПараметровК);
		БудущиеЭлементыСодержания.Вставить(Файл.ПолноеИмя, БудущийЭлементСодержания);
		
	КонецЦикла;	
	
	// Соответствие пути к каталогу и ссылки на группу
	// элемента справочника СодержаниеЭлектронныхКурсов.
	ЗагруженныеГруппыЭлементов = Новый Соответствие; 	
	
	// Выполняем загрузку в базу
	
	Для каждого Файл Из ФайлыДляЗагрузки Цикл		
		
		Состояние(НСтр("ru = 'Загружаются файлы...'"), Окр(ЗагруженоФайлов/КоличествоФайлов*100), Файл.Имя);
		
		Если ПутиКСкрытымФайламиИКаталогам.Найти(Файл.ПолноеИмя) <> Неопределено Тогда
			Продолжить; // Это скрытый файл или каталог (он будет загружен внутрь элемента)
		КонецЕсли;
		
		РодительскийЭлементСодержания = ЗагруженныеГруппыЭлементов.Получить(Файл.Путь);				
		Если РодительскийЭлементСодержания <> Неопределено Тогда
			ИдентификаторРодительскойСтроки = ИдентификаторСтрокиНавигационногоДереваПоСсылкеНаЭлемент(РодительскийЭлементСодержания);
		Иначе
			ИдентификаторРодительскойСтроки = Неопределено;
		КонецЕсли;		
		
		БудущийЭлементСодержания = БудущиеЭлементыСодержания.Получить(Файл.ПолноеИмя);
		
		Если Файл.ЭтоКаталог() Тогда
			
			НоваяСтрока = НовыйЭлементСодержания(ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Группа"), ИдентификаторРодительскойСтроки);
			НоваяСтрока.Наименование = Файл.Имя;
			СохранитьНовуюГруппуЭлементовНаСервере(НоваяСтрока.ПолучитьИдентификатор());
			
			ЗагруженныеГруппыЭлементов.Вставить(ЭлектронноеОбучениеСлужебныйКлиентСервер.ДобавитьКонечныйРазделительПути(Файл.ПолноеИмя), НоваяСтрока.Ссылка);
			
		Иначе			
			
			ЭтоФайлВидео = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлВидео(Файл.Расширение);
			ЭтоФайлАудио = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлАудио(Файл.Расширение);
			ЭтоФайлКартинки = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлКартинки(Файл.Расширение);
			ЭтоФайлТаблиц = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлТаблиц(Файл.Расширение);			
			ЭтоФайлURL = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлURL(Файл.Расширение);			
			ЭтоФайлPDF = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлPDF(Файл.Расширение);
			ЭтоФайлZIP = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлZIP(Файл.Расширение);			
			ЭтоФайлHTML = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлHTML(Файл.Расширение);			
			ЭтоФайлДокументаWord = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлДокументаWord(Файл.Расширение);
			ЭтоФайлПрезентацииPowerPoint = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлПрезентацииPowerPoint(Файл.Расширение);			
			ЭтоФайлДокументаOpenOffice = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлДокументаOpenOffice(Файл.Расширение);			
			ЭтоФайлПрезентацииOpenOffice = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлПрезентацииOpenOffice(Файл.Расширение);
			
			Если ЭтоФайлДокументаWord Тогда							
				РазработкаЭлектронныхКурсовСлужебныйКлиент.ИнициализироватьПриложениеWord(ПриложениеWord,,Файл.Путь);
				Если ПриложениеWord = Неопределено Тогда
					Продолжить; // Нельзя загрузить файл Office
				Иначе
					// Делаем копию документа, которая реально будет сохраняться в базу
					ПриложениеWord.РабочийКаталог.ФайлДляСохранения = ПриложениеWord.РабочийКаталог.Копия + Файл.Имя;
					ЭлектронноеОбучениеСлужебныйКлиентСервер.СкопироватьФайл(Файл.ПолноеИмя, ПриложениеWord.РабочийКаталог.ФайлДляСохранения);					
					// Указываем ярлыки, иными словами соответствие между
					// другим файлами в загружаемом каталоге и теми элементами содержания
					// в которые они превратятся
					ПриложениеWord.РабочийКаталог.Ярлыки = БудущиеЭлементыСодержания;				
					// Сохраняем документ в базу
					НоваяСтрока = НовыйЭлементСодержания(ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ДокументWord"), ИдентификаторРодительскойСтроки);
					СохранитьДокументWordВБазу(ПриложениеWord.РабочийКаталог.ФайлДляСохранения, НоваяСтрока.ПолучитьИдентификатор(), Файл.ИмяБезРасширения, БудущийЭлементСодержания);					
					ПриложениеWord.РабочийКаталог = Неопределено; // Обязательно, так как каталог не временный
				КонецЕсли;
			КонецЕсли;					
			
			Если ЭтоФайлДокументаOpenOffice Тогда
				РазработкаЭлектронныхКурсовСлужебныйКлиент.ИнициализироватьПриложениеWriter(ПриложениеWriter,,Файл.Путь);
				Если ПриложениеWriter = Неопределено Тогда
					Продолжить; // Нельзя загрузить файл OpenOffice
				Иначе					
					ДокументOpenOfficeДляСохранения = ПриложениеWriter.РабочийКаталог.Копия + Файл.Имя;
					ЭлектронноеОбучениеСлужебныйКлиентСервер.СкопироватьФайл(Файл.ПолноеИмя, ДокументOpenOfficeДляСохранения);					
					Если ОбщегоНазначенияКлиент.ЭтоLinuxКлиент() Тогда
						ПриложениеWriter.РабочийКаталог.Ярлыки = БудущиеЭлементыСодержания;								
					КонецЕсли;
					НоваяСтрока = НовыйЭлементСодержания(ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ДокументOpenOffice"), ИдентификаторРодительскойСтроки);
					СохранитьДокументOpenOfficeВБазу(ДокументOpenOfficeДляСохранения, НоваяСтрока.ПолучитьИдентификатор(), Файл.ИмяБезРасширения, БудущийЭлементСодержания);			
					ПриложениеWriter.РабочийКаталог = Неопределено; // Обязательно, так как каталог не временный
				КонецЕсли;				
			КонецЕсли;
			
			Если ЭтоФайлURL Тогда
				
				ЧтениеТекстаФайлаURL = Новый ЧтениеТекста(Файл.ПолноеИмя, КодировкаТекста.UTF8);
				URLИзФайла = "";
				СтрокаФайлаURL = ЧтениеТекстаФайлаURL.ПрочитатьСтроку();
				Пока СтрокаФайлаURL <> Неопределено Цикл
					Если ВРег(Лев(СтрокаФайлаURL, СтрДлина("URL="))) = "URL=" Тогда
						URLИзФайла = Сред(СтрокаФайлаURL, СтрДлина("URL=") + 1);
						Прервать;
					КонецЕсли;
					СтрокаФайлаURL = ЧтениеТекстаФайлаURL.ПрочитатьСтроку();
				КонецЦикла;
				
				ЧтениеТекстаФайлаURL.Закрыть();
				
				ИдентификаторВидеоYouTube = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ИдентификаторВидеоYouTubeИзURI(URLИзФайла);
				
				Если ЗначениеЗаполнено(ИдентификаторВидеоYouTube) Тогда
					НоваяСтрока = НовыйЭлементСодержания(ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.YouTube"), ИдентификаторРодительскойСтроки);
					СвойстваФайла = СвойстваФайлаВидеоYouTube(ИдентификаторВидеоYouTube);
					СохранитьЭлементКурсаНаСервере(СвойстваФайла, НоваяСтрока.ПолучитьИдентификатор(), Файл.ИмяБезРасширения, БудущийЭлементСодержания);
				ИначеЕсли РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлВидеоПоддерживаемогоФормата(URLИзФайла) Тогда
					СвойстваФайла = СвойстваФайлаВидеоИзИнтернета(URLИзФайла, "video/mp4");
					НоваяСтрока = НовыйЭлементСодержания(ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Видео"), ИдентификаторРодительскойСтроки);					
					СохранитьЭлементКурсаНаСервере(СвойстваФайла, НоваяСтрока.ПолучитьИдентификатор(), Файл.ИмяБезРасширения, БудущийЭлементСодержания);
				КонецЕсли;
				
			КонецЕсли;
			
			Если ЭтоФайлВидео ИЛИ ЭтоФайлАудио Тогда
				
				Если ЭтоФайлВидео Тогда
					ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Видео");
				КонецЕсли;
				Если ЭтоФайлАудио Тогда
					ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Звук");					
				КонецЕсли;			
				
				НоваяСтрока = НовыйЭлементСодержания(ТипЭлемента, ИдентификаторРодительскойСтроки);				
				СвойстваФайла = ПодготовитьВидеоИлиАудиоДляЗагрузкиВБазу(Файл);
				СохранитьЭлементКурсаНаСервере(СвойстваФайла, НоваяСтрока.ПолучитьИдентификатор(), Файл.ИмяБезРасширения, БудущийЭлементСодержания);

				Если ЭтоФайлВидео И ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Видео") Тогда
				
					Если СвойстваФайла.Свойство("ДанныеЗаписанногоЭлементаРесурса")	
						И ЗначениеЗаполнено(СвойстваФайла.ДанныеЗаписанногоЭлементаРесурса.Ссылка)	Тогда	
						ЗаписанныйВБазуФайлВидео = СвойстваФайла.ДанныеЗаписанногоЭлементаРесурса.Ссылка;
					Иначе		
						ВызватьИсключение НСтр("ru = 'Файл видео не записан в базу'");		
					КонецЕсли;				
					
					Если НЕ РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлВидеоПоддерживаемогоФормата(Файл.Расширение) Тогда
						ВидеоФайлыДляКонвертирования.Добавить(ЗаписанныйВБазуФайлВидео);						
					КонецЕсли;			
					
				КонецЕсли;
					
			КонецЕсли;
			
			Если ЭтоФайлПрезентацииPowerPoint Тогда			
				ПрезентацияДобавлена = ДобавитьНовуюПрезентациюPowerPointВБазу(Файл, ИдентификаторРодительскойСтроки, БудущийЭлементСодержания);
				Если НЕ ПрезентацияДобавлена Тогда
					Продолжить;
				КонецЕсли;
			КонецЕсли;
			
			Если ЭтоФайлПрезентацииOpenOffice Тогда
				ПрезентацияДобавлена = ДобавитьНовуюПрезентациюOpenOfficeВБазу(Файл, ИдентификаторРодительскойСтроки, БудущийЭлементСодержания);				
				Если НЕ ПрезентацияДобавлена Тогда
					Продолжить;
				КонецЕсли;				
			КонецЕсли;
			
			Если ЭтоФайлТаблиц Тогда			
				ДобавитьНовыйТестИзФайлаExcel(Файл, ИдентификаторРодительскойСтроки, БудущийЭлементСодержания);
			КонецЕсли;
			
			Если ЭтоФайлPDF ИЛИ ЭтоФайлZIP ИЛИ ЭтоФайлHTML ИЛИ ЭтоФайлКартинки Тогда
				ДобавитьНовыйСтатичныйФайлВБазу(Файл, ИдентификаторРодительскойСтроки, БудущийЭлементСодержания);
			КонецЕсли;				
			
		КонецЕсли;
		
		ЗагруженоФайлов = ЗагруженоФайлов + 1;
		
	КонецЦикла;
	
	ФайлыДляЗагрузки = Новый Массив; // Очищаем переменную модуля	
	
	// Запускаем конвертер видео или просто завершаем загрузку
	
	ПараметрыПослеЗагрузки = Новый Структура("ПоследняяСтрока, ПерваяЗаписьКурса", НоваяСтрока, ПерваяЗаписьКурса);
	
	Если ВидеоФайлыДляКонвертирования.Количество() > 0 Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("ПослеЗагрузкиФайловСДискаВБазу", ЭтотОбъект, ПараметрыПослеЗагрузки);
		
		ОткрытьФорму("Справочник.ЭлементыЭлектронныхРесурсов.Форма.КонвертерВидео",
			Новый Структура("ЭлементРесурса, Автозапуск", Новый ФиксированныйМассив(ВидеоФайлыДляКонвертирования), Истина),
			ЭтотОбъект,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);		
			
	Иначе
		
		ПослеЗагрузкиФайловСДискаВБазу(Неопределено, ПараметрыПослеЗагрузки)
			
	КонецЕсли;	
	
	#КонецЕсли

КонецПроцедуры

&НаКлиенте
Процедура ПослеЗагрузкиФайловСДискаВБазу(РезультатЗакрытия, ПараметрыПослеЗагрузки) Экспорт	
	
	Если ПараметрыПослеЗагрузки.ПоследняяСтрока <> Неопределено Тогда
		Элементы.НавигационноеДерево.ТекущаяСтрока = ПараметрыПослеЗагрузки.ПоследняяСтрока.ПолучитьИдентификатор();
	КонецЕсли;
	
	Если ПараметрыПослеЗагрузки.ПерваяЗаписьКурса Тогда		
		Оповестить("ЭлектронныйКурсЗаписан",,ЭтотОбъект);		
	КонецЕсли;		
	
	ПриРедактировании();
	
	ПоказатьПредупреждение(, НСтр("ru = 'Загрузка завершена'"));
	
КонецПроцедуры

&НаКлиенте
Функция НайтиКаталогСкрытыхРесурсов(Файл)
	
	Если Файл.ЭтоКаталог() Тогда
		Возврат Неопределено; // Каталог не может иметь скрытых ресурсов
	КонецЕсли;
	
	ИмяКаталогаСкрытыхРесурсов = Файл.Путь;
	ИмяКаталогаСкрытыхРесурсов = ЭлектронноеОбучениеСлужебныйКлиентСервер.ДобавитьКонечныйРазделительПути(ИмяКаталогаСкрытыхРесурсов);
	ИмяКаталогаСкрытыхРесурсов = ИмяКаталогаСкрытыхРесурсов + Файл.ИмяБезРасширения;
	
	Для каждого ФайлДляЗагрузки Из ФайлыДляЗагрузки Цикл // Переменная формы
	
		Если ФайлДляЗагрузки.ЭтоКаталог() 
			И (ФайлДляЗагрузки.ПолноеИмя = ИмяКаталогаСкрытыхРесурсов 
			ИЛИ ЭтоКаталогДополнительныхФайловHTML(ФайлДляЗагрузки.ПолноеИмя, ИмяКаталогаСкрытыхРесурсов)) Тогда
			
			Возврат ФайлДляЗагрузки;
			
		КонецЕсли;
	
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

&НаКлиенте
Функция ЭтоКаталогДополнительныхФайловHTML(Знач ИмяКаталога, Знач ИмяФайлаHTMLБезРасширения)
	
	Возврат ИмяКаталога = ИмяФайлаHTMLБезРасширения + "_files"
		ИЛИ ИмяКаталога = ИмяФайлаHTMLБезРасширения + ".files"
		ИЛИ ИмяКаталога = ИмяФайлаHTMLБезРасширения;
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьПеременнуюФайлыДляЗагрузки(МассивФайловДляЗагрузки, РекурсивныйВызов = Ложь)
	
	Если НЕ РекурсивныйВызов Тогда
		ФайлыДляЗагрузки = Новый Массив; // Очищаем переменную модуля
	КонецЕсли;
	
	Для каждого Файл Из МассивФайловДляЗагрузки Цикл
		
		ЭтоКаталог = Файл.ЭтоКаталог();
		
		Если ТипЭлектронногоКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Учебник") Тогда
		
			ФайлыДляЗагрузки.Добавить(Файл);
		
			Если ЭтоКаталог Тогда
				ФайлыКаталога = ЭлектронноеОбучениеСлужебныйКлиентСервер.ИскатьФайлы(Файл.ПолноеИмя, "*", Ложь);
				ЗаполнитьПеременнуюФайлыДляЗагрузки(ФайлыКаталога, Истина); // Рекурсия
			КонецЕсли;
			
		Иначе
			
			Если НЕ ЭтоКаталог Тогда
				ФайлыДляЗагрузки.Добавить(Файл);
			КонецЕсли;
			
		КонецЕсли;		
	
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ДокументыWordИOpenOffice

// Word

&НаКлиенте
Процедура ОткрытьДокументWord()
	
	ТекстИнформацииОРедактировании = НСтр("ru = '
	|<!DOCTYPE html>
	|<html>
	|<head>
	|    <meta charset=""UTF-8"">
	|    <style>
	|        body, html {
	|            height: 100%;
	|            margin: 0;
	|            padding: 0;
	|        }
	|
	|        html {
	|            font-family: Arial, sans-serif, Helvetica;
	|            font-size: 10pt;
	|        }
	|
	|        .main {
	|            padding: 20px;
	|            width: 100%;
	|            max-width: 600px;
	|        }
	|
	|        .main-p {
	|            margin-top: 10px;
	|        }
	|        .main-filename {
	|            font-weight: bold;
	|        }
	|
	|    </style>
	|</head>
	|<body>
	|
	|    <div class=""main"">
	|        <div class=""main-p"">Документ открыт для редактирования во внешней программе.</div>
	|        <div class=""main-p""><!--{{Подсказка}}--></div>
	|    </div>
	|
	|</body>
	|</html>'");
	
	ДополнительныеКомментарии = "";
	Если ОбщегоНазначенияКлиент.ЭтоWindowsКлиент() Тогда
		ДополнительныеКомментарии = ДополнительныеКомментарии + НСтр("ru = 'В процессе редактирования при помощи команды <i>Вставка -> Гиперссылка</i>
		|можно расставлять гиперссылки на файлы с расширением lnk, соответствующие элементам учебника. Они размещены рядом с документом.'");
	ИначеЕсли ОбщегоНазначенияКлиент.ЭтоOSXКлиент() Тогда
		ДополнительныеКомментарии = ДополнительныеКомментарии + НСтр("ru = 'В процессе редактирования при помощи команды <i>Вставка -> Ссылка</i>
		|можно расставлять гиперссылки на файлы-приложения с иконкой 1С, соответствующие элементам учебника. Они размещены рядом с документом.'");		
	КонецЕсли;
	ТекстИнформацииОРедактировании = СтрЗаменить(ТекстИнформацииОРедактировании, "<!--{{Подсказка}}-->", ДополнительныеКомментарии);	
	
	ОбластьПросмотра = ТекстИнформацииОРедактировании; 
	
	Если ДанныеХраненияВнешнегоДокумента = Неопределено Тогда	
		// Новый документ
		РазработкаЭлектронныхКурсовСлужебныйКлиент.ОткрытьДокументWord(ПриложениеWord, ВладелецФормы, ЭтотОбъект, Ложь, Неопределено, Неопределено);
	Иначе
		// Существующий документ
		РазработкаЭлектронныхКурсовСлужебныйКлиент.ОткрытьДокументWord(ПриложениеWord, ВладелецФормы, ЭтотОбъект, Ложь, ДанныеХраненияВнешнегоДокумента.МестоХраненияДокументаВБазе, ДанныеХраненияВнешнегоДокумента);
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Функция ДокументWordДоступен()
	
	Возврат РазработкаЭлектронныхКурсовСлужебныйКлиент.ДокументWordДоступен(ПриложениеWord);
	
КонецФункции

&НаКлиенте
Процедура ВнешнийОбработчик_ПриЗакрытииПриложенияWord() Экспорт   
	ВыйтиИзРежимаРедактирования(Ложь);
КонецПроцедуры

&НаКлиенте
Процедура ВнешнийОбработчик_ПриЗаписиДокументаWord(ТекущийДокумент, ЭтоИнтерактивнаяЗапись, ОтменаОперации) Экспорт   
	
	Если ПриложениеWord.Документ <> ТекущийДокумент Тогда
		Возврат;
	КонецЕсли;
	
	Если ПриложениеWord.ПропуститьЗапись Тогда
		ПриложениеWord.ПропуститьЗапись = Ложь;
		Возврат;
	КонецЕсли;
	
	Если ТекущийДокумент = ПриложениеWord.Документ И НЕ ЭтоИнтерактивнаяЗапись Тогда
		
		ОтменаОперации = Истина;				
		
		Если ПриложениеWord.Свойство("ВыйтиИзРежимаРедактированияПослеЗаписиДокументаWord")
			И ПриложениеWord.ВыйтиИзРежимаРедактированияПослеЗаписиДокументаWord Тогда
			СохранитьЭлементКурса(, Истина, Истина);
		Иначе
			СохранитьЭлементКурса(, Ложь, Истина);
		КонецЕсли;
		
		ПриРедактировании();
		
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ВнешнийОбработчик_ПриЗакрытииДокументаWord(ТекущийДокумент, ОтменаОперации) Экспорт   
	
	Если ПриложениеWord.Документ <> ТекущийДокумент Тогда
		Возврат;
	КонецЕсли;	
	
	Если РазработкаЭлектронныхКурсовСлужебныйКлиент.ДокументWordМодифицирован(ПриложениеWord) Тогда
		ПриложениеWord.Вставить("ВыйтиИзРежимаРедактированияПослеЗаписиДокументаWord", Истина);
	Иначе
		ВыйтиИзРежимаРедактирования(Ложь);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьДокументWord(Знач Синхронно, Знач ОбновитьПредставлениеДокументаWord)

	Если ОбщегоНазначенияКлиент.ЭтоWindowsКлиент() Тогда
	
		ДокументДоступен = ДокументWordДоступен();
				
		Если НЕ ДокументДоступен Тогда
			Возврат;
		КонецЕсли;		
		
		// Сохраняем документ
		
		ПриложениеWord.ПропуститьЗапись = Истина;	
		ПриложениеWord.Документ.Save();	
		ПриложениеWord.ПропуститьЗапись = Ложь;
		
		// Делаем копию документа	
		
		ПриложениеWord.Вставить("ИмяСохраняемогоДокументаWord", ПриложениеWord.Документ.Name);
		ПриложениеWord.РабочийКаталог.ФайлДляСохранения = ПриложениеWord.РабочийКаталог.Копия + ПриложениеWord.РабочийКаталог.ИмяФайла;	
		ЭлектронноеОбучениеСлужебныйКлиентСервер.СкопироватьФайл(ПриложениеWord.Документ.FullName, ПриложениеWord.РабочийКаталог.ФайлДляСохранения);
		
		// Сохраняем копию в HTML
		
		Если Синхронно Тогда
			СохранитьДокументWordПродолжение(ОбновитьПредставлениеДокументаWord);
		Иначе
			ПодключитьОбработчикОжидания("Подключаемый_СохранитьДокументWord", 0.01, Истина);
		КонецЕсли;
		
	КонецЕсли;	
	
	Если ОбщегоНазначенияКлиент.ЭтоOSXКлиент() Тогда
		// Закрываем и записываем все открытые документы
		ПутьКФайлуПрограммыЗакрытияДокументов = ПриложениеWord.Скрытое + "closeAndSaveDocuments.scpt";
		ПараметрыЗапускаПрограммы = ФайловаяСистемаКлиент.ПараметрыЗапускаПрограммы();			
		ПараметрыЗапускаПрограммы.ДождатьсяЗавершения = Истина;					
		ФайловаяСистемаКлиент.ЗапуститьПрограмму("osascript """ + ПутьКФайлуПрограммыЗакрытияДокументов + """", ПараметрыЗапускаПрограммы);
		// Сохраняем в базу
		СохранитьДокументWordВБазу(ПриложениеWord.РабочийКаталог.Документ + ПриложениеWord.РабочийКаталог.ИмяФайла, ИдентификаторРедактируемойСтрокиНаКлиенте());
	КонецЕсли;
	
	ПриРедактировании();
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_СохранитьДокументWord()	
	СохранитьДокументWordПродолжение(Истина);	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьДокументWordПродолжение(ОбновитьПредставлениеДокументаWord = Истина)
	
	Если ПриложениеWord = Неопределено
		ИЛИ ПриложениеWord.РабочийКаталог = Неопределено
		ИЛИ НЕ ЗначениеЗаполнено(ПриложениеWord.РабочийКаталог.ФайлДляСохранения) Тогда
		
		ВызватьИсключение НСтр("ru = 'Нет файла для сохранения'")
		
	КонецЕсли;		
	
	СохранитьДокументWordВБазу(ПриложениеWord.РабочийКаталог.ФайлДляСохранения, ИдентификаторРедактируемойСтрокиНаКлиенте());
	
	// Очищаем переменные
	
	ПриложениеWord.РабочийКаталог.ФайлДляСохранения = Неопределено;
	
	// Обновляем представление
	
	Если ОбновитьПредставлениеДокументаWord Тогда	
		УстановитьЭлементДляПросмотра(ТекущийЭлементСодержания());	
	КонецЕсли;
	
	ПриРедактировании();
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьДокументWordВБазу(ФайлДляСохранения, НомерРедактируемойСтроки = Неопределено, НаименованиеНовогоЭлемента = Неопределено, ЭлементаСодержанияДляЗаписи = Неопределено)
	
	// Формируем файлы документа, которые будем сохранять
	
	ПараметрыЗагрузки = Новый Структура();	
	
	ПараметрыЗагрузки.Вставить("ПутьКДокументу", ФайлДляСохранения);
	ПараметрыЗагрузки.Вставить("Приложение", ПриложениеWord.Скрытое);
	ПараметрыЗагрузки.Вставить("УникальныйИдентификатор", УникальныйИдентификатор);
	ПараметрыЗагрузки.Вставить("КонтекстФайла", "Document");
	ПараметрыЗагрузки.Вставить("Ярлыки", ПриложениеWord.РабочийКаталог.Ярлыки);
	ПараметрыЗагрузки.Вставить("ПутьККаталогуОригинальногоДокумента", ПриложениеWord.РабочийКаталог.Документ);
	ПараметрыЗагрузки.Вставить("ПутьККаталогуКопииДокумента", ПриложениеWord.РабочийКаталог.Копия);
	
	ПараметрыЗагрузки.Вставить("ПереданныеФайлы", Новый Массив);	
	ПараметрыЗагрузки.Вставить("НастройкиКартинок", РазработкаЭлектронныхКурсовСлужебныйКлиент.НовоеОписаниеКартинокДокументаWord());	
	ПараметрыЗагрузки.Вставить("ПередаваемыеФайлы", Новый Массив);
	ПараметрыЗагрузки.Вставить("СтруктураФайлов", Новый Массив);
	ПараметрыЗагрузки.Вставить("ТекстовыеДанныеДляИндексирования", "");
	ПараметрыЗагрузки.Вставить("ВнутренниеГиперссылки", Новый Соответствие);
	
	РазработкаЭлектронныхКурсовСлужебныйКлиент.СформироватьДокументWordДляСохраненияВБазе(ПараметрыЗагрузки);
	
	// Записываем файлы документа в базу	
	
	Если ПриложениеWord.Свойство("ИмяСохраняемогоДокументаWord") 
		И ЗначениеЗаполнено(ПриложениеWord.ИмяСохраняемогоДокументаWord) Тогда		
		СтруктураИмениФайла = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(ПриложениеWord.ИмяСохраняемогоДокументаWord, Ложь);		
		ПриложениеWord.ИмяСохраняемогоДокументаWord = ""; // Сбрасываем свойство
	Иначе		
		СтруктураИмениФайла = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(ФайлДляСохранения, Ложь);		
	КонецЕсли;
	
	СвойстваФайла = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ПустаяСтруктураСвойствЗагружаемогоФайла();
	
	СвойстваФайла.Имя = СтруктураИмениФайла.ИмяБезРасширения;
	СвойстваФайла.Расширение = СтруктураИмениФайла.Расширение;
	СвойстваФайла.ЭтоКаталог = Ложь;
	СвойстваФайла.Преобразовать = Истина;
	СвойстваФайла.СтруктураФайлов = ПараметрыЗагрузки.СтруктураФайлов;
	СвойстваФайла.СписокФайлов = ПараметрыЗагрузки.ПереданныеФайлы;
	СвойстваФайла.НастройкиКартинок = ПараметрыЗагрузки.НастройкиКартинок;
	СвойстваФайла.ДанныеВидео = Неопределено;
	СвойстваФайла.КонтекстФайла = "Document";
	СвойстваФайла.ТекстовыеДанныеДляИндексирования = ПараметрыЗагрузки.ТекстовыеДанныеДляИндексирования;	
	СвойстваФайла.ВнутренниеГиперссылки = ПараметрыЗагрузки.ВнутренниеГиперссылки;
	
	СохранитьЭлементКурсаНаСервере(СвойстваФайла, НомерРедактируемойСтроки, НаименованиеНовогоЭлемента, ЭлементаСодержанияДляЗаписи);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьДокументWord()
	
	РазработкаЭлектронныхКурсовСлужебныйКлиент.ПриЗакрытииФормыДокументаWord(ПриложениеWord, Ложь, ЭтотОбъект);	
	
	Если ОбщегоНазначенияКлиент.ЭтоWindowsКлиент() 
		И НЕ РазработкаЭлектронныхКурсовСлужебныйКлиент.ЕстьОткрытыеДокументыWord(ПриложениеWord)
		И РазработкаЭлектронныхКурсовСлужебныйКлиент.ПриложениеMSOfficeДоступно(ПриложениеWord.Пользовательское) Тогда
		
		ПриложениеWord.Пользовательское.Visible = Ложь;
		
	КонецЕсли;
	
	Если ДанныеХраненияВнешнегоДокумента <> Неопределено
		И ДанныеХраненияВнешнегоДокумента.Свойство("НовоеНаименование")
		И ЗначениеЗаполнено(ДанныеХраненияВнешнегоДокумента.НовоеНаименование) Тогда
		
		УстановитьНовоеНаименованиеДокументаWord(ДанныеХраненияВнешнегоДокумента, Параметры.КонтекстРедактирования);
		
	КонецЕсли;	
	
	ДанныеХраненияВнешнегоДокумента = Неопределено;	
	Если ОбщегоНазначенияКлиент.ЭтоWindowsКлиент() Тогда
		ПриложениеWord.Вставить("ВыйтиИзРежимаРедактированияПослеЗаписиДокументаWord", Ложь)
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьНовоеНаименованиеДокументаWord(ДанныеДокументаWord, КонтекстРедактирования)
	
	ЭлементКурсаОбъект = ДанныеДокументаWord.СсылкаНаЭлементСДокументом.ПолучитьОбъект();
	ЭлементКурсаОбъект.Наименование = ДанныеДокументаWord.НовоеНаименование;
	
	СтароеИмяСтруктура = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(ДанныеДокументаWord.ИмяФайла, Ложь);
	
	ЭлементКурсаОбъект.ИмяФайла = 
		Лев(ОбщегоНазначенияКлиентСервер.ЗаменитьНедопустимыеСимволыВИмениФайла(ДанныеДокументаWord.НовоеНаименование, ""), 10)
		+ СтароеИмяСтруктура.Расширение;
	
	ЭлементКурсаОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", КонтекстРедактирования);	
	ЭлементКурсаОбъект.Записать();
	
КонецПроцедуры

// OpenOffice (Writer)

&НаКлиенте
Процедура СохранитьДокументOpenOfficeВБазу(ФайлДляСохранения, НомерРедактируемойСтроки = Неопределено, НаименованиеНовогоЭлемента = Неопределено, ЭлементаСодержанияДляЗаписи = Неопределено)
	
	// Формируем файлы документа, которые будем сохранять
	
	ПараметрыЗагрузки = Новый Структура();	
	
	ПараметрыЗагрузки.Вставить("ПутьКДокументу", ФайлДляСохранения);
	ПараметрыЗагрузки.Вставить("ПутьКПриложению", ПриложениеWriter.ПутьКПриложению);
	ПараметрыЗагрузки.Вставить("УникальныйИдентификатор", УникальныйИдентификатор);
	ПараметрыЗагрузки.Вставить("КонтекстФайла", "Document");
	ПараметрыЗагрузки.Вставить("Ярлыки", ПриложениеWriter.РабочийКаталог.Ярлыки);
	ПараметрыЗагрузки.Вставить("ПутьККаталогуОригинальногоДокумента", ПриложениеWriter.РабочийКаталог.Документ);
	
	ПараметрыЗагрузки.Вставить("ПереданныеФайлы", Новый Массив);	
	ПараметрыЗагрузки.Вставить("НастройкиКартинок", Неопределено);	
	ПараметрыЗагрузки.Вставить("ПередаваемыеФайлы", Новый Массив);
	ПараметрыЗагрузки.Вставить("СтруктураФайлов", Новый Массив);
	ПараметрыЗагрузки.Вставить("ТекстовыеДанныеДляИндексирования", "");
	ПараметрыЗагрузки.Вставить("ВнутренниеГиперссылки", Новый Соответствие);

	РазработкаЭлектронныхКурсовСлужебныйКлиент.СформироватьДокументWriterДляСохраненияВБазе(ПараметрыЗагрузки);
	
	// Записываем файлы документа в базу	
	
	СтруктураИмениФайла = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(ФайлДляСохранения, Ложь);		
	
	СвойстваФайла = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ПустаяСтруктураСвойствЗагружаемогоФайла();
	
	СвойстваФайла.Имя = СтруктураИмениФайла.ИмяБезРасширения;
	СвойстваФайла.Расширение = СтруктураИмениФайла.Расширение;
	СвойстваФайла.ЭтоКаталог = Ложь;
	СвойстваФайла.Преобразовать = Истина;
	СвойстваФайла.СтруктураФайлов = ПараметрыЗагрузки.СтруктураФайлов;
	СвойстваФайла.СписокФайлов = ПараметрыЗагрузки.ПереданныеФайлы;
	СвойстваФайла.НастройкиКартинок = ПараметрыЗагрузки.НастройкиКартинок;
	СвойстваФайла.ДанныеВидео = Неопределено;
	СвойстваФайла.КонтекстФайла = "Document";
	СвойстваФайла.ТекстовыеДанныеДляИндексирования = ПараметрыЗагрузки.ТекстовыеДанныеДляИндексирования;	
	СвойстваФайла.ВнутренниеГиперссылки = ПараметрыЗагрузки.ВнутренниеГиперссылки;
	
	СохранитьЭлементКурсаНаСервере(СвойстваФайла, НомерРедактируемойСтроки, НаименованиеНовогоЭлемента, ЭлементаСодержанияДляЗаписи);	
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьОткрытыйДокументOpenOffice()
	
	ПутьКДокументу = ПриложениеWriter.РабочийКаталог.Документ + ДанныеХраненияВнешнегоДокумента.ИмяФайла;
	
	СохранитьДокументOpenOfficeВБазу(ПутьКДокументу, ИдентификаторРедактируемойСтрокиНаКлиенте());
	
	УстановитьЭлементДляПросмотра(ТекущийЭлементСодержания());
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьДокументOpenOffice()
		
	Если ДанныеХраненияВнешнегоДокумента = Неопределено Тогда
		
		ВызватьИсключение НСтр("ru = 'Данные документа OpenOffice не определены'");
		
	Иначе
		
		РазработкаЭлектронныхКурсовСлужебныйКлиент.ОткрытьДокументWriter(ПриложениеWriter, ДанныеХраненияВнешнегоДокумента.МестоХраненияДокументаВБазе, ДанныеХраненияВнешнегоДокумента.ИмяФайла, ДанныеХраненияВнешнегоДокумента, ЭтотОбъект);
		
		ТекстИнформацииОРедактировании = НСтр("ru = '
		|<!DOCTYPE html>
		|<html>
		|<head>
		|    <meta charset=""UTF-8"">
		|    <style>
		|        body, html {
		|            height: 100%;
		|            margin: 0;
		|            padding: 0;
		|        }
		|
		|        html {
		|            font-family: Arial, sans-serif, Helvetica;
		|            font-size: 10pt;
		|        }
		|
		|        .main {
		|            padding: 20px;
		|            width: 100%;
		|            max-width: 600px;
		|        }
		|
		|        .main-p {
		|            margin-top: 10px;
		|        }
		|        .main-filename {
		|            font-weight: bold;
		|        }
		|
		|    </style>
		|</head>
		|<body>
		|    <div class=""main"">
		|        <div class=""main-p"">Документ <span class=""main-filename"">{{ИмяДокумента}}</span> открыт для редактирования во внешней программе.</div>
		|        <div class=""main-p"">После окончания редактирования закройте документ и нажмите кнопку <i>Закончить редактирование</i>, чтобы сохранить изменения.</div>
		|		 <!--{{ДополнительныеКомментарии}}-->
		|    </div>
		|</body>
		|</html>'");
		
		ТекстИнформацииОРедактировании = СтрЗаменить(ТекстИнформацииОРедактировании, "{{ИмяДокумента}}", ДанныеХраненияВнешнегоДокумента.ИмяФайла);
		
		ДополнительныеКомментарии = "";
		
		Если ПриложениеWriter.РаботаСЯрлыками.Доступно Тогда
			ДополнительныеКомментарии = ДополнительныеКомментарии
			+ НСтр("ru = '<div class=""main-p"">В процессе редактирования при помощи команды
			|<i>Вставка -> Гиперссылка</i> можно расставлять гиперссылки на файлы с расширением e1clink,
			|соответствующие элементам учебника. На панель «Места» окна выбора файла операционной системы
			|добавлена папка <span class=""main-filename"">{{ИмяКаталогаКурса}}</span> для быстрого перехода
			|к файлам e1clink.</div>'");
			ДополнительныеКомментарии = СтрЗаменить(ДополнительныеКомментарии, "{{ИмяКаталогаКурса}}", ПриложениеWriter.РабочийКаталог.ИмяКаталогаКурса);
		КонецЕсли;
		
		Если ПриложениеWriter.РаботаСЯрлыками.Доступно 
			И НЕ ПриложениеWriter.РаботаСЯрлыками.НастроенПереходПоЯрлыкам Тогда
			ДополнительныеКомментарии = ДополнительныеКомментарии
			+ НСтр("ru = '<div class=""main-p"">Для открытия файлов с расширением e1clink необходимо зарегистрировать их в системе.
			|Для этого нужны права суперпользователя. <a id=""regE1clinkMimeType"" href=""#"">Выполнить настройку</a></div>'");
		КонецЕсли;
		
		ТекстИнформацииОРедактировании = СтрЗаменить(ТекстИнформацииОРедактировании, "<!--{{ДополнительныеКомментарии}}-->", ДополнительныеКомментарии);
		
		ОбластьПросмотра = ТекстИнформацииОРедактировании; 
		
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьДокументOpenOffice()
	РазработкаЭлектронныхКурсовСлужебныйКлиент.ПриЗакрытииФормыДокументаWriter(ПриложениеWriter, ЭтотОбъект);
КонецПроцедуры

// Общее

&НаСервереБезКонтекста
Функция ДанныеХраненияВнешнегоДокумента(ЭлементСодержания, РодительскийЭлементСодержания, СсылкаНаЭлемент, ИдентификаторФормы)	
	
	Если ТипЗнч(СсылкаНаЭлемент) = Тип("СправочникСсылка.ТеорияЭлектронныхКурсов") Тогда
		
		НаименованиеЭлемента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаНаЭлемент, "Наименование");
		Ресурс = Справочники.ТеорияЭлектронныхКурсов.ЕдинственныйЭлемент(СсылкаНаЭлемент);
		
		Если ЗначениеЗаполнено(Ресурс) И ТипЗнч(Ресурс) = Тип("СправочникСсылка.ЭлектронныеРесурсы") Тогда			
			ЭлементРесурса = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ресурс, "ЕдинственныйЭлемент");
		Иначе			
			ВызватьИсключение НСтр("ru = 'Неверный тип теории'");			
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ЭлементРесурса) Тогда
			ВызватьИсключение НСтр("ru = 'Элемент ресурса с документом не найден'");
		КонецЕсли;
		
	Иначе		
		
		ВызватьИсключение НСтр("ru = 'Элемент для хранения документа не определен'");		
		
	КонецЕсли;		
	
	МестоХраненияДокументаВБазе = Справочники.ЭлементыЭлектронныхРесурсов.ДанныеЭлементаДляРедактирования(ЭлементРесурса, Перечисления.ТипыЭлементовЭлектронныхРесурсов.Document, ИдентификаторФормы);
	
	Если НЕ ЗначениеЗаполнено(МестоХраненияДокументаВБазе) Тогда
		ВызватьИсключение НСтр("ru = 'Место хранения документа не определено'");
	КонецЕсли;	
	
	ДанныеЭлемента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЭлементРесурса, "Наименование, ИмяФайла");
	
	ДанныеЭлемента.Вставить("РодительскийЭлементСодержания", РодительскийЭлементСодержания);
	ДанныеЭлемента.Вставить("ЭлементСодержания", ЭлементСодержания);
	ДанныеЭлемента.Вставить("СсылкаНаЭлементСДокументом", ЭлементРесурса);
	ДанныеЭлемента.Вставить("МестоХраненияДокументаВБазе", МестоХраненияДокументаВБазе);
	ДанныеЭлемента.Вставить("Ресурс", Ресурс);
	ДанныеЭлемента.Вставить("ВнутренниеГиперссылки", Справочники.СодержаниеЭлектронныхКурсов.Гиперссылки(ЭлементСодержания));
	
	// Новое наименование будет установлено после выхода из режима редактирования.
	// Это важно, так как файл документа, который редактируется должен иметь то же имя,
	// что и элемент курса, чтобы выполнялся поиск по имени файла. Но при выходе его
	// можно переименовать.
	
	Если НаименованиеЭлемента <> ДанныеЭлемента.Наименование Тогда	
		ДанныеЭлемента.Вставить("НовоеНаименование", НаименованиеЭлемента);		
	КонецЕсли;
	
	Возврат Новый ФиксированнаяСтруктура(ДанныеЭлемента);
	
КонецФункции

&НаКлиенте
Процедура Подключаемый_ОжиданиеОткрытияЭлементаПоСсылкеДокумента() Экспорт
	
	Если НЕ ЗначениеЗаполнено(ПутьКФайлуОжиданияОткрытияГиперссылки) Тогда
		Возврат;
	КонецЕсли;
	
	ФайлСлежения = Новый Файл(ПутьКФайлуОжиданияОткрытияГиперссылки);
	
	Если НЕ ЭлектронноеОбучениеСлужебныйКлиентСервер.ФайлСуществует(ФайлСлежения) Тогда
		Возврат;
	КонецЕсли;
	
	ЧтениеТекста = Новый ЧтениеТекста(ПутьКФайлуОжиданияОткрытияГиперссылки, КодировкаТекста.Системная);
	СодержимоеФайла = СокрЛП(ЧтениеТекста.ПрочитатьСтроку());
	ЧтениеТекста.Закрыть();
	ЭлектронноеОбучениеСлужебныйКлиентСервер.УдалитьВременныйФайл(ПутьКФайлуОжиданияОткрытияГиперссылки);
	
	ИдентификаторЭлементаСодержания = Неопределено;
	
	Попытка
		ИдентификаторЭлементаСодержания = Новый УникальныйИдентификатор(СодержимоеФайла);
	Исключение
		ЭлектронноеОбучениеСлужебныйКлиент.ЗаписатьОшибкуВЖурналРегистрации(		
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())
		);		
	КонецПопытки;
	
	ОткрытьЭлементСодержанияВНовомОкне(ИдентификаторЭлементаСодержания);
	
КонецПроцедуры

#КонецОбласти

#Область ПрезентацииPowerPointИOpenOffice

// PowerPoint

&НаКлиенте
Процедура ОткрытьПрезентациюPowerPoint()
	
	#Если НЕ ВебКлиент И НЕ МобильныйКлиент Тогда
		
	Если ОбщегоНазначенияКлиент.ЭтоLinuxКлиент() Тогда
		ВызватьИсключение НСтр("ru = 'Работа с презентациями PowerPoint в Linux не поддерживается'");		
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиент.ЭтоWindowsКлиент() Тогда
		
		// Инициируем работу с PowerPoint
		
		Если РазработкаЭлектронныхКурсовСлужебныйКлиент.ПрезентацияPowerPointДоступна(ПриложениеPowerPoint) Тогда

			ПриложениеPowerPoint.Пользовательское.Visible = Истина;		
			ПриложениеPowerPoint.Пользовательское.WindowState = 2;
			ПриложениеPowerPoint.Пользовательское.WindowState = 1;			
			
		Иначе		
			
			РазработкаЭлектронныхКурсовСлужебныйКлиент.ИнициализироватьПриложениеPowerPoint(ПриложениеPowerPoint);
			
			Если ПриложениеPowerPoint = Неопределено Тогда
				Возврат;
			КонецЕсли;		
			
			Если ЗначениеЗаполнено(НаименованиеКурса) Тогда
				ПриложениеPowerPoint.ХранениеНаДиске = НовыйПутьХраненияПрезентацииPowerPoint(НаименованиеКурса, ПриложениеPowerPoint);
			Иначе
				ПриложениеPowerPoint.ХранениеНаДиске = НовыйПутьХраненияПрезентацииPowerPoint(НаименованиеНовогоЭлектронногоКурса(ТипЭлектронногоКурса), ПриложениеPowerPoint);
			КонецЕсли;
			
			Если ТипЭлектронногоКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Учебник") Тогда
				РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());	
				Если РедактируемаяСтрока = Неопределено Тогда
					ВызватьИсключение НСтр("ru = 'Редактируемая строка не определена'");
				КонецЕсли;
				ПриложениеPowerPoint.ХранениеВБазе = ДанныеХраненияПрезентацииТеории(РедактируемаяСтрока.СсылкаНаЭлемент, УникальныйИдентификатор);
			Иначе
				ПриложениеPowerPoint.ХранениеВБазе = ДанныеХраненияПрезентацииЭлектронногоКурса(ЭлектронныйКурс, УникальныйИдентификатор);
			КонецЕсли;
			
			ПолучитьФайл(ПриложениеPowerPoint.ХранениеВБазе.МестоХраненияВБазе, ПриложениеPowerPoint.ХранениеНаДиске, Ложь);		
			
			ПриложениеPowerPoint.Презентация = ПриложениеPowerPoint.Пользовательское.Presentations.Open(ПриложениеPowerPoint.ХранениеНаДиске,,,Истина);
			
			ДобавитьОбработчик ПриложениеPowerPoint.Пользовательское.PresentationBeforeSave, ПередЗаписьюПрезентацииPowerPoint;	
			ДобавитьОбработчик ПриложениеPowerPoint.Пользовательское.PresentationBeforeClose, ПередЗакрытиемПрезентацииPowerPoint;	
			
		КонецЕсли;
		
	КонецЕсли;

	Если ОбщегоНазначенияКлиент.ЭтоOSXКлиент() Тогда
		
		РазработкаЭлектронныхКурсовСлужебныйКлиент.ИнициализироватьПриложениеPowerPoint(ПриложениеPowerPoint);
		
		Если ПриложениеPowerPoint = Неопределено Тогда
			Возврат;
		КонецЕсли;				
		
		ПриложениеPowerPoint.ХранениеНаДиске = НовыйПутьХраненияПрезентацииPowerPoint(Неопределено, ПриложениеPowerPoint);
		
		Если ТипЭлектронногоКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Учебник") Тогда
			РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());	
			Если РедактируемаяСтрока = Неопределено Тогда
				ВызватьИсключение НСтр("ru = 'Редактируемая строка не определена'");
			КонецЕсли;
			ПриложениеPowerPoint.ХранениеВБазе = ДанныеХраненияПрезентацииТеории(РедактируемаяСтрока.СсылкаНаЭлемент, УникальныйИдентификатор);
		Иначе
			ПриложениеPowerPoint.ХранениеВБазе = ДанныеХраненияПрезентацииЭлектронногоКурса(ЭлектронныйКурс, УникальныйИдентификатор);
		КонецЕсли;
			
		ПолучитьФайл(ПриложениеPowerPoint.ХранениеВБазе.МестоХраненияВБазе, ПриложениеPowerPoint.ХранениеНаДиске, Ложь);		
		
		ФайловаяСистемаКлиент.ОткрытьФайл(ПриложениеPowerPoint.ХранениеНаДиске);
		
	КонецЕсли;
	
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьНовыйСлайдВPowerPoint()
	
	#Если ВебКлиент ИЛИ МобильныйКлиент Тогда
			
	ПоказатьПредупреждение(,НСтр("ru = 'Работа со слайдами PowerPoint недоступна в браузере.
		|Воспользуйтесь настольной версией программы.'"));
	
	Возврат;
	
	#КонецЕсли
	
	Если ОбщегоНазначенияКлиент.ЭтоLinuxКлиент() Тогда		
		ПоказатьПредупреждение(,НСтр("ru = 'Работа со слайдами PowerPoint недоступно в Linux.'"));
	    Возврат;
	КонецЕсли;
	
	Если ТипЭлектронногоКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Слайдовый")
		И ДанныеХраненияПрезентацииЭлектронногоКурса(ЭлектронныйКурс, УникальныйИдентификатор) <> Неопределено Тогда
		
		НоваяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());	
		НоваяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.СлайдПрезентацииPowerPoint");
		
		НачатьРедактироватьЭлементКурса();
		ОткрытьПрезентациюPowerPoint();		
		ПриРедактировании();
		
	Иначе
		
		ЗагрузитьФайлы(ПредопределенноеЗначение("Перечисление.ТипыЭлементовЭлектронныхРесурсов.Presentation"));
		
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Функция НовыйПутьХраненияПрезентацииPowerPoint(НаименованиеПрезентации, Приложение)
	
	#Если ВебКлиент ИЛИ МобильныйКлиент Тогда
		
	ВызватьИсключение НСтр("ru = 'Работа с презентациями в веб-клиенте не поддерживается'");	
		
	#Иначе
		
	Если ОбщегоНазначенияКлиент.ЭтоLinuxКлиент()Тогда
		ВызватьИсключение НСтр("ru = 'Работа с презентациями PowerPoint в Linux не поддерживается'");	
	КонецЕсли;	
		
	Если ОбщегоНазначенияКлиент.ЭтоWindowsКлиент() Тогда			
		ПутьКПрезентацииНаДиске = ПолучитьИмяВременногоФайла("");
		ЭлектронноеОбучениеСлужебныйКлиентСервер.НовыйКаталог(ПутьКПрезентацииНаДиске);		
		ПутьКПрезентацииНаДиске = ЭлектронноеОбучениеСлужебныйКлиентСервер.ДобавитьКонечныйРазделительПути(ПутьКПрезентацииНаДиске);		
		ПутьКПрезентацииНаДиске = ПутьКПрезентацииНаДиске + ЭлектронноеОбучениеСлужебныйКлиентСервер.ЗаменитьЗапрещенныеСимволыВИмениФайла(НаименованиеПрезентации);
		ПутьКПрезентацииНаДиске = ПутьКПрезентацииНаДиске + ".pptx";		
	КонецЕсли;	
	
	Если ОбщегоНазначенияКлиент.ЭтоOSXКлиент() Тогда		
		ПутьКПрезентацииНаДиске = Приложение.РабочийКаталог.Путь + "presentation.pptx";			
	КонецЕсли;
	
	Возврат ПутьКПрезентацииНаДиске;
	
	#КонецЕсли	
	
КонецФункции

&НаКлиенте
Процедура Подключаемый_СохранитьПрезентациюPowerPoint() Экспорт	

	#Если НЕ ВебКлиент И НЕ МобильныйКлиент Тогда
		
	ПрезентацияДоступна = РазработкаЭлектронныхКурсовСлужебныйКлиент.ПрезентацияPowerPointДоступна(ПриложениеPowerPoint);
	ПрезентацияМодифицирована = РазработкаЭлектронныхКурсовСлужебныйКлиент.ПрезентацияPowerPointМодифицирована(ПриложениеPowerPoint);
		
	Если ПрезентацияДоступна И ПрезентацияМодифицирована Тогда
		
		// Ждем, пока презентация сохранится
		ПодключитьОбработчикОжидания("Подключаемый_СохранитьПрезентациюPowerPoint", 0.2, Истина); // Рекурсия
		Возврат;
		
	КонецЕсли;		
	
	Если НЕ ПрезентацияМодифицирована Тогда
		
		ПриложениеPowerPoint.ХранениеНаДискеКопия = НовыйПутьХраненияПрезентацииPowerPoint("Presentation", ПриложениеPowerPoint);
		ЭлектронноеОбучениеСлужебныйКлиентСервер.СкопироватьФайл(ПриложениеPowerPoint.ХранениеНаДиске, ПриложениеPowerPoint.ХранениеНаДискеКопия);	

		ПропуститьАктивациюЭлементаСодержания = Истина;
		
		Если ТипЭлектронногоКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Учебник") Тогда
			СохранитьПрезентациюPowerPointВБазу(ПриложениеPowerPoint.ХранениеНаДискеКопия, ИдентификаторРедактируемойСтрокиНаКлиенте());
		Иначе			
			СохранитьПрезентациюPowerPointВБазу(ПриложениеPowerPoint.ХранениеНаДискеКопия);
		КонецЕсли;
		
	КонецЕсли;
	
	Если НЕ ПрезентацияДоступна
		ИЛИ ПриложениеPowerPoint.ВыйтиИзРежимаРедактированияПослеЗаписи Тогда
		
		ЗакрытьПрезентациюPowerPoint(Ложь);
		ВыйтиИзРежимаРедактирования(Ложь);
		
	КонецЕсли;
	
	ПриРедактировании();
	
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗаписьюПрезентацииPowerPoint(Pres, Cancel) Экспорт   
	
	#Если НЕ ВебКлиент И НЕ МобильныйКлиент Тогда
	
	Если ПриложениеPowerPoint.Презентация <> Pres Тогда
		Возврат;
	КонецЕсли;	
	
	ПодключитьОбработчикОжидания("Подключаемый_СохранитьПрезентациюPowerPoint", 0.2, Истина);	
		
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытиемПрезентацииPowerPoint(Pres, Cancel) Экспорт   
	
	Если ПриложениеPowerPoint.Презентация <> Pres Тогда
		Возврат;
	КонецЕсли;	
	
	ПодключитьОбработчикОжидания("Подключаемый_ПриЗакрытииПрезентацииPowerPoint", 0.2, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьПрезентациюPowerPoint(УдалятьCOMПриложенияПриЗакрытии, ЗавершениеРаботы = Ложь)
	
	Если ПриложениеPowerPoint <> Неопределено Тогда
		
		Если ОбщегоНазначенияКлиент.ЭтоWindowsКлиент() Тогда
			
			Если ПриложениеPowerPoint.Пользовательское <> Неопределено Тогда
				
				Попытка
					УдалитьОбработчик ПриложениеPowerPoint.Пользовательское.PresentationBeforeSave, ПередЗаписьюПрезентацииPowerPoint;	
					УдалитьОбработчик ПриложениеPowerPoint.Пользовательское.PresentationBeforeClose, ПередЗакрытиемПрезентацииPowerPoint;	
				Исключение
					// Обработка исключения не требуется
				КонецПопытки;		
				
			КонецЕсли;
			
			Если ПриложениеPowerPoint.Презентация <> Неопределено Тогда
				
				Попытка
					ПриложениеPowerPoint.Презентация.Close();
				Исключение	
					// Обработка исключения не требуется
				КонецПопытки;
				
			КонецЕсли;				
			
			Если ПриложениеPowerPoint.Пользовательское <> Неопределено
				И НЕ РазработкаЭлектронныхКурсовСлужебныйКлиент.ЕстьОткрытыеПрезентацииPowerPoint(ПриложениеPowerPoint) Тогда			
				РазработкаЭлектронныхКурсовСлужебныйКлиент.ЗакрытьПриложениеMSOffice(ПриложениеPowerPoint.Пользовательское,,ЗавершениеРаботы);
			КонецЕсли;					
			
			Если ПриложениеPowerPoint.Скрытое <> Неопределено
				И УдалятьCOMПриложенияПриЗакрытии Тогда			
				РазработкаЭлектронныхКурсовСлужебныйКлиент.ЗакрытьПриложениеMSOffice(ПриложениеPowerPoint.Скрытое,,ЗавершениеРаботы);
			КонецЕсли;			
			
			Если ЗначениеЗаполнено(ПриложениеPowerPoint.ХранениеНаДиске) Тогда
				ХранениеПрезентацииНаДискеСтруктура = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(ПриложениеPowerPoint.ХранениеНаДиске, Ложь);
				ЭлектронноеОбучениеСлужебныйКлиентСервер.УдалитьВременныйФайл(ХранениеПрезентацииНаДискеСтруктура.Путь, ЗавершениеРаботы);
			КонецЕсли;		
			
			Если ЗначениеЗаполнено(ПриложениеPowerPoint.ХранениеНаДискеКопия) Тогда
				ХранениеПрезентацииНаДискеСтруктура = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(ПриложениеPowerPoint.ХранениеНаДискеКопия, Ложь);
				ЭлектронноеОбучениеСлужебныйКлиентСервер.УдалитьВременныйФайл(ХранениеПрезентацииНаДискеСтруктура.Путь, ЗавершениеРаботы);
			КонецЕсли;					
			
		КонецЕсли;		
		
		Если ОбщегоНазначенияКлиент.ЭтоOSXКлиент() Тогда
			
			Если ЗначениеЗаполнено(ПриложениеPowerPoint.Скрытое) Тогда
				// Закрываем и записываем все открытые документы
				ПутьКФайлуПрограммыЗакрытияДокументов = ПриложениеPowerPoint.Скрытое + "closePresentations.scpt";
				ПараметрыЗапускаПрограммы = ФайловаяСистемаКлиент.ПараметрыЗапускаПрограммы();			
				ПараметрыЗапускаПрограммы.ДождатьсяЗавершения = Истина;					
				ФайловаяСистемаКлиент.ЗапуститьПрограмму("osascript """ + ПутьКФайлуПрограммыЗакрытияДокументов + """", ПараметрыЗапускаПрограммы);
				// Удаляем временный каталог со скриптами
				ЭлектронноеОбучениеСлужебныйКлиентСервер.УдалитьВременныйФайл(ПриложениеPowerPoint.Скрытое, ЗавершениеРаботы);
				ПриложениеPowerPoint.Скрытое = Неопределено;
				ПриложениеPowerPoint.Пользовательское = Неопределено;
			КонецЕсли;
			
		КонецЕсли;		
		
		РабочийКаталог = ПриложениеPowerPoint.РабочийКаталог;
			
		Если РабочийКаталог <> Неопределено 
			И ЗначениеЗаполнено(РабочийКаталог.Путь)
			И РабочийКаталог.ЭтоВременный Тогда
			
			ЭлектронноеОбучениеСлужебныйКлиентСервер.УдалитьВременныйФайл(РабочийКаталог.Путь, ЗавершениеРаботы);
			
		КонецЕсли;			
		
		ПриложениеPowerPoint.РабочийКаталог = Неопределено;
		
		Если УдалятьCOMПриложенияПриЗакрытии Тогда
			ПриложениеPowerPoint = Неопределено;
		КонецЕсли;			
		
	КонецЕсли;		
		
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПриЗакрытииПрезентацииPowerPoint() Экспорт	

	ПрезентацияДоступна = РазработкаЭлектронныхКурсовСлужебныйКлиент.ПрезентацияPowerPointДоступна(ПриложениеPowerPoint);
	
	Если ПрезентацияДоступна Тогда
		ПодключитьОбработчикОжидания("Подключаемый_ПриЗакрытииПрезентацииPowerPoint", 0.2, Истина); // Рекурсия
		Возврат; // Еще не закрыли
	Иначе
		ВыйтиИзРежимаРедактирования(Ложь);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ДобавитьНовуюПрезентациюPowerPointВБазу(ПользовательскийФайлПрезентации, ИдентификаторРодительскойСтроки = Неопределено, ЭлементаСодержанияДляЗаписи = Неопределено)
	
	#Если НЕ ВебКлиент И НЕ МобильныйКлиент Тогда
		
	// Инициируем работу с PowerPoint
			
	РазработкаЭлектронныхКурсовСлужебныйКлиент.ИнициализироватьПриложениеPowerPoint(ПриложениеPowerPoint);				
	
	Если ПриложениеPowerPoint = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;	
	
	Если ТипЭлектронногоКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Учебник") Тогда
		
		// Создаем новый элемент содержания и сохраняем презентацию в базу
		
		ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ПрезентацияPowerPoint");
		НоваяСтрока = НовыйЭлементСодержания(ТипЭлемента, ИдентификаторРодительскойСтроки);
		
		ПутьКФайлуПрезентацииКурса = НовыйПутьХраненияПрезентацииPowerPoint("Presentation", ПриложениеPowerPoint);
		
		ЭлектронноеОбучениеСлужебныйКлиентСервер.СкопироватьФайл(ПользовательскийФайлПрезентации.ПолноеИмя, ПутьКФайлуПрезентацииКурса);

		СохранитьПрезентациюPowerPointВБазу(ПутьКФайлуПрезентацииКурса, НоваяСтрока.ПолучитьИдентификатор(), ПользовательскийФайлПрезентации.ИмяБезРасширения, ЭлементаСодержанияДляЗаписи);
		
	Иначе		
		
		// Получаем данные о хранении презентации в базе
		
		Если ПриложениеPowerPoint.ХранениеВБазе = Неопределено Тогда		
			ПриложениеPowerPoint.ХранениеВБазе = ДанныеХраненияПрезентацииЭлектронногоКурса(ЭлектронныйКурс, УникальныйИдентификатор);		
		КонецЕсли;
		
		// Формируем файл презентации курса
		
		ПутьКФайлуПрезентацииКурса = НовыйПутьХраненияПрезентацииPowerPoint("Presentation", ПриложениеPowerPoint);	 
		
		Если ОбщегоНазначенияКлиент.ЭтоWindowsКлиент() Тогда
		
			Если ПриложениеPowerPoint.ХранениеВБазе = Неопределено Тогда
				
				// Первая загрузка презентации (копируем пользовательский файл или сохраняем в формате pptx)
				
				Если НРег(ПользовательскийФайлПрезентации.Расширение) = ".pptx" Тогда
					ЭлектронноеОбучениеСлужебныйКлиентСервер.СкопироватьФайл(ПользовательскийФайлПрезентации.ПолноеИмя, ПутьКФайлуПрезентацииКурса);
				Иначе
					Презентация = ПриложениеPowerPoint.Скрытое.Presentations.Open(ПользовательскийФайлПрезентации.ПолноеИмя,,,Ложь);	
					Презентация.SaveAs(ПутьКФайлуПрезентацииКурса, 11); //ppSaveAsDefault
					Презентация.Close();
				КонецЕсли;		
				
			Иначе
				
				// Добавляем слайды к существующей презентации
				
				ПолучитьФайл(ПриложениеPowerPoint.ХранениеВБазе.МестоХраненияВБазе, ПутьКФайлуПрезентацииКурса, Ложь);
				
				Презентация = ПриложениеPowerPoint.Скрытое.Presentations.Open(ПутьКФайлуПрезентацииКурса,,,Ложь);
				Презентация.Slides.InsertFromFile(ПользовательскийФайлПрезентации.ПолноеИмя, Презентация.Slides.Count);
				Презентация.Save();
				Презентация.Close();
				
			КонецЕсли;
			
		КонецЕсли;
		
		Если ОбщегоНазначенияКлиент.ЭтоOSXКлиент() Тогда
			
			Если ПриложениеPowerPoint.ХранениеВБазе = Неопределено Тогда
				
				ЭлектронноеОбучениеСлужебныйКлиентСервер.СкопироватьФайл(ПользовательскийФайлПрезентации.ПолноеИмя, ПутьКФайлуПрезентацииКурса);
				
			Иначе
				
				// Размещаем файл презентации из базы на диск
				//
				
				ПолучитьФайл(ПриложениеPowerPoint.ХранениеВБазе.МестоХраненияВБазе, ПутьКФайлуПрезентацииКурса, Ложь);
				
				// Копируем пользовательский файл, который надо объединить
				// с файлом презентации из базы
				
				ЭлектронноеОбучениеСлужебныйКлиентСервер.СкопироватьФайл(ПользовательскийФайлПрезентации.ПолноеИмя, ПриложениеPowerPoint.РабочийКаталог.Путь + "presentationSource.pptx");
				
				// Запускаем объединение
				//
				
				ПутьКФайлуПрограммыКонвертации = ПриложениеPowerPoint.Скрытое + "/combinePresentations.scpt";
				ПараметрыЗапускаПрограммы = ФайловаяСистемаКлиент.ПараметрыЗапускаПрограммы();			
				ПараметрыЗапускаПрограммы.ДождатьсяЗавершения = Истина;
				ПараметрыЗапускаПрограммы.ПолучитьПотокВывода = Истина;							
				ОтветПрограммы = ФайловаяСистемаКлиент.ЗапуститьПрограмму("osascript """ + ПутьКФайлуПрограммыКонвертации + """", ПараметрыЗапускаПрограммы).ПотокВывода;
				ОтветПрограммы = СокрЛП(ОтветПрограммы);		
				
				Если ОтветПрограммы <> "true" Тогда
					ВызватьИсключение НСтр("ru = 'Не удалось объединить презентации.
					|Попробуйте завершить приложение PowerPoint (Правой кнопкой мыши -> Завершить),
					|закрыть форму курса и попробовать провести операцию снова.'");
				КонецЕсли;				
				
			КонецЕсли;
			
		КонецЕсли;
			
		СохранитьПрезентациюPowerPointВБазу(ПутьКФайлуПрезентацииКурса);		
		
		РаскрытьКорень();
		
	КонецЕсли;
	
	Возврат Истина;
	
	#КонецЕсли
	
	Возврат Ложь;
	
КонецФункции

&НаКлиенте
Процедура УдалитьСлайдыИзПрезентацииPowerPointСлайдовогоКурса(МассивЭлементовСодержания)
	
	#Если НЕ ВебКлиент И НЕ МобильныйКлиент Тогда
	
	Если РазработкаЭлектронныхКурсовСлужебныйКлиент.ПрезентацияPowerPointДоступна(ПриложениеPowerPoint) Тогда
		ВызватьИсключение НСтр("ru = 'Слайды не могут быть удалены в открытой презентации'");
	КонецЕсли;
	
	Если ТипЭлектронногоКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Учебник") Тогда
		ВызватьИсключение НСтр("ru = 'Функциональность не поддерживается в электронном учебнике'");
	КонецЕсли;	
	
	РазработкаЭлектронныхКурсовСлужебныйКлиент.ИнициализироватьПриложениеPowerPoint(ПриложениеPowerPoint);
	
	Если ПриложениеPowerPoint = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПриложениеPowerPoint.ХранениеНаДиске = НовыйПутьХраненияПрезентацииPowerPoint("presentation", ПриложениеPowerPoint);
	ПриложениеPowerPoint.ХранениеВБазе = ДанныеХраненияПрезентацииЭлектронногоКурса(ЭлектронныйКурс, УникальныйИдентификатор);
	ПолучитьФайл(ПриложениеPowerPoint.ХранениеВБазе.МестоХраненияВБазе, ПриложениеPowerPoint.ХранениеНаДиске, Ложь);		
	
	ИдентификаторыСлайдов = ИдентификаторыСлайдовПрезентацииЭлементовСодержания(МассивЭлементовСодержания);
	
	Если ОбщегоНазначенияКлиент.ЭтоWindowsКлиент() Тогда
	
		ПриложениеPowerPoint.Презентация = ПриложениеPowerPoint.Пользовательское.Presentations.Open(ПриложениеPowerPoint.ХранениеНаДиске,,,Ложь);
		
		Для каждого ИдентификаторСлайда Из ИдентификаторыСлайдов Цикл	
			СлайдПрезентации = ПриложениеPowerPoint.Презентация.Slides.FindBySlideID(ИдентификаторСлайда);
			СлайдПрезентации.Delete();	
		КонецЦикла;
		
		ПриложениеPowerPoint.Презентация.Save();
		ПриложениеPowerPoint.Презентация.Close();
		
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиент.ЭтоOSXКлиент() Тогда
		
		ПутьКФайлуСоСпискомУдаляемыхСлайдов = ПриложениеPowerPoint.РабочийКаталог.Путь + "slidesToDelete.txt";
		
		Текст = Новый ЗаписьТекста(ПутьКФайлуСоСпискомУдаляемыхСлайдов, КодировкаТекста.UTF8);
		Для каждого ИдентификаторСлайда Из ИдентификаторыСлайдов Цикл	
			Текст.ЗаписатьСтроку(ЭлектронноеОбучениеСлужебныйКлиентСервер.ЧислоВСтроку(ИдентификаторСлайда));
		КонецЦикла;
		Текст.Закрыть();
		
		ПутьКФайлуПрограммыКонвертации = ПриложениеPowerPoint.Скрытое + "deleteSlides.scpt";
		ПараметрыЗапускаПрограммы = ФайловаяСистемаКлиент.ПараметрыЗапускаПрограммы();			
		ПараметрыЗапускаПрограммы.ДождатьсяЗавершения = Истина;
		ПараметрыЗапускаПрограммы.ПолучитьПотокВывода = Истина;							
		ОтветПрограммы = ФайловаяСистемаКлиент.ЗапуститьПрограмму("osascript """ + ПутьКФайлуПрограммыКонвертации + """", ПараметрыЗапускаПрограммы).ПотокВывода;
		ОтветПрограммы = СокрЛП(ОтветПрограммы);		
		
		Если ОтветПрограммы <> "true" Тогда
			ВызватьИсключение НСтр("ru = 'Не удалось удалить слайды в презентации'");
		КонецЕсли;		
		
	КонецЕсли;
		
	СохранитьПрезентациюPowerPointВБазу(ПриложениеPowerPoint.ХранениеНаДиске);
	
	ЗакрытьПрезентациюPowerPoint(Ложь);
	
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьПрезентациюPowerPointВБазу(ПутьКФайлуПрезентацииКурса, ИдентификаторРедактируемойСтроки = Неопределено, НаименованиеПрезентации = Неопределено, ЭлементаСодержанияДляЗаписи = Неопределено)
	
	#Если НЕ ВебКлиент И НЕ МобильныйКлиент Тогда
		
	ФайлПрезентацииКурса = Новый Файл(ПутьКФайлуПрезентацииКурса);
	Если НЕ ФайлПрезентацииКурса.Существует() Тогда
		ВызватьИсключение СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Файл %1 презентации не найден'"), ФайлПрезентацииКурса.ПолноеИмя);
	КонецЕсли;				
	
	ФайлыДляУдаления = Новый Массив;
	ФайлыДляСохранения = Новый Массив;
	
	ФайлыДляУдаления.Добавить(ПутьКФайлуПрезентацииКурса);
	ФайлыДляСохранения.Добавить(ФайлПрезентацииКурса);
	
	// Сохраняем картинки слайдов и формируем переменную НастройкиКартинок
	//
	
	НастройкиКартинок = Новый Структура("Слайды");
	НастройкиКартинок.Слайды = Новый Массив;
	
	Если ОбщегоНазначенияКлиент.ЭтоWindowsКлиент() Тогда
	
		ПутьКаталогуСКартинками = ПолучитьИмяВременногоФайла("");
		ЭлектронноеОбучениеСлужебныйКлиентСервер.НовыйКаталог(ПутьКаталогуСКартинками);		
		ФайлыДляУдаления.Добавить(ПутьКаталогуСКартинками);
		
		Презентация = ПриложениеPowerPoint.Скрытое.Presentations.Open(ПутьКФайлуПрезентацииКурса,,,Ложь);
		
		Для каждого СвойстваСлайда Из Презентация.Slides Цикл
		
			СтруктураСлайда = Новый Структура("Номер, Идентификатор, ИмяФайла");
			СтруктураСлайда.Номер = СвойстваСлайда.SlideIndex;
			СтруктураСлайда.Идентификатор = СвойстваСлайда.SlideID;
			СтруктураСлайда.ИмяФайла = ЭлектронноеОбучениеСлужебныйКлиентСервер.ЧислоВСтроку(СтруктураСлайда.Идентификатор) + ".png"; // Будет сохранено в базу
			
			НастройкиКартинок.Слайды.Добавить(СтруктураСлайда);
			
		КонецЦикла;
		
		НастройкиКартинок = Новый ФиксированнаяСтруктура(НастройкиКартинок);
		
		Презентация.SaveAs(ПутьКаталогуСКартинками, 18); //ppSaveAsPNG	
		Презентация.Close();
		
	КонецЕсли;
	
	Если ОбщегоНазначенияКлиент.ЭтоOSXКлиент() Тогда
		
		Если ПриложениеPowerPoint.РабочийКаталог.ЭтоВременный Тогда
			ФайлыДляУдаления.Добавить(ПриложениеPowerPoint.РабочийКаталог.Путь);
		КонецЕсли;
		
		ПутьКПрезентацииВКаталогеКонвертации = ПриложениеPowerPoint.РабочийКаталог.Путь + "presentation.pptx";
			
		Если ПутьКФайлуПрезентацииКурса <> ПутьКПрезентацииВКаталогеКонвертации Тогда
			ВызватьИсключение НСтр("ru = 'Файл презентации не найден в каталоге конвертации'");
		КонецЕсли;
		
		// Запускаем конвертацию
		//
		
		ПутьКФайлуПрограммыКонвертации = ПриложениеPowerPoint.Скрытое + "convertPresentationToImages.scpt";
		ПараметрыЗапускаПрограммы = ФайловаяСистемаКлиент.ПараметрыЗапускаПрограммы();			
		ПараметрыЗапускаПрограммы.ДождатьсяЗавершения = Истина;
		ПараметрыЗапускаПрограммы.ПолучитьПотокВывода = Истина;							
		ОтветПрограммы = ФайловаяСистемаКлиент.ЗапуститьПрограмму("osascript """ + ПутьКФайлуПрограммыКонвертации + """", ПараметрыЗапускаПрограммы).ПотокВывода;
		ОтветПрограммы = СокрЛП(ОтветПрограммы);		
		
		Если ОтветПрограммы <> "true" Тогда
			ВызватьИсключение НСтр("ru = 'Не удалось преобразовать презентацию.
			|Попробуйте завершить приложение PowerPoint (Правой кнопкой мыши -> Завершить),
			|закрыть форму курса и попробовать провести операцию снова.'");
		КонецЕсли;
		
		ПутьКаталогуСКартинками = ПриложениеPowerPoint.РабочийКаталог.Путь + "images";
		
		// Читаем идентификаторы слайдов
		//
		
		ЧтениеТекста = Новый ЧтениеТекста(ПриложениеPowerPoint.РабочийКаталог.Путь + "slides.txt", КодировкаТекста.UTF8);
		ИдентификаторыСлайдовСтрока = ЧтениеТекста.Прочитать();
		ЧтениеТекста.Закрыть();
		
		ИдентификаторыСлайдовМассив = СтрРазделить(ИдентификаторыСлайдовСтрока, ";", Ложь);
		
		Для каждого ЗначениеСтрока Из ИдентификаторыСлайдовМассив Цикл
			
			ЗначениеСтрока = СокрЛП(ЗначениеСтрока);
			Если НЕ ЗначениеЗаполнено(ЗначениеСтрока) Тогда
				Продолжить;
			КонецЕсли;
			
			ЗначениеМассив = СтрРазделить(ЗначениеСтрока, "|", Ложь);
			Если ЗначениеМассив.Количество() < 2 Тогда
				ВызватьИсключение НСтр("ru = 'Ошибка формата файла с идентификаторами слайдов'");
			КонецЕсли;
			
			СтруктураСлайда = Новый Структура("Номер, Идентификатор, ИмяФайла");
			СтруктураСлайда.Номер = Число(ЗначениеМассив[0]);
			СтруктураСлайда.Идентификатор = Число(ЗначениеМассив[1]);
			СтруктураСлайда.ИмяФайла = ЭлектронноеОбучениеСлужебныйКлиентСервер.ЧислоВСтроку(СтруктураСлайда.Идентификатор) + ".png"; // Будет сохранено в базу
			
			НастройкиКартинок.Слайды.Добавить(СтруктураСлайда);			
			
		КонецЦикла;
		
	КонецЕсли;
	
	ПереименоватьСлайдыПоИдентификаторам(НастройкиКартинок, ПутьКаталогуСКартинками);
	
	// Проверяем есть ли все файлы
	//
	
	Для каждого СтруктураСлайда Из НастройкиКартинок.Слайды Цикл
	
		ФайлКартинки = Новый Файл(ПутьКаталогуСКартинками + СтруктураСлайда.ИмяФайла);
		Если НЕ ФайлКартинки.Существует() Тогда
			ВызватьИсключение СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Файл %1 презентации не найден'"), ФайлКартинки.ПолноеИмя);	
		КонецЕсли;
		
	КонецЦикла;
	
	// Сохраняем картинки и файл презентации в базу
	//
	
	СохранитьПрезентациюИКартинкиСлайдовВБазу(ПутьКФайлуПрезентацииКурса, ПутьКаталогуСКартинками, НастройкиКартинок, ФайлыДляСохранения, ФайлыДляУдаления, ИдентификаторРедактируемойСтроки, НаименованиеПрезентации, ЭлементаСодержанияДляЗаписи);
	
	#КонецЕсли
	
КонецПроцедуры

// OpenOffice (Impress)

&НаКлиенте
Функция ДобавитьНовуюПрезентациюOpenOfficeВБазу(ПользовательскийФайлПрезентации, ИдентификаторРодительскойСтроки = Неопределено, ЭлементаСодержанияДляЗаписи = Неопределено)
	
	#Если НЕ ВебКлиент И НЕ МобильныйКлиент Тогда
		
	// Инициируем работу с Impress
	
	РазработкаЭлектронныхКурсовСлужебныйКлиент.ИнициализироватьПриложениеImpress(ПриложениеImpress);				
	
	Если ПриложениеImpress = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;	
	
	Если ТипЭлектронногоКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Учебник") Тогда
		
		// Создаем новый элемент содержания и сохраняем презентацию в базу
		
		ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ПрезентацияImpress");
		НоваяСтрока = НовыйЭлементСодержания(ТипЭлемента, ИдентификаторРодительскойСтроки);
		
		ПутьКФайлуПрезентацииКурса = НовыйПутьХраненияПрезентацииOpenOffice("Presentation", ПриложениеImpress);
		
		ЭлектронноеОбучениеСлужебныйКлиентСервер.СкопироватьФайл(ПользовательскийФайлПрезентации.ПолноеИмя, ПутьКФайлуПрезентацииКурса);
		
		СохранитьПрезентациюOpenOfficeВБазу(ПутьКФайлуПрезентацииКурса, НоваяСтрока.ПолучитьИдентификатор(), ПользовательскийФайлПрезентации.ИмяБезРасширения, ЭлементаСодержанияДляЗаписи);
		
	Иначе		
		
		Если ПриложениеImpress.ХранениеВБазе = Неопределено Тогда		
			ПриложениеImpress.ХранениеВБазе = ДанныеХраненияПрезентацииЭлектронногоКурса(ЭлектронныйКурс, УникальныйИдентификатор);		
		КонецЕсли;
		
		Если ПриложениеImpress.ХранениеВБазе = Неопределено Тогда
			ПутьКФайлуПрезентацииКурса = НовыйПутьХраненияПрезентацииOpenOffice("Presentation", ПриложениеImpress);
			ЭлектронноеОбучениеСлужебныйКлиентСервер.СкопироватьФайл(ПользовательскийФайлПрезентации.ПолноеИмя, ПутьКФайлуПрезентацииКурса);
			СохранитьПрезентациюOpenOfficeВБазу(ПутьКФайлуПрезентацииКурса);
		Иначе			
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Курс уже содержит презентацию. Для объединения презентаций откройте уже загруженную презентацию на редактирование и скопируйте в нее нужные слайды.'"));
			Возврат Ложь;
		КонецЕсли;		
		
	КонецЕсли;
	
	Возврат Истина;
		
	#КонецЕсли
	
	Возврат Ложь;	
	
КонецФункции

&НаКлиенте
Процедура СоздатьНовыйСлайдВOpenOffice()
	
	#Если ВебКлиент ИЛИ МобильныйКлиент Тогда
			
	ПоказатьПредупреждение(,НСтр("ru = 'Работа со слайдами Impress недоступна в браузере.
		|Воспользуйтесь настольной версией программы.'"));
	
	Возврат;
	
	#КонецЕсли
	
	Если ТипЭлектронногоКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Слайдовый")
		И ДанныеХраненияПрезентацииЭлектронногоКурса(ЭлектронныйКурс, УникальныйИдентификатор) <> Неопределено Тогда
		
		НоваяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());	
		НоваяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.СлайдПрезентацииImpress");
		
		НачатьРедактироватьЭлементКурса();
		ОткрытьПрезентациюOpenOffice();
		ПриРедактировании();
		
	Иначе
		
		ЗагрузитьФайлы(ПредопределенноеЗначение("Перечисление.ТипыЭлементовЭлектронныхРесурсов.Presentation"));
		
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьПрезентациюOpenOffice()
	
	#Если НЕ ВебКлиент И НЕ МобильныйКлиент Тогда		
		
	// Инициируем работу с OpenOffice
	
	Если РазработкаЭлектронныхКурсовСлужебныйКлиент.ПрезентацияImpressДоступна(ПриложениеImpress) Тогда

		ПоказатьПредупреждение(,НСтр("ru = 'Презентация уже открыта'"));

	Иначе		
		
		РазработкаЭлектронныхКурсовСлужебныйКлиент.ИнициализироватьПриложениеImpress(ПриложениеImpress);
		
		Если ПриложениеImpress = Неопределено Тогда
			Возврат;
		КонецЕсли;		
		
		ПриложениеImpress.ХранениеНаДиске = НовыйПутьХраненияПрезентацииOpenOffice("Presentation", ПриложениеImpress);

		Если ТипЭлектронногоКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Учебник") Тогда
			РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());	
			Если РедактируемаяСтрока = Неопределено Тогда
				ВызватьИсключение НСтр("ru = 'Редактируемая строка не определена'");
			КонецЕсли;
			ПриложениеImpress.ХранениеВБазе = ДанныеХраненияПрезентацииТеории(РедактируемаяСтрока.СсылкаНаЭлемент, УникальныйИдентификатор);
		Иначе
			ПриложениеImpress.ХранениеВБазе = ДанныеХраненияПрезентацииЭлектронногоКурса(ЭлектронныйКурс, УникальныйИдентификатор);
		КонецЕсли;
		
		ПолучитьФайл(ПриложениеImpress.ХранениеВБазе.МестоХраненияВБазе, ПриложениеImpress.ХранениеНаДиске, Ложь);				
	
		Если ОбщегоНазначенияКлиент.ЭтоWindowsКлиент() Тогда
			
			ПараметрыОткрытияПрезентацииСтруктура = Новый Структура;
			ПараметрыОткрытияПрезентацииСтруктура.Вставить("MacroExecutionMode", 0);
			ПараметрыОткрытияПрезентацииСтруктура.Вставить("Hidden", Ложь);
			ПараметрыОткрытияПрезентации = РазработкаЭлектронныхКурсовСлужебныйКлиент.ПараметрыВФорматеOpenOffice(ПриложениеImpress.Пользовательское, ПараметрыОткрытияПрезентацииСтруктура);
			
			ПриложениеImpress.Презентация = ПриложениеImpress.Пользовательское.Desktop.loadComponentFromURL(
				РазработкаЭлектронныхКурсовСлужебныйКлиент.ПутьКФайлуВФорматеOpenOffice(ПриложениеImpress.ХранениеНаДиске),
				"_blank",
				0,
				ПараметрыОткрытияПрезентации
			);					
			
		Иначе
			
			ФайловаяСистемаКлиент.ОткрытьФайл(ПриложениеImpress.ХранениеНаДиске);
			
		КонецЕсли;
			
	КонецЕсли;
		
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьПрезентациюOpenOffice(УдалятьCOMПриложенияПриЗакрытии, ЗавершениеРаботы)
	
	Если ПриложениеImpress <> Неопределено Тогда
		
		Если ОбщегоНазначенияКлиент.ЭтоWindowsКлиент() Тогда
			
			Если ПриложениеImpress.Презентация <> Неопределено Тогда
							
				Попытка
					ПриложениеImpress.Презентация.close(true);
				Исключение	
					// Обработка исключения не требуется
					Если НЕ ЗавершениеРаботы Тогда
						ЭлектронноеОбучениеСлужебныйКлиент.ЗаписатьОшибкуВЖурналРегистрации(ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()), "ПриложениеImpress.Презентация.close(true)");
					КонецЕсли;					
				КонецПопытки;
				
			КонецЕсли;						
			
			Если УдалятьCOMПриложенияПриЗакрытии Тогда
				РазработкаЭлектронныхКурсовСлужебныйКлиент.ЗакрытьПриложениеOpenOffice(ПриложениеImpress.Пользовательское);
				РазработкаЭлектронныхКурсовСлужебныйКлиент.ЗакрытьПриложениеOpenOffice(ПриложениеImpress.Скрытое);				
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ПриложениеImpress.ХранениеНаДиске) Тогда
				ХранениеПрезентацииНаДискеСтруктура = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(ПриложениеImpress.ХранениеНаДиске, Ложь);
				ЭлектронноеОбучениеСлужебныйКлиентСервер.УдалитьВременныйФайл(ХранениеПрезентацииНаДискеСтруктура.Путь);
			КонецЕсли;		
			
			Если ЗначениеЗаполнено(ПриложениеImpress.ХранениеНаДискеКопия) Тогда
				ХранениеПрезентацииНаДискеСтруктура = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(ПриложениеImpress.ХранениеНаДискеКопия, Ложь);
				ЭлектронноеОбучениеСлужебныйКлиентСервер.УдалитьВременныйФайл(ХранениеПрезентацииНаДискеСтруктура.Путь);
			КонецЕсли;
			
		КонецЕсли;		
			
		РабочийКаталог = ПриложениеImpress.РабочийКаталог;
			
		Если РабочийКаталог <> Неопределено 
			И ЗначениеЗаполнено(РабочийКаталог.Путь)
			И РабочийКаталог.ЭтоВременный Тогда
			
			ЭлектронноеОбучениеСлужебныйКлиентСервер.УдалитьВременныйФайл(РабочийКаталог.Путь);
			
		КонецЕсли;			
		
		ПриложениеImpress.РабочийКаталог = Неопределено;
		
		Если УдалятьCOMПриложенияПриЗакрытии Тогда
			ПриложениеImpress = Неопределено;
		КонецЕсли;			
		
	КонецЕсли;		
		
КонецПроцедуры

&НаКлиенте
Функция НовыйПутьХраненияПрезентацииOpenOffice(НаименованиеПрезентации, Приложение)
	
	#Если ВебКлиент ИЛИ МобильныйКлиент Тогда
		
	ВызватьИсключение НСтр("ru = 'Работа с презентациями в веб-клиенте не поддерживается'");	
		
	#Иначе
		
	ПутьКПрезентацииНаДиске = ПолучитьИмяВременногоФайла("");
	ЭлектронноеОбучениеСлужебныйКлиентСервер.НовыйКаталог(ПутьКПрезентацииНаДиске);		
	ПутьКПрезентацииНаДиске = ЭлектронноеОбучениеСлужебныйКлиентСервер.ДобавитьКонечныйРазделительПути(ПутьКПрезентацииНаДиске);		
	ПутьКПрезентацииНаДиске = ПутьКПрезентацииНаДиске + ЭлектронноеОбучениеСлужебныйКлиентСервер.ЗаменитьЗапрещенныеСимволыВИмениФайла(НаименованиеПрезентации);		
	ПутьКПрезентацииНаДиске = ПутьКПрезентацииНаДиске + ".odp";
	
	Возврат ПутьКПрезентацииНаДиске;
	
	#КонецЕсли	
	
КонецФункции

&НаКлиенте
Процедура СохранитьПрезентациюOpenOfficeВБазу(ПутьКФайлуПрезентацииКурса, ИдентификаторРедактируемойСтроки = Неопределено, НаименованиеПрезентации = Неопределено, ЭлементаСодержанияДляЗаписи = Неопределено)
	
	#Если НЕ ВебКлиент И НЕ МобильныйКлиент Тогда
		
	ФайлПрезентацииКурса = Новый Файл(ПутьКФайлуПрезентацииКурса);
	Если НЕ ФайлПрезентацииКурса.Существует() Тогда
		ВызватьИсключение СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Файл %1 презентации не найден'"), ФайлПрезентацииКурса.ПолноеИмя);
	КонецЕсли;				
	
	ФайлыДляУдаления = Новый Массив;
	ФайлыДляСохранения = Новый Массив;
	
	ФайлыДляУдаления.Добавить(ПутьКФайлуПрезентацииКурса);
	ФайлыДляСохранения.Добавить(ФайлПрезентацииКурса);
	
	// Сохраняем картинки слайдов и формируем переменную НастройкиКартинок
	//
	
	НастройкиКартинок = Новый Структура("Слайды");
	НастройкиКартинок.Слайды = Новый Массив;
	
	
	Если ОбщегоНазначенияКлиент.ЭтоWindowsКлиент() Тогда
		
		// Подготовка
		//
		
		ПутьКаталогуСКартинками = ПолучитьИмяВременногоФайла("");
		ЭлектронноеОбучениеСлужебныйКлиентСервер.НовыйКаталог(ПутьКаталогуСКартинками);		
		ФайлыДляУдаления.Добавить(ПутьКаталогуСКартинками);
		
		// Открываем презентацию
		//
		
		ПараметрыОткрытияПрезентацииСтруктура = Новый Структура;
		ПараметрыОткрытияПрезентацииСтруктура.Вставить("MacroExecutionMode", 0);
		ПараметрыОткрытияПрезентацииСтруктура.Вставить("Hidden", Истина);
		ПараметрыОткрытияПрезентации = РазработкаЭлектронныхКурсовСлужебныйКлиент.ПараметрыВФорматеOpenOffice(ПриложениеImpress.Скрытое, ПараметрыОткрытияПрезентацииСтруктура);
		
		Doc = ПриложениеImpress.Скрытое.Desktop.loadComponentFromURL(
			РазработкаЭлектронныхКурсовСлужебныйКлиент.ПутьКФайлуВФорматеOpenOffice(ПутьКФайлуПрезентацииКурса),
			"_blank",
			0,
			ПараметрыОткрытияПрезентации
		);		
		
		oDrawPages = Doc.getDrawPages();
		КоличествоСлайдов = oDrawPages.Count; 
						
		// Указываем идентификатор слайда в имени слайда
		//
		
		Для ИндексСлайда = 0 По КоличествоСлайдов - 1 Цикл
			
			oSlide = oDrawPages.getByIndex(ИндексСлайда);
			ИмяСлайда = СокрЛП(oSlide.Name);
			
			Если СтроковыеФункцииКлиентСервер.ЭтоУникальныйИдентификатор(ИмяСлайда) Тогда
				Продолжить;
			Иначе
				oSlide.Name = Строка(Новый УникальныйИдентификатор());
			КонецЕсли;
			
		КонецЦикла;
		
		// Сохраняем картинки слайдов и устанавливаем имена-идентификаторы слайдов
		//
		
		oFilter = ПриложениеImpress.Скрытое.ServiceManager.createInstance("com.sun.star.drawing.GraphicExportFilter");
		
		Для ИндексСлайда = 0 По КоличествоСлайдов - 1 Цикл
		
			oSlide = oDrawPages.getByIndex(ИндексСлайда);
			
			ИдентификаторСлайда = СокрЛП(oSlide.Name);
			
			oFilter.setSourceDocument(oSlide);

			ПутьККартинке = ЭлектронноеОбучениеСлужебныйКлиентСервер.ДобавитьКонечныйРазделительПути(ПутьКаталогуСКартинками); 
			ПутьККартинке = ПутьККартинке + ИдентификаторСлайда + ".png"; 
			ПутьККартинке = РазработкаЭлектронныхКурсовСлужебныйКлиент.ПутьКФайлуВФорматеOpenOffice(ПутьККартинке);
			
			ПараметрыФильтраСтруктура = Новый Структура;
			ПараметрыФильтраСтруктура.Вставить("URL", ПутьККартинке);
			ПараметрыФильтраСтруктура.Вставить("MediaType", "image/png");
			ПараметрыФильтраСтруктура.Вставить("Overwrite", 1);
			ПараметрыФильтра = РазработкаЭлектронныхКурсовСлужебныйКлиент.ПараметрыВФорматеOpenOffice(ПриложениеImpress.Скрытое, ПараметрыФильтраСтруктура);			
	
		    oFilter.filter(ПараметрыФильтра);		
			
			СтруктураСлайда = Новый Структура("Номер, Идентификатор, ИмяФайла");
			СтруктураСлайда.Номер = ИндексСлайда;
			СтруктураСлайда.Идентификатор = ИдентификаторСлайда;
			СтруктураСлайда.ИмяФайла = СтруктураСлайда.Идентификатор + ".png"; // Будет сохранено в базу
			
			НастройкиКартинок.Слайды.Добавить(СтруктураСлайда);			
			
		КонецЦикла;
		
		Doc.store();
		Doc.close(true);
		
		НастройкиКартинок = Новый ФиксированнаяСтруктура(НастройкиКартинок);

		
	КонецЕсли;	
	
	Если ОбщегоНазначенияКлиент.ЭтоLinuxКлиент() 
		ИЛИ ОбщегоНазначенияКлиент.ЭтоOSXКлиент() Тогда
	
		// Устанавливаем идентификаторы слайдов (выполняется замена файла)
		
		ИдентификаторыВсехСлайдов = РазработкаЭлектронныхКурсовСлужебныйКлиент.УстановитьИменаСлайдовВПрезентацииImpress(ПутьКФайлуПрезентацииКурса);
		
		// Создаем каталог для распаковки файла
		
		ПутьККаталогуРаспаковки = ПолучитьИмяВременногоФайла("");	
		ЭлектронноеОбучениеСлужебныйКлиентСервер.НовыйКаталог(ПутьККаталогуРаспаковки);	
		ФайлыДляУдаления.Добавить(ПутьККаталогуРаспаковки);	
		ПутьККаталогуРаспаковки = ЭлектронноеОбучениеСлужебныйКлиентСервер.ДобавитьКонечныйРазделительПути(ПутьККаталогуРаспаковки);	
		
		// Распаковываем презентацию во временный каталог
		
		ФайлАрхива = Новый ЧтениеZIPФайла(ПутьКФайлуПрезентацииКурса);
		ФайлАрхива.ИзвлечьВсе(ПутьККаталогуРаспаковки, РежимВосстановленияПутейФайловZIP.Восстанавливать); 
		ФайлАрхива.Закрыть(); 		
		
		// Получаем текстовое содержимое файла content.xml
		
		СодержимоеДокументаСтрока = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ФайлContentВСтроку(ПутьККаталогуРаспаковки);
		
		// Создаем каталог для размещения картинок
		
		ПутьКаталогуСКартинками = ПолучитьИмяВременногоФайла("");
		ЭлектронноеОбучениеСлужебныйКлиентСервер.НовыйКаталог(ПутьКаталогуСКартинками);		
		ФайлыДляУдаления.Добавить(ПутьКаталогуСКартинками);		
		ПутьКаталогуСКартинками = ЭлектронноеОбучениеСлужебныйКлиентСервер.ДобавитьКонечныйРазделительПути(ПутьКаталогуСКартинками);
		
		// Конвертируем каждый слайд
		
		НомерСлайда = 0; // Нумерация файлов картинок начинается с нуля
		
		Для каждого ИдентификаторСлайда Из ИдентификаторыВсехСлайдов Цикл
			
			// Получаем временный файл odp
			
			ПутьКВременнойПрезентации = ПолучитьИмяВременногоФайла(".odp");		
			ФайлыДляУдаления.Добавить(ПутьКВременнойПрезентации);	
			
			// Упаковываем содержимое в файл odp
			
			ФайлZIP = Новый ЗаписьZipФайла(ПутьКВременнойПрезентации);
			ФайлZIP.Добавить(ПутьККаталогуРаспаковки + "*", РежимСохраненияПутейZIP.СохранятьОтносительныеПути,  РежимОбработкиПодкаталоговZIP.ОбрабатыватьРекурсивно);
			ФайлZIP.Записать();		
			
			// Конвертируем в картинку
			
			РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ПреобразоватьПервыйСлайдImpressВКартинку(ПриложениеImpress, ПутьКВременнойПрезентации, ПутьКаталогуСКартинками, ИдентификаторСлайда);
			
			// Удаляем слайд в СодержимоеДокументаСтрока
			
			МассивСлайдовДляУдаления = Новый Массив;
			МассивСлайдовДляУдаления.Добавить(ИдентификаторСлайда);
			КоличествоУдаленных = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.УдалитьСлайдыВФайлеContentПрезентации(СодержимоеДокументаСтрока, МассивСлайдовДляУдаления);
			
			Если КоличествоУдаленных <> 1 Тогда
				ВызватьИсключение НСтр("ru = 'Ошибка удаления слайда презентации'");
			КонецЕсли;
			
			// Актуализируем содержимое файла content.xml
			
			ПутьКФайлуContent = ПутьККаталогуРаспаковки + "content.xml"; 
			ЭлектронноеОбучениеСлужебныйКлиентСервер.ЗаписатьТекстовыйФайлUTF8БезBOM(ПутьКФайлуContent, СодержимоеДокументаСтрока);				
			
			// Запоминаем слайд в настройках картинок
			
			СтруктураСлайда = Новый Структура("Номер, Идентификатор, ИмяФайла");
			СтруктураСлайда.Номер = НомерСлайда;
			СтруктураСлайда.Идентификатор = Строка(ИдентификаторСлайда);
			СтруктураСлайда.ИмяФайла = Строка(ИдентификаторСлайда) + ".png"; // Будет сохранено в базу
				
			НастройкиКартинок.Слайды.Добавить(СтруктураСлайда);	

			НомерСлайда = НомерСлайда + 1;
			
		КонецЦикла;
				
	КонецЕсли;
			
	// Сохраняем картинки и файл презентации в базу
	//
	
	СохранитьПрезентациюИКартинкиСлайдовВБазу(ПутьКФайлуПрезентацииКурса, ПутьКаталогуСКартинками, НастройкиКартинок, ФайлыДляСохранения, ФайлыДляУдаления, ИдентификаторРедактируемойСтроки, НаименованиеПрезентации, ЭлементаСодержанияДляЗаписи);
	
	РаскрытьКорень();
	
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьСлайдыИзПрезентацииOpenOfficeСлайдовогоКурса(МассивЭлементовСодержания)
	
	#Если НЕ ВебКлиент И НЕ МобильныйКлиент Тогда
	
	Если РазработкаЭлектронныхКурсовСлужебныйКлиент.ПрезентацияImpressДоступна(ПриложениеImpress) Тогда
		ВызватьИсключение НСтр("ru = 'Слайды не могут быть удалены в открытой презентации'");
	КонецЕсли;
	
	Если ТипЭлектронногоКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Учебник") Тогда
		ВызватьИсключение НСтр("ru = 'Функциональность не поддерживается в электронном учебнике'");
	КонецЕсли;	
	
	ИдентификаторыСлайдов = ИдентификаторыСлайдовПрезентацииЭлементовСодержания(МассивЭлементовСодержания);
	
	РазработкаЭлектронныхКурсовСлужебныйКлиент.ИнициализироватьПриложениеImpress(ПриложениеImpress);
	
	Если ПриложениеImpress = Неопределено ИЛИ НЕ ОбщегоНазначенияКлиент.ЭтоWindowsКлиент() Тогда
		
		// Если не установлен OpenOffice или это не Windows, то удаляем методом распаковки архива
		
		ВременныйПутьКПрезентации = ПолучитьИмяВременногоФайла("odp");
		ХранениеПрезентацииВБазе = ДанныеХраненияПрезентацииЭлектронногоКурса(ЭлектронныйКурс, УникальныйИдентификатор);
		
		ПолучитьФайл(ХранениеПрезентацииВБазе.МестоХраненияВБазе, ВременныйПутьКПрезентации, Ложь);
		
		РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.УдалитьСлайдВПрезентацииImpress(ВременныйПутьКПрезентации, ИдентификаторыСлайдов);
		
		СохранитьПрезентациюOpenOfficeВБазу(ВременныйПутьКПрезентации);

		ЭлектронноеОбучениеСлужебныйКлиентСервер.УдалитьВременныйФайл(ВременныйПутьКПрезентации);
		
	Иначе
		
		// Удаляем через COM
		
		ПриложениеImpress.ХранениеНаДиске = НовыйПутьХраненияПрезентацииOpenOffice("presentation", ПриложениеImpress);
		ПриложениеImpress.ХранениеВБазе = ДанныеХраненияПрезентацииЭлектронногоКурса(ЭлектронныйКурс, УникальныйИдентификатор);
		ПолучитьФайл(ПриложениеImpress.ХранениеВБазе.МестоХраненияВБазе, ПриложениеImpress.ХранениеНаДиске, Ложь);		
		
		ПараметрыОткрытияПрезентацииСтруктура = Новый Структура;
		ПараметрыОткрытияПрезентацииСтруктура.Вставить("MacroExecutionMode", 0);
		ПараметрыОткрытияПрезентацииСтруктура.Вставить("Hidden", Истина);
		ПараметрыОткрытияПрезентации = РазработкаЭлектронныхКурсовСлужебныйКлиент.ПараметрыВФорматеOpenOffice(ПриложениеImpress.Скрытое, ПараметрыОткрытияПрезентацииСтруктура);
		
		Doc = ПриложениеImpress.Скрытое.Desktop.loadComponentFromURL(
			РазработкаЭлектронныхКурсовСлужебныйКлиент.ПутьКФайлуВФорматеOpenOffice(ПриложениеImpress.ХранениеНаДиске),
			"_blank",
			0,
			ПараметрыОткрытияПрезентации);		
		
		oDrawPages = Doc.getDrawPages();
		
		Для каждого ИдентификаторСлайда Из ИдентификаторыСлайдов Цикл
			oSlide = oDrawPages.getByName(ИдентификаторСлайда);		
			oDrawPages.remove(oSlide)
		КонецЦикла;
		
		Doc.store();
		Doc.close(Истина);		
		
		СохранитьПрезентациюOpenOfficeВБазу(ПриложениеImpress.ХранениеНаДиске);
		
		ЗакрытьПрезентациюOpenOffice(Ложь, Ложь);
		
	КонецЕсли;
	
	#КонецЕсли
	
КонецПроцедуры

// Общее для презентаций

&НаКлиенте
Процедура СохранитьПрезентациюИКартинкиСлайдовВБазу(ПутьКФайлуПрезентацииКурса, ПутьКаталогуСКартинками, НастройкиКартинок, ФайлыДляСохранения, ФайлыДляУдаления, ИдентификаторРедактируемойСтроки, НаименованиеПрезентации, ЭлементаСодержанияДляЗаписи = Неопределено)
	
	#Если НЕ ВебКлиент И НЕ МобильныйКлиент Тогда

	ФайлПрезентацииКурса = Новый Файл(ПутьКФайлуПрезентацииКурса);
	
	// Упаковываем картинки слайдов в архив
	//	
	
	ПутьКаталогуСКартинками = ЭлектронноеОбучениеСлужебныйКлиентСервер.ДобавитьКонечныйРазделительПути(ПутьКаталогуСКартинками);
	ПутьКАрхивуZIPСКартинками = ПолучитьИмяВременногоФайла("zip");
	
	ЗаписьZip = Новый ЗаписьZipФайла(ПутьКАрхивуZIPСКартинками,,,МетодСжатияZIP.Копирование);							
	ЗаписьZip.Добавить(ПутьКаталогуСКартинками + "*", РежимСохраненияПутейZIP.СохранятьОтносительныеПути,  РежимОбработкиПодкаталоговZIP.ОбрабатыватьРекурсивно);
	ЗаписьZip.Записать();		
	
	ФайлыДляУдаления.Добавить(ПутьКАрхивуZIPСКартинками);	
	ФайлыДляСохранения.Добавить(Новый Файл(ПутьКАрхивуZIPСКартинками));
		
	// Помещаем файлы во временное хранилище
	//	
		
	ПараметрыЗагрузки = Новый Структура();	
	
	ПараметрыЗагрузки.Вставить("УникальныйИдентификатор", УникальныйИдентификатор);
	ПараметрыЗагрузки.Вставить("КонтекстФайла", "Presentation");
	ПараметрыЗагрузки.Вставить("ПереданныеФайлы", Новый Массив);	
	ПараметрыЗагрузки.Вставить("ПередаваемыеФайлы", Новый Массив);
	ПараметрыЗагрузки.Вставить("СтруктураФайлов", Новый Массив);
	ПараметрыЗагрузки.Вставить("ТекстовыеДанныеДляИндексирования", "");

	ПараметрыЗагрузки.СтруктураФайлов.Добавить(
		ЭлектронноеОбучениеСлужебныйКлиентСервер.НовоеОписаниеФайла(ФайлПрезентацииКурса, ПараметрыЗагрузки.КонтекстФайла));
	
	Для каждого ФайлДляСохранения Из ФайлыДляСохранения Цикл		
		ПараметрыЗагрузки.ПередаваемыеФайлы.Добавить(Новый ОписаниеПередаваемогоФайла(ФайлДляСохранения.ПолноеИмя));
	КонецЦикла;	
	
	РазработкаЭлектронныхКурсовСлужебныйКлиент.ПоместитьФайлыВХранилище(ПараметрыЗагрузки.ПередаваемыеФайлы, ПараметрыЗагрузки.ПереданныеФайлы, ПараметрыЗагрузки.УникальныйИдентификатор);
	
	// Помещаем файлы в базу
	//
		
	СтруктураИмениФайла = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(ПутьКФайлуПрезентацииКурса, Ложь);
	
	СвойстваФайла = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ПустаяСтруктураСвойствЗагружаемогоФайла();
			
	СвойстваФайла.Имя = "Presentation"; // Всегда одинаковое для контроля целостности ресурса
	СвойстваФайла.Расширение = СтруктураИмениФайла.Расширение;
	СвойстваФайла.ЭтоКаталог = Ложь;
	СвойстваФайла.Преобразовать = Истина;
	СвойстваФайла.СтруктураФайлов = ПараметрыЗагрузки.СтруктураФайлов;
	СвойстваФайла.СписокФайлов = ПараметрыЗагрузки.ПереданныеФайлы;
	СвойстваФайла.НастройкиКартинок = НастройкиКартинок;
	СвойстваФайла.ДанныеВидео = Неопределено;
	СвойстваФайла.КонтекстФайла = "Presentation";
	СвойстваФайла.ТекстовыеДанныеДляИндексирования = ПараметрыЗагрузки.ТекстовыеДанныеДляИндексирования;			
			
	СохранитьЭлементКурсаНаСервере(СвойстваФайла, ИдентификаторРедактируемойСтроки, НаименованиеПрезентации, ЭлементаСодержанияДляЗаписи);
	
	// Удаляем старые файлы
	//
	
	Для каждого ПутьКФайлу Из ФайлыДляУдаления Цикл		
		ЭлектронноеОбучениеСлужебныйКлиентСервер.УдалитьВременныйФайл(ПутьКФайлу);		
	КонецЦикла;
	
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ПереименоватьСлайдыПоИдентификаторам(НастройкиКартинок, ПутьКаталогуСКартинками)
	
	ПутьКаталогуСКартинками = ЭлектронноеОбучениеСлужебныйКлиентСервер.ДобавитьКонечныйРазделительПути(ПутьКаталогуСКартинками);
	
	// Переименовываем файлы картинок по идентификатору слайда
	// Например, PowerPoint сделал файл Слайд01.png, а в базу
	// будет сохранен файл 256.png, где 256 - идентификатор слайда.
	//					
	
	ФайлыКартинок = ЭлектронноеОбучениеСлужебныйКлиентСервер.ИскатьФайлы(ПутьКаталогуСКартинками, "*.png");
	
	Если ФайлыКартинок.Количество() <> НастройкиКартинок.Слайды.Количество() Тогда
		ВызватьИсключение НСтр("ru = 'Слайды презентации не найдены'");
	КонецЕсли;
	
	Для каждого ФайлКартинки Из ФайлыКартинок Цикл
		
		ИмяБезРасширения = ФайлКартинки.ИмяБезРасширения;
		ДлинаИмениКартинки = СтрДлина(ИмяБезРасширения);
		ДлинаНомераСправа = 1;
		
		Пока ДлинаНомераСправа < ДлинаИмениКартинки Цикл
			
			НомерКартинкиСправа = Прав(ИмяБезРасширения, ДлинаНомераСправа);
			Если НЕ ЭлектронноеОбучениеСлужебныйКлиентСервер.ЭтоЧисло(НомерКартинкиСправа) Тогда
				ДлинаНомераСправа = ДлинаНомераСправа - 1; // Возвращаемся на шаг назад
				Прервать;
			КонецЕсли;
			
			ДлинаНомераСправа = ДлинаНомераСправа + 1;
			
		КонецЦикла;
		
		НомерКартинкиСправа = Число(Прав(ИмяБезРасширения, ДлинаНомераСправа));
		
		ИмяФайлаСлайда = "";
		Для каждого СтруктураСлайда Из НастройкиКартинок.Слайды Цикл
			
			Если СтруктураСлайда.Номер = НомерКартинкиСправа Тогда
				ИмяФайлаСлайда = СтруктураСлайда.ИмяФайла;
				Прервать;
			КонецЕсли;
		
		КонецЦикла;

		Если НЕ ЗначениеЗаполнено(ИмяФайлаСлайда) Тогда
			ВызватьИсключение НСтр("ru = 'Слайд в презентации не найден'");
		КонецЕсли;
		
		ЭлектронноеОбучениеСлужебныйКлиентСервер.СкопироватьФайл(
			ФайлКартинки.ПолноеИмя, ПутьКаталогуСКартинками + ИмяФайлаСлайда);
			
		ЭлектронноеОбучениеСлужебныйКлиентСервер.УдалитьВременныйФайл(ФайлКартинки.ПолноеИмя);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДанныеХраненияПрезентацииЭлектронногоКурса(ЭлектронныйКурс, ИдентификаторФормы)	
	
	Если ТипЗнч(ЭлектронныйКурс) = Тип("СправочникСсылка.ЭлектронныеКурсы")
		И ЗначениеЗаполнено(ЭлектронныйКурс) Тогда
		
		Ресурс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлектронныйКурс, "Презентация");
		
		Если НЕ ЗначениеЗаполнено(Ресурс) Тогда
			Возврат Неопределено; // Еще нет презентации
		КонецЕсли;
		
		Возврат ДанныеХраненияПрезентации(Ресурс, ИдентификаторФормы);
		
	Иначе		
		
		Возврат Неопределено; // Еще нет презентации		
		
	КонецЕсли;			
		
КонецФункции

&НаСервереБезКонтекста
Функция ДанныеХраненияПрезентацииТеории(Теория, ИдентификаторФормы)	
	
	Если ТипЗнч(Теория) = Тип("СправочникСсылка.ТеорияЭлектронныхКурсов")
		И ЗначениеЗаполнено(Теория) Тогда
		
		Ресурс = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Теория, "Презентация");
		
		Если НЕ ЗначениеЗаполнено(Ресурс) Тогда
			Возврат Неопределено; // Еще нет презентации
		КонецЕсли;
		
		Возврат ДанныеХраненияПрезентации(Ресурс, ИдентификаторФормы);
		
	Иначе		
		
		Возврат Неопределено; // Еще нет презентации		
		
	КонецЕсли;			
		
КонецФункции

&НаСервереБезКонтекста
Функция ДанныеХраненияПрезентации(РесурсСПрезентацией, ИдентификаторФормы)	
		
	ЭлементРесурса = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(РесурсСПрезентацией, "ЕдинственныйЭлемент");
	
	Если НЕ ЗначениеЗаполнено(ЭлементРесурса) Тогда
		ВызватьИсключение НСтр("ru = 'Элемент ресурса с презентацией не найден'");
	КонецЕсли;
	
	МестоХраненияПрезентацииВБазе = Справочники.ЭлементыЭлектронныхРесурсов.ДанныеЭлементаДляРедактирования(ЭлементРесурса, Перечисления.ТипыЭлементовЭлектронныхРесурсов.Presentation, ИдентификаторФормы);
	
	Если НЕ ЗначениеЗаполнено(МестоХраненияПрезентацииВБазе) Тогда
		ВызватьИсключение НСтр("ru = 'Место хранения документа не определено'");
	КонецЕсли;	
	
	ДанныеЭлемента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЭлементРесурса, "Наименование, ИмяФайла");
	
	ДанныеЭлемента.Вставить("СсылкаНаЭлементСПрезентацией", ЭлементРесурса);
	ДанныеЭлемента.Вставить("МестоХраненияВБазе", МестоХраненияПрезентацииВБазе);
	ДанныеЭлемента.Вставить("Ресурс", РесурсСПрезентацией);

	Возврат Новый ФиксированнаяСтруктура(ДанныеЭлемента);
	
КонецФункции

&НаСервереБезКонтекста
Функция ИдентификаторыСлайдовПрезентацииЭлементовСодержания(Знач МассивЭлементовСодержания)	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СодержаниеЭлектронныхКурсов.ПараметрыЗапуска КАК ПараметрыЗапуска
		|ИЗ
		|	Справочник.СодержаниеЭлектронныхКурсов КАК СодержаниеЭлектронныхКурсов
		|ГДЕ
		|	СодержаниеЭлектронныхКурсов.Ссылка В(&МассивЭлементовСодержания)";
	
	Запрос.УстановитьПараметр("МассивЭлементовСодержания", МассивЭлементовСодержания);
	
	МассивИменФайлов = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ПараметрыЗапуска");
	
	МассивИдентификаторов = Новый Массив;
	Для каждого ИмяФайла Из МассивИменФайлов Цикл
		МассивИдентификаторов.Добавить(ИмяФайлаСлайдаПрезентацииВИдентификатор(ИмяФайла));
	КонецЦикла;
	
	Возврат МассивИдентификаторов;
	
КонецФункции

&НаСервереБезКонтекста
Функция ИмяФайлаСлайдаПрезентацииВИдентификатор(Знач ИмяФайлаСлайда)
	
	Идентификатор = Лев(ИмяФайлаСлайда, СтрДлина(ИмяФайлаСлайда) - СтрДлина(".png"));
	Если СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке(Идентификатор) Тогда		
		Идентификатор = СтроковыеФункцииКлиентСервер.СтрокаВЧисло(Идентификатор);
	КонецЕсли;
	
	Возврат Идентификатор;
	
КонецФункции

#КонецОбласти

#Область ВидеоИАудио

// Загрузка

&НаКлиенте
Процедура ЗагрузитьИнтерактивноФайлВидеоВБазу()
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ЗагрузитьИнтерактивноФайлВидеоВБазуПослеВыбораСпособаРазмещения", ЭтотОбъект);
	ОткрытьФорму("Справочник.ЭлементыЭлектронныхРесурсов.Форма.ВыборСпособаРазмещенияВидео",,ЭтотОбъект,,,,ОписаниеОповещения);
			
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьИнтерактивноФайлВидеоВБазуПослеВыбораСпособаРазмещения(РезультатВыбора, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если РезультатВыбора = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если РезультатВыбора.Тип = "ВидеоYouTube" Тогда
		СвойстваФайла = СвойстваФайлаВидеоYouTube(РезультатВыбора.ИдентификаторВидео);
		НоваяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());
		НоваяСтрока.Наименование = НСтр("ru = 'Видео с YouTube'");
		НоваяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.YouTube");
		СохранитьЭлементКурса(СвойстваФайла, Истина); // Вызов сервера и выход из режима редактирования
	КонецЕсли;
	
	Если РезультатВыбора.Тип = "ВидеоИзИнтернета" Тогда
		СвойстваФайла = СвойстваФайлаВидеоИзИнтернета(РезультатВыбора.ГиперссылкаНаВидео, РезультатВыбора.ФорматВидео);
		НоваяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());
		НоваяСтрока.Наименование = НСтр("ru = 'Видео из интернета'");
		НоваяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Видео");
		СохранитьЭлементКурса(СвойстваФайла, Истина); // Вызов сервера и выход из режима редактирования	
	КонецЕсли;
	
	Если РезультатВыбора.Тип = "ВыбранныеФайлы" Тогда
		СоздатьВидеоИлиАудиоПродолжениеПослеВыбораФайла(РезультатВыбора.ВыбранныеФайлы);
	КонецЕсли;
	
	Если РезультатВыбора.Тип = "ПомещенныеФайлы" Тогда
		СоздатьВидеоИлиАудиоТолькоЗагрузкойПродолжение(РезультатВыбора.Результат, РезультатВыбора.Адрес, РезультатВыбора.ВыбранноеИмяФайла);
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьИнтерактивноФайлАудиоВБазу()
	
	#Если ВебКлиент ИЛИ МобильныйКлиент Тогда
		
	ОписаниеОповещения = Новый ОписаниеОповещения("СоздатьВидеоИлиАудиоТолькоЗагрузкойПродолжение", ЭтотОбъект);
	НачатьПомещениеФайла(ОписаниеОповещения,,, Истина, УникальныйИдентификатор);
		
	#Иначе		
	
	ОписаниеОповещения = Новый ОписаниеОповещения("СоздатьВидеоИлиАудиоПродолжениеПослеВыбораФайла", ЭтотОбъект);
	
	МассивТиповВыбора = Новый Массив;
	МассивТиповВыбора.Добавить(ПредопределенноеЗначение("Перечисление.ТипыЭлементовЭлектронныхРесурсов.Audio"));	
	
	ДиалогВыбораВидео = РазработкаЭлектронныхКурсовСлужебныйКлиент.ДиалогВыбораФайлаПоТипу(
		МассивТиповВыбора,
		НСтр("ru = 'Выберите файл с аудио'"),
		НСтр("ru = 'Звук'"));
	
	ДиалогВыбораВидео.Показать(ОписаниеОповещения);
	
	#КонецЕсли
		
КонецПроцедуры

&НаКлиенте
Процедура СоздатьВидеоИлиАудиоТолькоЗагрузкойПродолжение(Результат, Адрес, ВыбранноеИмяФайла, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если НЕ Результат ИЛИ НЕ ЗначениеЗаполнено(ВыбранноеИмяФайла) Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураФайла = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(ВыбранноеИмяФайла);
	
	УстановитьСвойстваНовогоЭлементаСодержанияСВидео(СтруктураФайла.Расширение);	
	
	СписокРазмещенныхФайлов = Новый Массив; // Список файлов с описанием места их хранения во временном хранилище.				
	КонтекстФайла = Неопределено; // Метка, позволяющая при записи файла в базу установить доп. свойства	
	
	СтруктураФайлов = Новый Массив;
	СтруктураФайлов.Добавить(ЭлектронноеОбучениеСлужебныйКлиентСервер.НовоеОписаниеФайла(СтруктураФайла, КонтекстФайла));
	
	СписокРазмещенныхФайлов = Новый Массив;
	СписокРазмещенныхФайлов.Добавить(Новый ОписаниеПередаваемогоФайла(ВыбранноеИмяФайла, Адрес));
	
	СвойстваФайла = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ПустаяСтруктураСвойствЗагружаемогоФайла();
	СвойстваФайла.Имя = СтруктураФайла.ИмяБезРасширения;
	СвойстваФайла.Расширение = СтруктураФайла.Расширение;
	СвойстваФайла.ЭтоКаталог = Ложь;
	СвойстваФайла.Преобразовать = Ложь;
	СвойстваФайла.СтруктураФайлов = СтруктураФайлов;
	СвойстваФайла.СписокФайлов = СписокРазмещенныхФайлов;
	СвойстваФайла.НастройкиКартинок = Неопределено;
	СвойстваФайла.ДанныеВидео = Неопределено;
	СвойстваФайла.КонтекстФайла = КонтекстФайла;
	СвойстваФайла.ТекстовыеДанныеДляИндексирования = Неопределено;
		
	СохранитьЭлементКурса(СвойстваФайла,,,СвойстваФайла.Имя); // Вызов сервера
	
	СоздатьВидеоИлиАудиоОкончание();
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьВидеоИлиАудиоПродолжениеПослеВыбораФайла(ВыбранныеФайлы, ДополнительныеПараметры = Неопределено) Экспорт
	
	// Делаем проверки
	
	Если ВыбранныеФайлы = Неопределено ИЛИ ВыбранныеФайлы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// Создаем новую строку дерева
	
	ФайлДляЗагрузки = Новый Файл(ВыбранныеФайлы[0]);
	
	УстановитьСвойстваНовогоЭлементаСодержанияСВидео(ФайлДляЗагрузки.Расширение);	
		
	НоваяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());		
	
	Состояние(НСтр("ru = 'Пожалуйста, подождите, выполняется передача файла видео на сервер...'"));
	
	СвойстваФайла = ПодготовитьВидеоИлиАудиоДляЗагрузкиВБазу(ФайлДляЗагрузки);
	
	ПропуститьАктивациюЭлементаСодержания = Истина; // Так как поменяется дерево
	
	СохранитьЭлементКурса(СвойстваФайла,,,СвойстваФайла.Имя); // Вызов сервера
	
	Если СвойстваФайла.Свойство("ДанныеЗаписанногоЭлементаРесурса")	
		И ЗначениеЗаполнено(СвойстваФайла.ДанныеЗаписанногоЭлементаРесурса.Ссылка)	Тогда	
		ЗаписанныйВБазуФайлВидео = СвойстваФайла.ДанныеЗаписанногоЭлементаРесурса.Ссылка;
	Иначе		
		ВызватьИсключение НСтр("ru = 'Файл видео не записан в базу'");		
	КонецЕсли;	
	
	Если НоваяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Видео") 
		И НЕ РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлВидеоПоддерживаемогоФормата(ФайлДляЗагрузки.Расширение) Тогда
		
		ОписаниеОповещения = Новый ОписаниеОповещения("СоздатьВидеоИлиАудиоОкончание", ЭтотОбъект, НоваяСтрока.Ссылка);
		
		ОткрытьФорму("Справочник.ЭлементыЭлектронныхРесурсов.Форма.КонвертерВидео",
			Новый Структура("ЭлементРесурса, Автозапуск", ЗаписанныйВБазуФайлВидео, Истина),
			ЭтотОбъект,,,,ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
	Иначе
		
		СоздатьВидеоИлиАудиоОкончание();
		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСвойстваНовогоЭлементаСодержанияСВидео(РасширениеНовогоФайла)
	
	ТипФайла = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ТипЭлементаРесурсаПоРасширению(РасширениеНовогоФайла);
	
	Если ТипФайла <> ПредопределенноеЗначение("Перечисление.ТипыЭлементовЭлектронныхРесурсов.Video")
		И ТипФайла <> ПредопределенноеЗначение("Перечисление.ТипыЭлементовЭлектронныхРесурсов.Audio") Тогда
		
		ВызватьИсключение НСтр("ru = 'Неизвестный тип файла'");
		
	КонецЕсли;	
	
	НоваяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());	
	
	Если ТипФайла = ПредопределенноеЗначение("Перечисление.ТипыЭлементовЭлектронныхРесурсов.Video") Тогда
		НоваяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Видео");
	Иначе
		НоваяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Звук");
	КонецЕсли;	
	
	Если НоваяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Видео") Тогда	
		НоваяСтрока.Наименование = НСтр("ru = 'Видео'");
	Иначе
		НоваяСтрока.Наименование = НСтр("ru = 'Звук'");
	КонецЕсли;		
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьВидеоИлиАудиоОкончание(РезультатЗакрытия = Неопределено, ДополнительныеПараметры = Неопределено) Экспорт	
	
	ВыйтиИзРежимаРедактирования(Ложь);	
		
КонецПроцедуры

// Обновление

&НаКлиенте
Процедура ОбновитьИнтерактивноФайлВидеоИлиАудиоВБазе()
	
	ТекстСообщения = НСтр("ru = 'Для загрузки файлов рекомендуется установить расширение для веб-клиента 1С:Предприятие.'");
	Обработчик = Новый ОписаниеОповещения("ОбновитьИнтерактивноФайлВидеоИлиАудиоВБазеПродолжение", ЭтотОбъект);
	ФайловаяСистемаКлиент.ПодключитьРасширениеДляРаботыСФайлами(Обработчик, ТекстСообщения, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьИнтерактивноФайлВидеоИлиАудиоВБазеПродолжение(РасширениеПодключено, ДополнительныеПараметры) Экспорт
	
	РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());
	Если РедактируемаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;	
	
	Если РасширениеПодключено Тогда
		
		ОповещениеЗавершения = Новый ОписаниеОповещения("ОбновитьИнтерактивноФайлВидеоИлиАудиоЗавершение", ЭтотОбъект, ДополнительныеПараметры);	
		
		МассивТиповВыбора = Новый Массив;
		Если РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Видео") Тогда
			МассивТиповВыбора.Добавить(ПредопределенноеЗначение("Перечисление.ТипыЭлементовЭлектронныхРесурсов.Video"));
			ЗаголовокТипаФайла = НСтр("ru = 'Видео'");
		ИначеЕсли РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Звук") Тогда
			МассивТиповВыбора.Добавить(ПредопределенноеЗначение("Перечисление.ТипыЭлементовЭлектронныхРесурсов.Audio"));
			ЗаголовокТипаФайла = НСтр("ru = 'Звук'");
		Иначе
			ВызватьИсключение НСтр("ru = 'Неизвестный тип элемента содержания'");
		КонецЕсли;
	
		ДиалогВыбораФайлов = РазработкаЭлектронныхКурсовСлужебныйКлиент.ДиалогВыбораФайлаПоТипу(
			МассивТиповВыбора,
			НСтр("ru = 'Выберите файл для обновления'"),
			ЗаголовокТипаФайла);		
				
		ДиалогВыбораФайлов.Показать(ОповещениеЗавершения);		
		
	Иначе
		
		ОповещениеФайла = Новый ОписаниеОповещения("ОбновитьИнтерактивноФайлВидеоИлиАудиоВебКлиентЗавершение", ЭтотОбъект, ДополнительныеПараметры);
		НачатьПомещениеФайла(ОповещениеФайла);
		
	КонецЕсли;	
		
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьИнтерактивноФайлВидеоИлиАудиоВебКлиентЗавершение(Результат, Адрес, ВыбранноеИмяФайла, ДополнительныеПараметры) Экспорт
	
