#КонецОбласти

#Область Тесты

&НаСервере
Процедура УстановитьМаксимальноеКоличествоВопросовВНастройкеТеста(ЭлектронныйТест)
	
	Если ЗначениеЗаполнено(ЭлектронныйТест) Тогда
		Элементы.НастройкиТестаКоличествоВопросов.МаксимальноеЗначение = Справочники.СтраницыЭлементовЭлектронныхКурсов.СтраницыВладельца(ЭлектронныйТест).Количество();
	Иначе
		Элементы.НастройкиТестаКоличествоВопросов.МаксимальноеЗначение = 0;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьДоступностьНастроекТестирования(Форма)
	
	КоличествоВопросовВТесте = КоличествоВопросовВТекущемТесте(Форма);
	
	// Количество вопросов
	
	Если КоличествоВопросовВТесте < 2 Тогда
		Форма.НастройкиТестаКоличествоВопросов = 0;
	КонецЕсли;
		
	Форма.НастройкиТестаКоличествоВопросовУстановлено = ?(Форма.НастройкиТестаКоличествоВопросов > 0, 1, 0);
	
	Форма.Элементы.НастройкиТестаКоличествоВопросовУстановлено.Доступность = (КоличествоВопросовВТесте > 1);
	Форма.Элементы.НастройкиТестаКоличествоВопросов.Доступность = (Форма.НастройкиТестаКоличествоВопросовУстановлено = 1);	
		
	// Вопросы в случайном порядке
	
	МожноВыводитьВопросыВСлучайномПорядке = (КоличествоВопросовВТесте > 1 И Форма.НастройкиТестаКоличествоВопросов <> 1);
	Если НЕ МожноВыводитьВопросыВСлучайномПорядке Тогда
		Форма.НастройкиТестаПеремешиватьВопросы = Ложь;
	КонецЕсли;	
	
	Форма.Элементы.НастройкиТестаПеремешиватьВопросы.Доступность = ?(МожноВыводитьВопросыВСлучайномПорядке, Истина, Ложь);
	
	// Общее время тестирования
	
	Форма.НастройкиТестаВремяТестаУстановлено = (Форма.НастройкиТестаВремяТеста > 0);	
	Форма.Элементы.НастройкиТестаВремяТеста.Доступность = (Форма.НастройкиТестаВремяТестаУстановлено);		
	
	// Количество попыток
	
	Форма.НастройкиТестаКоличествоПопытокУстановлено = (Форма.НастройкиТестаКоличествоПопыток > 0);	
	Форма.Элементы.НастройкиТестаКоличествоПопыток.Доступность = (Форма.НастройкиТестаКоличествоПопытокУстановлено);
	
	// Разрешить исправлять ошибки
	
	Если Форма.НастройкиТестаРазрешитьИсправлятьОшибки Тогда
		Форма.НастройкиТестаПоказыватьРезультатОтвета = Истина;
		Форма.Элементы.НастройкиТестаПоказыватьРезультатОтвета.Доступность = Ложь;
	Иначе
		Форма.Элементы.НастройкиТестаПоказыватьРезультатОтвета.Доступность = Истина;
	КонецЕсли;
	
	// Показывать правильные ответы
	
	Если Форма.НастройкиТестаПоказыватьПравильныеОтветы Тогда
		Форма.НастройкиТестаПоказыватьСтатистику = Истина;
		Форма.Элементы.НастройкиТестаПоказыватьСтатистику.Доступность = Ложь;
	Иначе
		Форма.Элементы.НастройкиТестаПоказыватьСтатистику.Доступность = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьНастройкиТеста()
	РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНавигационногоДерева);
	Если РедактируемаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	УстановитьМаксимальноеКоличествоВопросовВНастройкеТеста(РедактируемаяСтрока.СсылкаНаЭлемент);
	УстановитьДоступностьНастроекТестирования(ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьНовыйТестИзФайлаExcel(ПользовательскийФайлСТестом, ИдентификаторРодительскойСтроки = Неопределено, ЭлементаСодержанияДляЗаписи = Неопределено)
	
	#Если НЕ ВебКлиент И НЕ МобильныйКлиент Тогда
		
	ДополнительныеПараметры = Новый Структура("ИдентификаторРодительскойСтроки, ЭлементаСодержанияДляЗаписи", ИдентификаторРодительскойСтроки, ЭлементаСодержанияДляЗаписи);
	ОписаниеОповещения = Новый ОписаниеОповещения("ДобавитьНовыйТестИзФайлаExcelПродолжение", ЭтотОбъект, ДополнительныеПараметры);
	НачатьПомещениеФайла(ОписаниеОповещения,, ПользовательскийФайлСТестом.ПолноеИмя, Ложь, УникальныйИдентификатор);	
	
	#КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьНовыйТестИзФайлаExcelПродолжение(Результат, Адрес, ВыбранноеИмяФайла, ДополнительныеПараметры) Экспорт
	
	Если НЕ Результат Тогда
		Возврат;
	КонецЕсли;
	
	НоваяСтрока = НовыйЭлементСодержания(ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Тест"), ДополнительныеПараметры.ИдентификаторРодительскойСтроки);
	
	ЭлементаСодержанияДляЗаписи = Неопределено;
	Если ДополнительныеПараметры.Свойство("ЭлементаСодержанияДляЗаписи") Тогда
		ЭлементаСодержанияДляЗаписи = ДополнительныеПараметры.ЭлементаСодержанияДляЗаписи;
	КонецЕсли;
	ДобавитьНовыйТестИзФайлаExcelПродолжениеНаСервере(Адрес, ВыбранноеИмяФайла, НоваяСтрока.ПолучитьИдентификатор(), ЭлементаСодержанияДляЗаписи);
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьНовыйТестИзФайлаExcelПродолжениеНаСервере(ХранениеФайлаВХранилище, ИмяФайла, ИдентификаторРедактируемойСтроки, ЭлементаСодержанияДляЗаписи = Неопределено) Экспорт
	
	// Получаем табличный документ с данными теста
	
	СтруктураФайла = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(ИмяФайла);
	ПутьКВременномуФайлуТаблицы = ПолучитьИмяВременногоФайла(СтруктураФайла.Расширение);	
	ДвоичныеДанныеФайла = ПолучитьИзВременногоХранилища(ХранениеФайлаВХранилище);	
	ДвоичныеДанныеФайла.Записать(ПутьКВременномуФайлуТаблицы);
	
	ТабличныйДокументСДанными = Новый ТабличныйДокумент;
	ТабличныйДокументСДанными.Прочитать(ПутьКВременномуФайлуТаблицы, СпособЧтенияЗначенийТабличногоДокумента.Текст);	
	
	ТаблицаРисунков = Новый ТаблицаЗначений;
	ТаблицаРисунков.Колонки.Добавить("Картинка");
	ТаблицаРисунков.Колонки.Добавить("НомерСтроки");
	ТаблицаРисунков.Колонки.Добавить("НомерКолонки");
	ТаблицаРисунков.Колонки.Добавить("ИмяКолонки");
	
	Для каждого РисунокДокумента Из ТабличныйДокументСДанными.Рисунки Цикл
		
		Если ТипЗнч(РисунокДокумента.Картинка) <> Тип("Картинка") Тогда
			ВызватьИсключение НСтр("ru = 'Файл содержит картинку неизвестного формата'");
		КонецЕсли;
		
		НоваяСтрока = ТаблицаРисунков.Добавить();
		НоваяСтрока.Картинка = РисунокДокумента.Картинка;		
		
		// Ищем номер колонки картинки
		
		НомерКолонки = 0;
		ШиринаКолонок = 0;
		Пока ШиринаКолонок < РисунокДокумента.Лево Цикл
			НомерКолонки = НомерКолонки + 1;
			ШиринаКолонок = ШиринаКолонок + (ТабличныйДокументСДанными.Область(1,НомерКолонки).ШиринаКолонки*(100/54.25));
			Если НомерКолонки > 1000 Тогда
				ВызватьИсключение НСтр("ru = 'Ошибка при поиске колонки картинки'");
			КонецЕсли;
			Если НомерКолонки > ТабличныйДокументСДанными.ШиринаТаблицы Тогда
				ВызватьИсключение НСтр("ru = 'Положение картинки выходит за границы обрабатываемых колонок'");
			КонецЕсли;
		КонецЦикла;
		
		НоваяСтрока.НомерКолонки = НомерКолонки;
		НоваяСтрока.ИмяКолонки = ТабличныйДокументСДанными.Область(1,НомерКолонки).Текст;
		
		// Ищем номер строки картинки
		
		НомерСтроки = 0;
		ВысотаСтроки = 0;
		Пока ВысотаСтроки < РисунокДокумента.Верх Цикл
			НомерСтроки = НомерСтроки + 1;
			ВысотаСтроки = ВысотаСтроки + (ТабличныйДокументСДанными.Область(НомерСтроки,1).ВысотаСтроки*(350/993));
			Если НомерСтроки > 10000 Тогда
				ВызватьИсключение НСтр("ru = 'Ошибка при поиске строки картинки'");
			КонецЕсли;
			Если НомерСтроки > ТабличныйДокументСДанными.ВысотаТаблицы Тогда
				ВызватьИсключение НСтр("ru = 'Положение картинки выходит за границы обрабатываемых строк'");
			КонецЕсли;
		КонецЦикла;
		
		НоваяСтрока.НомерСтроки = НомерСтроки;		
		
	КонецЦикла;
	
	ЭлектронноеОбучениеСлужебныйКлиентСервер.УдалитьВременныйФайл(ПутьКВременномуФайлуТаблицы);
	
	// Преобразуем табличный документ в таблицу значений
	
	Построитель = Новый ПостроительЗапроса;
    Построитель.ИсточникДанных = Новый ОписаниеИсточникаДанных(ТабличныйДокументСДанными.Область());
	Попытка
		Построитель.Выполнить();
    	ТаблицаСДаннымиТеста = Построитель.Результат.Выгрузить();
	Исключение
		ВызватьИсключение НСтр("ru = 'Ошибка чтения теста из файла Excel.
		|Возможно,  макет таблицы не соответствует поддерживаемому формату.'");
	КонецПопытки;
	
	
	// Делаем проверки макета (кроме колонки "ВариантОтвета", см. ниже)
	
    ОбязательныеКолонки = Новый Массив;
    ОбязательныеКолонки.Добавить("Код");
    ОбязательныеКолонки.Добавить("Задание");    
    ОбязательныеКолонки.Добавить("ВерныйВариант");
	
	Для каждого ИмяОбязательнойКолонки Из ОбязательныеКолонки Цикл

		КолонкаНайдена = Ложь;

		Для каждого КолонкаТаблицыСДанными Из ТаблицаСДаннымиТеста.Колонки Цикл
			Если КолонкаТаблицыСДанными.Имя = ИмяОбязательнойКолонки Тогда
				КолонкаНайдена = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;

		Если НЕ КолонкаНайдена Тогда
			ТекстИсключения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Обязательная колонка ""%1"" макета теста не найдена в файле ""%2""'"), ИмяОбязательнойКолонки, ИмяФайла);
			ВызватьИсключение ТекстИсключения;
		КонецЕсли;
		
	КонецЦикла;
	
	// Находим имена колонок с вариантами ответов
	
	КолонкиВариантовОтветов = Новый Массив;
	
	Для каждого КолонкаТаблицыСДанными Из ТаблицаСДаннымиТеста.Колонки Цикл
		Если Лев(КолонкаТаблицыСДанными.Имя, СтрДлина("ВариантОтвета")) = "ВариантОтвета" Тогда
			Если КолонкаТаблицыСДанными.Имя = "ВариантОтвета" Тогда
				ТекстИсключения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'В файле ""%1"" колонка ""ВариантОтвета"" не имеет номера'"), ИмяФайла);
				ВызватьИсключение ТекстИсключения;				
			КонецЕсли;
			КолонкиВариантовОтветов.Добавить(КолонкаТаблицыСДанными.Имя);
		КонецЕсли;
	КонецЦикла;
	
	Если КолонкиВариантовОтветов.Количество() = 0 Тогда
		ТекстИсключения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'В файле ""%1"" не найдено ни одной колонки ""ВариантОтвета<N>""'"), ИмяФайла);
		ВызватьИсключение ТекстИсключения;		
	КонецЕсли;
	
	// Записываем тест и вопросы
	
	НачатьТранзакцию();
    
    Попытка
		
		// Создаем тест
		
		СохранитьЭлементКурсаНаСервере(Неопределено, ИдентификаторРедактируемойСтроки, СтруктураФайла.ИмяБезРасширения, ЭлементаСодержанияДляЗаписи);	
		РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтроки);
		ЭлектронныйТест = РедактируемаяСтрока.СсылкаНаЭлемент;
		
		// Записываем вопросы
		
		Для каждого СвойствоВопроса Из ТаблицаСДаннымиТеста Цикл
			
			Если НЕ ЗначениеЗаполнено(СвойствоВопроса.Задание)
				ИЛИ НЕ ЗначениеЗаполнено(СвойствоВопроса.Код) Тогда
				
				Продолжить;
				
			КонецЕсли;
			
			НомерСтрокиВопросаВФайле = ТаблицаСДаннымиТеста.Индекс(СвойствоВопроса)+2;
			
    		// Создаем вопрос
    		
    		ВопросОбъект = Справочники.ТестовыеВопросы.СоздатьЭлемент();
    		ВопросОбъект.Наименование = СвойствоВопроса.Задание;
    		ВопросОбъект.Родитель = Справочники.ЭлектронныеКурсы.ГруппаДляХраненияПодчиненныхЭлементов(ЭлектронныйКурс, Тип("СправочникСсылка.ТестовыеВопросы"));
	   		РазработкаЭлектронныхКурсовСлужебный.УстановитьПредпочитаемогоПоставщика(ВопросОбъект);
    		
    		ВопросОбъект.Код = СвойствоВопроса.Код;
			
			КартинкаЗаданияСтрока = ТаблицаРисунков.НайтиСтроки(Новый Структура("НомерСтроки, ИмяКолонки", НомерСтрокиВопросаВФайле, "Задание"));			
			
			ВложенияФД = Новый Структура;
			ТекстФД = "<div>" + СвойствоВопроса.Задание + "</div>";			
			
			НомерКартинки = 1;
			Для каждого Строка Из КартинкаЗаданияСтрока Цикл			
				НомерКартинки = НомерКартинки + 1;
				ИмяКартинки = "image" + Строка(НомерКартинки);
				ТекстФД = ТекстФД + "<div><img src="""+ ИмяКартинки +"""/></div>";
				ВложенияФД.Вставить(ИмяКартинки, Строка.Картинка);
			КонецЦикла;
			
			ЗаданиеФорматированныйДокумент = Новый ФорматированныйДокумент;
    		ЗаданиеФорматированныйДокумент.УстановитьHTML(ТекстФД, ВложенияФД);
			
    		ВопросОбъект.Задание = Новый ХранилищеЗначения(ЗаданиеФорматированныйДокумент);
    		
    		МассивВерныхВариантов = СтрРазделить(СвойствоВопроса.ВерныйВариант, ",", Ложь);
    		
    		Если МассивВерныхВариантов.Количество() = 1 Тогда
    			ВопросОбъект.ТипВопроса = Перечисления.ТипыТестовыхВопросов.ОдинИзМногих;
    		ИначеЕсли МассивВерныхВариантов.Количество() > 1 Тогда
    			ВопросОбъект.ТипВопроса = Перечисления.ТипыТестовыхВопросов.МногиеИзМногих;
    		Иначе
    			ВопросОбъект.ТипВопроса = Перечисления.ТипыТестовыхВопросов.Последовательность;
    		КонецЕсли;
			
			ВопросОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
    		ВопросОбъект.Записать();
    		
    		// Создаем варианты ответов
    		
    		НомерВарианта = 1;
			Для каждого ИмяКолонкиВарианта Из КолонкиВариантовОтветов Цикл
				
				ТекстВариантаОтвета = СвойствоВопроса[ИмяКолонкиВарианта];				
    			
    			Если ЗначениеЗаполнено(ТекстВариантаОтвета) Тогда
    			
    				ВариантОтветаОбъект = Справочники.ВариантыОтветовНаТестовыеВопросы.СоздатьЭлемент();
    				ВариантОтветаОбъект.Владелец = ВопросОбъект.Ссылка;
    				ВариантОтветаОбъект.Наименование = ТекстВариантаОтвета;
    				ВариантОтветаОбъект.ТекстВарианта = Новый ХранилищеЗначения(ТекстВариантаОтвета);				
    				
    				РазработкаЭлектронныхКурсовСлужебный.УстановитьПредпочитаемогоПоставщика(ВариантОтветаОбъект);

    				НомерВариантаСтрока = ЭлектронноеОбучениеСлужебныйКлиентСервер.ЧислоВСтроку(НомерВарианта);
    				
    				Если МассивВерныхВариантов.Найти(НомерВариантаСтрока) <> Неопределено Тогда
    					ВариантОтветаОбъект.Верный = Истина;
    				КонецЕсли;
					
					КартинкиВарианта = ТаблицаРисунков.НайтиСтроки(Новый Структура("НомерСтроки, ИмяКолонки", НомерСтрокиВопросаВФайле, ИмяКолонкиВарианта));
					
					Если КартинкиВарианта.Количество() > 1 Тогда
						ВызватьИсключение НСтр("ru = 'Для каждого варианта ответа должно быть не более одной картинки'");
					КонецЕсли;
					
					Если КартинкиВарианта.Количество() = 1 Тогда
						ВариантОтветаОбъект.Картинка = Новый ХранилищеЗначения(КартинкиВарианта[0].Картинка.ПолучитьДвоичныеДанные());
					КонецЕсли;
					
					ВариантОтветаОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
    				ВариантОтветаОбъект.Записать();
    				
    			КонецЕсли;
    				
    			НомерВарианта = НомерВарианта + 1;
    			
    		КонецЦикла;
    		
    		// Помещаем вопрос в тест
    		
    		СоздатьСтраницуТеории(ЭлектронныйТест, ВопросОбъект.Ссылка, Неопределено);			
		
		КонецЦикла;
		
		// Завершаем
		
	  	ЗафиксироватьТранзакцию();
		
    Исключение
 
 		ОтменитьТранзакцию();
    	ЭлектронноеОбучениеСлужебный.ЗаписатьОшибкуВЖурналРегистрации(ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
    	ВызватьИсключение;
    	
    КонецПопытки;	
	
КонецПроцедуры

&НаСервере
Функция АдресХраненияШаблонаТестаВФорматеExcel()	
	ДвоичныеДанные = Справочники.ЭлектронныеТесты.ПолучитьМакет(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		"ШаблонТестаВExcel_%1", ОбщегоНазначения.КодОсновногоЯзыка()));	
	Возврат ПоместитьВоВременноеХранилище(ДвоичныеДанные, УникальныйИдентификатор);
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция КоличествоВопросовВТекущемТесте(Форма)
	Возврат Форма.Элементы.НастройкиТестаКоличествоВопросов.МаксимальноеЗначение;
КонецФункции


#КонецОбласти

#Область Глоссарий

&НаКлиенте
Процедура ОткрытьТермин(Термин)	
	ПараметрыФормы = Новый Структура("Ключ", Термин);
	ОписаниеОповещения = Новый ОписаниеОповещения("ПослеЗакрытияФормыТерминаГлоссария", ЭтотОбъект, Термин);
	ОткрытьФорму("Справочник.ТерминыЭлектронныхГлоссариев.ФормаОбъекта", ПараметрыФормы, Элементы.ТерминыГлоссария,,,,ОписаниеОповещения);	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьНовыйТермин()	
	ОткрытьФорму("Справочник.ТерминыЭлектронныхГлоссариев.ФормаОбъекта",,Элементы.ТерминыГлоссария);
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗакрытияФормыТерминаГлоссария(РезультатЗакрытия, Термин) Экспорт
	ОбновитьСвойстваТерминаГлоссария(Термин);
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСвойстваТерминаГлоссария(Термин)
	МассивСтрок = ТерминыГлоссария.НайтиСтроки(Новый Структура("Термин", Термин));
	Если МассивСтрок.Количество() = 1 Тогда
		СвойстваТермина = СвойстваТерминаИзБазы(Термин);
		ЗаполнитьСтрокуТаблицыТерминов(МассивСтрок[0], СвойстваТермина)
	КонецЕсли;
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ЗаполнитьСтрокуТаблицыТерминов(СтрокаТТ, СвойстваТермина)
	
	// Процедура заполняет только свойства термина, но не свойства
	// таблицы терминов глоссария, такие как СоздаватьСсылки, КоличествоСсылок.
	
	СтрокаТТ.Термин = СвойстваТермина.Термин;
	СтрокаТТ.Представление = СвойстваТермина.Наименование;
	СтрокаТТ.Определение = СвойстваТермина.КраткоеОпределение;
	
	Если СвойстваТермина.Синонимы.Количество() > 0 Тогда
		СинонимыСтрокой = "";
		Для каждого СвойстваСинонима Из СвойстваТермина.Синонимы Цикл
			СинонимыСтрокой = СинонимыСтрокой + СвойстваСинонима.Представление + ",";
		КонецЦикла;
		СинонимыСтрокой = Лев(СинонимыСтрокой, СтрДлина(СинонимыСтрокой) - 1);
		СинонимыСтрокой = " (" + СинонимыСтрокой + ")";
		СтрокаТТ.Представление = СтрокаТТ.Представление + СинонимыСтрокой;
	КонецЕсли;	
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СвойстваТерминаИзБазы(Знач Термин)
	Возврат Справочники.ТерминыЭлектронныхГлоссариев.СвойстваТермина(Термин);
КонецФункции

&НаКлиенте
Процедура ДобавитьТерминВГлоссарий(Термин)	
	ЗаписатьТерминНаСервереИДобавитьВТаблицу(Термин);	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьТерминНаСервереИДобавитьВТаблицу(Знач Термин, Знач СоздаватьСсылки = Неопределено, Знач КоличествоСсылокТермина = Неопределено)
	
	// Создаем электронный курс, если он еще не записан
	
	Если НЕ ЗначениеЗаполнено(ЭлектронныйКурс) Тогда
		ЗаписатьНовыйЭлектронныйКурс();
	КонецЕсли;

	// Создаем глоссарий и помещаем его в электронный курс	
	
	Глоссарий = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлектронныйКурс, "Глоссарий");
	
	Если НЕ ЗначениеЗаполнено(Глоссарий) Тогда
		
		// Устанавливаем реквизиты по умолчанию
		
		СоздаватьСсылкиНаТерминыГлоссария = Истина;
		ПоказыватьКомандуГлоссария = Истина;
		
		// Создаем глоссарий
		
		ГлоссарийОбъект = Справочники.ЭлектронныеГлоссарии.СоздатьЭлемент();
		ГлоссарийОбъект.Наименование = НаименованиеКурса;
		ГлоссарийОбъект.Родитель = Справочники.ЭлектронныеКурсы.ГруппаДляХраненияПодчиненныхЭлементов(ЭлектронныйКурс, Тип("СправочникСсылка.ЭлектронныеГлоссарии"));
		ГлоссарийОбъект.СоздаватьСсылки = СоздаватьСсылкиНаТерминыГлоссария;
		ГлоссарийОбъект.ПоказыватьКоманду = ПоказыватьКомандуГлоссария;
		
		РазработкаЭлектронныхКурсовСлужебный.УстановитьПредпочитаемогоПоставщика(ГлоссарийОбъект);
		
		ГлоссарийОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
		ГлоссарийОбъект.Записать();
		
		Глоссарий = ГлоссарийОбъект.Ссылка;							
		
		// Записываем ссылку на презентацию
		
		ЭлектронныйКурсОбъект = ЭлектронныйКурс.ПолучитьОбъект();
		ЭлектронныйКурсОбъект.Глоссарий = Глоссарий;
		ЭлектронныйКурсОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
		ЭлектронныйКурсОбъект.Записать();		
		
		Элементы.ГруппаНастройкиГлоссария.Доступность = Истина;
		
	КонецЕсли;
	
	// Помещаем термин в глоссарий
	
	Если ГлоссарийОбъект = Неопределено Тогда
		ГлоссарийОбъект = Глоссарий.ПолучитьОбъект();
	КонецЕсли;
	
	Если СоздаватьСсылки = Неопределено Тогда
		СоздаватьСсылки = Истина;
	КонецЕсли;
	
	Если КоличествоСсылокТермина = Неопределено Тогда
		КоличествоСсылокТермина = 0;
	КонецЕсли;
	
	СуществующаяСтрокаТЧ = ГлоссарийОбъект.Термины.Найти(Термин, "Термин");	
	
	Если СуществующаяСтрокаТЧ = Неопределено Тогда
		
		НоваяСтрокаТЧ = ГлоссарийОбъект.Термины.Добавить();
		НоваяСтрокаТЧ.Термин = Термин;
		НоваяСтрокаТЧ.СоздаватьСсылки = СоздаватьСсылки;
		НоваяСтрокаТЧ.КоличествоСсылок = КоличествоСсылокТермина;
		
		НоваяСтрокаТТ = ТерминыГлоссария.Добавить();
		НоваяСтрокаТТ.Термин = Термин;
		НоваяСтрокаТТ.СоздаватьСсылки = СоздаватьСсылки;
		НоваяСтрокаТТ.КоличествоСсылок = КоличествоСсылокТермина;
		
		ЗаполнитьСтрокуТаблицыТерминов(НоваяСтрокаТТ, СвойстваТерминаИзБазы(Термин));
		
	Иначе
		
		СуществующаяСтрокаТЧ.СоздаватьСсылки = СоздаватьСсылки;
		СуществующаяСтрокаТЧ.КоличествоСсылок = КоличествоСсылокТермина;
		
		СуществующаяСтрокаТТ = ТерминыГлоссария.НайтиСтроки(Новый Структура("Термин", Термин))[0];
		
		СуществующаяСтрокаТТ.СоздаватьСсылки = СоздаватьСсылки;
		СуществующаяСтрокаТТ.КоличествоСсылок = КоличествоСсылокТермина;
		
		ЗаполнитьСтрокуТаблицыТерминов(СуществующаяСтрокаТТ, СвойстваТерминаИзБазы(Термин));
		
	КонецЕсли;
	
	ГлоссарийОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
	ГлоссарийОбъект.Записать();
	
	ТерминыГлоссария.Сортировать("Представление");
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьТерминИзГлоссария(Термин)	
	УдалитьТерминНаСервере(Термин);	
КонецПроцедуры

&НаСервере
Процедура УдалитьТерминНаСервере(Знач Термин)
	
	Если НЕ ЗначениеЗаполнено(Термин) Тогда
		Возврат;
	КонецЕсли;
	
	// Помечаем на удаление термин
	
	ТерминОбъект = Термин.ПолучитьОбъект();
	ТерминОбъект.УстановитьПометкуУдаления(Истина);
	
	// Удаляем термин из глоссария
	
	Глоссарий = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлектронныйКурс, "Глоссарий");
	ГлоссарийОбъект = Глоссарий.ПолучитьОбъект();
	СтрокаТЧ = ГлоссарийОбъект.Термины.Найти(Термин, "Термин");
	
	Если СтрокаТЧ <> Неопределено Тогда
		ГлоссарийОбъект.Термины.Удалить(СтрокаТЧ);
	КонецЕсли;
	
	ГлоссарийОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
	ГлоссарийОбъект.Записать();
	
	// Если больше не осталось терминов, удаляем глоссарий
	
	Если ГлоссарийОбъект.Термины.Количество() = 0 Тогда
		
		ГлоссарийОбъект.УстановитьПометкуУдаления(Истина);
		
		ЭлектронныйКурсОбъект = ЭлектронныйКурс.ПолучитьОбъект();
		ЭлектронныйКурсОбъект.Глоссарий = Неопределено;
		ЭлектронныйКурсОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
		ЭлектронныйКурсОбъект.Записать();
		
		СоздаватьСсылкиНаТерминыГлоссария = Ложь;
		ПоказыватьКомандуГлоссария = Ложь;
		
		Элементы.ГруппаНастройкиГлоссария.Доступность = Ложь;
		
	КонецЕсли;
	
	// Удаляем термин из таблицы
	
	СтрокиТТ = ТерминыГлоссария.НайтиСтроки(Новый Структура("Термин", Термин));	
	
	Если СтрокиТТ.Количество() = 1 Тогда
		ТерминыГлоссария.Удалить(СтрокиТТ[0]);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеТаблицыТерминов()
 
    НовоеОформление = УсловноеОформление.Элементы.Добавить();
    НовоеОформление.Использование = Истина;
    НовоеОформление.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Обычный; 
    НовоеОформление.ПредставлениеПользовательскойНастройки = НСтр("ru = 'Оформление терминов глоссария'"); 
	
    Отбор = НовоеОформление.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
    Отбор.ЛевоеЗначение    = Новый ПолеКомпоновкиДанных("ТерминыГлоссария.СоздаватьСсылки");
    Отбор.ВидСравнения     = ВидСравненияКомпоновкиДанных.Равно;
    Отбор.Использование    = Истина;
    Отбор.Представление    = НСтр("ru = 'Термин без создания ссылок'");
    Отбор.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;
    Отбор.ПравоеЗначение   = Ложь;	
	
	ЭлементОформленияЦветФона = ЭлектронноеОбучениеСлужебныйКлиентСервер.ЭлементУсловногоОформления(НовоеОформление, "Доступность");	
	ЭлементОформленияЦветФона.Значение = Ложь;
	ЭлементОформленияЦветФона.Использование = Истина;	
	
	ЭлементОформленияЦветФона = ЭлектронноеОбучениеСлужебныйКлиентСервер.ЭлементУсловногоОформления(НовоеОформление, "Формат");	
	ЭлементОформленияЦветФона.Значение = "ЧН=-";
	ЭлементОформленияЦветФона.Использование = Истина;		
	
    ПолеЭлемента = НовоеОформление.Поля.Элементы.Добавить();
    ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных("ТерминыГлоссарияКоличествоСсылок");	

КонецПроцедуры

&НаСервере
Функция АдресХраненияШаблонаГлоссарияВФорматеExcel()	
	ДвоичныеДанные = Справочники.ЭлектронныеГлоссарии.ПолучитьМакет("ШаблонГлоссарияВExcel");	
	Возврат ПоместитьВоВременноеХранилище(ДвоичныеДанные, УникальныйИдентификатор);	
КонецФункции

&НаКлиенте
Процедура ВыбратьФайлДляЗагрузкиТерминовГлоссария()
	
	ТекстСообщения = НСтр("ru = 'Для загрузки терминов глоссария рекомендуется установить расширение для веб-клиента 1С:Предприятие.'");
	Обработчик = Новый ОписаниеОповещения("ЗагрузитьТерминыГлоссарияПродолжение", ЭтотОбъект);
	ФайловаяСистемаКлиент.ПодключитьРасширениеДляРаботыСФайлами(Обработчик, ТекстСообщения, Истина);	
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьТерминыГлоссарияПродолжение(РасширениеПодключено, ДополнительныеПараметры) Экспорт
	
	Если НЕ РасширениеПодключено Тогда
		ОповещениеФайла = Новый ОписаниеОповещения("ЗагрузитьТерминыГлоссарияВебКлиентЗавершение", ЭтотОбъект, ДополнительныеПараметры);
		НачатьПомещениеФайла(ОповещениеФайла,,,,УникальныйИдентификатор);
		Возврат;
	КонецЕсли;
	
	ОповещениеЗавершения = Новый ОписаниеОповещения("ЗагрузитьТерминыГлоссарияЗавершение", ЭтотОбъект, ДополнительныеПараметры);	
	
	МассивТиповВыбора = Новый Массив;
	МассивТиповВыбора.Добавить(ПредопределенноеЗначение("Перечисление.ТипыЭлементовЭлектронныхРесурсов.Table"));
	
	ДиалогВыбораФайлов = РазработкаЭлектронныхКурсовСлужебныйКлиент.ДиалогВыбораФайлаПоТипу(
		МассивТиповВыбора,
		НСтр("ru = 'Выберите табличный файл с терминами'"),
		НСтр("ru = 'таблица'"));
	
	НачатьПомещениеФайлов(ОповещениеЗавершения, , ДиалогВыбораФайлов, Истина, УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьТерминыГлоссарияВебКлиентЗавершение(Результат, Адрес, ВыбранноеИмяФайла, ДополнительныеПараметры) Экспорт
	
	Если Результат Тогда
		ОписаниеФайлаСТерминами = Новый ОписаниеПередаваемогоФайла(ВыбранноеИмяФайла, Адрес);
		МассивФайловСТерминами = Новый Массив;
		МассивФайловСТерминами.Добавить(ОписаниеФайлаСТерминами);
		ЗагрузитьТерминыГлоссарияЗавершение(ОписаниеФайлаСТерминами, ДополнительныеПараметры);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьТерминыГлоссарияЗавершение(МассивФайловСТерминами, ДополнительныеПараметры) Экспорт
	
	Если МассивФайловСТерминами = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если МассивФайловСТерминами.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	РезультатДобавления = ДобавитьНовыеТерминыИзФайлаExcelНаСервере(
		МассивФайловСТерминами[0].Хранение,
		МассивФайловСТерминами[0].Имя
	);
	
	Если РезультатДобавления <> Неопределено Тогда
		
		Если ЗначениеЗаполнено(РезультатДобавления.КоличествоДобавленных)
			И ЗначениеЗаполнено(РезультатДобавления.КоличествоОбновленных) Тогда			
			ТекстПредупреждения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Добавлено новых: %1
                                                                                               |Обновлено: %2'"), РезультатДобавления.КоличествоДобавленных, РезультатДобавления.КоличествоОбновленных);			
		ИначеЕсли ЗначениеЗаполнено(РезультатДобавления.КоличествоДобавленных) Тогда
			ТекстПредупреждения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Добавлено новых: %1'"), РезультатДобавления.КоличествоДобавленных);
		ИначеЕсли ЗначениеЗаполнено(РезультатДобавления.КоличествоОбновленных) Тогда
			ТекстПредупреждения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Обновлено: %1'"), РезультатДобавления.КоличествоОбновленных);			
		Иначе
			ТекстПредупреждения = НСтр("ru = 'Нет терминов для добавления или обновления'");			
		КонецЕсли;
		
		ПоказатьПредупреждение(,ТекстПредупреждения);
		
	КонецЕсли;
	
КонецПроцедуры  

&НаСервере
Функция ДобавитьНовыеТерминыИзФайлаExcelНаСервере(ХранениеФайлаВХранилище, ИмяФайла) Экспорт
	
	РезультатДобавления = Новый Структура("КоличествоДобавленных, КоличествоОбновленных", 0, 0);
	
    // Получаем табличный документ с данными
    
    СтруктураФайла = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(ИмяФайла);
    ПутьКВременномуФайлуТаблицы = ПолучитьИмяВременногоФайла(СтруктураФайла.Расширение);	
    ДвоичныеДанныеФайла = ПолучитьИзВременногоХранилища(ХранениеФайлаВХранилище);	
    ДвоичныеДанныеФайла.Записать(ПутьКВременномуФайлуТаблицы);
    
    ТабличныйДокументСДанными = Новый ТабличныйДокумент;
    ТабличныйДокументСДанными.Прочитать(ПутьКВременномуФайлуТаблицы, СпособЧтенияЗначенийТабличногоДокумента.Текст);	
	
	ЭлектронноеОбучениеСлужебныйКлиентСервер.УдалитьВременныйФайл(ПутьКВременномуФайлуТаблицы);
	    
    // Преобразуем табличный документ в таблицу значений
    
    Построитель = Новый ПостроительЗапроса;
    Построитель.ИсточникДанных = Новый ОписаниеИсточникаДанных(ТабличныйДокументСДанными.Область());
    Попытка
    	Построитель.Выполнить();
    	ТаблицаСДаннымиТерминов = Построитель.Результат.Выгрузить();
    Исключение
    	ВызватьИсключение НСтр("ru = 'Ошибка чтения терминов из табличного файла.
    	|Возможно, макет таблицы не соответствует поддерживаемому формату.'");
    КонецПопытки;
    
    // Делаем проверки макета
    
    ОбязательныеКолонки = Новый Массив;
    ОбязательныеКолонки.Добавить("Термин");
    ОбязательныеКолонки.Добавить("Определение");    
    
    Для каждого ИмяОбязательнойКолонки Из ОбязательныеКолонки Цикл

    	КолонкаНайдена = Ложь;

    	Для каждого КолонкаТаблицыСДанными Из ТаблицаСДаннымиТерминов.Колонки Цикл
    		Если КолонкаТаблицыСДанными.Имя = ИмяОбязательнойКолонки Тогда
    			КолонкаНайдена = Истина;
    			Прервать;
    		КонецЕсли;
    	КонецЦикла;

    	Если НЕ КолонкаНайдена Тогда
    		ТекстИсключения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Обязательная колонка ""%1"" макета не найдена в файле ""%2""'"), ИмяОбязательнойКолонки, ИмяФайла);
    		ВызватьИсключение ТекстИсключения;
    	КонецЕсли;
    	
    КонецЦикла;
    
    // Находим имена колонок с синонимами
    
    КолонкиСинонимов = Новый Массив;
    
    Для каждого КолонкаТаблицыСДанными Из ТаблицаСДаннымиТерминов.Колонки Цикл
    	Если Лев(КолонкаТаблицыСДанными.Имя, СтрДлина("Синоним")) = "Синоним" Тогда
    		Если КолонкаТаблицыСДанными.Имя = "Синоним" Тогда
    			ТекстИсключения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'В файле ""%1"" колонка ""Синоним"" не имеет номера'"), ИмяФайла);
    			ВызватьИсключение ТекстИсключения;				
    		КонецЕсли;
    		КолонкиСинонимов.Добавить(КолонкаТаблицыСДанными.Имя);
    	КонецЕсли;
    КонецЦикла;  
      
    // Записываем термины
	
    НачатьТранзакцию();
    
    Попытка
		
		// Создаем электронный курс, если он еще не записан
		
		Если НЕ ЗначениеЗаполнено(ЭлектронныйКурс) Тогда
			ЗаписатьНовыйЭлектронныйКурс();
		КонецЕсли;		
		
		Для каждого СтрокаТДТ Из ТаблицаСДаннымиТерминов Цикл
		
			Если НЕ ЗначениеЗаполнено(СтрокаТДТ.Термин)
				ИЛИ НЕ ЗначениеЗаполнено(СтрокаТДТ.Определение) Тогда
				Продолжить;
			КонецЕсли;
			
			РодительТермина = Справочники.ЭлектронныеКурсы.ГруппаДляХраненияПодчиненныхЭлементов(ЭлектронныйКурс, Тип("СправочникСсылка.ТерминыЭлектронныхГлоссариев"));
			
			СуществующийТермин = Справочники.ТерминыЭлектронныхГлоссариев.НайтиПоНаименованию(СокрЛП(СтрокаТДТ.Термин), Истина, РодительТермина);
			
			Если ЗначениеЗаполнено(СуществующийТермин) Тогда
				ТерминОбъект = СуществующийТермин.ПолучитьОбъект();
				Если ТерминОбъект.ПометкаУдаления Тогда
					ТерминОбъект.УстановитьПометкуУдаления(Ложь);
					ЭтоНовыйТермин = Истина;
				Иначе
					ЭтоНовыйТермин = Ложь;
				КонецЕсли;				
			Иначе				
				ТерминОбъект = Справочники.ТерминыЭлектронныхГлоссариев.СоздатьЭлемент();
				ЭтоНовыйТермин = Истина;
			КонецЕсли;
			
			ТерминОбъект.Наименование = СокрЛП(СтрокаТДТ.Термин);
			ТерминОбъект.БукваДляПоиска = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.БукваДляПоискаТермина(ТерминОбъект.Наименование);
			ТерминОбъект.Родитель = РодительТермина;
			
       		РазработкаЭлектронныхКурсовСлужебный.УстановитьПредпочитаемогоПоставщика(ТерминОбъект);
			
			ТекстОпределенияТермина = "<div>" + СтрокаТДТ.Определение + "</div>";	
			
			ОпределениеФорматированныйДокумент = Новый ФорматированныйДокумент;
    		ОпределениеФорматированныйДокумент.УстановитьHTML(ТекстОпределенияТермина, Новый Структура);
    		
    		ТерминОбъект.Определение = Новый ХранилищеЗначения(ОпределениеФорматированныйДокумент);
			ТерминОбъект.КраткоеОпределение = СтрокаТДТ.Определение;
			
			ТерминОбъект.Синонимы.Очистить();
			
			Для каждого ИмяКолонкиСинонима Из КолонкиСинонимов Цикл	
				Если НЕ ЗначениеЗаполнено(СокрЛП(СтрокаТДТ[ИмяКолонкиСинонима])) Тогда
					Продолжить;
				КонецЕсли;
				НоваяСтрокаТЧС = ТерминОбъект.Синонимы.Добавить();
				НоваяСтрокаТЧС.Представление = СокрЛП(СтрокаТДТ[ИмяКолонкиСинонима]);	
				НоваяСтрокаТЧС.БукваДляПоиска = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.БукваДляПоискаТермина(НоваяСтрокаТЧС.Представление);
			КонецЦикла;
			
			ТерминОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
			ТерминОбъект.Записать();
			
			КоличествоСсылокТермина = Неопределено;
			Если ТаблицаСДаннымиТерминов.Колонки.Найти("КоличествоСсылок") <> Неопределено
				И ЭлектронноеОбучениеСлужебныйКлиентСервер.ЭтоЧисло(СтрокаТДТ.КоличествоСсылок) Тогда
				КоличествоСсылокТермина = Число(СтрокаТДТ.КоличествоСсылок);
			КонецЕсли;
			
			СоздаватьСсылки = Неопределено;
			Если ТаблицаСДаннымиТерминов.Колонки.Найти("СоздаватьСсылки") <> Неопределено Тогда
				СоздаватьСсылки = ЭлектронноеОбучениеСлужебныйКлиентСервер.СтрокаВБулево(СтрокаТДТ.СоздаватьСсылки);
			КонецЕсли;			
			
			ЗаписатьТерминНаСервереИДобавитьВТаблицу(ТерминОбъект.Ссылка, СоздаватьСсылки, КоличествоСсылокТермина);
			
			Если ЭтоНовыйТермин Тогда
				РезультатДобавления.КоличествоДобавленных = РезультатДобавления.КоличествоДобавленных + 1;
			Иначе
				РезультатДобавления.КоличествоОбновленных = РезультатДобавления.КоличествоОбновленных + 1;
			КонецЕсли;
			
		КонецЦикла;
		
    	// Завершаем
    	
      	ЗафиксироватьТранзакцию();
    	
    Исключение
 
 		ОтменитьТранзакцию();
    	ЭлектронноеОбучениеСлужебный.ЗаписатьОшибкуВЖурналРегистрации(ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
    	ВызватьИсключение;
    	
    КонецПопытки;	
	
	Возврат РезультатДобавления;
	
КонецФункции


#КонецОбласти

#Область СтатичныеФайлы

// Загрузка новых

&НаКлиенте
Процедура ДобавитьНовыйСтатичныйФайлВБазу(ФайлДляЗагрузки, ИдентификаторРодительскойСтроки = Неопределено, ЭлементаСодержанияДляЗаписи = Неопределено)
	
	#Если НЕ ВебКлиент И НЕ МобильныйКлиент Тогда
		
	Если РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлPDF(ФайлДляЗагрузки.Расширение) Тогда
		НоваяСтрока = НовыйЭлементСодержания(ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.PDF"), ИдентификаторРодительскойСтроки);
	ИначеЕсли РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлHTML(ФайлДляЗагрузки.Расширение) Тогда
		НоваяСтрока = НовыйЭлементСодержания(ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.HTML"), ИдентификаторРодительскойСтроки);
	ИначеЕсли РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлКартинки(ФайлДляЗагрузки.Расширение) Тогда
		НоваяСтрока = НовыйЭлементСодержания(ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Картинка"), ИдентификаторРодительскойСтроки);
	Иначе		
		НоваяСтрока = НовыйЭлементСодержания(ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Архив"), ИдентификаторРодительскойСтроки);
	КонецЕсли;
	
	СвойстваФайла = ПодготовитьСтатичныйФайлДляЗагрузкиВБазу(ФайлДляЗагрузки);
	СохранитьЭлементКурсаНаСервере(СвойстваФайла, НоваяСтрока.ПолучитьИдентификатор(), ФайлДляЗагрузки.ИмяБезРасширения, ЭлементаСодержанияДляЗаписи);
		
	#КонецЕсли

КонецПроцедуры

// Обновление

&НаКлиенте
Процедура ОбновитьИнтерактивноСтатичныйФайлВБазе()
	
	ТекстСообщения = НСтр("ru = 'Для загрузки файлов рекомендуется установить расширение для веб-клиента 1С:Предприятие.'");
	Обработчик = Новый ОписаниеОповещения("ОбновитьИнтерактивноСтатичныйФайлВБазеПродолжение", ЭтотОбъект);
	ФайловаяСистемаКлиент.ПодключитьРасширениеДляРаботыСФайлами(Обработчик, ТекстСообщения, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьИнтерактивноСтатичныйФайлВБазеПродолжение(РасширениеПодключено, ДополнительныеПараметры) Экспорт
	
	РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());
	Если РедактируемаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;	
	
	Если РасширениеПодключено Тогда
		
		ОповещениеЗавершения = Новый ОписаниеОповещения("ОбновитьИнтерактивноСтатичныйФайлЗавершение", ЭтотОбъект, ДополнительныеПараметры);	
		
		МассивТиповВыбора = Новый Массив;
		Если РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Архив") Тогда
			МассивТиповВыбора.Добавить("zip");
			ЗаголовокТипаФайла = НСтр("ru = 'Архив'");
		ИначеЕсли РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.PDF") Тогда
			МассивТиповВыбора.Добавить("pdf");
			ЗаголовокТипаФайла = НСтр("ru = 'PDF'");
		ИначеЕсли РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Картинка") Тогда			
			РасширенияКартинок = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.СоответствиеРасширенияИТипаЭлементаРесурса(ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Картинка"));
			Для каждого Элемент Из РасширенияКартинок Цикл		
				ТекущееРасширение = СтрЗаменить(Элемент.Ключ, "_", ".");	
				МассивТиповВыбора.Добавить(ТекущееРасширение);			
			КонецЦикла;
			ЗаголовокТипаФайла = НСтр("ru = 'Картинка'");			
		ИначеЕсли РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.HTML") Тогда
			МассивТиповВыбора.Добавить("htm");
			МассивТиповВыбора.Добавить("html");
			ЗаголовокТипаФайла = НСтр("ru = 'HTML'");			
		Иначе
			ВызватьИсключение НСтр("ru = 'Неизвестный тип элемента содержания'");
		КонецЕсли;
	
		ДиалогВыбораФайлов = РазработкаЭлектронныхКурсовСлужебныйКлиент.ДиалогВыбораФайлаПоТипу(
			МассивТиповВыбора,
			НСтр("ru = 'Выберите файл'"),
			ЗаголовокТипаФайла);			
				
		ДиалогВыбораФайлов.Показать(ОповещениеЗавершения);		
		
	Иначе
		
		ОповещениеФайла = Новый ОписаниеОповещения("ОбновитьИнтерактивноСтатичныйФайлВебКлиентЗавершение", ЭтотОбъект, ДополнительныеПараметры);
		НачатьПомещениеФайла(ОповещениеФайла);
		
	КонецЕсли;	
		
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьИнтерактивноСтатичныйФайлВебКлиентЗавершение(Результат, Адрес, ВыбранноеИмяФайла, ДополнительныеПараметры) Экспорт
	
	Если НЕ Результат ИЛИ НЕ ЗначениеЗаполнено(ВыбранноеИмяФайла) Тогда
		ОбновитьИнтерактивноСтатичныйФайлОкончание();
		Возврат;
	КонецЕсли;
	
	СтруктураФайла = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(ВыбранноеИмяФайла);
	
	СписокРазмещенныхФайлов = Новый Массив; // Список файлов с описанием места их хранения во временном хранилище.				
	КонтекстФайла = Неопределено; // Метка, позволяющая при записи файла в базу установить доп. свойства	
	
	СтруктураФайлов = Новый Массив;
	СтруктураФайлов.Добавить(ЭлектронноеОбучениеСлужебныйКлиентСервер.НовоеОписаниеФайла(СтруктураФайла, КонтекстФайла));
	
	СписокРазмещенныхФайлов = Новый Массив;
	СписокРазмещенныхФайлов.Добавить(Новый ОписаниеПередаваемогоФайла(ВыбранноеИмяФайла, Адрес));
	
	СвойстваФайла = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ПустаяСтруктураСвойствЗагружаемогоФайла();
	СвойстваФайла.Имя = СтруктураФайла.ИмяБезРасширения;
	СвойстваФайла.Расширение = СтруктураФайла.Расширение;
	СвойстваФайла.ЭтоКаталог = Ложь;
	СвойстваФайла.Преобразовать = Ложь;
	СвойстваФайла.СтруктураФайлов = СтруктураФайлов;
	СвойстваФайла.СписокФайлов = СписокРазмещенныхФайлов;
	СвойстваФайла.НастройкиКартинок = Неопределено;
	СвойстваФайла.ДанныеВидео = Неопределено;
	СвойстваФайла.КонтекстФайла = КонтекстФайла;
	СвойстваФайла.ТекстовыеДанныеДляИндексирования = Неопределено;
		
	СохранитьЭлементКурса(СвойстваФайла); // Вызов сервера	
	
	Состояние(НСтр("ru = 'Файл успешно обновлен'"));
	
	ОбновитьИнтерактивноСтатичныйФайлОкончание();
	
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьИнтерактивноСтатичныйФайлЗавершение(ВыбранныеФайлы, ДополнительныеПараметры = Неопределено) Экспорт

	// Делаем проверки
	
	Если ВыбранныеФайлы = Неопределено ИЛИ ВыбранныеФайлы.Количество() = 0 Тогда
		ОбновитьИнтерактивноСтатичныйФайлОкончание();
		Возврат;
	КонецЕсли;
	
	// Создаем новую строку дерева
	
	ФайлДляЗагрузки = Новый Файл(ВыбранныеФайлы[0]);
		
	Состояние(НСтр("ru = 'Пожалуйста, подождите, выполняется передача файла на сервер...'"));
	
	СвойстваФайла = ПодготовитьСтатичныйФайлДляЗагрузкиВБазу(ФайлДляЗагрузки);
	
	СохранитьЭлементКурса(СвойстваФайла); // Вызов сервера	

	ОбновитьИнтерактивноСтатичныйФайлОкончание();
	
	Состояние(НСтр("ru = 'Файл успешно обновлен'"));
	
КонецПроцедуры  

&НаКлиенте
Процедура ОбновитьИнтерактивноСтатичныйФайлОкончание()
	
	РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());
	Если РедактируемаяСтрока <> Неопределено
		И (РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.PDF")
		ИЛИ РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.HTML")
		ИЛИ РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Картинка")) Тогда
		
		ВыйтиИзРежимаРедактирования(Ложь);
		
	КонецЕсли;	
	
КонецПроцедуры

// Общее

&НаКлиенте
Функция ПодготовитьСтатичныйФайлДляЗагрузкиВБазу(ФайлДляЗагрузки)
	
	#Если НЕ ВебКлиент И НЕ МобильныйКлиент Тогда
		
	// Помещаем файл во временное хранилище и формируем переменные для передачи на сервер.
	
	ФайлыДляУдаления = Новый Массив;
	
	СписокФайлов = Новый Массив; // Линейный список файлов для последующего помещения во временное хранилище.
	СтруктураФайлов = Новый Массив; // Массив файлов с учетом иерархии каталогов.		
	СписокРазмещенныхФайлов = Новый Массив; // Список файлов с описанием места их хранения во временном хранилище.				
	КонтекстФайла = Неопределено; // Метка, позволяющая при записи файла в базу установить доп. свойства.
	
	Если РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоФайлHTML(ФайлДляЗагрузки.Расширение) Тогда
		
		ПутьКВременномуКаталогу = ПолучитьИмяВременногоФайла("");
		ЭлектронноеОбучениеСлужебныйКлиентСервер.НовыйКаталог(ПутьКВременномуКаталогу);		
		ФайлыДляУдаления.Добавить(ПутьКВременномуКаталогу);		
		ПутьКВременномуКаталогу = ОбщегоНазначенияКлиентСервер.ДобавитьКонечныйРазделительПути(ПутьКВременномуКаталогу);				
		
		// Копируем файл html во временный каталог и переименовываем в index.html
		
		ПутьКФайлуIndex = ПутьКВременномуКаталогу + "index.html";
		ЭлектронноеОбучениеСлужебныйКлиентСервер.СкопироватьФайл(ФайлДляЗагрузки.ПолноеИмя, ПутьКФайлуIndex);
		
		// Ищем каталог с дополнительными файлами и копируем их во временный каталог
		
		КандидатыВДополнительныеКаталоги = ЭлектронноеОбучениеСлужебныйКлиентСервер.ИскатьФайлы(ФайлДляЗагрузки.Путь, ФайлДляЗагрузки.ИмяБезРасширения + "*", Ложь);
		
		ДополнительныеКаталоги = Новый Массив;
		
		Для каждого ДопКаталог Из КандидатыВДополнительныеКаталоги Цикл		
			Если ЭтоКаталогДополнительныхФайловHTML(ДопКаталог.Имя, ФайлДляЗагрузки.ИмяБезРасширения) Тогда
				ДополнительныеКаталоги.Добавить(ДопКаталог);
			КонецЕсли;		
		КонецЦикла;
		
		Если ДополнительныеКаталоги.Количество() = 1 Тогда
			ЭлектронноеОбучениеСлужебныйКлиентСервер.СкопироватьКаталог(ДополнительныеКаталоги[0].ПолноеИмя, ПутьКВременномуКаталогу + ДополнительныеКаталоги[0].Имя); 
		ИначеЕсли ДополнительныеКаталоги.Количество() > 1 Тогда
			ВызватьИсключение СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Для %1 найдено более одного каталога с дополнительными файлами'"), ФайлДляЗагрузки.ПолноеИмя);
		КонецЕсли;
		
		// Упаковываем в архив HTML
		
		ПутьКАрхивуZIP = ПолучитьИмяВременногоФайла("zip");		
		ФайлыДляУдаления.Добавить(ПутьКАрхивуZIP);				
		ФайлZIP = Новый ЗаписьZipФайла(ПутьКАрхивуZIP,,,МетодСжатияZIP.Копирование);
		ФайлZIP.Добавить(ПутьКВременномуКаталогу + "*", РежимСохраненияПутейZIP.СохранятьОтносительныеПути, РежимОбработкиПодкаталоговZIP.ОбрабатыватьРекурсивно);

		ФайлZIP.Записать();		
		
		// Готовим к помещению в хранилище
		
		КонтекстФайла = "HTML";
		СтруктураФайлов.Добавить(ЭлектронноеОбучениеСлужебныйКлиентСервер.НовоеОписаниеФайла(ФайлДляЗагрузки, КонтекстФайла));	
		СписокФайлов.Добавить(Новый ОписаниеПередаваемогоФайла(ПутьКАрхивуZIP));
		
	Иначе
		
		ОтсортированныеФайлы = Новый Массив;
		ОтсортированныеФайлы.Добавить(ФайлДляЗагрузки);		
		ЭлектронноеОбучениеСлужебныйКлиентСервер.СформироватьОписаниеФайлов(ОтсортированныеФайлы, СтруктураФайлов, СписокФайлов, Ложь, КонтекстФайла);			
		
	КонецЕсли;
	
	РазработкаЭлектронныхКурсовСлужебныйКлиент.ПоместитьФайлыВХранилище(СписокФайлов, СписокРазмещенныхФайлов, УникальныйИдентификатор); 
	
	// Удаляем старые файлы
	//
	
	Для каждого ПутьКФайлу Из ФайлыДляУдаления Цикл		
		ЭлектронноеОбучениеСлужебныйКлиентСервер.УдалитьВременныйФайл(ПутьКФайлу);		
	КонецЦикла;		
	
	СвойстваФайла = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ПустаяСтруктураСвойствЗагружаемогоФайла();
	СвойстваФайла.Имя = ФайлДляЗагрузки.ИмяБезРасширения;
	СвойстваФайла.Расширение = ФайлДляЗагрузки.Расширение;
	СвойстваФайла.ЭтоКаталог = Ложь;
	СвойстваФайла.Преобразовать = Ложь;
	СвойстваФайла.СтруктураФайлов = СтруктураФайлов;
	СвойстваФайла.СписокФайлов = СписокРазмещенныхФайлов;
	СвойстваФайла.НастройкиКартинок = Неопределено;
	СвойстваФайла.ДанныеВидео = Неопределено;
	СвойстваФайла.КонтекстФайла = КонтекстФайла;
	СвойстваФайла.ТекстовыеДанныеДляИндексирования = Неопределено;	
	
	Возврат СвойстваФайла;	
	
	#КонецЕсли
	
КонецФункции

#КонецОбласти

#Область ЭлектронныйКурсИСодержание

// Общее

&НаСервере
Процедура ЗаполнитьРеквизитыЭлектронногоКурса()	
	
	Если НЕ РежимРедактирования И НЕ ЗначениеЗаполнено(ЭлектронныйКурс) Тогда
		ВызватьИсключение НСтр("ru = 'Электронный курс не задан'")
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЭлектронныйКурс) Тогда
		
		ДанныеЭлектронногоКурса = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЭлектронныйКурс, "Наименование, Тип");
		
		ТипЭлектронногоКурса = ДанныеЭлектронногоКурса.Тип;
		
		Если ТипЭлектронногоКурса = Перечисления.ТипыЭлектронныхКурсов.Учебник Тогда
		
			Если РежимРедактирования Тогда			
				ШаблонЗаголовка = НСтр("ru = 'Редактирование учебника ""%1""'");
			ИначеЕсли РежимИзучения Тогда			
				Если ЗначениеЗаполнено(Учащийся) И ЗначениеЗаполнено(Контекст) Тогда 
					ШаблонЗаголовка = НСтр("ru = 'Изучение учебника ""%1""'");
				Иначе
					ШаблонЗаголовка = НСтр("ru = 'Тестовое изучение учебника ""%1""'");
				КонецЕсли;			
			Иначе
				ШаблонЗаголовка = НСтр("ru = '%1'");
			КонецЕсли;			
			
		ИначеЕсли ТипЭлектронногоКурса = Перечисления.ТипыЭлектронныхКурсов.Тест Тогда
		
			Если РежимРедактирования Тогда			
				ШаблонЗаголовка = НСтр("ru = 'Редактирование теста ""%1""'");
			ИначеЕсли РежимИзучения Тогда			
				Если ЗначениеЗаполнено(Учащийся) И ЗначениеЗаполнено(Контекст) Тогда 
					ШаблонЗаголовка = НСтр("ru = 'Прохождение теста ""%1""'");
				Иначе
					ШаблонЗаголовка = НСтр("ru = 'Тестовое прохождение теста ""%1""'");
				КонецЕсли;			
			Иначе
				ШаблонЗаголовка = НСтр("ru = '%1'");
			КонецЕсли;			
			
		Иначе
			
			Если РежимРедактирования Тогда			
				ШаблонЗаголовка = НСтр("ru = 'Редактирование курса ""%1""'");
			ИначеЕсли РежимИзучения Тогда			
				Если ЗначениеЗаполнено(Учащийся) И ЗначениеЗаполнено(Контекст) Тогда 
					ШаблонЗаголовка = НСтр("ru = 'Изучение курса ""%1""'");
				Иначе
					ШаблонЗаголовка = НСтр("ru = 'Тестовое изучение курса ""%1""'");
				КонецЕсли;			
			Иначе
				ШаблонЗаголовка = НСтр("ru = '%1'");
			КонецЕсли;						
			
		КонецЕсли;
			
		НаименованиеКурса = ДанныеЭлектронногоКурса.Наименование;
		Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонЗаголовка, ДанныеЭлектронногоКурса.Наименование);			
		
	Иначе
		
		Если Параметры.Свойство("ТипЭлектронногоКурса")
			И ЗначениеЗаполнено(Параметры.ТипЭлектронногоКурса) Тогда
			
			ТипЭлектронногоКурса = Параметры.ТипЭлектронногоКурса;
			
		КонецЕсли;			
		
		Если ТипЭлектронногоКурса = Перечисления.ТипыЭлектронныхКурсов.Учебник Тогда
			
			Если РежимРедактирования Тогда			
				Заголовок = НСтр("ru = 'Электронный учебник (создание)'");			
			Иначе			
				Заголовок = НСтр("ru = 'Просмотр элемента'");			
			КонецЕсли;								
			
		ИначеЕсли ТипЭлектронногоКурса = Перечисления.ТипыЭлектронныхКурсов.Тест Тогда
			
			Если РежимРедактирования Тогда			
				Заголовок = НСтр("ru = 'Электронный тест (создание)'");			
			Иначе			
				Заголовок = НСтр("ru = 'Просмотр элемента'");			
			КонецЕсли;			
			
		Иначе
			
			Если РежимРедактирования Тогда			
				Заголовок = НСтр("ru = 'Электронный курс (создание)'");			
			Иначе			
				Заголовок = НСтр("ru = 'Просмотр элемента'");			
			КонецЕсли;					
			
		КонецЕсли;
		
		
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(ФиксированныйЗаголовок) Тогда
		Заголовок = ФиксированныйЗаголовок;	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьРедакторПрезентацийПоУмолчанию()
		
	Если ОбщегоНазначения.ЭтоLinuxКлиент() Тогда
		Элементы.РежимРедактированияСоздатьPowerPoint.Видимость = Ложь;
	Иначе
		Если ЕстьЭлементНавигационногоДереваЗаданногоТипа(Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.СлайдПрезентацииImpress) Тогда
			Элементы.РежимРедактированияСоздатьPowerPoint.Видимость = Ложь;
			Элементы.РежимРедактированияСоздатьImpress.Видимость = Истина;
		Иначе
			Элементы.РежимРедактированияСоздатьImpress.Видимость = Ложь;
			Элементы.РежимРедактированияСоздатьPowerPoint.Видимость = Истина;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Содержание курса

&НаКлиенте
Процедура АктивироватьЭлементСодержанияЧерезОбработчик()
	ТекущиеДанные = НавигационноеДеревоТекущиеДанные();
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;	
	АктивироватьЭлементСодержания(ТекущиеДанные.Ссылка, ТекущиеДанные.ЭтоГруппа, ТекущиеДанные.ТипЭлемента);
КонецПроцедуры

&НаКлиенте
Процедура АктивироватьЭлементСодержания(Знач АктивированныйЭлементСодержания, Знач ЭтоГруппа, Знач ТипЭлементаСодержания)	
	
	Если ВыполняетсяРедактированиеЭлемента() Тогда
		
		РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());
		
		Если РедактируемаяСтрока = Неопределено ИЛИ РедактируемаяСтрока.Ссылка <> НавигационноеДеревоТекущиеДанные().Ссылка Тогда
			ВыйтиИзРежимаРедактирования();			
		КонецЕсли;
		
	Иначе
		
		Если АктивированныйЭлементСодержания = ЭлектронныйКурс Тогда
			УстановитьЭлементДляПросмотра(ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Начало"));
		ИначеЕсли ЭтоГруппа Тогда
			УстановитьЭлементДляПросмотра(); // Пустой элемент
		ИначеЕсли ТипЗнч(АктивированныйЭлементСодержания) = Тип("СправочникСсылка.СодержаниеЭлектронныхКурсов") Тогда						
			УстановитьЭлементДляПросмотра(АктивированныйЭлементСодержания);
		Иначе			
			ОтобразитьПустойЭлементКурса(Элементы.НавигационноеДерево.ТекущаяСтрока);
		КонецЕсли;
		
		ПриАктивацииЭлементаСодержания();
		
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ПриАктивацииЭлементаСодержания()
	
	ТекущиеДанные = НавигационноеДеревоТекущиеДанные();
	ТипЭлементаСодержания = Неопределено;
	Если ТекущиеДанные <> Неопределено Тогда 
		ТипЭлементаСодержания = ТекущиеДанные.ТипЭлемента;
	КонецЕсли;
	
	Если ТипЭлементаСодержания = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.PDF")
		ИЛИ ТипЭлементаСодержания = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.HTML")
		ИЛИ ТипЭлементаСодержания = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Картинка") Тогда
		Элементы.РежимРедактированияРедактироватьЭлементКурса.Заголовок = НСтр("ru = 'Обновить с диска'");
		Элементы.РежимРедактированияРедактироватьЭлементКурса.ОтображениеПодсказки = ОтображениеПодсказки.Нет;
	Иначе
		Элементы.РежимРедактированияРедактироватьЭлементКурса.Заголовок = Неопределено;
		Элементы.РежимРедактированияРедактироватьЭлементКурса.ОтображениеПодсказки = ОтображениеПодсказки.Авто;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНавигационноеДерево()
	
	// Очищаем данные
	
	НавигационноеДерево.ПолучитьЭлементы().Очистить();
	
	// Получаем выгрузку элементов содержания
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СодержаниеЭлектронныхКурсов.Ссылка КАК Ссылка,
		|	СодержаниеЭлектронныхКурсов.Элемент КАК СсылкаНаЭлемент,
		|	СодержаниеЭлектронныхКурсов.Наименование КАК Наименование,
		|	СодержаниеЭлектронныхКурсов.ЭтоГруппа КАК ЭтоГруппа,
		|	СодержаниеЭлектронныхКурсов.Родитель КАК Группа,
		|	СодержаниеЭлектронныхКурсов.ТипЭлемента КАК ТипЭлемента,
		|	СодержаниеЭлектронныхКурсов.Скрытый КАК Скрытый
		|ИЗ
		|	Справочник.СодержаниеЭлектронныхКурсов КАК СодержаниеЭлектронныхКурсов
		|ГДЕ
		|	СодержаниеЭлектронныхКурсов.Владелец = &ЭлектронныйРесурс
		|	И СодержаниеЭлектронныхКурсов.ПометкаУдаления = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	СодержаниеЭлектронныхКурсов.Код ИЕРАРХИЯ,
		|	Наименование ИЕРАРХИЯ";

	Запрос.УстановитьПараметр("ЭлектронныйРесурс", ЭлектронныйКурс);

	Результат = Запрос.Выполнить();

	ДеревоСодержанияВыгрузка = Результат.Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	
	// Формируем дерево содержания
	
	ДеревоСодержания = Новый ДеревоЗначений();
	
	ДеревоСодержания.Колонки.Добавить("Ссылка");
	ДеревоСодержания.Колонки.Добавить("СсылкаНаЭлемент");
	ДеревоСодержания.Колонки.Добавить("Наименование");
	ДеревоСодержания.Колонки.Добавить("ЭтоГруппа");
	ДеревоСодержания.Колонки.Добавить("Картинка");
	ДеревоСодержания.Колонки.Добавить("Пройдено");
	ДеревоСодержания.Колонки.Добавить("Отмечено");
	ДеревоСодержания.Колонки.Добавить("ТипЭлемента");	
	ДеревоСодержания.Колонки.Добавить("ЭтоКорень");	
	ДеревоСодержания.Колонки.Добавить("ЭтоФинальныйСлайд");	
	ДеревоСодержания.Колонки.Добавить("Скрытый");	
	
	// Создаем корневой элемент дерева
	
	КореньДереваСодержания = ДеревоСодержания.Строки.Добавить();
	КореньДереваСодержания.Ссылка = ЭлектронныйКурс;
	КореньДереваСодержания.СсылкаНаЭлемент = ЭлектронныйКурс;
	
	Если ЗначениеЗаполнено(ЭлектронныйКурс) Тогда
		КореньДереваСодержания.Наименование = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлектронныйКурс, "Наименование");
	Иначе
		КореньДереваСодержания.Наименование = НаименованиеНовогоЭлектронногоКурса(ТипЭлектронногоКурса);
	КонецЕсли;
	
	КореньДереваСодержания.ЭтоКорень = Истина;
	КореньДереваСодержания.Отмечено = Ложь;
	КореньДереваСодержания.Пройдено = Истина;
	КореньДереваСодержания.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.Начало;
	КореньДереваСодержания.ЭтоФинальныйСлайд = Ложь;
	
	// Добавляем элементы курса в корень
	
	ДобавитьЭлементыСодержанияВДерево(КореньДереваСодержания.Строки, ДеревоСодержанияВыгрузка.Строки);	
		
	// Настраиваем корень дерева
	
	Для каждого Строка Из КореньДереваСодержания.Строки Цикл
	
		Если НЕ Строка.Пройдено Тогда
			КореньДереваСодержания.Пройдено = Ложь;
			Прервать;
		КонецЕсли;
	
	КонецЦикла;
	
	КореньДереваСодержания.Картинка = КартинкаЭлементаСодержания(КореньДереваСодержания, ТипЭлектронногоКурса); // Книга
	
	// Помещаем дерево в форму
	
	ЗначениеВРеквизитФормы(ДеревоСодержания, "НавигационноеДерево");	
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьЭлементыСодержанияВДерево(СтрокиДерева, СтрокиВыгрузки);

	Для каждого Строка Из СтрокиВыгрузки Цикл
		
		НоваяСтрока = СтрокиДерева.Добавить();		
		
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
		
		НоваяСтрока.ЭтоФинальныйСлайд = Ложь;
		НоваяСтрока.Отмечено  = Ложь;
		НоваяСтрока.Пройдено  = Ложь;
		НоваяСтрока.ЭтоКорень = Ложь;				
		
		Если ЗначениеЗаполнено(Строка.ТипЭлемента) Тогда
			НоваяСтрока.ТипЭлемента = Строка.ТипЭлемента;
		Иначе				
			НоваяСтрока.ТипЭлемента = Справочники.СодержаниеЭлектронныхКурсов.ТипЭлементаПоСсылке(Строка.СсылкаНаЭлемент, Строка.ЭтоГруппа);
		КонецЕсли;		
		
		Если Строка.ЭтоГруппа Тогда									
			ДобавитьЭлементыСодержанияВДерево(НоваяСтрока.Строки, Строка.Строки); // Рекурсия
		КонецЕсли;
		
		НоваяСтрока.Картинка = КартинкаЭлементаСодержания(НоваяСтрока, ТипЭлектронногоКурса);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция КартинкаЭлементаСодержания(ТекущаяСтрока, ТипЭлектронногоКурса)
	
	Если ТекущаяСтрока.ЭтоКорень Тогда		
		Если ТипЭлектронногоКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Слайдовый") Тогда
			Возврат 22;
		ИначеЕсли ТипЭлектронногоКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Учебник") Тогда			
			Возврат 15;
		Иначе
			Возврат 16;
		КонецЕсли;
	ИначеЕсли ТекущаяСтрока.ЭтоГруппа Тогда
		Возврат 2;
	ИначеЕсли ТекущаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Видео") Тогда
		Возврат 11;
	ИначеЕсли ТекущаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Глоссарий") Тогда
		Возврат 10;
	ИначеЕсли ТекущаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Документ") Тогда
		Возврат 7;
	ИначеЕсли ТекущаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ДокументWord") Тогда
		Возврат 8;
	ИначеЕсли ТекущаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Звук") Тогда
		Возврат 4;
	ИначеЕсли ТекущаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Тест") Тогда
		Возврат 5;
	ИначеЕсли ТекущаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.СлайдПрезентацииPowerPoint") Тогда
		Возврат 9;		
	ИначеЕсли ТекущаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ПрезентацияPowerPoint") Тогда
		Возврат 9;				
	ИначеЕсли ТекущаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.СлайдПрезентацииImpress") Тогда
		Возврат 21;				
	ИначеЕсли ТекущаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ПрезентацияImpress") Тогда
		Возврат 21;				
	ИначеЕсли ТекущаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.YouTube") Тогда
		Возврат 29;				
	ИначеЕсли ТекущаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.PDF") Тогда
		Возврат 19;				
	ИначеЕсли ТекущаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ДокументOpenOffice") Тогда
		Возврат 20;						
	ИначеЕсли ТекущаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.HTML") Тогда
		Возврат 13;						
	ИначеЕсли ТекущаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Архив") Тогда
		Возврат 28;				
	Иначе		
		Возврат 13;		
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Функция ТекущийЭлементСодержания()
	
	Если Элементы.НавигационноеДерево.Видимость Тогда
		
		ТекущиеДанные = НавигационноеДеревоТекущиеДанные();
		
		Если ТекущиеДанные = Неопределено
			ИЛИ ТипЗнч(ТекущиеДанные.Ссылка) <> Тип("СправочникСсылка.СодержаниеЭлектронныхКурсов") Тогда
			
			Возврат ПредопределенноеЗначение("Справочник.СодержаниеЭлектронныхКурсов.ПустаяСсылка");
			
		Иначе
			
			Возврат ТекущиеДанные.Ссылка;
			
		КонецЕсли;
		
	Иначе
		
		Возврат ПредопределенноеЗначение("Справочник.СодержаниеЭлектронныхКурсов.ПустаяСсылка");
		
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Функция ИдентификаторСтрокиНавигационногоДереваПоСсылкеНаЭлемент(Знач ЭлементСодержания, ТекущиеСтрокиДляОбхода = Неопределено)
	
	// В качестве переменной ЭлементСодержания
	// может быть передана, как ссылка, так и ее
	// уникальный идентификатор (тип УникальныйИдентификатор).
	
	Если ТекущиеСтрокиДляОбхода = Неопределено Тогда
		ТекущиеСтрокиДляОбхода = НавигационноеДерево.ПолучитьЭлементы();
	КонецЕсли;	
	
	НайденнаяСтрока = Неопределено;
	
	Для каждого Строка Из ТекущиеСтрокиДляОбхода Цикл
	
		Если ТипЗнч(ЭлементСодержания) = Тип("СправочникСсылка.СодержаниеЭлектронныхКурсов")
			И Строка.Ссылка = ЭлементСодержания 
			И НЕ Строка.ЭтоКорень Тогда // Корень не ищем
			НайденнаяСтрока = Строка.ПолучитьИдентификатор();			
		КонецЕсли;
			
		Если ТипЗнч(ЭлементСодержания) = Тип("УникальныйИдентификатор")
			И ЗначениеЗаполнено(ЭлементСодержания)
			И Строка.Ссылка.УникальныйИдентификатор() = ЭлементСодержания 
			И НЕ Строка.ЭтоКорень Тогда // Корень не ищем
			НайденнаяСтрока = Строка.ПолучитьИдентификатор();
		КонецЕсли;		
		
		Если НайденнаяСтрока = Неопределено
			И (Строка.ЭтоГруппа ИЛИ Строка.ЭтоКорень) Тогда
			
			НайденнаяСтрока = ИдентификаторСтрокиНавигационногоДереваПоСсылкеНаЭлемент(ЭлементСодержания, Строка.ПолучитьЭлементы()); // Рекурсия 
			
		КонецЕсли;
		
		Если НайденнаяСтрока <> Неопределено Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;	
	
	Возврат НайденнаяСтрока;
	
КонецФункции

&НаСервере
Функция ЕстьЭлементНавигационногоДереваЗаданногоТипа(Знач ТипЭлементаСодержания, ТекущиеСтрокиДляОбхода = Неопределено)
	
	Если ТекущиеСтрокиДляОбхода = Неопределено Тогда
		ТекущиеСтрокиДляОбхода = НавигационноеДерево.ПолучитьЭлементы();
	КонецЕсли;		
	
	ТипЭлементаНайден = Ложь;
	
	Для каждого Строка Из ТекущиеСтрокиДляОбхода Цикл
		
		Если Строка.ТипЭлемента = ТипЭлементаСодержания 
			И НЕ Строка.ЭтоКорень Тогда // Корень не ищем
			
			ТипЭлементаНайден = Истина;			
			
		КонецЕсли;		
		
		Если НЕ ТипЭлементаНайден И (Строка.ЭтоГруппа ИЛИ Строка.ЭтоКорень) Тогда			
			ТипЭлементаНайден = ЕстьЭлементНавигационногоДереваЗаданногоТипа(ТипЭлементаСодержания, Строка.ПолучитьЭлементы()); // Рекурсия 			
		КонецЕсли;
		
		Если ТипЭлементаНайден Тогда
			Прервать;
		КонецЕсли;
	
	КонецЦикла;	
	
	Возврат ТипЭлементаНайден;
	
КонецФункции

&НаКлиенте
Функция ЭлементСодержанияПоИдентификатору(Знач ИдентификаторЭлементаСодержания)
	
	ИдентификаторСтрокиСодержания = ИдентификаторСтрокиНавигационногоДереваПоСсылкеНаЭлемент(ИдентификаторЭлементаСодержания);
	
	Если ИдентификаторСтрокиСодержания = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	СтрокаСодержания = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторСтрокиСодержания);
	Возврат СтрокаСодержания.Ссылка;	
	
КонецФункции

&НаКлиенте
Функция НовыйЭлементСодержания(ТипЭлемента = Неопределено, ИдентификаторРодительскойСтроки = Неопределено)
	
	Если ИдентификаторРодительскойСтроки = Неопределено Тогда
	
		ИдентификаторТекущейСтроки = Элементы.НавигационноеДерево.ТекущаяСтрока;
		ТекущиеДанные = НавигационноеДеревоТекущиеДанные();
		
		Если ИдентификаторТекущейСтроки <> Неопределено Тогда
			ТекущаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторТекущейСтроки);
		КонецЕсли;
		
		Если ИдентификаторТекущейСтроки = Неопределено ИЛИ (ТекущиеДанные <> Неопределено И ТекущиеДанные.ЭтоКорень) ИЛИ ТекущаяСтрока = Неопределено Тогда		
			ЭлементыДереваДляДобавления = НавигационноеДерево.ПолучитьЭлементы().Получить(0).ПолучитьЭлементы(); // Элементы корня		
		ИначеЕсли ТекущиеДанные <> Неопределено И ТекущиеДанные.ЭтоГруппа Тогда		
			ЭлементыДереваДляДобавления = ТекущаяСтрока.ПолучитьЭлементы();		
		Иначе
			ЭлементыДереваДляДобавления = ТекущаяСтрока.ПолучитьРодителя().ПолучитьЭлементы();
		КонецЕсли;	
		
	Иначе
		
		РодительскаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРодительскойСтроки);
		Если РодительскаяСтрока = Неопределено Тогда
			ЭлементыДереваДляДобавления = НавигационноеДерево.ПолучитьЭлементы().Получить(0).ПолучитьЭлементы(); // Элементы корня
		Иначе			
			ЭлементыДереваДляДобавления = РодительскаяСтрока.ПолучитьЭлементы();
		КонецЕсли;		
		
	КонецЕсли;	
		
	НоваяСтрокаСодержания = ЭлементыДереваДляДобавления.Добавить();		
	Если ТипЭлектронногоКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Слайдовый") Тогда
		НоваяСтрокаСодержания.Наименование = НСтр("ru = 'Новый слайд'");
	Иначе
		НоваяСтрокаСодержания.Наименование = НСтр("ru = 'Новый элемент'");
	КонецЕсли;
	
	Если ТипЭлемента <> Неопределено Тогда
		НоваяСтрокаСодержания.ТипЭлемента = ТипЭлемента;
	КонецЕсли;
	
	Если НоваяСтрокаСодержания.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Группа") Тогда
		НоваяСтрокаСодержания.ЭтоГруппа = Истина;
	КонецЕсли;
	
	НоваяСтрокаСодержания.Картинка = КартинкаЭлементаСодержания(НоваяСтрокаСодержания, ТипЭлектронногоКурса);
	
	Возврат НоваяСтрокаСодержания;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция НаименованиеНовогоЭлектронногоКурса(ТипКурса)	
	Если ТипКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Учебник") Тогда
		Возврат НСтр("ru = 'Новый электронный учебник'");
	Иначе
		Возврат НСтр("ru = 'Новый электронный курс'");
	КонецЕсли;
КонецФункции

&НаСервере
Процедура ПереместитьЭлементСодержания(Знач НомерПеремещаемойСтроки, Знач НомерСтрокиНаКоторуюПеремещаем)
	
	ПеремещаемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(НомерПеремещаемойСтроки);	
	СтрокаНаКоторуюПеремещаем = НавигационноеДерево.НайтиПоИдентификатору(НомерСтрокиНаКоторуюПеремещаем);

	Если СтрокаНаКоторуюПеремещаем.ЭтоКорень Тогда
		
		НовыйРодитель = Справочники.СодержаниеЭлектронныхКурсов.ПустаяСсылка();
		
	ИначеЕсли СтрокаНаКоторуюПеремещаем.ЭтоГруппа Тогда
		
		НовыйРодитель = СтрокаНаКоторуюПеремещаем.Ссылка;		
		
	Иначе
		
		НовыйРодительСтрока = СтрокаНаКоторуюПеремещаем.ПолучитьРодителя();
		НовыйРодитель = НовыйРодительСтрока.Ссылка;		
		
	КонецЕсли;
	
	ПеремещаемыйЭлементОбъект = ПеремещаемаяСтрока.Ссылка.ПолучитьОбъект();
	ПеремещаемыйЭлементОбъект.Родитель = НовыйРодитель;
	ПеремещаемыйЭлементОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
	ПеремещаемыйЭлементОбъект.Записать();	
	
	ЗаполнитьНавигационноеДерево();
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьНаименованиеКурса()
	НавигационноеДерево.ПолучитьЭлементы().Получить(0).Наименование = НаименованиеКурса;
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьЭлементСодержанияВНовомОкне(ИдентификаторЭлементаСодержания)
	
	Если НЕ ЗначениеЗаполнено(ИдентификаторЭлементаСодержания) Тогда
		ПоказатьПредупреждение(,НСтр("ru = 'Элемент содержания не найден или не может быть открыт'"));
		Возврат;
	КонецЕсли;		
	
	ЭлементСодержания = ЭлементСодержанияПоИдентификатору(ИдентификаторЭлементаСодержания);	

	Если НЕ ЗначениеЗаполнено(ЭлементСодержания) Тогда
		ПоказатьПредупреждение(,НСтр("ru = 'Элемент содержания не найден или не может быть открыт'"));
		Возврат;
	КонецЕсли;	
	
	ИзучениеЭлектронныхКурсовСлужебныйКлиент.ОткрытьЭлектронныйКурс(ЭлектронныйКурс,,,,ЭлементСодержания,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);	
	
КонецПроцедуры

&НаКлиенте
Процедура РаскрытьКорень()
	
	// Раскрываем корень дерева	
	
	ТекущиеСтрокиДляОбхода = НавигационноеДерево.ПолучитьЭлементы();	
	ИдентификаторКорня = Неопределено;
	
	Для каждого Строка Из ТекущиеСтрокиДляОбхода Цикл	
		Если Строка.ЭтоКорень Тогда
			ИдентификаторКорня = Строка.ПолучитьИдентификатор();
			Прервать;
		КонецЕсли;				
	КонецЦикла;	
	
	Если ИдентификаторКорня <> Неопределено Тогда
		Элементы.НавигационноеДерево.Развернуть(ИдентификаторКорня);
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Процедура УстановитьУсловноеОформлениеСодержания()
	
	НовоеОформление = УсловноеОформление.Элементы.Добавить();
	НовоеОформление.Использование = Истина;
	НовоеОформление.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Обычный; 
	НовоеОформление.ПредставлениеПользовательскойНастройки = НСтр("ru = 'Оформление скрытых элементов содержания'"); 
	
	Отбор = НовоеОформление.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	Отбор.ЛевоеЗначение    = Новый ПолеКомпоновкиДанных("НавигационноеДерево.Скрытый");
	Отбор.ВидСравнения     = ВидСравненияКомпоновкиДанных.Равно;
	Отбор.Использование    = Истина;
	Отбор.Представление    = НСтр("ru = 'Скрытый элемент содержания'");
	Отбор.РежимОтображения = РежимОтображенияЭлементаНастройкиКомпоновкиДанных.Недоступный;
	Отбор.ПравоеЗначение   = Истина;	
	
	ЭлементОформленияЦветФона = ЭлектронноеОбучениеСлужебныйКлиентСервер.ЭлементУсловногоОформления(НовоеОформление, "ЦветТекста");	
	ЭлементОформленияЦветФона.Значение = Новый Цвет(192, 192, 192);
	ЭлементОформленияЦветФона.Использование = Истина;	
	
	ПолеЭлемента = НовоеОформление.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных("НавигационноеДерево");		
	
КонецПроцедуры

&НаКлиенте
Функция ИдентификаторРедактируемойСтрокиНаКлиенте()	
	Возврат ИдентификаторРедактируемойСтрокиНавигационногоДерева;
КонецФункции

&НаСервере
Функция ТекущееНаименованиеКурса()
	
	Если ИдентификаторЕдинственнойСтрокиНавигационногоДерева > -1 Тогда
		Возврат НаименованиеКурса;
	Иначе
		Возврат НавигационноеДерево.ПолучитьЭлементы().Получить(0).Наименование;
	КонецЕсли;
	
КонецФункции

