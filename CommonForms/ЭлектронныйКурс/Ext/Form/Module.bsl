// Добавление

&НаКлиенте
Процедура ДобавитьЭлементКурса()	
	
	Если НЕ РежимРедактирования Тогда
		Возврат;
	КонецЕсли;	
	
	Если ВыполняетсяРедактированиеЭлемента() Тогда
		
		ВыйтиИзРежимаРедактирования();
		
	Иначе		
		
		УстановитьЭлементДляПросмотра(); // Пустой элемент
		Если ИдентификаторЕдинственнойСтрокиНавигационногоДерева > -1 Тогда
			ДобавитьЭлементКурсаПродолжение();
		Иначе
			ПодключитьОбработчикОжидания("ДобавитьЭлементКурсаПродолжение", 0.1, Истина); // 8.3.10 IE11 video bug
		КонецЕсли;
				
						
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьЭлементКурсаПродолжение()
	
	ИдентификаторПустойСтроки = ИдентификаторСтрокиНавигационногоДереваПоСсылкеНаЭлемент(Неопределено);
	
	Если ИдентификаторПустойСтроки = Неопределено Тогда
		НоваяСтрока = НовыйЭлементСодержания(); 
		ИдентификаторПустойСтроки = НоваяСтрока.ПолучитьИдентификатор();
	КонецЕсли;
	
	Элементы.НавигационноеДерево.ТекущаяСтрока = ИдентификаторПустойСтроки;
	
	Если ИдентификаторЕдинственнойСтрокиНавигационногоДерева > -1 Тогда
		НоваяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторПустойСтроки);
		НоваяСтрока.Наименование = НСтр("ru = 'Тестирование'");
		НоваяСтрока.ТипЭлемента  = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Тест");	
		НачатьРедактироватьЭлементКурса();		
	Иначе
		ОтобразитьПустойЭлементКурса(ИдентификаторПустойСтроки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтобразитьПустойЭлементКурса(ИдентификаторПустойСтроки)
	
	ИдентификаторРедактируемойСтрокиНавигационногоДерева = ИдентификаторПустойСтроки;
	УстановитьВидимостьЭлементовРедактораКурса(Истина, ЭтотОбъект);		
	Элементы.СтраницыРедактора.ТекущаяСтраница = Элементы.СтраницаМастераСозданияЭлемента;		
	Элементы.КомандыМастераСозданияЭлемента.Видимость = Истина;			
	Элементы.ОбластьПросмотра.Видимость = Ложь;
	
КонецПроцедуры

#КонецОбласти

#Область Удаление

// Удаление

&НаКлиенте
Процедура УдалитьЭлементКурса()
	
	Если НЕ РежимРедактирования Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = НавигационноеДеревоТекущиеДанные();
	КоличествоЭлементовДляУдаления = Элементы.НавигационноеДерево.ВыделенныеСтроки.Количество();	
	
	Для каждого ИдентификаторСтрокиДляУдаления Из Элементы.НавигационноеДерево.ВыделенныеСтроки Цикл	
		ТекущийЭлементДерева = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторСтрокиДляУдаления);
		Если ТекущийЭлементДерева = Неопределено ИЛИ ТекущийЭлементДерева.ЭтоКорень Тогда
			КоличествоЭлементовДляУдаления = КоличествоЭлементовДляУдаления - 1; // Корень не считаем
		КонецЕсли;
	КонецЦикла;	
	
	Если ТекущиеДанные = Неопределено
		ИЛИ ТекущиеДанные.ЭтоКорень
		ИЛИ КоличествоЭлементовДляУдаления = 0 Тогда
		
		Возврат;
		
	КонецЕсли;	
	
	Если КоличествоЭлементовДляУдаления = 1 Тогда
		ТекстВопроса = НСтр("ru = 'Удалить элемент курса?'");
	Иначе		
		ТекстВопроса = НСтр("ru = 'Удалить элементы курса?'");
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("УдалитьЭлементКурсаПродолжение", ЭтотОбъект);
	ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет, 0);
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьЭлементКурсаПродолжение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Нет Тогда
        Возврат;
    КонецЕсли; 
	
	Состояние(НСтр("ru = 'Выполняется удаление элементов курса...'"));
	
	ВыделенныеСтрокиМассив = Новый Массив;
	ЭлементыСодержанияСоСлайдамиPowerPoint = Новый Массив;
	ЭлементыСодержанияСоСлайдамиImpress = Новый Массив;
	
	Для каждого ИдентификаторСтрокиДляУдаления Из Элементы.НавигационноеДерево.ВыделенныеСтроки Цикл	
		ТекущийЭлементДерева = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторСтрокиДляУдаления);
		Если ТекущийЭлементДерева <> Неопределено
			И НЕ ТекущийЭлементДерева.ЭтоКорень
			И ТекущийЭлементДерева.ТипЭлемента <> ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.СлайдПрезентацииPowerPoint")
			И ТекущийЭлементДерева.ТипЭлемента <> ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.СлайдПрезентацииImpress")  Тогда
			ВыделенныеСтрокиМассив.Добавить(ИдентификаторСтрокиДляУдаления); // Корень не удаляем
		КонецЕсли;
		Если ТипЭлектронногоКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Слайдовый") 
			И ТекущийЭлементДерева.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.СлайдПрезентацииPowerPoint") Тогда
			ЭлементыСодержанияСоСлайдамиPowerPoint.Добавить(ТекущийЭлементДерева.Ссылка);
		КонецЕсли;
		Если ТипЭлектронногоКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Слайдовый") 
			И ТекущийЭлементДерева.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.СлайдПрезентацииImpress") Тогда
			ЭлементыСодержанияСоСлайдамиImpress.Добавить(ТекущийЭлементДерева.Ссылка);
		КонецЕсли;
	КонецЦикла;
	
	Для каждого ИдентификаторСтрокиДляУдаления Из ВыделенныеСтрокиМассив Цикл	
		ТекущийЭлементДерева = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторСтрокиДляУдаления);
		Если ТекущийЭлементДерева = Неопределено Тогда
			Продолжить; // Уже удалили
		КонецЕсли;
		Если ЭлементыСодержанияСоСлайдамиPowerPoint.Найти(ТекущийЭлементДерева.Ссылка) <> Неопределено Тогда
			Продолжить; // Будет удален при удалении слайдов презентации
		КонецЕсли;		
		Если ЭлементыСодержанияСоСлайдамиImpress.Найти(ТекущийЭлементДерева.Ссылка) <> Неопределено Тогда
			Продолжить; // Будет удален при удалении слайдов презентации
		КонецЕсли;				
		УдалитьЭлементКурсаНаСервере(ТекущийЭлементДерева.Ссылка);
		ТекущийЭлементДерева.ПолучитьРодителя().ПолучитьЭлементы().Удалить(ТекущийЭлементДерева);		
	КонецЦикла;	
	
	Если ЭлементыСодержанияСоСлайдамиPowerPoint.Количество() > 0 Тогда
		УдалитьСлайдыИзПрезентацииPowerPointСлайдовогоКурса(ЭлементыСодержанияСоСлайдамиPowerPoint);
	КонецЕсли;	
	
	Если ЭлементыСодержанияСоСлайдамиImpress.Количество() > 0 Тогда
		УдалитьСлайдыИзПрезентацииOpenOfficeСлайдовогоКурса(ЭлементыСодержанияСоСлайдамиImpress);
	КонецЕсли;		
	
	ПриРедактировании();	
	
	// Раскрываем корень, так как он сворачивается после удаления	
	
	РаскрытьКорень();
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УдалитьЭлементКурсаНаСервере(ЭлементСодержания)
	
	Если ТипЗнч(ЭлементСодержания) <> Тип("СправочникСсылка.СодержаниеЭлектронныхКурсов") Тогда		
		Возврат;		
	КонецЕсли;
	
	ЭлементСодержанияОбъект = ЭлементСодержания.ПолучитьОбъект();
	ЭлементСодержанияОбъект.УстановитьПометкуУдаления(Истина, Истина);
	
КонецПроцедуры

#КонецОбласти

#Область Сохранение

// Редактирование и сохранение

&НаКлиенте
Функция НавигационноеДеревоТекущиеДанные()
	
	Если ИдентификаторЕдинственнойСтрокиНавигационногоДерева > -1 Тогда
		Возврат НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторЕдинственнойСтрокиНавигационногоДерева);
	Иначе
		Возврат Элементы.НавигационноеДерево.ТекущиеДанные;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура РедактироватьЭлементКурса()
	
	Если НЕ РежимРедактирования Тогда
		Возврат;
	КонецЕсли;	
	
	Если ИдентификаторЕдинственнойСтрокиНавигационногоДерева > -1 Тогда
		
		РедактироватьЭлементКурсаПродолжение();
		
	Иначе
		
		УстановитьЭлементДляПросмотра(); // Пустой элемент
		
		ТекущиеДанные = НавигационноеДеревоТекущиеДанные();
		
		Если ТекущиеДанные <> Неопределено Тогда
			Если ТекущиеДанные.ЭтоГруппа Тогда
				Элементы.НавигационноеДерево.ИзменитьСтроку();
			Иначе			
				ПодключитьОбработчикОжидания("РедактироватьЭлементКурсаПродолжение", 0.1, Истина); // 8.3.10 IE11 video bug
			КонецЕсли;
		КонецЕсли;		
		
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура РедактироватьЭлементКурсаПродолжение()	
	
	ПропуститьАктивациюЭлементаСодержания = Истина; // Событие НавигационноеДеревоПриАктивизацииСтроки срабатывает при вызове серверных функций.	
	НачатьРедактироватьЭлементКурса();		

	// После начала редактирования:
	
	Если ИдентификаторЕдинственнойСтрокиНавигационногоДерева > -1 Тогда
		РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторЕдинственнойСтрокиНавигационногоДерева);
	Иначе		
		РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());
	КонецЕсли;
	
	Если РедактируемаяСтрока <> Неопределено
		И РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ДокументWord") Тогда
		
		ОткрытьДокументWord();
		
	КонецЕсли;	
	
	Если РедактируемаяСтрока <> Неопределено
		И РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ДокументOpenOffice") Тогда
		
		ОткрытьДокументOpenOffice();
		
	КонецЕсли;	
	
	Если РедактируемаяСтрока <> Неопределено
		И (РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.СлайдПрезентацииPowerPoint")
		ИЛИ РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ПрезентацияPowerPoint")) Тогда
		
		ОткрытьПрезентациюPowerPoint();
		
	КонецЕсли;	
	
	Если РедактируемаяСтрока <> Неопределено
		И (РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ПрезентацияImpress")
		ИЛИ РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.СлайдПрезентацииImpress")) Тогда
		
		ОткрытьПрезентациюOpenOffice();
		
	КонецЕсли;		
	
	Если РедактируемаяСтрока <> Неопределено
		И (РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.PDF")
		ИЛИ РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.HTML")
		ИЛИ РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Картинка")) Тогда
		
		ОбновитьИнтерактивноСтатичныйФайлВБазе();
		
	КонецЕсли;	
	
	ПриРедактировании();
	
КонецПроцедуры

&НаСервере
Процедура НачатьРедактироватьЭлементКурса()
	
	// Получаем переменные
	//

	Если ИдентификаторЕдинственнойСтрокиНавигационногоДерева > -1 Тогда
		ИдентификаторРедактируемойСтрокиНавигационногоДерева = ИдентификаторЕдинственнойСтрокиНавигационногоДерева;
	Иначе
		ИдентификаторРедактируемойСтрокиНавигационногоДерева = Элементы.НавигационноеДерево.ТекущаяСтрока;
	КонецЕсли;
	
	РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНавигационногоДерева);		
	
	Если РедактируемаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЭтоНовыйЭлемент = НЕ ЗначениеЗаполнено(РедактируемаяСтрока.СсылкаНаЭлемент);
	
	// Устанавливаем видимость элементов формы
	//
	
	УстановитьВидимостьЭлементовРедактораКурса(Истина, ЭтотОбъект);	
	
	// Документ
	//	
	
	Если РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.Документ Тогда
		
		// Получаем текст документа и загружаем в редактор
		
		Если ЗначениеЗаполнено(РедактируемаяСтрока.СсылкаНаЭлемент) Тогда
			
			Ресурс = Справочники.ТеорияЭлектронныхКурсов.ЕдинственныйЭлемент(РедактируемаяСтрока.СсылкаНаЭлемент);		
			ЭлементРесурса = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Ресурс, "ЕдинственныйЭлемент");
			ДанныеДокумента = Справочники.ЭлементыЭлектронныхРесурсов.ДанныеЭлементаДляРедактирования(ЭлементРесурса,,УникальныйИдентификатор);
			
		КонецЕсли;
		
		// Показываем элементы формы
		
		Элементы.СтраницыРедактора.ТекущаяСтраница = Элементы.СтраницаДокумента;		
		Элементы.КомандыДокумента.Видимость = Истина;		
		Элементы.ОбластьПросмотра.Видимость = Ложь;
		
		ТекущийЭлемент = Элементы.РедакторДокумента;
		
	// Word
	//		
		
	ИначеЕсли РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.ДокументWord Тогда	
		
		// Получаем данные о документе
		
		Если ЗначениеЗаполнено(РедактируемаяСтрока.СсылкаНаЭлемент) Тогда
			ДанныеХраненияВнешнегоДокумента = ДанныеХраненияВнешнегоДокумента(РедактируемаяСтрока.Ссылка, РедактируемаяСтрока.ПолучитьРодителя().Ссылка, РедактируемаяСтрока.СсылкаНаЭлемент, УникальныйИдентификатор); // Сохраняем в реквизит
		КонецЕсли;
		
		// Показываем реквизиты формы
		
		Элементы.ОбластьПросмотра.Видимость = Истина;
		Элементы.СтраницыРедактора.Видимость = Ложь;
		Элементы.КомандыДокументаWord.Видимость = Истина;
		
	// OpenOffice
	//		
		
	ИначеЕсли РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.ДокументOpenOffice Тогда	
		
		// Получаем данные о документе
		
		Если ЗначениеЗаполнено(РедактируемаяСтрока.СсылкаНаЭлемент) Тогда
			ДанныеХраненияВнешнегоДокумента = ДанныеХраненияВнешнегоДокумента(РедактируемаяСтрока.Ссылка, РедактируемаяСтрока.ПолучитьРодителя().Ссылка, РедактируемаяСтрока.СсылкаНаЭлемент, УникальныйИдентификатор); // Сохраняем в реквизит
		КонецЕсли;
		
		Элементы.НавигационноеДерево.Доступность = Ложь;
		
		// Показываем реквизиты формы
		
		Элементы.ОбластьПросмотра.Видимость = Истина;
		Элементы.СтраницыРедактора.Видимость = Ложь;
		Элементы.КомандыДокументаOpenOffice.Видимость = Истина;
		
		
	// PowerPoint и Impress
	//		
		
	ИначеЕсли РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.СлайдПрезентацииPowerPoint
		ИЛИ РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.СлайдПрезентацииImpress
		ИЛИ РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.ПрезентацияPowerPoint
		ИЛИ РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.ПрезентацияImpress Тогда
		
		Элементы.НавигационноеДерево.Доступность = Ложь;
		
		// Показываем реквизиты формы
		
		Элементы.ОбластьПросмотра.Видимость = Истина;
		Элементы.СтраницыРедактора.Видимость = Ложь;
		Элементы.КомандыПрезентации.Видимость = Истина;		
		
	// Тест
	//
		
	ИначеЕсли РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.Тест Тогда		
		
		// Отображаем вопросы теста
		
		ЭлектронноеОбучениеСлужебныйКлиентСервер.УстановитьОтборЭлементовДинамическогоСписка(СтраницыЭлементов, РедактируемаяСтрока.СсылкаНаЭлемент);
		
		// Заполняем настройки теста
		
		Если НЕ ЭтоНовыйЭлемент Тогда
			
			ДанныеТеста = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
				РедактируемаяСтрока.СсылкаНаЭлемент,
				"ВремяТеста,
				|КоличествоПопыток,
				|КоличествоВопросов,
				|РазрешитьИсправлятьОшибки,
				|ПеремешиватьВопросы,
				|ПоказыватьРезультатОтвета,
				|ПоказыватьСтатистику,
				|ПоказыватьПравильныеОтветы");
			
			НастройкиТестаВремяТеста = ИзучениеЭлектронныхКурсовСлужебныйSCORM.КоличествоМинутИзДаты(ДанныеТеста.ВремяТеста);
			НастройкиТестаКоличествоВопросов = ДанныеТеста.КоличествоВопросов;
			НастройкиТестаКоличествоПопыток = ДанныеТеста.КоличествоПопыток;					
			НастройкиТестаПеремешиватьВопросы = ДанныеТеста.ПеремешиватьВопросы;
			НастройкиТестаПоказыватьПравильныеОтветы = ДанныеТеста.ПоказыватьПравильныеОтветы;
			НастройкиТестаПоказыватьРезультатОтвета = ДанныеТеста.ПоказыватьРезультатОтвета;
			НастройкиТестаПоказыватьСтатистику = ДанныеТеста.ПоказыватьСтатистику;
			НастройкиТестаРазрешитьИсправлятьОшибки = ДанныеТеста.РазрешитьИсправлятьОшибки;
			
		КонецЕсли;
		
		УстановитьМаксимальноеКоличествоВопросовВНастройкеТеста(РедактируемаяСтрока.СсылкаНаЭлемент);
		
		УстановитьДоступностьНастроекТестирования(ЭтотОбъект);
		
		// Показываем элементы формы
		
		Элементы.СтраницыРедактора.ТекущаяСтраница = Элементы.СтраницаТеста;		
		Элементы.КомандыТеста.Видимость = Истина;		
		Элементы.ОбластьПросмотра.Видимость = Истина;		
		
	// Видео
	//
		
	ИначеЕсли РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.Видео Тогда
		
		// Заполняем настройки видео
		
		ЭлементКурсаСВидео = Справочники.ЭлектронныеРесурсы.ЕдинственныйЭлемент(
			Справочники.ТеорияЭлектронныхКурсов.ЕдинственныйЭлемент(РедактируемаяСтрока.СсылкаНаЭлемент));		
			
		Если НЕ ЗначениеЗаполнено(ЭлементКурсаСВидео) Тогда
			ВызватьИсключение НСтр("ru = 'Элемент курса с видео не найден'");
		КонецЕсли;			
			
		ДанныеВидео = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЭлементКурсаСВидео, "ПроигрыватьАвтоматически, Описание, ЭтоВнешнийЭлемент, ИмяФайла");			
		
		НастройкиВидеоПроигрыватьАвтоматически = ДанныеВидео.ПроигрыватьАвтоматически;
		НастройкиВидеоОписание = ДанныеВидео.Описание.Получить();
		
		Если ДанныеВидео.ЭтоВнешнийЭлемент Тогда
			НастройкиВидеоАдресВнешнегоВидео = ДанныеВидео.ИмяФайла;
			НастройкиВидеоФорматВнешнегоВидео = Справочники.ЭлементыЭлектронныхРесурсов.ПроизвольныеДанныеЭлемента(ЭлементКурсаСВидео, "ХранилищеДанных", "ФорматВидео");
		КонецЕсли;
		
		// Показываем элементы формы
		
		Элементы.СтраницыРедактора.ТекущаяСтраница = Элементы.СтраницаВидео;
		Элементы.КомандыВидео.Видимость = Истина;
		Элементы.ОбластьПросмотра.Видимость = Ложь;
		Элементы.РежимРедактированияКонвертерВидео.Видимость = НЕ ДанныеВидео.ЭтоВнешнийЭлемент;
		Элементы.РежимРедактированияОбновитьФайлВидео.Видимость = НЕ ДанныеВидео.ЭтоВнешнийЭлемент;
		Элементы.ГруппаНастройкиВнешнегоВидео.Видимость = ДанныеВидео.ЭтоВнешнийЭлемент;		
		
	// Архив
	//
		
	ИначеЕсли РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.Архив Тогда
		
		// Заполняем настройки архива
		
		ЭлементКурсаСАрхивом = Справочники.ЭлектронныеРесурсы.ЕдинственныйЭлемент(
			Справочники.ТеорияЭлектронныхКурсов.ЕдинственныйЭлемент(РедактируемаяСтрока.СсылкаНаЭлемент));		
			
		Если НЕ ЗначениеЗаполнено(ЭлементКурсаСАрхивом) Тогда
			ВызватьИсключение НСтр("ru = 'Элемент курса с архивом не найден'");
		КонецЕсли;			
			
		ДанныеАрхива = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЭлементКурсаСАрхивом, "Описание");					
		НастройкиАрхиваОписание = ДанныеАрхива.Описание.Получить();
		
		// Показываем элементы формы		
		
		Элементы.СтраницыРедактора.ТекущаяСтраница = Элементы.СтраницаАрхив;
		Элементы.КомандыАрхив.Видимость = Истина;		
		Элементы.ОбластьПросмотра.Видимость = Ложь;
		
	// PDF, HTML или Картинка имеют пустую страницу настроек
	//
		
	ИначеЕсли РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.PDF
		ИЛИ РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.HTML
		ИЛИ РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.Картинка Тогда
		
		Элементы.СтраницыРедактора.ТекущаяСтраница = Элементы.СтраницаПустая;
		Элементы.ОбластьПросмотра.Видимость = Ложь;		
		
	// YouTube
	//
		
	ИначеЕсли РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.YouTube Тогда
		
		// Заполняем настройки видео
		
		ЭлементКурсаСВидео = Справочники.ЭлектронныеРесурсы.ЕдинственныйЭлемент(
			Справочники.ТеорияЭлектронныхКурсов.ЕдинственныйЭлемент(РедактируемаяСтрока.СсылкаНаЭлемент));		
			
		Если НЕ ЗначениеЗаполнено(ЭлементКурсаСВидео) Тогда
			ВызватьИсключение НСтр("ru = 'Элемент курса с видео не найден'");
		КонецЕсли;			
			
		ДанныеВидео = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЭлементКурсаСВидео, "ПроигрыватьАвтоматически, Описание");
		
		НастройкиВидеоПроигрыватьАвтоматически = ДанныеВидео.ПроигрыватьАвтоматически;
		НастройкиВидеоОписание = ДанныеВидео.Описание.Получить();
		
		// Показываем элементы формы
		
		Элементы.СтраницыРедактора.ТекущаяСтраница = Элементы.СтраницаYouTube;
		Элементы.КомандыYouTube.Видимость = Истина;
		Элементы.ОбластьПросмотра.Видимость = Ложь;		
		
	// Звук
	//
		
	ИначеЕсли РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.Звук Тогда
		
		// Заполняем настройки видео
		
		ЭлементКурсаСоЗвуком = Справочники.ЭлектронныеРесурсы.ЕдинственныйЭлемент(
			Справочники.ТеорияЭлектронныхКурсов.ЕдинственныйЭлемент(РедактируемаяСтрока.СсылкаНаЭлемент));		
			
		Если НЕ ЗначениеЗаполнено(ЭлементКурсаСоЗвуком) Тогда
			ВызватьИсключение НСтр("ru = 'Элемент курса со звуком не найден'");
		КонецЕсли;			
			
		ДанныеЗвука = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЭлементКурсаСоЗвуком, "ПроигрыватьАвтоматически, Описание");
		
		НастройкиВидеоОписание = ДанныеЗвука.Описание.Получить();		
		НастройкиВидеоПроигрыватьАвтоматически = ДанныеЗвука.ПроигрыватьАвтоматически;
		
		// Показываем элементы формы
		
		Элементы.СтраницыРедактора.ТекущаяСтраница = Элементы.СтраницаЗвук;
		Элементы.КомандыЗвук.Видимость = Истина;
		Элементы.ОбластьПросмотра.Видимость = Ложь;		
		
	// Начало (Корень)
	//
		
	ИначеЕсли РедактируемаяСтрока.ТипЭлемента = Перечисления.ТипыЭлементовСодержанияЭлектронногоКурса.Начало Тогда
		
		ДанныеЭлектронногоКурса = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЭлектронныйКурс, "СтартоваяСтраница, ФинальнаяСтраница, Наименование, Глоссарий");
		
		// Загружаем стартовую страницу
		
		Если ЗначениеЗаполнено(ДанныеЭлектронногоКурса.СтартоваяСтраница)
			И ТипЗнч(ДанныеЭлектронногоКурса.СтартоваяСтраница) = Тип("СправочникСсылка.ЭлектронныеРесурсы") Тогда
			
			ЭлементРесурса = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЭлектронногоКурса.СтартоваяСтраница, "ЕдинственныйЭлемент");
			ДанныеСтартовойСтраницы = Справочники.ЭлементыЭлектронныхРесурсов.ДанныеЭлементаДляРедактирования(ЭлементРесурса,,УникальныйИдентификатор);		
			
		КонецЕсли;
		
		// Загружаем финальную страницу
		
		Если ЗначениеЗаполнено(ДанныеЭлектронногоКурса.ФинальнаяСтраница)
			И ТипЗнч(ДанныеЭлектронногоКурса.ФинальнаяСтраница) = Тип("СправочникСсылка.ЭлектронныеРесурсы") Тогда

			ЭлементРесурса = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеЭлектронногоКурса.ФинальнаяСтраница, "ЕдинственныйЭлемент");
			ДанныеФинальнойСтраницы = Справочники.ЭлементыЭлектронныхРесурсов.ДанныеЭлементаДляРедактирования(ЭлементРесурса,,УникальныйИдентификатор);		
		
		КонецЕсли;		
		
		// Загружаем глоссарий
		
		ТерминыГлоссария.Очистить();
		
		Если ЗначениеЗаполнено(ДанныеЭлектронногоКурса.Глоссарий) Тогда
			
			СвойстваГлоссария = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеЭлектронногоКурса.Глоссарий, "СоздаватьСсылки, ПоказыватьКоманду");
			
			ПоказыватьКомандуГлоссария = СвойстваГлоссария.ПоказыватьКоманду;
			СоздаватьСсылкиНаТерминыГлоссария = СвойстваГлоссария.СоздаватьСсылки;			
			
			ТаблицаТерминовИзБД = Справочники.ЭлектронныеГлоссарии.Термины(ДанныеЭлектронногоКурса.Глоссарий);
			
			Для каждого СтрокаТБД Из ТаблицаТерминовИзБД Цикл
				
				НоваяСтрока = ТерминыГлоссария.Добавить();
				НоваяСтрока.КоличествоСсылок = СтрокаТБД.КоличествоСсылок;
				НоваяСтрока.СоздаватьСсылки = СтрокаТБД.СоздаватьСсылки;
				
				ЗаполнитьСтрокуТаблицыТерминов(НоваяСтрока, СтрокаТБД);				
			
			КонецЦикла;
			
			ТерминыГлоссария.Сортировать("Представление");
			
			Элементы.ГруппаНастройкиГлоссария.Доступность = Истина;
			
		Иначе
			
			ПоказыватьКомандуГлоссария = Ложь;
			СоздаватьСсылкиНаТерминыГлоссария = Ложь;
			
			Элементы.ГруппаНастройкиГлоссария.Доступность = Ложь;
			
		КонецЕсли;
		
		// Устанавливаем наименование
		
		НаименованиеКурса = ДанныеЭлектронногоКурса.Наименование;
		
		// Показываем элементы формы
		
		Элементы.СтраницыРедактора.ТекущаяСтраница = Элементы.СтраницаНачало;
		Элементы.КомандыНачало.Видимость = Истина;
		Элементы.ОбластьПросмотра.Видимость = Ложь;
		
		Элементы.ГруппаФинальнаяСтраница.Видимость = ?(ТипЭлектронногоКурса = Перечисления.ТипыЭлектронныхКурсов.Слайдовый, Истина, Ложь); 
		Элементы.ГруппаГлоссарий.Видимость = ?(ТипЭлектронногоКурса = Перечисления.ТипыЭлектронныхКурсов.Учебник, Истина, Ложь);
		
		Если ТипЭлектронногоКурса = Перечисления.ТипыЭлектронныхКурсов.Слайдовый Тогда
			Элементы.ГруппаСтартоваяСтраница.Заголовок = НСтр("ru = 'Стартовый слайд'");
			Элементы.ГруппаФинальнаяСтраница.Заголовок = НСтр("ru = 'Финальный слайд'");
		КонецЕсли;
		
		ТекущийЭлемент = Элементы.РедакторСтартовойСтраницы;
		
	// Ошибка	
	//
		
	Иначе
		
		ВызватьИсключение НСтр("ru = 'Неизвестный тип элемента содержания'")		
		
	КонецЕсли;
	
	// Сбрасываем модифицированность
	
	Модифицированность = Ложь;
		
КонецПроцедуры

&НаКлиенте
Процедура СохранитьЭлементКурса(СвойстваФайла = Неопределено, ВыйтиИзРежимаРедактирования = Ложь, Синхронно = Истина, НаименованиеНовогоЭлемента = Неопределено)
	
	ПерваяЗаписьКурса = НЕ ЗначениеЗаполнено(ЭлектронныйКурс);		
	РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(ИдентификаторРедактируемойСтрокиНаКлиенте());	
	
	Если РазработкаЭлектронныхКурсовСлужебныйКлиент.ПрезентацияPowerPointДоступна(ПриложениеPowerPoint) Тогда
		
		Если РазработкаЭлектронныхКурсовСлужебныйКлиент.ПрезентацияPowerPointМодифицирована(ПриложениеPowerPoint) Тогда
			ПриложениеPowerPoint.ВыйтиИзРежимаРедактированияПослеЗаписи = Истина;
			ПриложениеPowerPoint.Презентация.Save();
		Иначе
			ЗакрытьПрезентациюPowerPoint(Ложь);	
		КонецЕсли;
		
		// Само сохранение будет выполнено по событию закрытия презентации
		
	ИначеЕсли РедактируемаяСтрока <> Неопределено Тогда
		
		Если РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ДокументWord") Тогда
			
			СохранитьДокументWord(
			Синхронно,
			НЕ ВыйтиИзРежимаРедактирования
			);			
			
		ИначеЕсли РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ДокументOpenOffice") Тогда
			
			СохранитьОткрытыйДокументOpenOffice();
			
		ИначеЕсли РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ПрезентацияPowerPoint")
			ИЛИ РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.СлайдПрезентацииPowerPoint") Тогда
			
			Если ОбщегоНазначенияКлиент.ЭтоOSXКлиент() Тогда
				
				ПутьКФайлуПрограммыКонвертации = ПриложениеPowerPoint.Скрытое + "closeAndSavePresentations.scpt";
				ПараметрыЗапускаПрограммы = ФайловаяСистемаКлиент.ПараметрыЗапускаПрограммы();			
				ПараметрыЗапускаПрограммы.ДождатьсяЗавершения = Истина;						
				ФайловаяСистемаКлиент.ЗапуститьПрограмму("osascript """ + ПутьКФайлуПрограммыКонвертации + """", ПараметрыЗапускаПрограммы);		
				
				Если ТипЭлектронногоКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Слайдовый") Тогда
					СохранитьПрезентациюPowerPointВБазу(ПриложениеPowerPoint.ХранениеНаДиске, Неопределено);
				Иначе
					СохранитьПрезентациюPowerPointВБазу(ПриложениеPowerPoint.ХранениеНаДиске, ИдентификаторРедактируемойСтрокиНаКлиенте());
				КонецЕсли;
				
				// Под windows такой ситуации не возникает,
				// так как при закрытии презентации редактирование
				// завершается автоматически. Под macOS пользователь
				// может вручную нажать команду.
				
			КонецЕсли;				
			
		ИначеЕсли РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.ПрезентацияImpress")
			ИЛИ РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.СлайдПрезентацииImpress") Тогда
			
			Если ОбщегоНазначенияКлиент.ЭтоWindowsКлиент() Тогда
			
				Если РазработкаЭлектронныхКурсовСлужебныйКлиент.ПрезентацияImpressДоступна(ПриложениеImpress) Тогда			
					ПриложениеImpress.Презентация.store();		
					ПриложениеImpress.Презентация.close(true);
				Иначе
					РазработкаЭлектронныхКурсовСлужебныйКлиент.ИнициализироватьПриложениеImpress(ПриложениеImpress);
				КонецЕсли;				

			КонецЕсли;				
			
			Если ТипЭлектронногоКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Слайдовый") Тогда
				СохранитьПрезентациюOpenOfficeВБазу(ПриложениеImpress.ХранениеНаДиске, Неопределено);
			Иначе
				СохранитьПрезентациюOpenOfficeВБазу(ПриложениеImpress.ХранениеНаДиске, ИдентификаторРедактируемойСтрокиНаКлиенте());
			КонецЕсли;			
			
		Иначе
			
			СохранитьЭлементКурсаНаСервере(СвойстваФайла, ИдентификаторРедактируемойСтрокиНаКлиенте(), НаименованиеНовогоЭлемента);
			
		КонецЕсли;
			
	КонецЕсли;			
	
	Если ПерваяЗаписьКурса
		ИЛИ (РедактируемаяСтрока <> Неопределено 
				И РедактируемаяСтрока.ТипЭлемента = ПредопределенноеЗначение("Перечисление.ТипыЭлементовСодержанияЭлектронногоКурса.Начало"))
		ИЛИ (ИдентификаторЕдинственнойСтрокиНавигационногоДерева > -1) Тогда
		
		Оповестить("ЭлектронныйКурсЗаписан",,ЭтотОбъект); // Оповещаем о сохранении
		
	КонецЕсли;
	
	Если ПерваяЗаписьКурса Тогда
		ОповеститьОЗаписиНового(ЭлектронныйКурс); // Оповещаем владельца
	КонецЕсли;
	
	Если ВыйтиИзРежимаРедактирования Тогда
		ВыйтиИзРежимаРедактирования(Ложь, ПерваяЗаписьКурса);
	КонецЕсли;	
	
	ПриРедактировании();
	
КонецПроцедуры

&НаСервере
Процедура СохранитьЭлементКурсаНаСервере(СвойстваФайла = Неопределено, НомерРедактируемойСтроки = Неопределено, НаименованиеНовогоЭлемента = Неопределено, ЭлементаСодержанияДляЗаписи = Неопределено)			
		
	НачатьТранзакцию();
	
	Попытка

		// Блокируем курс
		//
		
		Если ЗначениеЗаполнено(ЭлектронныйКурс) Тогда
			
		    БлокировкаДанных = Новый БлокировкаДанных;
		    ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Справочник.ЭлектронныеКурсы");
		    ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", ЭлектронныйКурс);
		    ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
		    БлокировкаДанных.Заблокировать();			
			
		КонецЕсли;
		
		// Создаем электронный курс
		//
		
		ЭтоПерваяЗаписьЭлектронногоКурса = Ложь;

		Если НЕ ЗначениеЗаполнено(ЭлектронныйКурс) Тогда			
			ЭтоПерваяЗаписьЭлектронногоКурса = Истина;			
			ЗаписатьНовыйЭлектронныйКурс();							
		КонецЕсли;
				
		РедактируемаяСтрока = Неопределено;
		
		Если НомерРедактируемойСтроки <> Неопределено Тогда				
			РедактируемаяСтрока = НавигационноеДерево.НайтиПоИдентификатору(НомерРедактируемойСтроки);
		КонецЕсли;
		
		Если РедактируемаяСтрока = Неопределено Тогда
			
			// Загружаем презентацию курса
			//
			
			Если СвойстваФайла <> Неопределено
				И СвойстваФайла.КонтекстФайла = "Presentation" Тогда
				
				РесурсПрезентации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлектронныйКурс, "Презентация");				
				
				ЭтоПерваяЗагрузкаПрезентации = Ложь;
				
				Если НЕ ЗначениеЗаполнено(РесурсПрезентации) Тогда
					
					ЭтоПерваяЗагрузкаПрезентации = Истина;
					
					// Создаем ресурс для хранения презентации
					
					РесурсПрезентацииОбъект = Справочники.ЭлектронныеРесурсы.СоздатьЭлемент();
					РесурсПрезентацииОбъект.Наименование = НСтр("ru = 'Презентация'");
					РесурсПрезентацииОбъект.Родитель = Справочники.ЭлектронныеКурсы.ГруппаДляХраненияПодчиненныхЭлементов(ЭлектронныйКурс, Тип("СправочникСсылка.ЭлектронныеРесурсы"));
					
					РазработкаЭлектронныхКурсовСлужебный.УстановитьПредпочитаемогоПоставщика(РесурсПрезентацииОбъект);
					
					РесурсПрезентацииОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
					РесурсПрезентацииОбъект.Записать();
					
					РесурсПрезентации = РесурсПрезентацииОбъект.Ссылка;							
					
					// Записываем ссылку на презентацию
					
					ЭлектронныйКурсОбъект = ЭлектронныйКурс.ПолучитьОбъект();
					ЭлектронныйКурсОбъект.Презентация = РесурсПрезентации;
					ЭлектронныйКурсОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", Параметры.КонтекстРедактирования);
					ЭлектронныйКурсОбъект.Записать();
					
				КонецЕсли;
				
				// Сохраняем файлы презентации
				
				СвойстваВладельца = РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ПустаяСтруктураСвойствВладельцаЗагружаемыхФайлов();
