
#Область ОписаниеПеременных

// Изучение

&НаКлиенте
Перем ВыполняетсяЗакрытиеФормы;

// Редактирование

&НаКлиенте
Перем ОписаниеДопустимыхТиповПеретаскивания; // Типы, которые можно перетаскивать в курс

&НаКлиенте
Перем ПропуститьАктивациюЭлементаСодержания; // Признак того, что не будет срабатывать обработчик "НавигационноеДеревоПриАктивизацииСтроки".

&НаКлиенте
Перем ПриложениеWord; //  Данные для работы с документами Word

&НаКлиенте
Перем ПриложениеPowerPoint; // Данные для работы с презентациями PowerPoint 

&НаКлиенте
Перем ПриложениеWriter; // Данные для работы с документами OpenOffice

&НаКлиенте
Перем ПриложениеImpress; // Данные для работы с презентациями OpenOffice

&НаКлиенте
Перем ПубликоватьПриЗакрытии;

&НаКлиенте
Перем ФайлыДляЗагрузки;

#КонецОбласти

#Область ОбработчикиСобытийФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Условное оформление
	//
	
	УстановитьУсловноеОформлениеСодержания();
	УстановитьУсловноеОформлениеТаблицыТерминов();
	
	// Копируем курс
	//
	
	Если Параметры.Свойство("ЗначениеКопирования") И ЗначениеЗаполнено(Параметры.ЗначениеКопирования) Тогда		
		Параметры.ЭлектронныйКурс = Справочники.ЭлектронныеКурсы.СкопироватьЭлектронныйКурс(Параметры.ЗначениеКопирования, Параметры.КонтекстРедактирования);
		Скопирован = Истина; // Запоминаем в реквизите формы факт копирования
	КонецЕсли;
	
	// Получаем основные переменные
	//
	
	ЭлектронныйКурс                 = Параметры.ЭлектронныйКурс;
	Учащийся                        = Параметры.Учащийся;
	Контекст                        = Параметры.Контекст;	
	РежимПроверки                   = Параметры.РежимПроверки;			
	ЗакрыватьПослеОкончанияОбучения = Параметры.ЗакрыватьПослеОкончанияОбучения;
	ИмяОповещенияПриЗакрытии        = "";
	
	ЕстьПравоИзменения = ПравоДоступа("Изменение", Метаданные.Справочники.ЭлектронныеКурсы);
	
	Если ЕстьПравоИзменения И Параметры.РежимРедактирования	Тогда		
		РежимИзучения = Ложь;
		РежимРедактирования = Истина; // Можно редактировать курс		
	Иначе		
		РежимИзучения = Истина;
		РежимРедактирования = Ложь;		
	КонецЕсли;
	
	РеквизитыДляПереопределения = Новый Структура;
	РеквизитыДляПереопределения.Вставить("ЭлектронныйКурс", ЭлектронныйКурс);
	РеквизитыДляПереопределения.Вставить("Контекст", Контекст);
	РеквизитыДляПереопределения.Вставить("Учащийся", Учащийся);
	РеквизитыДляПереопределения.Вставить("РежимПроверки", РежимПроверки);
	РеквизитыДляПереопределения.Вставить("РежимРедактирования", РежимРедактирования);
	РеквизитыДляПереопределения.Вставить("РежимИзучения", РежимИзучения);
	РеквизитыДляПереопределения.Вставить("ИмяОповещенияПриЗакрытии", ИмяОповещенияПриЗакрытии);
	РеквизитыДляПереопределения.Вставить("Отказ", Отказ);
	РеквизитыДляПереопределения.Вставить("Заголовок", ФиксированныйЗаголовок);
	РеквизитыДляПереопределения.Вставить("ЗакрыватьПослеОкончанияОбучения", ЗакрыватьПослеОкончанияОбучения);	
	
	РеквизитыДляПереопределенияСтандартнаяОбработка = Истина;	
	ЭлектронноеОбучениеПереопределяемый.ПриСозданииФормыЭлектронногоКурса(РеквизитыДляПереопределения, РеквизитыДляПереопределенияСтандартнаяОбработка);	
	
	Если НЕ РеквизитыДляПереопределенияСтандартнаяОбработка Тогда
		ЭлектронныйКурс = РеквизитыДляПереопределения.ЭлектронныйКурс; 	
		Контекст = РеквизитыДляПереопределения.Контекст;
		Учащийся = РеквизитыДляПереопределения.Учащийся;
		РежимПроверки = РеквизитыДляПереопределения.РежимПроверки;
		РежимРедактирования = РеквизитыДляПереопределения.РежимРедактирования;
		РежимИзучения = РеквизитыДляПереопределения.РежимИзучения;
		ИмяОповещенияПриЗакрытии = РеквизитыДляПереопределения.ИмяОповещенияПриЗакрытии;
		Отказ = РеквизитыДляПереопределения.Отказ;
		ФиксированныйЗаголовок = РеквизитыДляПереопределения.Заголовок;
		ЗакрыватьПослеОкончанияОбучения = РеквизитыДляПереопределения.ЗакрыватьПослеОкончанияОбучения;
	КонецЕсли;
	
	// Делаем проверки
	
	Если Отказ Тогда
		СтандартнаяОбработка = Ложь;
		Возврат;
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(Контекст) И НЕ ЗначениеЗаполнено(Учащийся) Тогда
		ВызватьИсключение НСтр("ru = 'Учащийся не задан.'");
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(Учащийся) И НЕ ЗначениеЗаполнено(Контекст) Тогда
		ВызватьИсключение НСтр("ru = 'Контекст не задан.'");
	КонецЕсли;	
	
	Если РежимИзучения 
		И (НЕ ЗначениеЗаполнено(ЭлектронныйКурс)
		ИЛИ ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЭлектронныйКурс, "ЭтоГруппа")) Тогда
		
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Электронный курс не задан'"),,,,Отказ);
		Возврат;
		
	КонецЕсли;		
	
	// Заполняем переменные формы.
	//	
	
	ИдентификаторРедактируемойСтрокиНавигационногоДерева = -1;
	ЕстьПравоАдминистратораСистемы = ПравоДоступа("Изменение", Метаданные.РегистрыСведений.ОбщиеНастройкиЭлектронногоОбучения);
	АдресОбщегоКаталога = РегистрыСведений.ОбщиеНастройкиЭлектронногоОбучения.Значение("АдресОбщегоКаталогаНаВебСервере");
	ПутьКОбщемуКаталогу = РегистрыСведений.ОбщиеНастройкиЭлектронногоОбучения.Значение("ПутьКОбщемуКаталогуНаВебСервере");	
	
	ЗаполнитьРеквизитыЭлектронногоКурса();

	ЭтоВебКлиент = СтандартныеПодсистемыСервер.ПараметрыКлиентаНаСервере().Получить("ЭтоВебКлиент");	
	ВыгружатьФайлыЛокально = ИзучениеЭлектронныхКурсовСлужебный.ФайлыВыгружаютсяЛокально(); 
	
	Если НЕ ВыгружатьФайлыЛокально Тогда	
		Если НЕ РегистрыСведений.ОбщиеНастройкиЭлектронногоОбучения.ОбщийКаталогНастроен(АдресОбщегоКаталога, ПутьКОбщемуКаталогу) Тогда				
			ОбщегоНазначения.СообщитьПользователю(
				НСтр("ru = 'Для использования электронных курсов в данном режиме необходимо настроить общий каталог.
				|Обратитесь к администратору.'"),,,,Отказ);
			Возврат;				
		КонецЕсли;
		АдресКаталогаЭлектронныхКурсов = ИзучениеЭлектронныхКурсовСлужебный.ПутьККаталогуЭлектронныхКурсов(АдресОбщегоКаталога);
		ПутьККаталогуЭлектронныхКурсов = ИзучениеЭлектронныхКурсовСлужебный.ПутьККаталогуЭлектронныхКурсов(ПутьКОбщемуКаталогу);
	КонецЕсли;	
	
	Если РежимИзучения Тогда
		ИзучениеЭлектронныхКурсовПереопределяемый.ПриСозданииФормыИзученияЭлектронногоКурса(ЭлектронныйКурс, Контекст, Учащийся);
	КонецЕсли;
	
	Если РежимИзучения И ЗначениеЗаполнено(Учащийся) И ЗначениеЗаполнено(Контекст) И ЗначениеЗаполнено(ЭлектронныйКурс) Тогда
		
		ИзучениеЭлектронногоКурса = Документы.ИзучениеЭлектронногоКурса.НайтиПоКонтексту(ЭлектронныйКурс, Контекст, Учащийся); 
		
		УстановитьПривилегированныйРежим(Истина); // Для доступа учащимся
		
		Если ЗначениеЗаполнено(ИзучениеЭлектронногоКурса) Тогда
			
			ДанныеИзучения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ИзучениеЭлектронногоКурса, "ДанныеИзучения").Получить();			
			
		Иначе
			
			ИзучениеЭлектронногоКурсаОбъект = Документы.ИзучениеЭлектронногоКурса.СоздатьДокумент();
			ИзучениеЭлектронногоКурсаОбъект.Дата = ТекущаяДатаСеанса();
			ИзучениеЭлектронногоКурсаОбъект.Контекст = Контекст;
			ИзучениеЭлектронногоКурсаОбъект.Учащийся = Учащийся;
			ИзучениеЭлектронногоКурсаОбъект.ЭлектронныйКурс = ЭлектронныйКурс;			
			ИзучениеЭлектронногоКурсаОбъект.Записать(РежимЗаписиДокумента.Проведение);
			
			ИзучениеЭлектронногоКурса = ИзучениеЭлектронногоКурсаОбъект.Ссылка;
			
		КонецЕсли;
		
		УстановитьПривилегированныйРежим(Ложь);
		
	КонецЕсли;
	
	Если РежимРедактирования И ЗначениеЗаполнено(ЭлектронныйКурс) Тогда
		Отредактирован = РегистрыСведений.ИзмененныеЭлектронныеКурсы.ЭлектронныйКурсОтредактированТекущимПользователем(ЭлектронныйКурс);
	КонецЕсли;		
	
	Если НЕ РежимРедактирования
		И ЗначениеЗаполнено(ИзучениеЭлектронногоКурса) Тогда
		
		ДатаНачалаПопыткиИзучения = ТекущаяДатаСеанса();
		
	КонецЕсли;			
	
	// Выгружаем данные на сервер
	//
	
	Если ЗначениеЗаполнено(ЭлектронныйКурс) И НЕ ВыгружатьФайлыЛокально Тогда
		
		ИзучениеЭлектронныхКурсовСлужебныйКлиентСервер.ВыполнитьНачальноеЗаполнениеКаталогаЭлектронныхКурсов(ПутьККаталогуЭлектронныхКурсов);
		
		Если ЗначениеЗаполнено(ИзучениеЭлектронногоКурса) Тогда
			ЗаписатьВКаталогДанныеИзучения(ПутьККаталогуЭлектронныхКурсов, ИзучениеЭлектронногоКурса, ДанныеИзучения);			
		КонецЕсли;
		
		Если НЕ РежимРедактирования Тогда
			ВыгрузитьДанныеПередПросмотром(ЭлектронныйКурс, ЭлектронныйКурс, ПутьККаталогуЭлектронныхКурсов, УникальныйИдентификатор);
		КонецЕсли;
		
	КонецЕсли;
	
	// Заполняем навигационное дерево
	//	
	
	ИдентификаторЕдинственнойСтрокиНавигационногоДерева = -1;
	
	Если ТипЭлектронногоКурса = Перечисления.ТипыЭлектронныхКурсов.Тест Тогда
		ИдентификаторЕдинственнойСтрокиНавигационногоДерева = 1;
	КонецЕсли;
	
	Если РежимРедактирования Тогда
		ЗаполнитьНавигационноеДерево();		
	КонецЕсли;
	
	// Устанавливаем начальное состояние элементов формы
	//	
	
	Если РежимРедактирования Тогда
		
		УстановитьВидимостьЭлементовРедактораКурса(Ложь, ЭтотОбъект);
		
		Если ТипЭлектронногоКурса = Перечисления.ТипыЭлектронныхКурсов.Слайдовый Тогда
			Элементы.РежимРедактированияСоздатьГруппу.Видимость = Ложь;			
		КонецЕсли;		
		
		Если ЭтоВебКлиент ИЛИ ТипЭлектронногоКурса = Перечисления.ТипыЭлектронныхКурсов.Слайдовый Тогда
			Элементы.РежимРедактированияЗагрузитьКаталог.Видимость = Ложь;
		КонецЕсли;
		
		Если ЭтоВебКлиент Тогда
			Элементы.РежимРедактированияЗагрузитьФайлы.Видимость = Ложь;
			Элементы.ГруппаМастерСозданияКомандаЗагрузки.Видимость = Ложь;
		КонецЕсли;
		
		Если ТипЭлектронногоКурса = Перечисления.ТипыЭлектронныхКурсов.Тест Тогда
			Элементы.ГруппаНавигация.Видимость = Ложь;
		Иначе
			Элементы.ГруппаНавигация.Видимость = Истина;
		КонецЕсли;
		
		Если ТипЭлектронногоКурса = Перечисления.ТипыЭлектронныхКурсов.Тест Тогда
			Элементы.НаименованиеТеста.Видимость = Истина;
		Иначе
			Элементы.НаименованиеТеста.Видимость = Ложь;
		КонецЕсли;
	
	Иначе
		
		Элементы.ГруппаНавигация.Видимость = Ложь; 
		Элементы.КоманднаяПанельРедактора.Видимость = Ложь;	
		Элементы.СтраницыРедактора.Видимость = Ложь;
		
	КонецЕсли;	
	
	УстановитьРедакторПрезентацийПоУмолчанию();
	
	
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)	
		
	Если ТипЗнч(Элементы.ОбластьПросмотра.Документ) = Тип("COMОбъект")
		И СтрНайти(Элементы.ОбластьПросмотра.ИнформацияПрограммыПросмотра, "Trident/7.0") = 0 Тогда
		
		Отказ = Истина;
		ОбщегоНазначенияКлиент.СообщитьПользователю(
			НСтр("ru = 'Для работы с электронными курсами требуется установить на компьютер InternetExplorer 11'"));
			
		Возврат;
		
	КонецЕсли;		
	
	Если ВыгружатьФайлыЛокально Тогда
				
		#Если ВебКлиент ИЛИ МобильныйКлиент Тогда
			
		ВызватьИсключение НСтр("ru = 'Функциональность выгрузки файлов в веб-клиенте не поддерживается'");
			
		#Иначе

		ПутьКОбщемуКаталогу = ОбщегоНазначенияКлиентСервер.ДобавитьКонечныйРазделительПути(КаталогВременныхФайлов());
		АдресОбщегоКаталога = ПутьКОбщемуКаталогу;
			
		АдресКаталогаЭлектронныхКурсов    = ИзучениеЭлектронныхКурсовСлужебныйКлиент.ПутьККаталогуЭлектронныхКурсов(АдресОбщегоКаталога);
		ПутьККаталогуЭлектронныхКурсов    = ИзучениеЭлектронныхКурсовСлужебныйКлиент.ПутьККаталогуЭлектронныхКурсов(ПутьКОбщемуКаталогу);			
		
		ИзучениеЭлектронныхКурсовСлужебныйКлиентСервер.ВыполнитьНачальноеЗаполнениеКаталогаЭлектронныхКурсов(ПутьККаталогуЭлектронныхКурсов, ОбщегоНазначенияКлиент.ДатаСеанса());
		
		Если ЗначениеЗаполнено(ИзучениеЭлектронногоКурса) Тогда		
			ЗаписатьВКаталогДанныеИзучения(ПутьККаталогуЭлектронныхКурсов, ИзучениеЭлектронногоКурса, ДанныеИзучения);		
		КонецЕсли;
		
		#КонецЕсли
	
	КонецЕсли;			
	
	Если РежимРедактирования Тогда
		
		Если ЗначениеЗаполнено(Параметры.ПутьККаталогуСФайламиКурса) Тогда
			
			#Если ВебКлиент ИЛИ МобильныйКлиент Тогда				
			ВызватьИсключение НСтр("ru = 'Функциональность загрузки файлов в веб-клиенте не поддерживается'");			
			#Иначе				
			ПодключитьОбработчикОжидания("ЗагрузитьФайлыСДискаВБазуПриОткрытииФормы", 0.5, Истина);					
			#КонецЕсли
			
		Иначе
			
			Если НЕ ЗначениеЗаполнено(ЭлектронныйКурс) Тогда			
				НаименованиеКурса = НаименованиеНовогоЭлектронногоКурса(ТипЭлектронногоКурса);
				ДобавитьЭлементКурса();			
			КонецЕсли;		
			
		КонецЕсли;		
		
	Иначе		
		
		Если ЗначениеЗаполнено(ЭлектронныйКурс) И ВыгружатьФайлыЛокально Тогда
			ВыгрузитьДанныеПередПросмотром(ЭлектронныйКурс, ЭлектронныйКурс, ПутьККаталогуЭлектронныхКурсов, УникальныйИдентификатор);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Параметры.ЭлементСодержания) Тогда			
			УстановитьЭлементДляПросмотра(Параметры.ЭлементСодержания);
		Иначе
			УстановитьЭлементДляПросмотра(ЭлектронныйКурс);
		КонецЕсли;
		
	КонецЕсли;	
	
	Если Скопирован Тогда
		
		Оповестить("ЭлектронныйКурсЗаписан",,ЭлектронныйКурс);
		
		Если ТипЭлектронногоКурса = ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.SCORM") Тогда
			// При копировании курса SCORM надо его опубликовать при открытии, так как он не редактируется
			// и не будет опубликован при закрытии формы, как другие курсы.
			Отказ = Истина;			
			ИдентификаторЗаданияПубликации = ЗафиксироватьРедактирование(ЭлектронныйКурс, Истина, УникальныйИдентификатор, Параметры.КонтекстРедактирования);
			Если ЗначениеЗаполнено(ИдентификаторЗаданияПубликации) Тогда
				Оповестить("ВыполняетсяПубликацияЭлектронногоКурса", ИдентификаторЗаданияПубликации, Строка(ЭлектронныйКурс.УникальныйИдентификатор()));
			КонецЕсли;			
		КонецЕсли;		
		
	КонецЕсли;	
	
	Если ИдентификаторЕдинственнойСтрокиНавигационногоДерева > -1 Тогда
		ПодключитьОбработчикОжидания("АктивироватьЭлементСодержанияЧерезОбработчик", 0.01, Истина); //Web-client 404 bug
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если ЗавершениеРаботы = Неопределено Тогда
		ЗавершениеРаботы = Ложь;
	КонецЕсли;
	
	Если ВыполняетсяЗакрытиеФормы Тогда
		Возврат; // Никакие проверки не делаем
	КонецЕсли;
	
	Если РежимРедактирования Тогда
		
		Если НЕ Модифицированность
			И РазработкаЭлектронныхКурсовСлужебныйКлиент.ДокументWordМодифицирован(ПриложениеWord) Тогда
			
			Модифицированность = Истина;
			
		КонецЕсли;			
		
		Если Модифицированность Тогда
			
			Отказ = Истина;
			
			Если ЗавершениеРаботы Тогда				
				ТекстПредупреждения = НСтр("ru = 'Несохраненные изменения электронного курса будут потеряны.'");				
			Иначе				
				ВыйтиИзРежимаРедактирования(Истина);				
			КонецЕсли;
			
			Возврат;
			
		КонецЕсли;
		
		Если Отредактирован Тогда
						
			Если ЗавершениеРаботы Тогда				
				
				Отказ = Истина;
				ТекстПредупреждения = НСтр("ru = 'Электронный курс отредактирован, но не опубликован.
				|Если программа будет закрыта, то внесенные изменения не будут доступны для изучения.'");
				Возврат;
				
			Иначе
				
				ИдентификаторЗаданияПубликации = ЗафиксироватьРедактирование(ЭлектронныйКурс, ПубликоватьПриЗакрытии, УникальныйИдентификатор, Параметры.КонтекстРедактирования);

				Если ЗначениеЗаполнено(ИдентификаторЗаданияПубликации) Тогда
					Оповестить("ВыполняетсяПубликацияЭлектронногоКурса", ИдентификаторЗаданияПубликации, Строка(ЭлектронныйКурс.УникальныйИдентификатор()));
				КонецЕсли;
				
			КонецЕсли;
			
		КонецЕсли;
		
	Иначе	
					
		Если ЗавершениеРаботы И ТипЭлектронногоКурса <> ПредопределенноеЗначение("Перечисление.ТипыЭлектронныхКурсов.Тест") Тогда			
			Отказ = Истина;			
			ТекстПредупреждения = НСтр("ru = 'Изучение электронного курса будет прервано без сохранения последних результатов.
			|Перед выходом из программы закройте все открытые электронные курсы для сохранения данных об изучении.'");			
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	Если РежимИзучения 
		И ЗначениеЗаполнено(ИзучениеЭлектронногоКурса) 
		И Элементы.ОбластьПросмотра.Видимость
		И НЕ ЗавершениеРаботы Тогда
	
		Если ТипЗнч(Элементы.ОбластьПросмотра.Документ) = Тип("COMОбъект") Тогда
			ВыполняетсяЗакрытиеФормы = Истина;
			ОбластьПросмотра = "about:blank";
			Отказ = Истина;
			ПодключитьОбработчикОжидания("Подключаемый_ЗакрытьФорму", 3, Истина); // На случай сбоя в поле HTML
			Возврат;
		КонецЕсли;
		
		Если ТипЗнч(Элементы.ОбластьПросмотра.Документ) <> Тип("COMОбъект") Тогда
			Отказ = Истина;
			ВыполняетсяЗакрытиеФормы = Истина;
			РезультатСкрипта = ЭлектронноеОбучениеСлужебныйКлиент.ВыполнитьСкрипт(Элементы.ОбластьПросмотра.Документ, "var v8LearningDataBeforeClose = getLearningData();", "other");
			#Если ВебКлиент Тогда
			ДанныеИзучения = Элементы.ОбластьПросмотра.Документ.getElementById("v8ExchangeData").innerText;	
			#Иначе			
			ДанныеИзучения = Элементы.ОбластьПросмотра.Документ.window.v8LearningDataBeforeClose;
			#КонецЕсли
			СохранитьДанныеИзучения(Истина);
		КонецЕсли;
		
	КонецЕсли;
		
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	
	Если ЗавершениеРаботы = Неопределено Тогда
		ЗавершениеРаботы = Ложь;
	КонецЕсли;	
	
	Если РежимРедактирования Тогда
		РазработкаЭлектронныхКурсовСлужебныйКлиент.ПриЗакрытииФормыДокументаWord(ПриложениеWord, Истина, ЭтотОбъект, ЗавершениеРаботы);
		РазработкаЭлектронныхКурсовСлужебныйКлиент.ПриЗакрытииФормыДокументаWriter(ПриложениеWriter, ЭтотОбъект, ЗавершениеРаботы);
		ЗакрытьПрезентациюPowerPoint(Истина, ЗавершениеРаботы);
		ЗакрытьПрезентациюOpenOffice(Истина, ЗавершениеРаботы);
	КонецЕсли;
	
	Если ЗавершениеРаботы Тогда
		Возврат;
	ИначеЕсли ЗначениеЗаполнено(ИмяОповещенияПриЗакрытии) Тогда		
		Оповестить(ИмяОповещенияПриЗакрытии, ВладелецФормы, ЭтотОбъект);
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
		
	Если ИмяСобытия = "ПодборкаОбновлена"
		И ВыполняетсяРедактированиеЭлемента() Тогда
		
		ПриРедактировании();
		ПросмотретьСтраницуЭлементаКурса();
		
	КонецЕсли;
	
		
	Если ИмяСобытия = "ТерминГлоссарияОбновлен"
		И ВыполняетсяРедактированиеЭлемента() Тогда
		
		ПриРедактировании();
		
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ОбластьПросмотраПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	Если ДанныеСобытия = Неопределено Тогда		
		Возврат;		
	КонецЕсли;
	
	Если ВыполняетсяЗакрытиеФормы Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИзучениеЭлектронногоКурса) И ДанныеСобытия.Element.id = "v8ExchangeData" Тогда	
		СтандартнаяОбработка = Ложь;	
		ДанныеИзучения = ДанныеСобытия.Element.innerText;				
		Если ЗначениеЗаполнено(ДанныеИзучения) Тогда			
			ПодключитьОбработчикОжидания("Подключаемый_СохранитьДанныеИзучения", 0.01, Истина);
		КонецЕсли;		
	КонецЕсли;
	
	Если ДанныеСобытия.Element.id = "v8OpenItem" Тогда
		СтандартнаяОбработка = Ложь;
		Попытка
			ИдентификаторЭлементаСодержания = Новый УникальныйИдентификатор(ДанныеСобытия.Element.innerText);
		Исключение
			ВызватьИсключение НСтр("ru = 'Неверный формат идентификатора элемента содержания'");
		КонецПопытки;
	    ОткрытьЭлементСодержанияВНовомОкне(ИдентификаторЭлементаСодержания);
	КонецЕсли;
	
	Если ДанныеСобытия.Element.id = "regE1clinkMimeType" Тогда
		СтандартнаяОбработка = Ложь;
		РазработкаЭлектронныхКурсовСлужебныйКлиент.ЗарегистрироватьЯрлыкиДляLinux(ПриложениеWriter);
	КонецЕсли;
	
	Если ДанныеСобытия.Element.id = "v8DownloadFile" Тогда
		СтандартнаяОбработка = Ложь;
		ФайловаяСистемаКлиент.ОткрытьФайл(АдресКаталогаЭлектронныхКурсов + ДанныеСобытия.Element.innerText);
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ОбластьПросмотраДокументСформирован(Элемент)
	Если ВыполняетсяЗакрытиеФормы И ОбластьПросмотра = "about:blank" Тогда
		ПодключитьОбработчикОжидания("Подключаемый_ЗакрытьФорму", 0.01, Истина);
	КонецЕсли;		
КонецПроцедуры

