
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УстановитьЗначенияОтборов();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписок

&НаСервереБезКонтекста
Процедура СписокПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	Для Каждого Строка Из Строки Цикл
		ОформлениеЯчейки = Строка.Значение.Оформление["ЭтапРаботы"];
		ОформлениеЯчейки.УстановитьЗначениеПараметра("Текст", СтрШаблон("этап %1", Строка.Значение.Данные.ЭтапРаботы));
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ВыбратьИЗакрыть();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Выбрать(Команда)
	ВыбратьИЗакрыть();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьЗначенияОтборов()
	
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(
		Список,
		"ЭлектронныйКурс",
		Параметры.ИнструментОценки,
		Истина);
	
	Если Параметры.Свойство("Объект") И ЗначениеЗаполнено(Параметры.Объект) Тогда
		ГруппаОтбора = ОбщегоНазначенияКлиентСервер.СоздатьГруппуЭлементовОтбора(
			Список.Отбор.Элементы,
			НСтр("ru = 'Отбор по объекту и этапу'"),
			ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаНе);
		
		ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(
			ГруппаОтбора,
			"Объект",
			ВидСравненияКомпоновкиДанных.Равно,
			Параметры.Объект,,Истина);

		ОбщегоНазначенияКлиентСервер.ДобавитьЭлементКомпоновки(
			ГруппаОтбора,
			"ЭтапРаботы",
			ВидСравненияКомпоновкиДанных.Равно,
			Параметры.ЭтапРаботы,,Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьИЗакрыть()
	
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		СтруктураВыбора = Новый Структура;
		СтруктураВыбора.Вставить("ОбъектКопирования", ТекущиеДанные.Объект);
		СтруктураВыбора.Вставить("ЭтапРаботы", ТекущиеДанные.ЭтапРаботы);
		Закрыть(СтруктураВыбора);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти