#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Вакансия = Параметры.Вакансия;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ЗаполнитьАдресРезюмеИзБуфераОбмена();
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)

	Если ИмяСобытия = "ЗагрузкаРезюмеЗавершена" И Источник = ЭтотОбъект Тогда
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПродолжитьРаботу(Команда)
	НачатьЗагрузкуКандидата();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура НачатьЗагрузкуКандидата()
	РекрутинговыеСайтыКлиент.НачатьСозданиеКандидатаПоАдресуРезюме(ЭтотОбъект,
		РекрутинговыеСайтыКлиентСервер.АдресРезюмеПоUrlРезюме(UrlРезюме), Вакансия);
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьАдресРезюмеИзБуфераОбмена()
	
	Если Не ДоступнаРаботаСБуферомОбмена() Тогда
		Возврат;
	КонецЕсли;
	
	Объект = Новый COMОбъект("htmlfile");
	СтрокаИзБуфера = Объект.ParentWindow.ClipboardData.Getdata("Text");
	
	Если Не ЭтоАдресРезюме(СтрокаИзБуфера) Тогда
		Возврат;
	КонецЕсли;
	
	UrlРезюме = СтрокаИзБуфера;
	
КонецПроцедуры

&НаКлиенте
Функция ДоступнаРаботаСБуферомОбмена()

	#Если Не ВебКлиент И Не МобильныйКлиент Тогда
		Возврат ОбщегоНазначенияКлиент.ЭтоWindowsКлиент();
	#КонецЕсли
	
	Возврат Ложь;
	
КонецФункции

&НаСервереБезКонтекста
Функция ЭтоАдресРезюме(СтрокаИзБуфера)
	
	Возврат РекрутинговыеСайты.ЭтоАдресРезюме(СтрокаИзБуфера);
	
КонецФункции

#КонецОбласти