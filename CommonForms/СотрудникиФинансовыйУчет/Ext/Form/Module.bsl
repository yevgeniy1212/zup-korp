
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Параметры, "Заголовок, СотрудникСсылка, ДатаПриема, СозданиеНового");
	
	ПроинициализироватьФорму(Параметры.АдресВХранилище);
	
	Если ДоступенПросмотрФинансовыйУчетСотрудников Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы,
			"ФинансовыйУчетСотрудниковПериодСтрокой",
			"ТолькоПросмотр",
			Не ДоступноРедактированиеФинансовыйУчетСотрудников);
	КонецЕсли;
	
	КадровыеДанные = КадровыйУчет.КадровыеДанныеСотрудников(Истина, СотрудникСсылка, "МестоВСтруктуреПредприятия,ФизическоеЛицо", ОбщегоНазначения.ТекущаяДатаПользователя());
	
	Если КадровыеДанные.Количество() > 0 Тогда
		ТекущееПодразделение = КадровыеДанные[0].МестоВСтруктуреПредприятия;
		ФизическоеЛицоСсылка = КадровыеДанные[0].ФизическоеЛицо;
	КонецЕсли; 
	
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(РаспределениеРасходов, "Сотрудник", СотрудникСсылка);
	ОбщегоНазначенияКлиентСервер.УстановитьПараметрДинамическогоСписка(РаспределениеРасходов, "ФизическоеЛицо", ФизическоеЛицоСсылка);
	
	СформироватьОписаниеОтсутствияДокументов();
	
	ПроверитьРаспределениеРасходовСотрудника();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	СотрудникиКлиент.ЗарегистрироватьОткрытиеФормы(ЭтотОбъект, ИмяФормы);
	СотрудникиКлиент.ПроверитьРежимТолькоПросмотраДополнительнойФормы(ЭтотОбъект, Истина, Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Оповещение = Новый ОписаниеОповещения("СохранитьИЗакрыть", ЭтотОбъект);
	ОбщегоНазначенияКлиент.ПоказатьПодтверждениеЗакрытияФормы(Оповещение, Отказ, ЗавершениеРаботы, ТекстПредупреждения);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	ФинансовыйУчетКлиент.ФинансовыйУчетОбработкаОповещения(ЭтотОбъект, ИмяСобытия, Параметр, Источник, "СотрудникСсылка");
	
	Если ИмяСобытия = "Запись_РаспределениеРасходовНаПерсонал" Тогда
		ПроверитьРаспределениеРасходовСотрудника();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	Если ДоступенПросмотрФинансовыйУчетСотрудников Тогда
		РедактированиеПериодическихСведений.ПроверитьЗаписьВФорме(ЭтотОбъект, "ФинансовыйУчетСотрудников", СотрудникСсылка, Отказ);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

#Область ФинансовыйУчетРасходовСотрудников

&НаКлиенте
Процедура СпособОтраженияПриИзменении(Элемент)
	
	Если Не ФинансовыйУчетСотрудниковЗаблокироватьСотрудника() Тогда
		Возврат;
	КонецЕсли;
	
	ФинансовыйУчетКлиентСервер.ОбновитьПолеСведенияОФинансовомУчетеПериод(
		ЭтотОбъект, ОбщегоНазначенияКлиент.ДатаСеанса(), "ФинансовыйУчетСотрудников", "СотрудникСсылка");
	
КонецПроцедуры

&НаКлиенте
Процедура СпособОтраженияВФинансовомУчетеНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	Если Не ФинансовыйУчетСотрудниковЗаблокироватьСотрудника() Тогда
		СтандартнаяОбработка = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ФинансовыйУчетСотрудниковПериодСтрокойПриИзменении(Элемент)
	ЗарплатаКадрыКлиент.ВводМесяцаПриИзменении(ЭтотОбъект, "ФинансовыйУчетСотрудников.Период", "ФинансовыйУчетСотрудниковПериодСтрокой", Модифицированность);
КонецПроцедуры

&НаКлиенте
Процедура ФинансовыйУчетСотрудниковПериодСтрокойНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ЗарплатаКадрыКлиент.ВводМесяцаНачалоВыбора(
		ЭтотОбъект,
		ЭтотОбъект,
		"ФинансовыйУчетСотрудников.Период",
		"ФинансовыйУчетСотрудниковПериодСтрокой");
	
КонецПроцедуры

&НаКлиенте
Процедура ФинансовыйУчетСотрудниковПериодСтрокойРегулирование(Элемент, Направление, СтандартнаяОбработка)
	ЗарплатаКадрыКлиент.ВводМесяцаРегулирование(ЭтотОбъект, "ФинансовыйУчетСотрудников.Период", "ФинансовыйУчетСотрудниковПериодСтрокой", Направление, Модифицированность);
КонецПроцедуры

&НаКлиенте
Процедура ФинансовыйУчетСотрудниковПериодСтрокойАвтоПодбор(Элемент, Текст, ДанныеВыбора, Ожидание, СтандартнаяОбработка)
	ЗарплатаКадрыКлиент.ВводМесяцаАвтоПодборТекста(Текст, ДанныеВыбора, СтандартнаяОбработка);
КонецПроцедуры

&НаКлиенте
Процедура ФинансовыйУчетСотрудниковПериодСтрокойОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, СтандартнаяОбработка)
	ЗарплатаКадрыКлиент.ВводМесяцаОкончаниеВводаТекста(Текст, ДанныеВыбора, СтандартнаяОбработка);
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура ОписаниеОтсутствияДокументовОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
		
	Если НавигационнаяСсылкаФорматированнойСтроки = "ДобавитьНовоеРаспределение" Тогда
		СтандартнаяОбработка = Ложь;
		ВвестиНовоеРаспределениеРасходов();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыРаспределениеРасходов

&НаКлиенте
Процедура РаспределениеРасходовПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	
	Если Параметр = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗначенияЗаполнения = Новый Структура("Сотрудник", СотрудникСсылка);
	
	Если ЗначениеЗаполнено(ТекущееПодразделение) Тогда
		ЗначенияЗаполнения.Вставить("Подразделение", ТекущееПодразделение);
	КонецЕсли; 
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
	
	Отказ = Истина;
	ОткрытьФорму("Документ.РаспределениеРасходовНаПерсонал.ФормаОбъекта", ПараметрыФормы);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура РаспределениеРасходовПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	Если Строки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ПолученныеКлючи = Строки.ПолучитьКлючи();
	ДанныеСтроки = Строки[ПолученныеКлючи[0]].Данные;
	Если Не ДанныеСтроки.Свойство("ПредставлениеРаспределения") Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Документы", ОбщегоНазначения.ВыгрузитьКолонку(ПолученныеКлючи, "Ссылка"));
	Запрос.УстановитьПараметр("Сотрудник", ДанныеСтроки.Сотрудник);
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	РаспределениеРасходов.Ссылка КАК Документ,
		|	РаспределениеРасходов.СпособОтражения КАК СпособОтражения,
		|	РаспределениеРасходов.ДоляРаспределения КАК ДоляРаспределения
		|ИЗ
		|	Документ.РаспределениеРасходовНаПерсонал.РаспределениеРасходов КАК РаспределениеРасходов
		|ГДЕ
		|	РаспределениеРасходов.Ссылка В (&Документы)
		|	И РаспределениеРасходов.ИдентификаторСтрокиСотрудника В
		|		(ВЫБРАТЬ
		|			Сотрудники.ИдентификаторСтрокиСотрудника КАК ИдентификаторСтрокиСотрудника
		|		ИЗ
		|			Документ.РаспределениеРасходовНаПерсонал.Сотрудники КАК Сотрудники
		|		ГДЕ
		|			Сотрудники.Ссылка В (&Документы)
		|			И Сотрудники.Сотрудник = &Сотрудник)";
	
	Данные = Запрос.Выполнить().Выгрузить();
	Данные.Индексы.Добавить("Документ");
	
	Для Каждого КлючЗначение Из Строки Цикл
		ТаблицаРаспределения = Данные.Скопировать(Новый Структура("Документ", КлючЗначение.Ключ.Ссылка));
		СтруктураРаспределения = ЗарплатаКадрыРасширенный.ТаблицаЗначенийВСтруктуру(ТаблицаРаспределения);
		КлючЗначение.Значение.Данные["ПредставлениеРаспределения"] =
			ФинансовыйУчетКлиентСервер.ПредставлениеРаспределенияСтроки(СтруктураРаспределения);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ФинансовыйУчетСотрудниковИстория(Команда)
	ОткрытьФормуРедактированияИсторииФинансовыйУчет();
КонецПроцедуры

&НаКлиенте
Процедура ОК(Команда)
	СохранитьИЗакрытьНаКлиенте();
КонецПроцедуры

&НаКлиенте
Процедура Отмена(Команда)
	
	Модифицированность = Ложь;
	Закрыть();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПроинициализироватьФорму(АдресВХранилище)
	
	УстановитьЗначенияПравДоступа();
	
	СотрудникиФормы.ПрочитатьДанныеИзХранилищаВФорму(
		ЭтотОбъект,
		СотрудникиКлиентСервер.ОписаниеДополнительнойФормы(ИмяФормы),
		АдресВХранилище);
	
	Если ФинансовыйУчетСотрудниковПрежняя = Неопределено Тогда
		ПрочитатьДанныеФинансовогоУчетаДляРедактированияВФорме();
	КонецЕсли;
	
	ФинансовыйУчетКлиентСервер.ОбновитьПолеСведенияОФинансовомУчетеПериод(
		ЭтотОбъект, ТекущаяДатаСеанса(), "ФинансовыйУчетСотрудников", "СотрудникСсылка");
	
	РедактированиеРазрешено = ДоступноРедактированиеФинансовыйУчетСотрудников;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ФормаOK",
		"Видимость",
		РедактированиеРазрешено);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ФормаОтмена",
		"Заголовок",
		?(РедактированиеРазрешено, НСтр("ru = 'Отмена'"), НСтр("ru = 'Закрыть'")));
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ФормаOK",
		"КнопкаПоУмолчанию",
		РедактированиеРазрешено);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ФормаОтмена",
		"КнопкаПоУмолчанию",
		НЕ РедактированиеРазрешено);
	
КонецПроцедуры

&НаКлиенте
Функция ЗаблокироватьОбъектВФормеВладельце() Экспорт
	Возврат СотрудникиКлиент.ЗаблокироватьОбъектВФормеВладельцеДополнительнойФормы(ЭтотОбъект, Истина, Ложь);
КонецФункции

&НаСервере
Процедура ПрочитатьДанныеФинансовогоУчетаДляРедактированияВФорме()
	
	Если Не ДоступенПросмотрФинансовыйУчетСотрудников Тогда
		Возврат;
	КонецЕсли;
	
	РедактированиеПериодическихСведений.ПрочитатьЗаписьДляРедактированияВФорме(ЭтотОбъект, "ФинансовыйУчетСотрудников", СотрудникСсылка);
	
	Период = ФинансовыйУчетСотрудников.Период;
	Если ЗначениеЗаполнено(Период) Тогда
		НаборЗаписей = РегистрыСведений.ФинансовыйУчетСотрудников.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Сотрудник.Установить(СотрудникСсылка);
		НаборЗаписей.Отбор.Период.Установить(Период);
		НаборЗаписей.Прочитать();
	КонецЕсли;
	
	СтруктураЗаписиСтрокой = "";
	НужнаЗапятая = Ложь;
	Для Каждого КлючЗначение Из ФинансовыйУчетСотрудниковПрежняя Цикл
		Если НужнаЗапятая Тогда
			СтруктураЗаписиСтрокой = СтруктураЗаписиСтрокой + ",";
		КонецЕсли;
		СтруктураЗаписиСтрокой = СтруктураЗаписиСтрокой + КлючЗначение.Ключ;
		НужнаЗапятая = Истина;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьНаборЗаписейПериодическихСведенийПоСтруктуре(ИмяРегистра, СтруктураВедущихОбъектов) Экспорт
	РедактированиеПериодическихСведений.ПрочитатьНаборЗаписейПоСтруктуре(ЭтотОбъект, ИмяРегистра, СтруктураВедущихОбъектов);
КонецПроцедуры

&НаСервере
Процедура ПрочитатьНаборЗаписейПериодическихСведений(ИмяРегистра, ВедущийОбъект) Экспорт
	РедактированиеПериодическихСведений.ПрочитатьНаборЗаписей(ЭтотОбъект, ИмяРегистра, ВедущийОбъект);
КонецПроцедуры

&НаСервере
Функция АдресДанныхДополнительнойФормыНаСервере(ОписаниеДополнительнойФормы)
	Возврат СотрудникиФормы.АдресДанныхДополнительнойФормы(ОписаниеДополнительнойФормы, ЭтотОбъект);
КонецФункции

&НаКлиенте
Процедура СохранитьИЗакрыть(Результат, ДополнительныеПараметры) Экспорт 
	СохранитьИЗакрытьНаКлиенте();
КонецПроцедуры

&НаКлиенте
Процедура СохранитьИЗакрытьНаКлиенте(ЗакрытьФорму = Истина) Экспорт 

	Если НЕ ТолькоПросмотр Тогда
		ТекущийЭлемент = Элементы.ФормаOK;
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура("ЗакрытьФорму", ЗакрытьФорму);
	
	Оповещение = Новый ОписаниеОповещения("СохранитьИЗакрытьНаКлиентеЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	СохранитьДанные(Ложь, Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьИЗакрытьНаКлиентеЗавершение(Отказ, ДополнительныеПараметры) Экспорт 

	Если Не Отказ И Открыта() Тогда
		Модифицированность = Ложь;
		Если ДополнительныеПараметры.ЗакрытьФорму Тогда
			Закрыть();
		КонецЕсли; 
	КонецЕсли; 
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьДанные(Отказ, ОповещениеЗавершения = Неопределено)
	
	Если Не Модифицированность Тогда
		Если ОповещениеЗавершения <> Неопределено Тогда 
			ВыполнитьОбработкуОповещения(ОповещениеЗавершения, Отказ);
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	Если Не СозданиеНового
		И Не Отказ Тогда
		
		Если ДоступноРедактированиеФинансовыйУчетСотрудников Тогда
			ФинансовыйУчетСотрудниковЗапроситьРежимИзменения(ФинансовыйУчетСотрудников.Период, Отказ, ОповещениеЗавершения);
		Иначе
			СохранитьДанныеЗавершение(Отказ, ОповещениеЗавершения);
		КонецЕсли;
		
	Иначе
		СохранитьДанныеЗавершение(Отказ, ОповещениеЗавершения);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьДанныеЗавершение(Отказ, ОповещениеЗавершения) Экспорт 
	
	Если Не Отказ Тогда
		Если ПроверитьЗаполнение() Тогда
			ВозвращаемыйПараметр = Новый Структура;
			ВозвращаемыйПараметр.Вставить("ИмяФормы", ИмяФормы);
			ВозвращаемыйПараметр.Вставить("АдресВХранилище", АдресДанныхДополнительнойФормыНаСервере(СотрудникиКлиентСервер.ОписаниеДополнительнойФормы(ИмяФормы)));
			Оповестить("ИзмененыДанныеДополнительнойФормы", ВозвращаемыйПараметр, ВладелецФормы);
		Иначе
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли; 
	
	Если ОповещениеЗавершения <> Неопределено Тогда 
		ВыполнитьОбработкуОповещения(ОповещениеЗавершения, Отказ);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьЗначенияПравДоступа()
	
	ДоступенПросмотрФинансовыйУчетСотрудников = ПравоДоступа("Просмотр", Метаданные.РегистрыСведений.ФинансовыйУчетСотрудников);
	ДоступноРедактированиеФинансовыйУчетСотрудников = ПравоДоступа("Изменение", Метаданные.РегистрыСведений.ФинансовыйУчетСотрудников);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуРедактированияИсторииФинансовыйУчет()
	СотрудникиКлиент.ОткрытьФормуРедактированияИстории("ФинансовыйУчетСотрудников", СотрудникСсылка, ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура ФинансовыйУчетСотрудниковЗапроситьРежимИзменения(ДатаИзменения, Отказ, ОповещениеЗавершения)
	
	ДополнительныеПараметры = Новый Структура("ОповещениеЗавершения", ОповещениеЗавершения);
	Оповещение = Новый ОписаниеОповещения("ФинансовыйУчетСотрудниковЗапроситьРежимИзмененияЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	
	ТекстКнопкиДа = НСтр("ru = 'Изменился финансовый учет'");
	ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru =  'При редактировании изменился финансовый учет для сотрудника. 
					|Если просто исправлены прежние данные (они были ошибочны), нажмите ""Исправлена ошибка"".
					|Если финансовый учет сотрудника изменился с %1, нажмите ""Изменился финансовый учет""'"), 
		Формат(ДатаИзменения, "ДЛФ=DD"));
	
	РедактированиеПериодическихСведенийКлиент.ЗапроситьРежимИзмененияРегистра(ЭтотОбъект, "ФинансовыйУчетСотрудников", ТекстВопроса, ТекстКнопкиДа, Отказ, Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура ФинансовыйУчетСотрудниковЗапроситьРежимИзмененияЗавершение(Отказ, ДополнительныеПараметры) Экспорт 
	СохранитьДанныеЗавершение(Отказ, ДополнительныеПараметры.ОповещениеЗавершения);
КонецПроцедуры

&НаКлиенте
Функция ФинансовыйУчетСотрудниковЗаблокироватьСотрудника()
	
	Если Не ЗаблокироватьОбъектВФормеВладельце() Тогда
		ЗаполнитьЗначенияСвойств(ФинансовыйУчетСотрудников, ФинансовыйУчетСотрудниковПрежняя);
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

&НаКлиенте
Процедура ВвестиНовоеРаспределениеРасходов()
	
	ЗначенияЗаполнения = Новый Структура("Сотрудник, Подразделение", СотрудникСсылка, ТекущееПодразделение);
	
	ПараметрыФормы = Новый Структура("ЗначенияЗаполнения");
	ПараметрыФормы.ЗначенияЗаполнения = ЗначенияЗаполнения;
	
	ОткрытьФорму("Документ.РаспределениеРасходовНаПерсонал.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьРаспределениеРасходовСотрудника()
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ФизическоеЛицо", ФизическоеЛицоСсылка);
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ИСТИНА
		|ИЗ
		|	Документ.РаспределениеРасходовНаПерсонал КАК РаспределениеРасходовНаПерсонал
		|ГДЕ
		|	РаспределениеРасходовНаПерсонал.Проведен
		|	И ИСТИНА В
		|		(ВЫБРАТЬ ПЕРВЫЕ 1
		|			ИСТИНА
		|		ИЗ
		|			РегистрСведений.СоставДокументовЗарплатаКадры КАК СоставДокументовЗарплатаКадры
		|		ГДЕ
		|			СоставДокументовЗарплатаКадры.ФизическоеЛицо В (&ФизическоеЛицо)
		|			И РаспределениеРасходовНаПерсонал.Ссылка = СоставДокументовЗарплатаКадры.ДокументФизическогоЛица)";
	
	Если Запрос.Выполнить().Пустой() Тогда
		Элементы.РаспределениеРасходовСтраницы.ТекущаяСтраница = Элементы.РаспределениеРасходовПустаяСтраница;
	Иначе
		Элементы.РаспределениеРасходовСтраницы.ТекущаяСтраница = Элементы.РаспределениеРасходовДокументы;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьОписаниеОтсутствияДокументов()
	
	МассивСтрок = Новый Массив;
	
	МассивСтрок.Добавить(НСтр("ru = 'Пока нет ни одного документа распределения расходов.
		|Если требуется распределять расходы сотрудника более, чем одним способом одновременно'"));
	
	МассивСтрок.Добавить(", ");
	
	СтрокаСсылки = Новый ФорматированнаяСтрока(НСтр("ru = 'добавьте новый документ'"),,,, "ДобавитьНовоеРаспределение");
	МассивСтрок.Добавить(СтрокаСсылки);
	
	ОписаниеОтсутствияДокументов = Новый ФорматированнаяСтрока(МассивСтрок);
	
КонецПроцедуры

#КонецОбласти
