	ПараметрыФормы.Вставить("ИнструментОценки", ЭлектронныйКурс);
	
	ОткрытьФорму("ОбщаяФорма.СкопироватьНастройкиЭлектронногоТеста",
		ПараметрыФормы,
		ЭтаФорма,
		УникальныйИдентификатор,,,
		Оповещение);
	
КонецПроцедуры

