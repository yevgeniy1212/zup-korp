&НаКлиентеНаСервереБезКонтекста
Процедура ОбновитьДоступностьВариантУчетаКадровыхПерестановок(Форма)
	Форма.Элементы.РасчетСреднегоЗаработкаОрганизацийВариантУчетаКадровыхПерестановок.Доступность = Форма.РасчетСреднегоЗаработкаОрганизаций.РассчитыватьКоэффициентИндексацииВПределахКадровыхПерестановок;
КонецПроцедуры

&НаСервере
Функция ПолучитьМассивЗаписейНабораПорядокОкругления()
	
	СтруктураЗаписиСтрокой = "Период, Организация, ВидРасчета, СпособОкругления";
	
	МассивЗаписей = Новый Массив();
	Для Каждого Строка Из ЭтаФорма["ПорядокОкругленияРезультатовРасчетаЗарплатыНаборЗаписей"] Цикл
		НоваяСтрока = Новый Структура(СтруктураЗаписиСтрокой);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
		МассивЗаписей.Добавить(НоваяСтрока);
	КонецЦикла;
	
	Возврат МассивЗаписей;
	
КонецФункции

&НаСервере
Функция ПолучитьМассивЗаписейНабораСрокиПеречисленияВзносовИОтчислений()
	
	СтруктураЗаписиСтрокой = "Период, Организация, ВидНалогаВзносаОтчисления, ДатаПеречисленияНеПозжеЧем, ПорядокОпределенияСрокаПеречисления";
	
	МассивЗаписей = Новый Массив();
	Для Каждого Строка Из ЭтаФорма["СрокиПеречисленияВзносовИОтчисленийНаборЗаписей"] Цикл
		НоваяСтрока = Новый Структура(СтруктураЗаписиСтрокой);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
		МассивЗаписей.Добавить(НоваяСтрока);
	КонецЦикла;
	
	Возврат МассивЗаписей;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура ОбновитьПолеСведенияОРасчетеСреднегоЗаработкаПериод(Форма, Элементы, РасчетСреднегоЗаработкаОрганизаций, РасчетСреднегоЗаработкаОрганизацийПрежняя, ДатаСеанса)

	Если Элементы.Найти("РасчетСреднегоЗаработкаОрганизацийПериодСтрокой") = НеОпределено Тогда
		Возврат;
	КонецЕсли;
	РедактированиеПериодическихСведенийКлиентСервер.ОбновитьОтображениеПолейВвода(Форма, "РасчетСреднегоЗаработкаОрганизаций", Форма.ОрганизацияСсылка);
	// Не обязательно заполнение поля Период если данные по умолчанию и при этом 
	// записи о среднем заработке еще нет.
	Если Не ЗначениеЗаполнено(РасчетСреднегоЗаработкаОрганизаций.УчетРабочегоВремени) И Не ЗначениеЗаполнено(РасчетСреднегоЗаработкаОрганизаций.Период) Тогда
		Если ЗначениеЗаполнено(РасчетСреднегоЗаработкаОрганизаций.Период) Тогда
			РасчетСреднегоЗаработкаОрганизаций.Период = '00010101';
		КонецЕсли; 
	Иначе
		Если Не ЗначениеЗаполнено(РасчетСреднегоЗаработкаОрганизаций.Период) Тогда
			РасчетСреднегоЗаработкаОрганизаций.Период = НачалоМесяца(ДатаСеанса);
		КонецЕсли; 
	КонецЕсли;
	ЗарплатаКадрыКлиентСервер.ЗаполнитьМесяцПоДате(Форма, "РасчетСреднегоЗаработкаОрганизаций.Период", "РасчетСреднегоЗаработкаОрганизацийПериодСтрокой");

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ОбновитьПолеУчетнаяПолитикаПоНалоговомуУчетуПериод(Форма)
	
	РедактированиеПериодическихСведенийКлиентСервер.ОбновитьОтображениеПолейВвода(Форма, "УчетнаяПолитикаПоНалоговомуУчету", Форма.ОрганизацияСсылка);
	ЗарплатаКадрыКлиентСервер.ЗаполнитьМесяцПоДате(Форма, "УчетнаяПолитикаПоНалоговомуУчету.Период", "УчетнаяПолитикаПоНалоговомуУчетуПериодСтрокой");
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ОбновитьПолеУчетнаяПолитикаЗарплатаКадрыПериод(Форма)
	
	РедактированиеПериодическихСведенийКлиентСервер.ОбновитьОтображениеПолейВвода(Форма, "УчетнаяПолитикаЗарплатаКадры", ?(Форма.ОбособленноеПодразделение, Форма.ГоловнаяОрганизация, Форма.ОрганизацияСсылка));
	ЗарплатаКадрыКлиентСервер.ЗаполнитьМесяцПоДате(Форма, "УчетнаяПолитикаЗарплатаКадры.Период", "УчетнаяПолитикаЗарплатаКадрыПериодСтрокой");
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСведенияОПеречисленииВзносовИОтчислений(МассивЗаписей)
	
	ЭтаФорма["СрокиПеречисленияВзносовИОтчисленийНаборЗаписей"].Очистить();
	Для Каждого СтрокаМассива Из МассивЗаписей Цикл
		ЗаполнитьЗначенияСвойств(ЭтаФорма["СрокиПеречисленияВзносовИОтчисленийНаборЗаписей"].Добавить(), СтрокаМассива);
	КонецЦикла;
	ПрочитатьНастройкиПеречисленияВзносовИОтчисленийВФорме();
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьСведенияОПорядкеОкругления(МассивЗаписей)
	
	ЭтаФорма["ПорядокОкругленияРезультатовРасчетаЗарплатыНаборЗаписей"].Очистить();
	Для Каждого СтрокаМассива Из МассивЗаписей Цикл
		ЗаполнитьЗначенияСвойств(ЭтаФорма["ПорядокОкругленияРезультатовРасчетаЗарплатыНаборЗаписей"].Добавить(), СтрокаМассива);
	КонецЦикла;
	ПрочитатьНастройкиПорядкаОкругленияВФорме();
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуРедактированияИсторииПорядкаОкругления()
	
	ТолькоПросмотрИстории = ТолькоПросмотр;
	Если Не ТолькоПросмотрИстории Тогда
		Попытка
			ЗаблокироватьДанныеФормыДляРедактирования();
			ТолькоПросмотрИстории = Ложь;
		Исключение
			ТолькоПросмотрИстории = Истина;
		КонецПопытки
	КонецЕсли;
	
	Если НЕ ЭтаФорма["ПорядокОкругленияРезультатовРасчетаЗарплатыНаборЗаписейПрочитан"] Тогда 
		ПрочитатьНаборЗаписейПериодическихСведений("ПорядокОкругленияРезультатовРасчетаЗарплаты", ОрганизацияСсылка);
	КонецЕсли;
	
	МассивЗаписей = ПолучитьМассивЗаписейНабораПорядокОкругления();

	ПараметрыФормы = Новый Структура("МассивЗаписей,ВедущийОбъект,ТолькоПросмотр", МассивЗаписей, ОрганизацияСсылка, ТолькоПросмотрИстории);
	ОткрытьФорму("РегистрСведений.ПорядокОкругленияРезультатовРасчетаЗарплаты.Форма.РедактированиеИстории" , ПараметрыФормы, ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуРедактированияИсторииРасчетСреднегоЗаработка()

	ТолькоПросмотрИстории = ТолькоПросмотр;
	Если Не ТолькоПросмотрИстории Тогда
		Попытка
			ЗаблокироватьДанныеФормыДляРедактирования();
			ТолькоПросмотрИстории = Ложь;
		Исключение
			ТолькоПросмотрИстории = Истина;
		КонецПопытки
	КонецЕсли;
	
	МассивЗаписей = РедактированиеПериодическихСведенийКлиентСервер.МассивЗаписейИстории(ЭтаФорма, "РасчетСреднегоЗаработкаОрганизаций", ОрганизацияСсылка);
	
	ПараметрыФормы = Новый Структура("МассивЗаписей,ВедущийОбъект,ТолькоПросмотр", МассивЗаписей, ОрганизацияСсылка, ТолькоПросмотрИстории);
	ОткрытьФорму("РегистрСведений.РасчетСреднегоЗаработкаОрганизаций.Форма.РедактированиеИстории" , ПараметрыФормы, ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуРедактированияИсторииСроковПеречисленияВзносовИОтчислений()
	
	ТолькоПросмотрИстории = ТолькоПросмотр;
	Если Не ТолькоПросмотрИстории Тогда
		Попытка
			ЗаблокироватьДанныеФормыДляРедактирования();
			ТолькоПросмотрИстории = Ложь;
		Исключение
			ТолькоПросмотрИстории = Истина;
		КонецПопытки
	КонецЕсли;
	
	Если НЕ ЭтаФорма["СрокиПеречисленияВзносовИОтчисленийНаборЗаписейПрочитан"] Тогда 
		ПрочитатьНаборЗаписейПериодическихСведений("СрокиПеречисленияВзносовИОтчислений", ОрганизацияСсылка);
	КонецЕсли;
	
	МассивЗаписей = ПолучитьМассивЗаписейНабораСрокиПеречисленияВзносовИОтчислений();

	ПараметрыФормы = Новый Структура("МассивЗаписей,ВедущийОбъект,ТолькоПросмотр", МассивЗаписей, ОрганизацияСсылка, ТолькоПросмотрИстории);
	ОткрытьФорму("РегистрСведений.СрокиПеречисленияВзносовИОтчислений.Форма.РедактированиеИстории" , ПараметрыФормы, ЭтаФорма);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПеречисленияВзносовИОтчисленийИстория(Команда)

	ОткрытьФормуРедактированияИсторииСроковПеречисленияВзносовИОтчислений();
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПорядокОкругленияРезультатовРасчетаЗарплатыИстория(Команда)
	ОткрытьФормуРедактированияИсторииПорядкаОкругления();
КонецПроцедуры

&НаСервере
Процедура ПрочитатьДанныеРасчетаСреднегоЗаработкаДляРедактированияВФорме()

	РедактированиеПериодическихСведений.ПрочитатьЗаписьДляРедактированияВФорме(ЭтаФорма, "РасчетСреднегоЗаработкаОрганизаций", ОрганизацияСсылка);
	ОбновитьПолеСведенияОРасчетеСреднегоЗаработкаПериод(ЭтаФорма, ЭтаФорма.Элементы, ЭтаФорма["РасчетСреднегоЗаработкаОрганизаций"], ЭтаФорма["РасчетСреднегоЗаработкаОрганизацийПрежняя"], ТекущаяДатаСеанса());
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьДанныеУчетнойПолитикиПоНалоговомуУчету()

	РедактированиеПериодическихСведений.ПрочитатьЗаписьДляРедактированияВФорме(ЭтаФорма, "УчетнаяПолитикаПоНалоговомуУчету", ОрганизацияСсылка);
	ЭлементВыбораПустаяСсылка = Элементы.УчетнаяПолитикаПоНалоговомуУчетуСистемаНалогообложения.СписокВыбора.НайтиПоЗначению(Перечисления.СистемыНалогообложения.ПустаяСсылка());
	
	Если Не ЗначениеЗаполнено(ЭтаФорма["УчетнаяПолитикаПоНалоговомуУчету"].Период) Тогда
		
		ЭтаФорма["УчетнаяПолитикаПоНалоговомуУчету"].Период = НачалоГода(ТекущаяДатаСеанса());
		ЭтаФорма["УчетнаяПолитикаПоНалоговомуУчету"].СистемаНалогообложения = ЗарплатаКадрыПереопределяемый.СистемаНалогообложенияПоУмолчанию(ЭтаФорма["УчетнаяПолитикаПоНалоговомуУчету"].Организация, ЭтаФорма["УчетнаяПолитикаПоНалоговомуУчету"].Период);
		
		Модифицированность = Истина;
		
		Если НЕ ЭлементВыбораПустаяСсылка = Неопределено Тогда
			Элементы.УчетнаяПолитикаПоНалоговомуУчетуСистемаНалогообложения.СписокВыбора.Удалить(ЭлементВыбораПустаяСсылка);	
		КонецЕсли;
		
	Иначе
		
		// отображаем только у существующих учетных политик
		Если НЕ (ЭтаФорма["УчетнаяПолитикаПоНалоговомуУчету"].Период >= Дата('20210101') И ЭтаФорма["УчетнаяПолитикаПоНалоговомуУчету"].Период < Дата('20211231'))
			ИЛИ НЕ ЭтаФорма["УчетнаяПолитикаПоНалоговомуУчету"].СистемаНалогообложения = Перечисления.СистемыНалогообложения.ПустаяСсылка() Тогда
			
			Если НЕ ЭлементВыбораПустаяСсылка = Неопределено Тогда
				Элементы.УчетнаяПолитикаПоНалоговомуУчетуСистемаНалогообложения.СписокВыбора.Удалить(ЭлементВыбораПустаяСсылка);	
			КонецЕсли;
			
		КонецЕсли;	
		
	КонецЕсли;
	
	РозничныйНалог = Элементы.УчетнаяПолитикаПоНалоговомуУчетуСистемаНалогообложения.СписокВыбора.НайтиПоЗначению(Перечисления.СистемыНалогообложения.РозничныйНалог);
	Если ЭтаФорма["УчетнаяПолитикаПоНалоговомуУчету"].Период >= Дата('20260101') Тогда
		
		Если НЕ РозничныйНалог = Неопределено Тогда
			Элементы.УчетнаяПолитикаПоНалоговомуУчетуСистемаНалогообложения.СписокВыбора.Удалить(РозничныйНалог);	
		КонецЕсли;
		
	КонецЕсли;

	ОбновитьПолеУчетнаяПолитикаПоНалоговомуУчетуПериод(ЭтаФорма);

КонецПроцедуры

&НаСервере
Процедура ПрочитатьДанныеУчетнойПолитикиЗарплатаКадры()

	РедактированиеПериодическихСведений.ПрочитатьЗаписьДляРедактированияВФорме(ЭтаФорма, "УчетнаяПолитикаЗарплатаКадры", ?(ОбособленноеПодразделение, ГоловнаяОрганизация, ОрганизацияСсылка));
	
	Если Не ЗначениеЗаполнено(ЭтаФорма["УчетнаяПолитикаЗарплатаКадры"].Период) Тогда
		
		ЭтаФорма["УчетнаяПолитикаЗарплатаКадры"].Период = НачалоГода(ТекущаяДатаСеанса());
		
		Модифицированность = Истина;
		
	КонецЕсли;
	
	ОбновитьПолеУчетнаяПолитикаЗарплатаКадрыПериод(ЭтаФорма);

КонецПроцедуры

&НаСервере
Процедура ПрочитатьНастройкиПеречисленияВзносовИОтчисленийВФорме()

	Если НЕ ЭтаФорма["СрокиПеречисленияВзносовИОтчисленийНаборЗаписейПрочитан"] Тогда
		ПрочитатьНаборЗаписейПериодическихСведений("СрокиПеречисленияВзносовИОтчислений", ОрганизацияСсылка);
	КонецЕсли;
		
	НаборЗаписей = ЭтаФорма["СрокиПеречисленияВзносовИОтчислений"];
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТаблицаЗаписей", ЭтаФорма["СрокиПеречисленияВзносовИОтчисленийНаборЗаписей"].Выгрузить());
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СрокиПеречисленияВзносовИОтчислений.Период,
		|	СрокиПеречисленияВзносовИОтчислений.Организация,
		|	СрокиПеречисленияВзносовИОтчислений.ВидНалогаВзносаОтчисления,
		|	СрокиПеречисленияВзносовИОтчислений.ДатаПеречисленияНеПозжеЧем,
		|	СрокиПеречисленияВзносовИОтчислений.ПорядокОпределенияСрокаПеречисления
		|ПОМЕСТИТЬ ВТТаблицаЗаписей
		|ИЗ
		|	&ТаблицаЗаписей КАК СрокиПеречисленияВзносовИОтчислений
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПериодыСроковПеречисления.Период,
		|	ПериодыСроковПеречисления.ВидНалогаВзносаОтчисления,
		|	ВТТаблицаЗаписей.ДатаПеречисленияНеПозжеЧем,
		|	ВТТаблицаЗаписей.ПорядокОпределенияСрокаПеречисления,
		|	ВТТаблицаЗаписей.Организация
		|ИЗ
		|	(ВЫБРАТЬ
		|		МАКСИМУМ(ВТТаблицаЗаписей.Период) КАК Период,
		|		ВТТаблицаЗаписей.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления
		|	ИЗ
		|		ВТТаблицаЗаписей КАК ВТТаблицаЗаписей
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ВТТаблицаЗаписей.ВидНалогаВзносаОтчисления) КАК ПериодыСроковПеречисления
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТТаблицаЗаписей КАК ВТТаблицаЗаписей
		|		ПО ПериодыСроковПеречисления.Период = ВТТаблицаЗаписей.Период
		|			И ПериодыСроковПеречисления.ВидНалогаВзносаОтчисления = ВТТаблицаЗаписей.ВидНалогаВзносаОтчисления";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если НаборЗаписей.Количество() > 0 Тогда
		НаборЗаписей.Очистить();
	КонецЕсли;
	
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(НаборЗаписей.Добавить(), Выборка);		
	КонецЦикла;	
	
	ЗарплатаКадрыКлиентСервер.ЗаполнитьМесяцПоДатеВТабличнойЧасти(НаборЗаписей, "Период", "ПериодСтрокой");

КонецПроцедуры

&НаСервере
Процедура ПрочитатьНастройкиПорядкаОкругленияВФорме()

	Если НЕ ЭтаФорма["ПорядокОкругленияРезультатовРасчетаЗарплатыНаборЗаписейПрочитан"] Тогда
		ПрочитатьНаборЗаписейПериодическихСведений("ПорядокОкругленияРезультатовРасчетаЗарплаты", ОрганизацияСсылка);
	КонецЕсли;
		
	НаборЗаписей = ЭтаФорма["ПорядокОкругленияРезультатовРасчетаЗарплаты"];
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТаблицаЗаписей", ЭтаФорма["ПорядокОкругленияРезультатовРасчетаЗарплатыНаборЗаписей"].Выгрузить());
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПорядокОкругленияРезультатовРасчетаЗарплаты.Период,
		|	ПорядокОкругленияРезультатовРасчетаЗарплаты.Организация,
		|	ПорядокОкругленияРезультатовРасчетаЗарплаты.ВидРасчета,
		|	ПорядокОкругленияРезультатовРасчетаЗарплаты.СпособОкругления
		|ПОМЕСТИТЬ ВТТаблицаЗаписей
		|ИЗ
		|	&ТаблицаЗаписей КАК ПорядокОкругленияРезультатовРасчетаЗарплаты
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПериодыПорядкаОкругления.Период,
		|	ПериодыПорядкаОкругления.ВидРасчета,
		|	ВТТаблицаЗаписей.СпособОкругления,
		|	ВТТаблицаЗаписей.Организация
		|ИЗ
		|	(ВЫБРАТЬ
		|		МАКСИМУМ(ВТТаблицаЗаписей.Период) КАК Период,
		|		ВТТаблицаЗаписей.ВидРасчета КАК ВидРасчета
		|	ИЗ
		|		ВТТаблицаЗаписей КАК ВТТаблицаЗаписей
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ВТТаблицаЗаписей.ВидРасчета) КАК ПериодыПорядкаОкругления
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТТаблицаЗаписей КАК ВТТаблицаЗаписей
		|		ПО ПериодыПорядкаОкругления.Период = ВТТаблицаЗаписей.Период
		|			И ПериодыПорядкаОкругления.ВидРасчета = ВТТаблицаЗаписей.ВидРасчета";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если НаборЗаписей.Количество() > 0 Тогда
		НаборЗаписей.Очистить();
	КонецЕсли;
	
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(НаборЗаписей.Добавить(), Выборка);		
	КонецЦикла;	
	
	ЗарплатаКадрыКлиентСервер.ЗаполнитьМесяцПоДатеВТабличнойЧасти(НаборЗаписей, "Период", "ПериодСтрокой");

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ОбновитьВидимостьНастроекИПНаУпрощенке(ЭтаФорма)

	Элементы = ЭтаФорма.Элементы;
	
	Элементы.УчетнаяПолитикаПоНалоговомуУчетуСуммаЗаявленногоДоходаИП.Видимость = ЭтаФорма.ОрганизацияЯвляетсяИП И ЗначениеЗаполнено(ЭтаФорма.УчетнаяПолитикаПоНалоговомуУчету.СистемаНалогообложения);
	Элементы.УчетнаяПолитикаПоНалоговомуУчетуСпособОтраженияПоДоходуСубъектаПредпринимательства.Видимость = ЭтаФорма.ОрганизацияЯвляетсяИП И ЗначениеЗаполнено(ЭтаФорма.УчетнаяПолитикаПоНалоговомуУчету.СистемаНалогообложения);
	Элементы.ГруппаСНИндивидуальногоПредпринимателя.Видимость = ЭтаФорма.ОрганизацияЯвляетсяИП И ЭтаФорма.УчетнаяПолитикаПоНалоговомуУчету.СистемаНалогообложения = ПредопределенноеЗначение("Перечисление.СистемыНалогообложения.Общая");
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_УчетнаяПолитикаПоНалоговомуУчетуСистемаНалогообложенияПриИзменении(Элемент)
	
	ОбновитьВидимостьНастроекИПНаУпрощенке(ЭтаФорма);
	
	Если ЭтаФорма["ЭтоКонфигурацияЗарплатногоУчета"] Тогда
		ОбновитьВидимостьНастроекПоПериоду(ЭтаФорма);
	КонецЕсли;
	
	Если ЭтаФорма["УчетнаяПолитикаПоНалоговомуУчету"].СистемаНалогообложения = ПредопределенноеЗначение("Перечисление.СистемыНалогообложения.РозничныйНалог")
		И ЭтаФорма["УчетнаяПолитикаПоНалоговомуУчету"].Период < Дата('20240101') Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru='Установка системы налогообложения в значение ""Розничный налог"" доступно не ранее 2024 года.'"));
		ЭтаФорма["УчетнаяПолитикаПоНалоговомуУчету"].СистемаНалогообложения = ПредопределенноеЗначение("Перечисление.СистемыНалогообложения.Общая");
	КонецЕсли;
	
	Если НЕ ЭтаФорма["УчетнаяПолитикаПоНалоговомуУчету"].СистемаНалогообложения = ПредопределенноеЗначение("Перечисление.СистемыНалогообложения.Упрощенная")
		И ЭтаФорма["УчетнаяПолитикаПоНалоговомуУчету"].ПорядокОбложенияДоходовРаботников = ПредопределенноеЗначение("Перечисление.ПорядокОбложенияДоходовРаботников.ЕдиныйПлатеж") Тогда
		ЭтаФорма["УчетнаяПолитикаПоНалоговомуУчету"].ПорядокОбложенияДоходовРаботников = ПредопределенноеЗначение("Перечисление.ПорядокОбложенияДоходовРаботников.Общеустановленный");
	КонецЕсли;
	
КонецПроцедуры

//ЗУПК
&НаКлиенте
Процедура ЗапроситьРежимИзмененияУчетнойПолитикиПоНалоговомуУчету(Отказ, ОповещениеЗавершения) Экспорт
	
	ТекстКнопкиДа = НСтр("ru = 'Изменилась учетная политика по налоговому учету'");
	ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru =  'При редактировании изменены сведения об учетной политике по налоговому учету.
						|Если исправлена прежняя запись учетной политики (она была ошибочной), нажмите ""Исправлена ошибка"".
						|Если изменились сведения с %1, нажмите'") + " ""%2""",
			Формат(ЭтаФорма.УчетнаяПолитикаПоНалоговомуУчету.Период, "ДФ='д ММММ гггг ""г""'"),
			ТекстКнопкиДа);
			
	Оповещение = Новый ОписаниеОповещения("ЗапроситьРежимИзмененияРасчетаСреднегоЗаработкаОрганизаций", ЭтотОбъект, ОповещениеЗавершения);
	РедактированиеПериодическихСведенийКлиент.ЗапроситьРежимИзмененияРегистра(ЭтаФорма, "УчетнаяПолитикаПоНалоговомуУчету", ТекстВопроса, ТекстКнопкиДа, Отказ, Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапроситьРежимИзмененияРасчетаСреднегоЗаработкаОрганизаций(Отказ, ОповещениеЗавершения) Экспорт
	
	ТекстКнопкиДа = НСтр("ru = 'Изменился расчет среднего заработка организации'");
