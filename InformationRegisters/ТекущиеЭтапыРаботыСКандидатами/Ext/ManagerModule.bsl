#Область СлужебныйПрограммныйИнтерфейс

#Область ОбработчикиПравилРегистрации

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ШаблонОбработчика
Процедура ПриЗаполненииНастроекОбработчиковПравилРегистрации(Настройки) Экспорт
	ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляНезависимогоРегистра(Настройки, "Кандидат",
		"ПодборПерсонала");
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Текущий этап кандидата.
// 
// Параметры:
//  Кандидат - СправочникСсылка.Кандидаты
// 
// Возвращаемое значение:
//  - Произвольный
//  - Структура Из КлючИЗначение:
//		* Кандидат - СправочникСсылка.Кандидаты
//		* ЭтапРаботы - ОпределяемыйТип.ЭтапРаботыСКандидатами
//		* Состояние - ПеречислениеСсылка.СостоянияЭтаповРаботыСКандидатами
//		* ДатаВремя - Дата
Функция ТекущийЭтапКандидата(Кандидат) Экспорт
	Возврат ТекущиеЭтапыКандидатов(ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Кандидат))[Кандидат];
КонецФункции

// Текущие этапы кандидатов.
// 
// Параметры:
//  Кандидаты - Массив Из СправочникСсылка.Кандидаты
// 
// Возвращаемое значение:
//  Соответствие Из КлючИЗначение - Текущие этапы кандидатов:
//	* Ключ - СправочникСсылка.Кандидаты
//	* Значение - Структура Из КлючИЗначение:
//		* Кандидат - СправочникСсылка.Кандидаты
//		* ЭтапРаботы - ОпределяемыйТип.ЭтапРаботыСКандидатами
//		* Состояние - ПеречислениеСсылка.СостоянияЭтаповРаботыСКандидатами
//		* ДатаВремя - Дата
Функция ТекущиеЭтапыКандидатов(Кандидаты) Экспорт
	
	ТекущиеЭтапы = Новый Соответствие();
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Кандидаты", Кандидаты);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТекущиеЭтапыРаботыСКандидатами.Кандидат КАК Кандидат,
		|	ТекущиеЭтапыРаботыСКандидатами.ЭтапРаботы КАК ЭтапРаботы,
		|	ТекущиеЭтапыРаботыСКандидатами.Состояние КАК Состояние,
		|	ТекущиеЭтапыРаботыСКандидатами.ДатаВремя КАК ДатаВремя
		|ИЗ
		|	РегистрСведений.ТекущиеЭтапыРаботыСКандидатами КАК ТекущиеЭтапыРаботыСКандидатами
		|ГДЕ
		|	ТекущиеЭтапыРаботыСКандидатами.Кандидат В(&Кандидаты)";
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	Для Каждого СтрокаРезультата Из РезультатЗапроса Цикл
		ТекущиеЭтапы.Вставить(СтрокаРезультата.Кандидат, 
			ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(СтрокаРезультата));
	КонецЦикла;
	
	Возврат ТекущиеЭтапы;
	
КонецФункции

#КонецОбласти

#КонецЕсли