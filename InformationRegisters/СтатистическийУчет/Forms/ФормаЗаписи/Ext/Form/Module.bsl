#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура НаименованиеЗанятияНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
		
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ИмяМакета", "ПФ_MXL_КлассификаторЗанятий");
	ПараметрыФормы.Вставить("ИмяСекции", "Классификатор");
	ПараметрыФормы.Вставить("ПолучатьПолныеДанные", Истина);
	ПараметрыФормы.Вставить("ПолныйПоиск", Истина);
	ОткрытьФорму("ОбщаяФорма.ФормаВыбораИзКлассификатора", ПараметрыФормы, Элемент, , , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);

КонецПроцедуры

