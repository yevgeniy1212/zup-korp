#Область СлужебныйПрограммныйИнтерфейс

#Область ОбработчикиПравилРегистрации

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ШаблонОбработчика
Процедура ПриЗаполненииНастроекОбработчиковПравилРегистрации(Настройки) Экспорт
	ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляНезависимогоРегистра(Настройки, "Кандидат", "ПодборПерсонала");
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ОбработчикиОбновления

Функция ЗаполнитьКандидатов() Экспорт

	Если Метаданные.РегистрыСведений.ОценкиКандидатовПоХарактеристикам.Реквизиты.Найти(
		"УдалитьФизическоеЛицо") = Неопределено Тогда
		Возврат Истина;
	КонецЕсли;
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить(Метаданные.РегистрыСведений.ОценкиКандидатовПоХарактеристикам.ПолноеИмя());
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;

	НачатьТранзакцию();
	Попытка
		Блокировка.Заблокировать();
		
		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1000
			|	ОценкиКандидатовПоХарактеристикам.Кандидат,
			|	ОценкиКандидатовПоХарактеристикам.УдалитьФизическоеЛицо,
			|	ЕСТЬNULL(ФизическиеЛицаКандидатов.ЛичныеДанныеКандидата,
			|		ЗНАЧЕНИЕ(Справочник.ЛичныеДанныеКандидатов.ПустаяСсылка)) КАК ЛичныеДанныеКандидата
			|ИЗ
			|	РегистрСведений.ОценкиКандидатовПоХарактеристикам КАК ОценкиКандидатовПоХарактеристикам
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФизическиеЛицаКандидатов КАК ФизическиеЛицаКандидатов
			|		ПО ОценкиКандидатовПоХарактеристикам.УдалитьФизическоеЛицо = ФизическиеЛицаКандидатов.ФизическоеЛицо
			|ГДЕ
			|	ОценкиКандидатовПоХарактеристикам.ЛичныеДанныеКандидата = ЗНАЧЕНИЕ(Справочник.ЛичныеДанныеКандидатов.ПустаяСсылка)
			|	И ОценкиКандидатовПоХарактеристикам.УдалитьФизическоеЛицо <> ЗНАЧЕНИЕ(Справочник.ФизическиеЛица.ПустаяСсылка)";
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		КоличествоОбработанныхЗаписей = 0;
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			Если Не ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ЛичныеДанныеКандидата) Тогда
				Продолжить;
			КонецЕсли;
			
			НаборЗаписей = РегистрыСведений.ОценкиКандидатовПоХарактеристикам.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Кандидат.Установить(ВыборкаДетальныеЗаписи.Кандидат);
			НаборЗаписей.Прочитать();
			Для каждого ТекущаяЗапись Из НаборЗаписей Цикл
				ТекущаяЗапись.ЛичныеДанныеКандидата = ВыборкаДетальныеЗаписи.ЛичныеДанныеКандидата;
				КоличествоОбработанныхЗаписей = КоличествоОбработанныхЗаписей + 1;
			КонецЦикла;
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(НаборЗаписей, Истина);
			
		КонецЦикла;
		ЗафиксироватьТранзакцию();
		
		Возврат КоличествоОбработанныхЗаписей = 0;
	Исключение
		ОтменитьТранзакцию();
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Обновление информационной базы.Ошибка заполнения кандидатов в регистре Оценки кандидатов по характеристикам'",
				ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,
			Метаданные.РегистрыСведений.ОценкиКандидатовПоХарактеристикам);
		Возврат Ложь;
	КонецПопытки;

КонецФункции

#КонецОбласти

#КонецОбласти

#КонецЕсли