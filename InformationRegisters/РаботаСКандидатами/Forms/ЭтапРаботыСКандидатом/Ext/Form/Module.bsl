#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	УстановитьУсловноеОформление(УсловноеОформление);
	
	ЗаполнитьЗначенияСвойств(Запись, Параметры);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицуИзМассива(Кандидаты, Параметры.Кандидаты, "Кандидат");
	Если Кандидаты.Количество() = 1 Тогда
		Запись.Кандидат = Кандидаты[0].Кандидат;
	КонецЕсли;
	
	ПодобратьЭтапРаботы();
	УстановитьСпособОценкиХарактеристик();
	ПодобратьДатуВремяНачала();
	
	УстановитьСвойстваЭлементовФормы();
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(ВзаимодействияСписок, "Предмет", Запись.Кандидат);
	
	ПрочитатьНапоминание();
	
	ЗаполнитьШаблонПисьмаПоУмолчанию(ЭтотОбъект, ШаблонПисьмаКандидатам);
	ЗаполнитьШаблонSMSПоУмолчанию(ЭтотОбъект, ШаблонSMSКандидатам);
	
	ОтображатьСобытияВнешнихСистем = СинхронизацияКалендарей.ИспользуютсяВнешниеСистемыУчетаЗанятости();
	
	НастроитьЭлементыПланирования();
	
	ДобавитьТекущегоПользователяВУчастники();

	КопироватьКомментарий = Истина;
	
	ЗаполнитьКонтактыКандидатов();
	
	ИспользуютсяВидеоконференции = Видеоконференции.ИспользуютсяВидеоконференции();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ЗаполнитьСпискиВыбораВремени();
	ОтобразитьВыбранноеВремя();
	
	Если ИнтервалВремениНапоминания > 0 Тогда
		ИнтервалВремениСтрокой = РаботаСРабочимКалендаремКлиентСервер.ПредставлениеВремени(ИнтервалВремениНапоминания);
	КонецЕсли;
	
	СинхронизироватьКалендариПриОткрытии();
	ПоказатьПредупреждениеПриЭлектронномТестировании();
	ЗаполнитьТаблицуЗанятостиИзВнешнихСистем();
	ОтобразитьВидеоконференцию();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ТипЗнч(Параметр) = Тип("Структура") И Параметр.Свойство("Предмет") И Параметр.Предмет = Запись.Кандидат Тогда
		Элементы.ВзаимодействияСписок.Обновить();
	КонецЕсли;
	
	Если ИмяСобытия = "Запись_ТерриторииИПомещения" Тогда
		
		Отказ = ВозможноБронирование(Истина);
		
		Если Отказ Тогда
			Помещение = Неопределено;
		КонецЕсли;
		
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	Если Не ЗначениеЗаполнено(Запись.ЭтапРаботы) Тогда
		ОбщегоНазначения.СообщитьПользователю(
			НСтр("ru = 'Этап работы не указан.'"), , , "Запись.ЭтапРаботы", Отказ);
	КонецЕсли;
		
	Если Не ЗначениеЗаполнено(Запись.Период) Тогда
		ОбщегоНазначения.СообщитьПользователю(
			НСтр("ru = 'Не указана дата.'"), , , "Запись.Период", Отказ);
	КонецЕсли;
		
	Если ЗабронироватьПомещение И Не ЗначениеЗаполнено(Помещение) Тогда
		ОбщегоНазначения.СообщитьПользователю(
			НСтр("ru = 'Не указано помещение.'"), , , "Помещение", Отказ);
	КонецЕсли;
	
	ПодборПерсонала.ПроверитьВозможностьУстановкиЭтапаРаботы(
		СоставКандидатовНаСервере(), Запись.ЭтапРаботы, Запись.Период, Отказ);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	
	Индекс = Участники.Количество() - 1;
	Пока Индекс >= 0 Цикл
		ИндексВыбранного = ВыбранноеЗначение.Найти(Участники[Индекс].Участник);
		Если ИндексВыбранного = Неопределено Тогда
			Участники.Удалить(Индекс);
		Иначе
			ВыбранноеЗначение.Удалить(ИндексВыбранного);
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;
	
	Если ВыбранноеЗначение.Количество() > 0 Тогда
		Для Каждого НовыйУчастник Из ВыбранноеЗначение Цикл
			НоваяСтрока = Участники.Добавить();
			НоваяСтрока.Участник = НовыйУчастник;
			НоваяСтрока.СостояниеПриглашения =
				ПредопределенноеЗначение("Перечисление.СостоянияПриглашений.НеОтправлено");
		КонецЦикла;
	КонецЕсли;
	
	Если ОтображатьСобытияВнешнихСистем Тогда
		ЗаполнитьТаблицуЗанятостиИзВнешнихСистем();
	Иначе
		ИнициализироватьПланировщик();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

