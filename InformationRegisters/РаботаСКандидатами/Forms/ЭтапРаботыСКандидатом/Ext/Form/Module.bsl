&НаКлиенте
Процедура ПроверитьВозможностьБронирования(Отказ = Ложь)
	
	Если Не ДоступноБронированиеПомещения Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Помещение) Тогда
		Возврат;
	КонецЕсли;
	
	ОчиститьСообщения();
	Отказ = ВозможноБронирование();
	
КонецПроцедуры

&НаСервере
Функция ВозможноБронирование(ИзменилосьПомещение = Ложь)
	
	Отказ = Ложь;
	ТекстОшибки = "";
	Если Не БронированиеПомещений.ВозможнаБроньПомещения(
				Помещение, 
				Запись.Период, 
				Запись.ПериодОкончание, 
				Пользователи.ТекущийПользователь(), 
				"",
				ТекстОшибки) Тогда
		
		ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, , , "Помещение", Отказ);
		
	КонецЕсли;
	
	Если Не Отказ 
		И Не БронированиеПомещенийБЗК.ВозможнаБроньПомещенияПоЭтапуРаботы(
		Помещение, 
		Запись.Период, 
		Запись.ПериодОкончание,
		Запись.ЭтапРаботы,
		СоставКандидатовНаСервере()) Тогда
		
		Отказ = Истина;
		
	КонецЕсли;
	
	Если Не Отказ Тогда
	
		Если Не ИзменилосьПомещение Тогда
		
			Запрос = Новый Запрос;
			Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
			
			ПодборПерсонала.СоздатьВТДанныеЭтапаРаботыСКандидатами(
				Запрос.МенеджерВременныхТаблиц, Запись.Кандидат, Запись.ЭтапРаботы);
			
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	ПрежниеДанныеЭтапа.Кандидат КАК Кандидат,
			|	ПрежниеДанныеЭтапа.Помещение КАК Помещение
			|ИЗ
			|	ВТДанныеЭтапаРаботы КАК ПрежниеДанныеЭтапа";
			Выборка = Запрос.Выполнить().Выбрать();
			
			Пока Выборка.Следующий() Цикл
				ИзменилосьПомещение = Выборка.Помещение <> Помещение;
			КонецЦикла;
		
		КонецЕсли; 
		
		Если ИзменилосьПомещение 
			И Не СинхронизацияMSExchange.ВозможнаБроньПомещения(
			Помещение,
			Запись.Период,
			Запись.ПериодОкончание) Тогда
			
			ТекстОшибки = НСтр("ru = 'Помещение забронировано в Microsoft Exchange'");
			
			Сообщение = Новый СообщениеПользователю;
			Сообщение.ИдентификаторНазначения = УникальныйИдентификатор;
			Сообщение.Текст = ТекстОшибки;
			Сообщение.ПутьКДанным = "Помещение";
			Сообщение.Сообщить();
			
			Отказ = Истина;
			
		КонецЕсли;
	
	КонецЕсли; 
	
	Возврат Отказ;
	
КонецФункции

#КонецОбласти

