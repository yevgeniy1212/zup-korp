&НаКлиенте
Функция ПараметрыВидеособеседования()
	
	ПараметрыПараметрыВидеособеседования = ВидеособеседованияКлиент.НовыеПараметрыВидеособеседования();
	
	ПараметрыПараметрыВидеособеседования.Кандидат = Запись.Кандидат;
	ПараметрыПараметрыВидеособеседования.Этап = Запись.ЭтапРаботы;
	ПараметрыПараметрыВидеособеседования.УчетнаяЗапись = Запись.УчетнаяЗаписьВидеоконференции;
	ПараметрыПараметрыВидеособеседования.Идентификатор = Запись.ИдентификаторВидеоконференции;
	ПараметрыПараметрыВидеособеседования.Ссылка = СсылкаНаВидеоконференцию;
	ПараметрыПараметрыВидеособеседования.СсылкаОрганизатора = СсылкаНаВидеоконференциюДляОрганизатора;
	ПараметрыПараметрыВидеособеседования.Начало = Запись.Период;
	ПараметрыПараметрыВидеособеседования.Окончание = Запись.ПериодОкончание;
	
	Для Каждого Строка Из Участники Цикл
		ПараметрыПараметрыВидеособеседования.Участники.Добавить(Строка.Участник);
	КонецЦикла;
	
	Возврат ПараметрыПараметрыВидеособеседования;
	
КонецФункции

&НаКлиенте
Процедура ОтобразитьВидеоконференцию()
	
	Если Не ИспользуютсяВидеоконференции Или Не ЭтоПланированиеЭтапа(Запись) Тогда
		Элементы.ВидеоконференцияГруппа.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Видеоконференция = ЗначениеЗаполнено(Запись.УчетнаяЗаписьВидеоконференции);
	
	Если Видеоконференция Тогда
		Элементы.ЗаписьУчетнаяЗаписьВидеоконференции.СписокВыбора.ЗагрузитьЗначения(
			ВидеоконференцииКлиент.НастроенныеУчетныеЗаписи());
		
		Если ЗначениеЗаполнено(Запись.ИдентификаторВидеоконференции) Тогда
			ОповещениеОЗавершении =
				Новый ОписаниеОповещения("ОбработатьСостояниеВидеоконференции", ЭтотОбъект);
			
			ДлительнаяОперация =
				ДлительнаяОперацияПолученияДанных(Запись.УчетнаяЗаписьВидеоконференции,
					Запись.ИдентификаторВидеоконференции, УникальныйИдентификатор);
			
			ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
			ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
			ПараметрыОжидания.ТекстСообщения = НСтр("ru = 'Получаем данные о видеоконференции.'");
			ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
		КонецЕсли;
	КонецЕсли;
	
	ОбновитьОтображениеВидеоконференции();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДлительнаяОперацияПолученияДанных(УчетнаяЗапись, Идентификатор, УникальныйИдентификатор)
	
	ИмяПроцедуры = "Видеоконференции.ДанныеВидеоконференции";
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(УникальныйИдентификатор, ИмяПроцедуры, УчетнаяЗапись, Идентификатор);
	
КонецФункции

&НаКлиенте
Процедура ОбновитьОтображениеВидеоконференции()
	
	Запланирована = ЗначениеЗаполнено(Запись.ИдентификаторВидеоконференции);
	ВыбранаУчетнаяЗапись = ЗначениеЗаполнено(Запись.УчетнаяЗаписьВидеоконференции);
	
	Если Видеоконференция И ВыбранаУчетнаяЗапись Тогда
		Если Не Запланирована Тогда
			Элементы.ВидеоконференцияОписание.Заголовок = НСтр("ru = 'Не запланирована'");
		КонецЕсли;
		
		ДанныеСервиса = ВидеоконференцииКлиент.ДанныеСервиса(Запись.УчетнаяЗаписьВидеоконференции);
		Кнопки = ДанныеСервиса.НастройкиОтображения.Кнопки;
		
		Элементы.НачатьВидеоконференцию.Видимость = Кнопки.Старт.Использование;
		Элементы.НачатьВидеоконференцию.Заголовок = Кнопки.Старт.Заголовок;
		Элементы.ПерейтиВВидеоконференцию.Видимость = Кнопки.Перейти.Использование;
		Элементы.ПерейтиВВидеоконференцию.Заголовок = Кнопки.Перейти.Заголовок;
		Элементы.ЗапланироватьВидеоконференцию.Заголовок = Кнопки.Запланировать.Заголовок;
		Элементы.ОтменитьВидеоконференцию.Заголовок = Кнопки.Отменить.Заголовок;
		
		Элементы.ВидеоконференцияКнопки.Доступность = Запланирована;
		#Если ВебКлиент Тогда
		Если ДанныеСервиса.ЭтоСистемаВзаимодействия Тогда
			Элементы.НачатьВидеоконференцию.Видимость = Ложь;
		КонецЕсли;
		#КонецЕсли
	Иначе
		Элементы.ВидеоконференцияКнопки.Доступность = ВыбранаУчетнаяЗапись;
	КонецЕсли;
	
	Элементы.ЗапланироватьВидеоконференцию.Доступность = ВыбранаУчетнаяЗапись И Не Запланирована;
	Элементы.ОтменитьВидеоконференцию.Доступность = Запланирована;
	
	Элементы.ВидеоконференцияОсновноеГруппа.Видимость = Видеоконференция;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗапланироватьВидеоконференциюВопрос(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	ЗакрыватьФорму = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ЗакрыватьФорму", Ложь);
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ДанныеСервиса = ВидеоконференцииКлиент.ДанныеСервиса(Запись.УчетнаяЗаписьВидеоконференции);
		
		Если ДанныеСервиса.ДоступноПланирование Тогда
			ДанныеОПересечениях =
				ВидеособеседованияКлиент.ДанныеПересеченийВидеоконференций(ПараметрыВидеособеседования());
			
			Если ДанныеОПересечениях.ЕстьПересечения Тогда
				ПоказатьПредупреждение(, ДанныеОПересечениях.Предупреждение);
			Иначе
				Оповещение = Новый ОписаниеОповещения("ОбработатьСостояниеВидеоконференции",
					ЭтотОбъект, Новый Структура("ЗакрыватьФорму", ЗакрыватьФорму));
				ВидеособеседованияКлиент.НачатьПланированиеВидеособеседования(
					ЭтотОбъект, ПараметрыВидеособеседования(), Оповещение);
			КонецЕсли;
		Иначе
			Оповещение = Новый ОписаниеОповещения("ОбработатьСостояниеВидеоконференции",
				ЭтотОбъект, Новый Структура("ЗакрыватьФорму", ЗакрыватьФорму));
			ВидеособеседованияКлиент.НачатьПланированиеВидеособеседования(
				ЭтотОбъект, ПараметрыВидеособеседования(), Оповещение);
		КонецЕсли;
	ИначеЕсли РезультатВопроса = КодВозвратаДиалога.Нет И ЗакрыватьФорму Тогда
		Запись.УчетнаяЗаписьВидеоконференции = Неопределено;
		Запись.ИдентификаторВидеоконференции = Неопределено;
		ОКЗавершение();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтменитьВидеоконференциюВопрос(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		НачатьОтменуВидеоконференции(
			ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ЗакрыватьФорму", Ложь));
	Иначе
		Видеоконференция = Истина;
		ОбновитьОтображениеВидеоконференции();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменениеУчетнойЗаписиВидеоконференцииВопрос(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		НачатьОтменуВидеоконференции(
			Ложь, ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "НоваяУчетнаяЗапись"));
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьОтменуВидеоконференции(ЗакрыватьФорму = Ложь, НоваяУчетнаяЗапись = Неопределено)
	
	Если ЗначениеЗаполнено(Запись.ИдентификаторВидеоконференции) Тогда
		ОповещениеОЗавершении = 
			Новый ОписаниеОповещения("ОбработатьСостояниеВидеоконференции", 
				ЭтотОбъект, Новый Структура("ЗакрыватьФорму, НоваяУчетнаяЗапись", ЗакрыватьФорму, НоваяУчетнаяЗапись));
			
		ДлительнаяОперация = ДлительнаяОперацияОтменыВидеоконференции(
			Запись.УчетнаяЗаписьВидеоконференции, Запись.ИдентификаторВидеоконференции, УникальныйИдентификатор);
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
		ПараметрыОжидания.ТекстСообщения = НСтр("ru = 'Отменяем видеоконференцию.'");
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДлительнаяОперацияОтменыВидеоконференции(УчетнаяЗапись, Идентификатор, УникальныйИдентификатор)
	
	ИмяПроцедуры = "Видеоконференции.УдалитьВидеоконференцию";
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(УникальныйИдентификатор, ИмяПроцедуры, УчетнаяЗапись, Идентификатор);
	
КонецФункции

&НаКлиенте
Процедура ОбработатьВидеоконференциюПередЗакрытием()
	
	Если Не Видеоконференция
		И ИспользуютсяВидеоконференции
		И ЗначениеЗаполнено(Запись.ИдентификаторВидеоконференции) Тогда
		ПоказатьВопрос(
			Новый ОписаниеОповещения("ОтменитьВидеоконференциюВопрос", ЭтотОбъект, Новый Структура("ЗакрыватьФорму", Истина)),
			НСтр("ru = 'Запланированная ранее видеоконференция будет отменена. Продолжить?'"),
			РежимДиалогаВопрос.ДаНет);
	ИначеЕсли Видеоконференция И ЗначениеЗаполнено(Запись.ИдентификаторВидеоконференции) Тогда
		ДанныеСервиса = ВидеоконференцииКлиент.ДанныеСервиса(Запись.УчетнаяЗаписьВидеоконференции);
		
		Оповещение = Новый ОписаниеОповещения(
			"ОбработатьСостояниеВидеоконференции", ЭтотОбъект, Новый Структура("ЗакрыватьФорму", Истина));
		
		ВидеособеседованияКлиент.НачатьОбновлениеВидеособеседования(
			ЭтотОбъект, ПараметрыВидеособеседования(), Оповещение);
	ИначеЕсли Видеоконференция
			И ЗначениеЗаполнено(Запись.УчетнаяЗаписьВидеоконференции)
			И Не ЗначениеЗаполнено(Запись.ИдентификаторВидеоконференции) Тогда
		Оповещение = Новый ОписаниеОповещения(
			"ЗапланироватьВидеоконференциюВопрос", ЭтотОбъект, Новый Структура("ЗакрыватьФорму", Истина));
		
		ПоказатьВопрос(Оповещение,
			НСтр("ru = 'Видеоконференция не запланирована. Хотите запланировать перед сохранением?'"), РежимДиалогаВопрос.ДаНет);
	Иначе
		ОКЗавершение();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьСостояниеВидеоконференции(ДлительнаяОперация, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ДлительнаяОперация = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ДлительнаяОперация.Статус = "Ошибка" Тогда
		ПоказатьПредупреждение(, ДлительнаяОперация.КраткоеПредставлениеОшибки);
		Видеоконференция = Ложь;
		ОбновитьОтображениеВидеоконференции();
		Возврат;
	ИначеЕсли Не ДлительнаяОперация.Статус = "Выполнено" Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеВидеоконференции = ПолучитьИзВременногоХранилища(ДлительнаяОперация.АдресРезультата);
	
	Если Не ЗначениеЗаполнено(ДанныеВидеоконференции) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Не удалось авторизоваться в сервисе видеоконференций.'"));
		ОбновитьОтображениеВидеоконференции();
		Возврат;
	КонецЕсли;
	
	ТекстОповещения = "";
	СостояниеВидеоконференции = ВидеоконференцииКлиентСервер.СостояниеВидеоконференции();
	
	Если ДанныеВидеоконференции.Состояние = СостояниеВидеоконференции.Создана Тогда
		Запись.ИдентификаторВидеоконференции = ДанныеВидеоконференции.Идентификатор;
		
		СсылкаНаВидеоконференцию = ДанныеВидеоконференции.Ссылка;
		СсылкаНаВидеоконференциюДляКандидата = ДанныеВидеоконференции.СсылкаКандидата;
		СсылкаНаВидеоконференциюДляОрганизатора = ДанныеВидеоконференции.СсылкаОрганизатора;
		
		Если ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ЗакрыватьФорму", Ложь) Тогда
			ОКЗавершение();
		Иначе
			СохранитьДанныеВидеоконференции(РезультатВыбора());
			Оповестить("ИзмененаВидеоконференция");
		КонецЕсли;
		
		ТекстОповещения = НСтр("ru = 'Видеоконференция запланирована'");
	ИначеЕсли ДанныеВидеоконференции.Состояние = СостояниеВидеоконференции.Активна Тогда
		СсылкаНаВидеоконференцию = ДанныеВидеоконференции.Ссылка;
		СсылкаНаВидеоконференциюДляКандидата = ДанныеВидеоконференции.СсылкаКандидата;
		СсылкаНаВидеоконференциюДляОрганизатора = ДанныеВидеоконференции.СсылкаОрганизатора;
		ТекстОповещения = НСтр("ru = 'Видеоконференция активна'");
	ИначеЕсли ДанныеВидеоконференции.Состояние = СостояниеВидеоконференции.Обновлена Тогда
		Запись.ИдентификаторВидеоконференции = ДанныеВидеоконференции.Идентификатор;
		
		Если ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ЗакрыватьФорму", Ложь) Тогда
			ОКЗавершение();
		Иначе
			СсылкаНаВидеоконференцию = ДанныеВидеоконференции.Ссылка;
			СсылкаНаВидеоконференциюДляКандидата = ДанныеВидеоконференции.СсылкаКандидата;
			СсылкаНаВидеоконференциюДляОрганизатора = ДанныеВидеоконференции.СсылкаОрганизатора;
			СохранитьДанныеВидеоконференции(РезультатВыбора());
			Оповестить("ИзмененаВидеоконференция");
		КонецЕсли;
		
		ТекстОповещения = НСтр("ru = 'Видеоконференция обновлена'");
	ИначеЕсли ДанныеВидеоконференции.Состояние = СостояниеВидеоконференции.Отменена Тогда
		Запись.УчетнаяЗаписьВидеоконференции = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
			ДополнительныеПараметры, "НоваяУчетнаяЗапись", Запись.УчетнаяЗаписьВидеоконференции);
		Запись.ИдентификаторВидеоконференции = Неопределено;
		
		Если ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеПараметры, "ЗакрыватьФорму", Ложь) Тогда
			Видеоконференция = Ложь;
			ОКЗавершение();
		Иначе
			СохранитьДанныеВидеоконференции(РезультатВыбора());
			ВидеособеседованияКлиент.ОтменитьВидеоконференцииПоКандидату(ПараметрыВидеособеседования());
			Оповестить("ИзмененаВидеоконференция");
		КонецЕсли;
		
		ТекстОповещения = НСтр("ru = 'Видеоконференция отменена'");
	Иначе
		Запись.УчетнаяЗаписьВидеоконференции = Неопределено;
		Запись.ИдентификаторВидеоконференции = Неопределено;
		
		СохранитьДанныеВидеоконференции(РезультатВыбора());
		Оповестить("ИзмененаВидеоконференция");
		
		Видеоконференция = Ложь;
		
		ТекстОповещения = НСтр("ru = 'Видеоконференция не найдена'");
	КонецЕсли;
	
	Элементы.ВидеоконференцияОписание.Заголовок = ДанныеВидеоконференции.Описание;
	
	ПоказатьОповещениеПользователя(ТекстОповещения);
	
	ОбновитьОтображениеВидеоконференции();
	
КонецПроцедуры

&НаСервере
Процедура СохранитьДанныеВидеоконференции(РезультатВыбора)
	
	ПодборПерсонала.УстановитьСостояниеЭтапаРаботыКандидатов(РезультатВыбора);
	
КонецПроцедуры

#КонецОбласти

&НаКлиенте
Процедура СинхронизироватьКалендариПриОткрытии()

	Если Не ЭтоПланированиеЭтапа(Запись) Тогда
		Возврат;
	КонецЕсли;
	ДлительнаяОперация = ДлительнаяОперацияСинхронизации();
	Если ДлительнаяОперация = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("СинхронизироватьКалендариЗавершение", ЭтотОбъект);
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ФормаВладелец = ЭтаФорма;
	ПараметрыОжидания.ТекстСообщения = "Идет синхронизация календарей.";
	ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервере
Функция ДлительнаяОперацияСинхронизации()

	Возврат СинхронизацияКалендарей.ДлительнаяОперацияПередПланированиемЭтапа(УникальныйИдентификатор);

КонецФункции

&НаСервере
Процедура ДобавитьТекущегоПользователяВУчастники()
	
	Если Не (ДоступныЭлементыПланирования И Участники.Количество() = 0) Тогда
		Возврат;
	КонецЕсли;
	
	ЭтапБылЗапланирован = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	ПодборПерсонала.СоздатьВТДанныеЭтапаРаботыСКандидатами(
		Запрос.МенеджерВременныхТаблиц, Запись.Кандидат, Запись.ЭтапРаботы);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПрежниеДанныеЭтапа.Кандидат КАК Кандидат,
	|	ПрежниеДанныеЭтапа.Период КАК Период
	|ИЗ
	|	ВТДанныеЭтапаРаботы КАК ПрежниеДанныеЭтапа";
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ЭтапБылЗапланирован = Выборка.Период = Запись.Период;
	КонецЦикла;
	
	Если Не ЭтапБылЗапланирован Тогда
		НоваяСтрока = Участники.Добавить();
		НоваяСтрока.Участник = Пользователи.ТекущийПользователь();
		НоваяСтрока.СостояниеПриглашения = Перечисления.СостоянияПриглашений.НеОтправлено;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьВыборУчастника(Знач НовыеУчастники)
	
	Если Не ЗначениеЗаполнено(НовыеУчастники) Тогда
		Участники.Очистить();
		Возврат;
	КонецЕсли;
	
	Индекс = Участники.Количество() - 1;
	Пока Индекс >= 0 Цикл
		Найден = НовыеУчастники.Найти(Участники[Индекс]);
		Если Найден = Неопределено Тогда
			Участники.Удалить(Индекс);
		Иначе
			НовыеУчастники.Удалить(Найден);
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;
	
	Для Каждого НовыйУчастник Из НовыеУчастники Цикл
		Если Не ТипЗнч(НовыйУчастник) = Тип("СправочникСсылка.Пользователи") Тогда
			Продолжить;
		КонецЕсли;

		НоваяСтрока = Участники.Добавить();
		НоваяСтрока.Участник = НовыйУчастник;
		НоваяСтрока.СостояниеПриглашения = ПредопределенноеЗначение("Перечисление.СостоянияПриглашений.НеОтправлено");
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура СинхронизироватьКалендариЗавершение(Результат, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьТаблицуЗанятостиИзВнешнихСистем();
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьУсловноеОформление(УсловноеОформление)
	
	УсловноеОформление.Элементы.Очистить();
	
	УстановитьУсловноеОформлениеСостоянияПриглашений(УсловноеОформление,
		ПредопределенноеЗначение("Перечисление.СостоянияПриглашений.Принято"),
		ЦветаСтиля.ОтметкаПоложительногоВыполненияЗадачи);
		
	УстановитьУсловноеОформлениеСостоянияПриглашений(УсловноеОформление,
		ПредопределенноеЗначение("Перечисление.СостоянияПриглашений.Отклонено"),
		ЦветаСтиля.ОтметкаОтрицательногоВыполненияЗадачи);

	УстановитьУсловноеОформлениеСостоянияПриглашений(УсловноеОформление,
		ПредопределенноеЗначение("Перечисление.СостоянияПриглашений.ПодВопросом"),
		ЦветаСтиля.ОтметкаОтрицательногоВыполненияЗадачи);

	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьУсловноеОформлениеСостоянияПриглашений(УсловноеОформление, СостояниеПриглашения, ЦветТекстаПоля)
	
	Элемент = УсловноеОформление.Элементы.Добавить();

	ПолеЭлемента = Элемент.Поля.Элементы.Добавить();
	ПолеЭлемента.Поле = Новый ПолеКомпоновкиДанных("УчастникиСостояниеПриглашения");
	
	ОтборЭлемента = Элемент.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ОтборЭлемента.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Участники.СостояниеПриглашения");
	ОтборЭлемента.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ОтборЭлемента.ПравоеЗначение = СостояниеПриглашения;
	
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветТекстаПоля);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьТаблицуЗанятостиИзВнешнихСистем()
	
	Если Не ОтображатьСобытияВнешнихСистем Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЭтоПланированиеЭтапа(Запись) Тогда
		Возврат;
	КонецЕсли;
	
	ДлительнаяОперация = ДлительнаяОперацияЗаполненияТаблицыЗанятости(
		УникальныйИдентификатор, СоставУчастников(), ОтображаемаяДата);
	
	Если ДлительнаяОперация = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("ЗаполнитьТаблицуЗанятостиИзВнешнихСистемЗавершение", ЭтотОбъект);
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ФормаВладелец = ЭтаФорма;
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДлительнаяОперацияЗаполненияТаблицыЗанятости(УникальныйИдентификатор, СоставУчастников, ОтображаемаяДата)
	
	Возврат СинхронизацияКалендарей.ДлительнаяОперацияПолученияТаблицыЗанятости(УникальныйИдентификатор,
		СоставУчастников, НачалоДня(ОтображаемаяДата), КонецДня(ОтображаемаяДата));
	
КонецФункции

&НаКлиенте
Процедура ЗаполнитьТаблицуЗанятостиИзВнешнихСистемЗавершение(Результат, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(Результат) Тогда
		Если Результат.Статус = "Выполнено" Тогда
			АдресТаблицыЗанятостиИзВнешнихСистем = Результат.АдресРезультата;
			АктуализироватьСостояниеПриглашений();
		КонецЕсли;
	КонецЕсли;
	
	ИнициализироватьПланировщик();
	
КонецПроцедуры

&НаСервере
Функция АктуализироватьСостояниеПриглашений()
	
	СостоянияПриглашений = 
		РегистрыСведений.УчастникиЭтапаРаботыСКандидатом.ТаблицаУчастниковЭтапа(Запись.Кандидат, Запись.ЭтапРаботы);
		
	Для Каждого Строка Из Участники Цикл
	
		Отбор = Новый Структура("Участник", Строка.Участник); 
		
		НайденныеСтроки = СостоянияПриглашений.НайтиСтроки(Отбор);
		
		Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
			Строка.СостояниеПриглашения = НайденнаяСтрока.СостояниеПриглашения;
		КонецЦикла;  
	
	КонецЦикла; 
	
КонецФункции

&НаСервере
Процедура ОбработатьИзменениеОрганизатораДляПомещения()

	УстановитьПривилегированныйРежим(Истина);
	
	НачатьТранзакцию();
	
	Попытка
	
		БроньОбъект = Запись.Бронь.ПолучитьОбъект();
		БроньОбъект.Заблокировать();
		
		БроньОбъект.Автор = Пользователи.ТекущийПользователь();
		БроньОбъект.Пользователь = БроньОбъект.Автор;
		БроньОбъект.ДополнительныеСвойства.Вставить("ИзменениеСвязаннойБрони");
		БроньОбъект.Записать();
		
		ЗафиксироватьТранзакцию();
	
	Исключение
	    ОтменитьТранзакцию();
		ТекстСообщения = НСтр("ru = 'Не удалось изменить бронь помещения для этапа.'");
		ВызватьИсключение ТекстСообщения;
	КонецПопытки; 
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьИзменениеОрганизатораДляСинхронизации()
	
	УстановитьПривилегированныйРежим(Истина);
	НачатьТранзакцию();
	
	Попытка
		ДанныеСвязанныхЗаписей = 
			Справочники.ЗаписиРабочегоКалендаря.СвязанныеЗаписиКалендаря(Запись.Кандидат, Запись.ЭтапРаботы);
		
		Для Каждого ДанныеЗаписи Из ДанныеСвязанныхЗаписей Цикл
			Справочники.ЗаписиРабочегоКалендаря.УдалитьСвязаннуюЗаписьКалендаря(ДанныеЗаписи.Ссылка);
		КонецЦикла; 
		
		РегистрыСведений.УчастникиЭтапаРаботыСКандидатом.ЗаписатьУчастниковЭтапа(
			Запись.Кандидат, Запись.ЭтапРаботы, Неопределено);
			
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ТекстСообщения = НСтр("ru = 'Не удалось актуализировать данные этапа. Отмените его и запланируйте заново.'");
		ВызватьИсключение ТекстСообщения;
	КонецПопытки; 
	
КонецПроцедуры

#КонецОбласти