
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Приглашения.Параметры.УстановитьЗначениеПараметра("Ответственный", Пользователи.ТекущийПользователь());
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПриглашения

&НаКлиенте
Процедура ПриглашенияВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ТекДанные = Элемент.ТекущиеДанные;
	Если ТекДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Ключ", Элемент.ТекущиеДанные.Кандидат);
	ОткрытьФорму("Справочник.Кандидаты.Форма.ФормаЭлемента", ПараметрыОткрытия);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПриглашенияПриПолученииДанныхНаСервере(ИмяЭлемента, Настройки, Строки)
	
	Для Каждого СтрокаДС Из Строки Цикл
		ДанныеСтроки = СтрокаДС.Значение.Данные;
		ДанныеСтроки.Состояние = СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(
			НСтр("ru = 'Все придут;
			|Обязательный участник отклонил приглашение;;
			|%1 обязательных участника отклонили пришлашения;
			|%1 обязательных участников отклонили приглашения;'"),
			ДанныеСтроки.Отклонило,, "ЧДЦ=0");
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти