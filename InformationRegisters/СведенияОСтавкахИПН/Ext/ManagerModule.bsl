	ДобавитьСведенияОСтавкахИПНСПроверкой('20260101', Справочники.Организации.ПустаяСсылка(), Справочники.ВидыДоходов.Дивиденды,				5.0,  15.0, 15.0);
	ДобавитьСведенияОСтавкахИПНСПроверкой('20260101', Справочники.Организации.ПустаяСсылка(), Справочники.ВидыДоходов.ДоходыОтРаботодателя, 	10.0, 10.0, 15.0, 15.0);
	ДобавитьСведенияОСтавкахИПНСПроверкой('20260101', Справочники.Организации.ПустаяСсылка(), Справочники.ВидыДоходов.Вознаграждения,			10.0, 20.0, 15.0);
	ДобавитьСведенияОСтавкахИПНСПроверкой('20260101', Справочники.Организации.ПустаяСсылка(), Справочники.ВидыДоходов.Выигрыши,				 	10.0, 20.0, 15.0);
	ДобавитьСведенияОСтавкахИПНСПроверкой('20260101', Справочники.Организации.ПустаяСсылка(), Справочники.ВидыДоходов.ДоходыОтНалоговогоАгента, 10.0, 20.0, 15.0);
	ДобавитьСведенияОСтавкахИПНСПроверкой('20260101', Справочники.Организации.ПустаяСсылка(), Справочники.ВидыДоходов.ПрочиеДоходы,			 	10.0, 20.0, 20.0, 20.0);

КонецПроцедуры

