#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, Замещение)
	
	Если ЗарплатаКадры.ОтключитьБизнесЛогикуПриЗаписи(ЭтотОбъект) Тогда
		Возврат;
	КонецЕсли;
	
	СохранитьПрежнееСостояние();
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ, Замещение)

	Если ЗарплатаКадры.ОтключитьБизнесЛогикуПриЗаписи(ЭтотОбъект) Тогда
		Возврат;
	КонецЕсли;
	
	ИзменитьСостояниеСогласования(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура СохранитьПрежнееСостояние()
	
	Если Отбор["Вакансия"].Использование = Ложь Или Не ЗначениеЗаполнено(Отбор.Вакансия.Значение) Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеСвойства.Вставить("ПрежниеДанныеСостояния", 
		РегистрыСведений.СостоянияВакансий.ТекущееСостояниеВакансий(Отбор.Вакансия.Значение));
		
	РегистрыСведений.СостоянияВакансий.СохранитьПрежнийНаборЗаписей(ЭтотОбъект);
	
КонецПроцедуры

Процедура ИзменитьСостояниеСогласования(НаборЗаписей)
	
	Если Не ДополнительныеСвойства.Свойство("ПрежниеДанныеСостояния") Тогда
		Возврат;
	КонецЕсли;

	ПрежниеДанные = ДополнительныеСвойства["ПрежниеДанныеСостояния"];
	
	ВакансииМассив = Новый Массив;
	ВакансииМассив.Добавить(Отбор.Вакансия.Значение);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ВакансииМассив, 
		ОбщегоНазначения.ВыгрузитьКолонку(ПрежниеДанные, "Ключ"), Истина);
	
	ТекущиеДанные = РегистрыСведений.СостоянияВакансий.ТекущееСостояниеВакансий(ВакансииМассив);
	
	// Если у каких-то вакансий состояние изменилось, появилось или исчезло, 
	// уточняем состояние согласования по текущему состоянию.
	
	ДанныеВакансий = Справочники.Вакансии.ДанныеВакансий(ВакансииМассив);
	ОбщегоНазначенияБЗК.ДобавитьИндексКоллекции(ДанныеВакансий, "Вакансия");
	
	Для Каждого Вакансия Из ВакансииМассив Цикл
		НайденныеСтроки = ДанныеВакансий.НайтиСтроки(Новый Структура("Вакансия", Вакансия));
		Если НайденныеСтроки.Количество() = 0 Или ЗначениеЗаполнено(НайденныеСтроки[0].Основание) Тогда
			// Вакансия создана на основании заявки, отдельно не согласовывается.
			Продолжить;
		КонецЕсли;
		ПрежнееСостояние = СвойствоСтруктуры(ПрежниеДанные.Получить(Вакансия), "Состояние");
		ТекущееСостояние = СвойствоСтруктуры(ТекущиеДанные.Получить(Вакансия), "Состояние");
		СостояниеСогласования = СвойствоСтруктуры(СогласованиеВакансий.ДанныеСогласования(Вакансия), "СостояниеСогласования");
		Если Перечисления.СостоянияСогласования.РешениеПринято(СостояниеСогласования) Тогда
			// Решение принято, не трогаем эту вакансию.
			Продолжить;
		КонецЕсли;
		Если ПрежнееСостояние = ТекущееСостояние Тогда
			// Состояние не изменилось.
			Продолжить;
		КонецЕсли;
		Если ПрежнееСостояние = Перечисления.СостоянияВакансии.Открыта 
			И ТекущееСостояние <> Перечисления.СостоянияВакансии.Открыта Тогда
			// Отзываем с согласования.
			Если СостояниеСогласования <> Перечисления.СостоянияСогласования.ПустаяСсылка() Тогда
				СогласованиеВакансий.УстановитьСостояниеСогласования(
					Вакансия, Перечисления.СостоянияСогласования.ПустаяСсылка());
			КонецЕсли;
		КонецЕсли;
		Если ПрежнееСостояние <> Перечисления.СостоянияВакансии.Открыта 
			И ТекущееСостояние = Перечисления.СостоянияВакансии.Открыта Тогда
			// Направляем на согласование.
			Если СостояниеСогласования <> Перечисления.СостоянияСогласования.Рассматривается Тогда
				СогласованиеВакансий.УстановитьСостояниеСогласования(
					Вакансия, Перечисления.СостоянияСогласования.Рассматривается);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция СвойствоСтруктуры(Структура, Ключ)
	Возврат ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Структура, Ключ);
КонецФункции

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.'");
#КонецЕсли