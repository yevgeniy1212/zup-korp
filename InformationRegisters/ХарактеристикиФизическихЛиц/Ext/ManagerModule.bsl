#Область СлужебныеПроцедурыИФункции 

#Область ОбработчикиОбновления

Функция ЗаменитьФизическиеЛицаНаКандидатов() Экспорт

	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить(Метаданные.РегистрыСведений.ХарактеристикиФизическихЛиц.ПолноеИмя());
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;

	НачатьТранзакцию();
	Попытка
		Блокировка.Заблокировать();
		
		Запрос = Новый Запрос;
		Запрос.Текст =
			"ВЫБРАТЬ ПЕРВЫЕ 1000
			|	ХарактеристикиФизическихЛиц.Вакансия КАК Вакансия,
			|	ХарактеристикиФизическихЛиц.Этап КАК Этап,
			|	ХарактеристикиФизическихЛиц.ХарактеристикаПерсонала КАК ХарактеристикаПерсонала,
			|	ХарактеристикиФизическихЛиц.ЗначениеХарактеристики КАК ЗначениеХарактеристики,
			|	ХарактеристикиФизическихЛиц.ФизическоеЛицо КАК ФизическоеЛицо,
			|	ФизическиеЛицаКандидатов.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата,
			|	ХарактеристикиФизическихЛиц.Балл,
			|	ХарактеристикиФизическихЛиц.СпособОценкиХарактеристик,
			|	ХарактеристикиФизическихЛиц.Период
			|ИЗ
			|	РегистрСведений.ХарактеристикиФизическихЛиц КАК ХарактеристикиФизическихЛиц
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ФизическиеЛицаКандидатов КАК ФизическиеЛицаКандидатов
			|		ПО ХарактеристикиФизическихЛиц.ФизическоеЛицо = ФизическиеЛицаКандидатов.ФизическоеЛицо
			|ГДЕ
			|	ФизическиеЛицаКандидатов.ЛичныеДанныеКандидата <> ЗНАЧЕНИЕ(Справочник.ЛичныеДанныеКандидатов.ПустаяСсылка)";
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		КоличествоОбработанныхЗаписей = 0;
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			НаборЗаписей = РегистрыСведений.ХарактеристикиФизическихЛиц.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Вакансия.Установить(ВыборкаДетальныеЗаписи.Вакансия);
			НаборЗаписей.Отбор.Этап.Установить(ВыборкаДетальныеЗаписи.Этап);
			НаборЗаписей.Отбор.ФизическоеЛицо.Установить(ВыборкаДетальныеЗаписи.ФизическоеЛицо);
			НаборЗаписей.Отбор.ХарактеристикаПерсонала.Установить(ВыборкаДетальныеЗаписи.ХарактеристикаПерсонала);
			НаборЗаписей.Отбор.ЗначениеХарактеристики.Установить(ВыборкаДетальныеЗаписи.ЗначениеХарактеристики);
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(НаборЗаписей, Истина);
			
			НаборЗаписей.Отбор.Вакансия.Установить(ВыборкаДетальныеЗаписи.Вакансия);
			НаборЗаписей.Отбор.Этап.Установить(ВыборкаДетальныеЗаписи.Этап);
			НаборЗаписей.Отбор.ФизическоеЛицо.Установить(ВыборкаДетальныеЗаписи.ЛичныеДанныеКандидата);
			НаборЗаписей.Отбор.ХарактеристикаПерсонала.Установить(ВыборкаДетальныеЗаписи.ХарактеристикаПерсонала);
			НаборЗаписей.Отбор.ЗначениеХарактеристики.Установить(ВыборкаДетальныеЗаписи.ЗначениеХарактеристики);
			НоваяЗапись = НаборЗаписей.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяЗапись, ВыборкаДетальныеЗаписи);
			НоваяЗапись.ФизическоеЛицо = ВыборкаДетальныеЗаписи.ЛичныеДанныеКандидата;
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(НаборЗаписей, Истина);
			
			КоличествоОбработанныхЗаписей = КоличествоОбработанныхЗаписей + 1;
		КонецЦикла;
		ЗафиксироватьТранзакцию();
		
		Возврат КоличествоОбработанныхЗаписей = 0;
	Исключение
		ОтменитьТранзакцию();
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Обновление информационной базы.Ошибка заполнения кандидатов в регистре Характеристики физических лиц'",
				ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,
			Метаданные.РегистрыСведений.ХарактеристикиФизическихЛиц);
		Возврат Ложь;
	КонецПопытки;

КонецФункции

#КонецОбласти

#КонецОбласти

#КонецЕсли