// @strict-types

#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПриЗаписи(Отказ, Замещение)
	
	Если ЗарплатаКадры.ОтключитьБизнесЛогикуПриЗаписи(ЭтотОбъект) Тогда
		Возврат;
	КонецЕсли;
	
	Если Количество() = 0 
		Или Не (ЭтотОбъект[0].ИспользоватьРешениеОПриемеНаРаботу
			Или ЭтотОбъект[0].ИспользоватьРешениеОКадровомПереводе
			Или ЭтотОбъект[0].ИспользоватьРешениеОбУвольнении
			Или ЭтотОбъект[0].ИспользоватьРешениеОбОтпускеПоУходуЗаРебенком
			Или ЭтотОбъект[0].ИспользоватьРешениеОВозвратеИзОтпускаПоУходуЗаРебенком
			Или ЭтотОбъект[0].ИспользоватьРешениеОВосстановленииВДолжности) Тогда
		Константы.ИспользоватьАдаптациюУвольнение.Установить(Ложь);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.'");
#КонецЕсли