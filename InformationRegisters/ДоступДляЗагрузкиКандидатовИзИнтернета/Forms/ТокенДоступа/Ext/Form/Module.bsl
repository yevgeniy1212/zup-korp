#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Токен = Параметры.Токен;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	УстановитьВидимостьКопированияВБуферОбмена();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СкопироватьВБуферОбмена(Команда)
	СкопироватьТокенВБуферОбмена();
КонецПроцедуры

&НаКлиенте
Процедура ОК(Команда)
	Закрыть();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура УстановитьВидимостьКопированияВБуферОбмена()

	Если Не ДоступнаРаботаСБуферомОбмена() Тогда
		Элементы.СкопироватьВБуферОбмена.Видимость = Ложь;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура СкопироватьТокенВБуферОбмена()

	Если Не ДоступнаРаботаСБуферомОбмена() Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Работа с буфером обмена недоступна'"));
		Возврат;
	КонецЕсли;
	
	Попытка
		Объект = Новый COMОбъект("htmlfile");
		Объект.ParentWindow.ClipboardData.Setdata("Text", Токен);
		ПоказатьОповещениеПользователя(НСтр("ru = 'Успешно'"), , НСтр("ru = 'Токен доступа скопирован в буфер обмена'"));
	Исключение
		ВызватьИсключение НСтр("ru = 'Работа с буфером обмена недоступна'");
	КонецПопытки;

КонецПроцедуры

&НаКлиенте
Функция ДоступнаРаботаСБуферомОбмена()

	#Если Не ВебКлиент И Не МобильныйКлиент Тогда
		Возврат ОбщегоНазначенияКлиент.ЭтоWindowsКлиент();
	#КонецЕсли
	
	Возврат Ложь;
	
КонецФункции

#КонецОбласти