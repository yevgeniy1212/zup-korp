#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЗначенияДляЗаполнения  = Новый Структура("Организация", "Организация");
	ЗарплатаКадры.ЗаполнитьПервоначальныеЗначенияВФорме(ЭтаФорма, ЗначенияДляЗаполнения);
	ЗаполнитьНастройкиОрганизацииНаСервере();
	АвтоЗаголовок = Ложь;
	Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Идентификация по ФРМО подразделений организации %1'"), Организация);
	
	ЗаполнитьПодразделенияИБ();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСписок

&НаКлиенте
Процедура ПодразделенияИБВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ДанныеСтрокиПодразделенияИБ = Элементы.ПодразделенияИБ.ТекущиеДанные;
	Если ДанныеСтрокиПодразделенияИБ<>Неопределено Тогда
		ДанныеПодразделенияИБ = ДанныеСтрокиПодразделенияИБ;
		ТипПодразделенияКод = ДанныеПодразделенияИБ.ТипПодразделенияКод;
		ДанныеРодительскогоПодразделенияИБ = ДанныеПодразделенияИБ.ПолучитьРодителя();
		Пока ПустаяСтрока(ТипПодразделенияКод) И (ДанныеРодительскогоПодразделенияИБ<>Неопределено) Цикл 
			ДанныеПодразделенияИБ = ДанныеРодительскогоПодразделенияИБ;
			ТипПодразделенияКод = ДанныеПодразделенияИБ.ТипПодразделенияКод;
			ДанныеРодительскогоПодразделенияИБ = ДанныеПодразделенияИБ.ПолучитьРодителя();
		КонецЦикла;
		Если ПустаяСтрока(ТипПодразделенияКод) Тогда
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Подразделению организации не сопоставлен тип подразделения ФРМО.'"));
		Иначе 
			ТипПодразделения = Число(ТипПодразделенияКод);
			ОтборПоТипу = Новый Структура("Тип", ТипПодразделения);
			ОтобранныеСтроки = ПодразделенияФРМО.НайтиСтроки(ОтборПоТипу);
			Если ОтобранныеСтроки.Количество()=0 Тогда 
				ЗаполнитьПодразделенияФРМО(ТипПодразделения);
				ОтобранныеСтроки = ПодразделенияФРМО.НайтиСтроки(ОтборПоТипу);
			КонецЕсли;
			
			ПараметрыФормы = Новый Структура("ПодразделенияФРМО,ИдентификаторПодразделенияИБ", Новый Массив, ДанныеСтрокиПодразделенияИБ.ПолучитьИдентификатор());
			Для Каждого СтрокаПодразделения Из ОтобранныеСтроки Цикл 
				СтруктураСтроки = СтрокаПодразделенияВСтруктуру(СтрокаПодразделения);
				ПараметрыФормы.ПодразделенияФРМО.Добавить(СтруктураСтроки);
			КонецЦикла;
			СтандартнаяОбработка = Ложь;
			ОповещениеОЗакрытии = Новый ОписаниеОповещения("ЗаписатьВыбранныеИдентификаторы", ЭтотОбъект);
			ОткрытьФорму("РегистрСведений.ИдентификаторыОбъектовДляФедеральныхМедрегистров.Форма.ВыборПодразделенияФРМО", 
					ПараметрыФормы, ЭтотОбъект,,,, ОповещениеОЗакрытии, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьВыбранныеИдентификаторы(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Или Результат = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеСтрокиПодразделенияИБ = ПодразделенияИБ.НайтиПоИдентификатору(Результат.ИдентификаторПодразделенияИБ);
	Если ДанныеСтрокиПодразделенияИБ<>Неопределено Тогда
		ДанныеСтрокиПодразделенияИБ.НовыйИдентификаторПодразделения = Результат.Идентификатор;
		ДанныеСтрокиПодразделенияИБ.НовоеНаименованиеПодразделения = Результат.Наименование;
		ДанныеСтрокиПодразделенияИБ.НовыйИдентификаторОтделенияИлиКабинета = Результат.ДополнительныйИдентификатор;
		ДанныеСтрокиПодразделенияИБ.НовоеНаименованиеОтделенияИлиКабинета = Результат.ДополнительноеНаименование;
		Модифицированность = Истина;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Записать(Команда)
	
	Если Модифицированность Тогда
		СохранениеИзмененийНаСервере();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьПодразделенияИБ()
	
	Перем ДанныеСправочника, Запрос, КоллекцияЭлементовДерева;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ПодразделенияОрганизаций.Ссылка КАК Подразделение,
	|	ПодразделенияОрганизаций.Наименование КАК Наименование,
	|	ВЫБОР
	|		КОГДА ПодразделенияОрганизаций.ПометкаУдаления
	|			ТОГДА 4
	|		ИНАЧЕ 3
	|	КОНЕЦ КАК СтандартнаяКартинка,
	|	ХарактеристикиОбъектовДляФедеральныхМедрегистров.Характеристика.Код КАК ТипПодразделенияКод,
	|	ХарактеристикиОбъектовДляФедеральныхМедрегистров.Характеристика.НаименованиеПолное КАК ТипПодразделенияНаименование,
	|	ИдентификаторыОбъектовДляФедеральныхМедрегистров.Идентификатор КАК ИдентификаторПодразделения,
	|	ИдентификаторыОбъектовДляФедеральныхМедрегистров.Наименование КАК НаименованиеПодразделения,
	|	ИдентификаторыОбъектовДляФедеральныхМедрегистров.ДополнительныйИдентификатор КАК ИдентификаторОтделенияИлиКабинета,
	|	ИдентификаторыОбъектовДляФедеральныхМедрегистров.ДополнительноеНаименование КАК НаименованиеОтделенияИлиКабинета,
	|	ИдентификаторыОбъектовДляФедеральныхМедрегистров.Идентификатор КАК НовыйИдентификаторПодразделения,
	|	ИдентификаторыОбъектовДляФедеральныхМедрегистров.Наименование КАК НовоеНаименованиеПодразделения,
	|	ИдентификаторыОбъектовДляФедеральныхМедрегистров.ДополнительныйИдентификатор КАК НовыйИдентификаторОтделенияИлиКабинета,
	|	ИдентификаторыОбъектовДляФедеральныхМедрегистров.ДополнительноеНаименование КАК НовоеНаименованиеОтделенияИлиКабинета
	|ИЗ
	|	Справочник.ПодразделенияОрганизаций КАК ПодразделенияОрганизаций
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИдентификаторыОбъектовДляФедеральныхМедрегистров КАК ИдентификаторыОбъектовДляФедеральныхМедрегистров
	|		ПО (ИдентификаторыОбъектовДляФедеральныхМедрегистров.Объект = ПодразделенияОрганизаций.Ссылка)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ХарактеристикиОбъектовДляФедеральныхМедрегистров КАК ХарактеристикиОбъектовДляФедеральныхМедрегистров
	|		ПО (ХарактеристикиОбъектовДляФедеральныхМедрегистров.Объект = ПодразделенияОрганизаций.Ссылка)
	|			И (ХарактеристикиОбъектовДляФедеральныхМедрегистров.Классификатор.Код = ""1.2.643.5.1.13.13.99.2.299"")
	|ГДЕ
	|	ПодразделенияОрганизаций.Владелец = &Организация
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПодразделенияОрганизаций.Ссылка ИЕРАРХИЯ";
	
	Запрос.УстановитьПараметр("Организация", Организация);
	
	ДанныеСправочника = Запрос.Выполнить().Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);	
	КоллекцияЭлементовДерева = ПодразделенияИБ.ПолучитьЭлементы();
	ОбщегоНазначения.ЗаполнитьКоллекциюЭлементовДереваДанныхФормы(КоллекцияЭлементовДерева, ДанныеСправочника);

КонецПроцедуры

&НаСервере
Процедура СохранениеИзмененийНаСервере()
	
	ДеревоПодразделенийИБ = РеквизитФормыВЗначение("ПодразделенияИБ", Тип("ДеревоЗначений"));
	ДанныеИзменений = Новый Массив;
	ЗаполнитьДанныеИзменений(ДеревоПодразделенийИБ, ДанныеИзменений);
	СохранитьИзменения(ДанныеИзменений);
	Модифицированность = Ложь;

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаполнитьДанныеИзменений(ДеревоПодразделенийИБ, ДанныеИзменений)
	
	Для Каждого СтрокаДерева Из ДеревоПодразделенийИБ.Строки Цикл
		Если СтрокаДерева.НовыйИдентификаторПодразделения<>СтрокаДерева.ИдентификаторПодразделения
				Или СтрокаДерева.НовоеНаименованиеПодразделения<>СтрокаДерева.НаименованиеПодразделения
				Или СтрокаДерева.НовыйИдентификаторОтделенияИлиКабинета<>СтрокаДерева.ИдентификаторОтделенияИлиКабинета
				Или СтрокаДерева.НовоеНаименованиеОтделенияИлиКабинета<>СтрокаДерева.НаименованиеОтделенияИлиКабинета Тогда 
			НовоеИзменение = Новый Структура();
			НовоеИзменение.Вставить("Объект", СтрокаДерева.Подразделение);
			НовоеИзменение.Вставить("Идентификатор", СтрокаДерева.НовыйИдентификаторПодразделения);
			НовоеИзменение.Вставить("Наименование", СтрокаДерева.НовоеНаименованиеПодразделения);
			НовоеИзменение.Вставить("ДополнительныйИдентификатор", СтрокаДерева.НовыйИдентификаторОтделенияИлиКабинета);
			НовоеИзменение.Вставить("ДополнительноеНаименование", СтрокаДерева.НовоеНаименованиеОтделенияИлиКабинета);
			ДанныеИзменений.Добавить(НовоеИзменение);
		КонецЕсли;
		Если СтрокаДерева.Строки.Количество()>0 Тогда
			ЗаполнитьДанныеИзменений(СтрокаДерева, ДанныеИзменений);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры	
	
&НаСервереБезКонтекста
Процедура СохранитьИзменения(ДанныеИзменений)
	
	Для Каждого СтрокаИзменений Из ДанныеИзменений Цикл
		НаборДляЛогирования = РегистрыСведений.ИдентификаторыОбъектовДляФедеральныхМедрегистров.СоздатьНаборЗаписей();
		НаборДляЛогирования.Отбор.Объект.Установить(СтрокаИзменений.Объект);
		НаборДляЛогирования.Прочитать();
		Если НаборДляЛогирования.Количество() = 0 Тогда
			ЗаписьДляЛогирования = НаборДляЛогирования.Добавить();
		Иначе
			ЗаписьДляЛогирования = НаборДляЛогирования[0];
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(ЗаписьДляЛогирования, СтрокаИзменений);
		НаборДляЛогирования.Записать();
	КонецЦикла;
	
КонецПроцедуры	
	
&НаКлиенте
Функция СтрокаПодразделенияВСтруктуру(СтрокаПодразделения)
	Результат = Новый Структура("Тип,Наименование,Идентификатор,Уровень,Родитель");
	ЗаполнитьЗначенияСвойств(Результат, СтрокаПодразделения);
	СтруктураПодразделения = Новый Массив;
	ЭлементыСтруктурыПодразделения = СтрокаПодразделения.СтруктураПодразделения.ПолучитьЭлементы();
	Для Каждого ТекущийЭлементСтруктурыПодразделения Из ЭлементыСтруктурыПодразделения Цикл
		РеквизитыЭлементаСтруктурыПодразделения = Новый Структура("Наименование,Идентификатор");
		ЗаполнитьЗначенияСвойств(РеквизитыЭлементаСтруктурыПодразделения, ТекущийЭлементСтруктурыПодразделения);
		СтруктураПодразделения.Добавить(РеквизитыЭлементаСтруктурыПодразделения);
	КонецЦикла;
	Результат.Вставить("СтруктураПодразделения", СтруктураПодразделения);
	Возврат Результат;
КонецФункции

&НаКлиенте
Процедура ЗаполнитьПодразделенияФРМО(ТипПодразделения)
	
	Смещение = 0;
	Ограничение = 2;
	КоличествоЭлементов = 1; // Если 0, то вылетим при первой ошибке, т.к. КоличествоЭлементов будет равно ПолученоЭлементов.
	ПолученоЭлементов = 0;
	КоличествоПопыток = 1;
	МаксимумПопыток = 3;
	ПараметрыСервиса = ПараметрыСервиса();
	
	Пока Истина Цикл  
		ТокенДоступа = ТокенДоступа(ПараметрыСервиса);
		ПараметрыВызова = GetOrgDepart(ТипПодразделения, УИНОрганизации, Смещение, Ограничение);
		ОтветСервиса = ВызватьМетод(ТокенДоступа, ПараметрыВызова);
		Если ОтветСервиса.СообщениеОбОшибкеПользователю<>Неопределено Тогда
			СообщениеОбОшибкеПользователю = СтрШаблон(НСтр("ru = 'Получение списка подразделений из ФРМО: %1'"), ОтветСервиса.СообщениеОбОшибкеПользователю);
			ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибкеПользователю);
			КоличествоПопыток = КоличествоПопыток + 1;
		Иначе 
			КоличествоПопыток = 1;
			Смещение = Смещение + Ограничение;
			КоличествоЭлементов = ОтветСервиса.Количество;
			Для Каждого Подразделение Из ОтветСервиса.Контент Цикл
				ПолученоЭлементов = ПолученоЭлементов + 1;
				Если Не Подразделение.isPlanned Тогда 
					НовоеПодразделениеФРМО = ПодразделенияФРМО.Добавить();
					НовоеПодразделениеФРМО.Тип = ТипПодразделения;
					НовоеПодразделениеФРМО.Наименование = Подразделение.departName;
					НовоеПодразделениеФРМО.Идентификатор = Подразделение.oid;
					ПодчиненностьПодразделения = Подразделение.departStructure;
					НовоеПодразделениеФРМО.Уровень = ПодчиненностьПодразделения.level;
					НовоеПодразделениеФРМО.Родитель = ПодчиненностьПодразделения.headDepart;
					Если ТипПодразделения=1 Тогда // Ести кабинеты departReg -> room[] -> oid.
						Амбулатория = Неопределено;
						Если Подразделение.Свойство("departReg", Амбулатория) Тогда 
							Для Каждого Кабинет Из Амбулатория.room Цикл 
								НовыйКабинет = НовоеПодразделениеФРМО.СтруктураПодразделения.ПолучитьЭлементы().Добавить();
								НовыйКабинет.Наименование = Кабинет.subdivisionId.subdivision;
								НовыйКабинет.Идентификатор = Кабинет.oid;
							КонецЦикла;
						КонецЕсли;
					ИначеЕсли ТипПодразделения=3 Или ТипПодразделения=4 Тогда // Ести кабинеты, но в departLabs[] -> labOid.
						Лаборатории = Неопределено;
						Если Подразделение.Свойство("departLabs", Лаборатории) Тогда 
							Для Каждого Кабинет Из Лаборатории Цикл 
								НовыйКабинет = НовоеПодразделениеФРМО.СтруктураПодразделения.ПолучитьЭлементы().Добавить();
								НовыйКабинет.Наименование = Кабинет.roomTypeId.subdivision;
								НовыйКабинет.Идентификатор = Кабинет.labOid;
							КонецЦикла;
						КонецЕсли;
					ИначеЕсли ТипПодразделения=2 Тогда // Есть отделения
						Отделения = Неопределено;
						Если Подразделение.Свойство("departHospital", Отделения) Тогда 
							Для Каждого Отделение Из Отделения.hospitalSubdivision Цикл 
								НовоеОтделение = НовоеПодразделениеФРМО.СтруктураПодразделения.ПолучитьЭлементы().Добавить();
								НовоеОтделение.Наименование = Отделение.subdivisionName;
								НовоеОтделение.Идентификатор = Отделение.oid;
							КонецЦикла;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		Если ПолученоЭлементов>=КоличествоЭлементов Или КоличествоПопыток>МаксимумПопыток Тогда 
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры 

&НаСервереБезКонтекста
Функция ДанныеСертификата(СертификатСсылка)
	Возврат МедицинскиеРегистры.ДанныеСертификата(СертификатСсылка);
КонецФункции

&НаСервереБезКонтекста
Функция МоментВыпуска() Экспорт
	Возврат МедицинскиеРегистры.МоментВыпуска();
КонецФункции

&НаКлиенте
Функция ТокенДоступа(ПараметрыСервиса)
	АдресСервиса = ?(ПараметрыСервиса.ИспользоватьЗащищенноеСоединение, "https://", "http://") + ПараметрыСервиса.Адрес + ПараметрыСервиса.ТочкаДоступа;
	Возврат МедицинскиеРегистрыКлиент.ТокенДоступа(ДанныеСертификата(Сертификат), Пароль, АдресСервиса, МоментВыпуска(), ИдентификаторИнформационнойСистемы);
КонецФункции

&НаСервереБезКонтекста
Функция ВызватьМетод(ТокенДоступа, ПараметрыВызова)
	Возврат МедицинскиеРегистры.ВызватьМетод(ТокенДоступа, ПараметрыВызова);
КонецФункции

&НаСервереБезКонтекста
Функция ПараметрыСервиса()
	Возврат МедицинскиеРегистры.ПараметрыСервиса();
КонецФункции

&НаСервереБезКонтекста
Функция GetOrgDepart(departTypeId, oid, offset, limit) 
	Возврат МедицинскиеРегистрыФРМО.GetOrgDepart(departTypeId, oid, offset, limit);
КонецФункции

&НаСервере
Процедура ЗаполнитьНастройкиОрганизацииНаСервере()
	Если ЗначениеЗаполнено(Организация) Тогда
		НастройкиОрганизации = ПрочитатьНастройкиОрганизации(Организация);
		УИНОрганизации = НастройкиОрганизации.ИдентификаторДляМедрегистров;
		Сертификат = НастройкиОрганизации.Сертификат;
		ИдентификаторИнформационнойСистемы = НастройкиОрганизации.ИдентификаторИнформационнойСистемы;
	КонецЕсли;
КонецПроцедуры 

&НаСервереБезКонтекста
Функция ПрочитатьНастройкиОрганизации(Организация)
	Возврат МедицинскиеРегистры.ПолучитьНастройкиОрганизации(Организация)
КонецФункции 

#КонецОбласти
