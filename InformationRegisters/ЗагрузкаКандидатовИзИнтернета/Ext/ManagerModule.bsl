Функция НоваяЗагрузкаКандидата(ДанныеЗагрузки, Пользователь) Экспорт
	
	Идентификатор = Новый УникальныйИдентификатор();
	
	НаборЗаписей = РегистрыСведений.ЗагрузкаКандидатовИзИнтернета.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Идентификатор.Установить(Идентификатор);
	
	ЗаписьНабора = НаборЗаписей.Добавить();
	ЗаписьНабора.Идентификатор = Идентификатор;

	ЗаписьНабора.АдресРезюме = ДанныеЗагрузки.АдресРезюме;
	ЗаписьНабора.Вакансия = ДанныеЗагрузки.Вакансия;
	ЗаписьНабора.ГруппаДоступаКандидата = ДанныеЗагрузки.ГруппаДоступаКандидата;
	ЗаписьНабора.КомментарийПользователя = ДанныеЗагрузки.КомментарийПользователя;
	ЗаписьНабора.ДоступностьКомментария = ДанныеЗагрузки.ДоступностьКомментария;
	
	ЗаписьНабора.Пользователь = Пользователь;
	ЗаписьНабора.ДатаРегистрации = ТекущаяДатаСеанса();
	ЗаписьНабора.Состояние = Перечисления.СостоянияЗагрузкиКандидатовИзИнтернета.Зарегистрирован;
	ЗаписьНабора.ДатаСостояния = ЗаписьНабора.ДатаРегистрации;
	
	НаборЗаписей.Записать();
	
	Возврат Идентификатор;
	
КонецФункции

Функция НовыеДанныеЗагрузки() Экспорт
	
	ДанныеЗагрузки = Новый Структура();
	ДанныеЗагрузки.Вставить("АдресРезюме");
	ДанныеЗагрузки.Вставить("Вакансия");
	ДанныеЗагрузки.Вставить("ГруппаДоступаКандидата");
	ДанныеЗагрузки.Вставить("КомментарийПользователя", "");
	ДанныеЗагрузки.Вставить("ДоступностьКомментария", Перечисления.ДоступностьКомментарияКандидата.Общедоступный);
	
	Возврат ДанныеЗагрузки;
	
КонецФункции

Функция СостояниеЗагрузкиКандидата(ИдентификаторЗагрузки) Экспорт
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Идентификатор", ИдентификаторЗагрузки);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗагрузкаКандидатовИзИнтернета.Идентификатор КАК Идентификатор,
		|	ЗагрузкаКандидатовИзИнтернета.ДатаРегистрации КАК ДатаРегистрации,
		|	ЗагрузкаКандидатовИзИнтернета.Состояние КАК Состояние,
		|	ЗагрузкаКандидатовИзИнтернета.ДатаСостояния КАК ДатаСостояния,
		|	ЗагрузкаКандидатовИзИнтернета.КомментарийСостояния КАК КомментарийСостояния
		|ИЗ
		|	РегистрСведений.ЗагрузкаКандидатовИзИнтернета КАК ЗагрузкаКандидатовИзИнтернета
		|ГДЕ
		|	ЗагрузкаКандидатовИзИнтернета.Идентификатор = &Идентификатор";
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(РезультатЗапроса.Выгрузить()[0]);
	
КонецФункции

Функция НовыеДанныеСостояния() Экспорт
	
	Описание = Новый Структура();
	Описание.Вставить("Состояние");
	Описание.Вставить("Комментарий");
	Описание.Вставить("ЗагруженныйКандидат");
	Описание.Вставить("ЗагруженВручную");
	Возврат Описание;
	
КонецФункции

Процедура УстановитьСостояниеЗагрузкиКандидата(ИдентификаторЗагрузки, ОписаниеСостояния) Экспорт
	
	НаборЗаписей = СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Идентификатор.Установить(ИдентификаторЗагрузки);
	НаборЗаписей.Прочитать();
	
	Если НаборЗаписей.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ЗаписьНабора = НаборЗаписей[0];
	ЗаписьНабора.Состояние = ОписаниеСостояния.Состояние;
	ЗаписьНабора.КомментарийСостояния = ОписаниеСостояния.Комментарий;
	ЗаписьНабора.ДатаСостояния = ТекущаяДатаСеанса();
	ЗаписьНабора.Кандидат = ОписаниеСостояния.ЗагруженныйКандидат;
	ЗаписьНабора.ЗагруженВручную = ОписаниеСостояния.ЗагруженВручную;
	
	ЗаполнитьСведенияКандидата(ЗаписьНабора);
	
	НаборЗаписей.Записать();
	
КонецПроцедуры

Процедура ОтложитьЗагрузкиКандидатов(ИдентификаторыЗагрузки) Экспорт
	Обработано = 0;
	Для Каждого ИдентификаторЗагрузки Из ИдентификаторыЗагрузки Цикл
		ОтложитьЗагрузкуКандидата(ИдентификаторЗагрузки);
		Обработано = Обработано + 1;
		ДлительныеОперации.СообщитьПрогресс(Окр((Обработано / ИдентификаторыЗагрузки.Количество()) * 100));
	КонецЦикла;
КонецПроцедуры

Процедура ОтложитьЗагрузкуКандидата(ИдентификаторЗагрузки) Экспорт
	
	НаборЗаписей = СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Идентификатор.Установить(ИдентификаторЗагрузки);
	НаборЗаписей.Прочитать();
	
	Если НаборЗаписей.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ЗаписьНабора = НаборЗаписей[0];
	ЗаписьНабора.Отложена = Истина;
	НаборЗаписей.Записать();
	
КонецПроцедуры

Функция ЗависшиеОперацииЗагрузки(АдресРезюме) Экспорт
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("АдресРезюме", АдресРезюме);
	Запрос.УстановитьПараметр("Зависшие", Перечисления.СостоянияЗагрузкиКандидатовИзИнтернета.Зависшие());
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Загрузки.Идентификатор,
		|	Загрузки.АдресРезюме,
		|	Загрузки.Состояние,
		|	Загрузки.ДатаСостояния КАК ДатаСостояния,
		|	Загрузки.КомментарийСостояния КАК КомментарийСостояния,
		|	Загрузки.ДатаРегистрации КАК ДатаРегистрации,
		|	Загрузки.Вакансия,
		|	Загрузки.Пользователь
		|ИЗ
		|	РегистрСведений.ЗагрузкаКандидатовИзИнтернета КАК Загрузки
		|ГДЕ
		|	Загрузки.Состояние В (&Зависшие)
		|	И Загрузки.АдресРезюме = &АдресРезюме
		|	И НЕ Загрузки.Отложена
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДатаРегистрации УБЫВ";

	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Процедура ЗаполнитьСведенияКандидата(ЗаписьНабора)
	
	ЗаписьНабора.ПолКандидата = Неопределено;
	ЗаписьНабора.Сайт = Неопределено;
	
	Если Не ЗначениеЗаполнено(ЗаписьНабора.Кандидат) Тогда
		Возврат;
	КонецЕсли;
	
	РеквизитыКандидата = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
		ЗаписьНабора.Кандидат, "ЛичныеДанные, ИсточникИнформации");

	ЗаписьНабора.Сайт = РеквизитыКандидата.ИсточникИнформации;
	
	Если Не ЗначениеЗаполнено(РеквизитыКандидата.ЛичныеДанные) Тогда
		Возврат;
	КонецЕсли;
	
	СведенияОЛичныхДанныхКандидата = ПодборПерсонала.ОсновныеСведенияОЛичныхДанныхКандидатов(
		ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(РеквизитыКандидата.ЛичныеДанные));
	
	Если СведенияОЛичныхДанныхКандидата.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ЗаписьНабора.ПолКандидата = СведенияОЛичныхДанныхКандидата[0].Пол;
	
КонецПроцедуры

Функция НовыеЗагрузкиКандидатовИзИнтернета() Экспорт
	
	Результат = Новый Структура();
	Результат.Вставить("Загружены", Новый Массив);
	Результат.Вставить("НеЗагружены", Новый Массив);
	
	ПоследняяПроверка = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить(
		"ЗагрузкаКандидатовИзИнтернета", "МоментПроверки", Дата(1, 1, 1));
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("СМомента", ПоследняяПроверка);
	Запрос.УстановитьПараметр("Пользователь", Пользователи.АвторизованныйПользователь());
	Запрос.УстановитьПараметр("НеЗагруженные", Перечисления.СостоянияЗагрузкиКандидатовИзИнтернета.НеЗагруженные());
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Загрузки.Кандидат КАК Кандидат,
		|	Загрузки.Сайт КАК Сайт,
		|	Загрузки.ПолКандидата КАК Пол,
		|	Загрузки.ДатаСостояния КАК ДатаСостояния
		|ИЗ
		|	РегистрСведений.ЗагрузкаКандидатовИзИнтернета КАК Загрузки
		|ГДЕ
		|	Загрузки.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияЗагрузкиКандидатовИзИнтернета.Загружен)
		|	И Загрузки.ДатаСостояния > &СМомента
		|	И Загрузки.Пользователь = &Пользователь
		|	И НЕ Загрузки.ЗагруженВручную
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДатаСостояния
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Загрузки.Идентификатор,
		|	Загрузки.АдресРезюме,
		|	Загрузки.Состояние,
		|	Загрузки.ДатаСостояния КАК ДатаСостояния,
		|	Загрузки.КомментарийСостояния КАК КомментарийСостояния
		|ИЗ
		|	РегистрСведений.ЗагрузкаКандидатовИзИнтернета КАК Загрузки
		|ГДЕ
		|	Загрузки.Состояние В (&НеЗагруженные)
		|	И Загрузки.Пользователь = &Пользователь
		|	И НЕ Загрузки.Отложена
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДатаСостояния УБЫВ";

	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	ОбщегоНазначения.ХранилищеОбщихНастроекСохранить("ЗагрузкаКандидатовИзИнтернета", "МоментПроверки", ТекущаяДатаСеанса());
	
	Результат.Загружены = ОбщегоНазначения.ТаблицаЗначенийВМассив(РезультатыЗапроса[0].Выгрузить());

	ОповестилиОНеЗагруженных = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить(
		"ЗагрузкаКандидатовИзИнтернета", "ОповещениеОНезагруженных", Дата(1, 1, 1));
	
	НеЗагружены = ОбщегоНазначения.ТаблицаЗначенийВМассив(РезультатыЗапроса[1].Выгрузить());
	Если НеЗагружены.Количество() > 0 Тогда
		ПоследняяНеЗагрузка = НеЗагружены[0].ДатаСостояния;
		// Оповещаем о не загруженных через определенный интервал или если появились новые события
		Если Не ЗначениеЗаполнено(ОповестилиОНеЗагруженных) 
			Или ПоследняяНеЗагрузка > ОповестилиОНеЗагруженных 
			Или ОповестилиОНеЗагруженных + ИнтервалОповещенияОНеЗагруженных() < ТекущаяДатаСеанса() Тогда
			Результат.НеЗагружены = НеЗагружены;
			ОбщегоНазначения.ХранилищеОбщихНастроекСохранить("ЗагрузкаКандидатовИзИнтернета", 
				"ОповещениеОНезагруженных", ТекущаяДатаСеанса());
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ИнтервалОповещенияОНеЗагруженных()
	Возврат 3600;
КонецФункции

#КонецОбласти

#КонецЕсли