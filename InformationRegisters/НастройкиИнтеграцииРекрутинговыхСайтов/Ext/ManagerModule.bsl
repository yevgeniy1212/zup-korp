#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

#Область ОбработчикиПравилРегистрации

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ШаблонОбработчика
Процедура ПриЗаполненииНастроекОбработчиковПравилРегистрации(Настройки) Экспорт
	ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОтбораПоРазделамДанных(Настройки,
		"ПодборПерсонала");
КонецПроцедуры

#КонецОбласти

// Параметры:
//  Сайты - Массив из СправочникСсылка.ИсточникиИнформацииОКандидатах
//  Пользователь - СправочникСсылка.Пользователи
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//  * Ключ - СправочникСсылка.ИсточникиИнформацииОКандидатах
//  * Значение - Структура: См. РекрутинговыеСайтыСлужебный.НовыеРеквизитыСайта
Функция РеквизитыСайтов(Сайты, Пользователь) Экспорт
	
	РеквизитыСайтов = Новый Соответствие();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НастройкиИнтеграцииРекрутинговыхСайтов.Пользователь,
	|	НастройкиИнтеграцииРекрутинговыхСайтов.РекрутинговыйСайт КАК Сайт,
	|	НастройкиИнтеграцииРекрутинговыхСайтов.ИмяПользователя,
	|	НастройкиИнтеграцииРекрутинговыхСайтов.МаркерДоступа,
	|	НастройкиИнтеграцииРекрутинговыхСайтов.МаркерОбновления,
	|	НастройкиИнтеграцииРекрутинговыхСайтов.ДатаОкончанияДействияМаркераДоступа,
	|	НастройкиИнтеграцииРекрутинговыхСайтов.ИнтервалПроверкиОткликовКандидатов,
	|	НастройкиИнтеграцииРекрутинговыхСайтов.ИнтервалПроверкиКомментариевРезюме,
	|	НастройкиИнтеграцииРекрутинговыхСайтов.ИдентификаторПользователя,
	|	НастройкиИнтеграцииРекрутинговыхСайтов.Использовать КАК Подключен
	|ИЗ
	|	РегистрСведений.НастройкиИнтеграцииРекрутинговыхСайтов КАК НастройкиИнтеграцииРекрутинговыхСайтов
	|ГДЕ
	|	НастройкиИнтеграцииРекрутинговыхСайтов.Пользователь = &Пользователь
	|	И НастройкиИнтеграцииРекрутинговыхСайтов.Использовать
	|	И НастройкиИнтеграцииРекрутинговыхСайтов.РекрутинговыйСайт В (&Сайты)";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("Сайты", Сайты);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка= РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		РеквизитыСайта = РекрутинговыеСайтыСлужебный.НовыеРеквизитыСайта();
		ЗаполнитьЗначенияСвойств(РеквизитыСайта, Выборка);
		РеквизитыСайтов.Вставить(Выборка.Сайт, РеквизитыСайта);
	КонецЦикла;
	
	Возврат РеквизитыСайтов;
	
КонецФункции

#КонецОбласти

#КонецЕсли