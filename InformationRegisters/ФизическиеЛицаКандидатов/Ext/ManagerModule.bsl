#Область СлужебныйПрограммныйИнтерфейс

// Устанавливает связь кандидата с физическим лицом.
// 
// Параметры:
//  ЛичныеДанныеКандидата - СправочникСсылка.ЛичныеДанныеКандидатов
//  ФизическоеЛицо - СправочникСсылка.ФизическиеЛица
Процедура УстановитьСвязьКандидатаСФизическимЛицом(ЛичныеДанныеКандидата, ФизическоеЛицо) Экспорт
	
	НаборЗаписей = СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ЛичныеДанныеКандидата.Установить(ЛичныеДанныеКандидата);
	
	НоваяЗапись = НаборЗаписей.Добавить();
	НоваяЗапись.ЛичныеДанныеКандидата = ЛичныеДанныеКандидата;
	НоваяЗапись.ФизическоеЛицо = ФизическоеЛицо;
	
	НаборЗаписей.Записать();
	
КонецПроцедуры

// Удаляет связь физического лица с кандидатом.
// 
// Параметры:
//  ФизическоеЛицо - СправочникСсылка.ФизическиеЛица
Процедура УдалитьСвязьФизическогоЛицаСКандидатом(ФизическоеЛицо) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ФизическиеЛицаКандидатов.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата
		|ИЗ
		|	РегистрСведений.ФизическиеЛицаКандидатов КАК ФизическиеЛицаКандидатов
		|ГДЕ
		|	ФизическиеЛицаКандидатов.ФизическоеЛицо = &ФизическоеЛицо";
	
	Запрос.УстановитьПараметр("ФизическоеЛицо", ФизическоеЛицо);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ЛичныеДанныеКандидата = ВыборкаДетальныеЗаписи.ЛичныеДанныеКандидата; // СправочникСсылка.ЛичныеДанныеКандидатов
		УдалитьСвязьКандидатаСФизическимЛицом(ЛичныеДанныеКандидата);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Удаляет связь кандидата с физическим лицом.
// 
// Параметры:
//  ЛичныеДанныеКандидата - СправочникСсылка.ЛичныеДанныеКандидатов
Процедура УдалитьСвязьКандидатаСФизическимЛицом(ЛичныеДанныеКандидата)
	
	НаборЗаписей = СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ЛичныеДанныеКандидата.Установить(ЛичныеДанныеКандидата);
	НаборЗаписей.Записать();
	
КонецПроцедуры

