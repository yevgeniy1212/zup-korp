			<UseAlways>
				<Field>Список.Ссылка</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗЛИЧНЫЕ
	КандидатыПереопределяемый.Ссылка КАК Ссылка,
	КандидатыПереопределяемый.Код КАК Код,
	КандидатыПереопределяемый.Наименование КАК Наименование,
	КандидатыПереопределяемый.Вакансия КАК Вакансия,
	КандидатыПереопределяемый.ДатаРегистрации КАК ДатаРегистрации,
	КандидатыПереопределяемый.ДатаРешения КАК ДатаРешения,
	ДанныеПоискаФизическихЛицПереопределяемый.АдресаЭлектроннойПочты КАК АдресаЭлектроннойПочты,
	ДанныеПоискаФизическихЛицПереопределяемый.Телефоны КАК Телефоны
ИЗ
	Справочник.Кандидаты КАК КандидатыПереопределяемый
		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РешениеОПриемеНаРаботу КАК РешениеОПриемеНаРаботу
		ПО КандидатыПереопределяемый.Ссылка = РешениеОПриемеНаРаботу.Кандидат
		И КандидатыПереопределяемый.Позиция = РешениеОПриемеНаРаботу.ДолжностьПоШтатномуРасписанию
		И КандидатыПереопределяемый.ДатаРегистрации &lt; РешениеОПриемеНаРаботу.ДатаПриема
		И (НЕ РешениеОПриемеНаРаботу.ПометкаУдаления)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеПоискаФизическихЛиц КАК ДанныеПоискаФизическихЛицПереопределяемый
		ПО КандидатыПереопределяемый.ЛичныеДанные = ДанныеПоискаФизическихЛицПереопределяемый.ФизическоеЛицо
ГДЕ
	КандидатыПереопределяемый.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияСогласования.Согласовано)
	И (КандидатыПереопределяемый.Позиция.Владелец = &amp;Организация
	ИЛИ &amp;Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка))
	И (РешениеОПриемеНаРаботу.Ссылка ЕСТЬ NULL
	ИЛИ РешениеОПриемеНаРаботу.Ссылка = &amp;ТекущийДокумент)</QueryText>
				<MainTable>Catalog.Кандидаты</MainTable>
				<ListSettings>
					<dcsset:filter>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>dfcece9d-5077-440b-b6b3-45a5cb4538eb</dcsset:userSettingID>
					</dcsset:filter>
					<dcsset:order>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>88619765-ccb3-46c6-ac52-38e9c992ebd4</dcsset:userSettingID>
					</dcsset:order>
					<dcsset:conditionalAppearance>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>b75fecce-942b-4aed-abc9-e6a02e460fb3</dcsset:userSettingID>
					</dcsset:conditionalAppearance>
					<dcsset:itemsViewMode>Normal</dcsset:itemsViewMode>
					<dcsset:itemsUserSettingID>911b6018-f537-43e8-a417-da56b22f9aec</dcsset:itemsUserSettingID>
				</ListSettings>
			</Settings>
		</Attribute>
