			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ДокументЗаявкаНаОбучениеРазвитие.Ссылка КАК Ссылка,
	ВЫБОР
		КОГДА ДокументЗаявкаНаОбучениеРазвитие.Ссылка В (&amp;СписокУжеПодобранныхЗаявок)
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК УжеПодобрана,
	ДокументЗаявкаНаОбучениеРазвитие.Номер КАК Номер,
	ДокументЗаявкаНаОбучениеРазвитие.Дата КАК Дата,
	ДокументЗаявкаНаОбучениеРазвитие.Подразделение КАК Подразделение,
	ДокументЗаявкаНаОбучениеРазвитие.Мероприятие КАК Мероприятие,
	ДокументЗаявкаНаОбучениеРазвитие.ДатаНачала КАК ДатаНачала,
	ДокументЗаявкаНаОбучениеРазвитие.ДатаОкончания КАК ДатаОкончания,
	ДокументЗаявкаНаОбучениеРазвитие.СуммаРасходов КАК СуммаРасходов,
	ЕСТЬNULL(МероприятияОбученияРазвития.КоличествоУчебныхЧасов, 0) КАК КоличествоУчебныхЧасов,
	ДокументЗаявкаНаОбучениеРазвитие.Комментарий КАК Комментарий,
	ДокументЗаявкаНаОбучениеРазвитие.КраткийСоставДокумента КАК КраткийСоставДокумента,
	ДокументЗаявкаНаОбучениеРазвитие.Статус КАК Статус,
	ВЫБОР
		КОГДА ДинамическиеСтатусыЗаявок.Заявка ЕСТЬ NULL
			ТОГДА ВЫБОР
					КОГДА ДокументЗаявкаНаОбучениеРазвитие.Статус = ЗНАЧЕНИЕ(Перечисление.СостоянияСогласования.ПустаяСсылка)
						ТОГДА &amp;Готовится
					ИНАЧЕ ПРЕДСТАВЛЕНИЕ(ДокументЗаявкаНаОбучениеРазвитие.Статус)
				КОНЕЦ
		ИНАЧЕ &amp;Исполнена
	КОНЕЦ КАК СтатусНаименование,
	ЕСТЬNULL(ДинамическиеСтатусыЗаявок.ВключенаВОбучение, ЛОЖЬ) КАК ВключенаВОбучение,
	ВЫБОР
		КОГДА НаличиеФайлов.ЕстьФайлы ЕСТЬ NULL
			ТОГДА 0
		КОГДА НаличиеФайлов.ЕстьФайлы
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ЕстьФайлы
	
ИЗ
	Документ.ЗаявкаНаОбучениеРазвитие КАК ДокументЗаявкаНаОбучениеРазвитие
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.МероприятияОбученияРазвития КАК МероприятияОбученияРазвития
		ПО ДокументЗаявкаНаОбучениеРазвитие.Мероприятие = МероприятияОбученияРазвития.Ссылка
		{ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ РАЗЛИЧНЫЕ
			ОбучениеРазвитиеСотрудников.Основание КАК Заявка,
			ИСТИНА КАК ВключенаВОбучение
		ИЗ
			Документ.ОбучениеРазвитиеСотрудников КАК ОбучениеРазвитиеСотрудников
		ГДЕ
			ОбучениеРазвитиеСотрудников.Проведен
			И НЕ ОбучениеРазвитиеСотрудников.Основание = ЗНАЧЕНИЕ(Документ.ЗаявкаНаОбучениеРазвитие.ПустаяСсылка)
			И ОбучениеРазвитиеСотрудников.Ссылка &lt;&gt; &amp;РегистраторИсключение) КАК ДинамическиеСтатусыЗаявок
		ПО ДокументЗаявкаНаОбучениеРазвитие.Ссылка = ДинамическиеСтатусыЗаявок.Заявка}
		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеФайлов
		ПО ДокументЗаявкаНаОбучениеРазвитие.Ссылка = НаличиеФайлов.ОбъектСФайлами}
</QueryText>
