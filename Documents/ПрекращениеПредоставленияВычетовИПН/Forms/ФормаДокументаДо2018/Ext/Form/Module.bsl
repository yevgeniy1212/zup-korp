&НаСервере
Процедура ПриПолученииДанныхНаСервере()
	
	ЗарплатаКадрыКлиентСервер.ЗаполнитьМесяцПоДате(ЭтаФорма, "Объект.Месяц", "МесяцСтрокой");
	
	ПрочитатьВычетыПредыдущегоМесяца();
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьВычетыПредыдущегоМесяца()
	
	Если Объект.Сотрудник.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	ПредоставлятьПрочийВычет = Ложь;
	ПредоставлятьСтандартныйВычет = Ложь;
	ПредоставлятьЛьготу = Ложь;
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("Месяц",			Объект.Месяц);
	Запрос.УстановитьПараметр("ФизическоеЛицо",	Объект.Сотрудник);
	Запрос.УстановитьПараметр("Ссылка",			Объект.Ссылка);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВычетыФизическихЛицИПНСрезПоследних.ПредоставлятьВычет
	|ИЗ
	|	РегистрСведений.ВычетыФизическихЛицИПН.СрезПоследних(
	|			&Месяц,
	|			Регистратор <> &Ссылка
	|				И ФизическоеЛицо = &ФизическоеЛицо) КАК ВычетыФизическихЛицИПНСрезПоследних";
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ПредоставлятьСтандартныйВычет = Выборка.ПредоставлятьВычет;
	Иначе
		ПредоставлятьПрочийВычет = Ложь;
	КонецЕсли;
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЛьготыФизическихЛицИПНСрезПоследних.ПредоставлятьЛьготу,
	|	ЛьготыФизическихЛицИПНСрезПоследних.ДействуетДо КАК ДействуетДо,
	|	ЛьготыФизическихЛицИПНСрезПоследних.КатегорияЛицаПолучателяЛьготы,
	|	ЛьготыФизическихЛицИПНСрезПоследних.Основание
	|ИЗ
	|	РегистрСведений.ЛьготыФизическихЛицИПН.СрезПоследних(
	|			&Месяц,
	|			Регистратор <> &Ссылка
	|				И ФизическоеЛицо = &ФизическоеЛицо) КАК ЛьготыФизическихЛицИПНСрезПоследних
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДействуетДо";

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ПредоставлятьЛьготу = Выборка.ПредоставлятьЛьготу;
		КатегорияЛицаПолучателяЛьготы = Выборка.КатегорияЛицаПолучателяЛьготы;
		ДействуетДо = Выборка.ДействуетДо;
		ДокументПодтверждающийПравоНаЛьготу = Выборка.Основание;
	Иначе
		ПредоставлятьЛьготу = Ложь;
	КонецЕсли;

	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.ВидВычета КАК ВидВычетаИПН,
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.ДействуетПо КАК ДействуетПо,
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.Размер,
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.Основание КАК ДокументПодтверждающийПравоНаВычет
	|ИЗ
	|	РегистрСведений.ПрочиеВычетыФизическихЛицИПН.СрезПоследних(
	|			&Месяц,
	|			Регистратор <> &Ссылка
	|				И ФизическоеЛицо = &ФизическоеЛицо) КАК ПрочиеВычетыФизическихЛицИПНСрезПоследних
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.ВидВычета,
	|	ДействуетПо";

	Выборка = Запрос.Выполнить().Выбрать();
	
	ПрочиеВычеты.Очистить();
	Пока Выборка.Следующий() Цикл
		ПредоставлятьПрочийВычет = Истина; 
		ЗаполнитьЗначенияСвойств(ПрочиеВычеты.Добавить(), Выборка);
	КонецЦикла;
	
	ОбновитьОписаниеВычетовЛьгот();
	УстановитьИнформационнуюНадписьОВозможностиПроведения();

КонецПроцедуры

&НаСервере
Процедура ОбновитьОписаниеВычетовЛьгот()
	
	Если ПредоставлятьСтандартныйВычет Тогда
		Элементы.ПрекращаемыйСтандартныйВычет.Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Предоставляется стандартный вычет на %1 года.'"), МесяцСтрокой);
	Иначе
		Элементы.ПрекращаемыйСтандартныйВычет.Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Стандартный вычет на %1 года не предоставляется.'"), МесяцСтрокой);
	КонецЕсли;
	
		
	Если ПредоставлятьЛьготу Тогда
		Элементы.ПрекращаемаяЛьгота.Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Предоставляется льгота на %1 года.
																													|Категория лица получателя льготы: %2. Льгота действует %3 %4.
																													|Документ подтверждающий право на льготу: %5'"),
																										МесяцСтрокой,
																										КатегорияЛицаПолучателяЛьготы,
																										?(ЗначениеЗаполнено(ДействуетДо), НСтр("ru = 'до'"), НСтр("ru = ''")), 
																										?(ЗначениеЗаполнено(ДействуетДо), Формат(ДействуетДо, "ДФ=dd.MM.yyyy"), НСтр("ru = 'бессрочно'")),
																										ДокументПодтверждающийПравоНаЛьготу);
	Иначе
		Элементы.ПрекращаемаяЛьгота.Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Льгота на %1 года не предоставляется.'"), МесяцСтрокой);
	КонецЕсли;
	
	Если ПредоставлятьПрочийВычет Тогда
		Элементы.ПрекращаемыйПрочийВычет.Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Предоставляются прочие вычеты на %1 года.'"), МесяцСтрокой);
	Иначе
		Элементы.ПрекращаемыйПрочийВычет.Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Прочие вычеты на %1 года не предоставляются.'"), МесяцСтрокой);
	КонецЕсли;
	
	Элементы.ПрочиеВычеты.Видимость = ПредоставлятьПрочийВычет;

	
КонецПроцедуры

&НаСервере
Процедура УстановитьИнформационнуюНадписьОВозможностиПроведения()
	
	ИнформацияОВозможностиПроведения = "";
	
	Запрос = Новый Запрос;
	Запрос.Текст = Документы.ПрекращениеПредоставленияВычетовИПН.ТекстЗапросаКонфликтующиеРегистраторы();
	
	Запрос.УстановитьПараметр("ФизическоеЛицо",	Объект.Сотрудник);
	Запрос.УстановитьПараметр("Период",			Объект.Месяц);
	Запрос.УстановитьПараметр("Регистратор",	Объект.Ссылка);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если Не РезультатЗапроса.Пустой() Тогда
		
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		
		ИнформацияОВозможностиПроведения = Новый ФорматированнаяСтрока(
			НСтр("ru='Документ не может быть проведен. На'") + " ",
			НРег(Формат(Объект.Месяц, "ДФ='ММММ гггг'")) + " ",
			НСтр("ru='уже введено заявление'")
		);
			
		Если ТипЗнч(Выборка.Регистратор) = Тип("ДокументСсылка.ПрекращениеПредоставленияВычетовИПН") Тогда
			
			ИнформацияОВозможностиПроведения = Новый ФорматированнаяСтрока(
				ИнформацияОВозможностиПроведения,
				" " + НСтр("ru='о прекращении вычетов'"),
				" (",
				Новый ФорматированнаяСтрока(Выборка.ПредставлениеРегистратора, , , , ПолучитьНавигационнуюСсылку(Выборка.Регистратор)),
				")"
			);
			
		Иначе
			
			ИнформацияОВозможностиПроведения = Новый ФорматированнаяСтрока(
				ИнформацияОВозможностиПроведения,
				" " + НСтр("ru='на вычеты'")
			);
			
			ОрганизацияРегистратора = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Выборка.Регистратор, "Организация");
			Если Объект.Организация = ОрганизацияРегистратора Тогда

				ИнформацияОВозможностиПроведения = Новый ФорматированнаяСтрока(
					ИнформацияОВозможностиПроведения,
					" (",
					Новый ФорматированнаяСтрока(Выборка.ПредставлениеРегистратора, , , , ПолучитьНавигационнуюСсылку(Выборка.Регистратор)),
					")"
				);
				
			Иначе
				
				ИнформацияОВозможностиПроведения = Новый ФорматированнаяСтрока(
					ИнформацияОВозможностиПроведения,
					" " + НСтр("ru='в другой организации'"),
					" (",
					Новый ФорматированнаяСтрока(Выборка.ПредставлениеРегистратора, , , , ПолучитьНавигационнуюСсылку(Выборка.Регистратор)),
					")"
				);
				
			КонецЕсли;
			
		КонецЕсли; 
		
	КонецЕсли; 
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ИнформацияОВозможностиПроведения",
		"Заголовок",
		ИнформацияОВозможностиПроведения
	);
	
КонецПроцедуры

&НаКлиенте
Процедура КонтрольМесяца()
	
	ДатаКонтроля = '2018-01-01';
	
	Если Объект.Месяц >= ДатаКонтроля Тогда
		
		ТекстВопроса = НСтр("ru = 'Изменение месяца приведет к переоткрытию формы. Продолжить?'");
		
		ОписаниеОповещения = Новый ОписаниеОповещения("КонтрольМесяцаВопрос", ЭтотОбъект);
		ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КонтрольМесяцаВопрос(Результат, ДопПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Да Тогда
		
		ПараметрыФормы = Новый Структура;
		ПараметрыФормы.Вставить("Месяц",Объект.Месяц);
		ПараметрыФормы.Вставить("Организация",Объект.Организация);
		ПараметрыФормы.Вставить("Сотрудник",Объект.Сотрудник);
		ПараметрыФормы.Вставить("Ответственный",Объект.Ответственный);
		ПараметрыФормы.Вставить("Комментарий",Объект.Комментарий);
		ПараметрыФормы.Вставить("СменаФормы",Истина);
		ПараметрыФормы.Вставить("Модифицированность",Модифицированность);
		ПараметрыФормы.Вставить("Ключ",Объект.Ссылка);
		
		ОткрытьФорму("Документ.ПрекращениеПредоставленияВычетовИПН.Форма.ФормаДокумента",ПараметрыФормы);
		Модифицированность = Ложь;
		Закрыть();
		
	Иначе
		Объект.Месяц = НачалоМесяца('2017-12-01');
		МесяцСтрокой = НСтр("ru='Декабрь 2017'");
		ПрочитатьВычетыПредыдущегоМесяца();
	КонецЕсли;
	
КонецПроцедуры


#КонецОбласти