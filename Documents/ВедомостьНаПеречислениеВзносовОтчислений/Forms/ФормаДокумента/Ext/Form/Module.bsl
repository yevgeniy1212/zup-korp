КонецФункции	

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимостьВидаДоходов(Форма)
    
    Объект = Форма.Объект;
    Элементы = Форма.Элементы;
    
	ПоказыватьПорядокЗаполнения = (НЕ ЗначениеЗаполнено(Форма.ДатаКорректировкиВеденияУчетаПоДаннымНВО) 
                   ИЛИ Форма.ДатаКорректировкиВеденияУчетаПоДаннымНВО <= Объект.ПериодРегистрации)
                И (Объект.ВидНалогаВзносаОтчисления = ПредопределенноеЗначение("Перечисление.ВидыНалоговВзносовОтчислений.ВОСМС")
                    ИЛИ Объект.ВидНалогаВзносаОтчисления = ПредопределенноеЗначение("Перечисление.ВидыНалоговВзносовОтчислений.СО")
                    ИЛИ Объект.ВидНалогаВзносаОтчисления = ПредопределенноеЗначение("Перечисление.ВидыНалоговВзносовОтчислений.ОПВ"))
                И (Объект.ВидПлатежа <> ПредопределенноеЗначение("Перечисление.ВидыПлатежейВГосБюджет.ПениАкт")
                    И Объект.ВидПлатежа <> ПредопределенноеЗначение("Перечисление.ВидыПлатежейВГосБюджет.ПениСам")); 
                    
    ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ВидДохода",
		"Видимость",
		ПоказыватьПорядокЗаполнения);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидДохода()
    
    Если (НЕ ЗначениеЗаполнено(ДатаКорректировкиВеденияУчетаПоДаннымНВО) 
        ИЛИ ДатаКорректировкиВеденияУчетаПоДаннымНВО <= Объект.ПериодРегистрации)
        И (Объект.ВидПлатежа <> ПредопределенноеЗначение("Перечисление.ВидыПлатежейВГосБюджет.ПениАкт")
        И Объект.ВидПлатежа <> ПредопределенноеЗначение("Перечисление.ВидыПлатежейВГосБюджет.ПениСам")) Тогда
        Если Объект.ВидНалогаВзносаОтчисления = ПредопределенноеЗначение("Перечисление.ВидыНалоговВзносовОтчислений.ЕП")
            ИЛИ Объект.ВидНалогаВзносаОтчисления = ПредопределенноеЗначение("Перечисление.ВидыНалоговВзносовОтчислений.ООСМС")
            ИЛИ Объект.ВидНалогаВзносаОтчисления = ПредопределенноеЗначение("Перечисление.ВидыНалоговВзносовОтчислений.ОПВР")
            ИЛИ Объект.ВидНалогаВзносаОтчисления = ПредопределенноеЗначение("Перечисление.ВидыНалоговВзносовОтчислений.ОППВ") Тогда
            Объект.ВидДохода = ПредопределенноеЗначение("Справочник.ВидыДоходов.ДоходыОтРаботодателя");        
        Иначе	
            Объект.ВидДохода = ?(НЕ ЗначениеЗаполнено(Объект.ВидДохода), ПредопределенноеЗначение("Справочник.ВидыДоходов.ДоходыОтРаботодателя"), Объект.ВидДохода);        
        КонецЕсли;
    Иначе
        Объект.ВидДохода = ПредопределенноеЗначение("Справочник.ВидыДоходов.ПустаяСсылка");
    КонецЕсли;                

    УстановитьВидимостьВидаДоходов(ЭтаФорма);
    
КонецПроцедуры

#КонецОбласти

#Область ПроцедурыФормыРедактированияНалоговВзносовОтчесленийСтрокиВедомости

&НаКлиенте
Процедура РедактироватьНалогиВзносыОтчисленияСтроки(ДанныеСтроки) Экспорт
	
	Если ДанныеСтроки = Неопределено Тогда
		Возврат
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура;
	
	ПараметрыОткрытия.Вставить("Организация",			ПредопределенноеЗначение("Справочник.Организации.ПустаяСсылка"));
	ПараметрыОткрытия.Вставить("Подразделение",			ПредопределенноеЗначение("Справочник.ПодразделенияОрганизаций.ПустаяСсылка"));
	ПараметрыОткрытия.Вставить("ПериодРегистрации",		Дата(1,1,1));
	ЗаполнитьЗначенияСвойств(ПараметрыОткрытия, Объект);
	
	ПараметрыОткрытия.Вставить("ФизическоеЛицо", 		ДанныеСтроки.ФизическоеЛицо);
	ПараметрыОткрытия.Вставить("АдресВХранилищеНалогиВзносыОтчисленияПоСтроке", АдресВХранилищеНалогиВзносыОтчисленияПоСтроке(ДанныеСтроки.ФизическоеЛицо));
	
	ПараметрыОткрытия.Вставить("ТолькоПросмотр",		ЭтаФорма.ТолькоПросмотр);
	ПараметрыОткрытия.Вставить("ВидНалогаВзносаОтчисления", Объект.ВидНалогаВзносаОтчисления);
	ПараметрыОткрытия.Вставить("ВидПлатежа", 			Объект.ВидПлатежа);
	ПараметрыОткрытия.Вставить("ВидДохода", 			Объект.ВидДохода);
	ПараметрыОткрытия.Вставить("ДатаКорректировкиВеденияУчетаПоДаннымНВО", ДатаКорректировкиВеденияУчетаПоДаннымНВО);
	
	Оповещение = Новый ОписаниеОповещения("ВедомостьРедактироватьНалогиВзносыОтчисленияСтрокиЗавершение", ЭтотОбъект);
	ОткрытьФорму("Документ.ВедомостьНаПеречислениеВзносовОтчислений.Форма.РедактированиеСтрокиВедомости", ПараметрыОткрытия, ЭтаФорма, , , , Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ВедомостьРедактироватьНалогиВзносыОтчисленияСтрокиЗавершение(РезультатыРедактирования, ДополнительныеПараметры) Экспорт
	
	Если РезультатыРедактирования <> Неопределено И РезультатыРедактирования.Модифицированность Тогда
		РедактироватьНалогиВзносыОтчисленияСтрокиЗавершениеНаСервере(РезультатыРедактирования);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура РедактироватьНалогиВзносыОтчисленияСтрокиЗавершениеНаСервере(РезультатыРедактирования) Экспорт
	
	ФизическоеЛицо = РезультатыРедактирования.ФизическоеЛицо;
	
	УдаляемыеСтроки = Объект.НалогиВзносыОтчисления.НайтиСтроки(Новый Структура("ФизическоеЛицо", ФизическоеЛицо));
	Для Каждого УдаляемаяСтрока Из УдаляемыеСтроки Цикл
		Объект.НалогиВзносыОтчисления.Удалить(УдаляемаяСтрока);
	КонецЦикла;	
	
	НалогиВзносыОтчисленияСтроки = ПолучитьИзВременногоХранилища(РезультатыРедактирования.АдресВХранилищеНалогиВзносыОтчисленияПоСтроке);

	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(НалогиВзносыОтчисленияСтроки, Объект.НалогиВзносыОтчисления);

	ПриПолученииДанныхНаСервере();
		
	Модифицированность = Истина;

КонецПроцедуры

#КонецОбласти

// ИнтеграцияС1СДокументооборотом
&НаКлиенте
Процедура Подключаемый_ВыполнитьКомандуИнтеграции(Команда)
	
