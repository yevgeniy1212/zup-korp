&НаСервере
Процедура УстановитьФункциональныеОпцииФормы()
	
	ПараметрыФО = Новый Структура("Организация", Объект.Организация);
	УстановитьПараметрыФункциональныхОпцийФормы(ПараметрыФО);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьДанныеПоПозицииНаКлиенте()
	
	Если Не ЗначениеЗаполнено(Объект.ДолжностьПоШтатномуРасписанию) Тогда
		Объект.ВариантОплатыТруда = ПредопределенноеЗначение("Перечисление.ВариантыОплатыТруда.СогласованныйДоход");
		Возврат;
	КонецЕсли;
	
	ЗаполнитьДанныеПоПозицииНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтобразитьКадровыеДанныеДоПереводаНаКлиенте()
	
	Если Не ЗначениеЗаполнено(Объект.Сотрудник) Тогда
		Элементы.Подразделение.Подсказка = "";
		Элементы.ДолжностьПоШтатномуРасписанию.Подсказка = "";
		Элементы.РабочееМесто.Подсказка = "";
		Возврат;
	КонецЕсли;
	
	ОтобразитьКадровыеДанныеДоПереводаНаСервере();
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьДоступностьИзмененияКадровыхДанных(Форма)
	
	Элементы = Форма.Элементы;
	Объект = Форма.Объект;
	
	ДоступностьИзменения = ЗначениеЗаполнено(Объект.Сотрудник);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы, "ГлавноеГруппа", "Доступность", ДоступностьИзменения);
	
	Если ДоступностьИзменения Тогда
		УстановитьДоступностьИзмененияПодразделенияИДолжности(Форма);
		УстановитьДоступностьИзмененияТерритории(Форма);
		УстановитьДоступностьИзмененияРабочегоМеста(Форма);
		УстановитьДоступностьИзмененияДистанционнойРаботы(Форма);
		УстановитьДоступностьИзмененияОплатыТруда(Форма);
	КонецЕсли;
	
КонецПроцедуры

