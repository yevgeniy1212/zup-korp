&НаСервере
Процедура УстановитьДоступностьЭлементов()
	
	ПриказОформлен = ЗначениеЗаполнено(КадровыйПриказИнфоНадпись);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы, "ОсновноеГруппа", "Доступность", Не ПриказОформлен);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы, "СтандартныеГруппа", "Доступность", Не ПриказОформлен);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы, "ДатаНачала", "Доступность", Не ПриказОформлен);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы, "ДатаОкончания", "Доступность", Не ПриказОформлен);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы, "ГлавноеГруппа", "Доступность", Не ПриказОформлен);
	
	УстановитьВидимостьЗадачАдаптации();
	УстановитьОтображениеЗакладокФормы();
	
	Если Не ПриказОформлен Тогда
		УстановитьДоступностьИзмененияКадровыхДанных(ЭтаФорма);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьЗадачАдаптации()
	Элементы.ЗадачиАдаптацииСтраница.Видимость = ПолучитьФункциональнуюОпцию("ИспользоватьАдаптациюУвольнение");
КонецПроцедуры

&НаСервере
Процедура УстановитьОтображениеЗакладокФормы()
	
	Если (Не Элементы.ЗадачиАдаптацииСтраница.Видимость 
		Или Элементы.ЗадачиАдаптацииСтраница.ПодчиненныеЭлементы.Количество() = 0) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
			Элементы, "СтраницыФормы", "ОтображениеСтраниц", ОтображениеСтраницФормы.Нет);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьМероприятия()
	Объект.МероприятияАдаптацииУвольнения.Очистить();
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьПодразделение()
	Объект.Подразделение = Неопределено;
КонецПроцедуры

&НаКлиенте
Процедура НачатьПерезаполнениеМероприятий()
	
	Если Объект.МероприятияАдаптацииУвольнения.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ЗаголовокВопроса = НСтр("ru = 'Задачи адаптации'");
	ТекстВопроса = НСтр("ru = 'Перезаполнить список мероприятий?'");
	ОписаниеОповещения = Новый ОписаниеОповещения("ЗавершитьПерезаполнениеМероприятий", ЭтотОбъект);
	ПоказатьВопрос(ОписаниеОповещения, ТекстВопроса, РежимДиалогаВопрос.ДаНет,,, ЗаголовокВопроса);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьПерезаполнениеМероприятий(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьМероприятияЗавершение(Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьМероприятияЗавершение(Отказ, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если Не Отказ И ЗначениеЗаполнено(Объект.ДолжностьПоШтатномуРасписанию) Тогда
		ЗаполнитьМероприятияНаСервере();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьМероприятияНаСервере()
	
	ПараметрыЗаполнения = Документы.РешениеОКадровомПереводе.ПараметрыЗаполненияМероприятий(Объект);
	АдаптацияУвольнениеФормы.КадровыйПереводЗаполнитьНазначаемыеМероприятия(ЭтотОбъект, ПараметрыЗаполнения);
	
КонецПроцедуры

&НаКлиенте
Функция ПараметрыПолученияСвойствНазначаемогоМероприятия()
	
	ПараметрыПолучения = АдаптацияУвольнениеКлиент.ПараметрыПолученияСвойствНазначаемогоМероприятия();
	ПараметрыПолучения.ФизическоеЛицо = Объект.ФизическоеЛицо;
	ПараметрыПолучения.ДатаСобытия = Объект.ДатаНачала;
	
	Возврат ПараметрыПолучения;
	
КонецФункции

&НаСервере
Процедура ОрганизацияПриИзмененииНаСервере()
	
	ПрочитатьГоловнуюОрганизацию();
	
	ТекущееОбособленноеПодразделение = Объект.ОбособленноеПодразделение;
	
	Если ЗначениеЗаполнено(Объект.Организация) И НЕ ЗначениеЗаполнено(Объект.ОбособленноеПодразделение) Тогда
		Объект.ОбособленноеПодразделение = Объект.Организация;
	ИначеЕсли Объект.Организация <> Объект.ОбособленноеПодразделение Тогда
		Если ГоловнаяОрганизация <> ЗарплатаКадры.ГоловнаяОрганизация(Объект.ОбособленноеПодразделение) Тогда
			Объект.ОбособленноеПодразделение = Справочники.Организации.ПустаяСсылка();
		КонецЕсли;
	КонецЕсли;
	
	Если ТекущееОбособленноеПодразделение <> Объект.ОбособленноеПодразделение Тогда
		Объект.ДолжностьПоШтатномуРасписанию = Справочники.ШтатноеРасписание.ПустаяСсылка();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьГоловнуюОрганизацию()
	ГоловнаяОрганизация = ЗарплатаКадры.ГоловнаяОрганизация(Объект.Организация);
КонецПроцедуры

&НаСервере
Процедура ОбновитьДанныеФормы()
	
	УстановитьПривилегированныйРежим(Истина);
	КадровыеРешенияФормы.ФормаДокументаПриПолученииДанных(ЭтотОбъект);
	УстановитьПривилегированныйРежим(Ложь);
	
	УстановитьДоступностьЭлементов();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьОплатыТруда()
	
	Если Не Пользователи.РолиДоступны("ЧтениеНачисленийШтатногоРасписания", , Ложь) Тогда
		Элементы.СогласованныйДоход.Видимость = Истина;
		Элементы.ОплатаТруда.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Объект.ДолжностьПоШтатномуРасписанию) Тогда
		Элементы.ОплатаТруда.Видимость = Истина;
		Элементы.СогласованныйДоход.Видимость = Ложь;
		ФОТ = Объект.ДолжностьПоШтатномуРасписанию.ФОТ;
	Иначе
		Элементы.ОплатаТруда.Видимость = Ложь;
		Элементы.СогласованныйДоход.Видимость = Истина;
		ФОТ = 0;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеПоПозицииНаСервере()
	
	ДанныеПозиции = ДанныеПозицииШтатногоРасписания(Объект.ДолжностьПоШтатномуРасписанию);
	
	Если Не ЗначениеЗаполнено(Объект.ОбособленноеПодразделение) Тогда
		Объект.ОбособленноеПодразделение = ДанныеПозиции.Организация;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Подразделение) Тогда
		Объект.Подразделение = ДанныеПозиции.Подразделение;
	КонецЕсли;
	
	Должность = ДанныеПозиции.Должность;
	Объект.ВариантОплатыТруда = Перечисления.ВариантыОплатыТруда.ФОТ;
	
	УстановитьДоступностьРабочегоМеста(ЭтаФорма);
	СписокРабочихМест = СписокРабочихМестПоДаннымПозиции(ДанныеПозиции);
	Элементы.РабочееМесто.СписокВыбора.ЗагрузитьЗначения(СписокРабочихМест.ВыгрузитьЗначения());
	ЗаполнитьРабочееМесто(ЭтаФорма, СписокРабочихМест);
	
КонецПроцедуры

&НаСервере
Процедура ОтобразитьКадровыеДанныеДоПереводаНаСервере()
	
	ОтобразитьПодразделениеДоПереводаНаСервере();
	ОтобразитьПозициюДоПереводаНаСервере();
	ОтобразитьРабочееМестоДоПереводаНаСервере();
	// ЗУПК
	ОтобразитьРежимДистанционнойРаботыДоПереводаНаСервере();
	// ЗУПК
	
КонецПроцедуры

&НаСервере
Процедура ОтобразитьПодразделениеДоПереводаНаСервере()
	
	ДанныеПодразделения = КадровыйУчет.КадровыеДанныеСотрудников(Истина, Объект.Сотрудник, "Подразделение");
	
	Если ДанныеПодразделения.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТекущееПодразделениеСотрудника = ДанныеПодразделения[0].Подразделение;
	
	Если ЗначениеЗаполнено(ТекущееПодразделениеСотрудника) И Объект.Подразделение <> ТекущееПодразделениеСотрудника Тогда
		Элементы.Подразделение.Подсказка = СтрШаблон(
			НСтр("ru = 'Работает в подразделении %1'"), ТекущееПодразделениеСотрудника);
	Иначе
		Элементы.Подразделение.Подсказка = "";
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОтобразитьПозициюДоПереводаНаСервере()
	
	ДанныеПозиции = КадровыйУчет.КадровыеДанныеСотрудников(Истина, Объект.Сотрудник, "ДолжностьПоШтатномуРасписанию");
	
	Если ДанныеПозиции.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяПозицияСотрудника = ДанныеПозиции[0].ДолжностьПоШтатномуРасписанию;
	
	Если ЗначениеЗаполнено(ТекущаяПозицияСотрудника) И Объект.ДолжностьПоШтатномуРасписанию <> ТекущаяПозицияСотрудника Тогда
		Элементы.ДолжностьПоШтатномуРасписанию.Подсказка = СтрШаблон(
			НСтр("ru = 'Занимает должность %1'"), ТекущаяПозицияСотрудника);
		Если ЗначениеЗаполнено(Объект.ДолжностьПоШтатномуРасписанию) Тогда
			Объект.ИзменитьРабочееМесто = Истина;
			Элементы.ИзменитьРабочееМесто.Доступность = Ложь;
		Иначе
			Объект.ИзменитьРабочееМесто = Ложь;
			Элементы.ИзменитьРабочееМесто.Доступность = Истина;
		КонецЕсли;
	Иначе
		Элементы.ДолжностьПоШтатномуРасписанию.Подсказка = "";
		Объект.ИзменитьРабочееМесто = Ложь;
		Элементы.ИзменитьРабочееМесто.Доступность = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОтобразитьРабочееМестоДоПереводаНаСервере()
	
	ДанныеРабочегоМеста = КадровыйУчет.КадровыеДанныеСотрудников(Истина, Объект.Сотрудник, "РабочееМестоОхраныТруда");
	
	Если ДанныеРабочегоМеста.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТекущееРабочееМестоСотрудника = ДанныеРабочегоМеста[0].РабочееМестоОхраныТруда;
	
	Если ЗначениеЗаполнено(ТекущееРабочееМестоСотрудника) И Объект.РабочееМесто <> ТекущееРабочееМестоСотрудника Тогда
		Элементы.РабочееМесто.Подсказка = СтрШаблон(
			НСтр("ru = 'Имеет рабочее место %1'"), ТекущееРабочееМестоСотрудника);
	Иначе
		Элементы.РабочееМесто.Подсказка = "";
	КонецЕсли;
	
КонецПроцедуры

// ЗУПК
&НаСервере
Процедура ОтобразитьРежимДистанционнойРаботыДоПереводаНаСервере()
	
	ДанныеРежимаДистанционнойРаботы = КадровыйУчет.КадровыеДанныеСотрудников(Истина, Объект.Сотрудник, "РежимДистанционнойРаботы");
	
	Если ДанныеРежимаДистанционнойРаботы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТекущийРежимДистанционнойРаботы = ДанныеРежимаДистанционнойРаботы[0].РежимДистанционнойРаботы;
	
	Если ЗначениеЗаполнено(ТекущийРежимДистанционнойРаботы) И Объект.РежимДистанционнойРаботы <> ТекущийРежимДистанционнойРаботы Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РежимДистанционнойРаботы", "Подсказка", СтрШаблон(
			НСтр("ru = 'Имеет режим дистанционной работы %1'"), ТекущийРежимДистанционнойРаботы));
	Иначе
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РежимДистанционнойРаботы", "Подсказка", "");
	КонецЕсли;
	
КонецПроцедуры
