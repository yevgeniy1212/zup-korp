КонецПроцедуры
// Конец СтандартныеПодсистемы.Свойства

&НаСервере
Процедура УстановитьОтображениеЭлементов()
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЗапросОбработан", "ТолькоПросмотр",
		Не Пользователи.РолиДоступны(Метаданные.Роли.СогласованиеЗапросовСправокСотрудником.Имя));
		
	Если Объект.НазначениеСправки = Перечисления.НазначенияСправок2НДФЛ.ДляДекларации Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаГод", "Видимость", Истина);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаПериод", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаПредставлениеПериода",
			"Видимость", Ложь);
	Иначе
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаГод", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаПериод", "Видимость", Истина);
		Если Объект.КоличествоМесяцев = 0 Тогда
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаПредставлениеПериода",
				"Видимость", Истина);
			НачалоПериодаПредставление = ЗарплатаКадрыКлиентСервер.ПолучитьПредставлениеМесяца(Объект.НачалоПериода);
			КонецПериодаПредставление = ЗарплатаКадрыКлиентСервер.ПолучитьПредставлениеМесяца(Объект.КонецПериода);
		Иначе
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаПредставлениеПериода",
				"Видимость", Ложь);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Возвращаемое значение:
//  Структура - Виды периодов справки:
// * Последние3Месяца - Структура:
//   ** Идентификатор - Строка
//   ** КоличествоМесяцев - Число
// * ПоследниеПолгода - Структура:
//   ** Идентификатор - Строка
//   ** КоличествоМесяцев - Число
// * Последние9Месяцев - Структура:
//   ** Идентификатор - Строка
//   ** КоличествоМесяцев - Число
// * Последние12Месяцев - Структура:
//   ** Идентификатор - Строка
//   ** КоличествоМесяцев - Число
// * Произвольный - Структура:
//   ** Идентификатор - Строка
//   ** КоличествоМесяцев - Число
&НаКлиентеНаСервереБезКонтекста
Функция ВидыПериодовСправки()

	ВидыПериодовСправки = Новый Структура;
	
	ВидыПериодовСправки.Вставить("Последние3Месяца",
		Новый Структура("Идентификатор, КоличествоМесяцев", "Последние3Месяца", 3));
		
	ВидыПериодовСправки.Вставить("ПоследниеПолгода",
		Новый Структура("Идентификатор, КоличествоМесяцев", "ПоследниеПолгода", 6));
		
	ВидыПериодовСправки.Вставить("Последние9Месяцев",
		Новый Структура("Идентификатор, КоличествоМесяцев", "Последние9Месяцев", 9));
		
	ВидыПериодовСправки.Вставить("Последние12Месяцев",
		Новый Структура("Идентификатор, КоличествоМесяцев", "Последние12Месяцев", 12));
		
	ВидыПериодовСправки.Вставить("Произвольный",
		Новый Структура("Идентификатор, КоличествоМесяцев", "Произвольный", 0));
	
	Возврат ВидыПериодовСправки;
	
КонецФункции

&НаСервере
//@skip-check statement-type-change
//@skip-check property-return-type
Процедура УстановитьВидПериодаСправки()
	
	ВидПериодаСправки = "Произвольный";
	
	ВидыПериодов = ВидыПериодовСправки();
	
	Для Каждого КлючЗначение Из ВидыПериодов Цикл
		Если КлючЗначение.Значение.КоличествоМесяцев = Объект.КоличествоМесяцев Тогда
			ВидПериодаСправки = КлючЗначение.Значение.Идентификатор;
			Возврат;
		КонецЕсли;
	КонецЦикла;
		
КонецПроцедуры

// Количество месяцев.
// 
// Параметры:
//  ВидПериодаСправки - Строка
// 
// Возвращаемое значение:
//  Число
//@skip-check statement-type-change
//@skip-check property-return-type
&НаСервере
Функция КоличествоМесяцев(ВидПериодаСправки)
	
	КоличествоМесяцев = 0;
	
	ВидыПериодов = ВидыПериодовСправки();
	
	Для Каждого КлючЗначение Из ВидыПериодов Цикл
		Если КлючЗначение.Значение.Идентификатор = ВидПериодаСправки Тогда
			КоличествоМесяцев = КлючЗначение.Значение.КоличествоМесяцев;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат КоличествоМесяцев;
		
КонецФункции

// Заполнить список для выбора года на сервере.
// 
// Параметры:
//  ВыбранныйГод - Число,Неопределено - год, который должен обязательно присутствовать в списке выбора
&НаСервере
Процедура ЗаполнитьСписокДляВыбораГода(ВыбранныйГод = Неопределено)
	
	Элементы.Год.СписокВыбора.Очистить();
	
	Если Не ЗначениеЗаполнено(Объект.ФизическоеЛицо) Или Не ЗначениеЗаполнено(Объект.Организация)
		Или Сотрудники.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
		
	НайденныеСтроки = Сотрудники.НайтиСтроки(Новый Структура("Организация", Объект.Организация));
	Если НайденныеСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТекущийГод = Год(ТекущаяДатаСеанса());
	ГодНачала = Макс(Год(НайденныеСтроки[0].ДатаПриема), 2010);
	Если ЗначениеЗаполнено(НайденныеСтроки[0].ДатаУвольнения) Тогда
		ГодОкончания = Мин(Год(НайденныеСтроки[0].ДатаУвольнения), ТекущийГод);
	Иначе
		ГодОкончания = ТекущийГод;
	КонецЕсли;
	
	Для Сч = ГодНачала По ГодОкончания Цикл
		Элементы.Год.СписокВыбора.Добавить(Сч, Формат(Сч, "ЧГ=0;"));
	КонецЦикла;

	Если ЗначениеЗаполнено(ВыбранныйГод)
		И Элементы.Год.СписокВыбора.НайтиПоЗначению(ВыбранныйГод) = Неопределено Тогда
			
		Элементы.Год.СписокВыбора.Добавить(ВыбранныйГод, Формат(ВыбранныйГод, "ЧГ=0"));
		Элементы.Год.СписокВыбора.СортироватьПоЗначению();
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокОрганизаций(ВыбраннаяОрганизация = Неопределено)
	
	Элементы.Организация.СписокВыбора.Очистить();
	
	Если Не ЗначениеЗаполнено(Объект.ФизическоеЛицо) Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыПолученияСотрудников = КадровыйУчет.ПараметрыПолученияСотрудниковОрганизацийПоСпискуФизическихЛиц();
	//@skip-check property-return-type
	ПараметрыПолученияСотрудников.СписокФизическихЛиц = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(
		Объект.ФизическоеЛицо);
	ПараметрыПолученияСотрудников.КадровыеДанные = "Организация,ДатаПриема,ДатаУвольнения";
	
	УстановитьПривилегированныйРежим(Истина);
	СотрудникиФизическогоЛица = КадровыйУчет.СотрудникиОрганизации(Истина, ПараметрыПолученияСотрудников);
	УстановитьПривилегированныйРежим(Ложь);

	Сотрудники.Загрузить(СотрудникиФизическогоЛица.Скопировать(, "Сотрудник,Организация,ДатаПриема,ДатаУвольнения"));
	
	Организации = СотрудникиФизическогоЛица.ВыгрузитьКолонку("Организация"); // Массив из СправочникСсылка.Организации
	Элементы.Организация.СписокВыбора.ЗагрузитьЗначения(Организации);
	
	Если ЗначениеЗаполнено(ВыбраннаяОрганизация)
		И Элементы.Организация.СписокВыбора.НайтиПоЗначению(ВыбраннаяОрганизация) = Неопределено Тогда
		Элементы.Организация.СписокВыбора.Добавить(ВыбраннаяОрганизация);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ФизическоеЛицоПриИзмененииНаСервере()
	
	ЗаполнитьСписокОрганизаций();
	УстановитьОрганизациюИГод();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОрганизациюИГод()
	
	Если Сотрудники.Количество() = 1 Тогда
		Объект.Организация = Сотрудники[0].Организация;
		ЗаполнитьСписокДляВыбораГода();
		УстановитьГод();
	Иначе
		Элементы.Год.СписокВыбора.Очистить();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОрганизацияПриИзмененииНаСервере()
	
	ЗаполнитьСписокДляВыбораГода();
	УстановитьГод();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьГод()
	
	ГодыСписок = Элементы.Год.СписокВыбора; // СписокЗначений из Число
	РазмерСписка = ГодыСписок.Количество();
	
	Если РазмерСписка = 1 Тогда
		Объект.Год = ГодыСписок.Получить(0).Значение;
	ИначеЕсли ГодыСписок.Получить(РазмерСписка - 1).Значение = Год(ТекущаяДатаСеанса()) Тогда
		Объект.Год = ГодыСписок.Получить(РазмерСписка - 2).Значение;
	Иначе
		Объект.Год = ГодыСписок.Получить(РазмерСписка - 1).Значение;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВидПериодаСправкиПриИзмененииНаСервере()
	
	Объект.КоличествоМесяцев = КоличествоМесяцев(ВидПериодаСправки);
	Если Объект.КоличествоМесяцев = 0 Тогда
		НачалоТекущегоГода = НачалоГода(ТекущаяДатаСеанса());
		//@skip-check statement-type-change
		Объект.КонецПериода = НачалоТекущегоГода - 1;
		Объект.НачалоПериода = НачалоГода(Объект.КонецПериода);
	Иначе
		Объект.НачалоПериода = Дата(1, 1, 1);
		Объект.КонецПериода = Дата(1, 1, 1);
	КонецЕсли;
	
	УстановитьОтображениеЭлементов();
	
КонецПроцедуры

&НаСервере
Процедура НазначениеСправкиПриИзмененииНаСервере()
	
	Если Объект.НазначениеСправки = Перечисления.НазначенияСправок2НДФЛ.ПодтверждениеДоходов Тогда
		Объект.Год = 0;
	Иначе
		УстановитьГод();
	КонецЕсли;
	
	УстановитьОтображениеЭлементов();
	
КонецПроцедуры

#КонецОбласти
