Функция ПолучитьДанныеДляПроведения(Ссылка)Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИсключениеИзКадровогоРезерва.ДатаИсключения КАК Период,
		|	ИсключениеИзКадровогоРезерва.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсключениеИзКадровогоРезерваРезерв.ПозицияРезерва КАК ПозицияРезерва,
		|	ИсключениеИзКадровогоРезерваРезерв.ВидРезерва КАК ВидРезерва,
		|	ЗНАЧЕНИЕ(Перечисление.СостоянияСогласования.ПустаяСсылка) КАК Статус
		|ИЗ
		|	Документ.ИсключениеИзКадровогоРезерва.Резерв КАК ИсключениеИзКадровогоРезерваРезерв
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ИсключениеИзКадровогоРезерва КАК ИсключениеИзКадровогоРезерва
		|		ПО ИсключениеИзКадровогоРезерваРезерв.Ссылка = ИсключениеИзКадровогоРезерва.Ссылка
		|ГДЕ
		|	ИсключениеИзКадровогоРезерваРезерв.Действие = ЗНАЧЕНИЕ(Перечисление.ДействияСКадровымиРезервистами.Отклонить)
		|	И ИсключениеИзКадровогоРезерва.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	РезультатЗапроса = Запрос.Выполнить();
	ДвиженияИсторииКадровогоРезерва = РезультатЗапроса.Выгрузить();
	
	ДанныеДляПроведения = Новый Структура;
	ДанныеДляПроведения.Вставить("ДвиженияИсторииКадровогоРезерва", ДвиженияИсторииКадровогоРезерва);
	
	Возврат ДанныеДляПроведения;

КонецФункции	

