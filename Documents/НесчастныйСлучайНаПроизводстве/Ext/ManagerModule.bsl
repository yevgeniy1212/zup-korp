			/////////////////////////////////////////////////
			// Область 13
			
			Область13.Параметры.ЗаявленияПоступили = ?(ДанныеДокумента.СтрокаПоступившихЗаявлений = "", НСтр("ru = 'не поступили'"), НСтр("ru = 'поступили'"));
