		ДанныеПечати.Вставить("ОкончательныеДиагнозы", ПустаяТаблица);
		ДанныеПечати.Вставить("СтрокаОчевидцыФИО", "");
		ДанныеПечати.Вставить("СтепеньВины", ПустаяТаблица);
		ДанныеПечати.Вставить("Очевидцы", ПустаяТаблица);
		ДанныеПечати.Вставить("ФИОРуководителяРК", "");
		ДанныеПечати.Вставить("ФИООтветственногоЗаОхрануТрудаРК", "");
		ДанныеПечати.Вставить("МассивФИОЧленовКомиссииРК", Новый Массив);
		// ЗУПК
		
		Если ЗначениеЗаполнено(Выборка.Организация) Тогда
			// Сведения об организации
			КодыОрганизации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
				Выборка.Организация, "КодОКВЭД,НаименованиеОКВЭД,КодОКВЭД2,НаименованиеОКВЭД2,ИНН,НаименованиеОКФС,РегистрационныйНомерФСС");
			
			// ЗУПК
			Если ПолучитьФункциональнуюОпцию("ОтключенныйФункционалЗарплатаКадрыКОРП") Тогда
			// ЗУПК
			Если Выборка.Дата < '20170101' И Не ПустаяСтрока(КодыОрганизации.КодОКВЭД) Тогда
				КодОКВЭД = КодыОрганизации.КодОКВЭД;
				НаименованиеОКВЭД = КодыОрганизации.НаименованиеОКВЭД;
			Иначе
				КодОКВЭД = КодыОрганизации.КодОКВЭД2;
				НаименованиеОКВЭД = КодыОрганизации.НаименованиеОКВЭД2;
			КонецЕсли;
			// ЗУПК
			Иначе
				КодОКВЭД = КодыОрганизации.КодОКВЭД;
				НаименованиеОКВЭД = КодыОрганизации.НаименованиеОКВЭД;
			КонецЕсли;
			// ЗУПК
			
			// ЗУПК
			ДанныеОбОрганизации = ЗарплатаКадры.СведенияОбОрганизации(Выборка.Организация, "ТелОрганизации,ОргСубъект,ОргНПункт,ОргГород,ОКАТО");
			
			АдресВТаблице = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(Выборка.Организация, Справочники.ВидыКонтактнойИнформации.ФактАдресОрганизации, Выборка.Дата, Ложь);
			АдресПоПолям = "";
			Для Каждого Адрес Из АдресВТаблице Цикл
				АдресПоПолям = Адрес.Значение;
			КонецЦикла;
			// ЗУПК
			ПредставлениеФактическогоАдреса = УправлениеКонтактнойИнформацией.ПредставлениеКонтактнойИнформацииОбъекта(
				Выборка.Организация, Справочники.ВидыКонтактнойИнформации.ФактАдресОрганизации, , Выборка.Дата);
			ПредставлениеЮридическогоАдреса = УправлениеКонтактнойИнформацией.ПредставлениеКонтактнойИнформацииОбъекта(
				Выборка.Организация, Справочники.ВидыКонтактнойИнформации.ЮрАдресОрганизации, , Выборка.Дата);
				
			УстановитьПривилегированныйРежим(Истина);
			Численность = КадровыйУчет.СреднесписочнаяЧисленностьРаботающих(
				Выборка.Организация, ДанныеПечати.ДатаПроисшествияДатаВремя, ДанныеПечати.ДатаПроисшествияДатаВремя).Численность;
			УстановитьПривилегированныйРежим(Ложь);
			
			СведенияОбОрганизации = Выборка.НаименованиеОрганизации
				+ ?(ЗначениеЗаполнено(ПредставлениеЮридическогоАдреса), ", " + НСтр("ru = 'юр. адрес'") + ": " + ПредставлениеЮридическогоАдреса, "")
				+ ?(ЗначениеЗаполнено(ПредставлениеФактическогоАдреса), ", " + НСтр("ru = 'факт. адрес'") + ": " + ПредставлениеФактическогоАдреса, "")
				+ ?(ЗначениеЗаполнено(КодыОрганизации.ИНН), ", " + НСтр("ru = 'ИНН'") + " " + КодыОрганизации.ИНН, "")
