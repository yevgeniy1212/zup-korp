			Область6.Параметры.ОбстоятельстваПроисшествияЧасть8 = СписокСтрок[7];
			Область6.Параметры.ОбстоятельстваПроисшествияЧасть9 = СписокСтрок[8];
			
			ТабличныйДокумент.Вывести(Область6);
