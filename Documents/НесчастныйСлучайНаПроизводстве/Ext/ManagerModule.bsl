			/////////////////////////////////////////////////
			// Область 8
			
			СписокСтрок = ОхранаТруда.СтрокиДляПечатнойФормы(ДанныеДокумента.СтрокаВиновныеЛица, "100,100, 100,100, 100");
			Область8.Параметры.ВиновныеЛицаЧасть1 = СписокСтрок[0];
