		ДанныеПечати.Вставить("СтрокаПричиныПроисшествия", "");
		ДанныеПечати.Вставить("СтрокаВиновныеЛица", "");
		ПустаяТаблица = Новый ТаблицаЗначений;
		ПустаяТаблица.Колонки.Добавить("Пострадавший");
		ДанныеПечати.Вставить("Инструктажи", ПустаяТаблица);
		ДанныеПечати.Вставить("МедицинскиеОсмотры", ПустаяТаблица.СкопироватьКолонки());
		ДанныеПечати.Вставить("СтрокаОчевидцы", "");
		ДанныеПечати.Вставить("СведенияОПредседателеКомиссии", "");
		// ЗУПК
		ДанныеПечати.Вставить("СведенияОбОрганизацииРК", "");
		ДанныеПечати.Вставить("СведенияОбОрганизацииКод", "");
		ДанныеПечати.Вставить("БИН", "");
		ДанныеПечати.Вставить("ИИН", "");
		ДанныеПечати.Вставить("АдресРаботодателя1", "");
		ДанныеПечати.Вставить("АдресРаботодателя2", "");
		ДанныеПечати.Вставить("АдресРаботодателяКод", "");
		ДанныеПечати.Вставить("СведенияОПредседателеКомиссииБезДолжности", "");
