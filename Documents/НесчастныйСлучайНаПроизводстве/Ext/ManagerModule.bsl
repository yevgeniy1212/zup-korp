		ДанныеПечати.Вставить("СтрокаУчастникиОсмотраБезПредседателя", "");
		ДанныеПечати.Вставить("СтрокаПоступившихЗаявлений", "");
		ДанныеПечати.Вставить("МассивУчастниковОсмотра", Новый Массив);
