			/////////////////////////////////////////////////
			// Область СОУТ после 1.09.2022
			
			Если ЭтоПриказ223Н Тогда
				ОбластьСОУТ_1.Параметры.СведенияСОУТ = СтрокаПострадавшего.СведенияСОУТ;
				ТабличныйДокумент.Вывести(ОбластьСОУТ_1);
				
				ОбластьСОУТ_2.Параметры.СведенияОбОрганизацииПроводившейСОУТ = СтрокаПострадавшего.СведенияОПСОУТ;
				ТабличныйДокумент.Вывести(ОбластьСОУТ_2);
			КонецЕсли;
			
			/////////////////////////////////////////////////
			// Область 9
			
			СписокСтрок = ОхранаТруда.СтрокиДляПечатнойФормы(ДанныеДокумента.ТехническиеСредстваОсмотра, "60,100");
			Область9.Параметры.ТехническиеСредстваОсмотра = СписокСтрок[0];
			
