&НаКлиенте
Процедура ПодробнееОРасчетеНалогиВзносыОтчисления(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле.Имя = "НачисленияОПВ" Тогда
	
		СтандартнаяОбработка = Ложь;
		
		ДополнительныеПараметрыНВО = Новый Структура;
		ДополнительныеПараметрыНВО.Вставить("ВидНалогаВзносаОтчисления", ПредопределенноеЗначение("Перечисление.ВидыНалоговВзносовОтчислений.ОПВ"));
		ДополнительныеПараметрыНВО.Вставить("ФизическоеЛицо", Элементы.Начисления.ТекущиеДанные.Сотрудник);
		ДополнительныеПараметрыНВО.Вставить("Подразделение", Элементы.Начисления.ТекущиеДанные.Подразделение);
		УчетНалоговВзносовОтчисленийКлиентРасширенный.ОткрытьФормуРасчетаНалогаВзносаОтчисления(Объект, ЭтаФорма, ДополнительныеПараметрыНВО, ОписаниеДокумента(ЭтаФорма), Ложь);
	
	ИначеЕсли Поле.Имя = "НачисленияВОСМС" Тогда
	
		СтандартнаяОбработка = Ложь;
		
		ДополнительныеПараметрыНВО = Новый Структура;
		ДополнительныеПараметрыНВО.Вставить("ВидНалогаВзносаОтчисления", ПредопределенноеЗначение("Перечисление.ВидыНалоговВзносовОтчислений.ВОСМС"));
		ДополнительныеПараметрыНВО.Вставить("ФизическоеЛицо", Элементы.Начисления.ТекущиеДанные.Сотрудник);
		ДополнительныеПараметрыНВО.Вставить("Подразделение", Элементы.Начисления.ТекущиеДанные.Подразделение);
		УчетНалоговВзносовОтчисленийКлиентРасширенный.ОткрытьФормуРасчетаНалогаВзносаОтчисления(Объект, ЭтаФорма, ДополнительныеПараметрыНВО, ОписаниеДокумента(ЭтаФорма), Ложь);
		
	ИначеЕсли Поле.Имя = "НачисленияИПН" Тогда
	
		СтандартнаяОбработка = Ложь;
		
		ДополнительныеПараметрыНВО = Новый Структура;
		ДополнительныеПараметрыНВО.Вставить("ВидНалогаВзносаОтчисления", ПредопределенноеЗначение("Перечисление.ВидыНалоговВзносовОтчислений.ИПН"));
		ДополнительныеПараметрыНВО.Вставить("ФизическоеЛицо", Элементы.Начисления.ТекущиеДанные.Сотрудник); 
		ДополнительныеПараметрыНВО.Вставить("Подразделение", Элементы.Начисления.ТекущиеДанные.Подразделение);
		УчетНалоговВзносовОтчисленийКлиентРасширенный.ОткрытьФормуРасчетаНалогаВзносаОтчисления(Объект, ЭтаФорма, ДополнительныеПараметрыНВО, ОписаниеДокумента(ЭтаФорма), Ложь);
		
	ИначеЕсли Поле.Имя = "НачисленияЕП" Тогда
	
		СтандартнаяОбработка = Ложь;
		
		ДополнительныеПараметрыНВО = Новый Структура;
		ДополнительныеПараметрыНВО.Вставить("ВидНалогаВзносаОтчисления", ПредопределенноеЗначение("Перечисление.ВидыНалоговВзносовОтчислений.ЕП"));
		ДополнительныеПараметрыНВО.Вставить("ФизическоеЛицо", Элементы.Начисления.ТекущиеДанные.Сотрудник);
		ДополнительныеПараметрыНВО.Вставить("Подразделение", Элементы.Начисления.ТекущиеДанные.Подразделение);
		УчетНалоговВзносовОтчисленийКлиентРасширенный.ОткрытьФормуРасчетаНалогаВзносаОтчисления(Объект, ЭтаФорма, ДополнительныеПараметрыНВО, ОписаниеДокумента(ЭтаФорма), Ложь);
		
	КонецЕсли;
	
КонецПроцедуры

// ЗУПК
&НаСервере
Процедура ОбновитьДанныеНалогиВзносыОтчисленияНаСервере(АдресВременногоХранилища)
    
    Если ТипЗнч(АдресВременногоХранилища) = Тип("Строка") И ЭтоАдресВременногоХранилища(АдресВременногоХранилища) Тогда
        
        ПараметрыДанных = ПолучитьИзВременногоХранилища(АдресВременногоХранилища);
        
        КонтролируемыеПоля = Новый Структура;
        ОписаниеДокумента = ОписаниеДокумента(ЭтаФорма);
        ВидНалогаВзносаОтчисления = ПараметрыДанных.ВидНалогаВзносаОтчисления;
        ИзмененныеДанные.Загрузить(ПараметрыДанных.ИзмененныеДанные);

        ОтборСтрок = Новый Структура("ФизическоеЛицо, ВидНалогаВзносаОтчисления", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ПараметрыДанных.ФизическоеЛицо), ВидНалогаВзносаОтчисления);
        УчетНалоговВзносовОтчисленийРасширенный.ЗаменитьСтрокиНалогиВзносыОтчисления(Объект.НалогиВзносыОтчисления, Объект.ВычетыИПН, Объект.ДоходыНеПодлежащиеНалогообложению, ПараметрыДанных, КонтролируемыеПоля, ОписаниеДокумента, ОтборСтрок, Ложь, "ФизическоеЛицо,ВидНалогаВзносаОтчисления");
        
        Если ИзмененныеДанные.Количество() = 0 Тогда
            Возврат;
        КонецЕсли;
        РассчитатьВсеНаСервере();

        ЗаполнитьНалогиУдержания(); 
        
        Модифицированность = Истина;
        
    КонецЕсли;
	
КонецПроцедуры
// ЗУПК

&НаКлиенте
Процедура РедактированиеКорректировокВыплаты(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле.Имя <> "НачисленияКорректировкаВыплаты" Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ИспользоватьСтатьиФинансирования Тогда 
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	Сотрудник = Элементы.Начисления.ТекущиеДанные.Сотрудник;
	
	ПараметрыФормы = Новый Структура;       
	ПараметрыФормы.Вставить("ТолькоПросмотр", ТолькоПросмотр);
	ПараметрыФормы.Вставить("МесяцНачисления", Объект.ПериодРегистрации);
	ПараметрыФормы.Вставить("Организация", Объект.Организация);
	ПараметрыФормы.Вставить("ДанныеКорректировокВыплаты", ДанныеКорректировокВыплаты(Сотрудник));
	ПараметрыФормы.Вставить("СотрудникФизическоеЛицо", Сотрудник);
	
	ОткрытьФорму("ОбщаяФорма.РедактированиеКорректировокВыплаты", ПараметрыФормы, ЭтаФорма);
	
КонецПроцедуры

