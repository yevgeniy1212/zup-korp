#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ВедомостьПриИзмененииНаСервере()
	
	ВидНалогаВзносаОтчисления = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Ведомость, "ВидНалогаВзносаОтчисления");
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НалогиВзносыОтчисления.ФизическоеЛицо КАК ФизическоеЛицо,
	|	ВЫБОР
	|		КОГДА &ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ЕП)
	|			ТОГДА НалогиВзносыОтчисления.МесяцНалоговогоПериода
	|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|	КОНЕЦ КАК МесяцНалоговогоПериода,
	|	ВЫБОР
	|		КОГДА &ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ЕП)
	|			ТОГДА НалогиВзносыОтчисления.РегистрацияВНалоговомОргане
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.РегистрацииВНалоговомОргане.ПустаяСсылка)
	|	КОНЕЦ КАК РегистрацияВНалоговомОргане,
	|	ВЫБОР
	|		КОГДА &ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ЕП)
	|			ТОГДА НалогиВзносыОтчисления.НалогВзнос
	|		ИНАЧЕ 0
	|	КОНЕЦ КАК НалогВзнос
	|ИЗ
	|	Документ.ВедомостьНаПеречислениеВзносовОтчислений.НалогиВзносыОтчисления КАК НалогиВзносыОтчисления
	|ГДЕ
	|	НалогиВзносыОтчисления.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	НалогиВзносыОтчисления.ФизическоеЛицо,
	|	ВЫБОР
	|		КОГДА &ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ЕП)
	|			ТОГДА НалогиВзносыОтчисления.МесяцНалоговогоПериода
	|		ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1)
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА &ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ЕП)
	|			ТОГДА НалогиВзносыОтчисления.РегистрацияВНалоговомОргане
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.РегистрацииВНалоговомОргане.ПустаяСсылка)
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА &ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ЕП)
	|			ТОГДА НалогиВзносыОтчисления.НалогВзнос
	|		ИНАЧЕ 0
	|	КОНЕЦ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ФизическоеЛицо";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ведомость);
	Запрос.УстановитьПараметр("ВидНалогаВзносаОтчисления", ВидНалогаВзносаОтчисления);
	
	НалогиВзносыОтчисления = Запрос.Выполнить().Выгрузить();
	
	Объект.Сотрудники.Загрузить(НалогиВзносыОтчисления);       	
	
КонецПроцедуры

