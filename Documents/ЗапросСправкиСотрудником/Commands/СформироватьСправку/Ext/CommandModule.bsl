// @strict-types


#Область ОбработчикиСобытий

// Параметры:
//  ПараметрКоманды - ДокументСсылка.ЗапросСправкиСотрудником
//  ПараметрыВыполненияКоманды - ПараметрыВыполненияКоманды
&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	РезультатПолученияСправки = ПечатнаяФормаСправки(ПараметрКоманды);

	Если РезультатПолученияСправки.ОК Тогда
		ПечатнаяФормаСправки = РезультатПолученияСправки.ТабличныйДокумент;
		Оповестить("СформированаСправкаСМестаРаботы", ПечатнаяФормаСправки, ПараметрКоманды);
		ПоказатьПредупреждение(, НСтр("ru = 'Справка сформирована.'"));
	Иначе
		ВызватьИсключение РезультатПолученияСправки.ОписаниеОшибки;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Параметры:
//  Ссылка - ДокументСсылка.ЗапросСправкиСотрудником
// 
// Возвращаемое значение:
//  см. СамообслуживаниеСотрудников.НовыйРезультатПолученияСправки
&НаСервере
Функция ПечатнаяФормаСправки(Ссылка)
	
	Возврат Документы.ЗапросСправкиСотрудником.ПечатнаяФормаСправки(Ссылка);
	
КонецФункции

#КонецОбласти
