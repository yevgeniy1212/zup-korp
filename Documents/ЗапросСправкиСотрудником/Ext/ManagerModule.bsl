// Справка сотрудника.
// 
// Параметры:
//  ЗапросСправки - ДокументСсылка.ЗапросСправкиСотрудником, ДокументОбъект.ЗапросСправкиСотрудником - 
// 
// Возвращаемое значение:
//  см. СамообслуживаниеСотрудников.НовыйРезультатПолученияСправки
Функция ПечатнаяФормаСправки(ЗапросСправки) Экспорт
	
	Если ТипЗнч(ЗапросСправки) = Тип("ДокументСсылка.ЗапросСправкиСотрудником") Тогда
		РеквизитыСправки = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЗапросСправки, "ФизическоеЛицо, ВидСправки");
		ФизическоеЛицо = РеквизитыСправки.ФизическоеЛицо;
		ВидСправки = РеквизитыСправки.ВидСправки;
	Иначе
		ФизическоеЛицо = ЗапросСправки.ФизическоеЛицо;
		ВидСправки = ЗапросСправки.ВидСправки;
	КонецЕсли;
	
	ПечатнаяФормаСправки = Неопределено;
	
	Если Не ЗначениеЗаполнено(ФизическоеЛицо) Или Не ЗначениеЗаполнено(ВидСправки) Тогда
		Возврат ПечатнаяФормаСправки;
	КонецЕсли;
	
	ПараметрыПолученияСправок = СамообслуживаниеСотрудников.НовыеПараметрыПолученияСправок();
	НоваяСтрока = ПараметрыПолученияСправок.Добавить();
	НоваяСтрока.ИдентификаторЗапроса = 0;
	НоваяСтрока.ФизическоеЛицо = ФизическоеЛицо;
	НоваяСтрока.ВидСправки = ВидСправки;
	
	Результаты = СамообслуживаниеСотрудников.ПечатныеФормыПредоставляемыхСотрудникамСправок(
		ПараметрыПолученияСправок);
		
	Результат = Результаты.Найти(НоваяСтрока.ИдентификаторЗапроса, "ИдентификаторЗапроса").Результат;
		
	Возврат Результат;
	
КонецФункции

#КонецОбласти

