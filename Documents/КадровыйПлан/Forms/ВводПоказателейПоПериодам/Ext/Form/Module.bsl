#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Позиция = Параметры.Позиция;
	ИдентификаторСтроки = Параметры.ИдентификаторСтроки;
	
	СвойстваПоказателей = Параметры.СвойстваПоказателей;
	УникальныеИменаПоказателей = СвойстваПоказателей.Получить("УникальныеИменаПоказателей");
	
	ДополнитьФорму();
	
	Для Каждого СтрокаПериод Из Параметры.ПериодыПоказателей Цикл
		НоваяСтрока = ПериодыПоказателей.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаПериод);
		Для Каждого ЭлементИмяПоказателя Из УникальныеИменаПоказателей Цикл
			НоваяСтрока[ЭлементИмяПоказателя] = СтрокаПериод[ЭлементИмяПоказателя];
		КонецЦикла;
	КонецЦикла;
	
	СвернутьПериоды();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОК(Команда)
	
	Отказ = Ложь;
	АдресВХранилище = АдресРезультатаВХранилище(Отказ);
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("АдресВХранилище", АдресВХранилище);
	Результат.Вставить("ИдентификаторСтроки", ИдентификаторСтроки);
	
	Оповестить("ИзмененыПериодыПоказателей", Результат, ВладелецФормы);
	
	Закрыть();
	
КонецПроцедуры

&НаКлиенте
Процедура Отмена(Команда)
	
	Закрыть();
	
КонецПроцедуры

&НаКлиенте
Процедура РазбитьСтроку(Команда)
	
	Если ВыбранаСтрокаДляВыполненияКоманды(Элементы.ПериодыПоказателей) Тогда
		ПроверитьРазбитьПериодСервер();
		ТекущиеДанные = Элементы.ПериодыПоказателей.ТекущиеДанные;
		Разница = Месяц(ТекущиеДанные.Окончание) - Месяц(ТекущиеДанные.Начало);
		ДатаРазбиения = ДобавитьМесяц(ТекущиеДанные.Начало, Окр(Разница / 2));
		Оповещение = Новый ОписаниеОповещения("РазбитьСтрокуЗавершение", ЭтотОбъект);
		ПоказатьВводДаты(Оповещение, ДатаРазбиения, НСтр("ru='Разбить период с'"), ЧастиДаты.Дата);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ДополнитьФорму()
	
	ДобавляемыеРеквизиты = Новый Массив;
	
	Массив = Новый Массив();
	Массив.Очистить();
	Массив.Добавить(Тип("Число"));
	ОписаниеТиповЧ = Новый ОписаниеТипов(Массив, , ,Новый КвалификаторыЧисла(12,2));
	
	УникальныеИменаПоказателей = СвойстваПоказателей.Получить("УникальныеИменаПоказателей");
	Для Каждого ИмяПоказателя Из УникальныеИменаПоказателей Цикл
		СвойстваПоказателя = СвойстваПоказателей.Получить(ИмяПоказателя);
		ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы(ИмяПоказателя,
															ОписаниеТиповЧ,
															"ПериодыПоказателей",
															СвойстваПоказателя.КраткоеНаименование));
	КонецЦикла;
	
	ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	Для Каждого ИмяПоказателя Из УникальныеИменаПоказателей Цикл
		Элемент = Элементы.Найти("ПериодыПоказателей" + ИмяПоказателя);
		Если Элемент = Неопределено Тогда
			Элемент = Элементы.Вставить("ПериодыПоказателей" + ИмяПоказателя,
											Тип("ПолеФормы"),
											Элементы.ПериодыПоказателей);
			Элемент.Вид = ВидПоляФормы.ПолеВвода;
			Элемент.ПутьКДанным = "ПериодыПоказателей." + ИмяПоказателя;
			Элемент.ФорматРедактирования = "ЧДЦ=0";
			Элемент.Формат = "ЧДЦ=0";
		КонецЕсли;
	КонецЦикла;
	
	Элемент = Элементы.Найти("ПериодыПоказателейКоличествоСтавок");
	Элемент.ФорматРедактирования = УправлениеШтатнымРасписанием.ФорматКоличестваСтавок();
	
КонецПроцедуры

&НаСервере
Функция АдресРезультатаВХранилище(Отказ)
	
	ПериодыПоказателейПозиции = Новый Массив;
	Для Каждого СтрокаПериода Из ПериодыПоказателей Цикл
		Если Не ЗначениеЗаполнено(СтрокаПериода.Начало) Тогда
			ТекстСообщения = НСтр("ru = 'Не заполнена дата начала.'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ,"ПериодыПоказателей[" + Формат(ПериодыПоказателей.Индекс(СтрокаПериода), "ЧН=0; ЧГ=0") + "].Начало", , Отказ);
			Продолжить;
		КонецЕсли;
		Если Не ЗначениеЗаполнено(СтрокаПериода.Окончание) Тогда 
			ТекстСообщения = НСтр("ru = 'Не заполнена дата окончания.'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ,"ПериодыПоказателей[" + Формат(ПериодыПоказателей.Индекс(СтрокаПериода), "ЧН=0; ЧГ=0") + "].Окончание", , Отказ);
			Продолжить;
		КонецЕсли;
		Если СтрокаПериода.Начало > СтрокаПериода.Окончание Тогда 
			ТекстСообщения = НСтр("ru = 'Дата начала не может быть больше даты окончания'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ,"ПериодыПоказателей[" + Формат(ПериодыПоказателей.Индекс(СтрокаПериода), "ЧН=0; ЧГ=0") + "].Начало", , Отказ);
			Продолжить;
		КонецЕсли;
		Если СтрокаПериода.Начало < НачалоПериода Тогда 
			ТекстСообщения = НСтр("ru = 'Дата начала не может быть меньше начала периода кадрового плана (%1)'");
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, Формат(НачалоПериода, "ДЛФ=Д")); 
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ,"ПериодыПоказателей[" + Формат(ПериодыПоказателей.Индекс(СтрокаПериода), "ЧН=0; ЧГ=0") + "].Начало", , Отказ);
			Продолжить;
		КонецЕсли;
		Если СтрокаПериода.Окончание > ОкончаниеПериода Тогда 
			ТекстСообщения = НСтр("ru = 'Дата окончания не может быть больше окончания периода кадрового плана (%1)'");
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, Формат(ОкончаниеПериода, "ДЛФ=Д")); 
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ,"ПериодыПоказателей[" + Формат(ПериодыПоказателей.Индекс(СтрокаПериода), "ЧН=0; ЧГ=0") + "].Окончание", , Отказ);
			Продолжить;
		КонецЕсли;
		ДанныеПериода = Новый Структура("Начало, Окончание, ИндексСтроки");
		ЗаполнитьЗначенияСвойств(ДанныеПериода, СтрокаПериода);
		ДанныеПериода.ИндексСтроки = ПериодыПоказателей.Индекс(СтрокаПериода);
		Если ПериодыПоказателейПозиции.Количество() = 0 Тогда 
			ПериодыПоказателейПозиции = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ДанныеПериода);
		Иначе 
			Для Каждого ПериодПоказателей Из ПериодыПоказателейПозиции Цикл
				Если Не (ДанныеПериода.Начало > ПериодПоказателей.Окончание Или ДанныеПериода.Окончание < ПериодПоказателей.Начало) Тогда
					ТекстСообщения = НСтр("ru = 'Пересекаются периоды позиции %1 (%2 - %3 и %4 - %5)'");
					ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, Позиция, 
						Формат(ДанныеПериода.Начало, "ДЛФ=Д"), Формат(ДанныеПериода.Окончание, "ДЛФ=Д"), Формат(ПериодПоказателей.Начало, "ДЛФ=Д"), Формат(ПериодПоказателей.Окончание, "ДЛФ=Д"));
					ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, ,"ПериодыПоказателей[" + Формат(ДанныеПериода.ИндексСтроки, "ЧН=0; ЧГ=0") + "].Начало", , Отказ);
				КонецЕсли;
			КонецЦикла;
			ПериодыПоказателейПозиции.Добавить(ДанныеПериода);
		КонецЕсли;
	КонецЦикла;
	
	Если Отказ Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	РазвернутьПериоды();
	
	Возврат ПоместитьВоВременноеХранилище(ПериодыПоказателей.Выгрузить(), УникальныйИдентификатор);
	
КонецФункции

&НаСервере
Процедура РазвернутьПериоды()
	
	КоличествоСтрок = ПериодыПоказателей.Количество();
	
	ПредыдущаяСтрокаПериода = Неопределено;
	Для Сч = 1 По КоличествоСтрок Цикл
		СтрокаПериода = ПериодыПоказателей.Получить(Сч - 1);
		Если ПредыдущаяСтрокаПериода <> Неопределено Тогда
			РазницаМесяцев = Месяц(СтрокаПериода.Начало) - Месяц(ПредыдущаяСтрокаПериода.Начало);
			Если РазницаМесяцев > 1 Тогда
				Для Месяцев = 1 По РазницаМесяцев - 1 Цикл
					НоваяСтрокаПериод = ПериодыПоказателей.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрокаПериод, ПредыдущаяСтрокаПериода);
					НоваяСтрокаПериод.Начало = ДобавитьМесяц(ПредыдущаяСтрокаПериода.Начало, Месяцев);
					НоваяСтрокаПериод.Окончание = КонецМесяца(НоваяСтрокаПериод.Начало);
				КонецЦикла;
			КонецЕсли;
		КонецЕсли;
		ПредыдущаяСтрокаПериода = СтрокаПериода;
	КонецЦикла;
	
	Если ПредыдущаяСтрокаПериода <> Неопределено Тогда
		РазницаМесяцев = Месяц(ОкончаниеПериода) - Месяц(ПредыдущаяСтрокаПериода.Начало);
		Если РазницаМесяцев > 0 Тогда
			Для Месяцев = 1 По РазницаМесяцев Цикл
				НоваяСтрокаПериод = ПериодыПоказателей.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаПериод, ПредыдущаяСтрокаПериода);
				НоваяСтрокаПериод.Начало = ДобавитьМесяц(ПредыдущаяСтрокаПериода.Начало, Месяцев);
				НоваяСтрокаПериод.Окончание = КонецМесяца(НоваяСтрокаПериод.Начало);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	ПериодыПоказателей.Сортировать("Начало");
	
КонецПроцедуры

&НаСервере
Процедура СвернутьПериоды()
	
	ПериодыПоказателей.Сортировать("Начало");
	КоличествоСтрок = ПериодыПоказателей.Количество();
	
	ПредыдущаяСтрокаПериода = Неопределено;
	Для Сч = 1 По КоличествоСтрок Цикл
		СтрокаПериода = ПериодыПоказателей.Получить(КоличествоСтрок - Сч);
		Если ПредыдущаяСтрокаПериода <> Неопределено И ПоказателиИдентичны(ПредыдущаяСтрокаПериода, СтрокаПериода) Тогда
			СтрокаПериода.Окончание = ПредыдущаяСтрокаПериода.Окончание;
			ПериодыПоказателей.Удалить(КоличествоСтрок - Сч + 1);
		Иначе
			СтрокаПериода.Окончание = КонецМесяца(СтрокаПериода.Начало);
		КонецЕсли;
		ПредыдущаяСтрокаПериода = СтрокаПериода;
	КонецЦикла;
	
	НачалоПериода = ПериодыПоказателей.Получить(0).Начало;
	ОкончаниеПериода = ПериодыПоказателей.Получить(ПериодыПоказателей.Количество() - 1).Окончание;
	
КонецПроцедуры

&НаСервере
Функция ПоказателиИдентичны(Знач Строка1, Знач Строка2)
	
	Если Не Строка1.КоличествоСтавок = Строка2.КоличествоСтавок Тогда
		Возврат Ложь;
	КонецЕсли;
	
	УникальныеИменаПоказателей = СвойстваПоказателей.Получить("УникальныеИменаПоказателей");
	Для Каждого ЭлементИмяПоказателя Из УникальныеИменаПоказателей Цикл
		Если Не Строка1[ЭлементИмяПоказателя] = Строка2[ЭлементИмяПоказателя] Тогда
			Возврат Ложь;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

&НаКлиенте
Функция ВыбранаСтрокаДляВыполненияКоманды(ТаблицаФормы)
	
	Если Не ЗначениеЗаполнено(ТаблицаФормы.ВыделенныеСтроки) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Для выполнения команды требуется выбрать строку таблицы.'"));
		Возврат Ложь;
	Иначе
		Возврат Истина;
	КонецЕсли;
	
КонецФункции

&НаСервере
Процедура ПроверитьРазбитьПериодСервер()
	
	СтрокаПериод = ПериодыПоказателей.НайтиПоИдентификатору(Элементы.ПериодыПоказателей.ТекущаяСтрока);
	Если СтрокаПериод.Начало = НачалоМесяца(СтрокаПериод.Окончание) Тогда
		ВызватьИсключение НСтр("ru='Разбиение строки возможно для периодов, включающих более одного месяца.'");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РазбитьСтрокуЗавершение(ДатаРазбиения, ДополнительныеПараметры) Экспорт
	
	РазбитьСтрокуНаСервере(ДатаРазбиения); 
	
КонецПроцедуры

&НаСервере
Процедура РазбитьСтрокуНаСервере(ДатаРазбиения)
	
	Если ЗначениеЗаполнено(ДатаРазбиения) Тогда
		СтрокаПериод = ПериодыПоказателей.НайтиПоИдентификатору(Элементы.ПериодыПоказателей.ТекущаяСтрока);
		НоваяСтрокаПериод = ПериодыПоказателей.Вставить(ПериодыПоказателей.Индекс(СтрокаПериод) + 1);
		ЗаполнитьЗначенияСвойств(НоваяСтрокаПериод, СтрокаПериод);
		НоваяСтрокаПериод.Начало = НачалоМесяца(ДатаРазбиения);
		СтрокаПериод.Окончание = НоваяСтрокаПериод.Начало - 1;
	КонецЕсли; 
	
КонецПроцедуры

#КонецОбласти