	ВыборПозиции(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка);
КонецПроцедуры

&НаКлиенте
Процедура ПозицииКадровогоПланаПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, ЭтоГруппа, Параметр)
	
	Отказ = Истина;
	Если Не Копирование Тогда
		Добавить(Команды.Добавить);
		Возврат;
	КонецЕсли;
	
	СкопироватьПозицииНаСервере("ПозицииКадровогоПлана", "Объект.ПозицииКадровогоПлана");
	
КонецПроцедуры

&НаКлиенте
Процедура ПозицииКадровогоПланаПередУдалением(Элемент, Отказ)
	ПередУдалениемПозицииНаСервере("ПозицииКадровогоПлана", "Объект.ПозицииКадровогоПлана");
КонецПроцедуры

&НаКлиенте
Процедура ПозицииКадровогоПланаПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	ИдентификаторТекущейСтроки = Элементы.ПозицииКадровогоПлана.ТекущаяСтрока;
	ТекущиеДанные = Элементы.ПозицииКадровогоПлана.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		СтруктураПолей = Новый Структура;
		Для Сч = МесяцНачала По МесяцОкончания Цикл
			СтруктураПолей.Вставить("КоличествоСтавок" + Сч, ТекущиеДанные["КоличествоСтавок" + Сч]);
		КонецЦикла;
		УникальныеИменаПоказателей = СвойстваПоказателей.Получить("УникальныеИменаПоказателей");
		Для Каждого ИмяПоказателя Из УникальныеИменаПоказателей Цикл
			Для Сч = МесяцНачала По МесяцОкончания Цикл
				СтруктураПолей.Вставить(ИмяПоказателя + Сч, ТекущиеДанные[ИмяПоказателя + Сч]);
			КонецЦикла;
		КонецЦикла;
		СтарыеЗначенияПоказателей = ОбщегоНазначенияКлиент.СкопироватьРекурсивно(СтруктураПолей, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПозицииКадровогоПланаОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.ПозицииКадровогоПлана") Тогда
		ОбработкаВыбораНаСервере(ВыбранноеЗначение);
		Возврат;
	КонецЕсли;
	
	ПозицииДляПодбора = ОбработатьПозицииБезСвязиСоШтатнымРасписанием(ВыбранноеЗначение);
	
	Если ПозицииДляПодбора.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	АдресПодобранных = АдресСпискаПодобранныхПозиций(ПозицииДляПодбора);
	УчитыватьПодборПриЗаполнении = Истина;
	
	НачатьЗаполнениеПоДаннымШтатнойРасстановки(Неопределено, Новый Структура("ЭтоОбработкаВыбора", Истина));
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПозицииКадровогоПланаПоказательПриИзменении(Элемент)
	НачатьВопросОЗаполненииПоказателей(Элемент.Имя);
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСтавки

&НаКлиенте
Процедура СтавкиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ВыборПозиции(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка);
КонецПроцедуры

&НаКлиенте
Процедура СтавкиПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, ЭтоГруппа, Параметр)
	
	Отказ = Истина;
	Если Не Копирование Тогда
		Добавить(Команды.Добавить);
		Возврат;
	КонецЕсли;
	
	НачатьВопросОКопированииСтрок();
	
КонецПроцедуры

&НаКлиенте
Процедура СтавкиПередУдалением(Элемент, Отказ)
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Отказ = Истина;
	
	ТекстВопроса = НСтр("ru = 'Будут удалены все месяцы, связанные с выделенными позициями. Продолжить?'");
	
	ПараметрыВопроса = СтандартныеПодсистемыКлиент.ПараметрыВопросаПользователю();
	ПараметрыВопроса.Заголовок = НСтр("ru = 'Удаление позиций из кадрового плана'");
	ПараметрыВопроса.ПредлагатьБольшеНеЗадаватьЭтотВопрос = Ложь;
		
	Кнопки = Новый СписокЗначений;
	Кнопки.Добавить(КодВозвратаДиалога.Да, НСтр("ru = 'Удалить'"));
	Кнопки.Добавить(КодВозвратаДиалога.Отмена);
	
	СтандартныеПодсистемыКлиент.ПоказатьВопросПользователю(
		Новый ОписаниеОповещения("ЗавершитьВопросОбУдаленииСтрок", ЭтотОбъект), ТекстВопроса, Кнопки, ПараметрыВопроса);
	
КонецПроцедуры

&НаКлиенте
Процедура СтавкиПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	ИдентификаторТекущейСтроки = Элементы.Ставки.ТекущаяСтрока;
	ТекущиеДанные = Элементы.Ставки.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		СтруктураПолей = Новый Структура;
		СтруктураПолей.Вставить("КоличествоСтавок", ТекущиеДанные.КоличествоСтавок);
		УникальныеИменаПоказателей = СвойстваПоказателей.Получить("УникальныеИменаПоказателей");
		Для Каждого ИмяПоказателя Из УникальныеИменаПоказателей Цикл
			СтруктураПолей.Вставить(ИмяПоказателя, ТекущиеДанные[ИмяПоказателя]);
		КонецЦикла;
		СтарыеЗначенияПоказателей = ОбщегоНазначенияКлиент.СкопироватьРекурсивно(СтруктураПолей, Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_СтавкиПоказательПриИзменении(Элемент)
	НачатьВопросОЗаполненииПоказателей(Элемент.Имя);
