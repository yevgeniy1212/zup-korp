&НаКлиенте
Процедура АвтоРасчетПериодаЗакрытия(Команда)
	
	Объект.ПериодЗакрытия = РасчетныйПериодЗакрытия;
	УстановитьВидимостьАвтоРасчетаПериодаЗакрытия(ЭтотОбъект);
	ЗарплатаКадрыКлиентСервер.ЗаполнитьМесяцПоДате(ЭтотОбъект, "Объект.ПериодЗакрытия", "ПериодЗакрытияСтрокой");
	
КонецПроцедуры
// Конец ИсправлениеДокументов

&НаКлиенте
Процедура ПоказатьСкрытьСтруктуруПредприятия(Команда)
	
	Элементы.ПоказатьСкрытьСтруктуруПредприятия.Пометка = Не Элементы.ПоказатьСкрытьСтруктуруПредприятия.Пометка;
	ПриИзмененииПоказатьСкрытьСтруктуруПредприятия();
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьСкрытьСвойстваПозиций(Команда)
	
	Элементы.ПоказатьСкрытьСвойстваПозиций.Пометка = Не Элементы.ПоказатьСкрытьСвойстваПозиций.Пометка;
	ПриИзмененииПоказатьСкрытьСвойстваПозиций();
	
КонецПроцедуры

&НаКлиенте
Процедура Подбор(Команда)
	
	ПараметрыФормы = Новый Структура;
	
	ПараметрыФормы.Вставить("РежимВыбора", Истина);
	ПараметрыФормы.Вставить("МножественныйВыбор", Истина);
	ПараметрыФормы.Вставить("ЗакрыватьПриВыборе", Ложь);
	ПараметрыФормы.Вставить("Отбор", Новый Структура);
	ПараметрыФормы.Отбор.Вставить("Подразделение", ПодчиненныеПодразделения(Объект.Подразделение));
	ПараметрыФормы.Вставить("АдресСпискаПодобранных", АдресСпискаПодобранныхПозиций());
	
	ОткрытьФорму("Справочник.ПозицииКадровогоПлана.ФормаСписка", ПараметрыФормы, Элементы.ПозицииКадровогоПлана);
	
КонецПроцедуры

&НаКлиенте
Процедура Добавить(Команда)
	
	ПараметрыФормы = Новый Структура;
	
	ПараметрыФормы.Вставить("РежимВыбора", Истина);
	ПараметрыФормы.Вставить("МножественныйВыбор", Ложь);
	ПараметрыФормы.Вставить("ЗакрыватьПриВыборе", Истина);
	ПараметрыФормы.Вставить("Отбор", Новый Структура);
	ПараметрыФормы.Отбор.Вставить("Подразделение", ПодчиненныеПодразделения(Объект.Подразделение));
	
	ОткрытьФорму("Справочник.ПозицииКадровогоПлана.ФормаСписка", ПараметрыФормы, Элементы.ПозицииКадровогоПлана);
	
КонецПроцедуры

&НаКлиенте
Процедура Скопировать(Команда)
	
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаМесяцыВКолонках Тогда
		СкопироватьПозицииНаСервере("ПозицииКадровогоПлана", "Объект.ПозицииКадровогоПлана");
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница = Элементы.СтраницаМесяцыВСтроках Тогда
		НачатьВопросОКопированииСтрок();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьВФайл(Команда)
	
	ПараметрыПроверки = ПараметрыПроверкиЗаполнения();
	ПараметрыПроверки.ЭтоЗаполнение = Ложь;
	ПараметрыПроверки.ЗаголовокТабличнойЧасти = НСтр("ru = 'Позиции кадрового плана'");
	ПараметрыПроверки.ПроверяемыеРеквизиты.Вставить("ПериодПланирования", НСтр("ru = 'Период планирования'"));
	ПараметрыПроверки.ПроверяемыеРеквизиты.Вставить("Сценарий", НСтр("ru = 'Сценарий'"));
	Оповещение = Новый ОписаниеОповещения("НачатьВыгрузкуВФайл", ЭтотОбъект);
	ПроверитьВозможностьЗаполнения(Оповещение, ПараметрыПроверки);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьИзФайла(Команда)
	
	Если Не Объект.ПозицииКадровогоПлана.Количество() = 0 Тогда
		ТекстВопроса = НСтр("ru = 'Кадровый план будет перезаполнен. Продолжить?'");
		Оповещение = Новый ОписаниеОповещения("ЗагрузитьИзФайлаЗавершение", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	Иначе
		ПоказатьФормуЗагрузкиИзФайла();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

