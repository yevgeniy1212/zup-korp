		|	ВТПлановыеНачисленияИВзносыСотрудников КАК ПлановыеНачисленияИВзносыСотрудников
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТШтатноеРасписание КАК ШтатноеРасписание
		|		ПО ПлановыеНачисленияИВзносыСотрудников.Позиция = ШтатноеРасписание.ПозицияШтатногоРасписания
		|ГДЕ
		|	НЕ (ПлановыеНачисленияИВзносыСотрудников.Период, ПлановыеНачисленияИВзносыСотрудников.Позиция,
		|		ПлановыеНачисленияИВзносыСотрудников.Сотрудник) В
		|		(ВЫБРАТЬ РАЗЛИЧНЫЕ
		|			Т.Период,
		|			Т.ДолжностьПоШтатномуРасписанию,
		|			Т.Сотрудник
		|		ИЗ
		|			ВТФактическиеНачисленияИВзносыСотрудников КАК Т)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	НачисленияИВзносыСотрудников.Период,
		|	НачисленияИВзносыСотрудников.ДолжностьПоШтатномуРасписанию,
		|	ЕСТЬNULL(ПериодыРаботыСотрудников.ПозицияКадровогоПлана, ЗНАЧЕНИЕ(Справочник.ПозицииКадровогоПлана.ПустаяСсылка)),
		|	ЕСТЬNULL(ПериодыРаботыСотрудников.КоличествоСтавок, 0),
		|	НачисленияИВзносыСотрудников.Подразделение,
		|	НачисленияИВзносыСотрудников.Организация,
		|	НачисленияИВзносыСотрудников.Сотрудник,
		|	НачисленияИВзносыСотрудников.Сотрудник,
		|	НачисленияИВзносыСотрудников.КоличествоСтавок,
		|	НачисленияИВзносыСотрудников.Начисление,
		|	НачисленияИВзносыСотрудников.Сумма,
		|	НачисленияИВзносыСотрудников.ПФРДоПредельнойВеличины,
		|	НачисленияИВзносыСотрудников.ПФРСПревышения,
		|	НачисленияИВзносыСотрудников.ПФРДоПредельнойВеличины + НачисленияИВзносыСотрудников.ПФРСПревышения,
		|	НачисленияИВзносыСотрудников.ПФРПоСуммарномуТарифу,
		|	НачисленияИВзносыСотрудников.ФСС,
		|	НачисленияИВзносыСотрудников.ФССНесчастныеСлучаи,
		|	НачисленияИВзносыСотрудников.ФФОМС,
		|	НачисленияИВзносыСотрудников.ПФРНаДоплатуЛетчикам,
		|	НачисленияИВзносыСотрудников.ПФРНаДоплатуШахтерам,
		|	НачисленияИВзносыСотрудников.ПФРЗаЗанятыхНаПодземныхИВредныхРаботах,
		|	НачисленияИВзносыСотрудников.ПФРЗаЗанятыхНаТяжелыхИПрочихРаботах,
		|	НачисленияИВзносыСотрудников.ПФРСтраховая,
		|	НачисленияИВзносыСотрудников.ПФРНакопительная,
		|	НачисленияИВзносыСотрудников.ТФОМС,
		|	НачисленияИВзносыСотрудников.ПФРЗаЗанятыхНаПодземныхИВредныхРаботахБезСпецОценки,
		|	НачисленияИВзносыСотрудников.ПФРЗаЗанятыхНаПодземныхИВредныхРаботахСпецОценка,
		|	НачисленияИВзносыСотрудников.ПФРЗаЗанятыхНаТяжелыхИПрочихРаботахБезСпецОценки,
		|	НачисленияИВзносыСотрудников.ПФРЗаЗанятыхНаТяжелыхИПрочихРаботахСпецОценка
		|ИЗ
		|	ВТФактическиеНачисленияИВзносыСотрудников КАК НачисленияИВзносыСотрудников
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТПериодыРаботыСотрудников КАК ПериодыРаботыСотрудников
		|		ПО НачисленияИВзносыСотрудников.ДолжностьПоШтатномуРасписанию = ПериодыРаботыСотрудников.Позиция
		|		И НачисленияИВзносыСотрудников.Период = ПериодыРаботыСотрудников.Период
		|ГДЕ
		|	НЕ НачисленияИВзносыСотрудников.ДолжностьПоШтатномуРасписанию ЕСТЬ NULL
		|
		|УПОРЯДОЧИТЬ ПО
		|	Позиция,
		|	СотрудникГруппировка,
		|	Сотрудник,
		|	Период
		|ИТОГИ
		|	МАКСИМУМ(ПозицияКадровогоПлана) КАК ПозицияКадровогоПлана,
		|	МАКСИМУМ(КоличествоСтавокСотрудника) КАК КоличествоСтавокСотрудника,
		|	МАКСИМУМ(КоличествоСтавок) КАК КоличествоСтавок
		|ПО
		|	Позиция,
		|	СотрудникГруппировка,
		|	Сотрудник,
		|	Период";
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат РезультатЗапроса;
	
КонецФункции

Функция НоваяПозицияКадровогоПлана(ПозицияШтатногоРасписания)
	
	Должность = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПозицияШтатногоРасписания, "Должность");
	МестоВСтруктуреПредприятия = ОрганизационнаяСтруктура.МестоПозицииВСтруктуреПредприятия(ПозицияШтатногоРасписания);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ПозицииКадровогоПлана.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ПозицииКадровогоПлана КАК ПозицииКадровогоПлана
		|ГДЕ
		|	ПозицииКадровогоПлана.Подразделение = &МестоВСтруктуреПредприятия
		|	И ПозицииКадровогоПлана.Должность = &Должность";
	
	Запрос.УстановитьПараметр("Должность", Должность);
	Запрос.УстановитьПараметр("МестоВСтруктуреПредприятия", МестоВСтруктуреПредприятия);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		ПозицияКадровогоПлана = ВыборкаДетальныеЗаписи.Ссылка;
	Иначе
		ПозицияКадровогоПланаОбъект = Справочники.ПозицииКадровогоПлана.СоздатьЭлемент();		
		ПозицияКадровогоПланаОбъект.Наименование = НаименованиеПозицииКадровогоПлана(Должность, МестоВСтруктуреПредприятия);
		ПозицияКадровогоПланаОбъект.Должность = Должность;
		ПозицияКадровогоПланаОбъект.Подразделение = МестоВСтруктуреПредприятия;
		ПозицияКадровогоПланаОбъект.Записать();
		ПозицияКадровогоПлана = ПозицияКадровогоПланаОбъект.Ссылка;
	КонецЕсли;
	
	КадровоеПланирование.УстановитьСвязьПозиций(ПозицияШтатногоРасписания, ПозицияКадровогоПлана);
	
	Возврат ПозицияКадровогоПлана;
		
КонецФункции

Функция НаименованиеПозицииКадровогоПлана(Должность, МестоВСтруктуреПредприятия) 
	
	Шаблон = "%1";
	Если ЗначениеЗаполнено(МестоВСтруктуреПредприятия) Тогда
		Шаблон = Шаблон + " /%2/";
	КонецЕсли;
	
	Возврат СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Шаблон, Должность, МестоВСтруктуреПредприятия);
	
КонецФункции

Функция КомпоновщикСхемы(Схема, ВосстанавливатьНастройки = Истина)
	
	ИсточникДоступныхНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(Схема);
	Компоновщик = Новый КомпоновщикНастроекКомпоновкиДанных;
	Компоновщик.Инициализировать(ИсточникДоступныхНастроек);
	Компоновщик.ЗагрузитьНастройки(Схема.НастройкиПоУмолчанию);
	
	Если ВосстанавливатьНастройки Тогда
		Компоновщик.Восстановить(СпособВосстановленияНастроекКомпоновкиДанных.Полное);
	КонецЕсли;
	
	Возврат Компоновщик;
	
КонецФункции

Процедура ЗаполнитьКадровыйПланПоДаннымИзФайла(Форма, АдресЗагруженныхДанных) Экспорт
	
	ЗагруженныеДанные = ПолучитьИзВременногоХранилища(АдресЗагруженныхДанных);
	ОбщегоНазначенияБЗК.ДобавитьИндексКоллекции(ЗагруженныеДанные, "Сотрудник,Позиция");
	
	МесяцНачала = Форма.МесяцНачала;
	МесяцОкончания = Форма.МесяцОкончания;
	КоличествоМесяцев = МесяцОкончания - МесяцНачала + 1;
	ДатаНачала = ОбщегоНазначенияБЗК.ЗначениеРеквизитаПоПутиКДанным(Форма, "Объект.ПериодПланирования");
	ДатаОкончания = ДобавитьМесяц(ДатаНачала, МесяцОкончания - МесяцНачала);
	СвойстваПоказателей = Форма.СвойстваПоказателей;
	
	ПозицииКадровогоПлана = Форма.Объект.ПозицииКадровогоПлана;
	Ставки = Форма.Ставки;
	Показатели = Форма.Показатели;
	
	ПозицииКадровогоПлана.Очистить();
	Ставки.Очистить();
	Показатели.Очистить();
	
	Позиции = ЗагруженныеДанные.Скопировать();
	Позиции.Свернуть("Сотрудник, Позиция");
	
	ИдентификаторСтроки = 1;
	УникальныеИменаПоказателей = СвойстваПоказателей.Получить("УникальныеИменаПоказателей");
	
	Для Каждого Строка Из Позиции Цикл
		Если Не ЗначениеЗаполнено(Строка.Позиция) Тогда
			Продолжить;
		КонецЕсли;
		НоваяСтрока = ПозицииКадровогоПлана.Добавить();
		НоваяСтрока.Позиция = Строка.Позиция;
		НоваяСтрока.Сотрудник = Строка.Сотрудник;
		НоваяСтрока.ИдентификаторСтроки = ИдентификаторСтроки;
		НайденныеСтроки = ЗагруженныеДанные.НайтиСтроки(Новый Структура("Сотрудник, Позиция", Строка.Сотрудник, Строка.Позиция));
		
		НачальныйПериод = Неопределено;
		Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
			Если НайденнаяСтрока.Период < ДатаНачала Или НайденнаяСтрока.Период > ДатаОкончания Тогда
				Продолжить;
			КонецЕсли;
			Если НачальныйПериод = Неопределено Или НачальныйПериод > НайденнаяСтрока.Период Тогда
				НачальныйПериод = НайденнаяСтрока.Период;
			ИначеЕсли НачальныйПериод = НайденнаяСтрока.Период Тогда
				НоваяСтрока = ПозицииКадровогоПлана.Добавить();
				НоваяСтрока.Позиция = Строка.Позиция;
				НоваяСтрока.Сотрудник = Строка.Сотрудник;
				ИдентификаторСтроки = ИдентификаторСтроки + 1;
				НоваяСтрока.ИдентификаторСтроки = ИдентификаторСтроки;
			КонецЕсли;
			НомерМесяца = Месяц(НайденнаяСтрока.Период);
			НоваяСтрокаСтавка = Ставки.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрокаСтавка, НайденнаяСтрока);
			НоваяСтрокаСтавка.ИдентификаторСтроки = ИдентификаторСтроки;
			НоваяСтрока["КоличествоСтавок" + НомерМесяца] = НайденнаяСтрока.КоличествоСтавок;
			НомерПоказателя = 1;
			Для Каждого ИмяПоказателя Из УникальныеИменаПоказателей Цикл
				СвойстваПоказателя = СвойстваПоказателей.Получить(ИмяПоказателя);
				НоваяСтрокаПоказатель = Показатели.Добавить();
				НоваяСтрокаПоказатель.Период = НайденнаяСтрока.Период;
				НоваяСтрокаПоказатель.ИдентификаторСтроки = ИдентификаторСтроки;
				НоваяСтрокаПоказатель.УникальноеИмяПоказателя = СвойстваПоказателя.УникальноеИмяПоказателя;
				НоваяСтрокаПоказатель.Показатель = СвойстваПоказателя.Показатель;
				НоваяСтрокаПоказатель.Значение = НайденнаяСтрока["Показатель" + НомерПоказателя];
				НоваяСтрока[СвойстваПоказателя.УникальноеИмяПоказателя + НомерМесяца] = НоваяСтрокаПоказатель.Значение;
				НоваяСтрокаПоказатель.РеквизитДопУпорядочивания = НомерПоказателя;
				НомерПоказателя = НомерПоказателя + 1;
			КонецЦикла;
		КонецЦикла;
		
		ИдентификаторСтроки = ИдентификаторСтроки + 1;
	КонецЦикла;
	
	Если ПозицииКадровогоПлана.Количество() * КоличествоМесяцев > Ставки.Количество() Тогда
		Для Каждого Строка Из ПозицииКадровогоПлана Цикл
			НайденныйМесяц = 0;
			НайденныеСтроки = Ставки.НайтиСтроки(Новый Структура("ИдентификаторСтроки", Строка.ИдентификаторСтроки));
			КоличествоИндексов = НайденныеСтроки.ВГраница();
			ВычестьИндексов = КоличествоИндексов;
			Для Сч = МесяцНачала По МесяцОкончания Цикл
				Если Сч > НайденныйМесяц И ВычестьИндексов >= 0 Тогда
					НайденныйМесяц = Месяц(НайденныеСтроки[КоличествоИндексов - ВычестьИндексов].Период);
					ВычестьИндексов = ВычестьИндексов - 1;
				КонецЕсли;
				Если Сч = НайденныйМесяц Тогда
					Продолжить;
				КонецЕсли;
				НоваяСтрокаСтавка = Ставки.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаСтавка, Строка);
				НоваяСтрокаСтавка.Период = ДобавитьМесяц(ДатаНачала, Сч - МесяцНачала);
				НомерПоказателя = 1;
				Для Каждого ИмяПоказателя Из УникальныеИменаПоказателей Цикл
					СвойстваПоказателя = СвойстваПоказателей.Получить(ИмяПоказателя);
					НоваяСтрокаПоказатель = Показатели.Добавить();
					НоваяСтрокаПоказатель.Период = НоваяСтрокаСтавка.Период;
					НоваяСтрокаПоказатель.ИдентификаторСтроки = НоваяСтрокаСтавка.ИдентификаторСтроки;
					НоваяСтрокаПоказатель.УникальноеИмяПоказателя = СвойстваПоказателя.УникальноеИмяПоказателя;
					НоваяСтрокаПоказатель.Показатель = СвойстваПоказателя.Показатель;
					НоваяСтрокаПоказатель.РеквизитДопУпорядочивания = НомерПоказателя;
					НомерПоказателя = НомерПоказателя + 1;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
		Ставки.Сортировать("ИдентификаторСтроки, Период");
		Показатели.Сортировать("ИдентификаторСтроки, Период, РеквизитДопУпорядочивания");
	КонецЕсли;
	
	ЗаполнитьПоказателиВТаблицах(ПозицииКадровогоПлана, Ставки, Показатели, Форма.СвойстваПоказателей, МесяцНачала, МесяцОкончания);
	
КонецПроцедуры

// Таблицы данных о значениях показателей.
// 
// Параметры:
//  Ссылка - ДокументСсылка.КадровыйПлан - Ссылка на документ
// 
// Возвращаемое значение:
//  Структура - Таблицы данных о значениях показателей:
// * СведенияОСтавках - ТаблицаЗначений - 
// * СведенияОПоказателях - ТаблицаЗначений -
Функция ТаблицыДанныхОЗначенияхПоказателей(Ссылка) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("ПоказательКоличествоСтавок", КадровоеПланирование.ПоказательКоличествоСтавок());
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЗначенияПоказателейКадровыхПланов.ИдентификаторСтроки КАК ИдентификаторСтроки,
	|	ЗначенияПоказателейКадровыхПланов.ПериодПоказателя КАК ПериодПоказателя,
	|	ЗначенияПоказателейКадровыхПланов.Показатель КАК Показатель,
	|	ЗначенияПоказателейКадровыхПланов.Значение КАК Значение,
	|	ЗначенияПоказателейКадровыхПланов.ЗначениеЗаполнения КАК ЗначениеЗаполнения
	|ПОМЕСТИТЬ ВТЗначенияПоказателейКадровыхПланов
	|ИЗ
	|	РегистрСведений.ЗначенияПоказателейКадровыхПланов КАК ЗначенияПоказателейКадровыхПланов
	|ГДЕ
	|	ЗначенияПоказателейКадровыхПланов.КадровыйПлан = &Ссылка
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Показатель
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗначенияКоличестваСтавок.ИдентификаторСтроки КАК ИдентификаторСтроки,
	|	ЗначенияКоличестваСтавок.ПериодПоказателя КАК Период,
	|	ЗначенияКоличестваСтавок.Значение КАК КоличествоСтавок,
	|	ЗначенияКоличестваСтавок.ЗначениеЗаполнения КАК КоличествоСтавокЗаполнения
	|ИЗ
	|	ВТЗначенияПоказателейКадровыхПланов КАК ЗначенияКоличестваСтавок
	|ГДЕ
	|	ЗначенияКоличестваСтавок.Показатель = &ПоказательКоличествоСтавок
	|
	|УПОРЯДОЧИТЬ ПО
	|	ИдентификаторСтроки,
	|	Период
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЗначенияПоказателей.ИдентификаторСтроки КАК ИдентификаторСтроки,
	|	ЗначенияПоказателей.ПериодПоказателя КАК Период,
	|	ЗначенияПоказателей.Показатель КАК Показатель,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(100)) КАК УникальноеИмяПоказателя,
	|	ЗначенияПоказателей.Значение КАК Значение,
	|	ЗначенияПоказателей.ЗначениеЗаполнения КАК ЗначениеЗаполнения
	|ИЗ
	|	ВТЗначенияПоказателейКадровыхПланов КАК ЗначенияПоказателей
	|ГДЕ
	|	НЕ ЗначенияПоказателей.Показатель = &ПоказательКоличествоСтавок
	|
	|УПОРЯДОЧИТЬ ПО
	|	ИдентификаторСтроки,
	|	Период
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТЗначенияПоказателейКадровыхПланов";
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	УстановитьПривилегированныйРежим(Ложь);
	
	СведенияОПоказателях = РезультатыЗапроса[2].Выгрузить();
	ЗаполнитьУникальныеИменаПоказателей(СведенияОПоказателях);
	
	Возврат Новый Структура("СведенияОСтавках, СведенияОПоказателях", РезультатыЗапроса[1].Выгрузить(), СведенияОПоказателях);
	
КонецФункции

Процедура ЗаполнитьУникальныеИменаПоказателей(СведенияОПоказателях)
	
	ИменаПоказателей = Новый Соответствие;
	Для Каждого СтрокаПоказатель Из СведенияОПоказателях Цикл
		УникальноеИмяПоказателя = ИменаПоказателей.Получить(СтрокаПоказатель.Показатель);
		Если УникальноеИмяПоказателя = Неопределено Тогда
			УникальноеИмяПоказателя = КадровоеПланирование.УникальноеИмяПоказателя(СтрокаПоказатель.Показатель);
			ИменаПоказателей.Вставить(СтрокаПоказатель.Показатель, УникальноеИмяПоказателя);
		КонецЕсли;
		СтрокаПоказатель.УникальноеИмяПоказателя = УникальноеИмяПоказателя;
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьДополнительныеСвойстваОЗначенияхПоказателей(ДополнительныеСвойстваДокумента) Экспорт
	ДополнительныеСвойстваДокумента.Вставить("СведенияОПоказателях", РегистрыСведений.ЗначенияПоказателейКадровыхПланов.СоздатьНаборЗаписей());
КонецПроцедуры

#Область ЗагрузкаДанныхИзФайла

Функция ВыгрузитьКолонку(ЗагружаемыеДанные, ИмяКолонки)
	
	Таблица = ЗагружаемыеДанные.Скопировать();
	Таблица.Свернуть(ИмяКолонки);
	
	Возврат Таблица.ВыгрузитьКолонку(ИмяКолонки);

КонецФункции

Процедура ЗаполнитьПериодИзСтрокиВДату(НоваяСтрока, СоответствиеСтрокДатам, СтрокаПериод)
	
	Период = СоответствиеСтрокДатам.Получить(СтрокаПериод);
	
	Если Период = Неопределено Тогда
		Период = СтроковыеФункцииКлиентСервер.СтрокаВДату(СтрокаПериод);
		СоответствиеСтрокДатам.Вставить(СтрокаПериод, Период);
	КонецЕсли;
	
	НоваяСтрока.Период = Период;

КонецПроцедуры

Процедура ПроверитьНеоднозначностьСотрудника(НоваяСтрока, СтрокаТаблицы, КэшДанныхЗагрузки, СписокНеоднозначностей, РезультатЗагрузки)
	
	Если Не ПустаяСтрока(СтрокаТаблицы.Сотрудник) И Не ПустаяСтрока(СтрокаТаблицы.КодСотрудника) Тогда
		Отбор = Новый Структура("Сотрудник, КодСотрудника", СтрокаТаблицы.Сотрудник, СтрокаТаблицы.КодСотрудника);
		НоваяСтрока.Сотрудник = КэшДанныхЗагрузки.СоответствиеСотрудниковПоОтбору.Получить(Отбор);
		Если Не ЗначениеЗаполнено(НоваяСтрока.Сотрудник) Тогда
			Строки = РезультатЗагрузки.ТаблицаСотрудникиКодыСотрудников.НайтиСтроки(Отбор);
			Если Строки.Количество() = 1 Тогда 
				НоваяСтрока.Сотрудник = Строки[0].Ссылка;
				КэшДанныхЗагрузки.СоответствиеСотрудниковПоОтбору.Вставить(Отбор, НоваяСтрока.Сотрудник);
				КэшДанныхЗагрузки.СоответствиеСотрудников.Вставить(СтрокаТаблицы.Сотрудник, НоваяСтрока.Сотрудник);
				КэшДанныхЗагрузки.СоответствиеКодовСотрудников.Вставить(СтрокаТаблицы.КодСотрудника, НоваяСтрока.Сотрудник);
				Возврат;
			ИначеЕсли Строки.Количество() > 1 Тогда
				ЗаписьОНеоднозначности = СписокНеоднозначностей.Добавить();
				ЗаписьОНеоднозначности.Идентификатор = СтрокаТаблицы.Идентификатор; 
				ЗаписьОНеоднозначности.Колонка = "Сотрудник";
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ПустаяСтрока(СтрокаТаблицы.Сотрудник) И ПустаяСтрока(СтрокаТаблицы.КодСотрудника) Тогда
		НоваяСтрока.Сотрудник = КэшДанныхЗагрузки.СоответствиеСотрудников.Получить(СтрокаТаблицы.Сотрудник);
		Если Не ЗначениеЗаполнено(НоваяСтрока.Сотрудник) Тогда
			Отбор = Новый Структура("Сотрудник", СтрокаТаблицы.Сотрудник);
			Строки = РезультатЗагрузки.ТаблицаСотрудники.НайтиСтроки(Отбор);
			Если Строки.Количество() = 1 Тогда 
				НоваяСтрока.Сотрудник = Строки[0].Ссылка;
				КэшДанныхЗагрузки.СоответствиеСотрудников.Вставить(СтрокаТаблицы.Сотрудник, НоваяСтрока.Сотрудник);
				Возврат;
			ИначеЕсли Строки.Количество() > 1 Тогда
				ЗаписьОНеоднозначности = СписокНеоднозначностей.Добавить();
				ЗаписьОНеоднозначности.Идентификатор = СтрокаТаблицы.Идентификатор; 
				ЗаписьОНеоднозначности.Колонка = "Сотрудник";
				Возврат;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ПустаяСтрока(СтрокаТаблицы.КодСотрудника) Тогда
		НоваяСтрока.Сотрудник = КэшДанныхЗагрузки.СоответствиеКодовСотрудников.Получить(СтрокаТаблицы.КодСотрудника);
		Если Не ЗначениеЗаполнено(НоваяСтрока.Сотрудник) Тогда
			Отбор = Новый Структура("КодСотрудника", СтрокаТаблицы.КодСотрудника);
			Строки = РезультатЗагрузки.ТаблицаКодыСотрудников.НайтиСтроки(Отбор);
			Если Строки.Количество() = 1 Тогда 
				НоваяСтрока.Сотрудник = Строки[0].Ссылка;
				КэшДанныхЗагрузки.СоответствиеКодовСотрудников.Вставить(СтрокаТаблицы.КодСотрудника, НоваяСтрока.Сотрудник);
			ИначеЕсли Строки.Количество() > 1 Тогда
				ЗаписьОНеоднозначности = СписокНеоднозначностей.Добавить();
				ЗаписьОНеоднозначности.Идентификатор = СтрокаТаблицы.Идентификатор; 
				ЗаписьОНеоднозначности.Колонка = "Сотрудник";
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

Процедура ПроверитьНеоднозначностьПодразделения(НоваяСтрока, СтрокаТаблицы, КэшДанныхЗагрузки, СписокНеоднозначностей, РезультатЗагрузки, СтруктурыСоответствуют)
	
