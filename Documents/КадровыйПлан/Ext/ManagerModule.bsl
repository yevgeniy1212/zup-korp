		КонецЕсли;
	Иначе
		НоваяСтрока.Подразделение = КэшДанныхЗагрузки.СоответствиеКодовПодразделений.Получить(СтрокаТаблицы.КодПодразделения);
		Если ЗначениеЗаполнено(НоваяСтрока.Подразделение) Тогда
			Возврат;
		КонецЕсли;
		Отбор = Новый Структура("КодПодразделения", СтрокаТаблицы.КодПодразделения);
