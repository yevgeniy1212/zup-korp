#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Заполняет список команд печати.
//
// Параметры:
//   КомандыПечати - ТаблицаЗначений - состав полей см. в функции УправлениеПечатью.СоздатьКоллекциюКомандПечати.
//
Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	
	// Печать кадрового плана (периоды в колонках).
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.Идентификатор = "ПечатьКадровогоПланаПериодыВКолонках";
	КомандаПечати.Представление = НСтр("ru = 'Кадровый план (периоды в колонках)'");
	КомандаПечати.ПроверкаПроведенияПередПечатью = Истина;
	
	// Печать кадрового плана (периоды в строках).
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.Идентификатор = "ПечатьКадровогоПланаПериодыВСтроках";
	КомандаПечати.Представление = НСтр("ru = 'Кадровый план (периоды в строках)'");
	КомандаПечати.ПроверкаПроведенияПередПечатью = Истина;
	
КонецПроцедуры

// СтандартныеПодсистемы.УправлениеДоступом

// См. УправлениеДоступомПереопределяемый.ПриЗаполненииСписковСОграничениемДоступа.
Процедура ПриЗаполненииОграниченияДоступа(Ограничение) Экспорт
	Ограничение.Текст =
	"РазрешитьЧтениеИзменение
	|ГДЕ
	|	ЗначениеРазрешено(Подразделение)";
КонецПроцедуры

// Конец СтандартныеПодсистемы.УправлениеДоступом

// СтандартныеПодсистемы.ВерсионированиеОбъектов
// Определяет настройки объекта для подсистемы ВерсионированиеОбъектов.
//
// Параметры:
//  Настройки - Структура - настройки подсистемы.
Процедура ПриОпределенииНастроекВерсионированияОбъектов(Настройки) Экспорт
	Настройки.ПриПолученииСлужебныхРеквизитов = Истина;
КонецПроцедуры

// Ограничивает видимость реквизитов объекта в отчете по версии.
//
// Параметры:
//  Реквизиты - Массив - список имен реквизитов объекта.
Процедура ПриПолученииСлужебныхРеквизитов(Реквизиты) Экспорт
	Реквизиты.Добавить("ЗагрузкаИзФайлаПозицииКадровогоПлана.*");
КонецПроцедуры
// Конец СтандартныеПодсистемы.ВерсионированиеОбъектов

// СтандартныеПодсистемы.ЗагрузкаДанныхИзФайла

// Переопределяет параметры загрузки данных из файла.
//
// Параметры:
//  Параметры - Структура:
//   * ИмяМакетаСШаблоном - Строка - наименование макета. Например, "ЗагрузкаИзФайла".
//   * ИмяТабличнойЧасти - Строка - Полное имя табличной части. Например, "Документ._ДемоСчетНаОплатуПокупателю.ТабличнаяЧасть.Товары"
//   * ОбязательныеКолонки - Массив из Строка - наименования обязательных для заполнения колонок.
//   * ТипДанныхКолонки - Соответствие из КлючИЗначение:
//      * Ключ - Строка - имя колонки;
//      * Значение - ОписаниеТипов - тип колонки загружаемых данных.
//   * ДополнительныеПараметры - Структура
//
Процедура УстановитьПараметрыЗагрузкиИзФайлаВТЧ(Параметры) Экспорт

КонецПроцедуры

// Производит сопоставление данных, загружаемых в табличную часть ПолноеИмяТабличнойЧасти,
// с данными в ИБ, и заполняет параметры АдресТаблицыСопоставления и СписокНеоднозначностей.
//
// Параметры:
//   АдресЗагружаемыхДанных    - Строка - адрес временного хранилища с таблицей значений, в которой
//                               находятся загруженные данные из файла. Состав колонок:
//     * Идентификатор - Число - порядковый номер строки;
//     * остальные колонки соответствуют колонкам макета ЗагрузкаИзФайла.
//   АдресТаблицыСопоставления - Строка - адрес временного хранилища с пустой таблицей значений,
//                               являющейся копией табличной части документа, 
//                                        которую необходимо заполнить из таблицы АдресЗагружаемыхДанных.
//   СписокНеоднозначностей - ТаблицаЗначений - список неоднозначных значений, для которых в ИБ имеется несколько подходящих вариантов.
//       * Колонка       - Строка - имя колонки, в которой была обнаружена неоднозначность;
//       * Идентификатор - Число  - идентификатор строки, в которой была обнаружена неоднозначность.
//   ПолноеИмяТабличнойЧасти   - Строка - полное имя табличной части, в которую загружаются данные.
//   ДополнительныеПараметры   - ЛюбойТип - Любые дополнительные сведения.
//
Процедура СопоставитьЗагружаемыеДанные(АдресЗагружаемыхДанных, АдресТаблицыСопоставления, СписокНеоднозначностей, ПолноеИмяТабличнойЧасти, ДополнительныеПараметры) Экспорт
	
	ТаблицаСопоставления = ПолучитьИзВременногоХранилища(АдресТаблицыСопоставления);
	ЗагружаемыеДанные = ПолучитьИзВременногоХранилища(АдресЗагружаемыхДанных);
	
	СтруктурыСоответствуют = ДополнительныеПараметры.СтруктурыСоответствуют;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивСотрудников", ВыгрузитьКолонку(ЗагружаемыеДанные, "Сотрудник"));
	Запрос.УстановитьПараметр("МассивКодовСотрудников", ВыгрузитьКолонку(ЗагружаемыеДанные, "КодСотрудника"));
	Запрос.УстановитьПараметр("МассивКодовПодразделений", ВыгрузитьКолонку(ЗагружаемыеДанные, "КодПодразделения"));
	Запрос.УстановитьПараметр("МассивПозиций", ВыгрузитьКолонку(ЗагружаемыеДанные, "Позиция"));
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Сотрудники.Ссылка КАК Ссылка,
		|	Сотрудники.Код КАК КодСотрудника,
		|	Сотрудники.Наименование КАК Сотрудник
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|ГДЕ
		|	Сотрудники.Наименование В(&МассивСотрудников)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Сотрудники.Ссылка КАК Ссылка,
		|	Сотрудники.Код КАК КодСотрудника,
		|	Сотрудники.Наименование КАК Сотрудник
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|ГДЕ
		|	Сотрудники.Код В(&МассивКодовСотрудников)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПозицииКадровогоПлана.Ссылка КАК Ссылка,
		|	ПозицииКадровогоПлана.Наименование КАК Позиция,
		|	ПозицииКадровогоПлана.Подразделение КАК Подразделение
		|ИЗ
		|	Справочник.ПозицииКадровогоПлана КАК ПозицииКадровогоПлана
		|ГДЕ
		|	ПозицииКадровогоПлана.Наименование В(&МассивПозиций)";
	
	Если СтруктурыСоответствуют Тогда
		Запрос.Текст = Запрос.Текст + "
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	СтруктураПредприятия.Ссылка КАК Ссылка,
			|	СтруктураПредприятия.КодИсточника КАК КодПодразделения,
			|	ПодразделенияОрганизаций.Владелец.Наименование КАК Организация
			|ИЗ
			|	Справочник.СтруктураПредприятия КАК СтруктураПредприятия
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ПодразделенияОрганизаций КАК ПодразделенияОрганизаций
			|		ПО СтруктураПредприятия.Источник = ПодразделенияОрганизаций.Ссылка
			|ГДЕ
			|	СтруктураПредприятия.КодИсточника В (&МассивКодовПодразделений)";
	Иначе
		Запрос.Текст = Запрос.Текст + "
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	СтруктураПредприятия.Ссылка КАК Ссылка,
			|	СтруктураПредприятия.Код КАК КодПодразделения
			|ИЗ
			|	Справочник.СтруктураПредприятия КАК СтруктураПредприятия
			|ГДЕ
			|	СтруктураПредприятия.Код В (&МассивКодовПодразделений)";
	КонецЕсли;
	
	РезультатыЗапросов = Запрос.ВыполнитьПакет();
	
	РезультатЗагрузки = Новый Структура;
	СохранитьПроиндексированныйРезультат(РезультатЗагрузки, РезультатыЗапросов[0].Выгрузить(), "ТаблицаСотрудники", "Сотрудник");
	СохранитьПроиндексированныйРезультат(РезультатЗагрузки, РезультатыЗапросов[1].Выгрузить(), "ТаблицаКодыСотрудников", "КодСотрудника");
	СохранитьПроиндексированныйРезультат(РезультатЗагрузки, РезультатыЗапросов[2].Выгрузить(), "ТаблицаПозиции", "Позиция");
	СохранитьПроиндексированныйРезультат(РезультатЗагрузки, РезультатыЗапросов[3].Выгрузить(), "ТаблицаКодыПодразделений", "КодПодразделения");
	СохранитьПроиндексированныйРезультат(РезультатЗагрузки, РезультатЗагрузки.ТаблицаСотрудники.Скопировать(), "ТаблицаСотрудникиКодыСотрудников", "Сотрудник, КодСотрудника");
	СохранитьПроиндексированныйРезультат(РезультатЗагрузки, РезультатЗагрузки.ТаблицаПозиции.Скопировать(), "ТаблицаПозицииПодразделения", "Позиция, Подразделение");
	
	КэшДанныхЗагрузки = Новый Структура;
	КэшДанныхЗагрузки.Вставить("СоответствиеСтрокДатам", Новый Соответствие);
	КэшДанныхЗагрузки.Вставить("СоответствиеСотрудниковПоОтбору", Новый Соответствие);
	КэшДанныхЗагрузки.Вставить("СоответствиеСотрудников", Новый Соответствие);
	КэшДанныхЗагрузки.Вставить("СоответствиеКодовСотрудников", Новый Соответствие);
	КэшДанныхЗагрузки.Вставить("СоответствиеКодовПодразделений", Новый Соответствие);
	КэшДанныхЗагрузки.Вставить("СоответствиеПозиций", Новый Соответствие);
	КэшДанныхЗагрузки.Вставить("СоответствиеПозицийПодразделений", Новый Соответствие);
	
	Если СтруктурыСоответствуют Тогда
		СохранитьПроиндексированныйРезультат(РезультатЗагрузки, РезультатЗагрузки.ТаблицаКодыПодразделений.Скопировать(), "ТаблицаОрганизацийКодыИсточников", "Организация, КодПодразделения");
		КэшДанныхЗагрузки.Вставить("СоответствиеПодразделенийПоОтбору", Новый Соответствие);
	КонецЕсли;
	
	ПустаяДата = Дата(1,1,1);
	Для Каждого СтрокаТаблицы Из ЗагружаемыеДанные Цикл
		НоваяСтрока = ТаблицаСопоставления.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
		Если НоваяСтрока.Период = ПустаяДата Тогда
			ЗаполнитьПериодИзСтрокиВДату(НоваяСтрока, КэшДанныхЗагрузки.СоответствиеСтрокДатам, СтрокаТаблицы.Период);
		КонецЕсли;
    	ПроверитьНеоднозначностьСотрудника(НоваяСтрока, СтрокаТаблицы, КэшДанныхЗагрузки, СписокНеоднозначностей, РезультатЗагрузки);
		ПроверитьНеоднозначностьПодразделения(НоваяСтрока, СтрокаТаблицы, КэшДанныхЗагрузки, СписокНеоднозначностей, РезультатЗагрузки, СтруктурыСоответствуют);
        ПроверитьНеоднозначностьПозиции(НоваяСтрока, СтрокаТаблицы, КэшДанныхЗагрузки, СписокНеоднозначностей, РезультатЗагрузки);
	КонецЦикла;
	
	ПоместитьВоВременноеХранилище(ТаблицаСопоставления, АдресТаблицыСопоставления);
	
КонецПроцедуры

// Возвращает список подходящих объектов ИБ для неоднозначного значения ячейки.
// 
// Параметры:
//    ПолноеИмяТабличнойЧасти  - Строка - Полное имя табличной части, в которую загружаются данные.
//    ИмяКолонки               - Строка - Имя колонки, в который возникла неоднозначность. 
//    СписокНеоднозначностей    - Массив  - Массив для заполнения с неоднозначными данными.
//    ЗагружаемыеЗначенияСтрока - Строка  - Загружаемые данные, на основании которых возникла неоднозначность.
//    ДополнительныеПараметры   - ЛюбойТип - Любые дополнительные сведения
//
Процедура ЗаполнитьСписокНеоднозначностей(ПолноеИмяТабличнойЧасти, СписокНеоднозначностей, ИмяКолонки, ЗагружаемыеЗначенияСтрока, ДополнительныеПараметры) Экспорт
	
	Если ИмяКолонки = "Сотрудник" Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Сотрудники.Ссылка
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|ГДЕ
		|	Сотрудники.Наименование = &Наименование";
		Запрос.УстановитьПараметр("Наименование", ЗагружаемыеЗначенияСтрока.Сотрудник);
		РезультатЗапроса = Запрос.Выполнить();
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			СписокНеоднозначностей.Добавить(Выборка.Ссылка);  
		КонецЦикла;
	КонецЕсли;
	
	Если ИмяКолонки = "Позиция" Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	Позиции.Ссылка
			|ИЗ
			|	Справочник.ПозицииКадровогоПлана КАК Позиции
			|ГДЕ
			|	Позиции.Наименование = &Наименование";
		Запрос.УстановитьПараметр("Наименование", ЗагружаемыеЗначенияСтрока.Позиция);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			СписокНеоднозначностей.Добавить(Выборка.Ссылка);
		КонецЦикла;
	КонецЕсли;
	
	Если ИмяКолонки = "Подразделение" Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	СтруктураПредприятия.Ссылка КАК Ссылка
			|ИЗ
			|	Справочник.СтруктураПредприятия КАК СтруктураПредприятия
			|ГДЕ
			|	СтруктураПредприятия.Наименование = &Наименование";
		Запрос.УстановитьПараметр("Наименование", ЗагружаемыеЗначенияСтрока.Подразделение);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			СписокНеоднозначностей.Добавить(Выборка.Ссылка);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

// Конец СтандартныеПодсистемы.ЗагрузкаДанныхИзФайла

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Сторнирует документ по учетам. Используется подсистемой исправления документов.
//
// Параметры:
//  Движения				 - КоллекцияДвижений, Структура	 - Коллекция движений исправляющего документа в которую будут добавлены сторно стоки.
//  Регистратор				 - ДокументСсылка				 - Документ регистратор исправления (документ исправление).
//  ИсправленныйДокумент	 - ДокументСсылка				 - Исправленный документ движения которого будут сторнированы.
//  СтруктураВидовУчета		 - Структура					 - Виды учета, по которым будет выполнено сторнирование исправленного документа.
//  					Состав полей см. в ПроведениеРасширенныйСервер.СтруктураВидовУчета().
//  ДополнительныеПараметры	 - Структура					 - Структура со свойствами:
//  					* ИсправлениеВТекущемПериоде - Булево - Истина когда исправление выполняется в периоде регистрации исправленного документа.
//						* ОтменаДокумента - Булево - Истина когда исправление вызвано документом СторнированиеНачислений.
//  					* ПериодРегистрации	- Дата - Период регистрации документа регистратора исправления.
// 
// Возвращаемое значение:
//  Булево - "Истина" если сторнирование выполнено этой функцией, "Ложь" если специальной процедуры не предусмотрено.
//
Функция СторнироватьПоУчетам(Движения, Регистратор, ИсправленныйДокумент, СтруктураВидовУчета, ДополнительныеПараметры) Экспорт
	
	ИсправлениеДокументовЗарплатаКадры.СторнироватьДвиженияБезСпецификиУчетов(Движения, ИсправленныйДокумент, ДополнительныеПараметры);
	
	Возврат Истина;
	
КонецФункции

Функция СвойстваИсправляемогоДокумента(ДокументСсылка) Экспорт
	
	Реквизиты = ИсправлениеДокументовЗарплатаКадры.РеквизитыИсправляемогоДокумента();
	Возврат ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументСсылка, Реквизиты);
	
КонецФункции

Функция ПараметрыИсправляемогоДокумента(ДокументСсылка) Экспорт
	
	Возврат ИсправлениеДокументовЗарплатаКадры.ПараметрыИсправляемогоДокумента(ДокументСсылка,
		СвойстваИсправляемогоДокумента(ДокументСсылка));
	
КонецФункции

#Область ОбработчикиПравилРегистрации

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ШаблонОбработчика
Процедура ПриЗаполненииНастроекОбработчиковПравилРегистрации(Настройки) Экспорт
	ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОтбораПоПодразделению(Настройки);
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции
	
#Область Печать

// Формирует печатные формы.
//
// Параметры:
//  МассивОбъектов  - Массив    - ссылки на объекты, которые нужно распечатать;
//  ПараметрыПечати - Структура - дополнительные настройки печати;
//  КоллекцияПечатныхФорм - ТаблицаЗначений - сформированные табличные документы (выходной параметр).
//  ОбъектыПечати         - СписокЗначений  - значение - ссылка на объект;
//                                            представление - имя области в которой был выведен объект (выходной
//                                                            параметр);
//  ПараметрыВывода       - Структура       - дополнительные параметры сформированных табличных документов (выходной
//                                            параметр).
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПечатьКадровогоПланаПериодыВКолонках") Тогда
		ТабличныйДокумент = СформироватьПечатнуюФормуКадровогоПлана(МассивОбъектов, ОбъектыПечати,
			КадровоеПланированиеКлиентСервер.ВариантыКомпоновки().МесяцыВКолонках);
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
			КоллекцияПечатныхФорм, 
			"ПечатьКадровогоПланаПериодыВКолонках",
			НСтр("ru = 'Кадровый план (периоды в колонках)'"),
			ТабличныйДокумент);
	КонецЕсли;
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПечатьКадровогоПланаПериодыВСтроках") Тогда
		ТабличныйДокумент = СформироватьПечатнуюФормуКадровогоПлана(МассивОбъектов, ОбъектыПечати,
			КадровоеПланированиеКлиентСервер.ВариантыКомпоновки().МесяцыВСтроках);
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(
			КоллекцияПечатныхФорм,
			"ПечатьКадровогоПланаПериодыВСтроках",
			НСтр("ru = 'Кадровый план (периоды в строках)'"),
			ТабличныйДокумент);
	КонецЕсли;
	
КонецПроцедуры

Функция СформироватьПечатнуюФормуКадровогоПлана(МассивОбъектов, ОбъектыПечати, ИмяВарианта)
	
	Результат = Новый ТабличныйДокумент;
	Результат.АвтоМасштаб = Истина;
	Результат.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ПечатьКадровогоПлана" + ИмяВарианта;
	
	Если ИмяВарианта = КадровоеПланированиеКлиентСервер.ВариантыКомпоновки().МесяцыВКолонках Тогда
		Результат.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	КонецЕсли;
	
	ДанныеДляПечати = ДанныеПечатиКадровыхПланов(МассивОбъектов);
	
	Для Каждого ОписаниеКадровогоПлана Из ДанныеДляПечати Цикл
		РезультатПечати = ВывестиОтчетВТабличныйДокумент(ИмяВарианта, ОписаниеКадровогоПлана.ПозицииКадровогоПлана,
			ОписаниеКадровогоПлана.Ставки, ОписаниеКадровогоПлана.СвойстваПоказателей,
			ОписаниеКадровогоПлана.МесяцНачала, ОписаниеКадровогоПлана.МесяцОкончания);
		Результат.Вывести(РезультатПечати);
		Результат.ВывестиГоризонтальныйРазделительСтраниц();
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ДанныеПечатиКадровыхПланов(КадровыеПланы)
	
	ДанныеПечати = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("КадровыеПланы", КадровыеПланы);
	Запрос.УстановитьПараметр("ПоказательКоличествоСтавок", КадровоеПланирование.ПоказательКоличествоСтавок());
	Запрос.Текст =
		"ВЫБРАТЬ
		|	КадровыйПлан.Ссылка КАК ДокументСсылка,
		|	КадровыйПлан.ПериодПланирования,
		|	КадровыйПлан.Сценарий,
		|	КадровыйПлан.Периодичность,
		|	ВЫБОР
		|		КОГДА ИСТИНА В
		|			(ВЫБРАТЬ ПЕРВЫЕ 1
		|				ИСТИНА
		|			ИЗ
		|				Документ.КадровыйПлан.ПозицииКадровогоПлана КАК КадровыйПланПозиции
		|			ГДЕ
		|				КадровыйПланПозиции.Ссылка = КадровыйПлан.Ссылка)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЕстьПозиции,
		|	ВЫБОР
		|		КОГДА ИСТИНА В
		|			(ВЫБРАТЬ ПЕРВЫЕ 1
		|				ИСТИНА
		|			ИЗ
		|				РегистрСведений.ЗначенияПоказателейКадровыхПланов КАК ЗначенияКоличестваСтавок
		|			ГДЕ
		|				ЗначенияКоличестваСтавок.КадровыйПлан = КадровыйПлан.Ссылка
		|				И ЗначенияКоличестваСтавок.Показатель = &ПоказательКоличествоСтавок)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЕстьЗначенияКоличестваСтавок,
		|	ВЫБОР
		|		КОГДА ИСТИНА В
		|			(ВЫБРАТЬ ПЕРВЫЕ 1
		|				ИСТИНА
		|			ИЗ
		|				РегистрСведений.ЗначенияПоказателейКадровыхПланов КАК ЗначенияПоказателей
		|			ГДЕ
		|				ЗначенияПоказателей.КадровыйПлан = КадровыйПлан.Ссылка
		|				И НЕ ЗначенияПоказателей.Показатель = &ПоказательКоличествоСтавок)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЕстьЗначенияПоказателей
		|ИЗ
		|	Документ.КадровыйПлан КАК КадровыйПлан
		|ГДЕ
		|	КадровыйПлан.Ссылка В (&КадровыеПланы)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДокументСсылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КадровыйПланПозиции.Ссылка КАК ДокументСсылка,
		|	КадровыйПланПозиции.НомерСтроки,
		|	КадровыйПланПозиции.Позиция,
		|	КадровыйПланПозиции.ИдентификаторСтроки,
		|	КадровыйПланПозиции.Сотрудник
		|ИЗ
		|	Документ.КадровыйПлан.ПозицииКадровогоПлана КАК КадровыйПланПозиции
		|ГДЕ
		|	КадровыйПланПозиции.Ссылка В (&КадровыеПланы)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Ссылка,
		|	ИдентификаторСтроки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗначенияКоличестваСтавок.КадровыйПлан,
		|	ЗначенияКоличестваСтавок.ПериодПоказателя КАК Период,
		|	ЗначенияКоличестваСтавок.ИдентификаторСтроки,
		|	ЗначенияКоличестваСтавок.Значение КАК КоличествоСтавок
		|ИЗ
		|	РегистрСведений.ЗначенияПоказателейКадровыхПланов КАК ЗначенияКоличестваСтавок
		|ГДЕ
		|	ЗначенияКоличестваСтавок.КадровыйПлан В (&КадровыеПланы)
		|	И ЗначенияКоличестваСтавок.Показатель = &ПоказательКоличествоСтавок
		|
		|УПОРЯДОЧИТЬ ПО
		|	КадровыйПлан,
		|	ИдентификаторСтроки,
		|	ПериодПоказателя
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗначенияПоказателей.КадровыйПлан,
		|	ЗначенияПоказателей.ПериодПоказателя КАК Период,
		|	ЗначенияПоказателей.Показатель,
		|	ЗначенияПоказателей.ИдентификаторСтроки,
		|	ЗначенияПоказателей.Значение,
		|	ЗначенияПоказателей.Показатель.Категория КАК Категория,
		|	ЗначенияПоказателей.Показатель.КраткоеНаименование КАК КраткоеНаименование
		|ПОМЕСТИТЬ ВТЗначенияПоказателей
		|ИЗ
		|	РегистрСведений.ЗначенияПоказателейКадровыхПланов КАК ЗначенияПоказателей
		|ГДЕ
		|	ЗначенияПоказателей.КадровыйПлан В (&КадровыеПланы)
		|	И НЕ ЗначенияПоказателей.Показатель = &ПоказательКоличествоСтавок
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗначенияПоказателей.КадровыйПлан,
		|	ЗначенияПоказателей.Период,
		|	ЗначенияПоказателей.Показатель,
		|	ЗначенияПоказателей.ИдентификаторСтроки,
		|	ЗначенияПоказателей.Значение
		|ИЗ
		|	ВТЗначенияПоказателей КАК ЗначенияПоказателей
		|
		|УПОРЯДОЧИТЬ ПО
		|	КадровыйПлан,
		|	ИдентификаторСтроки,
		|	Период
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ЗначенияПоказателей.КадровыйПлан,
		|	ЗначенияПоказателей.Показатель,
		|	ЗначенияПоказателей.Категория КАК Категория,
		|	ЗначенияПоказателей.КраткоеНаименование КАК КраткоеНаименование
		|ИЗ
		|	ВТЗначенияПоказателей КАК ЗначенияПоказателей
		|
		|УПОРЯДОЧИТЬ ПО
		|	КадровыйПлан";
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаПозицииКадровогоПлана = РезультатЗапроса[1].Выбрать();
	ВыборкаСтавки = РезультатЗапроса[2].Выбрать();
	ВыборкаПоказатели = РезультатЗапроса[4].Выбрать();
	ВыборкаСоставПоказателей = РезультатЗапроса[5].Выбрать();
	
	РеквизитыТЧ = Метаданные.Документы.КадровыйПлан.ТабличныеЧасти.ПозицииКадровогоПлана.Реквизиты;
	ПозицииКадровогоПланаПустая = Новый ТаблицаЗначений;
	Для Каждого Реквизит Из РеквизитыТЧ Цикл
		ПозицииКадровогоПланаПустая.Колонки.Добавить(Реквизит.Имя, Реквизит.Тип);
	КонецЦикла;
	ОписаниеТиповЧ = ОбщегоНазначения.ОписаниеТипаЧисло(12, 2);
	ОписаниеТиповСП = Новый ОписаниеТипов("СправочникСсылка.СтруктураПредприятия");
	ПозицииКадровогоПланаПустая.Колонки.Добавить("Подразделение", ОписаниеТиповСП);
	ПозицииКадровогоПланаПустая.Колонки.Добавить("НомерСтроки", ОбщегоНазначения.ОписаниеТипаЧисло(15));
	
	СтавкиПустая = ОбщегоНазначенияБЗК.ТаблицаЗначенийПоИмениРегистраСведений("ЗначенияПоказателейКадровыхПланов");
	СтавкиПустая.Колонки.ПериодПоказателя.Имя = "Период";
	
	ПоказателиПустая = СтавкиПустая.Скопировать();
	ПоказателиПустая.Колонки.Добавить("УникальноеИмяПоказателя", ОбщегоНазначения.ОписаниеТипаСтрока(100));
	
	СтавкиПустая.Колонки.Значение.Имя = "КоличествоСтавок";
	СтавкиПустая.Колонки.Добавить("Подразделение", ОписаниеТиповСП);
	СтавкиПустая.Колонки.Добавить("Позиция", Новый ОписаниеТипов("СправочникСсылка.ПозицииКадровогоПлана"));
	СтавкиПустая.Колонки.Добавить("Сотрудник", Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
	СтавкиПустая.Колонки.Добавить("ЗависимаяВакансия", Новый ОписаниеТипов("Булево"));
	
	ВыборкаКадровыхПланов = РезультатЗапроса[0].Выбрать();
	
	Пока ВыборкаКадровыхПланов.Следующий() Цикл
		Описание = ОписаниеДляПечати();
		ЗаполнитьЗначенияСвойств(Описание, ВыборкаКадровыхПланов);
		
		СвойстваПоказателей = КадровоеПланирование.СвойстваПоказателейПоВыборкеРезультатаЗапроса(
			ВыборкаСоставПоказателей, ВыборкаКадровыхПланов.ДокументСсылка);
		УникальныеИменаПоказателей = СвойстваПоказателей.Получить("УникальныеИменаПоказателей");
		МесяцНачала = Месяц(Описание.ПериодПланирования);
		ШагРегулирования = ЗарплатаКадрыРасширенный.КоличествоМесяцевПериодичности(Описание.Периодичность);
		МесяцОкончания = МесяцНачала + ШагРегулирования - 1;
		
		Описание.СвойстваПоказателей = СвойстваПоказателей;
		Описание.МесяцНачала = МесяцНачала;
		Описание.МесяцОкончания = МесяцОкончания;
		
		Если ВыборкаКадровыхПланов.ЕстьПозиции Тогда
			ПозицииКадровогоПлана = ПозицииКадровогоПланаПустая.Скопировать();
			Для Сч = МесяцНачала По МесяцОкончания Цикл
				ПозицииКадровогоПлана.Колонки.Добавить("КоличествоСтавок" + Сч, ОписаниеТиповЧ);
			КонецЦикла;
			Для Каждого ИмяПоказателя Из УникальныеИменаПоказателей Цикл
				Для Сч = МесяцНачала По МесяцОкончания Цикл
					ПозицииКадровогоПлана.Колонки.Добавить(ИмяПоказателя + Сч, ОписаниеТиповЧ);
				КонецЦикла;
			КонецЦикла;
			Пока ВыборкаПозицииКадровогоПлана.НайтиСледующий(ВыборкаКадровыхПланов.ДокументСсылка, "ДокументСсылка") Цикл
				ЗаполнитьЗначенияСвойств(ПозицииКадровогоПлана.Добавить(), ВыборкаПозицииКадровогоПлана);
			КонецЦикла;
			Описание.ПозицииКадровогоПлана = ПозицииКадровогоПлана;
		КонецЕсли;
		Если ВыборкаКадровыхПланов.ЕстьЗначенияКоличестваСтавок Тогда
			Ставки = СтавкиПустая.Скопировать();
			Для Каждого ИмяПоказателя Из УникальныеИменаПоказателей Цикл
				Ставки.Колонки.Добавить(ИмяПоказателя, ОписаниеТиповЧ);
			КонецЦикла;
			Пока ВыборкаСтавки.НайтиСледующий(ВыборкаКадровыхПланов.ДокументСсылка, "КадровыйПлан") Цикл
				ЗаполнитьЗначенияСвойств(Ставки.Добавить(), ВыборкаСтавки);
			КонецЦикла;
			Описание.Ставки = Ставки;
		КонецЕсли;
		Если ВыборкаКадровыхПланов.ЕстьЗначенияПоказателей Тогда
			Показатели = ПоказателиПустая.Скопировать();
			Пока ВыборкаПоказатели.НайтиСледующий(ВыборкаКадровыхПланов.ДокументСсылка, "КадровыйПлан") Цикл
				ЗаполнитьЗначенияСвойств(Показатели.Добавить(), ВыборкаПоказатели);
			КонецЦикла;
			ЗаполнитьУникальныеИменаПоказателей(Показатели);
			Описание.Показатели = Показатели;
		КонецЕсли;
		ЗаполнитьПоказателиВТаблицах(Описание.ПозицииКадровогоПлана, Описание.Ставки, Описание.Показатели,
			СвойстваПоказателей, МесяцНачала, МесяцОкончания);
		ДанныеПечати.Добавить(Описание);
	КонецЦикла;
	
	Возврат ДанныеПечати;
	
КонецФункции

Функция ОписаниеДляПечати()
	
	Описание = Новый Структура;
	Описание.Вставить("ДокументСсылка");
	Описание.Вставить("ПериодПланирования");
	Описание.Вставить("Сценарий");
	Описание.Вставить("Периодичность");
	Описание.Вставить("СвойстваПоказателей");
	Описание.Вставить("МесяцНачала");
	Описание.Вставить("МесяцОкончания");
	Описание.Вставить("ПозицииКадровогоПлана");
	Описание.Вставить("Ставки");
	Описание.Вставить("Показатели");
	
	Возврат Описание;
	
КонецФункции

#КонецОбласти

Процедура ЗаполнитьПоказателиВТаблицах(ПозицииКадровогоПлана, Ставки, Показатели, СвойстваПоказателей, МесяцНачала, МесяцОкончания) Экспорт
	
	Если ТипЗнч(ПозицииКадровогоПлана) = Тип("ДанныеФормыКоллекция") Тогда
		МассивПозиций = ПозицииКадровогоПлана.Выгрузить().ВыгрузитьКолонку("Позиция");
	Иначе
		МассивПозиций = ПозицииКадровогоПлана.ВыгрузитьКолонку("Позиция");
	КонецЕсли;
	ПодразделенияПозиций = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(МассивПозиций, "Подразделение");
	
	УникальныеИменаПоказателей = СвойстваПоказателей.Получить("УникальныеИменаПоказателей");
	КоличествоПоказателей = УникальныеИменаПоказателей.Количество();
	
	СчНачало = 1;
	СчОкончание = СчНачало + МесяцОкончания - МесяцНачала;
	Дельта = МесяцНачала - СчНачало;
	
	Для Каждого СтрокаПозиции Из ПозицииКадровогоПлана Цикл
		СтрокаПозиции.Подразделение = ПодразделенияПозиций.Получить(СтрокаПозиции.Позиция);
		ИндексСтрокиСтавка = СтрокаПозиции.НомерСтроки * СчОкончание - СчОкончание;
		ИндексСтрокиПоказатель = СтрокаПозиции.НомерСтроки * СчОкончание * КоличествоПоказателей - СчОкончание * КоличествоПоказателей;
		Для Сч = СчНачало По СчОкончание Цикл
			Индекс = Сч - 1;
			СтрокаСтавка = Ставки[ИндексСтрокиСтавка + Индекс];
			СтрокаСтавка.Позиция = СтрокаПозиции.Позиция;
			СтрокаСтавка.Подразделение = СтрокаПозиции.Подразделение;
			СтрокаСтавка.Сотрудник = СтрокаПозиции.Сотрудник;
			СтрокаСтавка.ЗависимаяВакансия = СтрокаПозиции.ЗависимаяВакансия;
			СтрокаПозиции["КоличествоСтавок" + (Сч + Дельта)] = СтрокаСтавка.КоличествоСтавок;
			Для ИндексПоказателя = 0 По КоличествоПоказателей - 1 Цикл
				СтрокаПоказатель = Показатели[ИндексПоказателя + ИндексСтрокиПоказатель + КоличествоПоказателей * Индекс];
				СтрокаСтавка[СтрокаПоказатель.УникальноеИмяПоказателя] = СтрокаПоказатель.Значение;
				СтрокаПозиции[СтрокаПоказатель.УникальноеИмяПоказателя + (Сч + Дельта)] = СтрокаПоказатель.Значение;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

// Вывести отчет в табличный документ.
// 
// Параметры:
//  ИмяВарианта - Строка - Имя варианта
//  ПозицииКадровогоПлана - ТаблицаЗначений - Позиции кадрового плана
//  Ставки - ТаблицаЗначений - Ставки
//  СвойстваПоказателей - Соответствие - Свойства показателей
//  МесяцНачала - Дата
//  МесяцОкончания - Дата
// 
// Возвращаемое значение:
//  ТабличныйДокумент - Вывести отчет в табличный документ
Функция ВывестиОтчетВТабличныйДокумент(ИмяВарианта, ПозицииКадровогоПлана, Ставки, СвойстваПоказателей, МесяцНачала, МесяцОкончания) Экспорт
	
	СхемаСКД = ПолучитьМакет("МакетСКДКадровыйПлан");
	КомпоновщикНастроек = КомпоновщикСхемы(СхемаСКД);
	
	ВариантОтчета = СхемаСКД.ВариантыНастроек.Найти(ИмяВарианта);
	НастройкиКомпоновки = ВариантОтчета.Настройки;
	
	УсловноеОформление = НастройкиКомпоновки.УсловноеОформление.Элементы.Добавить();
	УсловноеОформление.Использование = Истина;
	УсловноеОформление.Оформление.УстановитьЗначениеПараметра(Новый ПараметрКомпоновкиДанных("Формат"), "ЧН=");
	
	Для Сч = МесяцНачала По МесяцОкончания Цикл
		ДобавитьКоличествоСтавокВСКД(СхемаСКД, НастройкиКомпоновки, УсловноеОформление, "ПозицииКадровогоПлана", Сч);
	КонецЦикла;
	
	Для Каждого ИмяПоказателя Из СвойстваПоказателей.Получить("УникальныеИменаПоказателей") Цикл
		СвойстваПоказателя = СвойстваПоказателей.Получить(ИмяПоказателя);
		Заголовок = СвойстваПоказателя.КраткоеНаименование;
		Если ИмяВарианта = КадровоеПланированиеКлиентСервер.ВариантыКомпоновки().МесяцыВСтроках Тогда
			ДобавитьПоказательВСКД(СхемаСКД, НастройкиКомпоновки, "Ставки", ИмяПоказателя, Заголовок);
		ИначеЕсли ИмяВарианта = КадровоеПланированиеКлиентСервер.ВариантыКомпоновки().МесяцыВКолонках Тогда
			Для Сч = МесяцНачала По МесяцОкончания Цикл
				ДобавитьПоказательВСКД(СхемаСКД, НастройкиКомпоновки, "ПозицииКадровогоПлана", ИмяПоказателя, Заголовок, Сч);
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	КомпоновщикНастроек.ЗагрузитьНастройки(НастройкиКомпоновки);
	Настройки = КомпоновщикНастроек.ПолучитьНастройки();
	ДанныеРасшифровки = Новый ДанныеРасшифровкиКомпоновкиДанных;
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаСКД, Настройки, ДанныеРасшифровки);
	ВнешнийНаборДанных = Новый Структура;
	ВнешнийНаборДанных.Вставить("ПозицииКадровогоПлана", ПозицииКадровогоПлана);
	ВнешнийНаборДанных.Вставить("Ставки", Ставки);
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки, ВнешнийНаборДанных, ДанныеРасшифровки);
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
		
 	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент;
	ПроцессорВывода.УстановитьДокумент(ТабличныйДокумент);
	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
	
	Возврат ТабличныйДокумент;
	
КонецФункции

Процедура ДобавитьПоказательВСКД(СхемаКомпоновкиДанных, НастройкиКомпоновки, ИмяНабора, ИмяПоказателя, Заголовок, Счетчик = "")
	
	ИмяПоля = ИмяПоказателя + Счетчик;
	
	НаборДанных = СхемаКомпоновкиДанных.НаборыДанных.Найти(ИмяНабора);
	
	ПолеНабораДанныхСхемыКомпоновкиДанных = НаборДанных.Поля.Добавить(Тип("ПолеНабораДанныхСхемыКомпоновкиДанных"));
	ПолеНабораДанныхСхемыКомпоновкиДанных.Поле = ИмяПоля;
	ПолеНабораДанныхСхемыКомпоновкиДанных.ПутьКДанным = ИмяПоля;
	ПолеНабораДанныхСхемыКомпоновкиДанных.Заголовок = Заголовок;
	
	Ресурс = СхемаКомпоновкиДанных.ПоляИтога.Добавить();
	Ресурс.ПутьКДанным = ИмяПоля;
	Ресурс.Выражение = СтрШаблон("Сумма(%1)", ИмяПоля);
	
	Если Счетчик = "" Тогда
		ВыбранноеПолеКомпоновкиДанных = НастройкиКомпоновки.Выбор.Элементы.Добавить(Тип("ВыбранноеПолеКомпоновкиДанных"));
		ВыбранноеПолеКомпоновкиДанных.Использование = Истина;
		ВыбранноеПолеКомпоновкиДанных.Поле = Новый ПолеКомпоновкиДанных(ИмяПоля);
	Иначе
		МесяцСтрокой = КадровоеПланирование.МесяцСтрокой(Счетчик, Истина);
		Для Каждого ВыбранноеПоле Из НастройкиКомпоновки.Выбор.Элементы Цикл
			Если ТипЗнч(ВыбранноеПоле) = Тип("ГруппаВыбранныхПолейКомпоновкиДанных") И ВыбранноеПоле.Заголовок = МесяцСтрокой Тогда
				ВыбранноеПолеКомпоновкиДанных = ВыбранноеПоле.Элементы.Добавить(Тип("ВыбранноеПолеКомпоновкиДанных"));
				ВыбранноеПолеКомпоновкиДанных.Использование = Истина;
				ВыбранноеПолеКомпоновкиДанных.Поле = Новый ПолеКомпоновкиДанных(ИмяПоля);
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьКоличествоСтавокВСКД(СхемаКомпоновкиДанных, НастройкиКомпоновки, УсловноеОформление, ИмяНабора, Счетчик = "")
	
	ИмяПоля = "КоличествоСтавок" + Счетчик;
	
	НаборДанных = СхемаКомпоновкиДанных.НаборыДанных.Найти(ИмяНабора);
	
	ПолеНабораДанныхСхемыКомпоновкиДанных = НаборДанных.Поля.Добавить(Тип("ПолеНабораДанныхСхемыКомпоновкиДанных"));
	ПолеНабораДанныхСхемыКомпоновкиДанных.Поле = ИмяПоля;
	ПолеНабораДанныхСхемыКомпоновкиДанных.ВыражениеПредставления = СтрШаблон("Выразить(%1, ""Число(15,2)"")", ИмяПоля);
	ПолеНабораДанныхСхемыКомпоновкиДанных.ТипЗначения = ОбщегоНазначения.ОписаниеТипаЧисло(15, 2, ДопустимыйЗнак.Неотрицательный);
	ПолеНабораДанныхСхемыКомпоновкиДанных.ПутьКДанным = ИмяПоля;
	ПолеНабораДанныхСхемыКомпоновкиДанных.Заголовок = НСтр("ru = 'Колич. ставок'");
	
	Ресурс = СхемаКомпоновкиДанных.ПоляИтога.Добавить();
	Ресурс.ПутьКДанным = ИмяПоля;
	Ресурс.Выражение = СтрШаблон("Выразить(Сумма(%1), ""Число(15,2)"")", ИмяПоля);
	
	МесяцСтрокой = КадровоеПланирование.МесяцСтрокой(Счетчик, Истина);
	
	Для Каждого ВыбранноеПоле Из НастройкиКомпоновки.Выбор.Элементы Цикл
		Если ТипЗнч(ВыбранноеПоле) = Тип("ГруппаВыбранныхПолейКомпоновкиДанных") И ВыбранноеПоле.Заголовок = МесяцСтрокой Тогда
			ВыбранноеПолеКомпоновкиДанных = ВыбранноеПоле.Элементы.Добавить(Тип("ВыбранноеПолеКомпоновкиДанных"));
			ВыбранноеПолеКомпоновкиДанных.Использование = Истина;
			ВыбранноеПолеКомпоновкиДанных.Поле = Новый ПолеКомпоновкиДанных(ИмяПоля);
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	ВыбранноеПолеКомпоновкиДанных = УсловноеОформление.Поля.Элементы.Добавить();
	ВыбранноеПолеКомпоновкиДанных.Использование = Истина;
	ВыбранноеПолеКомпоновкиДанных.Поле = Новый ПолеКомпоновкиДанных(ИмяПоля);
	
КонецПроцедуры

// Заполнить кадровый план по данным штатной расстановки.
// 
// Параметры:
//  СвойстваПоказателей - Структура - Имена показателей сценария
//  МестоВСтруктуреПредприятия - СправочникСсылка.СтруктураПредприятия - Место в структуре предприятия
//  ПериодПланирования - Дата - Период планирования
//  Периодичность - ПеречислениеСсылка.Периодичность - Периодичность
//  Позиции - Массив - СправочникСсылка.ШтатноеРасписание - Выбранные позиции ШР
//  МаксимальныйИдентификаторСтроки - Число
//  ПериодЗакрытия - Дата - Дата последнего закрытого периода
// 
// Возвращаемое значение:
//  Структура - Заполнить кадровый план по данным штатной расстановки:
// * ПозицииКадровогоПлана - ТаблицаЗначений
// * Ставки - ТаблицаЗначений
// * Показатели - ТаблицаЗначений
Функция ЗаполнитьКадровыйПланПоДаннымШтатнойРасстановки(СвойстваПоказателей, МестоВСтруктуреПредприятия, ПериодПланирования, Периодичность, Позиции, МаксимальныйИдентификаторСтроки, ПериодЗакрытия) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 0
	|	ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка) КАК Подразделение,
	|	*
	|ИЗ
	|	Документ.КадровыйПлан.ПозицииКадровогоПлана
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 0
	|	ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка) КАК Подразделение,
	|	ЗНАЧЕНИЕ(Справочник.ПозицииКадровогоПлана.ПустаяСсылка) КАК Позиция,
	|	ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка) КАК Сотрудник,
	|	ЗначенияКоличестваСтавок.ИдентификаторСтроки,
	|	ЗначенияКоличестваСтавок.ПериодПоказателя КАК Период,
	|	ЗначенияКоличестваСтавок.Значение КАК КоличествоСтавок,
	|	ЗначенияКоличестваСтавок.ЗначениеЗаполнения КАК КоличествоСтавокЗаполнения
	|ИЗ
	|	РегистрСведений.ЗначенияПоказателейКадровыхПланов КАК ЗначенияКоличестваСтавок
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 0
	|	ЗначенияПоказателей.ИдентификаторСтроки,
	|	ЗначенияПоказателей.ПериодПоказателя КАК Период,
	|	ЗначенияПоказателей.Показатель,
	|	ВЫРАЗИТЬ("""" КАК СТРОКА(100)) КАК УникальноеИмяПоказателя,
	|	ЗначенияПоказателей.Значение,
	|	ЗначенияПоказателей.ЗначениеЗаполнения
	|ИЗ
	|	РегистрСведений.ЗначенияПоказателейКадровыхПланов КАК ЗначенияПоказателей";
	
	Результаты = Запрос.ВыполнитьПакет();
	
	ДанныеОбъекта = Новый Структура("ПозицииКадровогоПлана, Ставки, Показатели");
	ДанныеОбъекта.ПозицииКадровогоПлана = Результаты[0].Выгрузить();
	ДанныеОбъекта.Ставки = Результаты[1].Выгрузить();
	ДанныеОбъекта.Показатели = Результаты[2].Выгрузить();
	
	ДанныеОбъекта.ПозицииКадровогоПлана.Колонки.Добавить("ПозицияШтатногоРасписания", Новый ОписаниеТипов("СправочникСсылка.ШтатноеРасписание"));
	ДанныеОбъекта.Ставки.Колонки.Добавить("ПозицияШтатногоРасписания", Новый ОписаниеТипов("СправочникСсылка.ШтатноеРасписание"));
	ДанныеОбъекта.Ставки.Колонки.Добавить("ЗависимаяВакансия", Новый ОписаниеТипов("Булево"));
	
	ОписаниеТиповЧ22 = ОбщегоНазначения.ОписаниеТипаЧисло(22, 20, ДопустимыйЗнак.Неотрицательный);
	ОписаниеТиповЧ12 = ОбщегоНазначения.ОписаниеТипаЧисло(12,2);
	
	МесяцНачала = Месяц(ПериодПланирования);
	ШагРегулирования = ЗарплатаКадрыРасширенный.КоличествоМесяцевПериодичности(Периодичность);
	МесяцОкончания = МесяцНачала + ШагРегулирования - 1;
	
	Для Сч = МесяцНачала По МесяцОкончания Цикл
		ДанныеОбъекта.ПозицииКадровогоПлана.Колонки.Добавить("КоличествоСтавок" + Сч, ОписаниеТиповЧ22);
		ДанныеОбъекта.ПозицииКадровогоПлана.Колонки.Добавить("КоличествоСтавокЗаполнения" + Сч, ОписаниеТиповЧ22);
	КонецЦикла;
	
	ПоказателиЗарплата = Новый Массив;
	ПоказателиСтраховыеВзносы = Новый Массив;
	УникальныеИменаПоказателей = СвойстваПоказателей.Получить("УникальныеИменаПоказателей");
	Для Каждого ИмяПоказателя Из УникальныеИменаПоказателей Цикл
		СвойстваПоказателя = СвойстваПоказателей.Получить(ИмяПоказателя);
		Если СвойстваПоказателя.Категория = Перечисления.КатегорииРасходовНаПерсонал.Зарплата Тогда
			ПоказателиЗарплата.Добавить(СвойстваПоказателя);
		ИначеЕсли СвойстваПоказателя.Категория = Перечисления.КатегорииРасходовНаПерсонал.СтраховыеВзносы Тогда
			ПоказателиСтраховыеВзносы.Добавить(СвойстваПоказателя);
		КонецЕсли;
		ДанныеОбъекта.Ставки.Колонки.Добавить(ИмяПоказателя, ОписаниеТиповЧ12);
		ДанныеОбъекта.Ставки.Колонки.Добавить(ИмяПоказателя + "Заполнения", ОписаниеТиповЧ12);
		Для Сч = МесяцНачала По МесяцОкончания Цикл
			ДанныеОбъекта.ПозицииКадровогоПлана.Колонки.Добавить(ИмяПоказателя + Сч, ОписаниеТиповЧ12);
			ДанныеОбъекта.ПозицииКадровогоПлана.Колонки.Добавить(СтрШаблон("%1Заполнения%2", ИмяПоказателя, Сч), ОписаниеТиповЧ12);
		КонецЦикла;
	КонецЦикла;
	
	ИдентификаторСтроки = МаксимальныйИдентификаторСтроки + 1;
	РезультатЗапроса = ТекущиеДанныеДляЗаполненияПоШтатнойРасстановке(МестоВСтруктуреПредприятия, ПериодПланирования,
		ДобавитьМесяц(ПериодПланирования, ШагРегулирования - 1), Периодичность, Позиции, ПериодЗакрытия);
	ВыборкаПозиция = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаПозиция.Следующий() Цикл
		Если Не ЗначениеЗаполнено(ВыборкаПозиция.Позиция) Тогда
			Продолжить;
		КонецЕсли;
		КоличествоСтавокОстаток = ВыборкаПозиция.КоличествоСтавок;
		ПозицияКадровогоПлана = ?(ЗначениеЗаполнено(ВыборкаПозиция.ПозицияКадровогоПлана),
			ВыборкаПозиция.ПозицияКадровогоПлана, НоваяПозицияКадровогоПлана(ВыборкаПозиция.Позиция));
		Подразделение = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПозицияКадровогоПлана, "Подразделение");
		ВыборкаСотрудникГруппировка = ВыборкаПозиция.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаСотрудникГруппировка.Следующий() Цикл
			ВыборкаСотрудник = ВыборкаСотрудникГруппировка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаСотрудник.Следующий() Цикл
				НоваяСтрока = ДанныеОбъекта.ПозицииКадровогоПлана.Добавить();
				НоваяСтрока.Позиция = ПозицияКадровогоПлана;
				НоваяСтрока.ПозицияШтатногоРасписания = ВыборкаПозиция.Позиция;
				НоваяСтрока.ИдентификаторСтроки = ИдентификаторСтроки;
				НоваяСтрока.Подразделение = Подразделение;
				НоваяСтрока.Сотрудник = ВыборкаСотрудник.Сотрудник;
				НоваяСтрока.ЗависимаяВакансия = ВыборкаСотрудник.Сотрудник <> ВыборкаСотрудник.СотрудникГруппировка;
				ВыборкаПериод = ВыборкаСотрудник.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				КоличествоСтавок = 0;
				Пока ВыборкаПериод.Следующий() Цикл
					ЗаполнитьПоказателиПозиции(ВыборкаПериод, НоваяСтрока, ДанныеОбъекта, ПоказателиЗарплата, ПоказателиСтраховыеВзносы);
					КоличествоСтавок = Макс(ВыборкаПериод.КоличествоСтавокСотрудника, КоличествоСтавок);
				КонецЦикла;
				ИдентификаторСтроки = ИдентификаторСтроки + 1;
			КонецЦикла;
			КоличествоСтавокОстаток = КоличествоСтавокОстаток - КоличествоСтавок;
		КонецЦикла;
		
		КоличествоИтераций = ЗарплатаКадрыКлиентСервер.Округлить(
			КоличествоСтавокОстаток, 1, Перечисления.ПравилаОкругленияПриРасчетеЗарплаты.ВБольшуюСторону);
		Если КоличествоСтавокОстаток > 0 Тогда
			СтруктураОтбора = Новый Структура("ИдентификаторСтроки", ИдентификаторСтроки - 1);
			НайденныеСтрокиПозиции = ДанныеОбъекта.ПозицииКадровогоПлана.НайтиСтроки(СтруктураОтбора);
			НайденныеСтрокиСтавки = ДанныеОбъекта.Ставки.НайтиСтроки(СтруктураОтбора);
			НайденныеСтрокиПоказатели = ДанныеОбъекта.Показатели.НайтиСтроки(СтруктураОтбора);
			Для Сч = 1 По КоличествоИтераций Цикл
				Если КоличествоСтавокОстаток < 1 Тогда
					КоличествоСтавок = КоличествоСтавокОстаток;
				Иначе
					КоличествоСтавок = 1;
				КонецЕсли;
				НоваяСтрокаПозиция = ДанныеОбъекта.ПозицииКадровогоПлана.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрокаПозиция, НайденныеСтрокиПозиции[0], , "Сотрудник");
				НоваяСтрокаПозиция.ИдентификаторСтроки = ИдентификаторСтроки;
				Для СчКоличество = МесяцНачала По МесяцОкончания Цикл
					НоваяСтрокаПозиция["КоличествоСтавок" + СчКоличество] = КоличествоСтавок;
					Для Каждого ИмяПоказателя Из УникальныеИменаПоказателей Цикл 
						НоваяСтрокаПозиция[ИмяПоказателя + СчКоличество] = КоличествоСтавок * НоваяСтрокаПозиция[СтрШаблон("%1Заполнения%2", ИмяПоказателя, СчКоличество)];
					КонецЦикла;
				КонецЦикла;
				Для Каждого СтрокаСтавка Из НайденныеСтрокиСтавки Цикл
					НоваяСтрокаСтавка = ДанныеОбъекта.Ставки.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрокаСтавка, СтрокаСтавка, , "Сотрудник");
					НоваяСтрокаСтавка.ИдентификаторСтроки = ИдентификаторСтроки;
					НоваяСтрокаСтавка.КоличествоСтавок = КоличествоСтавок;
					Для Каждого ИмяПоказателя Из УникальныеИменаПоказателей Цикл
						НоваяСтрокаСтавка[ИмяПоказателя] = КоличествоСтавок * НоваяСтрокаСтавка[СтрШаблон("%1Заполнения", ИмяПоказателя)];
					КонецЦикла;
				КонецЦикла;
				Для Каждого СтрокаПоказатель Из НайденныеСтрокиПоказатели Цикл
					НоваяСтрокаПоказатель = ДанныеОбъекта.Показатели.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрокаПоказатель, СтрокаПоказатель);
					НоваяСтрокаПоказатель.ИдентификаторСтроки = ИдентификаторСтроки;
					Если НоваяСтрокаПоказатель.Значение = 0 Тогда
						Продолжить;
					КонецЕсли;
					НоваяСтрокаПоказатель.Значение = КоличествоСтавок * НоваяСтрокаПоказатель.ЗначениеЗаполнения;
				КонецЦикла;
				ИдентификаторСтроки = ИдентификаторСтроки + 1;
				КоличествоСтавокОстаток = КоличествоСтавокОстаток - КоличествоСтавок;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ДанныеОбъекта;
	
КонецФункции

Процедура ЗаполнитьПоказателиПозиции(ВыборкаПериод, НоваяСтрока, ДанныеОбъекта, Знач ПоказателиЗарплата, Знач ПоказателиСтраховыеВзносы)
	
	НоваяСтрокаСтавка = ДанныеОбъекта.Ставки.Добавить();
	НоваяСтрокаСтавка.Период = ВыборкаПериод.Период;
	НоваяСтрокаСтавка.ИдентификаторСтроки = НоваяСтрока.ИдентификаторСтроки;
	НоваяСтрокаСтавка.КоличествоСтавок = ВыборкаПериод.КоличествоСтавокСотрудника;
	НоваяСтрокаСтавка.КоличествоСтавокЗаполнения = ?(НоваяСтрокаСтавка.КоличествоСтавок = 0, 1, НоваяСтрокаСтавка.КоличествоСтавок);
	НоваяСтрокаСтавка.Сотрудник = НоваяСтрока.Сотрудник;
	НоваяСтрокаСтавка.ЗависимаяВакансия = НоваяСтрока.ЗависимаяВакансия;
	НоваяСтрокаСтавка.Позиция = НоваяСтрока.Позиция;
	НоваяСтрокаСтавка.ПозицияШтатногоРасписания = НоваяСтрока.ПозицияШтатногоРасписания;
	НоваяСтрокаСтавка.Подразделение = НоваяСтрока.Подразделение;
	НомерМесяца = Месяц(ВыборкаПериод.Период);
	НоваяСтрока["КоличествоСтавок" + НомерМесяца] = НоваяСтрокаСтавка.КоличествоСтавок;
	НоваяСтрока["КоличествоСтавокЗаполнения" + НомерМесяца] = НоваяСтрокаСтавка.КоличествоСтавокЗаполнения;
	
	НоваяСтрокаВзносов = НоваяСтрокаВзносов();
	Для Каждого СвойстваПоказателя Из ПоказателиЗарплата Цикл
		НоваяСтрокаПоказатель = ДанныеОбъекта.Показатели.Добавить();
		НоваяСтрокаПоказатель.Период = ВыборкаПериод.Период;
		НоваяСтрокаПоказатель.ИдентификаторСтроки = НоваяСтрока.ИдентификаторСтроки;
		НоваяСтрокаПоказатель.УникальноеИмяПоказателя = СвойстваПоказателя.УникальноеИмяПоказателя;
		НоваяСтрокаПоказатель.Показатель = СвойстваПоказателя.Показатель;
		ЗначениеПоказателя = 0;
		Для Каждого СтрокаНачисление Из СвойстваПоказателя.Показатель.Начисления Цикл
			Выборка = ВыборкаПериод.Выбрать();
			Пока Выборка.СледующийПоЗначениюПоля("Начисление") Цикл
				Если Выборка.Начисление = СтрокаНачисление.Начисление Тогда
					ЗначениеПоказателя = ЗначениеПоказателя + Выборка.Размер;
					Для Каждого КлючИЗначение Из НоваяСтрокаВзносов Цикл
						НоваяСтрокаВзносов[КлючИЗначение.Ключ] = КлючИЗначение.Значение + Выборка[КлючИЗначение.Ключ];
					КонецЦикла;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		НоваяСтрокаПоказатель.Значение = ЗначениеПоказателя * НоваяСтрокаСтавка.КоличествоСтавок;
		НоваяСтрокаПоказатель.ЗначениеЗаполнения = ЗначениеПоказателя;
		
		НоваяСтрокаСтавка[СвойстваПоказателя.УникальноеИмяПоказателя] = НоваяСтрокаПоказатель.Значение;
		НоваяСтрока[СвойстваПоказателя.УникальноеИмяПоказателя + НомерМесяца] = НоваяСтрокаПоказатель.Значение;
		НоваяСтрокаСтавка[СвойстваПоказателя.УникальноеИмяПоказателя + "Заполнения"] = НоваяСтрокаПоказатель.ЗначениеЗаполнения;
		НоваяСтрока[СтрШаблон("%1Заполнения%2", СвойстваПоказателя.УникальноеИмяПоказателя, НомерМесяца)] = НоваяСтрокаПоказатель.ЗначениеЗаполнения;
	КонецЦикла;
	Для Каждого СвойстваПоказателя Из ПоказателиСтраховыеВзносы Цикл
		НоваяСтрокаПоказатель = ДанныеОбъекта.Показатели.Добавить();
		НоваяСтрокаПоказатель.Период = ВыборкаПериод.Период;
		НоваяСтрокаПоказатель.ИдентификаторСтроки = НоваяСтрока.ИдентификаторСтроки;
		НоваяСтрокаПоказатель.УникальноеИмяПоказателя = СвойстваПоказателя.УникальноеИмяПоказателя;
		НоваяСтрокаПоказатель.Показатель = СвойстваПоказателя.Показатель;
		ЗначениеПоказателя = 0;
		Для Каждого СтрокаВзносы Из СвойстваПоказателя.Показатель.СтраховыеВзносы Цикл
			ЗначениеПоказателя = ЗначениеПоказателя + НоваяСтрокаВзносов[ОбщегоНазначения.ИмяЗначенияПеречисления(СтрокаВзносы.ВидВзносов)];
		КонецЦикла;
		НоваяСтрокаПоказатель.Значение = ЗначениеПоказателя * НоваяСтрокаСтавка.КоличествоСтавок;
		НоваяСтрокаПоказатель.ЗначениеЗаполнения = ЗначениеПоказателя;
		
		НоваяСтрокаСтавка[СвойстваПоказателя.УникальноеИмяПоказателя] = НоваяСтрокаПоказатель.Значение;
		НоваяСтрока[СвойстваПоказателя.УникальноеИмяПоказателя + НомерМесяца] = НоваяСтрокаПоказатель.Значение;
		НоваяСтрокаСтавка[СвойстваПоказателя.УникальноеИмяПоказателя + "Заполнения"] = НоваяСтрокаПоказатель.ЗначениеЗаполнения;
		НоваяСтрока[СтрШаблон("%1Заполнения%2", СвойстваПоказателя.УникальноеИмяПоказателя, НомерМесяца)] = НоваяСтрокаПоказатель.ЗначениеЗаполнения;
	КонецЦикла;
	
КонецПроцедуры

Функция НоваяСтрокаВзносов()
	
	НоваяСтрокаВзносов = Новый Структура();
	Для Каждого ВидОперации Из КадровоеПланирование.ВидыОперацийПоЗарплатеВзносы() Цикл
		НоваяСтрокаВзносов.Вставить(ОбщегоНазначения.ИмяЗначенияПеречисления(ВидОперации), 0);
	КонецЦикла;
	
	Возврат НоваяСтрокаВзносов;
	
КонецФункции

Функция ТекущиеДанныеДляЗаполненияПоШтатнойРасстановке(МестоВСтруктуреПредприятия, НачалоПериода, ОкончаниеПериода, Периодичность, МассивПозиций, ПериодЗакрытия)
	
	УдалитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Если МассивПозиций.Количество() > 0 Тогда
		Запрос.УстановитьПараметр("Позиции", МассивПозиций); 
		Запрос.Текст = 
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ШтатноеРасписание.Ссылка КАК Позиция
			|ПОМЕСТИТЬ ВТПозиции
			|ИЗ
			|	Справочник.ШтатноеРасписание КАК ШтатноеРасписание
			|ГДЕ
			|	ШтатноеРасписание.Ссылка В(&Позиции)
			|	И ШтатноеРасписание.Утверждена
			|	И НЕ ШтатноеРасписание.Закрыта";
		Запрос.Выполнить();
		ОрганизационнаяСтруктура.СоздатьВТМестаПозицийВСтруктуреПредприятияПоВременнойТаблице(Запрос.МенеджерВременныхТаблиц);
		ИмяТаблицыПозицииПодразделений = "ВТМестаПозицийВСтруктуреПредприятия";
	Иначе
		Запрос.Текст = 
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	СтруктураПредприятия.Ссылка КАК Подразделение
			|ПОМЕСТИТЬ ВТСтруктураПредприятияОтбор
			|ИЗ
			|	Справочник.СтруктураПредприятия КАК СтруктураПредприятия";
		Если ЗначениеЗаполнено(МестоВСтруктуреПредприятия) Тогда
			Запрос.Текст = Запрос.Текст +
				"
				|ГДЕ
				|	СтруктураПредприятия.Ссылка В ИЕРАРХИИ(&МестоВСтруктуреПредприятия)";
			Запрос.УстановитьПараметр("МестоВСтруктуреПредприятия", МестоВСтруктуреПредприятия);
		КонецЕсли;
		
		Запрос.Выполнить();
		УдалитьВТ.Добавить("ВТСтруктураПредприятияОтбор");
		
		ОрганизационнаяСтруктура.СоздатьВТПозицииПодразделений(Запрос.МенеджерВременныхТаблиц, "ВТСтруктураПредприятияОтбор");
		Запрос.Текст = 
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ВТПозиции.Позиция КАК Позиция,
			|	ВТПозиции.Подразделение КАК Подразделение
			|ПОМЕСТИТЬ ВТПодразделенияОтбор
			|ИЗ
			|	ВТПозицииПодразделений КАК ВТПозиции
			|ГДЕ
			|	ВТПозиции.Позиция.Утверждена
			|	И НЕ ВТПозиции.Позиция.Закрыта
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ВТПодразделенияОтбор.Позиция КАК Позиция
			|ИЗ
			|	ВТПодразделенияОтбор КАК ВТПодразделенияОтбор";
		МассивПозиций = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Позиция");
		ИмяТаблицыПозицииПодразделений = "ВТПодразделенияОтбор";
	КонецЕсли;	
	УдалитьВТ.Добавить(ИмяТаблицыПозицииПодразделений);
	
	УстановитьПривилегированныйРежим(Истина);
	// Получаем сотрудников, работавших в периоде на этих местах
	КадровоеПланирование.СоздатьВТПериодыРаботыСотрудников(
		Запрос.МенеджерВременныхТаблиц, ИмяТаблицыПозицииПодразделений, НачалоПериода, КонецМесяца(ОкончаниеПериода));
	УдалитьВТ.Добавить("ВТПериодыРаботыСотрудников");
	
	ЗарплатаКадрыОбщиеНаборыДанных.СоздатьВТПериоды(Запрос.МенеджерВременныхТаблиц, КонецГода(НачалоПериода),
		КонецГода(ОкончаниеПериода), "ГОД", , "ВТПериодыРасширенныхСведенийОДоходах", Истина);
	УчетСтраховыхВзносов.СформироватьВТОписаниеТарифов(НачалоПериода, ОкончаниеПериода, Запрос.МенеджерВременныхТаблиц);
	
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СтраховыеВзносыПоФизическимЛицам.Сотрудник КАК Сотрудник,
		|	СтраховыеВзносыПоФизическимЛицам.Начисление КАК Начисление,
		|	НАЧАЛОПЕРИОДА(СтраховыеВзносыПоФизическимЛицам.Период, МЕСЯЦ) КАК Период,
		|	СтраховыеВзносыПоФизическимЛицам.Подразделение КАК Подразделение,
		|	СтраховыеВзносыПоФизическимЛицам.Организация КАК Организация,
