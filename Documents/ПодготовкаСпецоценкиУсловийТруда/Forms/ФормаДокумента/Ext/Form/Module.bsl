&НаКлиенте
Процедура Подбор(Команда)
	
	Отказ = Ложь;
	
	Если Не ЗначениеЗаполнено(Объект.ДатаНачала) Тогда
		ТекстСообщения = НСтр("ru = 'Не указана дата начала.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, , "Объект.ДатаНачала", , Отказ);
	КонецЕсли;
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	КадровыйУчетКлиент.ВыбратьСотрудниковРаботающихВПериодеПоПараметрамОткрытияФормыСписка(
		Элементы.РабочиеМеста,
		Объект.Организация,
		Объект.Подразделение,
		Объект.ДатаНачала,
		Объект.ДатаОкончания,
		,
		АдресСпискаПодобранныхСотрудников());
	
КонецПроцедуры

&НаКлиенте
Процедура ВыделитьАналогичныеРабочиеМеста(Команда)
	
	ОсновноеРабочееМесто = Неопределено;
	
	ВыделенныеСтроки = Элементы.РабочиеМеста.ВыделенныеСтроки;
	КоличествоСтрок = ВыделенныеСтроки.Количество();
	
	Если КоличествоСтрок = 0 Тогда
		Возврат;
	КонецЕсли;
	
	МассивАналогичныеМеста = Новый Массив;
	Если КоличествоСтрок = 1 Тогда
		СтрокаТаблицы = Объект.РабочиеМеста.НайтиПоИдентификатору(ВыделенныеСтроки[0]);
		ОткрытьФормуАналогичныхРабочихМестПоСтроке(СтрокаТаблицы);
		Возврат;
	Иначе
		СоответствиеПодразделений = Новый Соответствие;
		СоответствиеДолжностей = Новый Соответствие;
		
		Для Каждого ВыделеннаяСтрока Из ВыделенныеСтроки Цикл
			СтрокаТаблицы = Объект.РабочиеМеста.НайтиПоИдентификатору(ВыделеннаяСтрока);
			Если СтрокаТаблицы <> Неопределено Тогда 
				Если Не ЗначениеЗаполнено(СтрокаТаблицы.РабочееМесто) Тогда
					Продолжить;
				КонецЕсли;
				МассивАналогичныеМеста.Добавить(СтрокаТаблицы.РабочееМесто);
				Для Каждого РабочееМесто Из СтрокаТаблицы.МассивАналогичныхРабочихМест Цикл
					Если ОсновноеРабочееМесто = Неопределено Тогда
						ОсновноеРабочееМесто = СтрокаТаблицы.РабочееМесто;
					КонецЕсли;
					МассивАналогичныеМеста.Добавить(РабочееМесто);
				КонецЦикла;
				СоответствиеПодразделений.Вставить(СтрокаТаблицы.Подразделение,"");
				СоответствиеДолжностей.Вставить(СтрокаТаблицы.Должность,"");
			КонецЕсли;
		КонецЦикла;
		Если СоответствиеПодразделений.Количество() > 1 Тогда
			ВызватьИсключение НСтр("ru = 'Не удалось выделить аналогичные рабочие места: выберите строки с одинаковыми подразделениями.'");
		ИначеЕсли СоответствиеДолжностей.Количество() > 1 Тогда
			ВызватьИсключение НСтр("ru = 'Не удалось выделить аналогичные рабочие места: выберите строки с одинаковыми должностями.'");
		КонецЕсли;
	КонецЕсли;
	
	МассивРабочиеМеста = Новый Массив;
	ПараметрыОтбора = Новый Структура("Должность, Подразделение", СтрокаТаблицы.Должность, СтрокаТаблицы.Подразделение);
	Для Каждого СтрокаРабочиеМеста Из Объект.РабочиеМеста.НайтиСтроки(ПараметрыОтбора) Цикл
		Если Не ЗначениеЗаполнено(СтрокаРабочиеМеста.РабочееМесто) Тогда
			Продолжить;
		КонецЕсли;
		МассивРабочиеМеста.Добавить(Новый Структура("РабочееМесто", СтрокаРабочиеМеста.РабочееМесто));
	КонецЦикла;
	
	ПараметрыОткрытия = Новый Структура;
	Если МассивАналогичныеМеста.Количество() > 0 Тогда
		ПараметрыОткрытия.Вставить("ОсновноеРабочееМесто", ?(ОсновноеРабочееМесто = Неопределено, МассивАналогичныеМеста[0], ОсновноеРабочееМесто));
	КонецЕсли;
	ПараметрыОткрытия.Вставить("АналогичныеМеста", ОбщегоНазначенияКлиентСервер.СвернутьМассив(МассивАналогичныеМеста));
	ПараметрыОткрытия.Вставить("РабочиеМеста", МассивРабочиеМеста);
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("ВыделитьАналогичныеРабочиеМестаПослеЗакрытия", ЭтотОбъект);
	ОткрытьФорму("Документ.ПодготовкаСпецоценкиУсловийТруда.Форма.ФормаАналогичныхМест",
		ПараметрыОткрытия, ЭтотОбъект, , , , ОповещениеОЗакрытии, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ВыделитьАналогичныеРабочиеМестаПослеЗакрытия(РезультатЗакрытия, ДополнительныеПараметры) Экспорт 
	
	Если ТипЗнч(РезультатЗакрытия) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	ВыделитьАналогичныеРабочиеМестаПослеЗакрытияНаСервере(РезультатЗакрытия, ДополнительныеПараметры);
	
КонецПроцедуры

&НаСервере
Процедура ВыделитьАналогичныеРабочиеМестаПослеЗакрытияНаСервере(РезультатЗакрытия, ДополнительныеПараметры)
	
	ОсновноеРабочееМесто = РезультатЗакрытия.ОсновноеРабочееМесто;
	ПрежнееРабочееМесто = РезультатЗакрытия.ПрежнееРабочееМесто;
	ЕстьАналогичныеМеста = РезультатЗакрытия.АналогичныеМеста.Количество() > 0;
	
	Если ПрежнееРабочееМесто <> ОсновноеРабочееМесто И ЕстьАналогичныеМеста Тогда
		// Очистим аналогичные рабочие места у прежнего основного рабочего места
		НайденныеСтроки = Объект.РабочиеМеста.НайтиСтроки(Новый Структура("РабочееМесто", ПрежнееРабочееМесто));
		Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
			Объект.РабочиеМеста.Удалить(НайденнаяСтрока);
		КонецЦикла;
	КонецЕсли;
	
	НайденныеСтрокиОсновногоМеста = Объект.РабочиеМеста.НайтиСтроки(Новый Структура("РабочееМесто", ОсновноеРабочееМесто));
	Если НайденныеСтрокиОсновногоМеста.Количество() = 0 Тогда
		// Заменим предыдущее основное рабочее место текущим
		НайденныеСтрокиОсновногоМеста = Объект.РабочиеМеста.НайтиСтроки(Новый Структура("РабочееМесто", ПрежнееРабочееМесто));
	КонецЕсли;
	
	Если ЕстьАналогичныеМеста Тогда
		Если НайденныеСтрокиОсновногоМеста.Количество() = 0 Тогда
			ОсновнаяСтрока = Объект.РабочиеМеста.Добавить();
			ОсновнаяСтрока.РабочееМесто = ОсновноеРабочееМесто;
			МаксимальныйИдентификаторСтрокиРабочегоМеста = МаксимальныйИдентификаторСтрокиРабочегоМеста + 1;
			ОсновнаяСтрока.ИдентификаторСтрокиРабочегоМеста = МаксимальныйИдентификаторСтрокиРабочегоМеста;
			ОсновнаяСтрока.МассивАналогичныхРабочихМест = Новый ФиксированныйМассив(Новый Массив());
			РабочиеМестаРабочееМестоПриИзмененииНаСервере(Неопределено, ОсновнаяСтрока);
		Иначе
			Для Каждого ОсновнаяСтрока Из НайденныеСтрокиОсновногоМеста Цикл
				ОсновнаяСтрока.РабочееМесто = ОсновноеРабочееМесто;
				РабочиеМестаРабочееМестоПриИзмененииНаСервере(Неопределено, ОсновнаяСтрока, Истина);
			КонецЦикла;
		КонецЕсли;
		
		МассивАналогичныхРабочихМестПриемник = Новый Массив(ОсновнаяСтрока.МассивАналогичныхРабочихМест);
		
		Для Каждого АналогичноеРабочееМесто Из РезультатЗакрытия.АналогичныеМеста Цикл
			// Если аналогичное место было основным, то его нужно заменить на основное рабочее место.
			НайденныеСтроки = Объект.РабочиеМеста.НайтиСтроки(Новый Структура("РабочееМесто", АналогичноеРабочееМесто));
			Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
				Для Каждого ДанныеСотрудника Из НайденнаяСтрока.МассивСотрудников Цикл
					ДополнитьМассивСотрудников(ОсновнаяСтрока, ДанныеСотрудника);
				КонецЦикла;
				Объект.РабочиеМеста.Удалить(НайденнаяСтрока);
			КонецЦикла;
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(
				МассивАналогичныхРабочихМестПриемник,
				ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(АналогичноеРабочееМесто),
				Истина);
		КонецЦикла;
		
		ОсновнаяСтрока.МассивАналогичныхРабочихМест = Новый ФиксированныйМассив(МассивАналогичныхРабочихМестПриемник);
		ЗаполнитьКраткийСоставАналогичныхМест(ОсновнаяСтрока);
		ЗаполнитьКраткийСоставСотрудников(ОсновнаяСтрока);
	Иначе
		Для Каждого НайденнаяСтрока Из НайденныеСтрокиОсновногоМеста Цикл
			НайденнаяСтрока.МассивАналогичныхРабочихМест = Новый ФиксированныйМассив(Новый Массив());
			РабочиеМестаРабочееМестоПриИзмененииНаСервере(Неопределено, НайденнаяСтрока);
		КонецЦикла;
	КонецЕсли;
	
	Для каждого РабочееМесто Из РезультатЗакрытия.РабочиеМеста Цикл
		// Если нет рабочего места, значит оно было удалено из аналогичных рабочих мест
		// Такое рабочее место нужно вернуть в список рабочих мест.
		НайденныеСтроки = Объект.РабочиеМеста.НайтиСтроки(Новый Структура("РабочееМесто", РабочееМесто));
		Если НайденныеСтроки.Количество() = 0 Тогда
			
			НоваяСтрока = Объект.РабочиеМеста.Добавить();
			МаксимальныйИдентификаторСтрокиРабочегоМеста = МаксимальныйИдентификаторСтрокиРабочегоМеста + 1;
			НоваяСтрока.ИдентификаторСтрокиРабочегоМеста = МаксимальныйИдентификаторСтрокиРабочегоМеста;
			НоваяСтрока.МассивАналогичныхРабочихМест = Новый ФиксированныйМассив(Новый Массив());
			НоваяСтрока.РабочееМесто = РабочееМесто;
			РабочиеМестаРабочееМестоПриИзмененииНаСервере(Неопределено, НоваяСтрока);
			
		КонецЕсли;
	КонецЦикла;
	
	Модифицированность = Истина;
	
КонецПроцедуры

// ИнтеграцияС1СДокументооборотом
