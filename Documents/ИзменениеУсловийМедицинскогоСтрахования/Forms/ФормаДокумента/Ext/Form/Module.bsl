&НаСервере
Процедура СотрудникиЗаполнитьНаСервере(МассивСотрудников = Неопределено, МассивЗастрахованных = Неопределено)
	
	СтруктураИменТаблиц = МедицинскоеСтрахованиеФормы.СтруктураИменТаблиц();
	СтруктураИменТаблиц.ИмяТаблицыСотрудники = "Сотрудники";
	СтруктураИменТаблиц.ИмяТаблицыПрограммыСтрахованияСотрудников = "ПрограммыСтрахованияСотрудников";
	СтруктураИменТаблиц.ИмяТаблицыРасширенийПрограммСтрахованияСотрудников = "РасширенияПрограммСтрахованияСотрудников";
	СтруктураИменТаблиц.ИмяТаблицыРодственники = "Родственники";
	СтруктураИменТаблиц.ИмяТаблицыПрограммыСтрахованияРодственников = "ПрограммыСтрахованияРодственников";
	СтруктураИменТаблиц.ИмяТаблицыРасширенийПрограммСтрахованияРодственников = "РасширенияПрограммСтрахованияРодственников";
	
	// Очистим данные
	МассивФизическихЛиц = Новый Массив;
	ЗаполняемыеТаблицыСотрудников = Новый Массив;
	ЕстьОтборПоСотрудникам = Ложь;
	Если СтруктураИменТаблиц.ИмяТаблицыСотрудники <> Неопределено Тогда
		ЗаполняемыеТаблицыСотрудников.Добавить(Объект[СтруктураИменТаблиц.ИмяТаблицыСотрудники]);
	КонецЕсли;
	Если СтруктураИменТаблиц.ИмяТаблицыПрограммыСтрахованияСотрудников <> Неопределено Тогда
		ЗаполняемыеТаблицыСотрудников.Добавить(Объект[СтруктураИменТаблиц.ИмяТаблицыПрограммыСтрахованияСотрудников]);
	КонецЕсли;
	Если СтруктураИменТаблиц.ИмяТаблицыРасширенийПрограммСтрахованияСотрудников <> Неопределено Тогда
		ЗаполняемыеТаблицыСотрудников.Добавить(Объект[СтруктураИменТаблиц.ИмяТаблицыРасширенийПрограммСтрахованияСотрудников]);
	КонецЕсли;
	
	ЗаполняемыеТаблицыФизическихЛиц = Новый Массив;
	Если СтруктураИменТаблиц.ИмяТаблицыРодственники <> Неопределено Тогда
		ЗаполняемыеТаблицыФизическихЛиц.Добавить(Объект[СтруктураИменТаблиц.ИмяТаблицыРодственники]);
	КонецЕсли;
	Если СтруктураИменТаблиц.ИмяТаблицыПрограммыСтрахованияРодственников <> Неопределено Тогда
		ЗаполняемыеТаблицыФизическихЛиц.Добавить(Объект[СтруктураИменТаблиц.ИмяТаблицыПрограммыСтрахованияРодственников]);
	КонецЕсли;
	Если СтруктураИменТаблиц.ИмяТаблицыРасширенийПрограммСтрахованияРодственников <> Неопределено Тогда
		ЗаполняемыеТаблицыФизическихЛиц.Добавить(Объект[СтруктураИменТаблиц.ИмяТаблицыРасширенийПрограммСтрахованияРодственников]);
	КонецЕсли;
	
	Если МассивСотрудников = Неопределено Тогда
		Для Каждого ЗаполняемаяТаблица Из ЗаполняемыеТаблицыСотрудников Цикл
			ЗаполняемаяТаблица.Очистить();
		КонецЦикла;
		Для Каждого ЗаполняемаяТаблица Из ЗаполняемыеТаблицыФизическихЛиц Цикл
			ЗаполняемаяТаблица.Очистить();
		КонецЦикла;
	Иначе
		Для Каждого СотрудникМассива Из МассивСотрудников Цикл
			
			СтруктураОтбора = Новый Структура("Сотрудник", СотрудникМассива);
			Для Каждого ЗаполняемаяТаблица Из ЗаполняемыеТаблицыСотрудников Цикл
				НайденныеСтроки = ЗаполняемаяТаблица.НайтиСтроки(СтруктураОтбора);
				Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
					ЗаполняемаяТаблица.Удалить(НайденнаяСтрока);
				КонецЦикла;
			КонецЦикла;
			
			ФизическоеЛицо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СотрудникМассива, "ФизическоеЛицо");
			СтруктураОтбора = Новый Структура("ФизическоеЛицо", ФизическоеЛицо);
			Для Каждого ЗаполняемаяТаблица Из ЗаполняемыеТаблицыФизическихЛиц Цикл
				НайденныеСтроки = ЗаполняемаяТаблица.НайтиСтроки(СтруктураОтбора);
				Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
					ЗаполняемаяТаблица.Удалить(НайденнаяСтрока);
				КонецЦикла;
			КонецЦикла;
			МассивФизическихЛиц.Добавить(ФизическоеЛицо);
			ЕстьОтборПоСотрудникам = Истина;
		КонецЦикла;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Объект.Организация) Или Не ЗначениеЗаполнено(Объект.СтраховаяКомпания) Или Не ЗначениеЗаполнено(Объект.ДатаИзменения) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаИзменения", Объект.ДатаИзменения);
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("СтраховаяКомпания", Объект.СтраховаяКомпания);
	Запрос.УстановитьПараметр("ЕстьОтборПоСотрудникам", ЕстьОтборПоСотрудникам);
	Запрос.УстановитьПараметр("МассивФизическихЛиц", МассивФизическихЛиц);
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПрограммыМедицинскогоСтрахованияСотрудниковСрезПоследних.Регистратор КАК Регистратор
		|ИЗ
		|	РегистрСведений.ПрограммыМедицинскогоСтрахованияСотрудников.СрезПоследних(
		|			&ДатаИзменения,
		|			Организация = &Организация
		|				И ПрограммаСтрахования.СтраховаяКомпания = &СтраховаяКомпания
		|				И Действует = ИСТИНА) КАК ПрограммыМедицинскогоСтрахованияСотрудниковСрезПоследних
		|ГДЕ
		|	ВЫБОР
		|			КОГДА &ЕстьОтборПоСотрудникам
		|				ТОГДА ПрограммыМедицинскогоСтрахованияСотрудниковСрезПоследних.ФизическоеЛицо В (&МассивФизическихЛиц)
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ";
	МассивПрикреплений = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Регистратор");
	Если МассивПрикреплений.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Прикрепление Из МассивПрикреплений Цикл
		СотрудникиТаблица= СотрудникиПрикрепления(Прикрепление, ЕстьОтборПоСотрудникам, МассивСотрудников);
		Для Каждого СтрокаСотрудники Из СотрудникиТаблица Цикл
			НоваяСтрока = Объект.Сотрудники.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаСотрудники);
		КонецЦикла;
		ПрограммыСотрудниковТаблица = ПрограммыСтрахованияСотрудников(Прикрепление, ЕстьОтборПоСотрудникам, МассивСотрудников);
		Для Каждого СтрокаПрограммыСотрудника Из ПрограммыСотрудниковТаблица Цикл
			НоваяСтрока = Объект.ПрограммыСтрахованияСотрудников.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаПрограммыСотрудника);
		КонецЦикла;
		РасширенияСотрудниковТаблица = РасширенияПрограммСтрахованияСотрудников(Прикрепление, ЕстьОтборПоСотрудникам, МассивСотрудников);
		Для Каждого СтрокаРасширениеСотрудника Из РасширенияСотрудниковТаблица Цикл
			НоваяСтрока = Объект.РасширенияПрограммСтрахованияСотрудников.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаРасширениеСотрудника);
		КонецЦикла;
		ГрафикУдержанийТаблица = ГрафикУдержаний(Прикрепление, ЕстьОтборПоСотрудникам, МассивФизическихЛиц);
		Для Каждого СтрокаГрафика Из ГрафикУдержанийТаблица Цикл
			НоваяСтрока = Объект.ГрафикУдержаний.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаГрафика);
		КонецЦикла;
		РодственникиТаблица = РодственникиПрикрепления(Прикрепление, ЕстьОтборПоСотрудникам, МассивФизическихЛиц);
		Для Каждого СтрокаРодственника Из РодственникиТаблица Цикл
			НоваяСтрока = Объект.Родственники.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаРодственника);
		КонецЦикла;
		ПрограммыРодственниковТаблица = ПрограммыСтрахованияРодственников(Прикрепление, ЕстьОтборПоСотрудникам, МассивФизическихЛиц);
		Для Каждого СтрокаПрограммыРодственника Из ПрограммыРодственниковТаблица Цикл
			НоваяСтрока = Объект.ПрограммыСтрахованияРодственников.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаПрограммыРодственника);
		КонецЦикла;
		РасширенияРодственниковТаблица = РасширенияПрограммСтрахованияРодственников(Прикрепление, ЕстьОтборПоСотрудникам, МассивФизическихЛиц);
		Для Каждого СтрокаРасширениеРодственника Из РасширенияРодственниковТаблица Цикл
			НоваяСтрока = Объект.РасширенияПрограммСтрахованияРодственников.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаРасширениеРодственника);
		КонецЦикла;
		Если РодственникиТаблица.Количество() > 0 Тогда
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(МассивФизическихЛиц,
				РодственникиТаблица.ВыгрузитьКолонку("РодственникСсылка"));
		КонецЕсли;
		ДанныеЗастрахованныхТаблица = ДанныеЗастрахованных(Прикрепление, ЕстьОтборПоСотрудникам, МассивФизическихЛиц);
		Для Каждого СтрокаДанныеЗастрахованных Из ДанныеЗастрахованныхТаблица Цикл
			НоваяСтрока = Объект.ДанныеЗастрахованных.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДанныеЗастрахованных);
		КонецЦикла;
		КИЗастрахованныхТаблица = КонтактнаяИнформацияЗастрахованных(Прикрепление, ЕстьОтборПоСотрудникам, МассивФизическихЛиц);
		Для Каждого СтрокаКИЗастрахованных Из КИЗастрахованныхТаблица Цикл
			НоваяСтрока = Объект.КонтактнаяИнформацияЗастрахованных.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаКИЗастрахованных);
		КонецЦикла;
		Если ИспользоватьДополнительныеРеквизитыИСведения Тогда
			ДопРеквизитыИСведенияЗастрахованныхТаблица = ДополнительныеРеквизитыИСведенияЗастрахованных(Прикрепление, ЕстьОтборПоСотрудникам, МассивФизическихЛиц);
			Для Каждого СтрокаДопРеквизиты Из ДопРеквизитыИСведенияЗастрахованныхТаблица Цикл
				НоваяСтрока = Объект.ДополнительныеРеквизитыИСведенияЗастрахованных.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДопРеквизиты);
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	ЗаполнитьИзмененияПерсональныхДанных(МассивЗастрахованных);
	ДанныеВРеквизиты();
	Объект.Сотрудники.Сортировать("Сотрудник");
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьИзмененияПерсональныхДанных(МассивЗастрахованных)
	
	Если МассивЗастрахованных = Неопределено Тогда
		МассивЗастрахованных = Новый Массив;
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(МассивЗастрахованных,
			Объект.Сотрудники.Выгрузить( , "ФизическоеЛицо").ВыгрузитьКолонку("ФизическоеЛицо"));
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(МассивЗастрахованных,
			Объект.Родственники.Выгрузить( , "РодственникСсылка").ВыгрузитьКолонку("РодственникСсылка"));
	КонецЕсли;
	
	Если МассивЗастрахованных.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьИзмененияДанных(МассивЗастрахованных);
	ЗаполнитьИзмененияКонтактнойИнформации(МассивЗастрахованных);
	ЗаполнитьИзмененияДопРеквизитовИСведений(МассивЗастрахованных);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьИзмененияДанных(МассивЗастрахованных)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ИзменениеОтправленныхДанныхЗастрахованных.Организация КАК Организация,
		|	ИзменениеОтправленныхДанныхЗастрахованных.СтраховаяКомпания КАК СтраховаяКомпания,
		|	ИзменениеОтправленныхДанныхЗастрахованных.Застрахованный КАК Застрахованный,
		|	ИзменениеОтправленныхДанныхЗастрахованных.Фамилия КАК Фамилия,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ИзмениласьФамилия КАК ИзмениласьФамилия,
		|	ИзменениеОтправленныхДанныхЗастрахованных.Имя КАК Имя,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ИзменилосьИмя КАК ИзменилосьИмя,
		|	ИзменениеОтправленныхДанныхЗастрахованных.Отчество КАК Отчество,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ИзменилосьОтчество КАК ИзменилосьОтчество,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ДатаРождения КАК ДатаРождения,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ИзмениласьДатаРождения КАК ИзмениласьДатаРождения,
		|	ИзменениеОтправленныхДанныхЗастрахованных.СтраховойНомерПФР КАК СтраховойНомерПФР,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ИзменилсяСтраховойНомерПФР КАК ИзменилсяСтраховойНомерПФР,
		|	ИзменениеОтправленныхДанныхЗастрахованных.Пол КАК Пол,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ИзменилсяПол КАК ИзменилсяПол,
		|	ИзменениеОтправленныхДанныхЗастрахованных.Страна КАК Страна,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ИзмениласьСтрана КАК ИзмениласьСтрана,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ДокументПредставление КАК ДокументПредставление,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ДокументВид КАК ДокументВид,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ДокументСерия КАК ДокументСерия,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ДокументНомер КАК ДокументНомер,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ДокументДатаВыдачи КАК ДокументДатаВыдачи,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ДокументСрокДействия КАК ДокументСрокДействия,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ДокументКемВыдан КАК ДокументКемВыдан,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ДокументКодПодразделения КАК ДокументКодПодразделения
		|ИЗ
		|	РегистрСведений.ИзменениеОтправленныхДанныхЗастрахованных КАК ИзменениеОтправленныхДанныхЗастрахованных
		|ГДЕ
		|	ИзменениеОтправленныхДанныхЗастрахованных.Организация = &Организация
		|	И ИзменениеОтправленныхДанныхЗастрахованных.СтраховаяКомпания = &СтраховаяКомпания
		|	И ИзменениеОтправленныхДанныхЗастрахованных.Застрахованный В(&МассивЗастрахованных)";
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("СтраховаяКомпания", Объект.СтраховаяКомпания);
	Запрос.УстановитьПараметр("МассивЗастрахованных", МассивЗастрахованных);
	Результат = Запрос.Выполнить().Выбрать();
	Пока Результат.Следующий() Цикл
		ФизическоеЛицо = ?(ТипЗнч(Результат.Застрахованный) = Тип("СправочникСсылка.ФизическиеЛица"),
			Результат.Застрахованный,
			ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Результат.Застрахованный, "Владелец"));
		НайденныеСтрокиСотрудники = Объект.Сотрудники.НайтиСтроки(Новый Структура("ФизическоеЛицо", ФизическоеЛицо));
		Если НайденныеСтрокиСотрудники.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		Если ТипЗнч(Результат.Застрахованный) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
			НайденныеСтрокиСотрудники[0].ИзменилисьОтправленныеДанныеСотрудника = Истина;
		Иначе
			НайденныеСтрокиСотрудники[0].ИзменилисьУсловияСтрахованияРодственников = Истина;
		КонецЕсли;
		
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("Застрахованный", Результат.Застрахованный);
		НайденныеСтроки = Объект.ДанныеЗастрахованных.НайтиСтроки(СтруктураПоиска);
		Если НайденныеСтроки.Количество() = 0 Тогда
			НайденнаяСтрока = Объект.ДанныеЗастрахованных.Добавить();
			НайденнаяСтрока.Застрахованный = Результат.Застрахованный;
		Иначе
			НайденнаяСтрока = НайденныеСтроки[0];
		КонецЕсли;
		
		Если Результат.ИзмениласьФамилия Тогда
			НайденнаяСтрока.Фамилия = Результат.Фамилия;
		КонецЕсли;
		Если Результат.ИзменилосьИмя Тогда
			НайденнаяСтрока.Имя = Результат.Имя;
		КонецЕсли;
		Если Результат.ИзменилосьОтчество Тогда
			НайденнаяСтрока.Отчество = Результат.Отчество;
		КонецЕсли;
		Если Результат.ИзмениласьДатаРождения Тогда
			НайденнаяСтрока.ДатаРождения = Результат.ДатаРождения;
		КонецЕсли;
		Если Результат.ИзменилсяСтраховойНомерПФР Тогда
			НайденнаяСтрока.СтраховойНомерПФР = Результат.СтраховойНомерПФР;
		КонецЕсли;
		Если Результат.ИзменилсяПол Тогда
			НайденнаяСтрока.Пол = Результат.Пол;
		КонецЕсли;
		Если Результат.ИзмениласьСтрана Тогда
			НайденнаяСтрока.Страна = Результат.Страна;
		КонецЕсли;
		Если ЗначениеЗаполнено(Результат.ДокументВид) Тогда
