&НаСервере
Процедура ЗаполнитьИзмененияКонтактнойИнформации(МассивЗастрахованных)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных.Застрахованный КАК Застрахованный,
		|	ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных.Вид КАК Вид,
		|	ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных.Представление КАК Представление
		|ИЗ
		|	РегистрСведений.ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных КАК ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных
		|ГДЕ
		|	ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных.Организация = &Организация
		|	И ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных.СтраховаяКомпания = &СтраховаяКомпания
		|	И ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных.Застрахованный В(&МассивЗастрахованных)";
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("СтраховаяКомпания", Объект.СтраховаяКомпания);
	Запрос.УстановитьПараметр("МассивЗастрахованных", МассивЗастрахованных);
	Результат = Запрос.Выполнить().Выбрать();
	Пока Результат.Следующий() Цикл
		Если ТипЗнч(Результат.Застрахованный) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
			НайденныеСтрокиСотрудники = Объект.Сотрудники.НайтиСтроки(Новый Структура("ФизическоеЛицо", Результат.Застрахованный));
			Если НайденныеСтрокиСотрудники.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			НайденныеСтрокиСотрудники[0].ИзменилисьОтправленныеДанныеСотрудника = Истина;
			
			СтруктураПоиска = Новый Структура;
			СтруктураПоиска.Вставить("Застрахованный", Результат.Застрахованный);
			СтруктураПоиска.Вставить("Вид", Результат.Вид);
			НайденныеСтрокиКИ = Объект.КонтактнаяИнформацияЗастрахованных.НайтиСтроки(СтруктураПоиска);
			Если НайденныеСтрокиКИ.Количество() = 0 Тогда
				НайденнаяСтрокаКИ = Объект.КонтактнаяИнформацияЗастрахованных.Добавить();
				НайденнаяСтрокаКИ.Застрахованный = Результат.Застрахованный;
				НайденнаяСтрокаКИ.Вид = Результат.Вид;
			Иначе
				НайденнаяСтрокаКИ = НайденныеСтрокиКИ[0];
			КонецЕсли;
			НайденнаяСтрокаКИ.Значение = Результат.Представление;
			НайденнаяСтрокаКИ.Представление = Результат.Представление;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

