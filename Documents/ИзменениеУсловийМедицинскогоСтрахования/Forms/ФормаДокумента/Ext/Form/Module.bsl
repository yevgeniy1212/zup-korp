&НаКлиенте
Процедура СотрудникиЧастичноеУдержаниеПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Сотрудники.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Элементы.СотрудникиПроцентЧастичногоУдержания.Видимость = ТекущиеДанные.ЧастичноеУдержание;
	Элементы.СотрудникиСуммаЧастичногоУдержания.Видимость = ТекущиеДанные.ЧастичноеУдержание;
	
	ПересчитатьУдержания(ТекущиеДанные.ФизическоеЛицо, ТекущиеДанные.СпособУдержания);
	
КонецПроцедуры

&НаКлиенте
Процедура СотрудникиПроцентЧастичногоУдержанияПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Сотрудники.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	РассчитатьОбщуюСуммуУдержания(ТекущиеДанные.ФизическоеЛицо);
	Если ТекущиеДанные.ОбщаяСуммаУдержания = 0 Тогда
		ТекущиеДанные.ПроцентЧастичногоУдержания = 0;
		ТекущиеДанные.СуммаЧастичногоУдержания = 0;
	Иначе
		Если ТекущиеДанные.ПроцентЧастичногоУдержания > 100 Тогда
			ТекущиеДанные.ПроцентЧастичногоУдержания = 100;
		КонецЕсли;
		ТекущиеДанные.СуммаЧастичногоУдержания = Окр(ТекущиеДанные.ОбщаяСуммаУдержания * ТекущиеДанные.ПроцентЧастичногоУдержания / 100, 2);
	КонецЕсли;
	УстановитьНадписиУдержаний(ТекущиеДанные.ФизическоеЛицо);
	Если ТекущиеДанные.СпособУдержания = ПредопределенноеЗначение("Перечисление.СпособыУдержанияМедицинскогоСтрахованияСотрудников.ПоГрафику") Тогда
		ПересчитатьГрафикУдержаний(ТекущиеДанные.ФизическоеЛицо);
		ОбновитьПодвалГрафикаУдержаний();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СотрудникиСуммаЧастичногоУдержанияПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Сотрудники.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	РассчитатьОбщуюСуммуУдержания(ТекущиеДанные.ФизическоеЛицо);
	Если ТекущиеДанные.ОбщаяСуммаУдержания = 0 Тогда
		ТекущиеДанные.ПроцентЧастичногоУдержания = 0;
		ТекущиеДанные.СуммаЧастичногоУдержания = 0;
	Иначе
		Если ТекущиеДанные.СуммаЧастичногоУдержания > ТекущиеДанные.ОбщаяСуммаУдержания Тогда
			ТекущиеДанные.СуммаЧастичногоУдержания = ТекущиеДанные.ОбщаяСуммаУдержания;
		КонецЕсли;
		ТекущиеДанные.ПроцентЧастичногоУдержания = Окр(ТекущиеДанные.СуммаЧастичногоУдержания / ТекущиеДанные.ОбщаяСуммаУдержания * 100, 2);
	КонецЕсли;
	УстановитьНадписиУдержаний(ТекущиеДанные.ФизическоеЛицо);
	Если ТекущиеДанные.СпособУдержания = ПредопределенноеЗначение("Перечисление.СпособыУдержанияМедицинскогоСтрахованияСотрудников.ПоГрафику") Тогда
		ПересчитатьГрафикУдержаний(ТекущиеДанные.ФизическоеЛицо);
		ОбновитьПодвалГрафикаУдержаний();
	КонецЕсли;
	
КонецПроцедуры

