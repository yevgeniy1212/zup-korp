	КонецЕсли;
	
	// Удалим строки показателей
	СтруктураОтбора = Новый Структура("ИдентификаторСтрокиВидаРасчета", ТекущиеДанные.ИдентификаторСтрокиВидаРасчета);
	НайденныеСтроки = Объект.Показатели.НайтиСтроки(СтруктураОтбора);
	Для каждого НайденнаяСтрока Из НайденныеСтроки Цикл
		Объект.Показатели.Удалить(НайденнаяСтрока);
	КонецЦикла;
	
КонецПроцедуры

