Процедура ЗаполнитьИзмененияПрограммСтрахования(ВыборкаПрограммы, ДанныеДокументов)
	
	Пока ВыборкаПрограммы.СледующийПоЗначениюПоля("Ссылка") Цикл
		ДанныеДокумента = ДанныеДокументов.Добавить();
		ЗаполнитьЗначенияСвойств(ДанныеДокумента, ВыборкаПрограммы);
		Пока ВыборкаПрограммы.Следующий() Цикл
			Если ВыборкаПрограммы.Действие = Перечисления.ДействияСПрограммамиМедицинскогоСтрахования.Добавить Тогда
				Если ЗначениеЗаполнено(ВыборкаПрограммы.СотрудникРодственника) Тогда
					Если ДанныеДокумента.ПрикрепленияРодственники.Колонки.Количество() = 0 Тогда
						ДанныеДокумента.ПрикрепленияРодственники = ТаблицаСтрахования();
					КонецЕсли;
					ТаблицаПрикрепления = ДанныеДокумента.ПрикрепленияРодственники;
				Иначе
					Если ДанныеДокумента.ПрикрепленияСотрудники.Колонки.Количество() = 0 Тогда
						ДанныеДокумента.ПрикрепленияСотрудники = ТаблицаСтрахования();
					КонецЕсли;
					ТаблицаПрикрепления = ДанныеДокумента.ПрикрепленияСотрудники;
				КонецЕсли;
				НайденныеСтроки = ТаблицаПрикрепления.НайтиСтроки(Новый Структура("Застрахованный", ВыборкаПрограммы.Застрахованный));
				Если НайденныеСтроки.Количество() > 0 Тогда
					ДанныеЗастрахованного = НайденныеСтроки[0];
					ДанныеЗастрахованного.ПрограммыСтрахования.Добавить(ВыборкаПрограммы.ПрограммаСтрахования);
					ДанныеЗастрахованного.СтраховаяПремия = ДанныеЗастрахованного.СтраховаяПремия + ВыборкаПрограммы.СтраховаяПремия;
				Иначе
					ДанныеЗастрахованного = ТаблицаПрикрепления.Добавить();
					ЗаполнитьЗначенияСвойств(ДанныеЗастрахованного, ВыборкаПрограммы, "Застрахованный, СотрудникРодственника, ДатаНачала, ДатаОкончания, СтраховаяПремия");
					ДанныеЗастрахованного.ПрограммыСтрахования.Добавить(ВыборкаПрограммы.ПрограммаСтрахования);
				КонецЕсли;
			ИначеЕсли ВыборкаПрограммы.Действие = Перечисления.ДействияСПрограммамиМедицинскогоСтрахования.Изменить Тогда
				Если ЗначениеЗаполнено(ВыборкаПрограммы.СотрудникРодственника) Тогда
					Если ДанныеДокумента.ОткрепленияРодственники.Колонки.Количество() = 0 Тогда
						ДанныеДокумента.ОткрепленияРодственники = ТаблицаСтрахования();
					КонецЕсли;
					ТаблицаОткрепления = ДанныеДокумента.ОткрепленияРодственники;
				Иначе
					Если ДанныеДокумента.ОткрепленияСотрудники.Колонки.Количество() = 0 Тогда
						ДанныеДокумента.ОткрепленияСотрудники = ТаблицаСтрахования();
					КонецЕсли;
					ТаблицаОткрепления = ДанныеДокумента.ОткрепленияСотрудники;
				КонецЕсли;
				НайденныеСтроки = ТаблицаОткрепления.НайтиСтроки(Новый Структура("Застрахованный", ВыборкаПрограммы.Застрахованный));
				Если НайденныеСтроки.Количество() > 0 Тогда
					ДанныеЗастрахованного = НайденныеСтроки[0];
					ДанныеЗастрахованного.ПрограммыСтрахования.Добавить(ВыборкаПрограммы.ПрограммаСтрахования);
					ДанныеЗастрахованного.СтраховаяПремия = ДанныеЗастрахованного.СтраховаяПремия + ВыборкаПрограммы.СтраховаяПремия;
				Иначе
					ДанныеЗастрахованного = ТаблицаОткрепления.Добавить();
					ЗаполнитьЗначенияСвойств(ДанныеЗастрахованного, ВыборкаПрограммы, "Застрахованный, СотрудникРодственника, ДатаНачала, ДатаОкончания, СтраховаяПремия");
					ДанныеЗастрахованного.ПрограммыСтрахования.Добавить(ВыборкаПрограммы.ПрограммаСтрахования);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьИзмененияРасширенийСтрахования(ВыборкаРасширения, ДанныеДокументов)
	
	Пока ВыборкаРасширения.СледующийПоЗначениюПоля("Ссылка") Цикл
		НайденныеСтроки = ДанныеДокументов.НайтиСтроки(Новый Структура("Ссылка", ВыборкаРасширения.Ссылка));
		Если НайденныеСтроки.Количество() > 0 Тогда
			ДанныеДокумента = НайденныеСтроки[0];
