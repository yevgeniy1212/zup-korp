#Область Печать

// Заполняет список команд печати.
// 
// Параметры:
//   КомандыПечати - ТаблицаЗначений - состав полей см. в функции УправлениеПечатью.СоздатьКоллекциюКомандПечати.
//
Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	
	// Изменение условий медицинского страхования
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.Обработчик = "УправлениеПечатьюБЗККлиент.ВыполнитьКомандуПечати";
	КомандаПечати.Идентификатор = "ИзменениеУсловийМедицинскогоСтрахования";
	КомандаПечати.Представление = НСтр("ru = 'Изменение условий медицинского страхования'");
	
	КомандаПечати.ПроверкаПроведенияПередПечатью = Истина;
	
КонецПроцедуры

// Формирует печатные формы
//
// Параметры:
//  (входные)
//    МассивОбъектов  - Массив    - ссылки на объекты, которые нужно распечатать;
//    ПараметрыПечати - Структура - дополнительные настройки печати;
//  (выходные)
//   КоллекцияПечатныхФорм - ТаблицаЗначений - сформированные табличные документы.
//   ОбъектыПечати         - СписокЗначений  - значение - ссылка на объект;
//                                             представление - имя области в которой был выведен объект;
//   ПараметрыВывода       - Структура       - дополнительные параметры сформированных табличных документов.
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ИзменениеУсловийМедицинскогоСтрахования") Тогда
		ТабличныйДокумент = ПечатьИзменениеУсловийМедицинскогоСтрахования(МассивОбъектов, ОбъектыПечати);
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм, "ИзменениеУсловийМедицинскогоСтрахования", НСтр("ru = 'Изменение условий медицинского страхования'"), ТабличныйДокумент);
	КонецЕсли;
	
КонецПроцедуры

Функция ПечатьИзменениеУсловийМедицинскогоСтрахования(МассивОбъектов, ОбъектыПечати)
	
	ДанныеДокументов = ДанныеДокументовИзменениеУсловийМедицинскогоСтрахования(МассивОбъектов);
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_МедицинскоеСтрахование_ИзменениеУсловийМедицинскогоСтрахования";
	
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.ИзменениеУсловийМедицинскогоСтрахования.ПФ_MXL_ИзменениеУсловийМедицинскогоСтрахования");
	
	ПервыйДокумент = Истина;
	
	Для Каждого ДанныеДокумента Из ДанныеДокументов Цикл
		
		// Документы нужно выводить на разных страницах.
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		Иначе
			ПервыйДокумент = Ложь;
		КонецЕсли;
		
		ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
		ОбластьЗаголовок.Параметры.Дата = Формат(ДанныеДокумента.Дата, "ДЛФ=D");
		ОбластьЗаголовок.Параметры.Номер = ДанныеДокумента.Номер;
		ОбластьЗаголовок.Параметры.Организация = ДанныеДокумента.Организация;
		ОбластьЗаголовок.Параметры.СтраховаяКомпания = ДанныеДокумента.СтраховаяКомпания;
		ТабличныйДокумент.Вывести(ОбластьЗаголовок);
		
		ОбластьЗаголовокПрикрепленияСотрудники = Макет.ПолучитьОбласть("ЗаголовокПрикрепленияСотрудники");
		ТабличныйДокумент.Вывести(ОбластьЗаголовокПрикрепленияСотрудники);
		Если ДанныеДокумента.ПрикрепленияСотрудники.Количество() > 0 Тогда
			ОбластьШапкаПрикрепленияСотрудники = Макет.ПолучитьОбласть("ШапкаПрикрепленияСотрудники");
			ТабличныйДокумент.Вывести(ОбластьШапкаПрикрепленияСотрудники);
			НомерСтроки = 0;
			Для Каждого ПрикрепленияСотрудники Из ДанныеДокумента.ПрикрепленияСотрудники Цикл
				НомерСтроки = НомерСтроки + 1;
				ОбластьСтрокаПрикрепленияСотрудники = Макет.ПолучитьОбласть("СтрокаПрикрепленияСотрудники");
				ОбластьСтрокаПрикрепленияСотрудники.Параметры.НомерСтроки = НомерСтроки;
				ОбластьСтрокаПрикрепленияСотрудники.Параметры.Застрахованный = ПрикрепленияСотрудники.Застрахованный;
				ПрограммыСтрахования = "";
				Для Каждого ПрограммаСтрахования Из ПрикрепленияСотрудники.ПрограммыСтрахования Цикл
					ПрограммыСтрахования = ПрограммыСтрахования + Строка(ПрограммаСтрахования) + "; ";
				КонецЦикла;
				СтроковыеФункцииКлиентСервер.УдалитьПоследнийСимволВСтроке(ПрограммыСтрахования, 2);
				ОбластьСтрокаПрикрепленияСотрудники.Параметры.ПрограммыСтрахования = ПрограммыСтрахования;
				РасширенияСтрахования = "";
				Для Каждого РасширениеСтрахования Из ПрикрепленияСотрудники.РасширенияСтрахования Цикл
					РасширенияСтрахования = РасширенияСтрахования + Строка(РасширениеСтрахования) + "; ";
				КонецЦикла;
				СтроковыеФункцииКлиентСервер.УдалитьПоследнийСимволВСтроке(РасширенияСтрахования, 2);
				ОбластьСтрокаПрикрепленияСотрудники.Параметры.РасширенияПрограмм = РасширенияСтрахования;
				ОбластьСтрокаПрикрепленияСотрудники.Параметры.ДатаПрикрепления = ПрикрепленияСотрудники.ДатаНачала;
				ОбластьСтрокаПрикрепленияСотрудники.Параметры.ДатаОткрепления = ПрикрепленияСотрудники.ДатаОкончания;
				ОбластьСтрокаПрикрепленияСотрудники.Параметры.СтраховаяПремия = ПрикрепленияСотрудники.СтраховаяПремия;
				ТабличныйДокумент.Вывести(ОбластьСтрокаПрикрепленияСотрудники);
			КонецЦикла;
		Иначе
			ОбластьДанныеОтсутствуют = Макет.ПолучитьОбласть("ДанныеОтсутствуют");
			ТабличныйДокумент.Вывести(ОбластьДанныеОтсутствуют);
		КонецЕсли;
		
		ОбластьЗаголовокПрикрепленияРодственники = Макет.ПолучитьОбласть("ЗаголовокПрикрепленияРодственники");
		ТабличныйДокумент.Вывести(ОбластьЗаголовокПрикрепленияРодственники);
		Если ДанныеДокумента.ПрикрепленияРодственники.Количество() > 0 Тогда
			ОбластьШапкаПрикрепленияРодственники = Макет.ПолучитьОбласть("ШапкаПрикрепленияРодственники");
			ТабличныйДокумент.Вывести(ОбластьШапкаПрикрепленияРодственники);
			НомерСтроки = 0;
			Для Каждого ПрикрепленияРодственники Из ДанныеДокумента.ПрикрепленияРодственники Цикл
				НомерСтроки = НомерСтроки + 1;
				ОбластьСтрокаПрикрепленияРодственники = Макет.ПолучитьОбласть("СтрокаПрикрепленияРодственники");
				ОбластьСтрокаПрикрепленияРодственники.Параметры.НомерСтроки = НомерСтроки;
				ОбластьСтрокаПрикрепленияРодственники.Параметры.Застрахованный = ПрикрепленияРодственники.Застрахованный;
				ОбластьСтрокаПрикрепленияРодственники.Параметры.ФИОСотрудника = ПрикрепленияРодственники.СотрудникРодственника;
				ПрограммыСтрахования = "";
				Для Каждого ПрограммаСтрахования Из ПрикрепленияРодственники.ПрограммыСтрахования Цикл
					ПрограммыСтрахования = ПрограммыСтрахования + Строка(ПрограммаСтрахования) + "; ";
				КонецЦикла;
				СтроковыеФункцииКлиентСервер.УдалитьПоследнийСимволВСтроке(ПрограммыСтрахования, 2);
				ОбластьСтрокаПрикрепленияРодственники.Параметры.ПрограммыСтрахования = ПрограммыСтрахования;
				РасширенияСтрахования = "";
				Для Каждого РасширениеСтрахования Из ПрикрепленияРодственники.РасширенияСтрахования Цикл
					РасширенияСтрахования = РасширенияСтрахования + Строка(РасширениеСтрахования) + "; ";
				КонецЦикла;
				СтроковыеФункцииКлиентСервер.УдалитьПоследнийСимволВСтроке(РасширенияСтрахования, 2);
				ОбластьСтрокаПрикрепленияРодственники.Параметры.РасширенияПрограмм = РасширенияСтрахования;
				ОбластьСтрокаПрикрепленияРодственники.Параметры.ДатаПрикрепления = ПрикрепленияРодственники.ДатаНачала;
				ОбластьСтрокаПрикрепленияРодственники.Параметры.ДатаОткрепления = ПрикрепленияРодственники.ДатаОкончания;
				ОбластьСтрокаПрикрепленияРодственники.Параметры.СтраховаяПремия = ПрикрепленияРодственники.СтраховаяПремия;
				ТабличныйДокумент.Вывести(ОбластьСтрокаПрикрепленияРодственники);
			КонецЦикла;
		Иначе
			ОбластьДанныеОтсутствуют = Макет.ПолучитьОбласть("ДанныеОтсутствуют");
			ТабличныйДокумент.Вывести(ОбластьДанныеОтсутствуют);
		КонецЕсли;
		
		ОбластьЗаголовокИзменениеЛичныхДанных = Макет.ПолучитьОбласть("ЗаголовокИзменениеЛичныхДанных");
		ТабличныйДокумент.Вывести(ОбластьЗаголовокИзменениеЛичныхДанных);
		Если ДанныеДокумента.ДанныеЗастрахованных.Количество() > 0 Тогда
			ОбластьШапкаИзменениеЛичныхДанных = Макет.ПолучитьОбласть("ШапкаИзменениеЛичныхДанных");
			ТабличныйДокумент.Вывести(ОбластьШапкаИзменениеЛичныхДанных);
			НомерСтроки = 0;
			Для Каждого ДанныеЗастрахованных Из ДанныеДокумента.ДанныеЗастрахованных Цикл
				НомерСтроки = НомерСтроки + 1;
				ОбластьСтрокаИзменениеЛичныхДанныхЗастрахованный = Макет.ПолучитьОбласть("СтрокаИзменениеЛичныхДанных|КолонкаЗастрахованный");
				ОбластьСтрокаИзменениеЛичныхДанныхЗастрахованный.Параметры.Застрахованный = ДанныеЗастрахованных.Застрахованный;
				ОбластьСтрокаИзменениеЛичныхДанныхЗастрахованный.Параметры.НомерСтроки = НомерСтроки;
				ТабличныйДокумент.Вывести(ОбластьСтрокаИзменениеЛичныхДанныхЗастрахованный);
				ОбластьСтрокаИзменениеЛичныхДанныхИзменения = Макет.ПолучитьОбласть("СтрокаИзменениеЛичныхДанных|КолонкаИзменения");
				Для Каждого Данные Из ДанныеЗастрахованных.Данные Цикл
					Если Не ЗначениеЗаполнено(ОбластьСтрокаИзменениеЛичныхДанныхИзменения.Параметры.Данные) Тогда
						ОбластьСтрокаИзменениеЛичныхДанныхИзменения.Параметры.Данные = Данные.Данные;
					Иначе
						ОбластьСтрокаИзменениеЛичныхДанныхИзменения.Параметры.Данные = Строка(ОбластьСтрокаИзменениеЛичныхДанныхИзменения.Параметры.Данные)
							+ Символы.ПС +Строка(Данные.Данные);
					КонецЕсли;
					Если Не ЗначениеЗаполнено(ОбластьСтрокаИзменениеЛичныхДанныхИзменения.Параметры.НовоеЗначение) Тогда
						ОбластьСтрокаИзменениеЛичныхДанныхИзменения.Параметры.НовоеЗначение = Данные.НовоеЗначение;
					Иначе
						ОбластьСтрокаИзменениеЛичныхДанныхИзменения.Параметры.НовоеЗначение = Строка(ОбластьСтрокаИзменениеЛичныхДанныхИзменения.Параметры.НовоеЗначение)
							+ Символы.ПС +Строка(Данные.НовоеЗначение);
					КонецЕсли;
					Если Не ЗначениеЗаполнено(ОбластьСтрокаИзменениеЛичныхДанныхИзменения.Параметры.СтароеЗначение) Тогда
						ОбластьСтрокаИзменениеЛичныхДанныхИзменения.Параметры.СтароеЗначение = Данные.СтароеЗначение;
					Иначе
						ОбластьСтрокаИзменениеЛичныхДанныхИзменения.Параметры.СтароеЗначение = Строка(ОбластьСтрокаИзменениеЛичныхДанныхИзменения.Параметры.СтароеЗначение)
							+ Символы.ПС +Строка(Данные.СтароеЗначение);
					КонецЕсли;
				КонецЦикла;
				ТабличныйДокумент.Присоединить(ОбластьСтрокаИзменениеЛичныхДанныхИзменения);
			КонецЦикла;
		Иначе
			ОбластьДанныеОтсутствуют = Макет.ПолучитьОбласть("ДанныеОтсутствуют");
			ТабличныйДокумент.Вывести(ОбластьДанныеОтсутствуют);
		КонецЕсли;
		
		ОбластьЗаголовокОткрепленияСотрудники = Макет.ПолучитьОбласть("ЗаголовокОткрепленияСотрудники");
		ТабличныйДокумент.Вывести(ОбластьЗаголовокОткрепленияСотрудники);
		Если ДанныеДокумента.ОткрепленияСотрудники.Количество() > 0 Тогда
			ОбластьШапкаОткрепленияСотрудники = Макет.ПолучитьОбласть("ШапкаОткрепленияСотрудники");
			ТабличныйДокумент.Вывести(ОбластьШапкаОткрепленияСотрудники);
			НомерСтроки = 0;
			Для Каждого ОткрепленияСотрудники Из ДанныеДокумента.ОткрепленияСотрудники Цикл
				НомерСтроки = НомерСтроки + 1;
				ОбластьСтрокаОткрепленияСотрудники = Макет.ПолучитьОбласть("СтрокаОткрепленияСотрудники");
				ОбластьСтрокаОткрепленияСотрудники.Параметры.НомерСтроки = НомерСтроки;
				ОбластьСтрокаОткрепленияСотрудники.Параметры.Застрахованный = ОткрепленияСотрудники.Застрахованный;
				ПрограммыСтрахования = "";
				Для Каждого ПрограммаСтрахования Из ОткрепленияСотрудники.ПрограммыСтрахования Цикл
					ПрограммыСтрахования = ПрограммыСтрахования + Строка(ПрограммаСтрахования) + "; ";
				КонецЦикла;
				СтроковыеФункцииКлиентСервер.УдалитьПоследнийСимволВСтроке(ПрограммыСтрахования, 2);
				ОбластьСтрокаОткрепленияСотрудники.Параметры.ПрограммыСтрахования = ПрограммыСтрахования;
				РасширенияСтрахования = "";
				Для Каждого РасширениеСтрахования Из ОткрепленияСотрудники.РасширенияСтрахования Цикл
					РасширенияСтрахования = РасширенияСтрахования + Строка(РасширениеСтрахования) + "; ";
				КонецЦикла;
				СтроковыеФункцииКлиентСервер.УдалитьПоследнийСимволВСтроке(РасширенияСтрахования, 2);
				ОбластьСтрокаОткрепленияСотрудники.Параметры.РасширенияПрограмм = РасширенияСтрахования;
				ОбластьСтрокаОткрепленияСотрудники.Параметры.ДатаОткрепления = ОткрепленияСотрудники.ДатаОкончания;
				ОбластьСтрокаОткрепленияСотрудники.Параметры.СтраховаяПремия = ОткрепленияСотрудники.СтраховаяПремия;
				ТабличныйДокумент.Вывести(ОбластьСтрокаОткрепленияСотрудники);
			КонецЦикла;
		Иначе
			ОбластьДанныеОтсутствуют = Макет.ПолучитьОбласть("ДанныеОтсутствуют");
			ТабличныйДокумент.Вывести(ОбластьДанныеОтсутствуют);
		КонецЕсли;
		
		ОбластьЗаголовокОткрепленияРодственники = Макет.ПолучитьОбласть("ЗаголовокОткрепленияРодственники");
		ТабличныйДокумент.Вывести(ОбластьЗаголовокОткрепленияРодственники);
		Если ДанныеДокумента.ОткрепленияРодственники.Количество() > 0 Тогда
			ОбластьШапкаОткрепленияРодственники = Макет.ПолучитьОбласть("ШапкаОткрепленияРодственники");
			ТабличныйДокумент.Вывести(ОбластьШапкаОткрепленияРодственники);
			НомерСтроки = 0;
			Для Каждого ОткрепленияРодственники Из ДанныеДокумента.ОткрепленияРодственники Цикл
				НомерСтроки = НомерСтроки + 1;
				ОбластьСтрокаОткрепленияРодственники = Макет.ПолучитьОбласть("СтрокаОткрепленияРодственники");
				ОбластьСтрокаОткрепленияРодственники.Параметры.НомерСтроки = НомерСтроки;
				ОбластьСтрокаОткрепленияРодственники.Параметры.Застрахованный = ОткрепленияРодственники.Застрахованный;
				ОбластьСтрокаОткрепленияРодственники.Параметры.ФИОСотрудника = ОткрепленияРодственники.СотрудникРодственника;
				ПрограммыСтрахования = "";
				Для Каждого ПрограммаСтрахования Из ОткрепленияРодственники.ПрограммыСтрахования Цикл
					ПрограммыСтрахования = ПрограммыСтрахования + Строка(ПрограммаСтрахования) + "; ";
				КонецЦикла;
				СтроковыеФункцииКлиентСервер.УдалитьПоследнийСимволВСтроке(ПрограммыСтрахования, 2);
				ОбластьСтрокаОткрепленияРодственники.Параметры.ПрограммыСтрахования = ПрограммыСтрахования;
				РасширенияСтрахования = "";
				Для Каждого РасширениеСтрахования Из ОткрепленияРодственники.РасширенияСтрахования Цикл
					РасширенияСтрахования = РасширенияСтрахования + Строка(РасширениеСтрахования) + "; ";
				КонецЦикла;
				СтроковыеФункцииКлиентСервер.УдалитьПоследнийСимволВСтроке(РасширенияСтрахования, 2);
				ОбластьСтрокаОткрепленияРодственники.Параметры.РасширенияПрограмм = РасширенияСтрахования;
				ОбластьСтрокаОткрепленияРодственники.Параметры.ДатаОткрепления = ОткрепленияРодственники.ДатаОкончания;
				ОбластьСтрокаОткрепленияРодственники.Параметры.СтраховаяПремия = ОткрепленияРодственники.СтраховаяПремия;
				ТабличныйДокумент.Вывести(ОбластьСтрокаОткрепленияРодственники);
			КонецЦикла;
		Иначе
			ОбластьДанныеОтсутствуют = Макет.ПолучитьОбласть("ДанныеОтсутствуют");
			ТабличныйДокумент.Вывести(ОбластьДанныеОтсутствуют);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции

Функция ДанныеДокументовИзменениеУсловийМедицинскогоСтрахования(МассивОбъектов)
	
	ДанныеДокументов = Новый ТаблицаЗначений;
	ДанныеДокументов.Колонки.Добавить("Ссылка");
	ДанныеДокументов.Колонки.Добавить("Дата");
	ДанныеДокументов.Колонки.Добавить("Номер");
	ДанныеДокументов.Колонки.Добавить("Организация");
	ДанныеДокументов.Колонки.Добавить("СтраховаяКомпания");
	ДанныеДокументов.Колонки.Добавить("ПрикрепленияСотрудники", Новый ОписаниеТипов("ТаблицаЗначений"));
	ДанныеДокументов.Колонки.Добавить("ПрикрепленияРодственники", Новый ОписаниеТипов("ТаблицаЗначений"));
	ДанныеДокументов.Колонки.Добавить("ОткрепленияСотрудники", Новый ОписаниеТипов("ТаблицаЗначений"));
	ДанныеДокументов.Колонки.Добавить("ОткрепленияРодственники", Новый ОписаниеТипов("ТаблицаЗначений"));
	ДанныеДокументов.Колонки.Добавить("ДанныеЗастрахованных", Новый ОписаниеТипов("ТаблицаЗначений"));
	
	ЗаполнитьДанныеИзмененияУсловийМедицинскогоСтрахования(МассивОбъектов, ДанныеДокументов);
	
	Возврат ДанныеДокументов;
	
КонецФункции

Процедура ЗаполнитьДанныеИзмененияУсловийМедицинскогоСтрахования(МассивДокументов, ДанныеДокументов)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ИзменениеУсловийМедицинскогоСтрахования", МассивДокументов);
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ИзменениеУсловийМедицинскогоСтрахования.Ссылка КАК Ссылка,
		|	ИзменениеУсловийМедицинскогоСтрахования.Дата КАК Дата,
		|	ИзменениеУсловийМедицинскогоСтрахования.Номер КАК Номер,
		|	ИзменениеУсловийМедицинскогоСтрахования.Организация КАК Организация,
		|	ИзменениеУсловийМедицинскогоСтрахования.СтраховаяКомпания КАК СтраховаяКомпания,
		|	ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияСотрудников.Сотрудник КАК Застрахованный,
		|	ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияСотрудников.ПрограммаСтрахования КАК ПрограммаСтрахования,
		|	ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияСотрудников.ДатаНачала КАК ДатаНачала,
		|	ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияСотрудников.ДатаОкончания КАК ДатаОкончания,
		|	ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияСотрудников.СтраховаяПремия КАК СтраховаяПремия,
		|	ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияСотрудников.Действие КАК Действие,
		|	NULL КАК СотрудникРодственника
		|ИЗ
		|	Документ.ИзменениеУсловийМедицинскогоСтрахования.ПрограммыСтрахованияСотрудников КАК ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияСотрудников
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ИзменениеУсловийМедицинскогоСтрахования.Сотрудники КАК ИзменениеУсловийМедицинскогоСтрахованияСотрудники
		|		ПО ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияСотрудников.Ссылка = ИзменениеУсловийМедицинскогоСтрахованияСотрудники.Ссылка
		|			И ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияСотрудников.Сотрудник = ИзменениеУсловийМедицинскогоСтрахованияСотрудники.Сотрудник
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ИзменениеУсловийМедицинскогоСтрахования КАК ИзменениеУсловийМедицинскогоСтрахования
		|		ПО ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияСотрудников.Ссылка = ИзменениеУсловийМедицинскогоСтрахования.Ссылка
		|ГДЕ
		|	ИзменениеУсловийМедицинскогоСтрахования.Ссылка В(&ИзменениеУсловийМедицинскогоСтрахования)
		|	И ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияСотрудников.Действие <> ЗНАЧЕНИЕ(Перечисление.ДействияСПрограммамиМедицинскогоСтрахования.ПустаяСсылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ИзменениеУсловийМедицинскогоСтрахования.Ссылка,
		|	ИзменениеУсловийМедицинскогоСтрахования.Дата,
		|	ИзменениеУсловийМедицинскогоСтрахования.Номер,
		|	ИзменениеУсловийМедицинскогоСтрахования.Организация,
		|	ИзменениеУсловийМедицинскогоСтрахования.СтраховаяКомпания,
		|	ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияРодственников.РодственникСсылка,
		|	ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияРодственников.ПрограммаСтрахования,
		|	ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияРодственников.ДатаНачала,
		|	ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияРодственников.ДатаОкончания,
		|	ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияРодственников.СтраховаяПремия,
		|	ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияРодственников.Действие,
		|	ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияРодственников.ФизическоеЛицо
		|ИЗ
		|	Документ.ИзменениеУсловийМедицинскогоСтрахования.ПрограммыСтрахованияРодственников КАК ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияРодственников
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ИзменениеУсловийМедицинскогоСтрахования.Родственники КАК ИзменениеУсловийМедицинскогоСтрахованияРодственники
		|		ПО ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияРодственников.Ссылка = ИзменениеУсловийМедицинскогоСтрахованияРодственники.Ссылка
		|			И ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияРодственников.РодственникСсылка = ИзменениеУсловийМедицинскогоСтрахованияРодственники.РодственникСсылка
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ИзменениеУсловийМедицинскогоСтрахования КАК ИзменениеУсловийМедицинскогоСтрахования
		|		ПО ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияРодственников.Ссылка = ИзменениеУсловийМедицинскогоСтрахования.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ИзменениеУсловийМедицинскогоСтрахования.Сотрудники КАК ИзменениеУсловийМедицинскогоСтрахованияСотрудники
		|		ПО ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияРодственников.Ссылка = ИзменениеУсловийМедицинскогоСтрахованияСотрудники.Ссылка
		|			И ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияРодственников.ФизическоеЛицо = ИзменениеУсловийМедицинскогоСтрахованияСотрудники.ФизическоеЛицо
		|ГДЕ
		|	ИзменениеУсловийМедицинскогоСтрахования.Ссылка В(&ИзменениеУсловийМедицинскогоСтрахования)
		|	И ИзменениеУсловийМедицинскогоСтрахованияПрограммыСтрахованияРодственников.Действие <> ЗНАЧЕНИЕ(Перечисление.ДействияСПрограммамиМедицинскогоСтрахования.ПустаяСсылка)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Ссылка,
		|	Застрахованный
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИзменениеУсловийМедицинскогоСтрахования.Ссылка КАК Ссылка,
