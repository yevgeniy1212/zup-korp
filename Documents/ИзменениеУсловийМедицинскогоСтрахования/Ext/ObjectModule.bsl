#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ЗарплатаКадры.ОтключитьБизнесЛогикуПриЗаписи(ЭтотОбъект) Тогда
		Возврат;
	КонецЕсли;
	
	МассивСотрудников = Сотрудники.Выгрузить(, "Сотрудник").ВыгрузитьКолонку("Сотрудник");
	МассивФизическихЛиц = Новый Массив;
	ФизическиеЛицаСотрудников = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(МассивСотрудников, "ФизическоеЛицо");
	Для каждого ЭлементСоответствия Из ФизическиеЛицаСотрудников Цикл
		Если МассивФизическихЛиц.Найти(ЭлементСоответствия.Значение) = Неопределено Тогда
			МассивФизическихЛиц.Добавить(ЭлементСоответствия.Значение);
		КонецЕсли;
	КонецЦикла;
	
	СтруктураИменТаблиц = МедицинскоеСтрахованиеФормы.СтруктураИменТаблиц();
	СтруктураИменТаблиц.ИмяТаблицыСотрудники = "Сотрудники";
	СтруктураИменТаблиц.ИмяТаблицыПрограммыСтрахованияСотрудников = "ПрограммыСтрахованияСотрудников";
	СтруктураИменТаблиц.ИмяТаблицыРасширенийПрограммСтрахованияСотрудников = "РасширенияПрограммСтрахованияСотрудников";
	СтруктураИменТаблиц.ИмяТаблицыРодственники = "Родственники";
	СтруктураИменТаблиц.ИмяТаблицыПрограммыСтрахованияРодственников = "ПрограммыСтрахованияРодственников";
	СтруктураИменТаблиц.ИмяТаблицыРасширенийПрограммСтрахованияРодственников = "РасширенияПрограммСтрахованияРодственников";
	
	Для каждого ЗначениеСтруктуры Из СтруктураИменТаблиц Цикл
		СтрокиДляУдаления = Новый Массив;
		Для Каждого СтрокаТаблицы Из ЭтотОбъект[ЗначениеСтруктуры.Значение] Цикл
			Если СтрНайти(ЗначениеСтруктуры.Ключ, "Сотрудник") > 0 Тогда
				Если МассивСотрудников.Найти(СтрокаТаблицы.Сотрудник) = Неопределено Тогда
					СтрокиДляУдаления.Добавить(СтрокаТаблицы);
				КонецЕсли;
			Иначе
				Если МассивФизическихЛиц.Найти(СтрокаТаблицы.ФизическоеЛицо) = Неопределено Тогда
					СтрокиДляУдаления.Добавить(СтрокаТаблицы);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		Для Каждого СтрокаДляУдаления Из СтрокиДляУдаления Цикл
			ЭтотОбъект[ЗначениеСтруктуры.Значение].Удалить(СтрокаДляУдаления);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	ОтражениеЗарплатыВБухучетеРасширенный.УточнитьСоставПроверяемыхРеквизитовБухучетПлановыхУдержаний(ЭтотОбъект, ПроверяемыеРеквизиты);
	ЗарплатаКадры.ПроверитьКорректностьДаты(Ссылка, ДатаНачалаСтрахования, "Объект.ДатаНачалаСтрахования", Отказ, НСтр("ru='Дата начала события'"), , , Ложь);
	
	УникальныеЗначения = Новый Соответствие;
	ИндексСтроки = 0;
	Для Каждого ДанныеФизическогоЛица Из Сотрудники Цикл
		Если УникальныеЗначения[ДанныеФизическогоЛица.Сотрудник] = Неопределено Тогда
			УникальныеЗначения.Вставить(ДанныеФизическогоЛица.Сотрудник, Истина);
		Иначе
			ТекстОшибки = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Информация о сотруднике %1 была введена в документе ранее.'"), ДанныеФизическогоЛица.Сотрудник);
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки, Ссылка, "Объект.Сотрудники[" + Формат(ИндексСтроки, "ЧН=0; ЧГ=0") + "].Сотрудник", ,Отказ);
		КонецЕсли;
		Если ДанныеФизическогоЛица.СтраховатьСотрудника Тогда
			ЗарплатаКадры.ПроверитьКорректностьДаты(Ссылка, ДанныеФизическогоЛица.ДатаПрикрепления, "Объект.Сотрудники[" + Формат(ИндексСтроки, "ЧН=0; ЧГ=0") + "].ДатаПрикрепления", Отказ,
				НСтр("ru='Дата прикрепления'"), ДатаНачалаСтрахования, НСтр("ru='Даты начала страхования'"));
		КонецЕсли;
		ИндексСтроки = ИндексСтроки + 1;
	КонецЦикла;
	
	ПараметрыПолученияСотрудниковОрганизаций = КадровыйУчет.ПараметрыПолученияРабочихМестВОрганизацийПоСпискуФизическихЛиц();
	ПараметрыПолученияСотрудниковОрганизаций.Организация 		= Организация;
	ПараметрыПолученияСотрудниковОрганизаций.НачалоПериода		= ДатаНачалаСтрахования;
	ПараметрыПолученияСотрудниковОрганизаций.ОкончаниеПериода	= ДатаОкончанияСтрахования;
	
	КадровыйУчет.ПроверитьРаботающихСотрудников(
		ОбщегоНазначения.ВыгрузитьКолонку(Сотрудники, "Сотрудник"),
		ПараметрыПолученияСотрудниковОрганизаций,
		Отказ,
		Новый Структура("ИмяПоляСотрудник, ИмяОбъекта", "Сотрудник", "Объект"));
		
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	// Подготовка к регистрации перерасчетов
	ДанныеДокумента = Новый МенеджерВременныхТаблиц;
	СоздатьВТДанныеДокументов(ДанныеДокумента);
	
	// Проведение документа
	ПроведениеСервер.ПодготовитьНаборыЗаписейКРегистрацииДвижений(ЭтотОбъект);
	
	ОчиститьИзмененияПерсональныхДанных();
	СформироватьДвиженияПрикрепленияКПрограммамСтрахования(Движения, ДанныеДокумента);
	
	СформироватьДвиженияОтправленныеДанныеЗастрахованных(Движения);
	СформироватьДвиженияОтправленнаяКонтактнаяИнформацияЗастрахованных(Движения);
	СформироватьДвиженияОтправленныеДополнительныеРеквизитыИСведенияЗастрахованных(Движения);
	Если ПолучитьФункциональнуюОпцию("ИспользоватьУдержанияВМедицинскомСтрахованииСотрудников") Тогда
		ДанныеДляПроведения = РасчетЗарплатыРасширенный.СоздатьДанныеДляРегистрацииПлановыхУдержаний();
		ЗаполнитьДанныеДляРегистрацииПлановыхУдержанийСпискаСотрудников(ДанныеДляПроведения, Ссылка);
		ЗаполнитьПредельныеСуммыУдержанийСотрудников(ДанныеДляПроведения);
		
		ДвиженияУдержаний = Новый Структура;
		ДвиженияУдержаний.Вставить("ДанныеПлановыхУдержаний", ДанныеДляПроведения.ДанныеПлановыхУдержаний);
		ДвиженияУдержаний.Вставить("ЗначенияПоказателей", ДанныеДляПроведения.ЗначенияПоказателей);
		ДвиженияУдержаний.Вставить("РабочиеМестаУдержаний", ДанныеДляПроведения.РабочиеМестаУдержаний);
		
		РасчетЗарплатыРасширенный.СформироватьДвиженияПлановыхУдержаний(Движения, ДвиженияУдержаний);
		РасчетЗарплатыРасширенный.СформироватьДвиженияПредельныхСуммУдержанийСотрудников(Движения, ДанныеДляПроведения.ПредельныеСуммыУдержанийСотрудников);
		
		СформироватьДвиженияУдержаний(Движения);
		СформироватьДвиженияГрафикаУдержаний(Движения);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	Если ТипЗнч(ДанныеЗаполнения) <> Тип("ДокументСсылка.ПрикреплениеКПрограммамМедицинскогоСтрахования") Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеПрикрепления = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
		ДанныеЗаполнения,
		"Организация, СтраховаяКомпания, Подразделение, ДатаНачалаСтрахования, ДатаОкончанияСтрахования");
		
	Основание = ДанныеЗаполнения;
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, ДанныеЗаполнения, "Организация, СтраховаяКомпания, Подразделение, ДатаНачалаСтрахования, ДатаОкончанияСтрахования");
	
	Сотрудники.Загрузить(СотрудникиПрикрепления(ДанныеЗаполнения));
	ПрограммыСтрахованияСотрудников.Загрузить(ПрограммыСтрахованияСотрудников(ДанныеЗаполнения));
	РасширенияПрограммСтрахованияСотрудников.Загрузить(РасширенияПрограммСтрахованияСотрудников(ДанныеЗаполнения));
	ГрафикУдержаний.Загрузить(ГрафикУдержаний(ДанныеЗаполнения));
	Родственники.Загрузить(РодственникиПрикрепления(ДанныеЗаполнения));
	ПрограммыСтрахованияРодственников.Загрузить(ПрограммыСтрахованияРодственников(ДанныеЗаполнения));
	РасширенияПрограммСтрахованияРодственников.Загрузить(РасширенияПрограммСтрахованияРодственников(ДанныеЗаполнения));
	ДанныеЗастрахованных.Загрузить(ДанныеЗастрахованных(ДанныеЗаполнения));
	КонтактнаяИнформацияЗастрахованных.Загрузить(КонтактнаяИнформацияЗастрахованных(ДанныеЗаполнения));
	ДополнительныеРеквизитыИСведенияЗастрахованных.Загрузить(ДополнительныеРеквизитыИСведенияЗастрахованных(ДанныеЗаполнения));
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СотрудникиПрикрепления(ПрикреплениеСсылка)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ПрикреплениеСсылка);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияСотрудники.Сотрудник КАК Сотрудник,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияСотрудники.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияСотрудники.ДатаПрикрепления КАК ДатаПрикрепления,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияСотрудники.ПрограммыСтрахования КАК ПрограммыСтрахования,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияСотрудники.РасширенияПрограммСтрахования КАК РасширенияПрограммСтрахования,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияСотрудники.СтраховаяПремия КАК СтраховаяПремия,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияСотрудники.СуммаУдержания КАК СуммаУдержания,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияСотрудники.СуммаПредела КАК СуммаПредела,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияСотрудники.ПрограммаСтрахования КАК ПрограммаСтрахования,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияСотрудники.РасширениеПрограммСтрахования КАК РасширениеПрограммСтрахования,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияСотрудники.УдерживатьИзЗарплаты КАК УдерживатьИзЗарплаты,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияСотрудники.Удержание КАК Удержание,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияСотрудники.СпособУдержания КАК СпособУдержания,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияСотрудники.ОбщаяСуммаУдержания КАК ОбщаяСуммаУдержания,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияСотрудники.ЧастичноеУдержание КАК ЧастичноеУдержание,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияСотрудники.СуммаЧастичногоУдержания КАК СуммаЧастичногоУдержания,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияСотрудники.ПроцентЧастичногоУдержания КАК ПроцентЧастичногоУдержания
		|ИЗ
		|	Документ.ПрикреплениеКПрограммамМедицинскогоСтрахования.Сотрудники КАК ПрикреплениеКПрограммамМедицинскогоСтрахованияСотрудники
		|ГДЕ
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияСотрудники.Ссылка = &Ссылка";
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция ПрограммыСтрахованияСотрудников(ПрикреплениеСсылка)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ПрикреплениеСсылка);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияПрограммыСтрахованияСотрудников.Сотрудник КАК Сотрудник,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияПрограммыСтрахованияСотрудников.ПрограммаСтрахования КАК ПрограммаСтрахования,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияПрограммыСтрахованияСотрудников.СтраховаяПремия КАК СтраховаяПремия,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияПрограммыСтрахованияСотрудников.ДатаНачала КАК ДатаНачала,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияПрограммыСтрахованияСотрудников.ДатаОкончания КАК ДатаОкончания
		|ИЗ
		|	Документ.ПрикреплениеКПрограммамМедицинскогоСтрахования.ПрограммыСтрахованияСотрудников КАК ПрикреплениеКПрограммамМедицинскогоСтрахованияПрограммыСтрахованияСотрудников
		|ГДЕ
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияПрограммыСтрахованияСотрудников.Ссылка = &Ссылка";
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция РасширенияПрограммСтрахованияСотрудников(ПрикреплениеСсылка)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ПрикреплениеСсылка);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияРасширенияПрограммСтрахованияСотрудников.Сотрудник КАК Сотрудник,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияРасширенияПрограммСтрахованияСотрудников.РасширениеСтрахования КАК РасширениеСтрахования,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияРасширенияПрограммСтрахованияСотрудников.СтраховаяПремия КАК СтраховаяПремия,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияРасширенияПрограммСтрахованияСотрудников.ДатаНачала КАК ДатаНачала,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияРасширенияПрограммСтрахованияСотрудников.ДатаОкончания КАК ДатаОкончания
		|ИЗ
		|	Документ.ПрикреплениеКПрограммамМедицинскогоСтрахования.РасширенияПрограммСтрахованияСотрудников КАК ПрикреплениеКПрограммамМедицинскогоСтрахованияРасширенияПрограммСтрахованияСотрудников
		|ГДЕ
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияРасширенияПрограммСтрахованияСотрудников.Ссылка = &Ссылка";
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция РодственникиПрикрепления(ПрикреплениеСсылка)

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ПрикреплениеСсылка);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияРодственники.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияРодственники.ДатаПрикрепления КАК ДатаПрикрепления,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияРодственники.ДатаОткрепления КАК ДатаОткрепления,
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияРодственники.ПрограммыСтрахования КАК ПрограммыСтрахования,
