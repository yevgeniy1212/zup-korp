
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// ЗУПК
	СобытияФормЗУПК.ПриСозданииНаСервере(ЭтаФорма, Отказ, СтандартнаяОбработка);
	// ЗУПК
	
	Если Параметры.Свойство("РабочееМесто") Тогда
		РабочееМесто = Параметры.РабочееМесто;
	КонецЕсли;
	
	МедицинскийОсмотр = Перечисления.ВидыОбследований.МедицинскийОсмотр;
	ПсихиатрическоеОсвидетельствование = Перечисления.ВидыОбследований.ПсихиатрическоеОсвидетельствование;
	
	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьПсихиатрическиеОсвидетельствования") Тогда
		Элементы.Переместить(Элементы.ВредныеФакторыИВидыРаботМедицинские, Элементы.ВредныеФакторыГруппа);
	КонецЕсли;
	
	ВредныеФакторыИВидыРаботМедицинские.Очистить();
	ВредныеФакторыИВидыРаботПсихиатрические.Очистить();
	Для Каждого ВредныйФактор Из Параметры.ВредныеФакторы Цикл
		Если ВредныйФактор.ВидОсмотра = МедицинскийОсмотр Тогда
			ВредныеФакторыИВидыРаботМедицинские.Добавить().ВредныйФактор = ВредныйФактор;
		Иначе
			ВредныеФакторыИВидыРаботПсихиатрические.Добавить().ВредныйФактор = ВредныйФактор;
		КонецЕсли;
	КонецЦикла;
	
	ВредныеФакторыИВидыРаботМедицинские.Сортировать("ВредныйФактор");
	ВредныеФакторыИВидыРаботПсихиатрические.Сортировать("ВредныйФактор");
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаОК(Команда)
	
	МассивВредныхФакторов = Новый Массив();
	
	ПараметрЗакрытия = Новый Структура;

	Отказ = Ложь;
	
	Для Каждого СтрокаВредныйФактор Из ВредныеФакторыИВидыРаботМедицинские Цикл
		ИндексСтроки = ВредныеФакторыИВидыРаботМедицинские.Индекс(СтрокаВредныйФактор);
		ПроверитьЗаполнениеВредногоФактора(
			СтрокаВредныйФактор.ВредныйФактор, ИндексСтроки, "ВредныеФакторыИВидыРаботМедицинские", Отказ);
		МассивВредныхФакторов.Добавить(СтрокаВредныйФактор.ВредныйФактор);
	КонецЦикла;
	
	Для Каждого СтрокаВредныйФактор Из ВредныеФакторыИВидыРаботПсихиатрические Цикл
		ИндексСтроки = ВредныеФакторыИВидыРаботПсихиатрические.Индекс(СтрокаВредныйФактор);
		ПроверитьЗаполнениеВредногоФактора(
			СтрокаВредныйФактор.ВредныйФактор, ИндексСтроки, "ВредныеФакторыИВидыРаботПсихиатрические", Отказ);
		МассивВредныхФакторов.Добавить(СтрокаВредныйФактор.ВредныйФактор);
	КонецЦикла;
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрЗакрытия.Вставить("ВредныеФакторы", МассивВредныхФакторов);
	ПараметрЗакрытия.Вставить("РабочееМесто", РабочееМесто);
	
	Закрыть(ПараметрЗакрытия);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПроверитьЗаполнениеВредногоФактора(ВредныйФактор, ИндексСтроки, ИмяТаблицы, Отказ)
	
	Если Не ЗначениеЗаполнено(ВредныйФактор) Тогда
		ТекстСообщения = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения(,, НСтр("ru = 'Вредный фактор'"));
		Поле = ИмяТаблицы + "["+ Формат(ИндексСтроки, "ЧДЦ=; ЧГ=0") +"].ВредныйФактор";
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения, , Поле, "", Отказ);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти