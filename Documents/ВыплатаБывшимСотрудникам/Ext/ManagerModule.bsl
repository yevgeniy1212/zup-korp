	|	ВыплатаБывшимСотрудникам.Ссылка.ДолжностьИсполнителя КАК ДолжностьИсполнителя,
	|	ВыплатаБывшимСотрудникам.Ссылка.ОснованиеПодписиИсполнителя КАК ОснованиеПодписиИсполнителя
	|ИЗ
	|	Документ.ВыплатаБывшимСотрудникам.НачисленияУдержанияВзносы КАК ВыплатаБывшимСотрудникам
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТБанковскиеСчета КАК БанковскиеСчета
	|		ПО ВыплатаБывшимСотрудникам.ФизическоеЛицо = БанковскиеСчета.ФизическоеЛицо
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТФИООтветственныхЛиц КАК ФИООтветственныхЛиц
	|		ПО ВыплатаБывшимСотрудникам.Ссылка = ФИООтветственныхЛиц.Ссылка
	|			И ВыплатаБывшимСотрудникам.Ссылка.Исполнитель = ФИООтветственныхЛиц.ФизическоеЛицо
	// ЗУПК
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_НалогиВзносыОтчисления КАК НалогиВзносыОтчисления
	|		ПО ВыплатаБывшимСотрудникам.Ссылка = НалогиВзносыОтчисления.Ссылка
	|			И ВыплатаБывшимСотрудникам.ФизическоеЛицо = НалогиВзносыОтчисления.ФизическоеЛицо
	// ЗУПК
	|ГДЕ
	|	ВыплатаБывшимСотрудникам.Ссылка В(&МассивОбъектов)
	|ИТОГИ
	|	СУММА(Начислено),
	|	СУММА(СуммаВычета),
	|	СУММА(Удержано),
	// ЗУПК
	|	СУММА(ИПН),
	|	СУММА(ОПВ),
	|	СУММА(ВОСМС),
	|	СУММА(СН),
	|	СУММА(СО),
	|	СУММА(ОПВР),
	|	СУММА(ООСМС),
	// ЗУПК
	|	СУММА(КВыплате),
	|	МАКСИМУМ(ИсполнительРасшифровкаПодписи)
	|ПО
	|	Ссылка";
	
	// ЗУПК
	МассивНалоговВзносовОтчислений = Новый Массив;
	МассивНалоговВзносовОтчислений.Добавить(Перечисления.ВидыНалоговВзносовОтчислений.ЕП);
	МассивНалоговВзносовОтчислений.Добавить(Перечисления.ВидыНалоговВзносовОтчислений.ОППВ);
	Запрос.УстановитьПараметр("ВидыНалоговВзносовОтчислений", МассивНалоговВзносовОтчислений);
	// ЗУПК
	РезультатЗапроса = Запрос.Выполнить();
	ГруппировкаПоДокументу = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ГруппировкаПоДокументу.Следующий() Цикл
		
		ДанныеПечати = Новый Структура;
		ДанныеПечати.Вставить("Ссылка", ГруппировкаПоДокументу.Ссылка);
		ДанныеПечати.Вставить("НазваниеОрганизации", ГруппировкаПоДокументу.НазваниеОрганизации);
		ДанныеПечати.Вставить("НазваниеПодразделения", ГруппировкаПоДокументу.Подразделение);
		ДанныеПечати.Вставить("ЕдиницаИзмерения", ВалютаУчета.НаименованиеПолное);
		ДанныеПечати.Вставить("ВидВыплаты", ГруппировкаПоДокументу.ВидВыплаты);
		ДанныеПечати.Вставить("ДатаДокумента", Формат(ГруппировкаПоДокументу.Дата, "ДЛФ=D"));
		ДанныеПечати.Вставить("НомерДокумента", ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(ГруппировкаПоДокументу.Номер, Истина, Истина));
		ДанныеПечати.Вставить("ДолжностьИсполнителя", ГруппировкаПоДокументу.ДолжностьИсполнителя);
		ДанныеПечати.Вставить("ИсполнительРасшифровкаПодписи", ГруппировкаПоДокументу.ИсполнительРасшифровкаПодписи);
		ДанныеПечати.Вставить("ОснованиеПодписиИсполнителя", ГруппировкаПоДокументу.ОснованиеПодписиИсполнителя);
		ДанныеПечати.Вставить("ТабличнаяЧастьДокумента", Новый Массив);
		// ЗУПК
		ДанныеПечати.Вставить("ЕстьИПН", Ложь);
		ДанныеПечати.Вставить("ЕстьОПВ", Ложь);
		ДанныеПечати.Вставить("ЕстьВОСМС", Ложь);
		ДанныеПечати.Вставить("ЕстьСН", Ложь);
		ДанныеПечати.Вставить("ЕстьСО", Ложь);
		ДанныеПечати.Вставить("ЕстьОПВР", Ложь);
		ДанныеПечати.Вставить("ЕстьООСМС", Ложь);
		// ЗУПК
		
		ГруппировкаПоСотрудникам = ГруппировкаПоДокументу.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
		Пока ГруппировкаПоСотрудникам.Следующий() Цикл
			
			СтрокаДанныхПечати = Новый Структура;
			СтрокаДанныхПечати.Вставить("СотрудникИРеквизиты", "");
			СтрокаДанныхПечати.Вставить("Начислено", ГруппировкаПоСотрудникам.Начислено);
			СтрокаДанныхПечати.Вставить("НДФЛ", ГруппировкаПоСотрудникам.НДФЛ);
			СтрокаДанныхПечати.Вставить("СуммаВычета", ГруппировкаПоСотрудникам.СуммаВычета);
			СтрокаДанныхПечати.Вставить("Удержано", ГруппировкаПоСотрудникам.Удержано);
			// ЗУПК
			СтрокаДанныхПечати.Вставить("ИПН", ГруппировкаПоСотрудникам.ИПН);
			СтрокаДанныхПечати.Вставить("ОПВ", ГруппировкаПоСотрудникам.ОПВ);
			СтрокаДанныхПечати.Вставить("ВОСМС", ГруппировкаПоСотрудникам.ВОСМС);
			СтрокаДанныхПечати.Вставить("СН", ГруппировкаПоСотрудникам.СН);
			СтрокаДанныхПечати.Вставить("СО", ГруппировкаПоСотрудникам.СО);
			СтрокаДанныхПечати.Вставить("ОПВР", ГруппировкаПоСотрудникам.ОПВР);
			СтрокаДанныхПечати.Вставить("ООСМС", ГруппировкаПоСотрудникам.ООСМС);
			// ЗУПК
			СтрокаДанныхПечати.Вставить("КВыплате", ГруппировкаПоСотрудникам.КВыплате);
			
			ДанныеФизическогоЛица = КадровыйУчет.КадровыеДанныеФизическихЛиц(
				Истина, ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ГруппировкаПоСотрудникам.ФизическоеЛицо), 
				"ФИОПолные,Пол", ГруппировкаПоДокументу.Дата);
			
			Если ДанныеФизическогоЛица.Количество() > 0 Тогда
				СтрокаДанныхПечати.СотрудникИРеквизиты = ДанныеФизическогоЛица[0].ФИОПолные;
			КонецЕсли;

			Если Не ПустаяСтрока(ГруппировкаПоСотрудникам.НомерСчета) Тогда
				СтрокаПодстановки = НСтр("ru = '%1 (счет %2 в %3)'");
				СтрокаДанныхПечати.СотрудникИРеквизиты = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(СтрокаПодстановки,
					СтрокаДанныхПечати.СотрудникИРеквизиты, ГруппировкаПоСотрудникам.НомерСчета, ГруппировкаПоСотрудникам.Банк);
			КонецЕсли;
			
			ДанныеПечати.ТабличнаяЧастьДокумента.Добавить(СтрокаДанныхПечати);
			
            // ЗУПК
			Если ГруппировкаПоСотрудникам.ИПН <> 0 И НЕ ДанныеПечати.ЕстьИПН Тогда
				ДанныеПечати.ЕстьИПН = Истина;
			КонецЕсли;
			Если ГруппировкаПоСотрудникам.ОПВ <> 0 И НЕ ДанныеПечати.ЕстьОПВ Тогда
				ДанныеПечати.ЕстьОПВ = Истина;
			КонецЕсли;
			Если ГруппировкаПоСотрудникам.ВОСМС <> 0 И НЕ ДанныеПечати.ЕстьВОСМС Тогда
				ДанныеПечати.ЕстьВОСМС = Истина;
			КонецЕсли;
			Если ГруппировкаПоСотрудникам.СН <> 0 И НЕ ДанныеПечати.ЕстьСН Тогда
				ДанныеПечати.ЕстьСН = Истина;
			КонецЕсли;
			Если ГруппировкаПоСотрудникам.СО <> 0 И НЕ ДанныеПечати.ЕстьСО Тогда
				ДанныеПечати.ЕстьСО = Истина;
			КонецЕсли;
			Если ГруппировкаПоСотрудникам.ОПВР <> 0 И НЕ ДанныеПечати.ЕстьОПВР Тогда
				ДанныеПечати.ЕстьОПВР = Истина;
			КонецЕсли;
			Если ГруппировкаПоСотрудникам.ООСМС <> 0 И НЕ ДанныеПечати.ЕстьООСМС Тогда
				ДанныеПечати.ЕстьООСМС = Истина;
			КонецЕсли;
            // ЗУПК
			
		КонецЦикла;
		
		ДанныеПечатиОбъектов.Вставить(ГруппировкаПоДокументу.Ссылка, ДанныеПечати);
		
	КонецЦикла;
	
	Возврат ДанныеПечатиОбъектов;
	
КонецФункции

// ЗУПК
Процедура ВывестиКолонки(Макет, ДокументРезультат, ИмяОбласти, ДанныеДокумента, ДанныеСотрудника = Неопределено)
	
	ОбластьМакетПолучатель = Макет.ПолучитьОбласть(ИмяОбласти + "|СотрудникИРеквизиты");
	ОбластьМакетСуммаДохода = Макет.ПолучитьОбласть(ИмяОбласти + "|Начислено");
	ОбластьМакетИПН = Макет.ПолучитьОбласть(ИмяОбласти + "|НалогВзнос");
	ОбластьМакетОПВ = Макет.ПолучитьОбласть(ИмяОбласти + "|НалогВзнос");
	ОбластьМакетВОСМС = Макет.ПолучитьОбласть(ИмяОбласти + "|НалогВзнос");
	ОбластьМакетСН = Макет.ПолучитьОбласть(ИмяОбласти + "|НалогВзнос");
	ОбластьМакетСО = Макет.ПолучитьОбласть(ИмяОбласти + "|НалогВзнос");
	ОбластьМакетОПВР = Макет.ПолучитьОбласть(ИмяОбласти + "|НалогВзнос");
	ОбластьМакетООСМС = Макет.ПолучитьОбласть(ИмяОбласти + "|НалогВзнос");
	ОбластьМакетУдержано = Макет.ПолучитьОбласть(ИмяОбласти + "|Удержано");
	ОбластьМакетКВыплате = Макет.ПолучитьОбласть(ИмяОбласти + "|КВыплате");
	
	Если ДанныеСотрудника = Неопределено Тогда
		НомерКолонки = 1;
		ОбластьМакетПолучатель.Параметры.СотрудникИРеквизитыНомерКолонки = НомерКолонки;
		НомерКолонки = НомерКолонки + 1;
		ОбластьМакетСуммаДохода.Параметры.НачисленоНомерКолонки	 = НомерКолонки;
		НомерКолонки = НомерКолонки + 1;
		Если ДанныеДокумента.ЕстьИПН Тогда
			ОбластьМакетИПН.Параметры.НалогВзносНаименование = НСтр("ru = 'ИПН'");
			ОбластьМакетИПН.Параметры.НалогВзносНомерКолонки = НомерКолонки;
			НомерКолонки = НомерКолонки + 1;
		КонецЕсли;
		Если ДанныеДокумента.ЕстьОПВ Тогда
			ОбластьМакетОПВ.Параметры.НалогВзносНаименование = НСтр("ru = 'ОПВ'");
			ОбластьМакетОПВ.Параметры.НалогВзносНомерКолонки = НомерКолонки;
			НомерКолонки = НомерКолонки + 1;
		КонецЕсли;
		Если ДанныеДокумента.ЕстьВОСМС Тогда
			ОбластьМакетВОСМС.Параметры.НалогВзносНаименование = НСтр("ru = 'ВОСМС'");
			ОбластьМакетВОСМС.Параметры.НалогВзносНомерКолонки = НомерКолонки;
			НомерКолонки = НомерКолонки + 1;
		КонецЕсли;
		Если ДанныеДокумента.ЕстьСН Тогда
			ОбластьМакетСН.Параметры.НалогВзносНаименование = НСтр("ru = 'СН'");
			ОбластьМакетСН.Параметры.НалогВзносНомерКолонки = НомерКолонки;
			НомерКолонки = НомерКолонки + 1;
		КонецЕсли;
		Если ДанныеДокумента.ЕстьСО Тогда
			ОбластьМакетСО.Параметры.НалогВзносНаименование = НСтр("ru = 'СО'");
			ОбластьМакетСО.Параметры.НалогВзносНомерКолонки = НомерКолонки;
			НомерКолонки = НомерКолонки + 1;
		КонецЕсли;
		Если ДанныеДокумента.ЕстьОПВР Тогда
			ОбластьМакетОПВР.Параметры.НалогВзносНаименование = НСтр("ru = 'ОПВР'");
			ОбластьМакетОПВР.Параметры.НалогВзносНомерКолонки = НомерКолонки;
			НомерКолонки = НомерКолонки + 1;
		КонецЕсли;
		Если ДанныеДокумента.ЕстьООСМС Тогда
			ОбластьМакетООСМС.Параметры.НалогВзносНаименование = НСтр("ru = 'ООСМС'");
			ОбластьМакетООСМС.Параметры.НалогВзносНомерКолонки = НомерКолонки;
			НомерКолонки = НомерКолонки + 1;
		КонецЕсли;
		ОбластьМакетУдержано.Параметры.УдержаноНомерКолонки = НомерКолонки;
		НомерКолонки = НомерКолонки + 1;
		ОбластьМакетКВыплате.Параметры.КВыплатеНомерКолонки = НомерКолонки;
	Иначе
		ОбластьМакетПолучатель.Параметры.Заполнить(ДанныеСотрудника);
		ОбластьМакетСуммаДохода.Параметры.Заполнить(ДанныеСотрудника);
		Если ДанныеДокумента.ЕстьИПН Тогда
			ОбластьМакетИПН.Параметры.НалогВзнос = ДанныеСотрудника.ИПН;
		КонецЕсли;
		Если ДанныеДокумента.ЕстьОПВ Тогда
			ОбластьМакетОПВ.Параметры.НалогВзнос = ДанныеСотрудника.ОПВ;
		КонецЕсли;
		Если ДанныеДокумента.ЕстьВОСМС Тогда
			ОбластьМакетВОСМС.Параметры.НалогВзнос = ДанныеСотрудника.ВОСМС;
		КонецЕсли;
		Если ДанныеДокумента.ЕстьСН Тогда
			ОбластьМакетСН.Параметры.НалогВзнос = ДанныеСотрудника.СН;
		КонецЕсли;
		Если ДанныеДокумента.ЕстьСО Тогда
			ОбластьМакетСО.Параметры.НалогВзнос = ДанныеСотрудника.СО;
		КонецЕсли;
		Если ДанныеДокумента.ЕстьОПВР Тогда
			ОбластьМакетОПВР.Параметры.НалогВзнос = ДанныеСотрудника.ОПВР;
		КонецЕсли;
		Если ДанныеДокумента.ЕстьООСМС Тогда
			ОбластьМакетООСМС.Параметры.НалогВзнос = ДанныеСотрудника.ООСМС;
		КонецЕсли;
		ОбластьМакетУдержано.Параметры.Заполнить(ДанныеСотрудника);
		ОбластьМакетКВыплате.Параметры.Заполнить(ДанныеСотрудника);
	КонецЕсли;
	
	ДокументРезультат.Вывести(ОбластьМакетПолучатель);
	ДокументРезультат.Присоединить(ОбластьМакетСуммаДохода);
	Если ДанныеДокумента.ЕстьИПН Тогда
		ДокументРезультат.Присоединить(ОбластьМакетИПН);
	КонецЕсли;
	Если ДанныеДокумента.ЕстьОПВ Тогда
		ДокументРезультат.Присоединить(ОбластьМакетОПВ);
	КонецЕсли;
	Если ДанныеДокумента.ЕстьВОСМС Тогда
		ДокументРезультат.Присоединить(ОбластьМакетВОСМС);
	КонецЕсли;
	Если ДанныеДокумента.ЕстьСН Тогда
		ДокументРезультат.Присоединить(ОбластьМакетСН);
	КонецЕсли;
	Если ДанныеДокумента.ЕстьСО Тогда
		ДокументРезультат.Присоединить(ОбластьМакетСО);
	КонецЕсли;
	Если ДанныеДокумента.ЕстьОПВР Тогда
		ДокументРезультат.Присоединить(ОбластьМакетОПВР);
	КонецЕсли;
	Если ДанныеДокумента.ЕстьООСМС Тогда
		ДокументРезультат.Присоединить(ОбластьМакетООСМС);
	КонецЕсли;
	ДокументРезультат.Присоединить(ОбластьМакетУдержано);
	ДокументРезультат.Присоединить(ОбластьМакетКВыплате);
	
КонецПроцедуры
// ЗУПК

#КонецОбласти

Функция ДанныеДляБухучетаЗарплатыПервичныхДокументов(Объект) Экспорт
	
	Возврат УчетПрочихДоходов.ДанныеДляБухучетаЗарплатыПервичныхДокументов(Объект);
	
КонецФункции

