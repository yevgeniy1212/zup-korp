&НаСервере
Функция ИсключаемыеРегистраторы()
	
	Результат = Новый Массив;
	
	Если ЗначениеЗаполнено(СсылкаНаОбъект) Тогда
		Результат.Добавить(СсылкаНаОбъект);
	КонецЕсли;
	
	ПараметрыИсправленного = Неопределено;
	Если ИсправлениеДокументовЗарплатаКадрыКлиентСервер.ЭтоИсправление(ЭтотОбъект, ПараметрыИсправленного) Тогда
		Результат.Добавить(ПараметрыИсправленного.Ссылка);
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Результат,
			ИсправлениеДокументовЗарплатаКадры.ПолучитьДокументыЦепочкиИсправлений(ПараметрыИсправленного.Ссылка));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция ДеньУвольненияЯвляетсяРабочимДнем(Организация, ПериодРегистрации) Экспорт

	Возврат ЗарплатаКадрыРКПовтИсп.ДеньУвольненияЯвляетсяРабочимДнем(ЗарплатаКадрыПовтИсп.ГоловнаяОрганизация(Организация), ПериодРегистрации)
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ОписаниеТаблицыНалогиВзносыОтчисления()
	
	Описание = РасчетЗарплатыРасширенныйКлиентСервер.ОписаниеТаблицыРасчета();
	Описание.ИмяТаблицы = "НалогиВзносыОтчисления";
	Описание.ПутьКДанным = "Объект.НалогиВзносыОтчисления";
	Описание.ИмяПоляДляВставкиПоказателей = "НалогВзнос";
	Описание.ИмяПоляРезультат = "НалогВзнос";
	Описание.ИмяРеквизитаПериод = "МесяцНалоговогоПериода";
	Описание.НомерТаблицы = 3.5;
	Описание.СодержитПолеВидРасчета = Ложь;
	Описание.СодержитПолеСотрудник = Истина;
    Описание.ИмяРеквизитаСотрудник = "ФизическоеЛицо";
    Описание.ПроверяемыеРеквизиты = "ФизическоеЛицо,МесяцНалоговогоПериода";
	
	Описание.ОтменятьВсеИсправления	= Ложь;
	
	Возврат Описание;
	
КонецФункции

&НаСервере
Процедура ОбновитьДанныеНалогиВзносыОтчисленияНаСервере(АдресВременногоХранилища)
	
	ПараметрыДанных = ПолучитьИзВременногоХранилища(АдресВременногоХранилища);
	
	КонтролируемыеПоля = Новый Структура;
	ОписаниеДокумента = ОписаниеДокумента(ЭтаФорма);
	ВидНалогаВзносаОтчисления = ПараметрыДанных.ВидНалогаВзносаОтчисления;
    ИзмененныеДанные.Загрузить(ПараметрыДанных.ИзмененныеДанные);
    
    ОтборСтрок = Новый Структура("ФизическоеЛицо, ВидНалогаВзносаОтчисления", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ПараметрыДанных.ФизическоеЛицо), ВидНалогаВзносаОтчисления);
    УчетНалоговВзносовОтчисленийРасширенный.ЗаменитьСтрокиНалогиВзносыОтчисления(Объект.НалогиВзносыОтчисления, Объект.ВычетыИПН, Объект.ДоходыНеПодлежащиеНалогообложению, ПараметрыДанных, КонтролируемыеПоля, ОписаниеДокумента, ОтборСтрок, Ложь, "ФизическоеЛицо,ВидНалогаВзносаОтчисления");
    
    Если ИзмененныеДанные.Количество() = 0 Тогда
        Возврат;
    КонецЕсли;
	Модифицированность = Истина;
    
    ОбновитьИтоги(ЭтотОбъект);
    ОбновитьИтогиВычеты(ЭтаФорма);

	ЗарплатаКадрыРасширенныйКлиентСервер.КлючевыеРеквизитыЗаполненияФормыУстановитьОтображениеПредупреждения(ЭтаФорма);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьИтогиВычеты(Форма)
	
	ДатаКонтроля = '2018-01-01';
	
	Если Форма.Объект.ПериодРегистрации < ДатаКонтроля Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Элемент Из Форма.Объект.НалогиВзносыОтчисления Цикл
		
		РасчетВычетаИтого(Элемент.ПолучитьИдентификатор());
		
	КонецЦикла;
	
КонецПроцедуры

