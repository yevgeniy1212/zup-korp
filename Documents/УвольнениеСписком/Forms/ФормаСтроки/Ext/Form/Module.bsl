Процедура КомандаПровестиИЗакрыть(Команда)
	
	ВыполнитьОбработчикиОжиданияФормы();
	
	ПараметрыЗаписи = Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение);
	ЗаписатьНаКлиенте(Истина, ПараметрыЗаписи);
	
КонецПроцедуры

