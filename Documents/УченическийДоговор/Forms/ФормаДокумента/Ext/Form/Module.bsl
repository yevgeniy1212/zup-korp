КонецПроцедуры
// Конец СтандартныеПодсистемы.Свойства

&НаКлиенте
Процедура ВычислитьДатуОкончанияОбязательств()

	Если Объект.Обязательства.Количество() = 0 Тогда
		Объект.ДатаОкончанияОбязательств = Объект.ДатаНачалаОбязательств;
	Иначе
		ПоследняяСтрока = Объект.Обязательства[Объект.Обязательства.Количество()-1];
		Объект.ДатаОкончанияОбязательств = ПоследняяСтрока.ДатаОкончания;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура НачатьЗаполнениеПоОснованию()
	
	ПоказатьВопрос(Новый ОписаниеОповещения("ЗавершитьЗаполнениеПоОснованию", ЭтотОбъект), 
		НСтр("ru = 'Данные договора будут заполнены из документа основания. Продолжить?'"), РежимДиалогаВопрос.ДаНет);

КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьЗаполнениеПоОснованию(Результат, ДополнительныеПараметры) Экспорт

	Если Результат <> КодВозвратаДиалога.Да Тогда
		Объект.Основание = БылоОснование;
		Возврат;
	КонецЕсли;

	ЗаполнитьПоОснованиюНаСервере(Объект.Основание);
	УстановитьДоступностьДанныхМероприятия(ЭтотОбъект);
	ЗаполнитьБылоОснование(ЭтотОбъект);

КонецПроцедуры

&НаКлиенте
Процедура НачатьЗаполнениеПоМероприятию()

	ПоказатьВопрос(Новый ОписаниеОповещения("ЗавершитьЗаполнениеПоМероприятию", ЭтотОбъект), 
		НСтр("ru = 'Данные договора будут заполнены из мероприятия. Продолжить?'"), РежимДиалогаВопрос.ДаНет);

КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьЗаполнениеПоМероприятию(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = КодВозвратаДиалога.Да Тогда
		ЗаполнитьПоОснованиюНаСервере(Объект.Мероприятие);
		ВычислитьДатуОкончанияОбязательств();
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьНадпись()
	
	ТекущаяСтрока = Элементы.Обязательства.ТекущиеДанные;
	Если ТекущаяСтрока <> Неопределено И (ТекущаяСтрока.ПериодРаботы + ТекущаяСтрока.Сумма) > 0 Тогда
		Элементы.Обязательства.Подсказка = СтрШаблон(
					НСтр("ru = 'В случае увольнения после обучения без уважительных причин до %1 мес. сотрудник обязан возместить расходы, 
						// ЗУПК
						 |понесенные работодателем на его обучение в сумме %2 тг.'"), 
						// ЗУПК
					ТекущаяСтрока.ПериодРаботы, 
					ТекущаяСтрока.Сумма);
	Иначе
		Элементы.Обязательства.Подсказка = "";
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОрганизацияПриИзмененииНаСервере()
	ЗаполнитьДанныеФормыПоОрганизации();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеФормыПоОрганизации()
	
	// ЗарплатаКадрыПодсистемы.ПодписиДокументов
	ПодписиДокументов.ЗаполнитьПодписиПоОрганизации(ЭтаФорма);
	// Конец ЗарплатаКадрыПодсистемы.ПодписиДокументов
	
КонецПроцедуры

&НаСервере
Процедура ПриПолученииДанныхНаСервере()
	
	ЗаполнитьРеквизитыФормыПоМероприятию();
	ЗаполнитьДополнительныеРеквизитыОбязательств();
	УстановитьДоступностьДанныхМероприятия(ЭтотОбъект);
	УстановитьДоступностьОснования(ЭтотОбъект);
	ЗаполнитьБылоОснование(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ЗаполнитьБылоОснование(Форма)
	Форма.БылоОснование = Форма.Объект.Основание;
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьДоступностьДанныхМероприятия(Форма)
	
	Элементы = Форма.Элементы;
	Объект = Форма.Объект;
	
	Элементы.Мероприятие.ТолькоПросмотр = ЗначениеЗаполнено(Объект.Основание);
	Элементы.ДатаНачалаУчебы.ТолькоПросмотр = ЗначениеЗаполнено(Объект.Основание);
	Элементы.ДатаОкончанияУчебы.ТолькоПросмотр = ЗначениеЗаполнено(Объект.Основание);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьДоступностьОснования(Форма)
	
	Элементы = Форма.Элементы;
	Объект = Форма.Объект;
	
	Элементы.Основание.ТолькоПросмотр = Не ЗначениеЗаполнено(Объект.Организация) Или Не ЗначениеЗаполнено(Объект.ФизическоеЛицо);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДополнительныеРеквизитыОбязательств()

	Для Каждого Обязательство Из Объект.Обязательства Цикл
		Обязательство.Процент = ?(СтоимостьМероприятия = 0, 0, Окр(Обязательство.Сумма / СтоимостьМероприятия * 100, 2));
		Обязательство.ДатаОкончания = 
			НачалоДня(ДобавитьМесяц(Объект.ДатаНачалаОбязательств, Обязательство.ПериодРаботы))-1;
	КонецЦикла; 

	Объект.Обязательства.Сортировать("ПериодРаботы");
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоОснованиюНаСервере(Ссылка)

	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	ДокументОбъект.Заполнить(Ссылка);
	ЗначениеВРеквизитФормы(ДокументОбъект,"Объект");
	
	ПриПолученииДанныхНаСервере();

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРеквизитыФормыПоМероприятию()
	СтоимостьМероприятия = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Мероприятие, "Стоимость");
КонецПроцедуры

