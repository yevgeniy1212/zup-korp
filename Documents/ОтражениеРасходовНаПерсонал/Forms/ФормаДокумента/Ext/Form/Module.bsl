&НаСервере
Процедура ПриИзмененииПодразделенияНаСервере()
	
	Если СтруктураПредприятияНеСоответствуетСтруктуреЮридическихЛиц Тогда
		Возврат;
	КонецЕсли;
	
	ИсточникПодразделенияПредприятия = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Подразделение, "Источник");
	ЭтоПодразделение = ТипЗнч(ИсточникПодразделенияПредприятия) = Тип("СправочникСсылка.ПодразделенияОрганизаций");
	
КонецПроцедуры

&НаСервере
Процедура ПриПолученииДанныхНаСервере()
	
	ЗарплатаКадрыКлиентСервер.ЗаполнитьМесяцПоДате(ЭтотОбъект, "Объект.ПериодРегистрации", "ПериодРегистрацииСтрокой");
	
	СтруктураПредприятияНеСоответствуетСтруктуреЮридическихЛиц = ПолучитьФункциональнуюОпциюФормы("СтруктураПредприятияНеСоответствуетСтруктуреЮридическихЛиц");
	
	ПриИзмененииПодразделенияНаСервере();
	
	ДоступноЗаполнениеПоВсемПодразделениям = ОтражениеРасходовНаПерсонал.ОтражениеРасходовНаПерсоналОднимДокументомПоВсемПодразделениямДоступно();
	
	Если Не ДоступноЗаполнениеПоВсемПодразделениям Тогда
		// Для потребителей, в которых не поддерживается отражение в финансовом учете по всем подразделениям
		// отключаем возможность управления режимом.
		Элементы.ЗаполнятьПоВсемПодразделениям.Видимость = Ложь;
		Элементы.ЗаполнятьПоОдномуПодразделению.Видимость = Ложь;
		Элементы.Подразделение.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Авто;
		ЗаполнятьПоВсемПодразделениям = 0;
	ИначеЕсли Не ЗначениеЗаполнено(Объект.Подразделение) Тогда
		ЗаполнятьПоВсемПодразделениям = 1;
	КонецЕсли;
	
	УстановитьСвойстваПоляПодразделения();
	
КонецПроцедуры

&НаКлиенте
Процедура ПровестиДокумент()
	
	ОчиститьСообщения();
	
	Если Объект.ПометкаУдаления Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Помеченный на удаление документ не может быть проведен.'"));
		Возврат;
	КонецЕсли;
	
	Если Не ПроверитьЗаполнение() Тогда
		Возврат;
	КонецЕсли;
	
	ОбработатьПередПроведением();
	НачатьПроведение();
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьПередПроведением()
	
	Если Не (Модифицированность Или Объект.Проведен) Тогда
		Возврат;
	КонецЕсли;
	
	// Преобразовываем данные формы в объект, чтобы записать его.
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	ДокументОбъект.Проведен = Ложь;
	ДокументОбъект.Записать();
	// После записи сразу же перечитываем объект, чтобы избежать различия версий.
	ЗначениеВРеквизитФормы(ДокументОбъект, "Объект");
	ПриПолученииДанныхНаСервере();
	Модифицированность = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьПроведение() Экспорт 
	
	ДлительнаяОперация = ДлительнаяОперацияПроведения();
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ТекстСообщения = НСтр("ru = 'Проведение документа ""Отражение зарплаты в финансовом учете""'");
	ПараметрыОжидания.ВыводитьПрогрессВыполнения = Истина;
	ПараметрыОжидания.ВыводитьСообщения = Истина;
	
	Обработчик = Новый ОписаниеОповещения("ЗавершитьПроведение", ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Обработчик, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервере
Функция ДлительнаяОперацияПроведения()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	
	Возврат ДлительныеОперации.ВыполнитьПроцедуру(
		ПараметрыВыполнения, "Документы.ОтражениеРасходовНаПерсонал.ВыполнитьПроведение", Объект.Ссылка);
	
КонецФункции

&НаКлиенте
Процедура ЗавершитьПроведение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если Результат.Статус = "Ошибка" Тогда
		ВызватьИсключение Результат.КраткоеПредставлениеОшибки;
	КонецЕсли;
	
	ПроведениеПослеВыполненияДлительнойОперации();
	ОповеститьОбИзменении(Объект.Ссылка);
	ПараметрыОповещения = Новый Структура("РежимЗаписи", РежимЗаписиДокумента.Проведение);
	Оповестить("Запись_ОтражениеРасходовНаПерсонал", ПараметрыОповещения, Объект.Ссылка);
	Если ЗакрыватьПослеЗаписи Тогда
		ПодключитьОбработчикОжидания("ЗакрытьФорму", 0.1, Истина);
	Иначе
		ЗакрыватьПослеЗаписи = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьЗаполнение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если Результат.Статус = "Ошибка" Тогда
		ВызватьИсключение Результат.КраткоеПредставлениеОшибки;
	КонецЕсли;
	
	АдресХранилища = Результат.АдресРезультата;
	ЗаполнениеПослеВыполненияДлительнойОперации();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнениеПослеВыполненияДлительнойОперации()
	
	Объект.НачисленнаяЗарплата.Очистить();
	Объект.Взносы.Очистить();
	Объект.УдержаннаяЗарплата.Очистить();
	Объект.Займы.Очистить();
	Объект.Обучение.Очистить();
	
	СтруктураДанных = ПолучитьИзВременногоХранилища(АдресХранилища);
	Если ТипЗнч(СтруктураДанных) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;
	
	РезультатОтраженияЗарплаты = Неопределено;
	Если СтруктураДанных.Свойство("РезультатОтраженияЗарплаты", РезультатОтраженияЗарплаты) Тогда
		// Перенесем данные в табличные части документа.
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(РезультатОтраженияЗарплаты.Зарплата, Объект.НачисленнаяЗарплата);
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(РезультатОтраженияЗарплаты.СтраховыеВзносы, Объект.Взносы);
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(РезультатОтраженияЗарплаты.УдержаннаяЗарплата, Объект.УдержаннаяЗарплата);
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(РезультатОтраженияЗарплаты.Займы, Объект.Займы);
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(РезультатОтраженияЗарплаты.Обучение, Объект.Обучение);
		
		ЗаполнитьСтатьиАналитикуРасходовПоУмолчанию();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПроведениеПослеВыполненияДлительнойОперации()
	
	Если Не ЗакрыватьПослеЗаписи Тогда
		ДокументОбъект = Объект.Ссылка.ПолучитьОбъект();
		ЗначениеВРеквизитФормы(ДокументОбъект, "Объект");
		ПриПолученииДанныхНаСервере();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакрытьФорму()
	Закрыть();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСтатьиАналитикуРасходовПоУмолчанию()
	
	// Получаем последние используемые значения по совпадающим сочетаниям заполненных полей.
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	НачисленнаяЗарплата.ФизическоеЛицо,
	|	НачисленнаяЗарплата.Подразделение,
	|	НачисленнаяЗарплата.НаправлениеДеятельности,
	|	НачисленнаяЗарплата.СтатьяРасходов,
	|	НачисленнаяЗарплата.АналитикаРасходов
	|ПОМЕСТИТЬ ВТНачисленнаяЗарплата
	|ИЗ
	|	&НачисленнаяЗарплата КАК НачисленнаяЗарплата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Взносы.ФизическоеЛицо,
	|	Взносы.Подразделение,
	|	Взносы.НаправлениеДеятельности,
	|	Взносы.СтатьяРасходов,
	|	Взносы.АналитикаРасходов
	|ПОМЕСТИТЬ ВТВзносы
	|ИЗ
	|	&Взносы КАК Взносы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Удержания.ФизическоеЛицо,
	|	Удержания.Подразделение,
	|	Удержания.НаправлениеДеятельности,
	|	Удержания.СтатьяРасходов,
	|	Удержания.АналитикаРасходов
	|ПОМЕСТИТЬ ВТУдержаннаяЗарплата
	|ИЗ
	|	&УдержаннаяЗарплата КАК Удержания
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Займы.ФизическоеЛицо,
	|	Займы.Подразделение,
	|	Займы.НаправлениеДеятельности,
	|	Займы.СтатьяРасходов,
	|	Займы.АналитикаРасходов
	|ПОМЕСТИТЬ ВТЗаймы
	|ИЗ
	|	&Займы КАК Займы
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Обучение.ФизическоеЛицо,
	|	Обучение.Подразделение,
	|	Обучение.НаправлениеДеятельности,
	|	Обучение.СтатьяРасходов,
	|	Обучение.АналитикаРасходов
	|ПОМЕСТИТЬ ВТОбучение
	|ИЗ
	|	&Обучение КАК Обучение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НачисленнаяЗарплата.ФизическоеЛицо КАК ФизическоеЛицо,
	|	НачисленнаяЗарплата.Подразделение КАК Подразделение,
	|	НачисленнаяЗарплата.НаправлениеДеятельности КАК НаправлениеДеятельности
	|ПОМЕСТИТЬ ВТНезаполненнаяАналитика
	|ИЗ
	|	ВТНачисленнаяЗарплата КАК НачисленнаяЗарплата
	|ГДЕ
	|	НачисленнаяЗарплата.СтатьяРасходов = ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка)
	|	И НачисленнаяЗарплата.АналитикаРасходов = НЕОПРЕДЕЛЕНО
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	Взносы.ФизическоеЛицо,
	|	Взносы.Подразделение,
	|	Взносы.НаправлениеДеятельности
	|ИЗ
	|	ВТВзносы КАК Взносы
	|ГДЕ
	|	Взносы.СтатьяРасходов = ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка)
	|	И Взносы.АналитикаРасходов = НЕОПРЕДЕЛЕНО
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	Удержания.ФизическоеЛицо,
	|	Удержания.Подразделение,
	|	Удержания.НаправлениеДеятельности
	|ИЗ
	|	ВТУдержаннаяЗарплата КАК Удержания
	|ГДЕ
	|	Удержания.СтатьяРасходов = ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка)
	|	И Удержания.АналитикаРасходов = НЕОПРЕДЕЛЕНО
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	Займы.ФизическоеЛицо,
	|	Займы.Подразделение,
	|	Займы.НаправлениеДеятельности
	|ИЗ
	|	ВТЗаймы КАК Займы
	|ГДЕ
	|	Займы.СтатьяРасходов = ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка)
	|	И Займы.АналитикаРасходов = НЕОПРЕДЕЛЕНО
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	Обучение.ФизическоеЛицо,
	|	Обучение.Подразделение,
	|	Обучение.НаправлениеДеятельности
	|ИЗ
	|	ВТОбучение КАК Обучение
	|ГДЕ
	|	Обучение.СтатьяРасходов = ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка)
	|	И Обучение.АналитикаРасходов = НЕОПРЕДЕЛЕНО
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ФизическоеЛицо,
	|	Подразделение,
	|	НаправлениеДеятельности";
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("НачисленнаяЗарплата", Объект.НачисленнаяЗарплата.Выгрузить());
	Запрос.УстановитьПараметр("Взносы", Объект.Взносы.Выгрузить());
	Запрос.УстановитьПараметр("УдержаннаяЗарплата", Объект.УдержаннаяЗарплата.Выгрузить());
	Запрос.УстановитьПараметр("Займы", Объект.Займы.Выгрузить());
	Запрос.УстановитьПараметр("Обучение", Объект.Обучение.Выгрузить());
	Запрос.Выполнить();
	
	СоздатьВТАналитикаДругихДокументов(МенеджерВременныхТаблиц, Объект.Ссылка, Объект.Дата);
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	АналитикаДругихДокументов.ФизическоеЛицо,
	|	АналитикаДругихДокументов.Подразделение,
	|	АналитикаДругихДокументов.НаправлениеДеятельности,
	|	АналитикаДругихДокументов.СтатьяРасходов,
	|	АналитикаДругихДокументов.АналитикаРасходов
	|ИЗ
	|	ВТЗаполненнаяАналитика КАК АналитикаДругихДокументов";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда 
		Возврат;
	КонецЕсли;
	
	ОтборСтрок = Новый Структура("ФизическоеЛицо, Подразделение, НаправлениеДеятельности");
	
	ИменаТаблиц = Новый Массив;
	ИменаТаблиц.Добавить("НачисленнаяЗарплата");
	ИменаТаблиц.Добавить("Взносы");
	ИменаТаблиц.Добавить("УдержаннаяЗарплата");
	ИменаТаблиц.Добавить("Займы");
	ИменаТаблиц.Добавить("Обучение");
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ОтборСтрок, Выборка);
		Для Каждого ИмяТаблицы Из ИменаТаблиц Цикл
			НайденныеСтроки = Объект[ИмяТаблицы].НайтиСтроки(ОтборСтрок);
			Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
				НайденнаяСтрока.СтатьяРасходов = Выборка.СтатьяРасходов;
				НайденнаяСтрока.АналитикаРасходов = Выборка.АналитикаРасходов;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура СоздатьВТАналитикаДругихДокументов(МенеджерВременныхТаблиц, ТекущийДокумент, ДатаАктуальности)
	
	// Получаем последние используемые значения по совпадающим сочетаниям заполненных полей.
	
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	АналитикаДругихДокументов.Ссылка,
	|	АналитикаДругихДокументов.НомерСтроки КАК НомерСтроки,
	|	АналитикаДругихДокументов.НомерТаблицы,
	|	АналитикаДругихДокументов.ФизическоеЛицо КАК ФизическоеЛицо,
	|	АналитикаДругихДокументов.Подразделение КАК Подразделение,
	|	АналитикаДругихДокументов.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	АналитикаДругихДокументов.СтатьяРасходов,
	|	АналитикаДругихДокументов.АналитикаРасходов
	|ПОМЕСТИТЬ ВТАналитикаДругихДокументов
	|ИЗ
	|	(ВЫБРАТЬ
	|		НачисленнаяЗарплата.Ссылка КАК Ссылка,
	|		НачисленнаяЗарплата.НомерСтроки КАК НомерСтроки,
	|		1 КАК НомерТаблицы,
	|		НачисленнаяЗарплата.ФизическоеЛицо КАК ФизическоеЛицо,
	|		НачисленнаяЗарплата.Подразделение КАК Подразделение,
	|		НачисленнаяЗарплата.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|		НачисленнаяЗарплата.СтатьяРасходов КАК СтатьяРасходов,
	|		НачисленнаяЗарплата.АналитикаРасходов КАК АналитикаРасходов
	|	ИЗ
	|		Документ.ОтражениеРасходовНаПерсонал.НачисленнаяЗарплата КАК НачисленнаяЗарплата
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНезаполненнаяАналитика КАК НезаполненнаяАналитика
	|			ПО НезаполненнаяАналитика.ФизическоеЛицо = НачисленнаяЗарплата.ФизическоеЛицо
	|			И НезаполненнаяАналитика.Подразделение = НачисленнаяЗарплата.Подразделение
	|			И НезаполненнаяАналитика.НаправлениеДеятельности = НачисленнаяЗарплата.НаправлениеДеятельности
	|	ГДЕ
	|		НачисленнаяЗарплата.Ссылка <> &ТекущийДокумент
	|		И НачисленнаяЗарплата.Ссылка.Дата <= &ДатаАктуальности
	|		И НачисленнаяЗарплата.Ссылка.Проведен
	|		И НачисленнаяЗарплата.СтатьяРасходов <> ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка)
	|
	|	ОБЪЕДИНИТЬ ВСЕ
	|
	|	ВЫБРАТЬ
	|		Взносы.Ссылка,
	|		Взносы.НомерСтроки,
	|		2,
	|		Взносы.ФизическоеЛицо,
	|		Взносы.Подразделение,
	|		Взносы.НаправлениеДеятельности,
	|		Взносы.СтатьяРасходов,
	|		Взносы.АналитикаРасходов
	|	ИЗ
	|		Документ.ОтражениеРасходовНаПерсонал.Взносы КАК Взносы
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНезаполненнаяАналитика КАК НезаполненнаяАналитика
	|			ПО НезаполненнаяАналитика.ФизическоеЛицо = Взносы.ФизическоеЛицо
	|			И НезаполненнаяАналитика.Подразделение = Взносы.Подразделение
	|			И НезаполненнаяАналитика.НаправлениеДеятельности = Взносы.НаправлениеДеятельности
	|	ГДЕ
	|		Взносы.Ссылка <> &ТекущийДокумент
	|		И Взносы.Ссылка.Дата <= &ДатаАктуальности
	|		И Взносы.Ссылка.Проведен
	|		И Взносы.СтатьяРасходов <> ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка)
	|
	|	ОБЪЕДИНИТЬ ВСЕ
	|
	|	ВЫБРАТЬ
	|		УдержаннаяЗарплата.Ссылка,
	|		УдержаннаяЗарплата.НомерСтроки,
	|		3,
	|		УдержаннаяЗарплата.ФизическоеЛицо,
	|		УдержаннаяЗарплата.Подразделение,
	|		УдержаннаяЗарплата.НаправлениеДеятельности,
	|		УдержаннаяЗарплата.СтатьяРасходов,
	|		УдержаннаяЗарплата.АналитикаРасходов
	|	ИЗ
	|		Документ.ОтражениеРасходовНаПерсонал.УдержаннаяЗарплата КАК УдержаннаяЗарплата
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНезаполненнаяАналитика КАК НезаполненнаяАналитика
	|			ПО НезаполненнаяАналитика.ФизическоеЛицо = УдержаннаяЗарплата.ФизическоеЛицо
	|			И НезаполненнаяАналитика.Подразделение = УдержаннаяЗарплата.Подразделение
	|			И НезаполненнаяАналитика.НаправлениеДеятельности = УдержаннаяЗарплата.НаправлениеДеятельности
	|	ГДЕ
	|		УдержаннаяЗарплата.Ссылка <> &ТекущийДокумент
	|		И УдержаннаяЗарплата.Ссылка.Дата <= &ДатаАктуальности
	|		И УдержаннаяЗарплата.Ссылка.Проведен
	|		И УдержаннаяЗарплата.СтатьяРасходов <> ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка)
	|
	|	ОБЪЕДИНИТЬ ВСЕ
	|
	|	ВЫБРАТЬ
	|		Займы.Ссылка,
	|		Займы.НомерСтроки,
	|		4,
	|		Займы.ФизическоеЛицо,
	|		Займы.Подразделение,
	|		Займы.НаправлениеДеятельности,
	|		Займы.СтатьяРасходов,
	|		Займы.АналитикаРасходов
	|	ИЗ
	|		Документ.ОтражениеРасходовНаПерсонал.Займы КАК Займы
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНезаполненнаяАналитика КАК НезаполненнаяАналитика
	|			ПО НезаполненнаяАналитика.ФизическоеЛицо = Займы.ФизическоеЛицо
	|			И НезаполненнаяАналитика.Подразделение = Займы.Подразделение
	|			И НезаполненнаяАналитика.НаправлениеДеятельности = Займы.НаправлениеДеятельности
	|	ГДЕ
	|		Займы.Ссылка <> &ТекущийДокумент
	|		И Займы.Ссылка.Дата <= &ДатаАктуальности
	|		И Займы.Ссылка.Проведен
	|		И Займы.СтатьяРасходов <> ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка)
	|
	|	ОБЪЕДИНИТЬ ВСЕ
	|
	|	ВЫБРАТЬ
	|		Обучение.Ссылка,
	|		Обучение.НомерСтроки,
	|		5,
	|		Обучение.ФизическоеЛицо,
	|		Обучение.Подразделение,
	|		Обучение.НаправлениеДеятельности,
	|		Обучение.СтатьяРасходов,
	|		Обучение.АналитикаРасходов
	|	ИЗ
	|		Документ.ОтражениеРасходовНаПерсонал.Обучение КАК Обучение
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНезаполненнаяАналитика КАК НезаполненнаяАналитика
	|			ПО НезаполненнаяАналитика.ФизическоеЛицо = Обучение.ФизическоеЛицо
	|			И НезаполненнаяАналитика.Подразделение = Обучение.Подразделение
	|			И НезаполненнаяАналитика.НаправлениеДеятельности = Обучение.НаправлениеДеятельности
	|	ГДЕ
	|		Обучение.Ссылка <> &ТекущийДокумент
	|		И Обучение.Ссылка.Дата <= &ДатаАктуальности
	|		И Обучение.Ссылка.Проведен
	|		И Обучение.СтатьяРасходов <> ЗНАЧЕНИЕ(ПланВидовХарактеристик.СтатьиРасходов.ПустаяСсылка)) КАК
	|		АналитикаДругихДокументов
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ФизическоеЛицо,
	|	Подразделение,
	|	НаправлениеДеятельности
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АналитикаДругихДокументов.ФизическоеЛицо КАК ФизическоеЛицо,
	|	АналитикаДругихДокументов.Подразделение КАК Подразделение,
	|	АналитикаДругихДокументов.НаправлениеДеятельности КАК НаправлениеДеятельности,
	|	МАКСИМУМ(АналитикаДругихДокументов.Ссылка) КАК Ссылка,
	|	МАКСИМУМ(АналитикаДругихДокументов.НомерСтроки) КАК НомерСтроки,
	|	МИНИМУМ(АналитикаДругихДокументов.НомерТаблицы) КАК НомерТаблицы
	|ПОМЕСТИТЬ ВТЕдинственныеЗначения
	|ИЗ
	|	ВТАналитикаДругихДокументов КАК АналитикаДругихДокументов
	|СГРУППИРОВАТЬ ПО
	|	АналитикаДругихДокументов.ФизическоеЛицо,
	|	АналитикаДругихДокументов.Подразделение,
	|	АналитикаДругихДокументов.НаправлениеДеятельности
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ФизическоеЛицо,
	|	Подразделение,
	|	НаправлениеДеятельности
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	АналитикаДругихДокументов.ФизическоеЛицо,
	|	АналитикаДругихДокументов.Подразделение,
	|	АналитикаДругихДокументов.НаправлениеДеятельности,
	|	АналитикаДругихДокументов.СтатьяРасходов,
	|	АналитикаДругихДокументов.АналитикаРасходов
	|ПОМЕСТИТЬ ВТЗаполненнаяАналитика
	|ИЗ
	|	ВТАналитикаДругихДокументов КАК АналитикаДругихДокументов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТЕдинственныеЗначения КАК ЕдинственныеЗначения
	|		ПО АналитикаДругихДокументов.ФизическоеЛицо = ЕдинственныеЗначения.ФизическоеЛицо
	|		И АналитикаДругихДокументов.Подразделение = ЕдинственныеЗначения.Подразделение
	|		И АналитикаДругихДокументов.НаправлениеДеятельности = ЕдинственныеЗначения.НаправлениеДеятельности
	|		И АналитикаДругихДокументов.Ссылка = ЕдинственныеЗначения.Ссылка
	|		И АналитикаДругихДокументов.НомерТаблицы = ЕдинственныеЗначения.НомерТаблицы
	|		И АналитикаДругихДокументов.НомерСтроки = ЕдинственныеЗначения.НомерСтроки";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ТекущийДокумент", ТекущийДокумент);
	Запрос.УстановитьПараметр("ДатаАктуальности", ДатаАктуальности);
	Запрос.Выполнить();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СтатьяРасходовАналитикаПоУмолчанию(ФизическоеЛицо, Подразделение, НаправлениеДеятельности, ТекущийДокумент, ДатаАктуальности)
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	&ФизическоеЛицо КАК ФизическоеЛицо,
	|	&Подразделение КАК Подразделение,
	|	&НаправлениеДеятельности КАК НаправлениеДеятельности
	|ПОМЕСТИТЬ ВТНезаполненнаяАналитика";
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ФизическоеЛицо", ФизическоеЛицо);
	Запрос.УстановитьПараметр("Подразделение", Подразделение);
	Запрос.УстановитьПараметр("НаправлениеДеятельности", НаправлениеДеятельности);
	Запрос.Выполнить();
	
	СоздатьВТАналитикаДругихДокументов(МенеджерВременныхТаблиц, ТекущийДокумент, ДатаАктуальности);
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	АналитикаДругихДокументов.ФизическоеЛицо,
	|	АналитикаДругихДокументов.Подразделение,
	|	АналитикаДругихДокументов.НаправлениеДеятельности,
	|	АналитикаДругихДокументов.СтатьяРасходов,
	|	АналитикаДругихДокументов.АналитикаРасходов
	|ИЗ
	|	ВТЗаполненнаяАналитика КАК АналитикаДругихДокументов";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	РезультатЗапроса = Запрос.Выполнить();
	
	СтатьяАналитикаРасходов = Новый Структура("СтатьяРасходов, АналитикаРасходов");
	
	Выборка = РезультатЗапроса.Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(СтатьяАналитикаРасходов, Выборка);
	КонецЕсли;
	
	Возврат СтатьяАналитикаРасходов;
	
КонецФункции	

&НаКлиенте
Процедура УстановитьСтатьиРасходовВТабличнойЧасти(ТабличнаяЧасть, ВыделенныеСтроки)
	
	Если ТабличнаяЧасть.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ТабличнаяЧасть", ТабличнаяЧасть);
	ДополнительныеПараметры.Вставить("ВыделенныеСтроки", ВыделенныеСтроки);
	
	Оповещение = Новый ОписаниеОповещения("УстановитьСтатьиРасходовВТабличнойЧастиЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	
	ОткрытьФорму("ПланВидовХарактеристик.СтатьиРасходов.Форма.ФормаВыбораСтатьиИАналитики", , ЭтотОбъект, , , , Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСтатьиРасходовВТабличнойЧастиЗавершение(Структура, ДополнительныеПараметры) Экспорт 
	
	Если Не ЗначениеЗаполнено(Структура) Тогда
		Возврат;
	КонецЕсли;
	
	ТабличнаяЧасть = ДополнительныеПараметры.ТабличнаяЧасть;
	ВыделенныеСтроки = ДополнительныеПараметры.ВыделенныеСтроки;
	
	Если ЗначениеЗаполнено(ВыделенныеСтроки) Тогда
		Для Каждого Строка Из ВыделенныеСтроки Цикл
			СтрокаТаблицы = ТабличнаяЧасть.НайтиПоИдентификатору(Строка);
			Если СтрокаТаблицы <> Неопределено Тогда
				СтрокаТаблицы.СтатьяРасходов = Структура.СтатьяРасходов;
				СтрокаТаблицы.АналитикаРасходов = Структура.АналитикаРасходов;
			КонецЕсли;
		КонецЦикла;
	Иначе
		Для Каждого СтрокаТаблицы Из ТабличнаяЧасть Цикл
			СтрокаТаблицы.СтатьяРасходов = Структура.СтатьяРасходов;
			СтрокаТаблицы.АналитикаРасходов = Структура.АналитикаРасходов;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьСвойстваПоляПодразделения()
	
	ДоступенВводПодразделения = ЗаполнятьПоВсемПодразделениям = 0;
	
	Элементы.Подразделение.Доступность = ДоступенВводПодразделения;
	Элементы.Подразделение.АвтоОтметкаНезаполненного = ДоступенВводПодразделения;
	Элементы.Подразделение.ОтметкаНезаполненного = ДоступенВводПодразделения И Не ЗначениеЗаполнено(Объект.Подразделение);
	
	// Очищаем поле, если подразделение недоступно.
	Если Не ДоступенВводПодразделения Тогда
		Объект.Подразделение = Неопределено;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуСпискаСотрудниковРаботающихВПериодеПоПараметрам(СтандартнаяОбработка, ВладелецФормыВыбора)
	
	Если ОбщегоНазначенияКлиент.ПодсистемаСуществует("ЗарплатаКадрыКорпоративнаяПодсистемы.ФинансовыйУчет") Тогда
		СтандартнаяОбработка = Ложь;
		МодульФинансовыйУчетКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("ФинансовыйУчетКлиент");
		МодульФинансовыйУчетКлиент.ОткрытьФормуСпискаСотрудниковРаботающихВПериодеПоПараметрам(
			ЭтотОбъект, ВладелецФормыВыбора, Объект.ПериодРегистрации, КонецМесяца(Объект.ПериодРегистрации), Ложь);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаВыбораФизическогоЛица(ВыбранноеЗначение, СтандартнаяОбработка, ИдентификаторТекущейСтроки, ИмяТЧ)
	
	СтандартнаяОбработка = Ложь;
	
	Если ИдентификаторТекущейСтроки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Объект[ИмяТЧ].НайтиПоИдентификатору(ИдентификаторТекущейСтроки);
	Если ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.Сотрудники") Тогда
		ТекущиеДанные.ФизическоеЛицо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВыбранноеЗначение, "ФизическоеЛицо");
	Иначе
		ТекущиеДанные.ФизическоеЛицо = ВыбранноеЗначение;
	КонецЕсли;

КонецПроцедуры

#Область КлючевыеРеквизитыЗаполненияФормы

&НаСервере
// Функция возвращает описание таблиц формы подключенных к механизму ключевых реквизитов формы.
Функция КлючевыеРеквизитыЗаполненияФормыТаблицыОчищаемыеПриИзменении() Экспорт
	
	Массив = Новый Массив;
	Массив.Добавить("Объект.НачисленнаяЗарплата");
	Массив.Добавить("Объект.Взносы");
	Массив.Добавить("Объект.УдержаннаяЗарплата");
	Массив.Добавить("Объект.Займы");
	Массив.Добавить("Объект.Обучение");
	Массив.Добавить("Объект.ФизическиеЛица");
	
	Возврат Массив;
	
КонецФункции

&НаСервере
// Функция возвращает массив реквизитов формы подключенных к механизму ключевых реквизитов формы.
Функция КлючевыеРеквизитыЗаполненияФормыОписаниеКлючевыхРеквизитов() Экспорт
	
	Массив = Новый Массив;
	Массив.Добавить(Новый Структура("ЭлементФормы, Представление", "Подразделение", НСтр("ru = 'подразделения'")));
	
	Возврат Массив;
	
КонецФункции

#КонецОбласти

#КонецОбласти
