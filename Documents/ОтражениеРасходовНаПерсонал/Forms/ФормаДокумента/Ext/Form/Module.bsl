&НаКлиенте
Процедура Заполнить(Команда)
	
	Если Не ФормаДокументаГотоваДляЗаполнения() Тогда
		Возврат;
	КонецЕсли;
	
	ОчиститьСообщения();
	
	Если Объект.НачисленнаяЗарплата.Количество() > 0
		Или Объект.Взносы.Количество() > 0
		Или Объект.УдержаннаяЗарплата.Количество() > 0
		Или Объект.Займы.Количество() > 0
		Или Объект.Обучение.Количество() > 0 Тогда
		Оповещение = Новый ОписаниеОповещения("НачатьЗаполнение", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, НСтр("ru = 'Табличные части документа будут очищены. Продолжить?'"), РежимДиалогаВопрос.ДаНет);
	Иначе 
		НачатьЗаполнение(КодВозвратаДиалога.Да, Неопределено);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ФормаДокументаГотоваДляЗаполнения()
	
	ФормаДокументаГотова = Истина;
	
	Если ЗаполнятьПоВсемПодразделениям = 0 И Не ЗначениеЗаполнено(Объект.Подразделение) Тогда
		ФормаДокументаГотова = Ложь;
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Необходимо указать подразделение.'"), , "Подразделение", "Объект.Подразделение");
	КонецЕсли;
	
	Возврат ФормаДокументаГотова;
	
КонецФункции

&НаКлиенте
Процедура НачатьЗаполнение(Ответ, ДополнительныеПараметры) Экспорт 

	Если Ответ <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ДлительнаяОперация = ДлительнаяОперацияЗаполнения();
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ТекстСообщения = НСтр("ru = 'Заполнение документа ""Отражение зарплаты в финансовом учете""'");
	ПараметрыОжидания.ВыводитьПрогрессВыполнения = Истина;
	ПараметрыОжидания.ВыводитьСообщения = Истина;
	
	Обработчик = Новый ОписаниеОповещения("ЗавершитьЗаполнение", ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Обработчик, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервере
Функция ДлительнаяОперацияЗаполнения()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения, "Документы.ОтражениеРасходовНаПерсонал.ПодготовитьДанныеДляЗаполнения",
		Объект.Ссылка, Объект.Подразделение, Объект.ПериодРегистрации);
	
КонецФункции

