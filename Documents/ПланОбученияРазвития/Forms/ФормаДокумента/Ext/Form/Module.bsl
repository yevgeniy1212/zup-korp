&НаСервере
Функция АдресСпискаПодобранныхСотрудников()
	
	СписокСотрудниковПоМероприятию = Объект.Сотрудники.Выгрузить().НайтиСтроки(Новый Структура("НомерСтрокиМероприятия",АктивноеМероприятие));
	
	МассивСотрудников = Новый Массив;
	
	Для Каждого Сотрудник Из СписокСотрудниковПоМероприятию Цикл
		МассивСотрудников.Добавить(Сотрудник.Сотрудник);
	КонецЦикла; 
	
	Возврат ПоместитьВоВременноеХранилище(МассивСотрудников, УникальныйИдентификатор);
	
КонецФункции

&НаСервере
Функция АдресСпискаПодобранныхИПР()
	
	ТаблицаПодобранных = Объект.Мероприятия.Выгрузить(
			Новый Структура("ТипОснования", ТипыОснования().ИПР), "Заявка, Мероприятие, ДатаНачала, ДатаОкончания");
	ТаблицаПодобранных.Колонки.Заявка.Имя = "ИПР";
	
	Возврат ПоместитьВоВременноеХранилище(ТаблицаПодобранных, УникальныйИдентификатор);

КонецФункции

&НаСервере
Функция АдресСпискаПодобранныхЗаявок()
	Возврат ПоместитьВоВременноеХранилище(
		Объект.Мероприятия.Выгрузить(
			Новый Структура("ТипОснования", ТипыОснования().Заявка), "Заявка").ВыгрузитьКолонку("Заявка"), 
		УникальныйИдентификатор);
КонецФункции

&НаСервере
Процедура ДобавитьМероприятия(ДобавляемыеМероприятия)
	
	Заявки = Новый Массив;
	ФизическиеЛица = Новый Массив;
	Мероприятия = Новый Массив;
	
	Для Каждого ОписаниеМероприятия Из ДобавляемыеМероприятия Цикл
		ДобавитьВМассивЕслиОтсутствует(Мероприятия, ОписаниеМероприятия.Мероприятие);
		Если ОписаниеМероприятия.Свойство("Заявка") Тогда
			ДобавитьВМассивЕслиОтсутствует(Заявки, ОписаниеМероприятия.Заявка);
		ИначеЕсли ОписаниеМероприятия.Свойство("ИПР") Тогда
			ДобавитьВМассивЕслиОтсутствует(ФизическиеЛица, ОписаниеМероприятия.ФизическоеЛицо);
		Иначе
			ОбщегоНазначенияКлиентСервер.Проверить(Ложь, 
				НСтр("ru = 'В сведениях о выбранных мероприятиях нет ни заявки, ни ИПР.'"), ЭтотОбъект.ИмяФормы);
		КонецЕсли;
	КонецЦикла;
	
	СотрудникиЗаявок = СотрудникиЗаявок(Заявки);
	СотрудникиИПР = СотрудникиФизическихЛиц(ФизическиеЛица);
	РеквизитыМероприятий = РеквизитыМероприятий(Мероприятия, "Стоимость, СпособОпределенияСтоимости");
	
	Для Каждого ОписаниеМероприятия Из ДобавляемыеМероприятия Цикл
		СтрокаМероприятия = ДобавитьСтрокуМероприятия(ОписаниеМероприятия);
		РеквизитыМероприятия = РеквизитыМероприятий[ОписаниеМероприятия.Мероприятие];
		Если РеквизитыМероприятия <> Неопределено Тогда
			ЗаполнитьЗначенияСвойств(СтрокаМероприятия, РеквизитыМероприятия);
		КонецЕсли;
		Если ОписаниеМероприятия.Свойство("Заявка") Тогда
			СтрокаМероприятия.Заявка = ОписаниеМероприятия.Заявка;
			ДобавитьСотрудниковКСтрокеМероприятия(СтрокаМероприятия, СотрудникиЗаявок[ОписаниеМероприятия.Заявка]);
		ИначеЕсли ОписаниеМероприятия.Свойство("ИПР") Тогда
			СтрокаМероприятия.Заявка = ОписаниеМероприятия.ИПР;
			ДобавитьСотрудниковКСтрокеМероприятия(СтрокаМероприятия, 
				ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(
					СотрудникиИПР[ОписаниеМероприятия.ФизическоеЛицо]));
		КонецЕсли;
		ЗаполнитьДополнительныеРеквизитыМероприятияВСтроке(СтрокаМероприятия);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьВМассивЕслиОтсутствует(Массив, Значение)
	Если Массив.Найти(Значение) = Неопределено Тогда
		Массив.Добавить(Значение);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция ДобавитьСтрокуМероприятия(ОписаниеМероприятия)

	НоваяСтрока = Объект.Мероприятия.Добавить();
	ЗаполнитьЗначенияСвойств(НоваяСтрока, ОписаниеМероприятия);
	НоваяСтрока.НомерСтрокиМероприятия = СледующийНомерСтрокиМероприятия;
	СледующийНомерСтрокиМероприятия = СледующийНомерСтрокиМероприятия + 1;
	Модифицированность = Истина;
	
	Возврат НоваяСтрока;
	
КонецФункции

&НаСервере
Процедура ДобавитьСотрудниковКСтрокеМероприятия(СтрокаМероприятия, Сотрудники)
	Для Каждого Сотрудник Из Сотрудники Цикл
		НовыйСотрудник = Объект.Сотрудники.Добавить();
		НовыйСотрудник.НомерСтрокиМероприятия = СтрокаМероприятия.НомерСтрокиМероприятия;
		НовыйСотрудник.Сотрудник = Сотрудник;
		Модифицированность = Истина;
	КонецЦикла;
	УстановитьКоличествоСотрудниковВТабличнойЧастиМероприятия(ЭтотОбъект, СтрокаМероприятия.НомерСтрокиМероприятия);
КонецПроцедуры

&НаСервереБезКонтекста
Функция СотрудникиЗаявок(Заявки)

	СотрудникиЗаявок = Новый Соответствие();
	
	Если Заявки.Количество() = 0 Тогда
		Возврат СотрудникиЗаявок;
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Заявки", Заявки);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СотрудникиЗаявок.Сотрудник,
		|	СотрудникиЗаявок.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ЗаявкаНаВключениеВПланОбучения.Сотрудники КАК СотрудникиЗаявок
		|ГДЕ
		|	СотрудникиЗаявок.Ссылка В (&Заявки)
		|УПОРЯДОЧИТЬ ПО
		|	СотрудникиЗаявок.Ссылка";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.СледующийПоЗначениюПоля("Ссылка") Цикл
		СотрудникиЗаявки = Новый Массив;
		Пока Выборка.Следующий() Цикл
			СотрудникиЗаявки.Добавить(Выборка.Сотрудник);
		КонецЦикла;
		СотрудникиЗаявок.Вставить(Выборка.Ссылка, СотрудникиЗаявки);
	КонецЦикла;
	
	Возврат СотрудникиЗаявок;
	
КонецФункции

&НаСервереБезКонтекста
Функция СотрудникиФизическихЛиц(ФизическиеЛица)
	
	ПараметрыСотрудников = КадровыйУчет.ПараметрыПолученияСотрудниковОрганизацийПоСпискуФизическихЛиц();
	ПараметрыСотрудников.СписокФизическихЛиц = ФизическиеЛица;
	
	СотрудникиОрганизации = КадровыйУчет.СотрудникиОрганизации(Истина, ПараметрыСотрудников);
	ОбщегоНазначенияБЗК.ДобавитьИндексКоллекции(СотрудникиОрганизации, "ФизическоеЛицо");
	
	Сотрудники = Новый Соответствие;
	Для Каждого ФизическоеЛицо Из ФизическиеЛица Цикл
		НайденныеСотрудники = СотрудникиОрганизации.НайтиСтроки(Новый Структура("ФизическоеЛицо", ФизическоеЛицо));
		ОбщегоНазначенияКлиентСервер.Проверить(НайденныеСотрудники.Количество() > 0, 
			СтрШаблон(НСтр("ru = 'Не удалось подобрать сотрудника по индивидуальному плану физического лица %1'"), 
				ФизическоеЛицо));
		Сотрудники.Вставить(ФизическоеЛицо, НайденныеСотрудники[0].Сотрудник);
	КонецЦикла;
	
	Возврат Сотрудники;
	
КонецФункции

&НаСервереБезКонтекста
Функция РеквизитыМероприятий(Мероприятия, Реквизиты)
	Возврат ОбщегоНазначения.ЗначенияРеквизитовОбъектов(Мероприятия, Реквизиты, Истина);
КонецФункции

&НаСервере
Процедура УдалитьСотрудниковМероприятия()

