		ЗаполнитьДополнительныеРеквизитыМероприятияВСтроке(СтрокаКоллекции);
	КонецЦикла; 

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДополнительныеРеквизитыМероприятияВСтроке(СтрокаКоллекции)

	УстановитьКоличествоВычисляетсяСтроки(ЭтотОбъект, СтрокаКоллекции);
	УстановитьВторичныеРеквизитыСтрокиПоМероприятию(СтрокаКоллекции);
	УстановитьТипОснования(СтрокаКоллекции);

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьТипОснования(СтрокаКоллекции)
	Если ТипЗнч(СтрокаКоллекции.Заявка) = Тип("ДокументСсылка.ЗаявкаНаВключениеВПланОбучения") Тогда
		СтрокаКоллекции.ТипОснования = ТипыОснования().Заявка;
	ИначеЕсли ТипЗнч(СтрокаКоллекции.Заявка) = Тип("СправочникСсылка.ИндивидуальныйПланРазвития") Тогда 
		СтрокаКоллекции.ТипОснования = ТипыОснования().ИПР;
	Иначе
		СтрокаКоллекции.ТипОснования = Неопределено;
	КонецЕсли;
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ТипыОснования()
	Типы = Новый Структура();
	Типы.Вставить("Заявка", "Заявка");
	Типы.Вставить("ИПР", "ИПР");
	Возврат Типы;
КонецФункции

&НаСервере
Процедура УстановитьСледующийНомерСтрокиМероприятия()

	СледующийНомерСтрокиМероприятия = 1;
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПланОбученияРазвитияМероприятия.НомерСтрокиМероприятия КАК НомерСтрокиМероприятия
		|ПОМЕСТИТЬ ВТСтроки
		|ИЗ
		|	Документ.ПланОбученияРазвития.Мероприятия КАК ПланОбученияРазвитияМероприятия
		|ГДЕ
		|	ПланОбученияРазвитияМероприятия.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	1
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ВТСтроки.НомерСтрокиМероприятия) КАК НомерСтрокиМероприятия
		|ИЗ
		|	ВТСтроки КАК ВТСтроки";
		
		Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		Если НЕ РезультатЗапроса.Пустой() Тогда
			СледующийНомерСтрокиМероприятия = СледующийНомерСтрокиМероприятия + РезультатЗапроса.Выгрузить()[0].НомерСтрокиМероприятия;
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Функция УстановленОтборПоМероприятию()

	Сотрудники = Элементы.Сотрудники;
	
	ОтборПоМероприятию = Сотрудники.ОтборСтрок <> Неопределено И ЗначениеЗаполнено(Сотрудники.ОтборСтрок["НомерСтрокиМероприятия"]);
	Если НЕ ОтборПоМероприятию Тогда
		ПоказатьПредупреждение(,НСтр("ru = 'Не выбрано мероприятие'"));
	КонецЕсли;
	Возврат ОтборПоМероприятию;

КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьКоличествоСотрудниковВТабличнойЧастиМероприятия(Форма, НомерСтрокиМероприятия)

	ОтборСтрок = Новый Структура("НомерСтрокиМероприятия", НомерСтрокиМероприятия);
	МероприятияТекущиеДанные = Форма.Объект.Мероприятия.НайтиСтроки(ОтборСтрок);
	
	Если МероприятияТекущиеДанные.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаМероприятия = МероприятияТекущиеДанные[0];
	КоличествоСотрудников = Форма.Объект.Сотрудники.НайтиСтроки(ОтборСтрок).Количество();
	
	СтрокаМероприятия.КоличествоВычисляется = СтрокаМероприятия.КоличествоВычисляется
												Или (КоличествоСотрудников >= СтрокаМероприятия.КоличествоСотрудников);
	
	Если СтрокаМероприятия.КоличествоВычисляется Тогда
		СтрокаМероприятия.КоличествоСотрудников = КоличествоСотрудников;
		Если Не ЗначениеЗаполнено(СтрокаМероприятия.СуммаРасходов) Тогда
			РассчитатьСуммуМероприятия(СтрокаМероприятия);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьКоличествоВычисляетсяСтроки(Форма, ТекущаяСтрокаМероприятия)

	НайденныеСотрудники = Форма.Объект.Сотрудники.НайтиСтроки(Новый Структура("НомерСтрокиМероприятия", ТекущаяСтрокаМероприятия.НомерСтрокиМероприятия)); 
	ТекущаяСтрокаМероприятия.КоличествоВычисляется = (НайденныеСотрудники.Количество() = ТекущаяСтрокаМероприятия.КоличествоСотрудников);

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВторичныеРеквизитыСтрокиПоМероприятию(ТекущиеДанные)

	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ТекущиеДанные.Мероприятие) Тогда
		Возврат;
	КонецЕсли;
	
	МероприятиеСтруктураРеквизитов = РеквизитыМероприятия(ТекущиеДанные.Мероприятие, "Стоимость, СпособОпределенияСтоимости");
	ЗаполнитьЗначенияСвойств(ТекущиеДанные, МероприятиеСтруктураРеквизитов);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура РассчитатьСуммуМероприятия(ТекущиеДанные)

	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТекущиеДанные.СпособОпределенияСтоимости = ПредопределенноеЗначение("Перечисление.СпособыРасчетаСуммыРасходовНаПерсонал.СуммаКратнаКоличествуСотрудников") Тогда
		Сотрудников = ТекущиеДанные.КоличествоСотрудников;
	Иначе
		Сотрудников = 1;
	КонецЕсли;

	ТекущиеДанные.СуммаРасходов = ТекущиеДанные.Стоимость * Сотрудников;

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура РассчитатьКоличествоУчебныхЧасовМероприятия(ТекущиеДанные)

	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ТекущиеДанные.Мероприятие) Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ТекущиеДанные.КоличествоУчебныхЧасов) Тогда
		МероприятиеСтруктураРеквизитов = РеквизитыМероприятия(ТекущиеДанные.Мероприятие, "КоличествоУчебныхЧасов");
		ТекущиеДанные.КоличествоУчебныхЧасов = МероприятиеСтруктураРеквизитов.КоличествоУчебныхЧасов;
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция РеквизитыМероприятия(МероприятиеСсылка, ИменаРеквизитов)
	Возврат ОбщегоНазначения.ЗначенияРеквизитовОбъекта(МероприятиеСсылка, ИменаРеквизитов);
КонецФункции

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Элемент.Отбор, "Объект.Мероприятия.Заявка", , ВидСравненияКомпоновкиДанных.НеЗаполнено);
	Элемент.Поля.Элементы.Добавить().Поле = Новый ПолеКомпоновкиДанных("МероприятияЗаявка");
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ТекстПодобранногоЗначенияЦвет);
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<Не выбрано>'"));

	Элемент = УсловноеОформление.Элементы.Добавить();
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Элемент.Отбор, "Объект.Мероприятия.КоличествоВычисляется", Истина);
	Элемент.Поля.Элементы.Добавить().Поле = Новый ПолеКомпоновкиДанных("МероприятияКоличествоСотрудников");
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ТекстПодобранногоЗначенияЦвет);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьЗаявку(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)

	Если Поле.Имя <> "МероприятияЗаявка" Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	ДанныеСтроки = Объект.Мероприятия.НайтиПоИдентификатору(ВыбраннаяСтрока);
	
	Если Не ЗначениеЗаполнено(ДанныеСтроки.Заявка) Тогда
		Возврат;
	КонецЕсли;

	ПараметрыФормы = Новый Структура("Ключ", ДанныеСтроки.Заявка);
	Если ДанныеСтроки.ТипОснования = ТипыОснования().Заявка Тогда
		ОткрытьФорму("Документ.ЗаявкаНаВключениеВПланОбучения.ФормаОбъекта", ПараметрыФормы);
	ИначеЕсли ДанныеСтроки.ТипОснования = ТипыОснования().ИПР Тогда
		ОткрытьФорму("Справочник.ИндивидуальныйПланРазвития.ФормаОбъекта", ПараметрыФормы);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
