&НаКлиенте
Процедура СозданиеФизическогоЛицаЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Отмена Или Результат = Неопределено Тогда
		Закрыть();
	ИначеЕсли ТипЗнч(Результат) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
		Объект.ФизическоеЛицо = Результат;
	Иначе
		ТекстОшибки = СтрШаблон(НСтр("ru = 'Неизвестный тип %1 результата  %2'"), ТипЗнч(Результат), Результат);
		ОбщегоНазначенияКлиентСервер.Проверить(Ложь, ТекстОшибки,
			"Документы.НаправлениеНаМедицинскийОсмотр.ФормаДокумента.СозданиеФизическогоЛицаЗавершение");
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  Основание - ДокументСсылка.РешениеОПриемеНаРаботу - Основание
// 
// Возвращаемое значение:
//  СправочникСсылка.ЛичныеДанныеКандидатов
&НаСервере
Функция ЛичныеДанныеКандидата(Основание)
	
	Если ТипЗнч(Основание) = Тип("ДокументСсылка.РешениеОПриемеНаРаботу") Тогда
		Результат = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Основание, "ЛичныеДанныеКандидата");
	ИначеЕсли ТипЗнч(Основание) = Тип("СправочникСсылка.Кандидаты") Тогда
		Результат = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Основание, "ЛичныеДанные");
	Иначе
		Результат =  Справочники.ЛичныеДанныеКандидатов.ПустаяСсылка();
	КонецЕсли;
	
	Возврат Результат
	
КонецФункции

