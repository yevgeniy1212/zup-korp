	|ПОМЕСТИТЬ ВТСведенияОбОтветственныхЛицахОтбор
	|ИЗ
	|	ВТДанныеДокументов КАК ДанныеДокументов";
	
	Запрос.Выполнить();
	
	СведенияОбОтветственныхЛицах.СоздатьВТСведенияОбОтветственныхЛицах(Запрос.МенеджерВременныхТаблиц, "ВТСведенияОбОтветственныхЛицахОтбор", "ГлавныйБухгалтер", "ВТОтветственныеЛица");
	
	ОписательВременныхТаблиц = КадровыйУчет.ОписательВременныхТаблицДляСоздатьВТКадровыеДанныеФизическихЛиц(Запрос.МенеджерВременныхТаблиц, "ВТПострадавшиеФизическиеЛица", "Пострадавший,Период");
	КадровыйУчет.СоздатьВТКадровыеДанныеФизическихЛиц(ОписательВременныхТаблиц, Истина, "ФамилияИО, ФИОПолные, Профессии");
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Пострадавшие.Ссылка КАК Ссылка,
	|	Пострадавшие.Организация КАК Организация,
	|	Пострадавшие.Пострадавший КАК Пострадавший,
