		ДанныеПечати = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(Выборка);
		
		ДанныеПечати.Вставить("ДатаПроисшествия", Формат(Выборка.ДатаПроисшествияДатаВремя, "ДЛФ=ДД"));
