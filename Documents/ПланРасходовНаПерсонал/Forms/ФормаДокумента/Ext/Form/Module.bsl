&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

&НаКлиенте
Процедура ЗаполнитьФактомПрошлогоПериода(Команда)
	
	Если Не ЗначениеЗаполнено(Объект.Периодичность) Тогда 
		Возврат;
	КонецЕсли;
	
	ЗарплатаКадрыКлиент.КлючевыеРеквизитыЗаполненияФормыОчиститьТаблицы(ЭтотОбъект);
	
	НачалоПериода = ДобавитьМесяц(Объект.ПериодПланирования, - ШагиРегулирования.Получить(Объект.Периодичность));
	КонецПериода = Объект.ПериодПланирования - 1;
	
	ЗаполнитьФактомПрошлогоПериодаНаСервере(НачалоПериода, КонецПериода);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьФактомПрошлогоПериодаГод(Команда)
	
	Если Не ЗначениеЗаполнено(Объект.Периодичность) Тогда 
		Возврат;
	КонецЕсли;
	
	ЗарплатаКадрыКлиент.КлючевыеРеквизитыЗаполненияФормыОчиститьТаблицы(ЭтотОбъект);
	
	КоличествоМесяцевВГоду = 12;
	НачалоПериода = ДобавитьМесяц(Объект.ПериодПланирования, - КоличествоМесяцевВГоду);
	КонецПериода = ДобавитьМесяц(Объект.ПериодПланирования - 1,
		ШагиРегулирования.Получить(Объект.Периодичность) - КоличествоМесяцевВГоду);
	
	ЗаполнитьФактомПрошлогоПериодаНаСервере(НачалоПериода, КонецПериода);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьФактомВыбранногоПериода(Команда)
	
	Если Не ЗначениеЗаполнено(Объект.Периодичность) Тогда 
		Возврат;
	КонецЕсли;
	
	ЗарплатаКадрыКлиент.КлючевыеРеквизитыЗаполненияФормыОчиститьТаблицы(ЭтотОбъект);
	
	Оповещение = Новый ОписаниеОповещения("ЗаполнениеПослеВыбораПериода", ЭтотОбъект);
	
	Диалог = Новый ДиалогРедактированияСтандартногоПериода;
	Диалог.Период.ДатаНачала = ДобавитьМесяц(Объект.ПериодПланирования, - ШагиРегулирования.Получить(Объект.Периодичность));
	Диалог.Период.ДатаОкончания = Объект.ПериодПланирования - 1;
	Диалог.Показать(Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнениеПослеВыбораПериода(ВыбранныйПериод, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйПериод = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	РазницаВМесяцах = ЗарплатаКадрыРасширенныйКлиентСервер.РазницаВМесяцах(ВыбранныйПериод.ДатаНачала, ВыбранныйПериод.ДатаОкончания + 1);
	ШагРегулирования = ШагиРегулирования.Получить(Объект.Периодичность);
	Если РазницаВМесяцах > ШагРегулирования Тогда
		ВызватьИсключение СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru='Количество выбранных месяцев (%1) не должно превышать количество месяцев установленного периода (%2).'"),
			Строка(РазницаВМесяцах), Строка(ШагРегулирования));
	КонецЕсли;
	
	ЗаполнитьФактомПрошлогоПериодаНаСервере(ВыбранныйПериод.ДатаНачала, ВыбранныйПериод.ДатаОкончания);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоКадровомуПлану(Команда)
	
	Если Не Объект.ПланируемыеРасходы.Количество() = 0 Тогда
		ТекстВопроса = НСтр("ru = 'Планируемые расходы будут перезаполнены. Продолжить?'");
		Оповещение = Новый ОписаниеОповещения("ЗаполнитьПоКадровомуПлануПослеВопроса", ЭтотОбъект);
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ДаНет);
	Иначе
		НачатьЗаполнениеПоКадровомуПлану();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьИзФайла(Команда)
	
	ПараметрыЗагрузки = ЗагрузкаДанныхИзФайлаКлиент.ПараметрыЗагрузкиДанных();
	ПараметрыЗагрузки.ПолноеИмяТабличнойЧасти = "ПланРасходовНаПерсонал.ПланируемыеРасходы";
	ПараметрыЗагрузки.Заголовок = НСтр("ru = 'Загрузка расходов из файла'");
	
	ДополнительныеПараметры = Новый Структура();
	ДополнительныеПараметры.Вставить("СтруктурыСоответствуют", СтруктураПредприятияСоответствуетСтруктуреЮридическихЛиц());
	ПараметрыЗагрузки.ДополнительныеПараметры = ДополнительныеПараметры;
	
	// Описание колонок для макета загрузки расходов
	ПараметрыЗагрузки.КолонкиМакета = ОписаниеКолонокМакетаДляЗагрузкиРасходов(ДополнительныеПараметры.СтруктурыСоответствуют);
	
	Оповещение = Новый ОписаниеОповещения("ЗагрузитьИзФайлаЗавершение", ЭтотОбъект);
	ЗагрузкаДанныхИзФайлаКлиент.ПоказатьФормуЗагрузки(ПараметрыЗагрузки, Оповещение);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

