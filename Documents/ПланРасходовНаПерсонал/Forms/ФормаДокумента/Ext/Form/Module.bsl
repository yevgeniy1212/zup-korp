#Область КлючевыеРеквизитыЗаполненияФормы

&НаСервере
// Функция возвращает описание таблиц формы подключенных к механизму ключевых реквизитов формы.
Функция КлючевыеРеквизитыЗаполненияФормыТаблицыОчищаемыеПриИзменении() Экспорт
	
	Массив = Новый Массив;
	Массив.Добавить("Объект.ПланируемыеРасходы");
	
	Возврат Массив;
	
КонецФункции

&НаСервере
// Функция возвращает массив реквизитов формы подключенных к механизму ключевых реквизитов формы.
Функция КлючевыеРеквизитыЗаполненияФормыОписаниеКлючевыхРеквизитов() Экспорт
	
	Массив = Новый Массив;
	Массив.Добавить(Новый Структура("ЭлементФормы, Представление", "Подразделение", НСтр("ru = 'подразделения'")));
	Массив.Добавить(Новый Структура("ЭлементФормы, Представление", "Сценарий", НСтр("ru = 'сценария'")));
	Массив.Добавить(Новый Структура("ЭлементФормы, Представление", "Периодичность", НСтр("ru = 'периодичности'")));
	Массив.Добавить(Новый Структура("ЭлементФормы, Представление", "ПредставлениеПериодаПланирования", НСтр("ru = 'периода планирования'")));
	
	Возврат Массив;
	
КонецФункции

#КонецОбласти

&НаСервере
Процедура ПриПолученииДанныхНаСервере()
	
	ЗаполнитьПериодыСтрокой(ЭтотОбъект);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаполнитьСведенияОПериодичности(Форма)
	
	Форма.ШагиРегулирования = ОбщегоНазначения.ФиксированныеДанные(ЗарплатаКадрыРасширенный.СоответствиеКоличестваМесяцевПериодичности());
	
	СоответствиеФорматныхСтрок = Новый Соответствие;
	СоответствиеФорматныхСтрок.Вставить(Перечисления.Периодичность.Год, "ДФ=гггг");
	СоответствиеФорматныхСтрок.Вставить(Перечисления.Периодичность.Полугодие, "");
	СоответствиеФорматныхСтрок.Вставить(Перечисления.Периодичность.Квартал, НСтр("ru='ДФ=''к ""квартал"" гггг'''"));
	
	Форма.ФорматныеСтроки = Новый ФиксированноеСоответствие(СоответствиеФорматныхСтрок);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗаполнитьПериодыСтрокой(Форма)
	
	Для Каждого СтрокаТЧ Из Форма.Объект.ПланируемыеРасходы Цикл
		СтрокаТЧ.ПериодСтрокой = ЗарплатаКадрыКлиентСервер.ПолучитьПредставлениеМесяца(СтрокаТЧ.Период);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьФактомПрошлогоПериодаНаСервере(НачалоПериода, КонецПериода)
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	ДокументОбъект.ЗаполнитьРасходамиПрошлогоПериода(НачалоПериода, КонецПериода);
	ЗначениеВРеквизитФормы(ДокументОбъект, "Объект");
	
	Если Объект.ПланируемыеРасходы.Количество() = 0 Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не удалось найти фактического отражения расходов в финансовом учете по заданным критериям.
			|Вероятно, для выбранного периода заполнения не введен документ отражения расходов.'"));
		Возврат;
	КонецЕсли;
	
	ЗаполнитьПериодыСтрокой(ЭтотОбъект);

КонецПроцедуры

&НаКлиенте
Процедура УстановитьПредставлениеПериода()
	
	ФорматнаяСтрока = ФорматныеСтроки.Получить(Объект.Периодичность);
	Если ФорматнаяСтрока <> Неопределено Тогда
		ШагРегулирования = ШагиРегулирования.Получить(Объект.Периодичность);
		ПериодЗаголовка = ДобавитьМесяц(Объект.ПериодПланирования, - ШагРегулирования);
		ПериодЗаголовкаГод = ДобавитьМесяц(Объект.ПериодПланирования, - 12);
		Элементы.ЗаполнитьФактомПрошлогоПериода.Видимость = Истина;
		Элементы.ЗаполнитьФактомПрошлогоПериодаГод.Видимость = ШагРегулирования <> 12;
		Если ШагРегулирования = 6 Тогда
			// нет возможности построить форматную строку для полугодия
			ФорматнаяСтрока = НСтр("ru='ДФ=''"" полугодие"" гггг'''");
			ПредставлениеПериодаПланирования =
				?(Месяц(Объект.ПериодПланирования) / 6 > 1, "2", "1") + Формат(Объект.ПериодПланирования, ФорматнаяСтрока);
			ЗаголовокКнопки = ?(Месяц(ПериодЗаголовка) / 6 > 1, "2", "1") + Формат(ПериодЗаголовка, ФорматнаяСтрока);
			ЗаголовокКнопкиГод = ?(Месяц(ПериодЗаголовкаГод) / 6 > 1, "2", "1") + Формат(ПериодЗаголовкаГод, ФорматнаяСтрока);
		Иначе
			ПредставлениеПериодаПланирования = Формат(Объект.ПериодПланирования, ФорматнаяСтрока);
			ЗаголовокКнопки = Формат(ПериодЗаголовка, ФорматнаяСтрока);
			ЗаголовокКнопкиГод = Формат(ПериодЗаголовкаГод, ФорматнаяСтрока);
		КонецЕсли;
		Элементы.ЗаполнитьФактомПрошлогоПериода.Заголовок = ЗаголовокКнопки;
		Элементы.ЗаполнитьФактомПрошлогоПериодаГод.Заголовок = ЗаголовокКнопкиГод;
	Иначе
		ПредставлениеПериодаПланирования = "";
		Элементы.ЗаполнитьФактомПрошлогоПериода.Видимость = Ложь;
		Элементы.ЗаполнитьФактомПрошлогоПериодаГод.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПоКадровомуПлануПослеВопроса(Результат, ДополнительныеПараметры) Экспорт
	
	Если Не Результат = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ЗарплатаКадрыКлиент.КлючевыеРеквизитыЗаполненияФормыОчиститьТаблицы(ЭтотОбъект);
	
	НачатьЗаполнениеПоКадровомуПлану();
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьЗаполнениеПоКадровомуПлану()
	
	ДлительнаяОперация = ДлительнаяОперацияЗаполненияПоКадровомуПлану();
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ТекстСообщения = НСтр("ru = 'Заполнение планируемых расходов по кадровому плану'");
	ПараметрыОжидания.ВыводитьПрогрессВыполнения = Истина;
	ПараметрыОжидания.ВыводитьСообщения = Истина;
	
	Обработчик = Новый ОписаниеОповещения("ЗавершитьЗаполнениеПоКадровомуПлану", ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Обработчик, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервере
Функция ДлительнаяОперацияЗаполненияПоКадровомуПлану()
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		ПараметрыВыполнения, "ФинансовыйУчет.ПланируемыеРасходыПоДаннымКадровогоПлана",
		Объект.Подразделение, Объект.Сценарий, Объект.ПериодПланирования, Объект.Периодичность);
	
КонецФункции

&НаКлиенте
Процедура ЗавершитьЗаполнениеПоКадровомуПлану(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Если Результат.Статус = "Ошибка" Тогда
		ВызватьИсключение Результат.КраткоеПредставлениеОшибки;
	КонецЕсли;
	
	ЗаполнитьПоДаннымКадровогоПланаСервер(Результат.АдресРезультата);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоДаннымКадровогоПланаСервер(АдресРезультата)
	
	Если АдресРезультата = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Результат = ПолучитьИзВременногоХранилища(АдресРезультата);
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Количество() = 0 Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не удалось найти данные кадрового планирования по заданным критериям.
			|Вероятно, для выбранных периода и сценария не введен кадровый план.'"));
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаТаблицы Из Результат Цикл
		ЗаполнитьЗначенияСвойств(Объект.ПланируемыеРасходы.Добавить(), СтрокаТаблицы);
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ПроверитьЗаполнениеПериодовПланируемыхРасходов(Форма, Отказ)
	
	Объект = Форма.Объект;
	НачалоПериода = Объект.ПериодПланирования;
	КонецПериода = ДобавитьМесяц(НачалоПериода - 1, Форма.ШагиРегулирования.Получить(Объект.Периодичность));
	Для Каждого СтрокаТаблицы Из Объект.ПланируемыеРасходы Цикл
		Если СтрокаТаблицы.Период < НачалоПериода Тогда
			ТекстСообщения = НСтр("ru = 'Период расходов в строке меньше заданного в документе.'");
		ИначеЕсли СтрокаТаблицы.Период > КонецПериода Тогда
			ТекстСообщения = НСтр("ru = 'Период расходов в строке больше заданного в документе.'");
		Иначе
			Продолжить;
		КонецЕсли;
		Поле = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти(
			"Объект.ПланируемыеРасходы", СтрокаТаблицы.НомерСтроки, "ПериодСтрокой");
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , Поле, , Отказ);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ПериодСтрокойНачалоВыбораЗавершение(ЗначениеВыбрано, ДополнительныеПараметры) Экспорт
	
	Если Не ЗначениеВыбрано Тогда
		Возврат;
	КонецЕсли;
	
	ПроверитьКоррекностьПериода(Элементы.ПланируемыеРасходы.ТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьКоррекностьПериода(ТекущиеДанные)
	
	ТекстИсключения = "";
	
	Если ТекущиеДанные.Период < Объект.ПериодПланирования Тогда
		ТекстИсключения = НСтр("ru='Нельзя выбрать месяц меньше установленного периода.'");
	КонецЕсли;
	
	ШагРегулирования = ШагиРегулирования.Получить(Объект.Периодичность);
	Если ШагРегулирования <> Неопределено Тогда 
		Если ТекущиеДанные.Период > ДобавитьМесяц(Объект.ПериодПланирования - 1, ШагРегулирования) Тогда
			ТекстИсключения = НСтр("ru='Нельзя выбрать месяц больше установленного периода.'");
		КонецЕсли;
	КонецЕсли;
	
	Если Не ПустаяСтрока(ТекстИсключения) Тогда
		ОбработатьНекорректныйПериод(ТекущиеДанные, ТекстИсключения);
	КонецЕсли;
	
	СтароеЗначениеПериода = ТекущиеДанные.Период;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьНекорректныйПериод(ТекущиеДанные, ТекстИсключения)
	
	ТекущиеДанные.Период = СтароеЗначениеПериода;
	ТекущиеДанные.ПериодСтрокой = ЗарплатаКадрыКлиентСервер.ПолучитьПредставлениеМесяца(СтароеЗначениеПериода);
	
	ВызватьИсключение ТекстИсключения;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СтруктураПредприятияСоответствуетСтруктуреЮридическихЛиц()
	Возврат ОрганизационнаяСтруктура.СтруктураПредприятияСоответствуетСтруктуреЮридическихЛиц()
КонецФункции

&НаСервере
Функция ОписаниеКолонокМакетаДляЗагрузкиРасходов(СтруктурыСоответствуют)
	
	КолонкиМакета = ЗагрузкаДанныхИзФайла.СформироватьОписаниеКолонок(Объект.ПланируемыеРасходы);
	ЗагрузкаДанныхИзФайлаКлиентСервер.УдалитьКолонкуМакета("Подразделение", КолонкиМакета);
	ЗагрузкаДанныхИзФайлаКлиентСервер.УдалитьКолонкуМакета("ПериодСтрокой", КолонкиМакета);
	
	Колонка = ЗагрузкаДанныхИзФайлаКлиентСервер.КолонкаМакета("Период", КолонкиМакета);
	Колонка.Позиция = 1;
	Колонка.ОбязательнаДляЗаполнения = Истина;
	Колонка.Тип = ОбщегоНазначения.ОписаниеТипаСтрока(20);
	
	Колонка = ЗагрузкаДанныхИзФайлаКлиентСервер.ОписаниеКолонкиМакета("КодПодразделения", ОбщегоНазначения.ОписаниеТипаСтрока(9), НСтр("ru = 'Код подразделения'"));
	Колонка.Позиция = 2;
	Колонка.Заголовок = НСтр("ru = 'Код подразделения'");
	Колонка.Подсказка = НСтр("ru = 'Код управленческого подразделения'");
	КолонкиМакета.Добавить(Колонка);
	
	НомерКолонки = 3;
	Если СтруктурыСоответствуют Тогда
		Колонка = ЗагрузкаДанныхИзФайлаКлиентСервер.КолонкаМакета("КодПодразделения", КолонкиМакета);
		Колонка.Подсказка = НСтр("ru = 'Код юридического подразделения'");
		
		Колонка = ЗагрузкаДанныхИзФайлаКлиентСервер.ОписаниеКолонкиМакета(
			"Организация", ОбщегоНазначения.ОписаниеТипаСтрока(150), НСтр("ru = 'Организация'"), , НСтр("ru = 'Наименование организации'"));
		Колонка.Позиция = 3;
		КолонкиМакета.Добавить(Колонка);
		НомерКолонки = 4;
	КонецЕсли;
	
	Колонка = ЗагрузкаДанныхИзФайлаКлиентСервер.КолонкаМакета("СтатьяРасходов", КолонкиМакета);
	Колонка.Позиция = НомерКолонки;
	Колонка.Заголовок = НСтр("ru = 'Статья расходов'");
	Колонка.Тип = ОбщегоНазначения.ОписаниеТипаСтрока(100);
	НомерКолонки = НомерКолонки + 1;
	
	Колонка = ЗагрузкаДанныхИзФайлаКлиентСервер.КолонкаМакета("НаправлениеДеятельности", КолонкиМакета);
	Колонка.Позиция = НомерКолонки;
	Колонка.Заголовок = НСтр("ru = 'Направление деятельности'");
	Колонка.Тип = ОбщегоНазначения.ОписаниеТипаСтрока(100);
	НомерКолонки = НомерКолонки + 1;
	
	Колонка = ЗагрузкаДанныхИзФайлаКлиентСервер.КолонкаМакета("АналитикаРасходов", КолонкиМакета);
	Колонка.Позиция = НомерКолонки;
	Колонка.Заголовок = НСтр("ru = 'Аналитика расходов'");
	Колонка.Тип = ОбщегоНазначения.ОписаниеТипаСтрока(100);
	НомерКолонки = НомерКолонки + 1;
	
	Колонка = ЗагрузкаДанныхИзФайлаКлиентСервер.КолонкаМакета("СуммаРасходов", КолонкиМакета);
	Колонка.Позиция = НомерКолонки;
	Колонка.Заголовок = НСтр("ru = 'Сумма'");
	Колонка.ОбязательнаДляЗаполнения = Истина;
	НомерКолонки = НомерКолонки + 1;
	
	Колонка = ЗагрузкаДанныхИзФайлаКлиентСервер.КолонкаМакета("КатегорияРасходов", КолонкиМакета);
	Колонка.Позиция = НомерКолонки;
	Колонка.Заголовок = НСтр("ru = 'Категория расходов'");
	Колонка.Тип = ОбщегоНазначения.ОписаниеТипаСтрока(100);
	НомерКолонки = НомерКолонки + 1;
	
	Возврат КолонкиМакета;
	
КонецФункции

&НаКлиенте
Процедура ЗагрузитьИзФайлаЗавершение(АдресЗагруженныхДанных, ДополнительныеПараметры) Экспорт
	
	Если АдресЗагруженныхДанных = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗагрузитьИзФайлаНаСервере(АдресЗагруженныхДанных);
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьИзФайлаНаСервере(АдресЗагруженныхДанных)
	
	ЗагруженныеДанные = ПолучитьИзВременногоХранилища(АдресЗагруженныхДанных);
	
	РасходыДобавлены = Ложь;
	Для каждого СтрокаТаблицы Из ЗагруженныеДанные Цикл
		Если Не ЗначениеЗаполнено(СтрокаТаблицы.Период) Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрокаРасходы = Объект.ПланируемыеРасходы.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрокаРасходы, СтрокаТаблицы);
		НоваяСтрокаРасходы.ПериодСтрокой = ЗарплатаКадрыКлиентСервер.ПолучитьПредставлениеМесяца(НоваяСтрокаРасходы.Период);
		РасходыДобавлены = Истина;
	КонецЦикла;
	
	Если РасходыДобавлены Тогда
		Модифицированность = Истина;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти