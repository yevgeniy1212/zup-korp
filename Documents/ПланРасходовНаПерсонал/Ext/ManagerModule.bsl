//
Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	
КонецПроцедуры

#Область ЗагрузкаДанныхИзФайла

Функция ВыгрузитьКолонку(ЗагружаемыеДанные, ИмяКолонки)
	
	Таблица = ЗагружаемыеДанные.Скопировать();
	Таблица.Свернуть(ИмяКолонки);
	
	Возврат Таблица.ВыгрузитьКолонку(ИмяКолонки);

КонецФункции

Процедура ЗаполнитьПериодИзСтрокиВДату(НоваяСтрока, СоответствиеСтрокДатам, СтрокаПериод)
	
	Период = СоответствиеСтрокДатам.Получить(СтрокаПериод);
	
	Если Период = Неопределено Тогда
		Период = СтроковыеФункцииКлиентСервер.СтрокаВДату(СтрокаПериод);
		СоответствиеСтрокДатам.Вставить(СтрокаПериод, Период);
	КонецЕсли;
	
	НоваяСтрока.Период = Период;

КонецПроцедуры

Процедура ПроверитьНеоднозначностьЗначения(НоваяСтрока, СтрокаТаблицы, СоответствиеЗначений, СписокНеоднозначностей, ТаблицаЗагрузки, ИмяКолонки)
	
	НоваяСтрока[ИмяКолонки] = СоответствиеЗначений.Получить(СтрокаТаблицы[ИмяКолонки]);
	Если ЗначениеЗаполнено(НоваяСтрока[ИмяКолонки]) Тогда
		Возврат;
	КонецЕсли;
	Отбор = Новый Структура(ИмяКолонки, СтрокаТаблицы[ИмяКолонки]);
	Строки = ТаблицаЗагрузки.НайтиСтроки(Отбор);
	Если Строки.Количество() = 1 Тогда 
		НоваяСтрока[ИмяКолонки] = Строки[0].Ссылка;
		СоответствиеЗначений.Вставить(СтрокаТаблицы[ИмяКолонки], НоваяСтрока[ИмяКолонки]);
	ИначеЕсли Строки.Количество() > 1 Тогда
		ЗаписьОНеоднозначности = СписокНеоднозначностей.Добавить();
		ЗаписьОНеоднозначности.Идентификатор = СтрокаТаблицы.Идентификатор; 
		ЗаписьОНеоднозначности.Колонка = ИмяКолонки;
	КонецЕсли;

КонецПроцедуры

Процедура ПроверитьНеоднозначностьПодразделения(НоваяСтрока, СтрокаТаблицы, КэшДанныхЗагрузки, СписокНеоднозначностей, РезультатЗагрузки, СтруктурыСоответствуют)
	
	Если ПустаяСтрока(СтрокаТаблицы.КодПодразделения) Тогда
		Возврат;
	КонецЕсли;
	Если СтруктурыСоответствуют И Не ПустаяСтрока(СтрокаТаблицы.Организация) Тогда
		Отбор = Новый Структура("Организация, КодПодразделения", СтрокаТаблицы.Организация, СтрокаТаблицы.КодПодразделения);
		НоваяСтрока.Подразделение = КэшДанныхЗагрузки.СоответствиеПодразделенийПоОтбору.Получить(Отбор);
		Если ЗначениеЗаполнено(НоваяСтрока.Подразделение) Тогда
			Возврат;
		КонецЕсли;
		Строки = РезультатЗагрузки.ТаблицаОрганизацийКодыИсточников.НайтиСтроки(Отбор);
		Если Строки.Количество() = 1 Тогда 
			НоваяСтрока.Подразделение = Строки[0].Ссылка;
			КэшДанныхЗагрузки.СоответствиеПодразделенийПоОтбору.Вставить(Отбор, НоваяСтрока.Подразделение);
			КэшДанныхЗагрузки.СоответствиеКодовПодразделений.Вставить(СтрокаТаблицы.КодПодразделения, НоваяСтрока.Подразделение);
		ИначеЕсли Строки.Количество() > 1 Тогда
			ЗаписьОНеоднозначности = СписокНеоднозначностей.Добавить();
			ЗаписьОНеоднозначности.Идентификатор = СтрокаТаблицы.Идентификатор; 
			ЗаписьОНеоднозначности.Колонка = "Подразделение";
		КонецЕсли;
	Иначе
		НоваяСтрока.Подразделение = КэшДанныхЗагрузки.СоответствиеКодовПодразделений.Получить(СтрокаТаблицы.КодПодразделения);
		Если ЗначениеЗаполнено(НоваяСтрока.Подразделение) Тогда
			Возврат;
		КонецЕсли;
		Отбор = Новый Структура("КодПодразделения", СтрокаТаблицы.КодПодразделения);
		Строки = РезультатЗагрузки.ТаблицаКодыПодразделений.НайтиСтроки(Отбор);
		Если Строки.Количество() = 1 Тогда 
			НоваяСтрока.Подразделение = Строки[0].Ссылка;
			КэшДанныхЗагрузки.СоответствиеКодовПодразделений.Вставить(СтрокаТаблицы.КодПодразделения, НоваяСтрока.Подразделение);
		ИначеЕсли Строки.Количество() > 1 Тогда
			ЗаписьОНеоднозначности = СписокНеоднозначностей.Добавить();
			ЗаписьОНеоднозначности.Идентификатор = СтрокаТаблицы.Идентификатор; 
			ЗаписьОНеоднозначности.Колонка = "Подразделение";
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура СохранитьПроиндексированныйРезультат(РезультатЗагрузки, ТаблицаВыгрузки, ИмяТаблицы, Колонки)
	
	ОбщегоНазначенияБЗК.ДобавитьИндексКоллекции(ТаблицаВыгрузки, Колонки);
	РезультатЗагрузки.Вставить(ИмяТаблицы, ТаблицаВыгрузки);
	
КонецПроцедуры

