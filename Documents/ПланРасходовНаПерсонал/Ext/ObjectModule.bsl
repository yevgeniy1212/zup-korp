#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("Структура") Тогда
		Для Каждого ПараметрЗаполнения Из ДанныеЗаполнения Цикл
			Если НЕ ЗначениеЗаполнено(ЭтотОбъект[ПараметрЗаполнения.Ключ]) Тогда
				ЭтотОбъект[ПараметрЗаполнения.Ключ] = ПараметрЗаполнения.Значение;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, Режим)
	
	Выборка = СформироватьЗапросПоСтрокамДокумента().Выбрать();
	
	Движения.ПланируемыеРасходыНаПерсонал.Очистить();
	Движения.ПланируемыеРасходыНаПерсонал.Записывать = Истина;
	Пока Выборка.Следующий() Цикл
		Движение = Движения.ПланируемыеРасходыНаПерсонал.Добавить();
		ЗаполнитьЗначенияСвойств(Движение, Выборка);
	КонецЦикла;
	
КонецПроцедуры // ОбработкаПроведения()

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Процедура ЗаполнитьРасходамиПрошлогоПериода(НачалоПериода, КонецПериода) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("КоличествоМесяцев", ЗарплатаКадрыРасширенныйКлиентСервер.РазницаВМесяцах(НачалоПериода, ПериодПланирования));
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДОБАВИТЬКДАТЕ(ОтражениеРасходовНаПерсоналОбороты.Период, МЕСЯЦ, &КоличествоМесяцев) КАК Период,
		|	ОтражениеРасходовНаПерсоналОбороты.КатегорияРасходов КАК КатегорияРасходов,
		|	ОтражениеРасходовНаПерсоналОбороты.СтатьяРасходов КАК СтатьяРасходов,
		|	ОтражениеРасходовНаПерсоналОбороты.Подразделение КАК Подразделение,
		|	ОтражениеРасходовНаПерсоналОбороты.НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	ОтражениеРасходовНаПерсоналОбороты.АналитикаРасходов КАК АналитикаРасходов,
		|	СУММА(ОтражениеРасходовНаПерсоналОбороты.СуммаОборот) КАК СуммаРасходов
		|ИЗ
		|	РегистрНакопления.ОтражениеРасходовНаПерсонал.Обороты(&НачалоПериода, &КонецПериода, Месяц, ) КАК ОтражениеРасходовНаПерсоналОбороты
		|
		|СГРУППИРОВАТЬ ПО
		|	ДОБАВИТЬКДАТЕ(ОтражениеРасходовНаПерсоналОбороты.Период, МЕСЯЦ, &КоличествоМесяцев),
		|	ОтражениеРасходовНаПерсоналОбороты.КатегорияРасходов,
		|	ОтражениеРасходовНаПерсоналОбороты.СтатьяРасходов,
		|	ОтражениеРасходовНаПерсоналОбороты.Подразделение,
		|	ОтражениеРасходовНаПерсоналОбороты.НаправлениеДеятельности,
		|	ОтражениеРасходовНаПерсоналОбороты.АналитикаРасходов
		|
		|УПОРЯДОЧИТЬ ПО
		|	Подразделение,
		|	НаправлениеДеятельности,
		|	КатегорияРасходов,
		|	Период
		|АВТОУПОРЯДОЧИВАНИЕ";
	
	ПланируемыеРасходы.Загрузить(Запрос.Выполнить().Выгрузить());
	
КонецПроцедуры // ЗаполнитьРасходамиПрошлогоПериода

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СформироватьЗапросПоСтрокамДокумента()
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДокументыПланирования.Сценарий,
	|	Расходы.Период,
	|	Расходы.НомерСтроки,
	|	Расходы.КатегорияРасходов,
	|	Расходы.СтатьяРасходов,
	|	Расходы.Подразделение,
	|	Расходы.АналитикаРасходов,
	|	Расходы.НаправлениеДеятельности,
	|	Расходы.СуммаРасходов
	|ИЗ
	|	Документ.ПланРасходовНаПерсонал.ПланируемыеРасходы КАК Расходы
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПланРасходовНаПерсонал КАК ДокументыПланирования
	|		ПО Расходы.Ссылка = ДокументыПланирования.Ссылка
	|ГДЕ
	|	Расходы.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	Расходы.НомерСтроки";
	
	Возврат Запрос.Выполнить();
	
КонецФункции

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.'");
#КонецЕсли