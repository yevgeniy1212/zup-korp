&НаКлиенте
Процедура СотрудникиЗаполнить(Команда)
	
	СотрудникиЗаполнитьНаСервере();
	
	Если Элементы.Сотрудники.ТекущаяСтрока = Неопределено И Объект.Сотрудники.Количество() > 0 Тогда
		Элементы.Сотрудники.ТекущаяСтрока = Объект.Сотрудники[0].ПолучитьИдентификатор();
		Модифицированность = Истина;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура РодственникиЗаполнить(Команда)
	
	ТекущиеДанные = Элементы.Сотрудники.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	РодственникиЗаполнитьНаСервере(ТекущиеДанные.Сотрудник);
	УстановитьЗаголовокСтраницыСотрудники();
	
	Если ИспользуютсяУдержания Тогда
		ПересчитатьУдержания(ТекущиеДанные.ФизическоеЛицо, ТекущиеДанные.СпособУдержания);
	КонецЕсли;
	
