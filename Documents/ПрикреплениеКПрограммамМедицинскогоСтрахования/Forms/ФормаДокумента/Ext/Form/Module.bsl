	КонецЕсли;
	
	СотрудникиОбработкаВыбораНаСервере(ТекущиеДанные.Сотрудник);
	ЗаполнитьДействиеИПоказатели();
	
КонецПроцедуры

&НаКлиенте
Процедура СотрудникиДатаНачалаПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.Сотрудники.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СотрудникиДатаНачалаПриИзмененииНаСервере(ТекущиеДанные.Сотрудник, ТекущиеДанные.ДатаПрикрепления, ТекущиеДанные.ДатаРождения);
	ЗаполнитьДействиеИПоказатели();
	
	Если ИспользуютсяУдержания Тогда
		ПересчитатьУдержания(ТекущиеДанные.ФизическоеЛицо, ТекущиеДанные.СпособУдержания);
	КонецЕсли;
	
