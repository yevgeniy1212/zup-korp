&НаКлиенте
Процедура ПроверитьЗаполнениеОтправляемыхДанных(Отказ, ПараметрыЗаписи)
	
	ВыводитьПредупреждение = Ложь;
	Для Каждого СтрокаПараметров Из ЭтотОбъект.ПараметрыПередаваемыхСведений Цикл
		Если СтрокаПараметров.СпособПроверкиЗаполнения = ПредопределенноеЗначение("Перечисление.СпособыПроверкиЗаполненияПерсональныхДанныхМедицинскогоСтрахования.ВыводитьПредупреждение") Тогда
			ВыводитьПредупреждение = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Если ВыводитьПредупреждение Тогда
		
		Отказ = Истина;
		
		ЗакрытьПослеЗаписи =
		ПараметрыЗаписи.Свойство("ЗакрытьПослеЗаписи") И ПараметрыЗаписи.ЗакрытьПослеЗаписи;
		
		ПараметрыОбработчика = Новый Структура;
		ПараметрыОбработчика.Вставить("Записать", Истина);
		ПараметрыОбработчика.Вставить("Закрыть", ЗакрытьПослеЗаписи);
		ПараметрыОбработчика.Вставить("РежимЗаписи", ПараметрыЗаписи.РежимЗаписи);
		
		ОбработчикОтвета = Новый ОписаниеОповещения("ПроверитьЗаполнениеОтправляемыхДанныхПослеОтветаНаВопрос", ЭтотОбъект, ПараметрыОбработчика);
		ПараметрыВопроса = СтандартныеПодсистемыКлиент.ПараметрыВопросаПользователю();
		ПараметрыВопроса.Заголовок = НСтр("ru = 'Отправляемые данные застрахованных не заполнены'");
		ПараметрыВопроса.Картинка = БиблиотекаКартинок.Предупреждение32;
		ПараметрыВопроса.ПредлагатьБольшеНеЗадаватьЭтотВопрос = Ложь;
		
		ТекстВопроса = НСтр("ru = 'В документе не заполнены отправляемые данные, указанные в параметрах договора'");
		
		КнопкиОтвета = Новый СписокЗначений();
		КнопкиОтвета.Добавить(Истина, НСтр("ru = 'Все равно записать'"));
		КнопкиОтвета.Добавить(Ложь, НСтр("ru = 'Отмена'"));
		
		СтандартныеПодсистемыКлиент.ПоказатьВопросПользователю(ОбработчикОтвета, ТекстВопроса, КнопкиОтвета, ПараметрыВопроса);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьЗаполнениеОтправляемыхДанныхПослеОтветаНаВопрос(Ответ, ДополнительныеПараметры) Экспорт

	Если Ответ = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Ответ.Значение <> Истина Тогда
		Возврат;
	КонецЕсли;
	
	Если ДополнительныеПараметры = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ДополнительныеПараметры.Свойство("Записать") И ДополнительныеПараметры.Записать Тогда
		Если ДополнительныеПараметры.Свойство("Закрыть") И ДополнительныеПараметры.Закрыть Тогда
			ПараметрыЗаписи = Новый Структура("ЗакрытьПослеЗаписи, РежимЗаписи", Истина, ДополнительныеПараметры.РежимЗаписи);
			ЗаписатьВыполнить(ПараметрыЗаписи);
		Иначе
			ПараметрыЗаписи = Новый Структура("ЗакрытьПослеЗаписи, РежимЗаписи", Ложь, ДополнительныеПараметры.РежимЗаписи);
			ЗаписатьВыполнить(ПараметрыЗаписи);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьВыполнить(ПараметрыЗаписи)
	
	Если Не ПроверитьЗаполнение() Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыЗаписи.Вставить("ПроверкаПередЗаписьюВыполнена");
	
	Если Не Записать(ПараметрыЗаписи) Тогда
		Возврат;
	КонецЕсли;
	
	Если ПараметрыЗаписи.ЗакрытьПослеЗаписи И Открыта() Тогда
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

