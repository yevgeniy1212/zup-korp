&НаКлиенте
Процедура СотрудникиПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		УстановитьОтборСтрокРодственников(Элементы, Неопределено);
		УстановитьЗаголовокСтраницыСотрудники();
		Возврат;
	КонецЕсли;
	
	УстановитьОтборСтрокРодственников(Элементы, ТекущиеДанные.ФизическоеЛицо);
	УстановитьОтборСтрокПоказателей(Элементы, ТекущиеДанные.ИдентификаторСтрокиВидаРасчета);
	
	УдержатьПриПрикреплении = ТекущиеДанные.СуммаУдержания <> 0;
	ПрекратитьУдержания = ТекущиеДанные.СуммаПредела <> 0;
	
	УстановитьНадписьПрограммСтрахования(ТекущиеДанные);
	УстановитьНадписьРасширенийПрограммСтрахования(ТекущиеДанные);
	
	УстановитьДоступностьЭлементов();
	УстановитьЗаголовокСтраницыСотрудники();
	
	//Удержания
	Если Не ИспользуютсяУдержания Тогда
		Возврат;
	КонецЕсли;
	
	Если ИспользуетсяЧастичноеУдержание Тогда
		ЕстьУдержание = ТекущиеДанные.ОбщаяСуммаУдержания > 0;
		Элементы.ГруппаЧастичноеУдержание.Видимость = ЕстьУдержание;
	КонецЕсли;
	
	УстановитьНадписиУдержаний(ТекущиеДанные.ФизическоеЛицо);
	УстановитьВидимостьГрафикаУдержаний();
	Если ТекущиеДанные.СпособУдержания = ПредопределенноеЗначение("Перечисление.СпособыУдержанияМедицинскогоСтрахованияСотрудников.ПоГрафику") Тогда
		УстановитьОтборГрафикаУдержаний(Элементы, ТекущиеДанные.ФизическоеЛицо);
		ОбновитьПодвалГрафикаУдержаний();
	КонецЕсли;
	
КонецПроцедуры

