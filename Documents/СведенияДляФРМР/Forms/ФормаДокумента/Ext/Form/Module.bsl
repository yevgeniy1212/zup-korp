	Набор.Записать();
	
КонецПроцедуры
												
&НаСервереБезКонтекста
Процедура ЗаписатьРезультатВыгрузкиКвалификации(ФизическоеЛицо, ДатаПрисвоения, Специальность, РазрядКатегория, Идентификатор, МоментВыгрузки);
												
	Набор = РегистрыСведений.ИдентификаторыКвалификацийДляФедеральныхМедрегистров.СоздатьНаборЗаписей();
	Набор.Отбор.ФизическоеЛицо.Установить(ФизическоеЛицо);
	Набор.Отбор.ДатаПрисвоения.Установить(ДатаПрисвоения);
	Набор.Отбор.Специальность.Установить(Специальность);
	Набор.Прочитать();
	Если Набор.Количество() = 0 Тогда
		РезультатВыгрузки = Набор.Добавить();
		РезультатВыгрузки.ФизическоеЛицо = ФизическоеЛицо;
		РезультатВыгрузки.ДатаПрисвоения = ДатаПрисвоения;
		РезультатВыгрузки.Специальность = Специальность;
		РезультатВыгрузки.РазрядКатегория = РазрядКатегория;
	Иначе
		РезультатВыгрузки = Набор[0];
	КонецЕсли;
	РезультатВыгрузки.Идентификатор = Идентификатор;
	РезультатВыгрузки.МоментВыгрузки = МоментВыгрузки;
	Набор.Записать();
	
КонецПроцедуры
												
