				КонецЕсли;
			КонецЦикла;
		
			Если ВыгрузкаНеобходима(Работник.МоментВыгрузки, Работник.МоментИзменения) 
					Или Не ЛичноеДелоРаботникаВыгружено 
					Или Не ОбщееОбразованиеВыгружено 
					Или Не ПрофессиональноеОбразованиеВыгружено 
					Или Не ПослевузовскоеОбразованиеВыгружено 
					Или Не ДополнительноеПрофессиональноеОбразованиеВыгружено 
					Или Не СертификатыРаботникаВыгружены 
					Или Не НаградыРаботникаВыгружены 
					Или Не КвалификацииРаботникаВыгружены Тогда 
				Работник.СтадияВыгрузки = 1;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ДанныеМедицинскогоРаботника(ФизическоеЛицо)
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	
	ПараметрыМедРаботника = Новый Структура;
	ДанныеДляЗаполнения = Новый Структура;
	СтруктураОтбораФизЛицо = Новый Структура("ФизическоеЛицо", ФизическоеЛицо);	

	ДанныеДляЗаполнения.Вставить("Работники", ДокументОбъект.Работники.Выгрузить(СтруктураОтбораФизЛицо));
	ДанныеДляЗаполнения.Вставить("ДокументыУдостоверяющиеЛичность", ДокументОбъект.ДокументыУдостоверяющиеЛичность.Выгрузить(СтруктураОтбораФизЛицо));
	ДанныеДляЗаполнения.Вставить("ЛичноеДело", ДокументОбъект.ЛичноеДело.Выгрузить(СтруктураОтбораФизЛицо));
	ДанныеДляЗаполнения.Вставить("ОбщееОбразование", ДокументОбъект.ОбщееОбразование.Выгрузить(СтруктураОтбораФизЛицо));
	ДанныеДляЗаполнения.Вставить("ПрофессиональноеОбразование", ДокументОбъект.ПрофессиональноеОбразование.Выгрузить(СтруктураОтбораФизЛицо));
	ДанныеДляЗаполнения.Вставить("ПослевузовскоеОбразование", ДокументОбъект.ПослевузовскоеОбразование.Выгрузить(СтруктураОтбораФизЛицо));
	ДанныеДляЗаполнения.Вставить("ДополнительноеПрофессиональноеОбразование", ДокументОбъект.ДополнительноеПрофессиональноеОбразование.Выгрузить(СтруктураОтбораФизЛицо));
	ДанныеДляЗаполнения.Вставить("Сертификаты", ДокументОбъект.Сертификаты.Выгрузить(СтруктураОтбораФизЛицо));
	ДанныеДляЗаполнения.Вставить("Награды", ДокументОбъект.Награды.Выгрузить(СтруктураОтбораФизЛицо));
	ДанныеДляЗаполнения.Вставить("Квалификация", ДокументОбъект.Квалификация.Выгрузить(СтруктураОтбораФизЛицо));
	
	ПараметрыМедРаботника.Вставить("ДанныеДляЗаполнения", ДанныеДляЗаполнения); 

	Возврат ПоместитьВоВременноеХранилище(ПараметрыМедРаботника);

КонецФункции

#КонецОбласти

#Область Выгрузка

&НаКлиенте
Процедура ВыгрузитьВФРМРНаКлиенте() 
	
	Если Модифицированность Тогда
		Если Не Записать() Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;	
	
	ПараметрыОтбора = Новый Структура("ФизическоеЛицо", Неопределено);
	ПараметрыСервиса = ПараметрыСервиса();
	
	// Здесь удаление из ФРМР и (при успехе) из регистров лога.
	// Если удаляется весь медработник, то, наверное, предварительно удалять все его данные не нужно.
	// ---------
	
	// Здесь перечитывание регистров лога, чтобы не было недействительных идентификаторов после 
	// удаления строк из регистров лога (актуально для образований медработников).
	// Хорошо бы как-то более точечно, чем вызовом процедуры ЗаполнитьТекущиеПозицииРаботников().
//	ЗаполнитьТекущиеПозицииРаботников();

	Для Каждого Работник Из Объект.Работники Цикл
		
		СНИЛС = МедицинскиеРегистрыКлиент.ТолькоЦифры(Работник.СтраховойНомерПФР);
		
		ПараметрыОтбора.ФизическоеЛицо = Работник.ФизическоеЛицо;
		НайденныеСтрокиДокументыУдостоверяющиеЛичность = Объект.ДокументыУдостоверяющиеЛичность.НайтиСтроки(ПараметрыОтбора);
		
		НайденныеСтроки = Новый Структура("ЛичноеДело,ОбщееОбразование,ПрофессиональноеОбразование,ПослевузовскоеОбразование,ДополнительноеПрофессиональноеОбразование,Сертификаты,Награды,Квалификация");
		НайденныеСтроки.ЛичноеДело = Объект.ЛичноеДело.НайтиСтроки(ПараметрыОтбора);
		НайденныеСтроки.ОбщееОбразование = Объект.ОбщееОбразование.НайтиСтроки(ПараметрыОтбора);
		НайденныеСтроки.ПрофессиональноеОбразование = Объект.ПрофессиональноеОбразование.НайтиСтроки(ПараметрыОтбора);
		НайденныеСтроки.ПослевузовскоеОбразование = Объект.ПослевузовскоеОбразование.НайтиСтроки(ПараметрыОтбора);
		НайденныеСтроки.ДополнительноеПрофессиональноеОбразование = Объект.ДополнительноеПрофессиональноеОбразование.НайтиСтроки(ПараметрыОтбора);
		НайденныеСтроки.Сертификаты = Объект.Сертификаты.НайтиСтроки(ПараметрыОтбора);
		НайденныеСтроки.Награды = Объект.Награды.НайтиСтроки(ПараметрыОтбора);
		НайденныеСтроки.Квалификация = Объект.Квалификация.НайтиСтроки(ПараметрыОтбора);
		
#Область ПодборИдентификаторовФРМР
		
		РаботникИдентифицирован = Не ПустаяСтрока(Работник.Идентификатор);
		ВсеОбъектыИдентифицированы = Истина;
		Для Каждого ЭлементСтруктуры Из НайденныеСтроки Цикл
			Для Каждого БлокДанных Из ЭлементСтруктуры.Значение Цикл
				Если Не ЗначениеЗаполнено(БлокДанных.Идентификатор) Тогда 
					ВсеОбъектыИдентифицированы = Ложь;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			Если Не ВсеОбъектыИдентифицированы Тогда 
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		PersonKey = PersonKey();
	    PersonKey.mo = Объект.УИНОрганизации;
	    PersonKey.mr = Работник.ЯвляетсяМедработником;
		
		Если ВсеОбъектыИдентифицированы И РаботникИдентифицирован Тогда 
			// Ничего дополнительно получать не нужно, все идентификаторы заполнены.
			PersonKey.oid = Работник.Идентификатор;
		Иначе
			Если ВсеОбъектыИдентифицированы И Не РаботникИдентифицирован Тогда 
				// Получаем только данные непосредственно работника для определения oid.
				PersonKey.snils = СНИЛС;
				ПараметрыВызова = GetPerson(PersonKey);
				ТокенДоступа = ТокенДоступа(ПараметрыСервиса);
				ОтветСервиса = ВызватьМетод(ТокенДоступа, ПараметрыВызова);
				Если ОтветСервиса.КодСостояния<400 Тогда 
					Если ОтветСервиса.Контент<>Неопределено Тогда
						ПрисвоенныйИдентификатор = Неопределено;
						ОтветСервиса.Контент.Свойство("oid", ПрисвоенныйИдентификатор);
						Если ПрисвоенныйИдентификатор<>Неопределено И Работник.Идентификатор<>ПрисвоенныйИдентификатор Тогда
							Работник.Идентификатор = ПрисвоенныйИдентификатор;
							ЗаписатьРезультатВыгрузки(Работник.ФизическоеЛицо, ПрисвоенныйИдентификатор, Неопределено, Неопределено);
							PersonKey.oid = ПрисвоенныйИдентификатор;
							PersonKey.snils = Неопределено;
							РаботникИдентифицирован = Истина;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				Если ОтветСервиса.КодСостояния>200 И ОтветСервиса.СообщениеОбОшибкеПользователю<>Неопределено Тогда
					СообщениеОбОшибкеПользователю = СтрШаблон(НСтр("ru = 'Получение базовых данных медработника: %1'"), 
						ОтветСервиса.СообщениеОбОшибкеПользователю);
					ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибкеПользователю, , 
						СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Объект.Работники[%1].ФизическоеЛицо", Работник.НомерСтроки-1));
				КонецЕсли;
			Иначе
				// Получаем полные данные работника (не важно по oid или по СНИЛСу) для заполнения
				// идентификаторов в ТЧ или идентификатора работника и идентификаторов в ТЧ.
				Если РаботникИдентифицирован Тогда  
					PersonKey.oid = Работник.Идентификатор;
			    Иначе 
					PersonKey.snils = СНИЛС;
				КонецЕсли;
				ПараметрыВызова = GetPersonFull(PersonKey);
				ТокенДоступа = ТокенДоступа(ПараметрыСервиса);
				ОтветСервиса = ВызватьМетод(ТокенДоступа, ПараметрыВызова);
				Если ОтветСервиса.КодСостояния<400 Тогда 
					Если ОтветСервиса.Контент<>Неопределено Тогда
						Если Не РаботникИдентифицирован Тогда
							ПрисвоенныйИдентификатор = Неопределено;
							ОтветСервиса.Контент.Свойство("oid", ПрисвоенныйИдентификатор);
							Если ПрисвоенныйИдентификатор<>Неопределено И Работник.Идентификатор<>ПрисвоенныйИдентификатор Тогда
								Работник.Идентификатор = ПрисвоенныйИдентификатор;
								ЗаписатьРезультатВыгрузки(Работник.ФизическоеЛицо, ПрисвоенныйИдентификатор, Неопределено, Неопределено);
								PersonKey.oid = ПрисвоенныйИдентификатор;
								PersonKey.snils = Неопределено;
								РаботникИдентифицирован = Истина;
							КонецЕсли;
						КонецЕсли;
						// Тут заполнение идентификаторов в ТЧ.
						Если НайденныеСтроки.ЛичноеДело.Количество()>0 Тогда 
							РазделЛичноеДело = Неопределено;
							Если ОтветСервиса.Контент.Свойство("personCard", РазделЛичноеДело) Тогда
								Если РазделЛичноеДело<>Неопределено Тогда 
									// Сертификатов может быть несколько. Нужно подбирать по специальности и дате получения.
									Для Каждого ЛичноеДелоФРМР Из РазделЛичноеДело Цикл 
									    ОрганизацияЛичногоДелаФРМР = Неопределено;
									    ИдентификаторЛичногоДелаФРМР = Неопределено;
									    ТабельныйНомерЛичногоДелаФРМР = Неопределено;
									    ДатаНачалаЗаписиЛичногоДелаФРМР = Неопределено;
										Если ЛичноеДелоФРМР.Свойство("oid", ОрганизацияЛичногоДелаФРМР) 
												И ЛичноеДелоФРМР.Свойство("id", ИдентификаторЛичногоДелаФРМР) 
												И ЛичноеДелоФРМР.Свойство("serviceNumber", ТабельныйНомерЛичногоДелаФРМР) 
												И ЛичноеДелоФРМР.Свойство("beginDate", ДатаНачалаЗаписиЛичногоДелаФРМР) Тогда
											Для Каждого ЛичноеДелоИБ Из НайденныеСтроки.ЛичноеДело Цикл
												Если Объект.УИНОрганизации=ОрганизацияЛичногоДелаФРМР 
														И ЛичноеДелоИБ.ТабельныйНомер=ТабельныйНомерЛичногоДелаФРМР 
														И ЛичноеДелоИБ.ДатаНачалаЗаписи=МедицинскиеРегистрыКлиент.ДатаИзUTC(ДатаНачалаЗаписиЛичногоДелаФРМР) Тогда 
													ЛичноеДелоИБ.Идентификатор = ИдентификаторЛичногоДелаФРМР;
													ЗаписатьРезультатВыгрузкиЛичногоДела(Работник.ФизическоеЛицо, Объект.УИНОрганизации, ЛичноеДелоИБ.ТабельныйНомер, 
															ЛичноеДелоИБ.ДатаНачалаЗаписи, ЛичноеДелоИБ.Идентификатор, ЛичноеДелоИБ.МоментВыгрузки);
												КонецЕсли;
											КонецЦикла;
										КонецЕсли;
									КонецЦикла;
								КонецЕсли;
							КонецЕсли;
						КонецЕсли;
						Если НайденныеСтроки.ОбщееОбразование.Количество()>0 Тогда 
							РазделОбразование = Неопределено;
							Если ОтветСервиса.Контент.Свойство("educationCommon", РазделОбразование) Тогда
								Если РазделОбразование<>Неопределено Тогда 
									// Общее образование может быть только одно. Поэтому получили не массив, а простой объект json.
								    ПрисвоенныйИдентификаторРазделОбщееОбразование = Неопределено;
									Если РазделОбразование.Свойство("commonId", ПрисвоенныйИдентификаторРазделОбщееОбразование) Тогда 
										СтрокаОбщееОбразование = НайденныеСтроки.ОбщееОбразование[0];
										СтрокаОбщееОбразование.Идентификатор = ПрисвоенныйИдентификаторРазделОбщееОбразование;
										ЗаписатьРезультатВыгрузки(СтрокаОбщееОбразование.ОбразованиеРаботника, СтрокаОбщееОбразование.Идентификатор, 
												Неопределено, Неопределено);
									КонецЕсли;
								КонецЕсли;
							КонецЕсли;
						КонецЕсли;
						Если НайденныеСтроки.ПрофессиональноеОбразование.Количество()>0 Тогда 
							РазделОбразование = Неопределено;
							Если ОтветСервиса.Контент.Свойство("educationProf", РазделОбразование) Тогда
								Если РазделОбразование<>Неопределено Тогда 
									// Профессиональных образований может быть несколько. Подбирать по дате диплома.
									Для Каждого ОбразованиеФРМР Из РазделОбразование Цикл 
									    ИдентификаторФРМР = Неопределено;
									    Обучающийся = Неопределено;
									    ДатаДипломаФРМР = Неопределено;
									    ДатаСвидетельстваФРМР = Неопределено;
										Если ОбразованиеФРМР.Свойство("profId", ИдентификаторФРМР) 
												И ОбразованиеФРМР.Свойство("isStudentEducation", Обучающийся)
												И (ОбразованиеФРМР.Свойство("docDate", ДатаДипломаФРМР)
												Или ОбразованиеФРМР.Свойство("foreignCertDate", ДатаСвидетельстваФРМР)) Тогда
											Если Не Обучающийся Тогда
												Для Каждого ОбразованиеИБ Из НайденныеСтроки.ПрофессиональноеОбразование Цикл
													Если ОбразованиеИБ.ДатаВыдачиДиплома=МедицинскиеРегистрыКлиент.ДатаИзUTC(ДатаДипломаФРМР)
															Или ОбразованиеИБ.ДатаВыдачиДиплома=МедицинскиеРегистрыКлиент.ДатаИзUTC(ДатаСвидетельстваФРМР) Тогда 
														ОбразованиеИБ.Идентификатор = ИдентификаторФРМР;
														ЗаписатьРезультатВыгрузки(ОбразованиеИБ.ОбразованиеРаботника, ОбразованиеИБ.Идентификатор, 
																Неопределено, Неопределено);
													КонецЕсли;
												КонецЦикла;
											КонецЕсли;
										КонецЕсли;
									КонецЦикла;
								КонецЕсли;
							КонецЕсли;
						КонецЕсли;
						Если НайденныеСтроки.ПослевузовскоеОбразование.Количество()>0 Тогда 
							РазделОбразование = Неопределено;
							Если ОтветСервиса.Контент.Свойство("educationPostgraduate", РазделОбразование) Тогда
								Если РазделОбразование<>Неопределено Тогда 
									// Послевузовских образований может быть несколько. Подбирать по дате диплома.
									Для Каждого ОбразованиеФРМР Из РазделОбразование Цикл 
									    ИдентификаторФРМР = Неопределено;
									    Обучающийся = Неопределено;
									    ДатаДипломаФРМР = Неопределено;
									    ДатаСвидетельстваФРМР = Неопределено;
										Если ОбразованиеФРМР.Свойство("postgraduateId", ИдентификаторФРМР) 
												И ОбразованиеФРМР.Свойство("isStudying", Обучающийся)
												И (ОбразованиеФРМР.Свойство("docDate", ДатаДипломаФРМР)
												Или ОбразованиеФРМР.Свойство("foreignCertDate", ДатаСвидетельстваФРМР)) Тогда
											Если Не Обучающийся Тогда
												Для Каждого ОбразованиеИБ Из НайденныеСтроки.ПослевузовскоеОбразование Цикл
													Если ОбразованиеИБ.ДатаВыдачиДиплома=МедицинскиеРегистрыКлиент.ДатаИзUTC(ДатаДипломаФРМР)
															Или ОбразованиеИБ.ДатаВыдачиДиплома=МедицинскиеРегистрыКлиент.ДатаИзUTC(ДатаСвидетельстваФРМР) Тогда 
														ОбразованиеИБ.Идентификатор = ИдентификаторФРМР;
														ЗаписатьРезультатВыгрузки(ОбразованиеИБ.ОбразованиеРаботника, ОбразованиеИБ.Идентификатор, 
																Неопределено, Неопределено);
													КонецЕсли;
												КонецЦикла;
											КонецЕсли;
										КонецЕсли;
									КонецЦикла;
								КонецЕсли;
							КонецЕсли;
						КонецЕсли;
						Если НайденныеСтроки.ДополнительноеПрофессиональноеОбразование.Количество()>0 Тогда 
							РазделОбразование = Неопределено;
							Если ОтветСервиса.Контент.Свойство("educationExt", РазделОбразование) Тогда
								Если РазделОбразование<>Неопределено Тогда 
									// Послевузовских образований может быть несколько. Подбирать по дате диплома.
									Для Каждого ОбразованиеФРМР Из РазделОбразование Цикл 
									    ИдентификаторФРМР = Неопределено;
									    ДатаДипломаФРМР = Неопределено;
										Если ОбразованиеФРМР.Свойство("extId", ИдентификаторФРМР) 
												И (ОбразованиеФРМР.Свойство("docDate", ДатаДипломаФРМР)) Тогда
											Для Каждого ОбразованиеИБ Из НайденныеСтроки.ДополнительноеПрофессиональноеОбразование Цикл
												Если ОбразованиеИБ.ДатаВыдачиДиплома=МедицинскиеРегистрыКлиент.ДатаИзUTC(ДатаДипломаФРМР) Тогда 
													ОбразованиеИБ.Идентификатор = ИдентификаторФРМР;
													ЗаписатьРезультатВыгрузки(ОбразованиеИБ.ОбразованиеРаботника, ОбразованиеИБ.Идентификатор, 
															Неопределено, Неопределено);
												КонецЕсли;
											КонецЦикла;
										КонецЕсли;
									КонецЦикла;
								КонецЕсли;
							КонецЕсли;
						КонецЕсли;
						Если НайденныеСтроки.Сертификаты.Количество()>0 Тогда 
							РазделСертификаты = Неопределено;
							Если ОтветСервиса.Контент.Свойство("educationCert", РазделСертификаты) Тогда
								Если РазделСертификаты<>Неопределено Тогда 
									// Сертификатов может быть несколько. Нужно подбирать по специальности и дате получения.
									Для Каждого СертификатФРМР Из РазделСертификаты Цикл 
									    ИдентификаторСертификатаФРМР = Неопределено;
									    ДатаПолученияСертификатаФРМР = Неопределено;
									    СпециальностьКодСертификатаФРМР = Неопределено;
										Если СертификатФРМР.Свойство("certId", ИдентификаторСертификатаФРМР) 
												И СертификатФРМР.Свойство("examDate", ДатаПолученияСертификатаФРМР) 
												И СертификатФРМР.Свойство("specId", СпециальностьКодСертификатаФРМР) Тогда
											Для Каждого СертификатИБ Из НайденныеСтроки.Сертификаты Цикл
												Если СертификатИБ.СпециальностьКод=Формат(СпециальностьКодСертификатаФРМР, "ЧГ=0") 
														И СертификатИБ.ДатаПолучения=МедицинскиеРегистрыКлиент.ДатаИзUTC(ДатаПолученияСертификатаФРМР) Тогда 
													СертификатИБ.Идентификатор = ИдентификаторСертификатаФРМР;
													ЗаписатьРезультатВыгрузкиСертификата(Работник.ФизическоеЛицо, СертификатИБ.Специальность, 
															СертификатИБ.ДатаПолучения, СертификатИБ.Идентификатор, СертификатИБ.МоментВыгрузки);
												КонецЕсли;
											КонецЦикла;
										КонецЕсли;
									КонецЦикла;
								КонецЕсли;
							КонецЕсли;
						КонецЕсли;
						Если НайденныеСтроки.Награды.Количество()>0 Тогда 
							РазделНаграды = Неопределено;
							Если ОтветСервиса.Контент.Свойство("personNomination", РазделНаграды) Тогда
								Если РазделНаграды<>Неопределено Тогда 
									// Наград может быть несколько. Нужно подбирать по награде, номеру и дате.
									Для Каждого НаградаФРМР Из РазделНаграды Цикл 
									    ИдентификаторНаградыФРМР = Неопределено;
									    КодНаградыФРМР = Неопределено;
									    ДатаНаградыФРМР = Неопределено;
									    НомерНаградыФРМР = Неопределено;
										Если НаградаФРМР.Свойство("entityId", ИдентификаторНаградыФРМР) 
												И НаградаФРМР.Свойство("nomNumber", НомерНаградыФРМР) 
												И НаградаФРМР.Свойство("nomDate", ДатаНаградыФРМР) 
												И НаградаФРМР.Свойство("nominationId", КодНаградыФРМР) Тогда
											Для Каждого НаградаИБ Из НайденныеСтроки.Награды Цикл
												Если НаградаИБ.НаградаКод=Формат(КодНаградыФРМР, "ЧГ=0") 
														И НаградаИБ.НомерПриказа=НомерНаградыФРМР 
														И НаградаИБ.ДатаПриказа=МедицинскиеРегистрыКлиент.ДатаИзUTC(ДатаНаградыФРМР) Тогда 
													НаградаИБ.Идентификатор = ИдентификаторНаградыФРМР;
													ЗаписатьРезультатВыгрузкиНаграды(Работник.ФизическоеЛицо, НаградаИБ.Награда, НаградаИБ.ДатаПриказа, 
															НаградаИБ.НомерПриказа, НаградаИБ.Идентификатор, НаградаИБ.МоментВыгрузки);
												КонецЕсли;
											КонецЦикла;
										КонецЕсли;
									КонецЦикла;
								КонецЕсли;
							КонецЕсли;
						КонецЕсли;
						Если НайденныеСтроки.Квалификация.Количество()>0 Тогда 
							РазделКвалификация = Неопределено;
							Если ОтветСервиса.Контент.Свойство("personQualification", РазделКвалификация) Тогда
								Если РазделКвалификация<>Неопределено Тогда 
									// Квалификаций может быть несколько. Нужно подбирать по дате присвоения квалификационной категории, по специальности или по должности.
									// В отличие от ФРМР, в ИБ квалификация устанавливается только для специальности (не для должности), поэтому в каждой записи ИБ специальность
									// заполнена, однако при подготовке данных для выгрузки должность также подбирается в запросе и выгружается в ФРМР для немедицинских должностей.
									// Поэтому, строку в ИБ необходимо подобрать и по должности (если специальность не заполнена), 
									// однако результат будет всё равно залогирован по специальности.
									Для Каждого КвалификацияФРМР Из РазделКвалификация Цикл 
									    ИдентификаторКвалификацииФРМР = Неопределено;
										ДатаПрисвоенияФРМР = Неопределено;
										КодСпециальностиФРМР = Неопределено;
										КодДолжностиПоФедСправочникуФРМР = Неопределено;
										КодДолжностиФРМР = Неопределено;
										Если КвалификацияФРМР.Свойство("qualificationId", ИдентификаторКвалификацииФРМР) 
												И КвалификацияФРМР.Свойство("beginDate", ДатаПрисвоенияФРМР) Тогда
											УказанКодСпециальностиФРМР = КвалификацияФРМР.Свойство("specId", КодСпециальностиФРМР) И КодСпециальностиФРМР<>Неопределено;
											УказанКодДолжностиПоФедСправочникуФРМР = КвалификацияФРМР.Свойство("fedPostId", КодДолжностиПоФедСправочникуФРМР) 
											                                         И КодДолжностиПоФедСправочникуФРМР<>Неопределено;
											УказанКодДолжностиФРМР = КвалификацияФРМР.Свойство("postId", КодДолжностиФРМР) И КодДолжностиФРМР<>Неопределено;
											Для Каждого КвалификацияИБ Из НайденныеСтроки.Квалификация Цикл
												Если ДанныеКвалификацийСовпадают(КвалификацияИБ, ДатаПрисвоенияФРМР, КодДолжностиПоФедСправочникуФРМР, КодДолжностиФРМР, КодСпециальностиФРМР, 
													                             УказанКодДолжностиПоФедСправочникуФРМР, УказанКодДолжностиФРМР, УказанКодСпециальностиФРМР) Тогда
													КвалификацияИБ.Идентификатор = ИдентификаторКвалификацииФРМР;
													ЗаписатьРезультатВыгрузкиКвалификации(Работник.ФизическоеЛицо, КвалификацияИБ.ДатаПрисвоения, КвалификацияИБ.Специальность, 
															КвалификацияИБ.РазрядКатегория, КвалификацияИБ.Идентификатор, КвалификацияИБ.МоментВыгрузки);
												КонецЕсли;
											КонецЦикла;
										КонецЕсли;
									КонецЦикла;
								КонецЕсли;
							КонецЕсли;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				Если ОтветСервиса.СообщениеОбОшибкеПользователю<>Неопределено Тогда
					СообщениеОбОшибкеПользователю = СтрШаблон(НСтр("ru = 'Получение подробных данных медработника: %1'"), ОтветСервиса.СообщениеОбОшибкеПользователю);
					ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибкеПользователю, , 
						СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Объект.Работники[%1].ФизическоеЛицо", Работник.НомерСтроки-1));
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
#КонецОбласти
#Область ПроведениеВыгрузкиВФРМР

		ВыгрузкаПроизводилась = Ложь;
		ВыгрузкаВыполнена = Истина;
		
		// Основные данные работника.
		Если ВыгрузкаНеобходима(Работник.МоментВыгрузки, Работник.МоментИзменения) Тогда
			ВыгрузкаПроизводилась = Истина;
			PersonData = ПодготовитьОбщиеДанныеРаботника(Работник, НайденныеСтрокиДокументыУдостоверяющиеЛичность);
			ПараметрыВызова = PostPutPerson(PersonKey, PersonData);
			ТокенДоступа = ТокенДоступа(ПараметрыСервиса);
			ОтветСервиса = ВызватьМетод(ТокенДоступа, ПараметрыВызова);
			Если ОтветСервиса.КодСостояния<400 Тогда 
				Если ПараметрыВызова.Метод = "POST" И ОтветСервиса.Контент<>Неопределено Тогда 
					ПрисвоенныйИдентификатор = Неопределено;
					ОтветСервиса.Контент.Свойство("entityId", ПрисвоенныйИдентификатор);
					Если ПрисвоенныйИдентификатор<>Неопределено Тогда
						PersonKey.oid = ПрисвоенныйИдентификатор;
						PersonKey.snils = Неопределено;
						Работник.Идентификатор = ПрисвоенныйИдентификатор;
						Работник.МоментВыгрузки = МоментВыгрузкиНаСервере();
						ЗаписатьРезультатВыгрузки(Работник.ФизическоеЛицо, Работник.Идентификатор, Работник.МоментВыгрузки, ПараметрыВызова.РазделМедрегистра);
					Иначе 
						ВыгрузкаВыполнена = Ложь;
					КонецЕсли;
				ИначеЕсли ПараметрыВызова.Метод = "PUT" И ОтветСервиса.СообщениеОбОшибкеПользователю=Неопределено Тогда
					Работник.МоментВыгрузки = МоментВыгрузкиНаСервере();
					ЗаписатьРезультатВыгрузки(Работник.ФизическоеЛицо, Работник.Идентификатор, Работник.МоментВыгрузки, ПараметрыВызова.РазделМедрегистра);
				Иначе 
					ВыгрузкаВыполнена = Ложь;
				КонецЕсли;
			Иначе 
				ВыгрузкаВыполнена = Ложь;
			КонецЕсли;
			Если ОтветСервиса.СообщениеОбОшибкеПользователю<>Неопределено Тогда
				СообщениеОбОшибкеПользователю = СтрШаблон(НСтр("ru = 'Выгрузка базовых данных медработника: %1'"), ОтветСервиса.СообщениеОбОшибкеПользователю);
				ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибкеПользователю, , 
					СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Объект.Работники[%1].ФизическоеЛицо", Работник.НомерСтроки-1));
			КонецЕсли;
		КонецЕсли;
		
		// Личное дело.
		Для Каждого ЛичноеДелоРаботника Из НайденныеСтроки.ЛичноеДело Цикл
			Если ВыгрузкаНеобходима(ЛичноеДелоРаботника.МоментВыгрузки, ЛичноеДелоРаботника.МоментИзменения) Тогда
				ВыгрузкаПроизводилась = Истина;
				PersonCardData = ПодготовитьДанныеЛичногоДела(ЛичноеДелоРаботника);
				ПараметрыВызова = PostPutPersonCard(PersonKey, PersonCardData);
				ТокенДоступа = ТокенДоступа(ПараметрыСервиса);
				ОтветСервиса = ВызватьМетод(ТокенДоступа, ПараметрыВызова);
				Если ОтветСервиса.КодСостояния<400 Тогда 
					Если ПараметрыВызова.Метод = "POST" И ОтветСервиса.Контент<>Неопределено Тогда 
						ПрисвоенныйИдентификатор = Неопределено;
						ОтветСервиса.Контент.Свойство("entityId", ПрисвоенныйИдентификатор);
						Если ПрисвоенныйИдентификатор<>Неопределено Тогда
							ЛичноеДелоРаботника.Идентификатор = ПрисвоенныйИдентификатор;
							ЛичноеДелоРаботника.МоментВыгрузки = МоментВыгрузкиНаСервере();
							ЗаписатьРезультатВыгрузкиЛичногоДела(Работник.ФизическоеЛицо, Объект.УИНОрганизации, ЛичноеДелоРаботника.ТабельныйНомер, 
									ЛичноеДелоРаботника.ДатаНачалаЗаписи, ЛичноеДелоРаботника.Идентификатор, ЛичноеДелоРаботника.МоментВыгрузки)
						Иначе 
							ВыгрузкаВыполнена = Ложь;
						КонецЕсли;
					ИначеЕсли ПараметрыВызова.Метод = "PUT" И ОтветСервиса.СообщениеОбОшибкеПользователю=Неопределено Тогда
						ЛичноеДелоРаботника.МоментВыгрузки = МоментВыгрузкиНаСервере();
						ЗаписатьРезультатВыгрузкиЛичногоДела(Работник.ФизическоеЛицо, Объект.УИНОрганизации, ЛичноеДелоРаботника.ТабельныйНомер, 
								ЛичноеДелоРаботника.ДатаНачалаЗаписи, ЛичноеДелоРаботника.Идентификатор, ЛичноеДелоРаботника.МоментВыгрузки)
					Иначе 
						ВыгрузкаВыполнена = Ложь;
					КонецЕсли;
				Иначе 
					ВыгрузкаВыполнена = Ложь;
				КонецЕсли;
				Если ОтветСервиса.СообщениеОбОшибкеПользователю<>Неопределено Тогда
					СообщениеОбОшибкеПользователю = СтрШаблон(НСтр("ru = 'Выгрузка личного дела медработника: %1'"), ОтветСервиса.СообщениеОбОшибкеПользователю);
					ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибкеПользователю, , 
						СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Объект.Работники[%1].ФизическоеЛицо", Работник.НомерСтроки-1));
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		// Общее образование.
		Для Каждого ТекущееОбразование Из НайденныеСтроки.ОбщееОбразование Цикл
			Если ВыгрузкаНеобходима(ТекущееОбразование.МоментВыгрузки, ТекущееОбразование.МоментИзменения) Тогда
				ВыгрузкаПроизводилась = Истина;
				PersonCommonData = ПодготовитьДанныеОбщегоОбразования(ТекущееОбразование);
				ПараметрыВызова = PostPutPersonCommon(PersonKey, PersonCommonData);
				ШаблонСообщенияОбОшибке = НСтр("ru = 'Выгрузка основного (общего) образования медработника: %1'");
				ВыгрузкаВыполнена = ВыгрузкаВыполнена И ОтправитьЗапросИОбработатьРезультатДляОбразования(ПараметрыВызова, 
						ПараметрыСервиса, ТокенДоступа, Работник, ТекущееОбразование, ШаблонСообщенияОбОшибке);
			КонецЕсли;
		КонецЦикла;
		
		// Профессиональное образование.
		Для Каждого ТекущееОбразование Из НайденныеСтроки.ПрофессиональноеОбразование Цикл
			Если ВыгрузкаНеобходима(ТекущееОбразование.МоментВыгрузки, ТекущееОбразование.МоментИзменения) Тогда
				ВыгрузкаПроизводилась = Истина;
				PersonProfData = ПодготовитьДанныеПрофессиональногоОбразования(Работник, ТекущееОбразование);
				ПараметрыВызова = PostPutPersonProf(PersonKey, PersonProfData);
				ШаблонСообщенияОбОшибке = НСтр("ru = 'Выгрузка профессионального образования медработника: %1'");
				ВыгрузкаВыполнена = ВыгрузкаВыполнена И ОтправитьЗапросИОбработатьРезультатДляОбразования(ПараметрыВызова, 
						ПараметрыСервиса, ТокенДоступа, Работник, ТекущееОбразование, ШаблонСообщенияОбОшибке);
			КонецЕсли;
		КонецЦикла;
		
		// Послевузовское образование.
		Для Каждого ТекущееОбразование Из НайденныеСтроки.ПослевузовскоеОбразование Цикл
			Если ВыгрузкаНеобходима(ТекущееОбразование.МоментВыгрузки, ТекущееОбразование.МоментИзменения) Тогда
				ВыгрузкаПроизводилась = Истина;
				PersonPostgraduateData = ПодготовитьДанныеПослевузовскогоОбразования(ТекущееОбразование);
				ПараметрыВызова = PostPutPersonPostgraduate(PersonKey, PersonPostgraduateData);
				ШаблонСообщенияОбОшибке = НСтр("ru = 'Выгрузка послевузовского образования медработника: %1'");
				ВыгрузкаВыполнена = ВыгрузкаВыполнена И ОтправитьЗапросИОбработатьРезультатДляОбразования(ПараметрыВызова, 
						ПараметрыСервиса, ТокенДоступа, Работник, ТекущееОбразование, ШаблонСообщенияОбОшибке);
			КонецЕсли;
		КонецЦикла;
		
		// Дополнительное профессиональное образование.
		Для Каждого ТекущееОбразование Из НайденныеСтроки.ДополнительноеПрофессиональноеОбразование Цикл
			Если ВыгрузкаНеобходима(ТекущееОбразование.МоментВыгрузки, ТекущееОбразование.МоментИзменения) Тогда
				ВыгрузкаПроизводилась = Истина;
				PersonExtData = ПодготовитьДанныеДополнительногоПрофессиональногоОбразования(ТекущееОбразование);
				ПараметрыВызова = PostPutPersonExt(PersonKey, PersonExtData);
				ШаблонСообщенияОбОшибке = НСтр("ru = 'Выгрузка дополнительного профессионального образования медработника: %1'");
				ВыгрузкаВыполнена = ВыгрузкаВыполнена И ОтправитьЗапросИОбработатьРезультатДляОбразования(ПараметрыВызова, 
						ПараметрыСервиса, ТокенДоступа, Работник, ТекущееОбразование, ШаблонСообщенияОбОшибке);
			КонецЕсли;
		КонецЦикла;
		
		// Сертификаты.
		Для Каждого СертификатРаботника Из НайденныеСтроки.Сертификаты Цикл
			Если ВыгрузкаНеобходима(СертификатРаботника.МоментВыгрузки, СертификатРаботника.МоментИзменения) Тогда
				ВыгрузкаПроизводилась = Истина;
				PersonCertData = ПодготовитьДанныеСертификата(СертификатРаботника);
				ПараметрыВызова = PostPutPersonCert(PersonKey, PersonCertData);
				ТокенДоступа = ТокенДоступа(ПараметрыСервиса);
				ОтветСервиса = ВызватьМетод(ТокенДоступа, ПараметрыВызова);
				Если ОтветСервиса.КодСостояния<400 Тогда 
					Если ПараметрыВызова.Метод = "POST" И ОтветСервиса.Контент<>Неопределено Тогда 
						ПрисвоенныйИдентификатор = Неопределено;
						ОтветСервиса.Контент.Свойство("entityId", ПрисвоенныйИдентификатор);
						Если ПрисвоенныйИдентификатор<>Неопределено Тогда
							СертификатРаботника.Идентификатор = ПрисвоенныйИдентификатор;
							СертификатРаботника.МоментВыгрузки = МоментВыгрузкиНаСервере();
							ЗаписатьРезультатВыгрузкиСертификата(Работник.ФизическоеЛицо, СертификатРаботника.Специальность, 
									СертификатРаботника.ДатаПолучения, СертификатРаботника.Идентификатор, СертификатРаботника.МоментВыгрузки)
						Иначе 
							ВыгрузкаВыполнена = Ложь;
						КонецЕсли;
					ИначеЕсли ПараметрыВызова.Метод = "PUT" И ОтветСервиса.СообщениеОбОшибкеПользователю=Неопределено Тогда
						СертификатРаботника.МоментВыгрузки = МоментВыгрузкиНаСервере();
						ЗаписатьРезультатВыгрузкиСертификата(Работник.ФизическоеЛицо, СертификатРаботника.Специальность, 
								СертификатРаботника.ДатаПолучения, СертификатРаботника.Идентификатор, СертификатРаботника.МоментВыгрузки)
					Иначе 
						ВыгрузкаВыполнена = Ложь;
					КонецЕсли;
				Иначе 
					ВыгрузкаВыполнена = Ложь;
				КонецЕсли;
				Если ОтветСервиса.СообщениеОбОшибкеПользователю<>Неопределено Тогда
					СообщениеОбОшибкеПользователю = СтрШаблон(НСтр("ru = 'Выгрузка сертификата медработника: %1'"), ОтветСервиса.СообщениеОбОшибкеПользователю);
					ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибкеПользователю, , 
						СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Объект.Работники[%1].ФизическоеЛицо", Работник.НомерСтроки-1));
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		// Награды.
		Для Каждого НаградаРаботника Из НайденныеСтроки.Награды Цикл
			Если ВыгрузкаНеобходима(НаградаРаботника.МоментВыгрузки, НаградаРаботника.МоментИзменения) Тогда
				ВыгрузкаПроизводилась = Истина;
				PersonNominationData = ПодготовитьДанныеНаграды(НаградаРаботника);
				ПараметрыВызова = PostPutPersonNomination(PersonKey, PersonNominationData);
				ТокенДоступа = ТокенДоступа(ПараметрыСервиса);
				ОтветСервиса = ВызватьМетод(ТокенДоступа, ПараметрыВызова);
				Если ОтветСервиса.КодСостояния<400 Тогда 
					Если ПараметрыВызова.Метод = "POST" И ОтветСервиса.Контент<>Неопределено Тогда 
						ПрисвоенныйИдентификатор = Неопределено;
						ОтветСервиса.Контент.Свойство("entityId", ПрисвоенныйИдентификатор);
						Если ПрисвоенныйИдентификатор<>Неопределено Тогда
							НаградаРаботника.Идентификатор = ПрисвоенныйИдентификатор;
							НаградаРаботника.МоментВыгрузки = МоментВыгрузкиНаСервере();
							ЗаписатьРезультатВыгрузкиНаграды(Работник.ФизическоеЛицо, НаградаРаботника.Награда, НаградаРаботника.ДатаПриказа, 
									НаградаРаботника.НомерПриказа, НаградаРаботника.Идентификатор, НаградаРаботника.МоментВыгрузки)
						Иначе 
							ВыгрузкаВыполнена = Ложь;
						КонецЕсли;
					ИначеЕсли ПараметрыВызова.Метод = "PUT" И ОтветСервиса.СообщениеОбОшибкеПользователю=Неопределено Тогда
						НаградаРаботника.МоментВыгрузки = МоментВыгрузкиНаСервере();
						ЗаписатьРезультатВыгрузкиНаграды(Работник.ФизическоеЛицо, НаградаРаботника.Награда, НаградаРаботника.ДатаПриказа, 
								НаградаРаботника.НомерПриказа, НаградаРаботника.Идентификатор, НаградаРаботника.МоментВыгрузки)
					Иначе 
						ВыгрузкаВыполнена = Ложь;
					КонецЕсли;
				Иначе 
					ВыгрузкаВыполнена = Ложь;
				КонецЕсли;
				Если ОтветСервиса.СообщениеОбОшибкеПользователю<>Неопределено Тогда
					СообщениеОбОшибкеПользователю = СтрШаблон(НСтр("ru = 'Выгрузка награды медработника: %1'"), ОтветСервиса.СообщениеОбОшибкеПользователю);
					ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибкеПользователю, , 
						СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Объект.Работники[%1].ФизическоеЛицо", Работник.НомерСтроки-1));
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		// Квалификация.
		Для Каждого КвалификацияРаботника Из НайденныеСтроки.Квалификация Цикл
			Если ВыгрузкаНеобходима(КвалификацияРаботника.МоментВыгрузки, КвалификацияРаботника.МоментИзменения) Тогда
				ВыгрузкаПроизводилась = Истина;
				PersonQualificationData = ПодготовитьДанныеКвалификации(КвалификацияРаботника);
				ПараметрыВызова = PostPutPersonQualification(PersonKey, PersonQualificationData);
				ТокенДоступа = ТокенДоступа(ПараметрыСервиса);
				ОтветСервиса = ВызватьМетод(ТокенДоступа, ПараметрыВызова);
				Если ОтветСервиса.КодСостояния<400 Тогда 
					Если ПараметрыВызова.Метод = "POST" И ОтветСервиса.Контент<>Неопределено Тогда 
						ПрисвоенныйИдентификатор = Неопределено;
						ОтветСервиса.Контент.Свойство("entityId", ПрисвоенныйИдентификатор);
						Если ПрисвоенныйИдентификатор<>Неопределено Тогда
							КвалификацияРаботника.Идентификатор = ПрисвоенныйИдентификатор;
							КвалификацияРаботника.МоментВыгрузки = МоментВыгрузкиНаСервере();
							ЗаписатьРезультатВыгрузкиКвалификации(Работник.ФизическоеЛицо, КвалификацияРаботника.ДатаПрисвоения, КвалификацияРаботника.Специальность, 
									КвалификацияРаботника.РазрядКатегория, КвалификацияРаботника.Идентификатор, КвалификацияРаботника.МоментВыгрузки)
						Иначе 
							ВыгрузкаВыполнена = Ложь;
						КонецЕсли;
					ИначеЕсли ПараметрыВызова.Метод = "PUT" И ОтветСервиса.СообщениеОбОшибкеПользователю=Неопределено Тогда
						КвалификацияРаботника.МоментВыгрузки = МоментВыгрузкиНаСервере();
						ЗаписатьРезультатВыгрузкиКвалификации(Работник.ФизическоеЛицо, КвалификацияРаботника.ДатаПрисвоения, КвалификацияРаботника.Специальность, 
								КвалификацияРаботника.РазрядКатегория, КвалификацияРаботника.Идентификатор, КвалификацияРаботника.МоментВыгрузки)
					Иначе 
						ВыгрузкаВыполнена = Ложь;
					КонецЕсли;
				Иначе 
					ВыгрузкаВыполнена = Ложь;
				КонецЕсли;
				Если ОтветСервиса.СообщениеОбОшибкеПользователю<>Неопределено Тогда
					СообщениеОбОшибкеПользователю = СтрШаблон(НСтр("ru = 'Выгрузка квалификации медработника: %1'"), ОтветСервиса.СообщениеОбОшибкеПользователю);
					ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибкеПользователю, , 
						СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Объект.Работники[%1].ФизическоеЛицо", Работник.НомерСтроки-1));
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		Если ВыгрузкаПроизводилась Тогда
			Работник.СтадияВыгрузки = ?(ВыгрузкаВыполнена, 2, 3);
		КонецЕсли;
		
#КонецОбласти
	
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Функция ДанныеКвалификацийСовпадают(Знач КвалификацияИБ, Знач ДатаПрисвоенияФРМР, Знач КодДолжностиПоФедСправочникуФРМР, Знач КодДолжностиФРМР, 
	Знач КодСпециальностиФРМР, Знач УказанКодДолжностиПоФедСправочникуФРМР, Знач УказанКодДолжностиФРМР, Знач УказанКодСпециальностиФРМР)
	
	Возврат КвалификацияИБ.ДатаПрисвоения=МедицинскиеРегистрыКлиент.ДатаИзUTC(ДатаПрисвоенияФРМР)
	И (Не УказанКодСпециальностиФРМР Или КвалификацияИБ.СпециальностьКод=Формат(КодСпециальностиФРМР, "ЧГ=0")) 
	И ((Не УказанКодДолжностиПоФедСправочникуФРМР Или КвалификацияИБ.ДолжностьПоФедСправочникуКод=Формат(КодДолжностиПоФедСправочникуФРМР, "ЧГ=0")) 
		Или (Не УказанКодДолжностиФРМР Или КвалификацияИБ.ДолжностьКод=Формат(КодДолжностиФРМР, "ЧГ=0")));

КонецФункции

&НаКлиенте
Функция ПодготовитьОбщиеДанныеРаботника(Работник, ДанныеДокументовУдостоверяющихЛичность)
	
	PersonData = PersonData();
	PersonData.mr = Работник.ЯвляетсяМедработником;
	PersonData.student = Ложь;
	PersonData.lastName = Работник.Фамилия;
	PersonData.firstName = Работник.Имя;
	PersonData.patronymic = Работник.Отчество;
	PersonData.gender = Работник.Пол;
	PersonData.birthDate = Работник.ДатаРождения;
	PersonData.snils = МедицинскиеРегистрыКлиент.ТолькоЦифры(Работник.СтраховойНомерПФР);
	PersonData.inn = Работник.ИНН;
	PersonData.citizenShipId.code = Работник.ГражданствоКод;
	PersonData.citizenShipId.name = Работник.ГражданствоНаименование;
	PersonData.oksmId.code = Работник.СтранаКод;
	PersonData.oksmId.name = Работник.СтранаНаименование;
	PersonData.militaryRelationId = ?(ПустаяСтрока(Работник.ОтношениеКВоинскойОбязанностиКод), Неопределено, Работник.ОтношениеКВоинскойОбязанностиКод);
	PersonData.phone = ?(ПустаяСтрока(Работник.НомерТелефона), Неопределено, НомерТелефонаЦифрами(Работник.НомерТелефона));
	PersonData.email = ?(ПустаяСтрока(Работник.АдресЭлектроннойПочтыПредставление), Неопределено, Работник.АдресЭлектроннойПочтыПредставление);
	PersonData.isDisabled = Неопределено;
	PersonData.disabledGroupId = Неопределено;
	PersonData.disabledGroupName = Неопределено;
	PersonData.disabledDate = Неопределено;
	PersonData.covid19 = Неопределено;
	PersonData.documents = Новый Массив;
	PersonData.addresses = Новый Массив;
	
	Для Каждого ДокументМедработника Из ДанныеДокументовУдостоверяющихЛичность Цикл 
		PersonDocumentData = PersonDocumentData();
		PersonDocumentData.serial = МедицинскиеРегистрыКлиент.ТолькоЦифры(ДокументМедработника.Серия);
		PersonDocumentData.number = ДокументМедработника.Номер;
		PersonDocumentData.passDate = ДокументМедработника.ДатаВыдачи;
		PersonDocumentData.passOrg = ДокументМедработника.КемВыдан;
		PersonDocumentData.codeOrg = ?(ПустаяСтрока(ДокументМедработника.КодПодразделения), Неопределено, ДокументМедработника.КодПодразделения);
		PersonDocumentData.documentId = ДокументМедработника.ВидДокументаКод;
		PersonData.documents.Добавить(PersonDocumentData);
	КонецЦикла;
	
	Если ЗначениеЗаполнено(Работник.АдресПостояннойРегистрации) Тогда
		ДанныеАдреса = АдреснаяИнформация(1, Работник.ДатаРегистрации, Работник.АдресПостояннойРегистрации);
		PersonData.addresses.Добавить(ДанныеАдреса);
	КонецЕсли;
	Если ЗначениеЗаполнено(Работник.АдресМестаПроживания) Тогда 
		ДанныеАдреса = АдреснаяИнформация(2, Работник.ДатаРегистрации, Работник.АдресМестаПроживания);
		PersonData.addresses.Добавить(ДанныеАдреса);
	КонецЕсли;
	Возврат PersonData;

КонецФункции

&НаКлиенте
Функция ПодготовитьДанныеЛичногоДела(ЛичноеДелоРаботника)
	
	PersonCardData = PersonCardData();
	Если ЗначениеЗаполнено(ЛичноеДелоРаботника.Идентификатор) Тогда 
		PersonCardData.id = ЛичноеДелоРаботника.Идентификатор;
	Иначе
		PersonCardData.id = Неопределено;
	КонецЕсли;
	PersonCardData.lastName = ЛичноеДелоРаботника.Фамилия;
	PersonCardData.oid = Объект.УИНОрганизации;
	PersonCardData.organization = Объект.Организация;
	PersonCardData.nrPmuDepartId = ЛичноеДелоРаботника.ИдентификаторПодразделения;
	Если ЛичноеДелоРаботника.ТипПодразделенияКод="2" Тогда 
		PersonCardData.nrPmuDepartHospitalSubdivisionId = ?(ЗначениеЗаполнено(ЛичноеДелоРаботника.ИдентификаторОтделенияИлиКабинета), ЛичноеДелоРаботника.ИдентификаторОтделенияИлиКабинета, Неопределено);
	ИначеЕсли ЛичноеДелоРаботника.ТипПодразделенияКод="1"
		Или ЛичноеДелоРаботника.ТипПодразделенияКод="3"
		Или ЛичноеДелоРаботника.ТипПодразделенияКод="4" Тогда
		PersonCardData.roomOid = ?(ЗначениеЗаполнено(ЛичноеДелоРаботника.ИдентификаторОтделенияИлиКабинета), ЛичноеДелоРаботника.ИдентификаторОтделенияИлиКабинета, Неопределено);
	КонецЕсли;
	PersonCardData.contractNumber = ЛичноеДелоРаботника.ТрудовойДоговорНомер;
	PersonCardData.contractDate = ЛичноеДелоРаботника.ТрудовойДоговорДата;
	PersonCardData.serviceNumber = ЛичноеДелоРаботника.ТабельныйНомер;
	PersonCardData.fedPositionId = ЛичноеДелоРаботника.ДолжностьПоФедСправочникуКод;
	PersonCardData.seniority = Неопределено;
	PersonCardData.services = Новый Массив;
	НоваяМедУслуга = PersonCardServices();
	НоваяМедУслуга.code = ЛичноеДелоРаботника.ОказываемыеМедУслугиКод;
	PersonCardData.services.Добавить(НоваяМедУслуга); 
	PersonCardData.positionTypeId = ЛичноеДелоРаботника.ТипЗанятияДолжностиКод;
	PersonCardData.postId = ЛичноеДелоРаботника.ДолжностьКод;
	PersonCardData.rate = ЛичноеДелоРаботника.КоличествоСтавок;
	PersonCardData.beginDate = ЛичноеДелоРаботника.ДатаНачалаЗаписи;
	PersonCardData.endDate = ?(ЗначениеЗаполнено(ЛичноеДелоРаботника.ДатаОкончанияЗаписи), ЛичноеДелоРаботника.ДатаОкончанияЗаписи, Неопределено);
	Если ЗначениеЗаполнено(ЛичноеДелоРаботника.ВидСобытияОкончания) Тогда 
		PersonCardData.endTypeId = ЛичноеДелоРаботника.ОснованиеОкончанияКод;
		Если ЛичноеДелоРаботника.ВидСобытияОкончания=ВидыКадровыхСобытийУвольнение Тогда 
			PersonCardData.fireReasonId = ЛичноеДелоРаботника.ПричинаУвольненияКод;
		КонецЕсли;
	КонецЕсли;
	PersonCardData.targeted = ЛичноеДелоРаботника.ЦелеваяПодготовка;
	PersonCardData.temporaryDerelictions = Неопределено;
	Возврат PersonCardData;

КонецФункции

&НаКлиенте
