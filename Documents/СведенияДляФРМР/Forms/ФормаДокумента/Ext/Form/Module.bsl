&НаКлиенте
Функция ПодготовитьДанныеПрофессиональногоОбразования(Работник, ТекущееОбразование)
	
	ИдентификаторОбразования = ЗначениеИдентификатора(ТекущееОбразование);
	
	PersonProfData = PersonProfData();
	PersonProfData.profId = ИдентификаторОбразования;
	PersonProfData.isStudentEducation = Ложь;
	Если Не Работник.ЯвляетсяМедработником Тогда 
		PersonProfData.hasDiploma = Истина;
	КонецЕсли;
	PersonProfData.isDuplicate = Ложь;
	PersonProfData.beginYear = Год(ТекущееОбразование.Начало);
	PersonProfData.docSerial = ?(ПустаяСтрока(ТекущееОбразование.СерияДиплома), Неопределено, ТекущееОбразование.СерияДиплома);
	PersonProfData.docNumber = ТекущееОбразование.НомерДиплома;
	PersonProfData.docDate = ТекущееОбразование.ДатаВыдачиДиплома;
	PersonProfData.educationTypeId.code = ТекущееОбразование.ВидОбразованияКод;
	PersonProfData.specId = ТекущееОбразование.СпециальностьКод;
	PersonProfData.qualificationId = ТекущееОбразование.КвалификацияКод;
	Если ТекущееОбразование.ЗаПределамиРФ Тогда
		PersonProfData.foreignInstitution = ТекущееОбразование.ОбразовательнаяОрганизация;
		Если ЗначениеЗаполнено(ТекущееОбразование.РеспубликаСССРКод) И Не ЗначениеЗаполнено(ТекущееОбразование.СтранаМираКод) Тогда 
			PersonProfData.educPlace = 1;
			PersonProfData.unionRepublicId = ТекущееОбразование.РеспубликаСССРКод;
		Иначе 
			PersonProfData.educPlace = 2;
			PersonProfData.oksmId = ТекущееОбразование.СтранаМираКод;
			PersonProfData.hasForeignCert = 2;
		КонецЕсли;
	Иначе 
		PersonProfData.educPlace = 0;
		PersonProfData.institutionId = ТекущееОбразование.УчебноеЗаведениеКод;
		PersonProfData.isTargeted = ЗначениеЗаполнено(ТекущееОбразование.ЗаказчикЦелевогоОбученияКод);
		Если PersonProfData.isTargeted Тогда
			PersonProfData.targetedRegionId = ТекущееОбразование.ЗаказчикЦелевогоОбученияКод;
			PersonProfData.dutyMonthsPeriod = РазмерПериода(ТекущееОбразование.Начало, ТекущееОбразование.Окончание);
			PersonProfData.isTargetTerminated = ЗначениеЗаполнено(ТекущееОбразование.ПричинаРасторженияКод);
			Если PersonProfData.isTargetTerminated Тогда 
				PersonProfData.terminationReasonId = ТекущееОбразование.ПричинаРасторженияКод;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	Возврат PersonProfData;

КонецФункции

