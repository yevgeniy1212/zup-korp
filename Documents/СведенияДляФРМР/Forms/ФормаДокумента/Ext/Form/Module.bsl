&НаКлиенте
Функция ОтправитьЗапросИОбработатьРезультатДляОбразования(ПараметрыВызова, ПараметрыСервиса, ТокенДоступа, Работник, ТекущееОбразование, ШаблонСообщенияОбОшибке)
	
	ВыгрузкаВыполнена = Истина;
	ТокенДоступа = ТокенДоступа(ПараметрыСервиса);
	ОтветСервиса = ВызватьМетод(ТокенДоступа, ПараметрыВызова);
	Если ОтветСервиса.КодСостояния<400 Тогда 
		Если ПараметрыВызова.Метод = "POST" И ОтветСервиса.Контент<>Неопределено Тогда 
			ПрисвоенныйИдентификатор = Неопределено;
			ОтветСервиса.Контент.Свойство("entityId", ПрисвоенныйИдентификатор);
			Если ПрисвоенныйИдентификатор<>Неопределено Тогда
				ТекущееОбразование.Идентификатор = ПрисвоенныйИдентификатор;
				ТекущееОбразование.МоментВыгрузки = МоментВыгрузкиНаСервере();
				ЗаписатьРезультатВыгрузки(ТекущееОбразование.ОбразованиеРаботника, ТекущееОбразование.Идентификатор, ТекущееОбразование.МоментВыгрузки, ПараметрыВызова.РазделМедрегистра);
			Иначе 
				ВыгрузкаВыполнена = Ложь;
			КонецЕсли;
		ИначеЕсли ПараметрыВызова.Метод = "PUT" И ОтветСервиса.СообщениеОбОшибкеПользователю=Неопределено Тогда
			ТекущееОбразование.МоментВыгрузки = МоментВыгрузкиНаСервере();
			ЗаписатьРезультатВыгрузки(ТекущееОбразование.ОбразованиеРаботника, ТекущееОбразование.Идентификатор, ТекущееОбразование.МоментВыгрузки, ПараметрыВызова.РазделМедрегистра);
		Иначе 
			ВыгрузкаВыполнена = Ложь;
		КонецЕсли;
	Иначе 
		ВыгрузкаВыполнена = Ложь;
	КонецЕсли;
	Если ОтветСервиса.СообщениеОбОшибкеПользователю<>Неопределено Тогда
		СообщениеОбОшибкеПользователю = СтрШаблон(ШаблонСообщенияОбОшибке, ОтветСервиса.СообщениеОбОшибкеПользователю);
		ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибкеПользователю, , 
		СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("Объект.Работники[%1].ФизическоеЛицо", Работник.НомерСтроки-1));
	КонецЕсли;
	
	Возврат ВыгрузкаВыполнена;

КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ВыгрузкаНеобходима(МоментВыгрузки, МоментИзменения)
	
	ВыгрузкаНеПроводилась = МоментВыгрузки=Неопределено Или МоментВыгрузки=Дата('00010101');
	ЕстьИзменения = МоментВыгрузки<=МоментИзменения;
	Возврат ВыгрузкаНеПроводилась Или ЕстьИзменения;
	
КонецФункции

&НаСервереБезКонтекста
Процедура ЗаписатьРезультатВыгрузки(ОбъектСсылка, Идентификатор, МоментВыгрузки, РазделМедрегистра)
	
	Набор = РегистрыСведений.ИдентификаторыОбъектовДляФедеральныхМедрегистров.СоздатьНаборЗаписей();
	Набор.Отбор.Объект.Установить(ОбъектСсылка);
	Набор.Прочитать();
	Если Набор.Количество() = 0 Тогда
		РезультатВыгрузки = Набор.Добавить();
		РезультатВыгрузки.Объект = ОбъектСсылка;
	Иначе
		РезультатВыгрузки = Набор[0];
	КонецЕсли;
	РезультатВыгрузки.Идентификатор = Идентификатор;
	Если МоментВыгрузки<>Неопределено Тогда 
		РезультатВыгрузки.МоментВыгрузки = МоментВыгрузки;
	КонецЕсли;
	Если РазделМедрегистра<>Неопределено Тогда 
		РезультатВыгрузки.РазделМедрегистра = РазделМедрегистра;
	КонецЕсли;
	Набор.Записать();
	
КонецПроцедуры

