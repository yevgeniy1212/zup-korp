&НаСервереБезКонтекста
Функция АдреснаяИнформация(ТипАдреса, ДатаРегистрации, АдреснаяИнформацияJSON)
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("БезПредставлений",               Истина);
	ДополнительныеПараметры.Вставить("КодыАдреса",                     Истина);
	ДополнительныеПараметры.Вставить("КодыКЛАДР",                      Ложь);
	ДополнительныеПараметры.Вставить("НаименованиеВключаетСокращение", Ложь);
	ДополнительныеПараметры.Вставить("ПроверитьАдрес",                 Ложь);
	СведенияОбАдресе = РаботаСАдресами.СведенияОбАдресе(АдреснаяИнформацияJSON, ДополнительныеПараметры);
	
	PersonAddressData = МедицинскиеРегистрыФРМР.PersonAddressData();
	Если ДатаРегистрации<>Неопределено Тогда 
		PersonAddressData.regDate = ДатаРегистрации;
	КонецЕсли;
	PersonAddressData.addressTypeId = ТипАдреса;
	PersonAddressData.address.GARguid = СведенияОбАдресе.ИдентификаторДома;
	Если ЗначениеЗаполнено(СведенияОбАдресе.Идентификаторы.ГородИдентификатор) Тогда 
		PersonAddressData.address.aoidArea = СведенияОбАдресе.Идентификаторы.ГородИдентификатор;
		PersonAddressData.address.areaName = СведенияОбАдресе.Город;
		PersonAddressData.address.prefixArea = СведенияОбАдресе.ГородТипКраткий;
	Иначе 
		PersonAddressData.address.aoidArea = СведенияОбАдресе.Идентификаторы.НаселенныйПунктИдентификатор;
		PersonAddressData.address.areaName = СведенияОбАдресе.НаселенныйПункт;
		PersonAddressData.address.prefixArea = СведенияОбАдресе.НаселенныйПунктТипКраткий;
	КонецЕсли;
	PersonAddressData.address.aoidStreet = СведенияОбАдресе.Идентификаторы.УлицаИдентификатор;
	PersonAddressData.address.houseid = СведенияОбАдресе.ИдентификаторДома;
	PersonAddressData.address.region = Формат(Число(СведенияОбАдресе.КодРегиона), "ЧГ=0"); // Избавимся от лидирующего нуля.
	PersonAddressData.address.streetName = СведенияОбАдресе.Улица;
	PersonAddressData.address.prefixStreet = СведенияОбАдресе.УлицаТипКраткий;
	PersonAddressData.address.house = СведенияОбАдресе.Здание.Номер;
	PersonAddressData.address.building = Неопределено;
	PersonAddressData.address.struct = Неопределено;
	PersonAddressData.address.flat = Неопределено;
	
	Возврат PersonAddressData;
	
КонецФункции

