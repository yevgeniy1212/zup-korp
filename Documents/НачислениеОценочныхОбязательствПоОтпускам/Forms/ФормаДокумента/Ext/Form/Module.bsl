                    ПараметрыСтроки.СуммаРезерваСНИсчислено             = Окр(ПараметрыСтроки.СуммаРезерваИсчислено*(1-(СтавкаОПВ+СтавкаВОСМС)/100)*(СтавкаСН - СтавкаСО)/100, 2);
