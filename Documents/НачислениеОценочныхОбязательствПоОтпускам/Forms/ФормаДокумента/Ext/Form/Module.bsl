&НаСервере
Процедура УстановитьФункциональныеОпцииФормы()
	
	ПараметрыФО = Новый Структура("Организация, Период", Объект.Организация, НачалоДня(Объект.ПериодРегистрации));
	УстановитьПараметрыФункциональныхОпцийФормы(ПараметрыФО);
	ФормироватьРезервыОтпусковВНалоговомУчете = ПолучитьФункциональнуюОпциюФормы("ФормироватьРезервыОтпусковВНалоговомУчете");
	
КонецПроцедуры

&НаСервере
Процедура НастройкиРезервовОтпусков()
	
	НастройкиРезервовОтпусков = РезервОтпусков.НастройкиРезервовОтпусков(Объект.Организация, Объект.ПериодРегистрации);
	МетодОбязательств                  = НастройкиРезервовОтпусков.МетодНачисленияРезерваОтпусков = Перечисления.МетодыНачисленияРезервовПоОплатеТруда.МетодОбязательств;
	НормативОтчисленийВРезервОтпусков  = НастройкиРезервовОтпусков.НормативОтчисленийВРезервОтпусков;
	ОпределятьИзлишкиЕжемесячно        = НастройкиРезервовОтпусков.ОпределятьИзлишкиЕжемесячно;

	//ЗУПК
    // Получаем применение вычета в месяц отсутствия дохода
    УчетнаяПолитикаНУ = РегистрыСведений.УчетнаяПолитикаПоНалоговомуУчету.СрезПоследних(Объект.ПериодРегистрации, Новый Структура("Организация", Объект.Организация));
    ДанныеОрганизации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Организация, "ЮридическоеФизическоеЛицо, ИндивидуальныйПредприниматель");
    ЭтаФорма["ОрганизацияЯвляетсяИП"] = (ДанныеОрганизации.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо);
    ЭтаФорма["ФизическоеЛицоИП"] = ДанныеОрганизации.ИндивидуальныйПредприниматель;
    
    РежимНалогообложения = Перечисления.СистемыНалогообложения.Общая;
    ЭтаФорма["КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя"] = 0;
    ЭтаФорма["КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника"] = 0;
    
    // в расчете учитываем все три возможные положения 
    // РежимНалогообложения = ПустаяСсылка
    // для ИП и юр лица считаем как раньше
    //
    // РежимНалогообложения = Общая
    // для ИП считаем СН с учетом Коэффициентов
    // для юр лица считаем как раньше
    //
    // РежимНалогообложения = Упрощенная
    // для ИП и юр лица не считаем СН
    Если УчетнаяПолитикаНУ.Количество() > 0 Тогда
        
        РежимНалогообложения = УчетнаяПолитикаНУ[0].СистемаНалогообложения;
        
        Если ЭтаФорма["ОрганизацияЯвляетсяИП"] Тогда
            
            ЭтаФорма["КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя"] = УчетнаяПолитикаНУ[0].КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя;
            ЭтаФорма["КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника"] = УчетнаяПолитикаНУ[0].КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника;
            
        КонецЕсли;
        
        // не плательщик СН, независимо что в регистре
        Если РежимНалогообложения = Перечисления.СистемыНалогообложения.Упрощенная Тогда
            ЭтаФорма["КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя"] = 0;
            ЭтаФорма["КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника"] 			   = 0;
        КонецЕсли;
        
    КонецЕсли;
    
    МесячныйРасчетныйПоказатель = РегистрыСведений.МесячныйРасчетныйПоказатель.СрезПоследних(Объект.ПериодРегистрации);
    ЭтаФорма["РазмерМРП"] = 0;
    Если МесячныйРасчетныйПоказатель.Количество() > 0 Тогда
        ЭтаФорма["РазмерМРП"] = МесячныйРасчетныйПоказатель[0].Размер;
    КонецЕсли;
    //ЗУПК
	
	ДокументДоступен = РезервОтпусков.ДоступенВводДокументаРезервОтпусков(Объект.Организация, Объект.ПериодРегистрации);
	
КонецПроцедуры

