                ПараметрыСтроки.СуммаРезерваОППВИсчислено           = ?(ПараметрыСтроки.ОППВ = 0, 0, Окр(ПараметрыСтроки.СуммаРезерваИсчислено*СтавкаОППВ/100, 2));
