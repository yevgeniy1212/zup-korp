#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	Если ЗарплатаКадры.ОтключитьБизнесЛогикуПриЗаписи(ЭтотОбъект) Тогда
		Возврат;
	КонецЕсли;
	
	РеквизитыПлатежногоПоручения = РеквизитыПлатежногоПоручения();
	
КонецПроцедуры

Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
    ПроведениеСервер.ПодготовитьНаборыЗаписейКРегистрацииДвижений(ЭтотОбъект);
    
    Если НЕ ЭтоНовый() Тогда
        ЭтотОбъект.Движения.Записать();
    КонецЕсли; 

	Если Константы.ДатаКорректировкиВеденияУчетаПоДаннымНВО.Получить() <= ?(ЗначениеЗаполнено(Ссылка), Дата, ТекущаяДатаСеанса()) Тогда
		
	    Запрос = Новый Запрос;
	    Запрос.УстановитьПараметр("Ссылка", Ссылка);
	    Запрос.УстановитьПараметр("Организация", Организация);
	    Запрос.УстановитьПараметр("ВидНалогаВзносаОтчисления", ВидНалогаВзносаОтчисления);
	    Запрос.УстановитьПараметр("МесяцНалоговогоПериода", МесяцНалоговогоПериода);
	    Запрос.УстановитьПараметр("РегистрацияВНалоговомОргане", РегистрацияВНалоговомОргане);
	    
	    КонецПериодаГраница = Новый Граница(Макс(?(ЗначениеЗаполнено(Ссылка), Дата, ТекущаяДатаСеанса()), КонецМесяца(МесяцНалоговогоПериода)));
	    Запрос.УстановитьПараметр("ДатаОстатков", КонецПериодаГраница); 
	    
	    Запрос.УстановитьПараметр("ВидПлатежа", ?(ЗначениеЗаполнено(ВидПлатежа), ВидПлатежа, Перечисления.ВидыПлатежейВГосБюджет.Налог));
	    Запрос.УстановитьПараметр("ВидДохода", ВидДохода);
	    
	    Запрос.Текст = ТекстЗапросаДанныеДляПроведения();
	    РезультатЗапроса = Запрос.Выполнить();
	    
	    ВыборкаВидНалогаВзносаОтчисления = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	    
	    Пока ВыборкаВидНалогаВзносаОтчисления.Следующий() Цикл 
	        
	        ОстатокНалогВзнос = ВыборкаВидНалогаВзносаОтчисления.НалогВзнос - ВыборкаВидНалогаВзносаОтчисления.НалогВзносОстаток;
	     
	        ВыборкаДетальныеЗаписи = ВыборкаВидНалогаВзносаОтчисления.Выбрать();     
	        КоличествоСписать = ВыборкаВидНалогаВзносаОтчисления.НалогВзнос;
	        
	        Пока КоличествоСписать > 0 И ВыборкаДетальныеЗаписи.Следующий() Цикл
	            
	            Если ВыборкаДетальныеЗаписи.НалогВзносОстаток <> 0 Тогда
	                НоваяСтрока = Движения.НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.ДобавитьРасход();      
	                
	                КолПоПартии = МИН(КоличествоСписать, ВыборкаДетальныеЗаписи.НалогВзносОстаток);
	                ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаДетальныеЗаписи);
	                НоваяСтрока.НалогВзнос = КолПоПартии;
	                
	                Движения.НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.Записать();
	                Движения.НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.Записывать = Ложь;
	                
	                КоличествоСписать = КоличествоСписать - КолПоПартии;
	            КонецЕсли;
	            
	        КонецЦикла;
	        
			Если ОстатокНалогВзнос > 0 Тогда
				
				ТекстСообщения = НСтр("ru = 'Сумма документа превышает сумму налога к перечислению на %1 (по виду дохода ""%2"" остаток к перечислению %3). При необходимости, скорректируйте сумму документа самостоятельно (проанализировать сумму остатка по видам дохода возможно, используя универсальный отчет по регистру накопления ""Налоги, взносы, отчисления - расчеты с бюджетом и фондами"").'");
	            ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, ОстатокНалогВзнос, ?(ЗначениеЗаполнено(ВидДохода), ВидДохода, НСтр("ru = '<пустой>'")), ВыборкаВидНалогаВзносаОтчисления.НалогВзносОстаток);
	            ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,,, ?(ВидДохода = Справочники.ВидыДоходов.ПустаяСсылка(), Отказ, Неопределено));
	            
	            ПеречисленныйНалог = ДанныеДляПроведения();     
				
				Для Каждого СтрокаДанных Из ПеречисленныйНалог Цикл
					
					Если ЗначениеЗаполнено(СтрокаДанных.МесяцНалоговогоПериода) Тогда
	                    
	                    НоваяСтрока = Движения.НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.ДобавитьРасход();
	                    ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДанных);
	                    НоваяСтрока.НалогВзнос = ОстатокНалогВзнос;
	                    Если НЕ ЗначениеЗаполнено(СтрокаДанных.ВидДохода) Тогда
	                        НоваяСтрока.ВидДохода = Справочники.ВидыДоходов.ДоходыОтРаботодателя; 
	                    КонецЕсли;
	                    Если НЕ ЗначениеЗаполнено(СтрокаДанных.ВидПлатежа) Тогда
	                        НоваяСтрока.ВидПлатежа = Перечисления.ВидыПлатежейВГосБюджет.Налог; 
	                    КонецЕсли;
	                    Движения.НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.Записать();
	                    Движения.НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.Записывать = Ложь;
	                    
	                КонецЕсли;
					
				КонецЦикла;
				
			КонецЕсли;
			
		КонецЦикла;    
		
	Иначе
		
		ПеречисленныйНалог = ДанныеДляПроведения();
		
		Если ПеречисленныйНалог = Неопределено Тогда
			Возврат
		КонецЕсли;
		Для Каждого СтрокаДанных Из ПеречисленныйНалог Цикл
			Если ЗначениеЗаполнено(СтрокаДанных.МесяцНалоговогоПериода) Тогда
				
				НоваяСтрока = Движения.НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.ДобавитьРасход();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДанных);
				
				Движения.НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.Записать();
				Движения.НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.Записывать = Ложь;
				
			КонецЕсли;
		КонецЦикла;
			
	КонецЕсли;
		
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Если Константы.ДатаКорректировкиВеденияУчетаПоДаннымНВО.Получить() > Дата Тогда
		ПроверяемыеРеквизиты.Удалить(ПроверяемыеРеквизиты.Найти("ВидПлатежа"));		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция РеквизитыПлатежногоПоручения() Экспорт
	
	РеквизитыПлатежногоПорученияПоДатеНомеру = 
		СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		 	НСтр("ru = '№ %1 от %2'"), 
			ПлатежноеПоручениеНомер,  
			Формат(ПлатежноеПоручениеДата, "ДЛФ=D"));

	Возврат РеквизитыПлатежногоПорученияПоДатеНомеру
	
КонецФункции	

Функция	ТекстЗапросаДанныеДляПроведения()
		
    ТекстЗапросаДанныеДляПроведения = 
    "ВЫБРАТЬ
    |   НалогиВзносыОтчисленияРасчетыСБюджетомИФондамиОстатки.Организация КАК Организация,
    |   НалогиВзносыОтчисленияРасчетыСБюджетомИФондамиОстатки.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления,
    |   НалогиВзносыОтчисленияРасчетыСБюджетомИФондамиОстатки.ВидПлатежа КАК ВидПлатежа,
    |   НалогиВзносыОтчисленияРасчетыСБюджетомИФондамиОстатки.ВидДохода КАК ВидДохода,
    |   СУММА(НалогиВзносыОтчисленияРасчетыСБюджетомИФондамиОстатки.НалогВзносОстаток) КАК НалогВзносОстаток
    |ПОМЕСТИТЬ НалогиВзносыОтчисленияОстатки
    |ИЗ
    |   РегистрНакопления.НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.Остатки(
    |           &ДатаОстатков,
    |           Организация = &Организация
    |               И МесяцНалоговогоПериода <= &МесяцНалоговогоПериода
    |               И ВидНалогаВзносаОтчисления = &ВидНалогаВзносаОтчисления
    |               И ВидПлатежа = &ВидПлатежа
    |               И ВидДохода = &ВидДохода
    |               И РегистрацияВНалоговомОргане = &РегистрацияВНалоговомОргане) КАК НалогиВзносыОтчисленияРасчетыСБюджетомИФондамиОстатки
    |
    |СГРУППИРОВАТЬ ПО
    |   НалогиВзносыОтчисленияРасчетыСБюджетомИФондамиОстатки.Организация,
    |   НалогиВзносыОтчисленияРасчетыСБюджетомИФондамиОстатки.ВидНалогаВзносаОтчисления,
    |   НалогиВзносыОтчисленияРасчетыСБюджетомИФондамиОстатки.ВидПлатежа,
    |   НалогиВзносыОтчисленияРасчетыСБюджетомИФондамиОстатки.ВидДохода
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ
    |   НалогиВзносыОтчисленияОстатки.Организация КАК Организация,
    |   НалогиВзносыОтчисленияОстатки.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления,
    |   НалогиВзносыОтчисленияОстатки.ВидПлатежа КАК ВидПлатежа,
    |   НалогиВзносыОтчисленияОстатки.ВидДохода КАК ВидДохода,
    |   СУММА(НалогиВзносыОтчисленияОстатки.НалогВзносОстаток) КАК НалогВзносОстаток
    |ПОМЕСТИТЬ ВТНалогиВзносыИтог
    |ИЗ
    |   НалогиВзносыОтчисленияОстатки КАК НалогиВзносыОтчисленияОстатки
    |                                            
    |ГДЕ
    |   НалогиВзносыОтчисленияОстатки.НалогВзносОстаток > 0
    |
    |СГРУППИРОВАТЬ ПО
    |   НалогиВзносыОтчисленияОстатки.ВидПлатежа,
    |   НалогиВзносыОтчисленияОстатки.ВидДохода,
    |   НалогиВзносыОтчисленияОстатки.ВидНалогаВзносаОтчисления,
    |   НалогиВзносыОтчисленияОстатки.Организация
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ
    |   ПеречислениеНалоговВБюджет.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
    |   ПеречислениеНалоговВБюджет.Дата КАК Период,
    |   ПеречислениеНалоговВБюджет.Организация КАК Организация,
    |   ПеречислениеНалоговВБюджет.Сумма КАК НалогВзнос,
    |   ПеречислениеНалоговВБюджет.РегистрацияВНалоговомОргане КАК РегистрацияВНалоговомОргане,
    |   ПеречислениеНалоговВБюджет.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления,
    |   ПеречислениеНалоговВБюджет.ПлатежноеПоручениеНомер КАК ПлатежноеПоручениеНомер,
    |   ПеречислениеНалоговВБюджет.ПлатежноеПоручениеДата КАК ПлатежноеПоручениеДата,
    |   ЗНАЧЕНИЕ(Справочник.ФизическиеЛица.ПустаяСсылка) КАК ФизическоеЛицо,
    |   ПеречислениеНалоговВБюджет.ВидПлатежа КАК ВидПлатежа,
    |   ЕСТЬNULL(ВТНалогиВзносыИтог.НалогВзносОстаток, 0) КАК НалогВзносОстаток,
    |   ЕСТЬNULL(ВТНалогиВзносыИтог.ВидДохода, ПеречислениеНалоговВБюджет.ВидДохода) КАК ВидДохода
    |ИЗ
    |   Документ.ПеречислениеНалоговВБюджет КАК ПеречислениеНалоговВБюджет
    |       ЛЕВОЕ СОЕДИНЕНИЕ ВТНалогиВзносыИтог КАК ВТНалогиВзносыИтог
    |       ПО ПеречислениеНалоговВБюджет.Организация = ВТНалогиВзносыИтог.Организация
    |           И ПеречислениеНалоговВБюджет.ВидНалогаВзносаОтчисления = ВТНалогиВзносыИтог.ВидНалогаВзносаОтчисления
    |ГДЕ
    |   ПеречислениеНалоговВБюджет.Ссылка = &Ссылка
    |
    |УПОРЯДОЧИТЬ ПО
    |   ВидДохода
    |ИТОГИ
    |   МАКСИМУМ(НалогВзнос),
    |   СУММА(НалогВзносОстаток)
    |ПО
    |   ВидНалогаВзносаОтчисления";
    
	Возврат ТекстЗапросаДанныеДляПроведения;

КонецФункции

Функция	ДанныеДляПроведения()
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПеречислениеНалоговВБюджет.МесяцНалоговогоПериода,
	|	ПеречислениеНалоговВБюджет.Дата КАК Период,
	|	ПеречислениеНалоговВБюджет.Организация,
	|	ПеречислениеНалоговВБюджет.Сумма КАК НалогВзнос,
	|	ПеречислениеНалоговВБюджет.РегистрацияВНалоговомОргане,
	|	ПеречислениеНалоговВБюджет.ВидНалогаВзносаОтчисления,
	|	ПеречислениеНалоговВБюджет.ПлатежноеПоручениеНомер,
	|	ПеречислениеНалоговВБюджет.ПлатежноеПоручениеДата,
	|	ЗНАЧЕНИЕ(Справочник.ФизическиеЛица.ПустаяСсылка) КАК ФизическоеЛицо,
	|	ВЫБОР
	|		КОГДА ПеречислениеНалоговВБюджет.ВидПлатежа = ЗНАЧЕНИЕ(Перечисление.ВидыПлатежейВГосБюджет.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ВидыПлатежейВГосБюджет.Налог)
	|		ИНАЧЕ ПеречислениеНалоговВБюджет.ВидПлатежа
	|	КОНЕЦ КАК ВидПлатежа,
 	|	ПеречислениеНалоговВБюджет.ВидДохода КАК ВидДохода
	|ИЗ
	|	Документ.ПеречислениеНалоговВБюджет КАК ПеречислениеНалоговВБюджет
	|ГДЕ
	|	ПеречислениеНалоговВБюджет.Ссылка = &Ссылка";
	
	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

#КонецОбласти
	
#КонецЕсли