КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеСтрахования()

	Если Не ЗначениеЗаполнено(Объект.Организация) Или Не ЗначениеЗаполнено(Объект.Сотрудник) Тогда
		ОткреплятьСотрудника = Ложь;
		ДатаОткрепления = Неопределено;
		УдержатьОстаток = Ложь;
		Объект.ДанныеМедицинскогоСтрахования.Очистить();
		Элементы.ДанныеМедицинскогоСтрахования.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Элементы.ГруппаУдерживатьОстаток.Видимость = Ложь;
	Элементы.ГруппаКомпенсировать.Видимость = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПрограммыМедицинскогоСтрахованияСотрудниковСрезПоследних.ПрограммаСтрахования.СтраховаяКомпания КАК СтраховаяКомпания
		|ИЗ
		|	РегистрСведений.ПрограммыМедицинскогоСтрахованияСотрудников.СрезПоследних(
		|			,
		|			Организация = &Организация
		|				И ФизическоеЛицо = &ФизическоеЛицо
		|				И ДействуетДо >= &ДатаУвольнения
		|				И Действует = ИСТИНА) КАК ПрограммыМедицинскогоСтрахованияСотрудниковСрезПоследних";
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("ФизическоеЛицо", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Сотрудник, "ФизическоеЛицо"));
	Запрос.УстановитьПараметр("ДатаУвольнения", Объект.ДатаУвольнения);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеСтрахования = РезультатЗапроса.Выгрузить();
	
	Объект.ДанныеМедицинскогоСтрахования.Загрузить(ТекущиеСтрахования);
	
	Если Объект.ДанныеМедицинскогоСтрахования.Количество() = 1 Тогда
		Объект.ДанныеМедицинскогоСтрахования[0].Откреплять = Истина;
		Объект.ДанныеМедицинскогоСтрахования[0].ДатаОткрепления = Объект.ДатаУвольнения;
	КонецЕсли;
	
	Если Не ИспользуютсяУдержанияВМедицинскомСтрахованииСотрудников Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	УдержанияМедицинскогоСтрахованияСрезПоследних.Удержание КАК Удержание,
		|	УдержанияМедицинскогоСтрахованияСрезПоследних.СпособУдержания КАК СпособУдержания
		|ИЗ
		|	РегистрСведений.УдержанияМедицинскогоСтрахования.СрезПоследних(
		|			,
		|			Организация = &Организация
		|				И ФизическоеЛицо = &ФизическоеЛицо) КАК УдержанияМедицинскогоСтрахованияСрезПоследних";
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("ФизическоеЛицо", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Сотрудник, "ФизическоеЛицо"));
	РезультатЗапроса = Запрос.Выполнить().Выбрать();
	РезультатЗапроса.Следующий();
	СпособУдержания = РезультатЗапроса.СпособУдержания;
	Если Не ЗначениеЗаполнено(СпособУдержания) Тогда
		Возврат;
	КонецЕсли;
	Удержание = РезультатЗапроса.Удержание;
	
	Если СпособУдержания = Перечисления.СпособыУдержанияМедицинскогоСтрахованияСотрудников.ПоГрафику Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	СУММА(ГрафикУдержанийМедицинскогоСтрахованияСрезПоследних.Сумма) КАК Сумма
			|ИЗ
			|	РегистрСведений.ГрафикУдержанийМедицинскогоСтрахования.СрезПоследних(
			|			,
			|			Организация = &Организация
			|				И ФизическоеЛицо = &ФизическоеЛицо) КАК ГрафикУдержанийМедицинскогоСтрахованияСрезПоследних";
		Запрос.УстановитьПараметр("Организация", Объект.Организация);
		Запрос.УстановитьПараметр("ФизическоеЛицо", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Сотрудник, "ФизическоеЛицо"));
		РезультатЗапроса = Запрос.Выполнить().Выбрать();
		РезультатЗапроса.Следующий();
		СуммаУдержанияПоГрафику = РезультатЗапроса.Сумма;
		Если Не ЗначениеЗаполнено(СуммаУдержанияПоГрафику) Тогда
			СуммаУдержанияПоГрафику = 0;
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	СУММА(НачисленияУдержанияПоСотрудникам.Сумма) КАК Сумма
			|ИЗ
			|	РегистрНакопления.НачисленияУдержанияПоСотрудникам КАК НачисленияУдержанияПоСотрудникам
			|ГДЕ
			|	НачисленияУдержанияПоСотрудникам.ФизическоеЛицо = &ФизическоеЛицо
			|	И НачисленияУдержанияПоСотрудникам.НачислениеУдержание = &Удержание
			|	И НачисленияУдержанияПоСотрудникам.Организация = &Организация";
		Запрос.УстановитьПараметр("Организация", Объект.Организация);
		Запрос.УстановитьПараметр("Удержание", Удержание);
		Запрос.УстановитьПараметр("ФизическоеЛицо", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Сотрудник, "ФизическоеЛицо"));
		РезультатЗапроса = Запрос.Выполнить().Выбрать();
		РезультатЗапроса.Следующий();
		УдержаноПоГрафику = РезультатЗапроса.Сумма;
		Если Не ЗначениеЗаполнено(УдержаноПоГрафику) Тогда
			УдержаноПоГрафику = 0;
		КонецЕсли;
		
		Если СуммаУдержанияПоГрафику = УдержаноПоГрафику Тогда
			Возврат;
		КонецЕсли;
		
		Если СуммаУдержанияПоГрафику > УдержаноПоГрафику Тогда
			Элементы.ГруппаУдерживатьОстаток.Видимость = Истина;
			Объект.ДанныеМедицинскогоСтрахования[0].ОстатокУдержания = СуммаУдержанияПоГрафику - УдержаноПоГрафику;
		КонецЕсли;
		
		Если УдержаноПоГрафику > СуммаУдержанияПоГрафику Тогда
			Элементы.ГруппаКомпенсировать.Видимость = Истина;
			Объект.ДанныеМедицинскогоСтрахования[0].СуммаКомпенсации = УдержаноПоГрафику - СуммаУдержанияПоГрафику;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьИнформациюПоДМС()
	
	АктивенОдинПолисДМС  = ?(Объект.ДанныеМедицинскогоСтрахования.Количество() = 1, Истина, Ложь);
	Элементы.ДанныеМедицинскогоСтрахования.Видимость = АктивенОдинПолисДМС;
	
	Если АктивенОдинПолисДМС Тогда
		Элементы.НадписьДанныеМедицинскогоСтрахования.Заголовок = 
			СтрШаблон(НСтр("ru = 'Сотрудник имеет действующий полис ДМС в страховой компании %1
			|Вы можете открепить его, прекратив действие полиса или оставить полис действующим после увольнения.
			|Остаток стоимости полиса при этом можно удержать с сотрудника при окончательном расчете.'"),
			Объект.ДанныеМедицинскогоСтрахования[0].СтраховаяКомпания);
		ОткреплятьСотрудника = Объект.ДанныеМедицинскогоСтрахования[0].Откреплять;
		ДатаОткрепления = Объект.ДанныеМедицинскогоСтрахования[0].ДатаОткрепления;
		УдержатьОстаток = Объект.ДанныеМедицинскогоСтрахования[0].УдержатьОстаток;
		ОстатокУдержания = Объект.ДанныеМедицинскогоСтрахования[0].ОстатокУдержания;
		Компенсировать = Объект.ДанныеМедицинскогоСтрахования[0].КомпенсироватьСтоимостьПолиса;
		СуммаКомпенсации = Объект.ДанныеМедицинскогоСтрахования[0].СуммаКомпенсации;
		Элементы.ГруппаУдерживатьОстаток.Видимость = ?(ОстатокУдержания > 0, Истина, Ложь);
		Элементы.ГруппаКомпенсировать.Видимость = ?(СуммаКомпенсации > 0, Истина, Ложь);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткреплятьСотрудникаПриИзменении(Элемент)
	
	УдержатьОстаток = Не ОткреплятьСотрудника;
	
	Объект.ДанныеМедицинскогоСтрахования[0].Откреплять = ОткреплятьСотрудника;
	Объект.ДанныеМедицинскогоСтрахования[0].УдержатьОстаток = УдержатьОстаток;
	
КонецПроцедуры

&НаКлиенте
Процедура УдержатьОстатокПриИзменении(Элемент)
	
	ОткреплятьСотрудника = Не УдержатьОстаток;
	
	Объект.ДанныеМедицинскогоСтрахования[0].Откреплять = ОткреплятьСотрудника;
	Объект.ДанныеМедицинскогоСтрахования[0].УдержатьОстаток = УдержатьОстаток;
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаОткрепленияПриИзменении(Элемент)
	
	Объект.ДанныеМедицинскогоСтрахования[0].ДатаОткрепления = ДатаОткрепления;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция РезультатыМероприятия(Предмет, Мероприятие)
	
	Мероприятия = Новый Массив;
	Мероприятия.Добавить(Мероприятие);
	
	РезультатыМероприятий = АдаптацияУвольнение.РезультатыМероприятий(Предмет, Мероприятия);
	
	Возврат РезультатыМероприятий.Получить(Мероприятие);
	
КонецФункции

&НаСервереБезКонтекста
Процедура УстановитьУсловноеОформление(УсловноеОформление)
	
	УсловноеОформление.Элементы.Очистить();
	
	АдаптацияУвольнениеФормы.РешениеУстановитьУсловноеОформлениеРезультатаВыполнения(УсловноеОформление);
	
КонецПроцедуры

#КонецОбласти

