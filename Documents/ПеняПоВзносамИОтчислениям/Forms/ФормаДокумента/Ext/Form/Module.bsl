Процедура ОрганизацияПриИзмененииНаСервере()
	// Вставить содержимое обработчика.
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНаСервере()
	
	Объект.РаспределениеПени = Булево(РаспределениеПени);

	ТекущийОбъект = РеквизитФормыВЗначение("Объект");
	
	Если ТекущийОбъект.МожноЗаполнитьИсчислениеПени() Тогда
		ТекущийОбъект.ЗаполнитьИсчислениеПени();
	КонецЕсли;

	ОбработатьСообщенияПользователю();
	
	ЗначениеВРеквизитФормы(ТекущийОбъект, "Объект");
	
	ПриПолученииДанныхНаСервере();	
	
	
КонецПроцедуры

&НаКлиенте
Процедура СуммаПоДокументуПриИзменении(Элемент)
	
	Если Объект.ИсчислениеПени.Количество() > 0 Тогда
		Оповещение = Новый ОписаниеОповещения("СуммаПоДокументуПриИзмененииПослеЗакрытияВопроса", ЭтаФорма, Параметры);
		ПоказатьВопрос(Оповещение, НСтр("ru = 'После изменения суммы данные табличной части будут пересчитаны. Продолжить выполнение операции?'"), РежимДиалогаВопрос.ДаНет, 0);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СуммаПоДокументуПриИзмененииПослеЗакрытияВопроса(Результат, Параметры) Экспорт
	
	Если Результат = КодВозвратаДиалога.Нет Тогда
		Объект.СуммаПоДокументу = Объект.ИсчислениеПени.Итог("Сумма");
		Возврат;
    КонецЕсли;

	СуммаПоДокументуПриИзмененииНаСервере();

КонецПроцедуры

&НаСервере
Процедура СуммаПоДокументуПриИзмененииНаСервере()
	
	Объект.РаспределениеПени = Булево(РаспределениеПени);
	ТекущийОбъект = РеквизитФормыВЗначение("Объект");
	ТекущийОбъект.ПересчитатьРаспределениеПени();
	ОбработатьСообщенияПользователю();
	ЗначениеВРеквизитФормы(ТекущийОбъект, "Объект");
	ПриПолученииДанныхНаСервере();	
	
КонецПроцедуры

