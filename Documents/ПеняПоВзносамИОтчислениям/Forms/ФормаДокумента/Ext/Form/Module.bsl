&НаКлиенте
Процедура РедактироватьИсчислениеПени(Команда)
	РедактироватьИсчислениеПениСтроки(Элементы.Состав.ТекущиеДанные);	
КонецПроцедуры

&НаКлиенте
Процедура Подобрать(Команда)
	
	ПроверитьЗаполнениеНаСервере();
	
	ПараметрыОткрытияФормы = Новый Структура;
	
	СтруктураОтбора = Новый Структура;
	
	СтруктураОтбора.Вставить("Организация", Объект.Организация);
	
	МассивРолей = Новый Массив;
	МассивРолей.Добавить(ПредопределенноеЗначение("Перечисление.РолиФизическихЛиц.Сотрудник"));
	МассивРолей.Добавить(ПредопределенноеЗначение("Перечисление.РолиФизическихЛиц.ПрочийПолучательДоходов"));
	МассивРолей.Добавить(ПредопределенноеЗначение("Перечисление.РолиФизическихЛиц.БывшийСотрудник"));
	СтруктураОтбора.Вставить("Роль", Новый ФиксированныйМассив(МассивРолей));
	
	ПараметрыОткрытияФормы.Вставить("МножественныйВыбор", Истина);
	ПараметрыОткрытияФормы.Вставить("ЗакрыватьПриВыборе", Ложь);
	ПараметрыОткрытияФормы.Вставить("Отбор", СтруктураОтбора);
	
	ПараметрыОткрытияФормы.Вставить("АдресСпискаПодобранныхФизическихЛиц", АдресСпискаПодобранныхСотрудников());
	
	ОткрытьФорму("Справочник.ФизическиеЛица.Форма.ФормаВыбораПоРоли", ПараметрыОткрытияФормы, Элементы.Состав);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПриПолученииДанныхНаСервере()
	
	РаспределениеПени = Число(Объект.РаспределениеПени);
	ЗарплатаКадрыКлиентСервер.ЗаполнитьМесяцПоДате(ЭтаФорма, "Объект.ПериодРегистрации", "ПериодРегистрацииСтрокой");
	
	ПериодРегистрацииДокумента = Объект.ПериодРегистрации;
	
	ТЗИсчислениеПени = Объект.ИсчислениеПени.Выгрузить(, "НомерСтроки, ФизическоеЛицо, МесяцНалоговогоПериода, Сумма");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ИсчислениеПени", ТЗИсчислениеПени);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ИсчислениеПени.НомерСтроки,
	|	ИсчислениеПени.ФизическоеЛицо,
	|	ИсчислениеПени.МесяцНалоговогоПериода,
	|	ИсчислениеПени.Сумма
	|ПОМЕСТИТЬ ВТ_ИсчислениеПени
	|ИЗ
	|	&ИсчислениеПени КАК ИсчислениеПени
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ИсчислениеПени.ФизическоеЛицо КАК ФизическоеЛицо,
	|	ВТ_ИсчислениеПени.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
	|	МИНИМУМ(ВТ_ИсчислениеПени.НомерСтроки) КАК НомерСтроки,
	|	СУММА(ВТ_ИсчислениеПени.Сумма) КАК Сумма
	|ИЗ
	|	ВТ_ИсчислениеПени КАК ВТ_ИсчислениеПени
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_ИсчислениеПени.ФизическоеЛицо,
	|	ВТ_ИсчислениеПени.МесяцНалоговогоПериода
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки
	|ИТОГИ
	|	СУММА(Сумма)
	|ПО
	|	ФизическоеЛицо";
	
	ВыборкаПоФизическомуЛицу = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	СоставТЗ = Новый ТаблицаЗначений;
	СоставТЗ.Колонки.Добавить("ФизическоеЛицо");
	СоставТЗ.Колонки.Добавить("КНачислению");
	СоставТЗ.Колонки.Добавить("Расшифровка");
	
	Пока ВыборкаПоФизическомуЛицу.Следующий() Цикл
		СоставСтрока = СоставТЗ.Добавить();
		СоставСтрока.ФизическоеЛицо = ВыборкаПоФизическомуЛицу.ФизическоеЛицо;
		СоставСтрока.КНачислению 		= ВыборкаПоФизическомуЛицу.Сумма;
		
		Выборка = ВыборкаПоФизическомуЛицу.Выбрать();
		ПредставлениеПериодов = "";
		Индекс = 1;
		Пока Выборка.Следующий() Цикл
			
			ПредставлениеПериодов = ПредставлениеПериодов + ?(Индекс = 1, "", ", ") 
					+ НРег(ЗарплатаКадрыКлиентСервер.ПолучитьПредставлениеМесяца(Выборка.МесяцНалоговогоПериода));
			
			Если Индекс = 3 Тогда
				ПредставлениеПериодов = ПредставлениеПериодов + "...";
				Прервать;
			КонецЕсли;
			
			Индекс = Индекс + 1;
		КонецЦикла;
		
		Если ЗначениеЗаполнено(ПредставлениеПериодов) Тогда
			РасшифровкаПериодов = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = ' за %1'"), ПредставлениеПериодов); 
		Иначе
			РасшифровкаПериодов = ""; 
		КонецЕсли;
		
		СоставСтрока.Расшифровка = "";
		Если ЗначениеЗаполнено(РасшифровкаПериодов) Тогда
			СоставСтрока.Расшифровка = СоставСтрока.Расшифровка + РасшифровкаПериодов
		КонецЕсли;
		
	КонецЦикла;  
	
	Состав.Загрузить(СоставТЗ);	
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура НастроитьДоступностьЭлементовУправления(Форма)
	
	Форма.Элементы.СуммаПоДокументу.Доступность = Булево(Форма.РаспределениеПени);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПервоначальныеЗначения() Экспорт
	
	ЗначенияДляЗаполнения = Новый Структура;
	ЗначенияДляЗаполнения.Вставить("Месяц",				"Объект.ПериодРегистрации");
	ЗначенияДляЗаполнения.Вставить("Организация",		"Объект.Организация");
	ЗначенияДляЗаполнения.Вставить("Подразделение",		"Объект.Подразделение");
	ЗначенияДляЗаполнения.Вставить("Ответственный",		"Объект.Ответственный");
	
	ЗарплатаКадры.ЗаполнитьПервоначальныеЗначенияВФорме(ЭтаФорма, ЗначенияДляЗаполнения);
	
	Если НЕ ПолучитьФункциональнуюОпцию("ВыполнятьРасчетЗарплатыПоПодразделениям") Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьРеквизитФормыПоПути(ЭтаФорма, "Объект.Подразделение", Справочники.ПодразделенияОрганизаций.ПустаяСсылка());
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция АдресСпискаПодобранныхСотрудников() Экспорт
	Возврат ПоместитьВоВременноеХранилище(Объект.ИсчислениеПени.Выгрузить(,"ФизическоеЛицо").ВыгрузитьКолонку("ФизическоеЛицо"), УникальныйИдентификатор);
КонецФункции

&НаСервере
Функция АдресВХранилищеИсчислениеПениПоСтроке(ФизическоеЛицо) Экспорт
	Возврат ПоместитьВоВременноеХранилище(Объект.ИсчислениеПени.Выгрузить(Новый Структура("ФизическоеЛицо", ФизическоеЛицо)), УникальныйИдентификатор);
КонецФункции	

&НаКлиенте
Процедура РедактироватьИсчислениеПениСтроки(ДанныеСтроки)
	
	Если ДанныеСтроки = Неопределено Тогда
		Возврат
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("ПериодРегистрации",		Объект.ПериодРегистрации);
	ПараметрыОткрытия.Вставить("ФизическоеЛицо", 		ДанныеСтроки.ФизическоеЛицо);
	ПараметрыОткрытия.Вставить("АдресВХранилищеИсчислениеПениПоСтроке", АдресВХранилищеИсчислениеПениПоСтроке(ДанныеСтроки.ФизическоеЛицо));
	
	ПараметрыОткрытия.Вставить("ТолькоПросмотр",		ЭтаФорма.ТолькоПросмотр);
	
	Оповещение = Новый ОписаниеОповещения("РедактироватьИсчислениеПениСтрокиЗавершение", ЭтотОбъект);
	ОткрытьФорму("Документ.ПеняПоВзносамИОтчислениям.Форма.РедактированиеСтрокиНачисленияПени", ПараметрыОткрытия, ЭтаФорма, , , , Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура РедактироватьИсчислениеПениСтрокиЗавершение(РезультатыРедактирования, ДополнительныеПараметры) Экспорт
	
	Если РезультатыРедактирования <> Неопределено И РезультатыРедактирования.Модифицированность Тогда
		РедактироватьИсчислениеПениСтрокиЗавершениеНаСервере(РезультатыРедактирования);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура РедактироватьИсчислениеПениСтрокиЗавершениеНаСервере(РезультатыРедактирования)
	
	ФизическоеЛицо = РезультатыРедактирования.ФизическоеЛицо;
	
	УдаляемыеСтроки = Объект.ИсчислениеПени.НайтиСтроки(Новый Структура("ФизическоеЛицо", ФизическоеЛицо));
	Для Каждого УдаляемаяСтрока Из УдаляемыеСтроки Цикл
		Объект.ИсчислениеПени.Удалить(УдаляемаяСтрока);
	КонецЦикла;	
	
	ИсчислениеПениСтроки = ПолучитьИзВременногоХранилища(РезультатыРедактирования.АдресВХранилищеИсчислениеПениПоСтроке);

	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчислениеПениСтроки, Объект.ИсчислениеПени);
	
	Объект.СуммаПоДокументу = Объект.ИсчислениеПени.Итог("Сумма");

	ПриПолученииДанныхНаСервере();
		
	Модифицированность = Истина;

КонецПроцедуры

&НаСервере
Процедура СоставОбработкаВыбораНаСервере(ВыбранноеЗначение, СтандартнаяОбработка) 
	
	Если ТипЗнч(ВыбранноеЗначение) <> Тип("Массив") Тогда
		ВыбранныеСотрудники = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ВыбранноеЗначение);
	Иначе
		ВыбранныеСотрудники = ОбщегоНазначенияКлиентСервер.СвернутьМассив(ВыбранноеЗначение)
	КонецЕсли;
	
	СотрудникиМассив = Новый Массив;
	Для Каждого Сотрудник Из ВыбранныеСотрудники Цикл
		
		СтрокиСотрудника = Состав.НайтиСтроки(Новый Структура("ФизическоеЛицо", Сотрудник));
		
		Если СтрокиСотрудника.Количество() = 0 Тогда
			СотрудникиМассив.Добавить(Сотрудник)
		КонецЕсли;
		
	КонецЦикла;
	
	Если СотрудникиМассив.Количество() > 0 Тогда
		НачислениеПениДополнитьНаСервере(СотрудникиМассив);
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура НачислениеПениДополнитьНаСервере(СотрудникиМассив) Экспорт
	
	ТекущийОбъект = РеквизитФормыВЗначение("Объект");
	
	Если ТекущийОбъект.МожноЗаполнитьИсчислениеПени() Тогда
		ТекущийОбъект.ДополнитьИсчислениеПени(СотрудникиМассив);
	КонецЕсли;

	ОбработатьСообщенияПользователю();
	
	ЗначениеВРеквизитФормы(ТекущийОбъект, "Объект");
	
	ПриПолученииДанныхНаСервере();	
	
КонецПроцедуры

&НаСервере
Процедура ОбработатьСообщенияПользователю() Экспорт
	
	Сообщения = ПолучитьСообщенияПользователю(Ложь);
	
	Для Каждого Сообщение Из Сообщения Цикл
		Если СтрНайти(Сообщение.Поле, "ПериодРегистрации") Тогда
			Сообщение.Поле = "";
			Сообщение.ПутьКДанным = "ПериодРегистрацииСтрокой";
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура СоставПослеУдаленияНаСервере()

	Для Каждого Сотрудник Из Сотрудники Цикл
		
		УдаляемыеСтроки = Объект.ИсчислениеПени.НайтиСтроки(Новый Структура("ФизическоеЛицо", Сотрудник));
		Для Каждого УдаляемаяСтрока Из УдаляемыеСтроки Цикл
			Объект.ИсчислениеПени.Удалить(УдаляемаяСтрока);
		КонецЦикла;	
		
	КонецЦикла
	
КонецПроцедуры

&НаСервере
Функция ПроверитьЗаполнениеНаСервере()
	
	ТекущийОбъект = РеквизитФормыВЗначение("Объект");
	Возврат ТекущийОбъект.МожноЗаполнитьИсчислениеПени();
	
КонецФункции

