#Область ОбработчикиСобытийЭлементовТаблицыФормы

&НаКлиенте
Процедура СоставВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.Состав.ТекущиеДанные;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.ФизическоеЛицо) Тогда
		Если Поле.ГиперссылкаЯчейки ИЛИ Поле.ТолькоПросмотр Тогда
			РедактироватьИсчислениеПениСтроки(ТекущиеДанные);
			СтандартнаяОбработка = Ложь;
		КонецЕсли	
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СоставПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа, Параметр)
	Если Не Копирование Тогда
		КадровыйУчетКлиент.ПодобратьФизическихЛицОрганизации(
		Элементы.Состав, 
		Объект.Организация, 
		АдресСпискаПодобранныхСотрудников());
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура СоставПередУдалением(Элемент, Отказ)
	
	СотрудникиМассив = Новый Массив;
	
	Для Каждого ВыделеннаяСтрока Из Элемент.ВыделенныеСтроки Цикл
		
		Строка = Состав.НайтиПоИдентификатору(ВыделеннаяСтрока).ФизическоеЛицо;
		
		Если Строка <> Неопределено Тогда
			СотрудникиМассив.Добавить(Строка);
		КонецЕсли	
		
	КонецЦикла;	
	
	Сотрудники = Новый ФиксированныйМассив(СотрудникиМассив);

КонецПроцедуры

&НаКлиенте
Процедура СоставОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	СоставОбработкаВыбораНаСервере(ВыбранноеЗначение, СтандартнаяОбработка);
КонецПроцедуры

&НаКлиенте
Процедура СоставПослеУдаления(Элемент)
	СоставПослеУдаленияНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура СоставКНачислениюПриИзменении(Элемент)
	
	СоставКНачислениюПриИзмененииПриИзмененииНаСервере(Элементы.Состав.ТекущаяСтрока);
	
КонецПроцедуры

&НаСервере
Процедура СоставКНачислениюПриИзмененииПриИзмененииНаСервере(ИдентификаторСтроки)
	
	ТекущиеДанные = Состав.НайтиПоИдентификатору(ИдентификаторСтроки);
	
	СуммаПени = ТекущиеДанные.КНачислению;
	
	ИсчислениеПени = Объект.ИсчислениеПени.НайтиСтроки(Новый Структура("ФизическоеЛицо", ТекущиеДанные.ФизическоеЛицо));
	
	ЗарплатаКадры.РазнестиСуммуПоБазе(СуммаПени, ИсчислениеПени, "Сумма");
	
	Для Каждого Начисление Из ИсчислениеПени Цикл
		Если Начисление.Сумма = 0 Тогда
			Объект.ИсчислениеПени.Удалить(Начисление);
		КонецЕсли;	
	КонецЦикла;
		
КонецПроцедуры

#КонецОбласти

