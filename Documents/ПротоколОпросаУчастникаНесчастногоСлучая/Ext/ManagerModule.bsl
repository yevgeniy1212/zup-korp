		ДанныеПечати.Вставить("МассивУчастниковОпросаРК", МассивУчастниковОпросаРК);
		// ЗУПК
	КонецЦикла;
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Пострадавшие.Ссылка,
	|	Пострадавшие.Организация КАК Организация,
	|	Пострадавшие.Пострадавший,
