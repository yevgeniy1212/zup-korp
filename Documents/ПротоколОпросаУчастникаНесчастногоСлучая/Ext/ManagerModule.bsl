		ДанныеПечати = ДанныеПечатиОбъектов.Получить(Выборка.Ссылка);
		Если ДанныеПечати = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СтрокаПострадавшие = "";
		// ЗУПК
		СтрокаПострадавшиеСоСклонениями = "";
		// ЗУПК
		Пока Выборка.Следующий() Цикл
			СтрокаПострадавшие = СтрокаПострадавшие + Выборка.ФамилияИО + " " + СокрЛП(Выборка.Профессии) + " " + СокрЛП(Выборка.НаименованиеДолжности) + ", ";
			// ЗУПК
			ФИОПострадавшегоСклоняемое = "";
			ФизическиеЛицаЗарплатаКадры.Просклонять(Строка(Выборка.ФИОПолные), 5, ФИОПострадавшегоСклоняемое, Выборка.Пол);
			
			ДолжностьСклоняемая = "";
			ФизическиеЛицаЗарплатаКадры.Просклонять(Строка(Выборка.НаименованиеДолжности), 5, ДолжностьСклоняемая);
			
			СтрокаПострадавшиеСоСклонениями = СтрокаПострадавшиеСоСклонениями + ФИОПострадавшегоСклоняемое + ", " + ДолжностьСклоняемая + "; ";
			// ЗУПК
		КонецЦикла;
		СтроковыеФункцииКлиентСервер.УдалитьПоследнийСимволВСтроке(СтрокаПострадавшие, 2);
		ДанныеПечати.Вставить("СтрокаПострадавшие", СтрокаПострадавшие);
		// ЗУПК
		СтроковыеФункцииКлиентСервер.УдалитьПоследнийСимволВСтроке(СтрокаПострадавшиеСоСклонениями, 2);
		ДанныеПечати.Вставить("СтрокаПострадавшиеСоСклонениями", СтрокаПострадавшиеСоСклонениями);
		// ЗУПК
	КонецЦикла;
	
	Возврат ДанныеПечатиОбъектов;
	
