&НаСервереБезКонтекста
Функция ПолучитьДанныеВидаДохода(ПериодРегистрации, ВидПрочегоДохода) 
	
	ТаблицаНалогообложения = РегистрыСведений.НалогообложениеНачислений.СрезПоследних(ПериодРегистрации, Новый Структура("Начисление", ВидПрочегоДохода));
	
	Если ТаблицаНалогообложения.Количество() > 0 Тогда
		ВидДохода = ТаблицаНалогообложения[0].ВидДохода;
	Иначе
		ВидДохода = ПредопределенноеЗначение("Справочник.ВидыДоходов.ДоходыОтНалоговогоАгента");
	КонецЕсли;
	
	СтруктураРезультата = Новый Структура("УчитыватьОПВ, УчитыватьВОСМС, УчитыватьИПН, УчитыватьСН, УчитыватьСО, УчитыватьОПВР, УчитыватьООСМС"); 
	РеквизитыВидаДохода = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ВидДохода, СтруктураРезультата);
	ЗаполнитьЗначенияСвойств(СтруктураРезультата, РеквизитыВидаДохода);
	СтруктураРезультата.Вставить("ВидДохода", ВидДохода);
	
	Возврат СтруктураРезультата;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура ЗаполнитьИтогиВычеты(Форма)
		
	Форма.ИтогИПН = Форма.Объект.НачисленияУдержанияВзносы.Итог("ИПН");
	Форма.ИтогОПВ = Форма.Объект.НачисленияУдержанияВзносы.Итог("ОПВ");
	Форма.ИтогВОСМС = Форма.Объект.НачисленияУдержанияВзносы.Итог("ВОСМС");
	Форма.ИтогСО = Форма.Объект.НачисленияУдержанияВзносы.Итог("СО");
	Форма.ИтогСН = Форма.Объект.НачисленияУдержанияВзносы.Итог("СН");
	Форма.ИтогОПВР = Форма.Объект.НачисленияУдержанияВзносы.Итог("ОПВР");
	Форма.ИтогООСМС = Форма.Объект.НачисленияУдержанияВзносы.Итог("ООСМС");
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПлановымДоходомИПНаСервере()
	
	УчетнаяПолитикаНУ = РегистрыСведений.УчетнаяПолитикаПоНалоговомуУчету.СрезПоследних(Объект.ПериодРегистрации, Новый Структура("Организация", Объект.Организация));
	СуммаЗаявленногоДоходаИП = 0;
	Если УчетнаяПолитикаНУ.Количество() > 0 Тогда
		СуммаЗаявленногоДоходаИП = УчетнаяПолитикаНУ[0].СуммаЗаявленногоДоходаИП;
	КонецЕсли;
	
	Если УчетнаяПолитикаНУ.Количество() = 0 
		ИЛИ СуммаЗаявленногоДоходаИП = 0 Тогда
		ВызватьИсключение НСтр("ru = 'В учетной политике по налоговому учету не указана сумма заявленного дохода ИП'");
	КонецЕсли;
	
	Объект.НачисленияУдержанияВзносы.Очистить();
	
	ФизическоеЛицо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Организация, "ИндивидуальныйПредприниматель");
	
	СтрокаНачисленияУдержанияВзносы = Объект.НачисленияУдержанияВзносы.Добавить();
	СтрокаНачисленияУдержанияВзносы.ФизическоеЛицо = ФизическоеЛицо;
	СтрокаНачисленияУдержанияВзносы.Начислено = СуммаЗаявленногоДоходаИП;	
	
	РассчитатьНДФЛИВзносыНаСервере(ФизическоеЛицо);
	ЗаполнитьИтогиВычеты(ЭтаФорма);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьДанныеНалогиВзносыОтчисленияНаСервере(АдресВременногоХранилища)
	
	ПараметрыДанных = ПолучитьИзВременногоХранилища(АдресВременногоХранилища);
	
	КонтролируемыеПоля = Новый Структура;
	ОписаниеДокумента = ОписаниеДокумента();
	ВидНалогаВзносаОтчисления = ПараметрыДанных.ВидНалогаВзносаОтчисления;
	
	ОтборСтрок = Новый Структура("ФизическоеЛицо, ВидНалогаВзносаОтчисления", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ПараметрыДанных.ФизическоеЛицо), ВидНалогаВзносаОтчисления);
	УчетНалоговВзносовОтчисленийРасширенный.ЗаменитьСтрокиНалогиВзносыОтчисления(Объект.НалогиВзносыОтчисления, Объект.ВычетыИПН, Объект.ДоходыНеПодлежащиеНалогообложению, ПараметрыДанных, КонтролируемыеПоля, ОписаниеДокумента, ОтборСтрок, Ложь, "ФизическоеЛицо,ВидНалогаВзносаОтчисления");
	
	Модифицированность = Истина;
	
	РассчитатьИтогиНаСервере();
	
	Модифицированность = Истина;
	
	ПараметрыРасчета = УчетПрочихДоходов.ПараметрыРасчетаДокумента();
	ПараметрыРасчета.РасчетНДФЛНарастающимИтогомСНачалаГода = РасчетНДФЛНарастающимИтогомСНачалаГода;
	ПараметрыРасчета.ОбновитьБухУчетНачислений = Ложь;
	ПараметрыРасчета.РассчитатьНалогиИВзносы = Ложь;
	ПараметрыРасчета.ИспользоватьСтатьиФинансирования = ИспользоватьСтатьиФинансирования;
	ПараметрыРасчета.РассчитатьУдержания = Истина;
	ПараметрыРасчета.СписокФизическихЛиц = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ПараметрыДанных.ФизическоеЛицо);
	
	ДанныеРасчета = УчетПрочихДоходов.РассчитатьДокумент(Объект, ПараметрыРасчета);
	УчетПрочихДоходов.РезультатРасчетаВДанныеФормы(ЭтотОбъект, ДанныеРасчета);
	
	РассчитатьИтогиНаСервере();
	ЗаполнитьИтогиВычеты(ЭтаФорма);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьВидимостьЭлементовВидаДохода()
	
	Элементы.НачисленияУдержанияВзносыЗаполнитьПлановымДоходом.Видимость = (ЭтаФорма["ОрганизацияЯвляетсяИП"] И ЭтаФорма["ВидДохода"] = ПредопределенноеЗначение("Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства"));
																			
	Элементы.Подразделение.Видимость = (НЕ ЭтаФорма["ВидДохода"] = ПредопределенноеЗначение("Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства"));
	Элементы.СпособОтраженияЗарплатыВБухучете.Видимость = (НЕ ЭтаФорма["ВидДохода"] = ПредопределенноеЗначение("Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства"));
	Элементы.РегистрироватьВыплатуВедомостью.Видимость = (НЕ ЭтаФорма["ВидДохода"] = ПредопределенноеЗначение("Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства"));
	
КонецПроцедуры

