&НаСервере
Процедура ПриПолученииДанныхНаСервере()
	
	ЗарплатаКадрыКлиентСервер.ЗаполнитьМесяцПоДате(ЭтотОбъект, "Объект.ДатаНачала", "ДатаНачалаСтрокой");
	ЗарплатаКадрыКлиентСервер.ЗаполнитьМесяцПоДате(ЭтотОбъект, "Объект.ДатаОкончания", "ДатаОкончанияСтрокой");
	
	ДанныеВРеквизиты();
	
	УстановитьСвойстваДатыОкончания();
	
	СтруктураПредприятияНеСоответствуетСтруктуреЮридическихЛиц = ПолучитьФункциональнуюОпциюФормы("СтруктураПредприятияНеСоответствуетСтруктуреЮридическихЛиц");
	
	ПриИзмененииПодразделенияНаСервере();
	
	// заполним предупреждения 
	ЗарплатаКадры.КлючевыеРеквизитыЗаполненияФормыЗаполнитьПредупреждения(ЭтотОбъект);
	ЗарплатаКадрыКлиентСервер.КлючевыеРеквизитыЗаполненияФормыУстановитьОтображениеПредупреждения(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ПриИзмененииПодразделенияНаСервере()
	
	Если СтруктураПредприятияНеСоответствуетСтруктуреЮридическихЛиц Тогда
		Возврат;
	КонецЕсли;
	
	ИсточникПодразделенияПредприятия = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Подразделение, "Источник");
	ЭтоПодразделение = ТипЗнч(ИсточникПодразделенияПредприятия) = Тип("СправочникСсылка.ПодразделенияОрганизаций");
	
КонецПроцедуры

&НаСервере
// Функция возвращает описание таблиц формы подключенных к механизму ключевых реквизитов формы.
Функция КлючевыеРеквизитыЗаполненияФормыТаблицыОчищаемыеПриИзменении() Экспорт
	
	Массив = Новый Массив;
	Массив.Добавить("Объект.Сотрудники");
	Массив.Добавить("Объект.РаспределениеРасходов");
	Массив.Добавить("Объект.ФизическиеЛица");
	
	Возврат Массив;
	
КонецФункции

&НаСервере
// Функция возвращает массив реквизитов формы подключенных к механизму ключевых реквизитов формы.
Функция КлючевыеРеквизитыЗаполненияФормыОписаниеКлючевыхРеквизитов() Экспорт
	
	Массив = Новый Массив;
	Массив.Добавить(Новый Структура("ЭлементФормы, Представление", "Подразделение", НСтр("ru = 'подразделения'")));
	
	Возврат Массив;
	
КонецФункции

&НаСервере
Процедура ДанныеВРеквизиты()

	УстановитьПривилегированныйРежим(Истина);
	
	ДанныеРаспределения = Объект.РаспределениеРасходов.Выгрузить();
	
	ОтборСтрок = Новый Структура("ИдентификаторСтрокиСотрудника");
	
	Для каждого СтрокаТЧ Из Объект.Сотрудники Цикл
		ОтборСтрок.ИдентификаторСтрокиСотрудника = СтрокаТЧ.ИдентификаторСтрокиСотрудника;
		ТаблицаРаспределения = ДанныеРаспределения.Скопировать(ОтборСтрок);
		СтруктураРаспределения = ЗарплатаКадрыРасширенный.ТаблицаЗначенийВСтруктуру(ТаблицаРаспределения);
		СтрокаТЧ.РезультатРаспределения = СтруктураРаспределения;
		СтрокаТЧ.ПредставлениеРаспределения = ПредставлениеРаспределенияСтроки(СтруктураРаспределения);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура РеквизитыВДанные(ТекущийОбъект)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ТекущийОбъект.РаспределениеРасходов.Очистить();
	
	ИдентификаторСтрокиСотрудника = 1;
	Для каждого СтрокаТЧ Из Объект.Сотрудники Цикл
		
		СтрокаТЧ.ИдентификаторСтрокиСотрудника = ИдентификаторСтрокиСотрудника;
		ТекущийОбъект.Сотрудники[Объект.Сотрудники.Индекс(СтрокаТЧ)].ИдентификаторСтрокиСотрудника = ИдентификаторСтрокиСотрудника;
		
		РезультатРаспределения = СтрокаТЧ.РезультатРаспределения;
		Если РезультатРаспределения <> Неопределено Тогда
			Для Каждого СтрокаРаспределения Из РезультатРаспределения Цикл
				НоваяСтрока = ТекущийОбъект.РаспределениеРасходов.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаРаспределения);
				НоваяСтрока.ИдентификаторСтрокиСотрудника = ИдентификаторСтрокиСотрудника;
			КонецЦикла;
		КонецЕсли;
		
		ИдентификаторСтрокиСотрудника = ИдентификаторСтрокиСотрудника + 1;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура РедактироватьСтроку(ДанныеСтроки, ВыбраннаяСтрока)
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("Подразделение", Объект.Подразделение);
	ПараметрыОткрытия.Вставить("ДатаНачала", Объект.ДатаНачала);
	ПараметрыОткрытия.Вставить("СуммарнаяДоляСтоПроцентов", Объект.СуммарнаяДоляСтоПроцентов);
	ПараметрыОткрытия.Вставить("РаспределениеРасходов", ДанныеСтроки.РезультатРаспределения);
	ПараметрыОткрытия.Вставить("ТолькоПросмотр", ТолькоПросмотр);
	ПараметрыОткрытия.Вставить("Сотрудник", ДанныеСтроки.Сотрудник);
	
	ДополнительныеПараметры = Новый Структура("ИдентификаторСтроки", ВыбраннаяСтрока);
	Оповещение = Новый ОписаниеОповещения("РедактироватьСтрокуЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	
	ОткрытьФорму("Документ.РаспределениеРасходовНаПерсонал.Форма.ФормаСтрокиРаспределения",
				ПараметрыОткрытия, ЭтотОбъект, Истина, , , Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаСервере
Функция АдресСпискаПодобранныхСотрудников() Экспорт
	
	Возврат ПоместитьВоВременноеХранилище(Объект.Сотрудники.Выгрузить(,"Сотрудник").ВыгрузитьКолонку("Сотрудник"), УникальныйИдентификатор);
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПредставлениеРаспределенияСтроки(РезультатРаспределения)
	Возврат ФинансовыйУчетКлиентСервер.ПредставлениеРаспределенияСтроки(РезультатРаспределения);
КонецФункции

&НаКлиенте
Процедура РедактироватьСтрокуЗавершение(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Модифицированность = Истина;
	
	ТекущиеДанные = Объект.Сотрудники.НайтиПоИдентификатору(ДополнительныеПараметры.ИдентификаторСтроки);
	ТекущиеДанные.Сотрудник = Результат.Сотрудник;
	ТекущиеДанные.РезультатРаспределения = Результат.РаспределениеРасходов;
	ТекущиеДанные.ПредставлениеРаспределения = ПредставлениеРаспределенияСтроки(ТекущиеДанные.РезультатРаспределения);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьРаспределениеЗавершение(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого СтрокаТЧ Из Объект.Сотрудники Цикл
		СтрокаТЧ.РезультатРаспределения = Новый ФиксированныйМассив(ОбщегоНазначенияКлиент.СкопироватьРекурсивно(Результат.РаспределениеРасходов, Ложь));
		СтрокаТЧ.ПредставлениеРаспределения = ПредставлениеРаспределенияСтроки(СтрокаТЧ.РезультатРаспределения);
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура ОбработкаПодбораНаСервере(Знач Сотрудники)
	
	Модифицированность = Истина;
	
	Если ТипЗнч(Сотрудники) <> Тип("Массив") Тогда
		Сотрудники = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Сотрудники);
	КонецЕсли;
	
	МестаСотрудников = МестоСотрудниковВСтруктуреПредприятия(Сотрудники, Объект.ДатаНачала);
	
	Для Каждого Сотрудник Из Сотрудники Цикл
		СтрокиСотрудников = Объект.Сотрудники.НайтиСтроки(Новый Структура("Сотрудник", Сотрудник));
		
		Если СтрокиСотрудников.Количество() = 0 Тогда
			НоваяСтрока = Объект.Сотрудники.Добавить();
			НоваяСтрока.Сотрудник = Сотрудник;
			НоваяСтрока.Подразделение = МестаСотрудников.Получить(Сотрудник);
			НоваяСтрока.ПредставлениеРаспределения = НСтр("ru='Не задано'");
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСотрудниковНаСервере(СообщатьПользователю = Ложь)
	
	Объект.Сотрудники.Очистить();
	
	СотрудникиПодразделения = ОрганизационнаяСтруктура.СотрудникиПодразделения(
		Объект.Подразделение, Объект.ДатаНачала, КонецМесяца(Объект.ДатаНачала));
	
	Для каждого СтрокаТаблицы Из СотрудникиПодразделения Цикл
		НоваяСтрокаТЧ = Объект.Сотрудники.Добавить();
		НоваяСтрокаТЧ.Сотрудник = СтрокаТаблицы.Сотрудник;
		НоваяСтрокаТЧ.Подразделение = СтрокаТаблицы.МестоВСтруктуреПредприятия;
		НоваяСтрокаТЧ.ПредставлениеРаспределения = НСтр("ru='Не задано'");
	КонецЦикла;

КонецПроцедуры

&НаСервере
Процедура УстановитьСвойстваДатыОкончания()
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДатаОкончанияСтрокой", "ТолькоПросмотр", Объект.Бессрочно);
	ОбщегоНазначенияБЗККлиентСервер.УстановитьОбязательностьПоляВводаФормы(ЭтотОбъект, "ДатаОкончанияСтрокой", Не Объект.Бессрочно);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьПодразделениеСтрокиПоСотруднику()
	
	ТекущиеДанные = Элементы.Сотрудники.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущиеДанные.Сотрудник) Тогда
		ТекущиеДанные.Подразделение = Неопределено;
		Возврат;
	КонецЕсли;
	
	МестаСотрудников = МестоСотрудниковВСтруктуреПредприятия(ТекущиеДанные.Сотрудник, Объект.ДатаНачала);
	
	ТекущиеДанные.Подразделение = МестаСотрудников.Получить(ТекущиеДанные.Сотрудник);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция МестоСотрудниковВСтруктуреПредприятия(СписокСотрудников, ДатаПолученияДанных)
	Возврат ОрганизационнаяСтруктура.МестоСотрудниковВСтруктуреПредприятия(Ложь, СписокСотрудников, ДатаПолученияДанных);
КонецФункции

#Область ЗагрузкаДанныхИзФайла

&НаКлиенте
Процедура ЗагрузитьСотрудниковИзФайлаЗавершение(АдресЗагруженныхДанных, ДополнительныеПараметры) Экспорт
	
	Если АдресЗагруженныхДанных = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	ЗагрузитьСотрудниковИзФайлаНаСервере(АдресЗагруженныхДанных);
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьСотрудниковИзФайлаНаСервере(АдресЗагруженныхДанных)
	
	ДобавленыСтроки = Ложь;
	
	ДобавленыСотрудники = Ложь;
	ДобавленныеСотрудники = Новый Массив;
	
	ЗагруженныеДанные = ПолучитьИзВременногоХранилища(АдресЗагруженныхДанных);
	Для Каждого СтрокаДанных Из ЗагруженныеДанные Цикл 
		Если Не ЗначениеЗаполнено(СтрокаДанных.Сотрудник) Тогда 
			Продолжить;
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(Объект.РаспределениеРасходов.Добавить(), СтрокаДанных);
		
		СтрокиСотрудников = Объект.Сотрудники.НайтиСтроки(Новый Структура("Сотрудник", СтрокаДанных.Сотрудник));
		
		Если СтрокиСотрудников.Количество() = 0 Тогда
			НоваяСтрока = Объект.Сотрудники.Добавить();
			НоваяСтрока.Сотрудник = СтрокаДанных.Сотрудник;
			ДобавленныеСотрудники.Добавить(НоваяСтрока.Сотрудник);
		КонецЕсли;
		
		ДобавленыСтроки = Истина;
	КонецЦикла;
	
	Если ДобавленыСтроки Тогда
		Если ДобавленныеСотрудники.Количество() > 0 Тогда
			ДобавленыСотрудники = Истина;
			МестаСотрудников = МестоСотрудниковВСтруктуреПредприятия(ДобавленныеСотрудники, Объект.ДатаНачала);
		КонецЕсли;
		ИдентификаторСтрокиСотрудника = 1;
		Для каждого СтрокаТЧ Из Объект.Сотрудники Цикл
			Если ДобавленыСотрудники И ДобавленныеСотрудники.Найти(СтрокаТЧ.Сотрудник) <> Неопределено Тогда
				СтрокаТЧ.Подразделение = МестаСотрудников.Получить(СтрокаТЧ.Сотрудник);
			КонецЕсли;
			СтрокаТЧ.ИдентификаторСтрокиСотрудника = ИдентификаторСтрокиСотрудника;
			
			СтрокиРаспределениеРасходов = Объект.РаспределениеРасходов.НайтиСтроки(Новый Структура("Сотрудник", СтрокаТЧ.Сотрудник));
			
			Для Каждого СтрокаРаспределения Из СтрокиРаспределениеРасходов Цикл
				СтрокаРаспределения.ИдентификаторСтрокиСотрудника = ИдентификаторСтрокиСотрудника;
			КонецЦикла;
			
			ИдентификаторСтрокиСотрудника = ИдентификаторСтрокиСотрудника + 1;
		КонецЦикла;
		
		ДанныеВРеквизиты();
	КонецЕсли;
	
	Модифицированность = Модифицированность Или ДобавленыСтроки;
	
КонецПроцедуры

&НаСервере
Функция ОписаниеКолонокМакетаДляЗагрузкиИзФайла()
	
	КолонкиМакета = Документы.РаспределениеРасходовНаПерсонал.ОписаниеКолонокМакетаДляЗагрузкиИзФайла();
	
	Возврат КолонкиМакета;
	
КонецФункции

#КонецОбласти

#КонецОбласти
