// Возвращает описание состава документа
//
// Возвращаемое значение:
//  Структура - см. ЗарплатаКадрыСоставДокументов.НовоеОписаниеСоставаОбъекта.
Функция ОписаниеСоставаОбъекта() Экспорт
	
	МетаданныеДокумента = Метаданные.Документы.РаспределениеРасходовНаПерсонал;
	Возврат ЗарплатаКадрыСоставДокументов.ОписаниеСоставаОбъектаПоМетаданнымФизическиеЛицаВТабличныхЧастях(МетаданныеДокумента);
	
КонецФункции

Функция ОписаниеКолонокМакетаДляЗагрузкиИзФайла() Экспорт
	
	КолонкиМакета = Новый Массив;
	
	Группа = НСтр("ru = 'Сотрудник'");
	
	Колонка = ЗагрузкаДанныхИзФайлаКлиентСервер.ОписаниеКолонкиМакета(
		"СотрудникКод", Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(10)));
	Колонка.Заголовок = НСтр("ru = 'Код'");
	Колонка.Группа = Группа;
	Колонка.Ширина = 10;
	Колонка.Родитель = "Сотрудник";
	Колонка.Позиция = КолонкиМакета.Количество() + 1;
	КолонкиМакета.Добавить(Колонка);
	
	Колонка = ЗагрузкаДанныхИзФайлаКлиентСервер.ОписаниеКолонкиМакета(
		"СотрудникФИО", Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(100)));
	Колонка.Заголовок = НСтр("ru = 'ФИО'");
	Колонка.ОбязательнаДляЗаполнения = Истина;
	Колонка.Группа = Группа;
	Колонка.Родитель = "Сотрудник";
	Колонка.Позиция = КолонкиМакета.Количество() + 1;
	КолонкиМакета.Добавить(Колонка);
	
	Колонка = ЗагрузкаДанныхИзФайлаКлиентСервер.ОписаниеКолонкиМакета(
		"СпособОтражения", Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(100)));
	Колонка.Заголовок = НСтр("ru = 'Способ отражения'");
	Колонка.ОбязательнаДляЗаполнения = Истина;
	Колонка.Позиция = КолонкиМакета.Количество() + 1;
	КолонкиМакета.Добавить(Колонка);
	
	Колонка = ЗагрузкаДанныхИзФайлаКлиентСервер.ОписаниеКолонкиМакета(
		"ДоляРаспределения", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла()));
	Колонка.Заголовок = НСтр("ru = 'Доля распределения'");
	Колонка.ОбязательнаДляЗаполнения = Истина;
	Колонка.Ширина = 15;
	Колонка.Позиция = КолонкиМакета.Количество() + 1;
	КолонкиМакета.Добавить(Колонка);
	
	Возврат КолонкиМакета;
	
КонецФункции

