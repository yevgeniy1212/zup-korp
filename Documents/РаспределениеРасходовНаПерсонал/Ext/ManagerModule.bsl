Функция ТекстЗапросаЗагружаемыхДанных(Колонки)
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Таблица.Идентификатор КАК Идентификатор
	|ПОМЕСТИТЬ ЗагружаемыеДанные
	|ИЗ &ЗагружаемыеДанные КАК Таблица";
	
	СхемаЗапроса = Новый СхемаЗапроса();
	СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
	
	Запрос = СхемаЗапроса.ПакетЗапросов[0].Операторы[0];
	Для Каждого Колонка Из Колонки Цикл
		Если Колонка.Имя = "Идентификатор" Тогда
			Продолжить;
		КонецЕсли;
		Запрос.ВыбираемыеПоля.Добавить("Таблица." + Колонка.Имя);
	КонецЦикла;
	
	ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ТекстЗапросаСопоставленияДанных(Колонки)
	
	МассивЗапросов = Новый Массив;
	
	Если Колонки.Найти("СотрудникФИО") = Неопределено Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ ПЕРВЫЕ 0
		|	ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка) КАК Ссылка,
		|	0 КАК ИдентификаторСтроки,
		|	0 КАК Приоритет
		|ПОМЕСТИТЬ СотрудникиСопоставленные";
	Иначе
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	Сотрудники.Ссылка КАК Ссылка,
		|	ЗагружаемыеДанные.Идентификатор КАК ИдентификаторСтроки,
		|	2 КАК Приоритет
		|ПОМЕСТИТЬ СотрудникиСопоставленные
		|ИЗ Справочник.Сотрудники КАК Сотрудники
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЗагружаемыеДанные КАК ЗагружаемыеДанные
		|		ПО Сотрудники.Код = ЗагружаемыеДанные.СотрудникКод
		|			И Сотрудники.Наименование = ЗагружаемыеДанные.СотрудникФИО
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Сотрудники.Ссылка,
		|	ЗагружаемыеДанные.Идентификатор,
		|	1
		|ИЗ Справочник.Сотрудники КАК Сотрудники
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЗагружаемыеДанные КАК ЗагружаемыеДанные
		|		ПО Сотрудники.Наименование = ЗагружаемыеДанные.СотрудникФИО
		|			И ЗагружаемыеДанные.СотрудникКод = """"
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ИдентификаторСтроки";
	КонецЕсли;
	МассивЗапросов.Добавить(ТекстЗапроса);
	
	Если Колонки.Найти("СпособОтражения") = Неопределено Тогда
		ТекстЗапроса =
		"ВЫБРАТЬ ПЕРВЫЕ 0
		|	ЗНАЧЕНИЕ(Справочник.СпособыОтраженияВФинансовомУчете.ПустаяСсылка) КАК Ссылка,
		|	0 КАК ИдентификаторСтроки,
		|	0 КАК Приоритет
		|ПОМЕСТИТЬ СпособыОтраженияСопоставленные";
	Иначе
		ТекстЗапроса =
		"ВЫБРАТЬ
		|	СпособыОтражения.Ссылка КАК Ссылка,
		|	ЗагружаемыеДанные.Идентификатор КАК ИдентификаторСтроки,
		|	1 КАК Приоритет
		|ПОМЕСТИТЬ СпособыОтраженияСопоставленные
		|ИЗ Справочник.СпособыОтраженияВФинансовомУчете КАК СпособыОтражения
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ЗагружаемыеДанные КАК ЗагружаемыеДанные
		|		ПО СпособыОтражения.Наименование = ЗагружаемыеДанные.СпособОтражения
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ИдентификаторСтроки";
	КонецЕсли;
	МассивЗапросов.Добавить(ТекстЗапроса);
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	Таблица.Идентификатор КАК Идентификатор,
	|	МАКСИМУМ(ЕСТЬNULL(Сотрудники.Приоритет, 0)) КАК ПриоритетСотрудников,
	|	МАКСИМУМ(ЕСТЬNULL(СпособыОтражения.Приоритет, 0)) КАК ПриоритетСпособовОтражения
	|ПОМЕСТИТЬ ПриоритетыСопоставления
	|ИЗ ЗагружаемыеДанные КАК Таблица
	|	ЛЕВОЕ СОЕДИНЕНИЕ СотрудникиСопоставленные КАК Сотрудники
	|		ПО Таблица.Идентификатор = Сотрудники.ИдентификаторСтроки
	|	ЛЕВОЕ СОЕДИНЕНИЕ СпособыОтраженияСопоставленные КАК СпособыОтражения
	|		ПО Таблица.Идентификатор = СпособыОтражения.ИдентификаторСтроки
	|
	|СГРУППИРОВАТЬ ПО
	|	Таблица.Идентификатор
	|;
	|
	|ВЫБРАТЬ
	|	Таблица.Идентификатор КАК ИдентификаторСтроки,
	|	МАКСИМУМ(Сотрудники.Ссылка) КАК Сотрудник,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Сотрудники.Ссылка) КАК КоличествоСотрудников,
	|	МАКСИМУМ(СпособыОтражения.Ссылка) КАК СпособОтражения,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ СпособыОтражения.Ссылка) КАК КоличествоСпособовОтражения
	|ПОМЕСТИТЬ СопоставленныеДанные
	|ИЗ ПриоритетыСопоставления КАК Таблица
	|	ЛЕВОЕ СОЕДИНЕНИЕ СотрудникиСопоставленные КАК Сотрудники
	|		ПО Таблица.Идентификатор = Сотрудники.ИдентификаторСтроки
	|		И Таблица.ПриоритетСотрудников = Сотрудники.Приоритет
	|	ЛЕВОЕ СОЕДИНЕНИЕ СпособыОтраженияСопоставленные КАК СпособыОтражения
	|		ПО Таблица.Идентификатор = СпособыОтражения.ИдентификаторСтроки
	|		И Таблица.ПриоритетСпособовОтражения = СпособыОтражения.Приоритет
	|
	|СГРУППИРОВАТЬ ПО
	|	Таблица.Идентификатор";
	
	МассивЗапросов.Добавить(ТекстЗапроса);
	
	ТекстЗапроса =
	"УНИЧТОЖИТЬ ПриоритетыСопоставления;
	|УНИЧТОЖИТЬ СотрудникиСопоставленные;
	|УНИЧТОЖИТЬ СпособыОтраженияСопоставленные";
	
	МассивЗапросов.Добавить(ТекстЗапроса);
	
	Возврат СтрСоединить(МассивЗапросов, ОбщегоНазначения.РазделительПакетаЗапросов());
	
КонецФункции

Функция ТекстЗапросаВыборкиСопоставленныхДанных()
	
	ТекстЗапроса =
	"ВЫБРАТЬ
	|	ВЫБОР
	|		КОГДА СопоставленныеДанные.КоличествоСотрудников = 1
	|			ТОГДА СопоставленныеДанные.Сотрудник
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК Сотрудник,
	|	ВЫБОР
	|		КОГДА СопоставленныеДанные.КоличествоСпособовОтражения = 1
	|			ТОГДА СопоставленныеДанные.СпособОтражения
	|		ИНАЧЕ НЕОПРЕДЕЛЕНО
	|	КОНЕЦ КАК СпособОтражения,
	|	СопоставленныеДанные.КоличествоСотрудников КАК КоличествоСотрудников,
	|	СопоставленныеДанные.КоличествоСпособовОтражения КАК КоличествоСпособовОтражения,
	|	ЗагружаемыеДанные.*
	|ИЗ ЗагружаемыеДанные КАК ЗагружаемыеДанные
	|	ЛЕВОЕ СОЕДИНЕНИЕ СопоставленныеДанные КАК СопоставленныеДанные
	|		ПО ЗагружаемыеДанные.Идентификатор = СопоставленныеДанные.ИдентификаторСтроки";
	
	Возврат ТекстЗапроса;
	
КонецФункции

#КонецОбласти

#Область Печать

// Заполняет список команд печати.
// 
// Параметры:
//   КомандыПечати - ТаблицаЗначений - состав полей см. в функции УправлениеПечатью.СоздатьКоллекциюКомандПечати.
//
Процедура ДобавитьКомандыПечати(КомандыПечати) Экспорт
	
	КомандаПечати = КомандыПечати.Добавить();
	КомандаПечати.Идентификатор = "ПФ_MXL_СправкаОРаспределенииРасходов";
	КомандаПечати.Представление = НСтр("ru = 'Справка о регистрации распределения'");
	КомандаПечати.МенеджерПечати = "Документ.РаспределениеРасходовНаПерсонал";
	КомандаПечати.Обработчик = "УправлениеПечатьюБЗККлиент.ВыполнитьКомандуПечати";
	КомандаПечати.ПроверкаПроведенияПередПечатью = Истина;
	
КонецПроцедуры

// Формирует печатные формы
//
// Параметры:
//  (входные)
//    МассивОбъектов  - Массив    - ссылки на объекты, которые нужно распечатать;
//    ПараметрыПечати - Структура - дополнительные настройки печати;
//  (выходные)
//   КоллекцияПечатныхФорм - ТаблицаЗначений - сформированные табличные документы.
//   ОбъектыПечати         - СписокЗначений  - значение - ссылка на объект;
//                                             представление - имя области в которой был выведен объект;
//   ПараметрыВывода       - Структура       - дополнительные параметры сформированных табличных документов.
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт
	
	Если УправлениеПечатью.НужноПечататьМакет(КоллекцияПечатныхФорм, "ПФ_MXL_СправкаОРаспределенииРасходов") Тогда
		
		УправлениеПечатью.ВывестиТабличныйДокументВКоллекцию(КоллекцияПечатныхФорм,
			"ПФ_MXL_СправкаОРаспределенииРасходов",
			НСтр("ru = 'Справка о регистрации распределения расходов на персонал'"),
			ПечатьСправкиОРаспределенииРасходов(МассивОбъектов, ОбъектыПечати),
			,
			"Документ.РаспределениеРасходовНаПерсонал.ПФ_MXL_СправкаОРаспределенииРасходов");
			
	КонецЕсли;
						
КонецПроцедуры

Функция ПечатьСправкиОРаспределенииРасходов(МассивОбъектов, ОбъектыПечати)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_РаспределениеРасходовНаПерсонал_СправкаОРаспределенииРасходов";
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Макет = УправлениеПечатью.МакетПечатнойФормы("Документ.РаспределениеРасходовНаПерсонал.ПФ_MXL_СправкаОРаспределенииРасходов");
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Запрос.УстановитьПараметр("ПодбираетсяАвтоматически", НСтр("ru = '<подбирается автоматически>'"));
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Сотрудники.Ссылка КАК Ссылка,
	|	Сотрудники.Ссылка.Подразделение КАК Подразделение,
	|	Сотрудники.Ссылка.ДатаНачала КАК ДатаНачала,
	|	Сотрудники.Ссылка.ДатаОкончания КАК ДатаОкончания,
	|	Сотрудники.Ссылка.Ответственный КАК Ответственный,
	|	Сотрудники.Ссылка.СуммарнаяДоляСтоПроцентов КАК СуммарнаяДоляСтоПроцентов,
	|	Сотрудники.Сотрудник КАК Сотрудник,
	|	СтрокиРаспределения.СпособОтражения КАК СпособОтражения,
	|	СтрокиРаспределения.ДоляРаспределения КАК ДоляРаспределения,
	|	Сотрудники.Ссылка.Дата КАК Дата,
	|	Сотрудники.Ссылка.Номер КАК Номер,
	|	Сотрудники.Сотрудник.Наименование КАК СотрудникНаименование,
	|	Сотрудники.НомерСтроки КАК НомерСтроки,
	|	СтрокиРаспределения.НомерСтроки КАК НомерСтрокиРаспределения
	|ИЗ
	|	Документ.РаспределениеРасходовНаПерсонал.Сотрудники КАК Сотрудники
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РаспределениеРасходовНаПерсонал.РаспределениеРасходов КАК СтрокиРаспределения
	|		ПО Сотрудники.ИдентификаторСтрокиСотрудника = СтрокиРаспределения.ИдентификаторСтрокиСотрудника
	|			И Сотрудники.Ссылка = СтрокиРаспределения.Ссылка
	|ГДЕ
	|	Сотрудники.Ссылка В(&МассивОбъектов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка,
	|	НомерСтроки,
	|	НомерСтрокиРаспределения";

	Выборка = Запрос.Выполнить().Выбрать();
	
	ПервыйДокумент = Истина;
	
	ОбластьШапка = Макет.ПолучитьОбласть("Шапка");
	ОбластьЗаголовокТаблицы = Макет.ПолучитьОбласть("ЗаголовокТаблицы");
	ОбластьСтрокаСотрудник = Макет.ПолучитьОбласть("СтрокаСотрудник");
	ОбластьСтрокаРаспределение = Макет.ПолучитьОбласть("СтрокаРаспределение");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");

	ДанныеШапки = Новый Структура("Подразделение,ПериодРегистрации,ДатаДокумента,НомерДокумента");
	ДанныеСтрокаСотрудник = Новый Структура("Номер,Сотрудник,Доля");
	
	Пока Выборка.СледующийПоЗначениюПоля("Ссылка") Цикл
		
		Если Не ПервыйДокумент Тогда
			// Все документы нужно выводить на разных страницах.
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		ДанныеШапки.Подразделение = Выборка.Подразделение;
		ДанныеШапки.ДатаДокумента = Формат(Выборка.Дата, "ДЛФ=D");
		ДанныеШапки.НомерДокумента = ПрефиксацияОбъектовКлиентСервер.НомерНаПечать(Выборка.Номер, Истина, Истина);
		
		Если Не ЗначениеЗаполнено(Выборка.ДатаОкончания) Тогда
			ДатаНачала = Формат(Выборка.ДатаНачала, НСтр("ru='ДФ=''ММММ yyyy'''"));
			ДанныеШапки.ПериодРегистрации = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'с %1 г.'"), СклонениеПредставленийОбъектов.ПросклонятьПредставление(ДатаНачала, 2));
		ИначеЕсли Выборка.ДатаНачала = Выборка.ДатаОкончания Тогда
			ДатаНачала = Формат(Выборка.ДатаНачала, НСтр("ru='ДФ=''ММММ yyyy'''"));
			ДанныеШапки.ПериодРегистрации = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'в %1 г.'"), СклонениеПредставленийОбъектов.ПросклонятьПредставление(ДатаНачала, 6));
		ИначеЕсли Год(Выборка.ДатаНачала) = Год(Выборка.ДатаОкончания) Тогда
			ДатаНачала = Формат(Выборка.ДатаНачала, НСтр("ru='ДФ=''ММММ'''"));
			ДатаОкончания = Формат(Выборка.ДатаОкончания, НСтр("ru='ДФ=''ММММ yyyy'''"));
			ДанныеШапки.ПериодРегистрации = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'с %1 по %2 г.'"),
				СклонениеПредставленийОбъектов.ПросклонятьПредставление(ДатаНачала, 2), ДатаОкончания);
		Иначе
			ДатаНачала = Формат(Выборка.ДатаНачала, НСтр("ru='ДФ=''ММММ yyyy'''"));
			ДатаОкончания = Формат(Выборка.ДатаОкончания, НСтр("ru='ДФ=''ММММ yyyy'''"));
			ДанныеШапки.ПериодРегистрации = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'с %1 г. по %2 г.'"),
				СклонениеПредставленийОбъектов.ПросклонятьПредставление(ДатаНачала, 2), ДатаОкончания);
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(ОбластьШапка.Параметры, ДанныеШапки);
		ТабличныйДокумент.Вывести(ОбластьШапка);
		
		ТабличныйДокумент.Вывести(ОбластьЗаголовокТаблицы);
		
		НомерСтроки = 1;
		Пока Выборка.СледующийПоЗначениюПоля("НомерСтроки") Цикл
			СуммарнаяДоля = 0;
			ДанныеРаспределения = Новый Массив;
			Пока Выборка.Следующий() Цикл
				ДанныеСтрокаРаспределения = Новый Структура("СпособОтражения,Доля");
				ЗаполнитьЗначенияСвойств(ДанныеСтрокаРаспределения, Выборка);
				ДанныеСтрокаРаспределения.Доля = Формат(Выборка.ДоляРаспределения, "ЧЦ=14; ЧДЦ=3");
				ДанныеРаспределения.Добавить(ДанныеСтрокаРаспределения);
				СуммарнаяДоля = СуммарнаяДоля + Выборка.ДоляРаспределения;
			КонецЦикла; 
			
			ДанныеСтрокаСотрудник.Номер = НомерСтроки;
			ДанныеСтрокаСотрудник.Сотрудник = Выборка.Сотрудник;
			ДанныеСтрокаСотрудник.Доля = Формат(СуммарнаяДоля, "ЧЦ=14; ЧДЦ=3");
			ЗаполнитьЗначенияСвойств(ОбластьСтрокаСотрудник.Параметры, ДанныеСтрокаСотрудник);
			ТабличныйДокумент.Вывести(ОбластьСтрокаСотрудник);
			
			Для каждого СтрокаРаспределения Из ДанныеРаспределения Цикл
				ЗаполнитьЗначенияСвойств(ОбластьСтрокаРаспределение.Параметры, СтрокаРаспределения);
				ТабличныйДокумент.Вывести(ОбластьСтрокаРаспределение);
			КонецЦикла;
			
			НомерСтроки = НомерСтроки + 1;
		КонецЦикла;
		
		ТабличныйДокумент.Вывести(ОбластьПодвал);
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, Выборка.Ссылка);
	КонецЦикла;
	
	Возврат ТабличныйДокумент;
	
КонецФункции

#КонецОбласти

#КонецОбласти

#КонецЕсли