	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>~Список.КартинкаСогласования</Field>
				<Field>~Список.Состояние</Field>
				<Field>Список.ЕстьФайлы</Field>
				<Field>Список.ИндексКартинки</Field>
				<Field>Список.ПометкаУдаления</Field>
				<Field>Список.Ссылка</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ЗаявкаНаПодбор.Ссылка КАК Ссылка,
	ЗаявкаНаПодбор.ПометкаУдаления КАК ПометкаУдаления,
	ЗаявкаНаПодбор.Номер КАК Номер,
	ЗаявкаНаПодбор.Дата КАК Дата,
	ЗаявкаНаПодбор.Проведен КАК Проведен,
	ЗаявкаНаПодбор.Позиция КАК Позиция,
	ЗаявкаНаПодбор.Подразделение КАК Подразделение,
	ЗаявкаНаПодбор.Должность КАК Должность,
	ЗаявкаНаПодбор.ПрофильДолжности КАК ПрофильДолжности,
	ЗаявкаНаПодбор.СоответствуетПрофилюДолжности КАК СоответствуетПрофилюДолжности,
	ЗаявкаНаПодбор.Требования КАК Требования,
	ЗаявкаНаПодбор.Обязанности КАК Обязанности,
	ЗаявкаНаПодбор.Условия КАК Условия,
	ЗаявкаНаПодбор.ПредполагаемыйДоход КАК ПредполагаемыйДоход,
	ЗаявкаНаПодбор.ПланируемаяДатаЗакрытия КАК ПланируемаяДатаЗакрытия,
	ЗаявкаНаПодбор.Приоритет КАК Приоритет,
	ЗаявкаНаПодбор.ПричинаОткрытия КАК ПричинаОткрытия,
	ЗаявкаНаПодбор.Ответственный КАК Ответственный,
	ЗаявкаНаПодбор.Комментарий КАК Комментарий,
	ЗаявкаНаПодбор.МоментВремени КАК МоментВремени,
	Вакансии.Ссылка КАК Вакансия,
	СогласованиеВакансий.СостояниеСогласования КАК СостояниеСогласования,
	СогласованиеВакансий.Рассмотрел КАК Рассмотрел,
	СогласованиеВакансий.ДатаРассмотрения КАК ДатаРассмотрения,
	ТекущиеСостоянияВакансий.Состояние КАК СостояниеВакансии,
	ВЫБОР
		КОГДА СогласованиеВакансий.ПометкаУдаления = ИСТИНА
			ТОГДА 4
		ИНАЧЕ ВЫБОР
				КОГДА СогласованиеВакансий.СостояниеСогласования = ЗНАЧЕНИЕ(Перечисление.СостоянияСогласования.Согласовано)
					ТОГДА 0
				КОГДА СогласованиеВакансий.СостояниеСогласования = ЗНАЧЕНИЕ(Перечисление.СостоянияСогласования.Отклонено)
					ТОГДА 1
				ИНАЧЕ ВЫБОР
						КОГДА СогласованиеВакансий.Проведен
								И СогласованиеВакансий.СостояниеСогласования = ЗНАЧЕНИЕ(Перечисление.СостоянияСогласования.Рассматривается)
							ТОГДА 2
						ИНАЧЕ 3
					КОНЕЦ
			КОНЕЦ
	КОНЕЦ КАК ИндексКартинки,
	ВЫБОР
		КОГДА НаличиеФайлов.ЕстьФайлы ЕСТЬ NULL
			ТОГДА 0
		КОГДА НаличиеФайлов.ЕстьФайлы
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ЕстьФайлы
ИЗ
	Документ.ЗаявкаНаПодборПерсонала КАК ЗаявкаНаПодбор
		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СогласованиеВакансий КАК СогласованиеВакансий
		ПО (СогласованиеВакансий.Вакансия = ЗаявкаНаПодбор.Ссылка)}
		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеФайлов
		ПО ЗаявкаНаПодбор.Ссылка = НаличиеФайлов.ОбъектСФайлами}
		{ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Вакансии КАК Вакансии
		ПО (Вакансии.Основание = ЗаявкаНаПодбор.Ссылка)
			И (Вакансии.Ссылка В
				(ВЫБРАТЬ
					МАКСИМУМ(Вакансии.Ссылка)
				ИЗ
					Справочник.Вакансии КАК Вакансии
				ГДЕ
					Вакансии.Основание = ЗаявкаНаПодбор.Ссылка))
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СостоянияВакансий.СрезПоследних КАК ТекущиеСостоянияВакансий
		ПО (ТекущиеСостоянияВакансий.Вакансия = Вакансии.Ссылка)}</QueryText>
				<MainTable>Document.ЗаявкаНаПодборПерсонала</MainTable>
				<ListSettings>
					<dcsset:filter>
						<dcsset:item xsi:type="dcsset:FilterItemComparison">
							<dcsset:use>false</dcsset:use>
							<dcsset:left xsi:type="dcscor:Field">Подразделение</dcsset:left>
							<dcsset:comparisonType>Equal</dcsset:comparisonType>
							<dcsset:userSettingID>b4fbdc5a-3209-41e7-aa86-d61c3cccd7ee</dcsset:userSettingID>
						</dcsset:item>
						<dcsset:item xsi:type="dcsset:FilterItemGroup">
							<dcsset:groupType>AndGroup</dcsset:groupType>
							<dcsset:item xsi:type="dcsset:FilterItemComparison">
								<dcsset:left xsi:type="dcscor:Field">СостояниеВакансии</dcsset:left>
								<dcsset:comparisonType>NotInList</dcsset:comparisonType>
								<dcsset:right xsi:type="dcscor:DesignTimeValue">Перечисление.СостоянияВакансии.Приостановлена</dcsset:right>
								<dcsset:right xsi:type="dcscor:DesignTimeValue">Перечисление.СостоянияВакансии.Закрыта</dcsset:right>
								<dcsset:right xsi:type="dcscor:DesignTimeValue">Перечисление.СостоянияВакансии.Отменена</dcsset:right>
							</dcsset:item>
							<dcsset:userSettingID>ad3cbf1b-cd64-4de5-99ac-1f1ccf1e83fe</dcsset:userSettingID>
							<dcsset:userSettingPresentation xsi:type="xs:string">Только заявки по открытым вакансиям</dcsset:userSettingPresentation>
						</dcsset:item>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>dfcece9d-5077-440b-b6b3-45a5cb4538eb</dcsset:userSettingID>
					</dcsset:filter>
					<dcsset:order>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>88619765-ccb3-46c6-ac52-38e9c992ebd4</dcsset:userSettingID>
					</dcsset:order>
					<dcsset:conditionalAppearance>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>b75fecce-942b-4aed-abc9-e6a02e460fb3</dcsset:userSettingID>
					</dcsset:conditionalAppearance>
					<dcsset:itemsViewMode>Normal</dcsset:itemsViewMode>
					<dcsset:itemsUserSettingID>911b6018-f537-43e8-a417-da56b22f9aec</dcsset:itemsUserSettingID>
				</ListSettings>
			</Settings>
