&НаСервере
Процедура ОбработатьСообщенияПользователю() Экспорт
	
	Сообщения = ПолучитьСообщенияПользователю(Ложь);
	
	Для Каждого Сообщение Из Сообщения Цикл
		Если СтрНайти(Сообщение.Поле, "ПериодВзаиморасчетов") Тогда
			Сообщение.Поле = "";
			Сообщение.ПутьКДанным = "ПериодРегистрацииСтрокой";
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПриПолученииДанныхНаСервере() Экспорт
	
	ПериодВзаиморасчетовВедомости = Объект.ПериодВзаиморасчетов;
	
	ТЗПрочиеВыплаты = Объект.ПрочиеВыплаты.Выгрузить(, "ФизическоеЛицо, ПериодВзаиморасчетов, Сумма, НомерСтроки");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ПрочиеВыплаты", ТЗПрочиеВыплаты);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПрочиеВыплаты.ФизическоеЛицо,
	|	ПрочиеВыплаты.ПериодВзаиморасчетов,
	|	ПрочиеВыплаты.Сумма,
	|	ПрочиеВыплаты.НомерСтроки
	|ПОМЕСТИТЬ ВТ_ПрочиеВыплаты
	|ИЗ
	|	&ПрочиеВыплаты КАК ПрочиеВыплаты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПрочиеВыплаты.ФизическоеЛицо КАК ФизическоеЛицо,
	|	ПрочиеВыплаты.ПериодВзаиморасчетов КАК ПериодВзаиморасчетов,
	|	СУММА(ПрочиеВыплаты.Сумма) КАК Сумма,
	|	МИНИМУМ(ПрочиеВыплаты.НомерСтроки) КАК НомерСтроки
	|ИЗ
	|	ВТ_ПрочиеВыплаты КАК ПрочиеВыплаты
	|
	|СГРУППИРОВАТЬ ПО
	|	ПрочиеВыплаты.ФизическоеЛицо,
	|	ПрочиеВыплаты.ПериодВзаиморасчетов
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки
	|ИТОГИ
	|	СУММА(Сумма)
	|ПО
	|	ФизическоеЛицо";
		
	ВыборкаПоФизическомуЛицу = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	СоставТЗ = Новый ТаблицаЗначений;
	СоставТЗ.Колонки.Добавить("ФизическоеЛицо");
	СоставТЗ.Колонки.Добавить("Сумма");
	СоставТЗ.Колонки.Добавить("Расшифровка");
	
	Пока ВыборкаПоФизическомуЛицу.Следующий() Цикл
		
		СоставСтрока = СоставТЗ.Добавить();
		СоставСтрока.ФизическоеЛицо = ВыборкаПоФизическомуЛицу.ФизическоеЛицо;
		СоставСтрока.Сумма 			= ВыборкаПоФизическомуЛицу.Сумма;
		
		Выборка = ВыборкаПоФизическомуЛицу.Выбрать();
		ПредставлениеПериодов = "";
		Индекс = 1;
		Пока Выборка.Следующий() Цикл
			Если Выборка.ПериодВзаиморасчетов = ПериодВзаиморасчетовВедомости Тогда
				// период ведомости в комментарий не включаем
				Продолжить;
			КонецЕсли;
			
			ПредставлениеПериодов = ПредставлениеПериодов + ?(Индекс = 1, "", ", ") 
					+ НРег(ЗарплатаКадрыКлиентСервер.ПолучитьПредставлениеМесяца(Выборка.ПериодВзаиморасчетов));
			
			Если Индекс = 3 Тогда
				ПредставлениеПериодов = ПредставлениеПериодов + "...";
				Прервать;
			КонецЕсли;
			
			Индекс = Индекс + 1;
		КонецЦикла;
		
		Если ЗначениеЗаполнено(ПредставлениеПериодов) Тогда
			РасшифровкаПериодов = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'в т.ч. за %1'"), ПредставлениеПериодов); 
		Иначе
			РасшифровкаПериодов = ""; 
		КонецЕсли;
		
		СоставСтрока.Расшифровка = "";
		Если ЗначениеЗаполнено(РасшифровкаПериодов) Тогда
			СоставСтрока.Расшифровка = СоставСтрока.Расшифровка + РасшифровкаПериодов
		КонецЕсли;
		
	КонецЦикла;  
	
	Состав.Загрузить(СоставТЗ);	
	
	УстановитьДоступностьЭлементов();
	УстановитьПредставлениеОплаты();
	
КонецПроцедуры

&НаКлиенте
Процедура РедактироватьПрочиеВыплатыСтроки(ДанныеСтроки) Экспорт
	
	Если ДанныеСтроки = Неопределено Тогда
		Возврат
	КонецЕсли;
	
	ПараметрыОткрытия = Новый Структура;
	
	ПараметрыОткрытия.Вставить("Организация",			Объект.Организация);
	ПараметрыОткрытия.Вставить("ПериодВзаиморасчетов",	Объект.ПериодВзаиморасчетов);
	ПараметрыОткрытия.Вставить("ФизическоеЛицо", 		ДанныеСтроки.ФизическоеЛицо);
	
	ПараметрыОткрытия.Вставить("АдресВХранилищеПрочиеВыплатыПоСтроке", АдресВХранилищеПрочиеВыплатыПоСтроке(ДанныеСтроки.ФизическоеЛицо));
	
	ПараметрыОткрытия.Вставить("ТолькоПросмотр",		ЭтаФорма.ТолькоПросмотр);
	
	Оповещение = Новый ОписаниеОповещения("ВедомостьРедактироватьПрочиеВыплатыСтрокиЗавершение", ЭтотОбъект);
	ОткрытьФорму("Документ.ВедомостьНаПеречислениеПрочихВыплат.Форма.РедактированиеСтрокиВедомости", ПараметрыОткрытия, ЭтаФорма, , , , Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ВедомостьРедактироватьПрочиеВыплатыСтрокиЗавершение(РезультатыРедактирования, ДополнительныеПараметры) Экспорт
	
	Если РезультатыРедактирования <> Неопределено И РезультатыРедактирования.Модифицированность Тогда
		РедактироватьПрочиеВыплатыСтрокиЗавершениеНаСервере(РезультатыРедактирования);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура РедактироватьПрочиеВыплатыСтрокиЗавершениеНаСервере(РезультатыРедактирования) Экспорт
	
	ФизическоеЛицо = РезультатыРедактирования.ФизическоеЛицо;
	
	УдаляемыеСтроки = Объект.ПрочиеВыплаты.НайтиСтроки(Новый Структура("ФизическоеЛицо", ФизическоеЛицо));
	Для Каждого УдаляемаяСтрока Из УдаляемыеСтроки Цикл
		Объект.ПрочиеВыплаты.Удалить(УдаляемаяСтрока);
	КонецЦикла;	
	
	ПрочиеВыплатыСтроки = ПолучитьИзВременногоХранилища(РезультатыРедактирования.АдресВХранилищеПрочиеВыплатыПоСтроке);

	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ПрочиеВыплатыСтроки, Объект.ПрочиеВыплаты);

	ПриПолученииДанныхНаСервере();
		
	Модифицированность = Истина;

КонецПроцедуры

&НаСервере
Процедура УстановитьПредставлениеОплаты() Экспорт
	
	ОплатыПредставление = ПредставлениеОплаты();
	
КонецПроцедуры

&НаСервере
Функция ПредставлениеОплаты()  
	
	Если ОплатыСписок.Количество() = 0 Тогда
		
		ПредставлениеОплаты = Новый ФорматированнаяСтрока(НСтр("ru = 'Выплаты по ведомости не выполнялись'"));
		
	ИначеЕсли ОплатыСписок.Количество() = 1 Тогда	
		
		ПредставлениеДокумента = 
			НРег(Лев(ОплатыСписок[0], 1))
			+ Сред(ОплатыСписок[0], 2, СтрНайти(ОплатыСписок[0], " - ") - 2);
			
		ПредставлениеОплаты = Новый ФорматированнаяСтрока(
			НСтр("ru = 'Выплата по ведомости выполнена документом'"),
			" ",
			Новый ФорматированнаяСтрока(ПредставлениеДокумента, , , , "ссылка"));
		
	Иначе
		
		ПредставлениеОплаты = Новый ФорматированнаяСтрока(
			НСтр("ru = 'Выплаты по ведомости:'"),
			" ",
			Новый ФорматированнаяСтрока(
				НРег(ЧислоПрописью(ОплатыСписок.Количество(),,НСтр("ru = 'документ, документа, документов, м, ,,,,0'"))),
				, , , "ссылка"));
				
			КонецЕсли;	
	
	Возврат ПредставлениеОплаты
	
КонецФункции

&НаСервере
Процедура УстановитьДоступностьЭлементов(ПереопределитьТолькоПросмотрФормы = Ложь) Экспорт
	
	ТаблицаОплатыПоВедомости = ОплатыПоВедомости();
	
	ОплатыСписок.Очистить();
	
	Для Каждого СтрокаОплаты Из ТаблицаОплатыПоВедомости Цикл
		ОплатыСписок.Добавить(СтрокаОплаты.Ссылка, СтрокаОплаты.ПредставлениеСсылки);
	КонецЦикла;
	
	Если ПереопределитьТолькоПросмотрФормы Тогда
		ЭтаФорма.ТолькоПросмотр = ОплатыСписок.Количество() > 0;
	Иначе
		ЭтаФорма.ТолькоПросмотр = ЭтаФорма.ТолькоПросмотр ИЛИ ОплатыСписок.Количество() > 0;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура СоставПослеУдаленияНаСервере()
	
	Для Каждого ФизическоеЛицо Из ФизическиеЛица Цикл
		
		УдаляемыеСтроки = Объект.ПрочиеВыплаты.НайтиСтроки(Новый Структура("ФизическоеЛицо", ФизическоеЛицо));
		Для Каждого УдаляемаяСтрока Из УдаляемыеСтроки Цикл
			Объект.ПрочиеВыплаты.Удалить(УдаляемаяСтрока);
		КонецЦикла;	
		
	КонецЦикла
	
КонецПроцедуры

&НаСервере
Функция АдресСпискаПодобранныхФизическихЛиц() Экспорт
	Возврат ПоместитьВоВременноеХранилище(Объект.ПрочиеВыплаты.Выгрузить(,"ФизическоеЛицо").ВыгрузитьКолонку("ФизическоеЛицо"), УникальныйИдентификатор);
КонецФункции

&НаСервере
Функция АдресВХранилищеПрочиеВыплатыПоСтроке(ФизическоеЛицо) Экспорт
	Возврат ПоместитьВоВременноеХранилище(Объект.ПрочиеВыплаты.Выгрузить(Новый Структура("ФизическоеЛицо", ФизическоеЛицо)), УникальныйИдентификатор);
КонецФункции	

&НаСервере
Функция ОплатыПоВедомости() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("Ведомость", Объект.Ссылка);
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьВнешниеХозяйственныеОперацииЗарплатаКадры") Тогда 
		
		Документ = "ПлатежноеПоручение";
		ТабличнаяЧасть = "ВедомостиПрочие";
		
	Иначе
		
		Документ = "СписаниеБезналичныхДенежныхСредств";
		ТабличнаяЧасть = "РасшифровкаПлатежа";
		
	КонецЕсли;
	
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ОплатаВедомостей.Ссылка КАК Ссылка,
	|	ОплатаВедомостей.Ссылка.Представление КАК ПредставлениеСсылки
	|ИЗ
	|	Документ.ВедомостьНаВозвратПрочихВыплат КАК ОплатаВедомостей
	|ГДЕ
	|	ОплатаВедомостей.ДокументОснование = &Ведомость
	|	И ОплатаВедомостей.Проведен
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ ПЕРВЫЕ 1
	|	ОплатаВедомостей.Ссылка,
	|	Документ.Ссылка.Представление
	|ИЗ
	|	Документ." + Документ + "." + ТабличнаяЧасть + " КАК ОплатаВедомостей
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ." + Документ + " КАК Документ
	|		ПО Документ.Ссылка = ОплатаВедомостей.Ссылка
	|ГДЕ
	|	ОплатаВедомостей.Ведомость = &Ведомость
	|	И Документ.Проведен";
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции	

&НаСервере
Процедура ВедомостьДополнитьНаСервере(ФизическиеЛицаМассив) Экспорт
	
	ТекущийОбъект = РеквизитФормыВЗначение("Объект");
	
	Если ТекущийОбъект.МожноЗаполнитьПрочиеВыплаты() Тогда
		ТекущийОбъект.ДополнитьПрочиеВыплаты(ФизическиеЛицаМассив);
	КонецЕсли;

	ОбработатьСообщенияПользователю();
	
	ЗначениеВРеквизитФормы(ТекущийОбъект, "Объект");
	
	ПриПолученииДанныхНаСервере();	
	
КонецПроцедуры

&НаСервере
Процедура ПодобратьНаСервере() Экспорт
	
	ТекущийОбъект = РеквизитФормыВЗначение("Объект");
	Если НЕ ТекущийОбъект.МожноЗаполнитьПрочиеВыплаты() Тогда
		  Возврат		
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПервоначальныеЗначения() Экспорт
	
	ЗначенияДляЗаполнения = Новый Структура;
	Для Каждого ЗначениеДляЗаполнения Из ВедомостьЗначенияДляЗаполненияОтветственныхЛиц() Цикл
		ЗначенияДляЗаполнения.Вставить(ЗначениеДляЗаполнения.Ключ, ЗначениеДляЗаполнения.Значение);
	КонецЦикла;	
	ЗначенияДляЗаполнения.Вставить("ПредыдущийМесяц",	"Объект.ПериодВзаиморасчетов");
	ЗначенияДляЗаполнения.Вставить("Организация",		"Объект.Организация");
	ЗначенияДляЗаполнения.Вставить("Ответственный",		"Объект.Ответственный");
	
	ЗарплатаКадры.ЗаполнитьПервоначальныеЗначенияВФорме(ЭтаФорма, ЗначенияДляЗаполнения);
	
	Если НЕ ПолучитьФункциональнуюОпцию("ВыполнятьРасчетЗарплатыПоПодразделениям") Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьРеквизитФормыПоПути(ЭтаФорма, "Объект.Подразделение", Справочники.ПодразделенияОрганизаций.ПустаяСсылка());
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ВедомостьЗначенияДляЗаполненияОтветственныхЛиц()Экспорт
	
	МенеджерВедомости = ОбщегоНазначения.МенеджерОбъектаПоСсылке(Объект.Ссылка);
	РеквизитыОтветственныхЛиц = МенеджерВедомости.РеквизитыОтветственныхЛиц();
	
	ЗначенияДляЗаполнения = Новый Структура;
	Для Каждого Реквизит Из РеквизитыОтветственныхЛиц Цикл
		ПутьРеквизита = "Объект." + Реквизит;
		ЗначенияДляЗаполнения.Вставить(Реквизит, ПутьРеквизита);
	КонецЦикла;
	
	Возврат ЗначенияДляЗаполнения
	
КонецФункции

