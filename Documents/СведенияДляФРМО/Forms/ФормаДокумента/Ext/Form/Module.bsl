#Область ОписаниеПеременных

&НаКлиенте
Перем ПараметрыОбработчикаОжидания;

&НаКлиенте
Перем ФормаДлительнойОперации;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Ключ.Пустая() Тогда
		
		ЗапрашиваемыеЗначения = Новый Структура;
		ЗапрашиваемыеЗначения.Вставить("Организация", "Объект.Организация");
		ЗапрашиваемыеЗначения.Вставить("Ответственный", "Объект.Ответственный");
		
		ЗарплатаКадры.ЗаполнитьПервоначальныеЗначенияВФорме(ЭтаФорма, ЗапрашиваемыеЗначения);
		
		ЗаполнитьНастройкиОрганизацииНаСервере();
		
		ПриПолученииДанныхНаСервере();
	Иначе
		НастройкиОрганизации = МедицинскиеРегистры.ПолучитьНастройкиОрганизации(Объект.Организация);
		Сертификат = НастройкиОрганизации.Сертификат;
		ИдентификаторИнформационнойСистемы = НастройкиОрганизации.ИдентификаторИнформационнойСистемы;
	КонецЕсли;
	
	ЗаполнитьИсточникиИзмененийШтатногоРасписания();
	
	
	
	// Обработчик подсистемы "ВерсионированиеОбъектов".
	ВерсионированиеОбъектов.ПриСозданииНаСервере(ЭтаФорма);
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКоманды.ПриСозданииНаСервере(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// СтандартныеПодсистемы.Свойства
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяЭлементаДляРазмещения", "ГруппаДополнительныеРеквизиты");
	УправлениеСвойствами.ПриСозданииНаСервере(ЭтотОбъект, ДополнительныеПараметры);
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьИсточникиИзмененийШтатногоРасписания()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ИзменениеШтатногоРасписания.ДатаВступленияВСилу КАК ДатаНачалаДействия,
	|	ЕСТЬNULL(ИдентификаторыОбъектовДляФедеральныхМедрегистров.МоментВыгрузки, ДАТАВРЕМЯ(1, 1, 1)) <= ЕСТЬNULL(ИдентификаторыОбъектовДляФедеральныхМедрегистров.МоментИзменения, ДАТАВРЕМЯ(1, 1, 1)) КАК ТребуетВыгрузки
	|ПОМЕСТИТЬ ВТДатыНачалаДействия
	|ИЗ
	|	Документ.ИзменениеШтатногоРасписания КАК ИзменениеШтатногоРасписания
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИдентификаторыОбъектовДляФедеральныхМедрегистров КАК ИдентификаторыОбъектовДляФедеральныхМедрегистров
	|		ПО (ИдентификаторыОбъектовДляФедеральныхМедрегистров.Объект = ЗНАЧЕНИЕ(Документ.УтверждениеШтатногоРасписания.ПустаяСсылка))
	|			И (ИдентификаторыОбъектовДляФедеральныхМедрегистров.ДатаСобытия = ИзменениеШтатногоРасписания.ДатаВступленияВСилу)
	|ГДЕ
	|	ИзменениеШтатногоРасписания.Проведен
	|	И ИзменениеШтатногоРасписания.Организация = &Организация
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	УтверждениеШтатногоРасписания.МесяцВступленияВСилу,
	|	ЕСТЬNULL(ИдентификаторыОбъектовДляФедеральныхМедрегистров.МоментВыгрузки, ДАТАВРЕМЯ(1, 1, 1)) <= ЕСТЬNULL(ИдентификаторыОбъектовДляФедеральныхМедрегистров.МоментИзменения, ДАТАВРЕМЯ(1, 1, 1))
	|ИЗ
	|	Документ.УтверждениеШтатногоРасписания КАК УтверждениеШтатногоРасписания
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИдентификаторыОбъектовДляФедеральныхМедрегистров КАК ИдентификаторыОбъектовДляФедеральныхМедрегистров
	|		ПО (ИдентификаторыОбъектовДляФедеральныхМедрегистров.Объект = ЗНАЧЕНИЕ(Документ.УтверждениеШтатногоРасписания.ПустаяСсылка))
	|			И (ИдентификаторыОбъектовДляФедеральныхМедрегистров.ДатаСобытия = УтверждениеШтатногоРасписания.МесяцВступленияВСилу)
	|ГДЕ
	|	УтверждениеШтатногоРасписания.Проведен
	|	И УтверждениеШтатногоРасписания.Организация = &Организация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВТДатыНачалаДействия.ДатаНачалаДействия КАК ДатаНачалаДействия,
	|	ВТДатыНачалаДействия.ТребуетВыгрузки КАК ТребуетВыгрузки
	|ИЗ
	|	ВТДатыНачалаДействия КАК ВТДатыНачалаДействия
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаНачалаДействия
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТДатыНачалаДействия";
	
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	ВсеИзменения = Запрос.Выполнить().Выгрузить();
	Источники.Очистить();
	КоличествоДокументов = ВсеИзменения.Количество();
	ДатаОкончания = Дата('21000101');
	Для ТекущийНомер = (1 - КоличествоДокументов) По 0 Цикл 
		Изменение = ВсеИзменения[-ТекущийНомер];
		Если Изменение.ТребуетВыгрузки Или Изменение.ДатаНачалаДействия=Объект.ДатаНачалаДействия Тогда 
			НовыйИсточник = Источники.Добавить();
			НовыйИсточник.ДатаНачалаДействия = Изменение.ДатаНачалаДействия;
			НовыйИсточник.ДатаОкончанияДействия = НачалоДня(НачалоДня(ДатаОкончания) - 1);
		КонецЕсли;
		ДатаОкончания = Изменение.ДатаНачалаДействия;
	КонецЦикла;
	Элементы.ДатаНачалаДействияИзмененийШтатногоРасписания.СписокВыбора.Очистить();
	Элементы.ДатаНачалаДействияИзмененийШтатногоРасписания.СписокВыбора.ЗагрузитьЗначения(Источники.Выгрузить(, "ДатаНачалаДействия").ВыгрузитьКолонку("ДатаНачалаДействия"));

КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	ЗаполнитьМоментВыгрузки(Объект.ДатаНачалаДействия);
	
	// СтандартныеПодсистемы.ДатыЗапретаИзменения
	ДатыЗапретаИзменения.ОбъектПриЧтенииНаСервере(ЭтаФорма, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.ДатыЗапретаИзменения 
	
	ПриПолученииДанныхНаСервере();
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// СтандартныеПодсистемы.УправлениеДоступом
	УправлениеДоступом.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.УправлениеДоступом
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПриЧтенииНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	// СтандартныеПодсистемы.ПодключаемыеКоманды
	ПодключаемыеКомандыКлиент.НачатьОбновлениеКоманд(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.ПодключаемыеКоманды
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	// СтандартныеПодсистемы.Свойства
	Если УправлениеСвойствамиКлиент.ОбрабатыватьОповещения(ЭтотОбъект, ИмяСобытия, Параметр) Тогда
		ОбновитьЭлементыДополнительныхРеквизитов();
		УправлениеСвойствамиКлиент.ПослеЗагрузкиДополнительныхРеквизитов(ЭтотОбъект);
	КонецЕсли;
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры
	
&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ПередЗаписьюНаСервере(ЭтотОбъект, ТекущийОбъект);
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры
	
&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	// СтандартныеПодсистемы.Свойства
	УправлениеСвойствами.ОбработкаПроверкиЗаполнения(ЭтотОбъект, Отказ, ПроверяемыеРеквизиты);
	// Конец СтандартныеПодсистемы.Свойства
	
КонецПроцедуры
	
&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	
	// СтандартныеПодсистемы.УправлениеДоступом
	УправлениеДоступом.ПослеЗаписиНаСервере(ЭтотОбъект, ТекущийОбъект, ПараметрыЗаписи);
	// Конец СтандартныеПодсистемы.УправлениеДоступом
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ДатаНачалаДействияИзмененийШтатногоРасписанияПриИзменении(Элемент)
	Объект.ШтатныеЕдиницы.Очистить();
	Объект.ВыгрузкаПроведена = Ложь;
	ЗаполнитьДанныеШтатногоРасписанияНаСервере(Объект.ДатаНачалаДействия);
	ЗаполнитьНаКлиенте();
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДанныеШтатногоРасписанияНаСервере(ВыбраннаяДатаНачалаДействия)
	
	ОтобранныеСтрокиШР = Источники.НайтиСтроки(Новый Структура("ДатаНачалаДействия", ВыбраннаяДатаНачалаДействия));
	Если ОтобранныеСтрокиШР.Количество()>0 Тогда 
		ТекущиеДанныеШР = ОтобранныеСтрокиШР[0];
		Объект.НомерШтатногоРасписания = Формат(ТекущиеДанныеШР.ДатаНачалаДействия, "ДФ='ггггММдд'");
		Объект.ДатаУтверждения = ТекущиеДанныеШР.ДатаНачалаДействия;
		Объект.ДатаОкончанияДействия = ТекущиеДанныеШР.ДатаОкончанияДействия;
	КонецЕсли;
	
	ЗаполнитьМоментВыгрузки(ВыбраннаяДатаНачалаДействия);
	
КонецПроцедуры 

&НаСервере
Процедура ЗаполнитьМоментВыгрузки(ДатаНачалаДействия)
	
	МоментВыгрузки = Дата('00010101');
	МоментВыгрузкиТекст = НСтр("ru = 'Выгрузка не проводилась'");
	
	Если ЗначениеЗаполнено(ДатаНачалаДействия) Тогда 
		Набор = РегистрыСведений.ИдентификаторыОбъектовДляФедеральныхМедрегистров.СоздатьНаборЗаписей();
		Набор.Отбор.Объект.Установить(Документы.УтверждениеШтатногоРасписания.ПустаяСсылка());
		Набор.Отбор.ДатаСобытия.Установить(ДатаНачалаДействия);
		Набор.Прочитать();
		Если Набор.Количество()>0 Тогда
			МоментВыгрузки = Набор[0].МоментВыгрузки;
			МоментВыгрузкиТекст = СтрШаблон(НСтр("ru = 'Выгрузка проводилась %1'"), МоментВыгрузки);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры 

&НаКлиенте
Процедура ОрганизацияПриИзменении(Элемент)
	ЗарплатаКадрыКлиент.КлючевыеРеквизитыЗаполненияФормыОчиститьТаблицы(ЭтаФорма);
	ЗаполнитьНастройкиОрганизацииНаКлиенте();
	ЗаполнитьИсточникиИзмененийШтатногоРасписания();
КонецПроцедуры

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	ЗарплатаКадрыКлиент.КлючевыеРеквизитыЗаполненияФормыОчиститьТаблицы(ЭтаФорма);
	ЗаполнитьИсточникиИзмененийШтатногоРасписания();
КонецПроцедуры

&НаКлиенте
Процедура СертификатПриИзменении(Элемент)
	СертификатПриИзмененииНаСервере(Объект.Организация, Сертификат);
КонецПроцедуры

#КонецОбласти

