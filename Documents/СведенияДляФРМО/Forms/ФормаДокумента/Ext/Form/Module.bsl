// СтандартныеПодсистемы.Свойства
&НаКлиенте
Процедура Подключаемый_СвойстваВыполнитьКоманду(ЭлементИлиКоманда, НавигационнаяСсылка = Неопределено, СтандартнаяОбработка = Неопределено)
	УправлениеСвойствамиКлиент.ВыполнитьКоманду(ЭтотОбъект, ЭлементИлиКоманда, СтандартнаяОбработка);
КонецПроцедуры
// Конец СтандартныеПодсистемы.Свойства

// СтандартныеПодсистемы.ПодключаемыеКоманды
&НаКлиенте
Процедура Подключаемый_ВыполнитьКоманду(Команда)
	ПодключаемыеКомандыКлиент.ВыполнитьКоманду(ЭтотОбъект, Команда, Объект);
КонецПроцедуры

&НаСервере
Процедура Подключаемый_ВыполнитьКомандуНаСервере(Контекст, Результат) Экспорт
	ПодключаемыеКоманды.ВыполнитьКоманду(ЭтотОбъект, Контекст, Объект, Результат);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ОбновитьКоманды()
	ПодключаемыеКомандыКлиентСервер.ОбновитьКоманды(ЭтотОбъект, Объект);
КонецПроцедуры
// Конец СтандартныеПодсистемы.ПодключаемыеКоманды

&НаКлиенте
Процедура ВыгрузитьВФРМО(Команда)
	ОчиститьСообщения();
	ВыгрузитьВФРМОНаКлиенте();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// СтандартныеПодсистемы.Свойства 
&НаСервере
Процедура ОбновитьЭлементыДополнительныхРеквизитов()
	УправлениеСвойствами.ОбновитьЭлементыДополнительныхРеквизитов(ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЗависимостиДополнительныхРеквизитов()
	УправлениеСвойствамиКлиент.ОбновитьЗависимостиДополнительныхРеквизитов(ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПриИзмененииДополнительногоРеквизита(Элемент)
	УправлениеСвойствамиКлиент.ОбновитьЗависимостиДополнительныхРеквизитов(ЭтотОбъект);
КонецПроцедуры
// Конец СтандартныеПодсистемы.Свойства

#Область ЗаполнениеДокумента

&НаСервереБезКонтекста
Процедура СертификатПриИзмененииНаСервере(Организация, Сертификат = Неопределено)
	
	Если Не ЗначениеЗаполнено(Организация) Или Не ЗначениеЗаполнено(Сертификат) Тогда
		Возврат;
	КонецЕсли;
	
	НастройкиОрганизации = МедицинскиеРегистры.СоздатьПустыеНастройкиОрганизации();
	НастройкиОрганизации.Сертификат = Сертификат;
	
	МедицинскиеРегистры.СохранитьНастройкиОрганизации(Организация, НастройкиОрганизации);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНастройкиОрганизацииНаСервере()
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		НастройкиОрганизации = ПрочитатьНастройкиОрганизации(Объект.Организация);
		Объект.УИНОрганизации = НастройкиОрганизации.ИдентификаторДляМедрегистров;
		Сертификат = НастройкиОрганизации.Сертификат;
		ИдентификаторИнформационнойСистемы = НастройкиОрганизации.ИдентификаторИнформационнойСистемы;
	КонецЕсли;
КонецПроцедуры 

&НаКлиенте
Процедура ЗаполнитьНастройкиОрганизацииНаКлиенте()
	Если ЗначениеЗаполнено(Объект.Организация) Тогда
		НастройкиОрганизации = ПрочитатьНастройкиОрганизации(Объект.Организация);
		Объект.УИНОрганизации = НастройкиОрганизации.ИдентификаторДляМедрегистров;
		Сертификат = НастройкиОрганизации.Сертификат;
		ИдентификаторИнформационнойСистемы = НастройкиОрганизации.ИдентификаторИнформационнойСистемы;
	КонецЕсли;
КонецПроцедуры 

&НаСервереБезКонтекста
Функция ПрочитатьНастройкиОрганизации(Организация)
	Возврат МедицинскиеРегистры.ПолучитьНастройкиОрганизации(Организация)
КонецФункции 

&НаКлиенте
Процедура ЗаполнитьНаКлиенте()

	Результат = РезультатЗаполненияВДлительнойОперации();
	
	Если Результат.ЗаданиеВыполнено Тогда
		
		ОповеститьОбИзменении(Объект.Ссылка);
		
	Иначе
		
		ИдентификаторЗадания = Результат.ИдентификаторЗадания;
		АдресХранилища		 = Результат.АдресХранилища;
		
		ДлительныеОперацииКлиент.ИнициализироватьПараметрыОбработчикаОжидания(ПараметрыОбработчикаОжидания);
		ПодключитьОбработчикОжидания("Подключаемый_ПроверитьВыполнениеЗадания", 1, Истина);
		ФормаДлительнойОперации = ДлительныеОперацииКлиент.ОткрытьФормуДлительнойОперации(ЭтаФорма, ИдентификаторЗадания);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция РезультатЗаполненияВДлительнойОперации()
	
	ПараметрыЗаполнения = Новый Структура("ДанныеДляЗаполнения,Организация,ДатаАктуальности");
	ПараметрыЗаполнения.Организация = Объект.Организация;
	ПараметрыЗаполнения.ДатаАктуальности = Объект.ДатаНачалаДействия;
	
	НаименованиеЗадания = НСтр("ru = 'Заполнение документа ""Сведения для ФРМО""'");
	
	Результат = ДлительныеОперации.ЗапуститьВыполнениеВФоне(
		УникальныйИдентификатор,
		"Документы.СведенияДляФРМО.ПодготовитьДанныеДляЗаполнения",
		ПараметрыЗаполнения,
		НаименованиеЗадания);
	
	АдресХранилища = Результат.АдресХранилища;
	
	Если Результат.ЗаданиеВыполнено Тогда
		ЗаполнениеПослеВыполненияДлительнойОперации();
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура ЗаполнениеПослеВыполненияДлительнойОперации()
	
	ДокументОбъект = РеквизитФормыВЗначение("Объект");
	ДокументОбъект.ЗаполнитьИзХранилища(АдресХранилища);
	ЗначениеВРеквизитФормы(ДокументОбъект,"Объект");
	
	ЗарплатаКадрыКлиентСервер.КлючевыеРеквизитыЗаполненияФормыУстановитьОтображениеПредупреждения(ЭтаФорма);
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПроверитьВыполнениеЗадания()
	
	Попытка
		Если ФормаДлительнойОперации.Открыта() 
			И ФормаДлительнойОперации.ИдентификаторЗадания = ИдентификаторЗадания Тогда
			
			Если ЗаданиеВыполнено(ИдентификаторЗадания) Тогда
				ЗаполнениеПослеВыполненияДлительнойОперации();
				ДлительныеОперацииКлиент.ЗакрытьФормуДлительнойОперации(ФормаДлительнойОперации);
			Иначе
				ДлительныеОперацииКлиент.ОбновитьПараметрыОбработчикаОжидания(ПараметрыОбработчикаОжидания);
				ПодключитьОбработчикОжидания(
					"Подключаемый_ПроверитьВыполнениеЗадания",
					ПараметрыОбработчикаОжидания.ТекущийИнтервал,
					Истина);
			КонецЕсли;
				
		КонецЕсли;
		
	Исключение
		
		ДлительныеОперацииКлиент.ЗакрытьФормуДлительнойОперации(ФормаДлительнойОперации);
		
		СообщенияПользователю = СообщенияФоновогоЗадания(ИдентификаторЗадания);
		Если СообщенияПользователю <> Неопределено Тогда
			
			Для Каждого СообщениеФоновогоЗадания Из СообщенияПользователю Цикл
				СообщениеФоновогоЗадания.Сообщить();
			КонецЦикла;
			
		КонецЕсли;
		
		ВызватьИсключение;
		
	КонецПопытки;
	
	ОповеститьОбИзменении(Объект.Ссылка);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗаданиеВыполнено(ИдентификаторЗадания)
	
	Возврат ДлительныеОперации.ЗаданиеВыполнено(ИдентификаторЗадания);
	
КонецФункции

&НаСервереБезКонтекста
Функция СообщенияФоновогоЗадания(ИдентификаторЗадания)
	
	СообщенияПользователю = Новый Массив;
	ФоновоеЗадание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(ИдентификаторЗадания);
	Если ФоновоеЗадание <> Неопределено Тогда
		СообщенияПользователю = ФоновоеЗадание.ПолучитьСообщенияПользователю();
	КонецЕсли;
	
	Возврат СообщенияПользователю;
	
КонецФункции

#КонецОбласти

#Область ВыгрузкаВФРМО

&НаКлиенте
Процедура ВыгрузитьВФРМОНаКлиенте() 
	
	Если Модифицированность Тогда
		Если Не Записать() Тогда
			Возврат;
		КонецЕсли;
	КонецЕсли;	
	
	Идентификатор = Неопределено;
	КонфликтующееШтатноеРасписаниеФРМО = Неопределено;
	ПараметрыСервиса = ПараметрыСервиса();
	ПараметрыВызова = GetOrgStaff(Объект.УИНОрганизации);
	ТокенДоступа = ТокенДоступа(ПараметрыСервиса);
	ОтветСервиса = ВызватьМетод(ТокенДоступа, ПараметрыВызова);
	Если ОтветСервиса.КодСостояния<400 Тогда 
		Если ТипЗнч(ОтветСервиса.Контент)=Тип("Массив") Тогда
			Для Каждого ШтатноеРасписаниеФРМО Из ОтветСервиса.Контент Цикл 
				ИдентификаторФРМО = ШтатноеРасписаниеФРМО.staffId;
				ДатаНачалаДействияФРМО = МедицинскиеРегистрыКлиент.ДатаИзUTC(ШтатноеРасписаниеФРМО.beginDate);
				ДатаОкончанияДействияФРМО = МедицинскиеРегистрыКлиент.ДатаИзUTC(ШтатноеРасписаниеФРМО.endDate);
				Если ДатаНачалаДействияФРМО=Объект.ДатаНачалаДействия Тогда
					Идентификатор = ИдентификаторФРМО;
					ЗаписатьРезультатВыгрузки(Объект.ДатаНачалаДействия, Идентификатор, Неопределено, Неопределено);
				ИначеЕсли ДатаНачалаДействияФРМО<Объект.ДатаНачалаДействия И Объект.ДатаНачалаДействия<=ДатаОкончанияДействияФРМО Тогда 
					КонфликтующееШтатноеРасписаниеФРМО =  ШтатноеРасписаниеФРМО;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	Если ОтветСервиса.СообщениеОбОшибкеПользователю<>Неопределено Тогда
		СообщениеОбОшибкеПользователю = СтрШаблон(НСтр("ru = 'Получение данных штатного расписания: %1'"), ОтветСервиса.СообщениеОбОшибкеПользователю);
		ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибкеПользователю);
	КонецЕсли;

	StaffData = StaffData();
	StaffData.staffNum = Объект.НомерШтатногоРасписания;
	StaffData.staffCreateDate = Объект.ДатаУтверждения;
	StaffData.beginDate = Объект.ДатаНачалаДействия;
	StaffData.endDate = Объект.ДатаОкончанияДействия;
	StaffData.staffDetails = Новый Массив;
	
	Для Каждого Позиция Из Объект.ШтатныеЕдиницы Цикл  
	    staffDetails = staffDetails();
		staffDetails.nrPmuDepartId = Позиция.ИдентификаторПодразделения;
		staffDetails.departName = Позиция.НаименованиеПодразделения;
		staffDetails.nrPmuDepartHospitalSubdivisionId = ?(ПустаяСтрока(Позиция.ИдентификаторОтделенияИлиКабинета), Неопределено, Позиция.ИдентификаторОтделенияИлиКабинета);
		staffDetails.hospitalName = ?(ПустаяСтрока(Позиция.НаименованиеОтделенияИлиКабинета), Неопределено, Позиция.НаименованиеОтделенияИлиКабинета);
		staffDetails.postFedCode.code = ?(ПустаяСтрока(Позиция.ДолжностьПоФедСправочникуКод), Неопределено, Позиция.ДолжностьПоФедСправочникуКод);
		staffDetails.postFedCode.name = ?(ПустаяСтрока(Позиция.ДолжностьПоФедСправочникуНаименование), Неопределено, Позиция.ДолжностьПоФедСправочникуНаименование);
		staffDetails.post.code = ?(ПустаяСтрока(Позиция.ДолжностьКод), Неопределено, Позиция.ДолжностьКод);
		staffDetails.post.name = ?(ПустаяСтрока(Позиция.ДолжностьНаименование), Неопределено, Позиция.ДолжностьНаименование);
		staffDetails.flCount = Позиция.КоличествоФизлиц;
		staffDetails.averageAge = 0;
		staffDetails.rate = Позиция.КоличествоСтавок;
		staffDetails.busyRate = Позиция.Занято;
		staffDetails.busyRateMain = Позиция.ЗанятоПоОсновномуМестуРаботы;
		staffDetails.externalRate = Позиция.ЗанятоПоВнешнемуСовместительству;
		staffDetails.vacancy = Позиция.КоличествоВакансий;
		staffDetails.staffNote = Позиция.Описание;
		StaffData.staffDetails.Добавить(staffDetails);
	КонецЦикла;
	
	ВыгрузкаДопускается = Истина;
	Если ТипЗнч(КонфликтующееШтатноеРасписаниеФРМО)=Тип("Структура") Тогда 
		ДатаНачала = МедицинскиеРегистрыКлиент.ДатаИзUTC(КонфликтующееШтатноеРасписаниеФРМО.beginDate);
		НоваяДатаОкончания = НачалоДня(НачалоДня(Объект.ДатаНачалаДействия) - 1);
		КонфликтующееШтатноеРасписаниеФРМО.staffCreateDate = МедицинскиеРегистрыКлиент.ДатаИзUTC(КонфликтующееШтатноеРасписаниеФРМО.staffCreateDate);
		КонфликтующееШтатноеРасписаниеФРМО.beginDate = ДатаНачала;
		КонфликтующееШтатноеРасписаниеФРМО.endDate = НоваяДатаОкончания;
		Для Каждого Позиция Из КонфликтующееШтатноеРасписаниеФРМО.staffDetails Цикл
			Позиция.postFedCode.code = Формат(Позиция.postFedCode.code, "ЧГ=0; ЧН=");
			Позиция.post.code = Формат(Позиция.post.code, "ЧГ=0; ЧН=");
		КонецЦикла;
		ПараметрыВызова = PostPutOrgStaff(Объект.УИНОрганизации, КонфликтующееШтатноеРасписаниеФРМО.staffId, КонфликтующееШтатноеРасписаниеФРМО);
		ТокенДоступа = ТокенДоступа(ПараметрыСервиса);
		ОтветСервиса = ВызватьМетод(ТокенДоступа, ПараметрыВызова);
		Если ОтветСервиса.СообщениеОбОшибкеПользователю<>Неопределено Тогда
			СообщениеОбОшибкеПользователю = СтрШаблон(НСтр("ru = 'Замена даты окончания штатного расписания: %1'"), ОтветСервиса.СообщениеОбОшибкеПользователю);
			ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибкеПользователю);
			ВыгрузкаДопускается = Ложь;
		Иначе 
			ВыгрузкаДопускается = ЗаписатьНовуюДатуОкончания(ДатаНачала, НоваяДатаОкончания, Объект.Организация);
			Если Не ВыгрузкаДопускается Тогда 
				СообщениеОбОшибкеПользователю = НСтр("ru = 'Не удалось сделать замену даты окончания предыдущего штатного расписания в документе выгрузки.
				|Возможно, он открыт для редактирования.'");
				ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибкеПользователю);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ВыгрузкаДопускается Тогда
		
		Объект.ВыгрузкаПроведена = Истина;
		ПараметрыВызова = PostPutOrgStaff(Объект.УИНОрганизации, Идентификатор, StaffData);
		ТокенДоступа = ТокенДоступа(ПараметрыСервиса);
		ОтветСервиса = ВызватьМетод(ТокенДоступа, ПараметрыВызова);
		Если ОтветСервиса.КодСостояния<400 Тогда 
			Если ПараметрыВызова.Метод = "POST" И ОтветСервиса.Контент<>Неопределено Тогда 
				Идентификатор = ОтветСервиса.Контент.entityId;
				МоментВыгрузки = МоментВыгрузкиНаСервере();
				МоментВыгрузкиТекст = СтрШаблон(НСтр("ru = 'Выгрузка проведена %1'"), МоментВыгрузки);
				ЗаписатьРезультатВыгрузки(Объект.ДатаНачалаДействия, Идентификатор, МоментВыгрузки, ПараметрыВызова.РазделМедрегистра);
			ИначеЕсли ПараметрыВызова.Метод = "PUT" И ОтветСервиса.СообщениеОбОшибкеПользователю=Неопределено Тогда
				МоментВыгрузки = МоментВыгрузкиНаСервере();
				МоментВыгрузкиТекст = СтрШаблон(НСтр("ru = 'Выгрузка проведена %1'"), МоментВыгрузки);
				ЗаписатьРезультатВыгрузки(Объект.ДатаНачалаДействия, Идентификатор, МоментВыгрузки, ПараметрыВызова.РазделМедрегистра);
			Иначе 
				Объект.ВыгрузкаПроведена = Ложь;
			КонецЕсли;
		Иначе 
			Объект.ВыгрузкаПроведена = Ложь;
		КонецЕсли;
		Если ОтветСервиса.СообщениеОбОшибкеПользователю<>Неопределено Тогда
			СообщениеОбОшибкеПользователю = СтрШаблон(НСтр("ru = 'Выгрузка штатного расписания: %1'"), ОтветСервиса.СообщениеОбОшибкеПользователю);
			ОбщегоНазначенияКлиент.СообщитьПользователю(СообщениеОбОшибкеПользователю);
		КонецЕсли;
		
		Записать();
		
	КонецЕсли;
			
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция МоментВыгрузкиНаСервере()
	Возврат ТекущаяДатаСеанса();
КонецФункции

&НаКлиенте
Функция ТокенДоступа(ПараметрыСервиса)
	АдресСервиса = ?(ПараметрыСервиса.ИспользоватьЗащищенноеСоединение, "https://", "http://") + ПараметрыСервиса.Адрес + ПараметрыСервиса.ТочкаДоступа;
	Возврат МедицинскиеРегистрыКлиент.ТокенДоступа(ДанныеСертификата(Сертификат), Пароль, АдресСервиса, МоментВыпуска(), ИдентификаторИнформационнойСистемы);
КонецФункции

&НаСервереБезКонтекста
Функция МоментВыпуска() Экспорт
	Возврат МедицинскиеРегистры.МоментВыпуска();
КонецФункции

&НаСервереБезКонтекста
Функция ДанныеСертификата(СертификатСсылка)
	Возврат МедицинскиеРегистры.ДанныеСертификата(СертификатСсылка);
КонецФункции

&НаСервереБезКонтекста
Функция ВызватьМетод(ТокенДоступа, ПараметрыВызова)
	Возврат МедицинскиеРегистры.ВызватьМетод(ТокенДоступа, ПараметрыВызова);
КонецФункции

&НаСервереБезКонтекста
Функция ПараметрыСервиса()
	Возврат МедицинскиеРегистры.ПараметрыСервиса();
КонецФункции

&НаСервереБезКонтекста
Процедура ЗаписатьРезультатВыгрузки(ДатаСобытия, Идентификатор, МоментВыгрузки, РазделМедрегистра)
	
	Набор = РегистрыСведений.ИдентификаторыОбъектовДляФедеральныхМедрегистров.СоздатьНаборЗаписей();
	Набор.Отбор.Объект.Установить(Документы.УтверждениеШтатногоРасписания.ПустаяСсылка());
	Набор.Отбор.ДатаСобытия.Установить(ДатаСобытия);
	Набор.Прочитать();
	Если Набор.Количество() = 0 Тогда
		РезультатВыгрузки = Набор.Добавить();
		РезультатВыгрузки.Объект = Документы.УтверждениеШтатногоРасписания.ПустаяСсылка();
		РезультатВыгрузки.ДатаСобытия = ДатаСобытия;
	Иначе
		РезультатВыгрузки = Набор[0];
	КонецЕсли;
	РезультатВыгрузки.Идентификатор = Идентификатор;
	Если МоментВыгрузки<>Неопределено Тогда 
		РезультатВыгрузки.МоментВыгрузки = МоментВыгрузки;
	КонецЕсли;
	Если РазделМедрегистра<>Неопределено Тогда 
		РезультатВыгрузки.РазделМедрегистра = РазделМедрегистра;
	КонецЕсли;
	Набор.Записать();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ЗаписатьНовуюДатуОкончания(ДатаНачала, НоваяДатаОкончания, Организация)
	
	ДокументИзмененУспешно = Истина;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СведенияДляФРМО.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.СведенияДляФРМО КАК СведенияДляФРМО
		|ГДЕ
		|	СведенияДляФРМО.Организация = &Организация
		|	И СведенияДляФРМО.ДатаНачалаДействия = &ДатаНачалаДействия";
	
	Запрос.УстановитьПараметр("ДатаНачалаДействия", ДатаНачала);
	Запрос.УстановитьПараметр("Организация", Организация);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ДокументДляЗаписи = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		ДокументЗаблокирован = Истина;
		Попытка
		  ДокументДляЗаписи.Заблокировать();
		Исключение
			ДокументЗаблокирован = Ложь;
			ДокументИзмененУспешно = Ложь;
		КонецПопытки;
		
		Если ДокументЗаблокирован Тогда 
			ДокументДляЗаписи.ДатаОкончанияДействия = НоваяДатаОкончания;
			ДокументДляЗаписи.Записать();
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ДокументИзмененУспешно;
	
КонецФункции

