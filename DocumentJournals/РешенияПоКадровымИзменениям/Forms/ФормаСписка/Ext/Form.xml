	<Attributes>
		<Attribute name="Список" id="1">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<UseAlways>
				<Field>Список.Ссылка</Field>
			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	Решения.Ссылка КАК Ссылка,
	Решения.Дата КАК Дата,
	НАЧАЛОПЕРИОДА(Решения.Дата, ДЕНЬ) КАК ДатаДокумента,
	Решения.ПометкаУдаления КАК ПометкаУдаления,
	Решения.Номер КАК Номер,
	Решения.Проведен КАК Проведен,
	Решения.Организация КАК Организация,
	Решения.Сотрудник КАК Сотрудник,
	Решения.ДатаСобытия КАК ДатаСобытия,
	Решения.Ответственный КАК Ответственный,
	Решения.Комментарий КАК Комментарий,
	КадровыеДокументы.КадровыйДокумент КАК КадровыйДокумент,
	Решения.Тип КАК Тип,
	ВЫБОР
		КОГДА НаличиеФайлов.ЕстьФайлы ЕСТЬ NULL
			ТОГДА 0
		КОГДА НаличиеФайлов.ЕстьФайлы
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ЕстьФайлы
ИЗ
	ЖурналДокументов.РешенияПоКадровымИзменениям КАК Решения
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НаличиеФайлов КАК НаличиеФайлов
		ПО Решения.Ссылка = НаличиеФайлов.ОбъектСФайлами
		{ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КадровыеДокументыПоРешениям КАК КадровыеДокументы
		ПО КадровыеДокументы.Решение = Решения.Ссылка}
{ГДЕ
	(ИСТИНА В
		(ВЫБРАТЬ ПЕРВЫЕ 1
			ИСТИНА
		ИЗ
			РегистрСведений.СоставДокументовЗарплатаКадры КАК СоставДокументовЗарплатаКадры
		ГДЕ
			СоставДокументовЗарплатаКадры.ФизическоеЛицо = &amp;ФизическоеЛицо
			И Решения.Ссылка = СоставДокументовЗарплатаКадры.ДокументФизическогоЛица))}</QueryText>
				<MainTable>DocumentJournal.РешенияПоКадровымИзменениям</MainTable>
				<ListSettings>
					<dcsset:filter>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>dfcece9d-5077-440b-b6b3-45a5cb4538eb</dcsset:userSettingID>
					</dcsset:filter>
					<dcsset:order>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>88619765-ccb3-46c6-ac52-38e9c992ebd4</dcsset:userSettingID>
					</dcsset:order>
					<dcsset:conditionalAppearance>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>b75fecce-942b-4aed-abc9-e6a02e460fb3</dcsset:userSettingID>
					</dcsset:conditionalAppearance>
					<dcsset:itemsViewMode>Normal</dcsset:itemsViewMode>
					<dcsset:itemsUserSettingID>911b6018-f537-43e8-a417-da56b22f9aec</dcsset:itemsUserSettingID>
				</ListSettings>
			</Settings>
