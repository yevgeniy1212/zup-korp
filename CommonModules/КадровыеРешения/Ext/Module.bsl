// Процедура выполняет распределение присоединенных файлов решений по кадровым изменениям
//
Процедура РаспределениеПрисоединенныхФайловРешенийПоКадровымИзменениям(ПараметрыОбновления = Неопределено) Экспорт

	ОбновлениеИБ = ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1000
		|	ПрисоединенныеФайлы.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.РешенияПоКадровымИзменениямПрисоединенныеФайлы КАК ПрисоединенныеФайлы
		|ГДЕ
		|	НЕ ПрисоединенныеФайлы.ПометкаУдаления";
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		ОбновлениеИБ.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
		Возврат;
	КонецЕсли;
	
	БлокировкаДанных = Новый БлокировкаДанных;
	ЭлементБлокировки = БлокировкаДанных.Добавить(
		Метаданные.Справочники.РешенияПоКадровымИзменениямПрисоединенныеФайлы.ПолноеИмя());
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;

	НачатьТранзакцию();
	Попытка
		БлокировкаДанных.Заблокировать();
		ОбновлениеИБ.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Ложь);
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			ПрисоединенныйФайлНовый = ПрисоединенныйФайлПоТипуЗначения(ТипЗнч(Выборка.Ссылка.ВладелецФайла));
			Если ПрисоединенныйФайлНовый = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ЗаполнитьЗначенияСвойств(ПрисоединенныйФайлНовый, Выборка.Ссылка,, "Владелец, Ссылка, Родитель");
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ПрисоединенныйФайлНовый);
			ПрисоединенныйФайлСтарый = Выборка.Ссылка.ПолучитьОбъект();
			ПрисоединенныйФайлСтарый.ПометкаУдаления = Истина;
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ПрисоединенныйФайлСтарый);
		КонецЦикла;
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;
	
	Если ПараметрыОбновления <> Неопределено Тогда
		ОбновлениеИБ.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
	КонецЕсли;
	
КонецПроцедуры

Функция ПрисоединенныйФайлПоТипуЗначения(ТипЗначения)
	
	Если ТипЗначения = Тип("ДокументСсылка.РешениеОПриемеНаРаботу") Тогда
		ПрисоединенныйФайл = Справочники.РешениеОПриемеНаРаботуПрисоединенныеФайлы.СоздатьЭлемент();
	ИначеЕсли ТипЗначения = Тип("ДокументСсылка.РешениеОбУвольнении") Тогда
		ПрисоединенныйФайл = Справочники.РешениеОПриемеНаРаботуПрисоединенныеФайлы.СоздатьЭлемент();
	ИначеЕсли ТипЗначения = Тип("ДокументСсылка.РешениеОВозвратеИзОтпускаПоУходуЗаРебенком") Тогда
		ПрисоединенныйФайл = Справочники.РешениеОПриемеНаРаботуПрисоединенныеФайлы.СоздатьЭлемент();
	ИначеЕсли ТипЗначения = Тип("ДокументСсылка.РешениеОВосстановленииВДолжности") Тогда
		ПрисоединенныйФайл = Справочники.РешениеОПриемеНаРаботуПрисоединенныеФайлы.СоздатьЭлемент();
	ИначеЕсли ТипЗначения = Тип("ДокументСсылка.РешениеОКадровомПереводе") Тогда
		ПрисоединенныйФайл = Справочники.РешениеОПриемеНаРаботуПрисоединенныеФайлы.СоздатьЭлемент();
	ИначеЕсли ТипЗначения = Тип("ДокументСсылка.РешениеОбОтпускеПоУходуЗаРебенком") Тогда
		ПрисоединенныйФайл = Справочники.РешениеОПриемеНаРаботуПрисоединенныеФайлы.СоздатьЭлемент();
	Иначе
		ПрисоединенныйФайл = Неопределено;
	КонецЕсли;
	
	Возврат ПрисоединенныйФайл;
	
КонецФункции

// Связать сотрудников с решениями о приеме на работу.
// 
// Параметры:
//  ПараметрыОбновления - Структура:
//	* ОбработкаЗавершена - Булево
Процедура СвязатьСотрудниковСРешениямиОПриемеНаРаботу(ПараметрыОбновления) Экспорт

	ОбновлениеИБ = ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый;

	РешенияБезФизическогоЛица = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
		ПараметрыОбновления, "РешенияБезФизическогоЛица", Новый Массив); // Массив Из ДокументСсылка.РешениеОПриемеНаРаботу
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("РешенияБезФизическогоЛица", РешенияБезФизическогоЛица); 
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1000
		|	Решения.Ссылка КАК Ссылка,
		|	Решения.Кандидат КАК Кандидат,
		|	Решения.Организация КАК Организация
		|ИЗ
		|	Документ.РешениеОПриемеНаРаботу КАК Решения
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СотрудникиПоРешениямОПриемеНаРаботу КАК СотрудникиПоРешениям
		|		ПО (СотрудникиПоРешениям.Решение = Решения.Ссылка)
		|ГДЕ
		|	Решения.Проведен
		|	И СотрудникиПоРешениям.Сотрудник ЕСТЬ NULL
		|	И НЕ Решения.Ссылка В (&РешенияБезФизическогоЛица)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Решения.Дата УБЫВ";
	
	ОписаниеДанных = Новый Массив;
	ОписаниеДанных.Добавить(ОписаниеБлокируемыхДанных(Метаданные.Документы.РешениеОПриемеНаРаботу));
	ОписаниеДанных.Добавить(ОписаниеБлокируемыхДанных(Метаданные.Справочники.Сотрудники));
	ОписаниеДанных.Добавить(ОписаниеБлокируемыхДанных(Метаданные.РегистрыСведений.СотрудникиПоРешениямОПриемеНаРаботу));

	Если Не ОбновлениеИБ.НачатьОбновлениеДанных(ОписаниеДанных, ПараметрыОбновления) Тогда
		Возврат;
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		ОбновлениеИБ.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
		ПараметрыОбновления.ОбработкаЗавершена = Истина;
		Возврат;
	КонецЕсли;
	
	ПараметрыОбновления.ОбработкаЗавершена = Ложь;

	Кандидаты = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Кандидат"); // Массив Из СправочникСсылка.Кандидаты
	
	СотрудникиПоКандидатам = ПодборПерсонала.СотрудникиПоКандидатам(Кандидаты);
	ФизическиеЛицаПоКандидатам = Справочники.Кандидаты.ФизическиеЛицаКандидатов(Кандидаты);
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		Сотрудник = СотрудникиПоКандидатам.Получить(Выборка.Кандидат);
		Если Сотрудник = Неопределено Тогда
			Если ФизическиеЛицаПоКандидатам[Выборка.Кандидат] = Неопределено Тогда
				ЗаписьЖурналаРегистрации(
					НСтр("ru = 'Обновление информационной базы.Связать сотрудников с решениями о приеме на работу'", 
						ОбщегоНазначения.КодОсновногоЯзыка()),
					УровеньЖурналаРегистрации.Предупреждение, , , 
					СтрШаблон(
						НСтр("ru = 'Для кандидата %1 проведено решение о приеме на работу %2, но при этом не удалось обнаружить физическое лицо.
							 |Для этого решения сотрудник не был создан.
							 |Необходимо создать физическое лицо для кандидата %1, затем перепровести документ.'"),
						Выборка.Кандидат,
						Выборка.Ссылка));
				РешенияБезФизическогоЛица.Добавить(Выборка.Ссылка);
				Продолжить;
			КонецЕсли;
			Сотрудник = КадровыйУчет.НовыйСотрудникФизическогоЛица(
				ФизическиеЛицаПоКандидатам[Выборка.Кандидат], Выборка.Организация);
		КонецЕсли;
		НаборЗаписей = РегистрыСведений.СотрудникиПоРешениямОПриемеНаРаботу.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Решение.Установить(Выборка.Ссылка);
		СтрокаНабора = НаборЗаписей.Добавить();
		СтрокаНабора.Решение = Выборка.Ссылка;
		СтрокаНабора.Сотрудник = Сотрудник;
		ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
	КонецЦикла;
	
	ОбновлениеИБ.ЗавершитьОбновлениеДанных(ПараметрыОбновления);

	ПараметрыОбновления.Вставить("РешенияБезФизическогоЛица", РешенияБезФизическогоЛица);
	
КонецПроцедуры

Функция ОписаниеБлокируемыхДанных(МетаданныеОбъекта)
	Описание = ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ОписаниеБлокируемыхДанных(МетаданныеОбъекта);
	Описание.ПоляБлокировки.Очистить();
	Возврат Описание;
КонецФункции

Процедура УстановитьФОКадровыхРешений(ПараметрыОбновления) Экспорт

	ОбновлениеИБ = ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый;
	
	Запрос = Новый Запрос();
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ИСТИНА КАК ИспользоватьАдаптациюУвольнение
		|ИЗ
		|	Константа.ИспользоватьАдаптациюУвольнение КАК НастройкаАдаптации
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиКадровыхРешений КАК Настройки
		|		ПО (ИСТИНА)
		|ГДЕ
		|	НастройкаАдаптации.Значение = ИСТИНА
		|	И ЕСТЬNULL(Настройки.ИспользоватьРешениеОбОтпускеПоУходуЗаРебенком, ЛОЖЬ) = ЛОЖЬ
		|	И ЕСТЬNULL(Настройки.ИспользоватьРешениеОбУвольнении, ЛОЖЬ) = ЛОЖЬ
		|	И ЕСТЬNULL(Настройки.ИспользоватьРешениеОВозвратеИзОтпускаПоУходуЗаРебенком, ЛОЖЬ) = ЛОЖЬ
		|	И ЕСТЬNULL(Настройки.ИспользоватьРешениеОВосстановленииВДолжности, ЛОЖЬ) = ЛОЖЬ
		|	И ЕСТЬNULL(Настройки.ИспользоватьРешениеОКадровомПереводе, ЛОЖЬ) = ЛОЖЬ
		|	И ЕСТЬNULL(Настройки.ИспользоватьРешениеОПриемеНаРаботу, ЛОЖЬ) = ЛОЖЬ";
	
	ОписаниеДанных = Новый Массив;
	ОписаниеДанных.Добавить(ОписаниеБлокируемыхДанных(Метаданные.РегистрыСведений.НастройкиКадровыхРешений));
	ОписаниеДанных.Добавить(ОписаниеБлокируемыхДанных(Метаданные.Константы.ИспользоватьАдаптациюУвольнение));

	Если Не ОбновлениеИБ.НачатьОбновлениеДанных(ОписаниеДанных, ПараметрыОбновления) Тогда
		Возврат;
	КонецЕсли;

	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		ОбновлениеИБ.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
		ПараметрыОбновления.ОбработкаЗавершена = Истина;
		Возврат;
	КонецЕсли;
	
	ПараметрыОбновления.ОбработкаЗавершена = Ложь;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		НаборЗаписей = РегистрыСведений.НастройкиКадровыхРешений.СоздатьНаборЗаписей();
		СтрокаНабора = НаборЗаписей.Добавить();
		СтрокаНабора.ИспользоватьРешениеОбОтпускеПоУходуЗаРебенком = Выборка.ИспользоватьАдаптациюУвольнение;
		СтрокаНабора.ИспользоватьРешениеОбУвольнении = Выборка.ИспользоватьАдаптациюУвольнение;
