#Область СлужебныйПрограммныйИнтерфейс

// Связанный с решением приказ.
// 
// Параметры:
//  Решение - ОпределяемыйТип.КадровоеРешение -
// 
// Возвращаемое значение:
//  Неопределено, 
//	ДокументСсылка.КадровыйПеревод, 
//	ДокументСсылка.Увольнение, 
//	ДокументСсылка.ВосстановлениеВДолжности, 
//	ДокументСсылка.ВозвратИзОтпускаПоУходуЗаРебенком, 
//	ДокументСсылка.КадровыйПереводСписком, 
//	ДокументСсылка.ПриемНаРаботу, 
//	ДокументСсылка.УвольнениеСписком, 
//	ДокументСсылка.ОтпускПоУходуЗаРебенком, 
//	ДокументСсылка.ПриемНаРаботуСписком - кадровый документ.
Функция СвязанныйСРешениемПриказ(Решение) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Решение", Решение);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КадровыйДокумент
		|ИЗ
		|	РегистрСведений.КадровыеДокументыПоРешениям
		|ГДЕ
		|	Решение = &Решение";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.КадровыйДокумент;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Процедура ДобавитьПодменюРешенияПоКадровымИзменениям(ОписаниеМеню) Экспорт
	
	ПунктыМеню = Новый Массив;
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьРешениеОКадровомПереводе") 
		И ПравоДоступа("Добавление", Метаданные.Документы.РешениеОКадровомПереводе) Тогда
		ПунктыМеню.Добавить("Документы.РешениеОКадровомПереводе");
	КонецЕсли;
	Если ПолучитьФункциональнуюОпцию("ИспользоватьРешениеОбУвольнении") 
		И ПравоДоступа("Добавление", Метаданные.Документы.РешениеОбУвольнении) Тогда
		ПунктыМеню.Добавить("Документы.РешениеОбУвольнении");
	КонецЕсли;
	Если ПолучитьФункциональнуюОпцию("ИспользоватьРешениеОбОтпускеПоУходуЗаРебенком") 
		И ПравоДоступа("Добавление", Метаданные.Документы.РешениеОбОтпускеПоУходуЗаРебенком) Тогда
		ПунктыМеню.Добавить("Документы.РешениеОбОтпускеПоУходуЗаРебенком");
	КонецЕсли;
	Если ПолучитьФункциональнуюОпцию("ИспользоватьРешениеОВозвратеИзОтпускаПоУходуЗаРебенком") 
		И ПравоДоступа("Добавление", Метаданные.Документы.РешениеОВозвратеИзОтпускаПоУходуЗаРебенком) Тогда
		ПунктыМеню.Добавить("Документы.РешениеОВозвратеИзОтпускаПоУходуЗаРебенком");
	КонецЕсли;
	Если ПолучитьФункциональнуюОпцию("ИспользоватьРешениеОВосстановленииВДолжности") 
		И ПравоДоступа("Добавление", Метаданные.Документы.РешениеОВосстановленииВДолжности) Тогда
		ПунктыМеню.Добавить("Документы.РешениеОВосстановленииВДолжности");
	КонецЕсли;
	
	Если ПунктыМеню.Количество() > 0 Тогда
		ОписаниеМеню.Пункты.Добавить(СотрудникиФормы.РазделМеню(НСтр("ru = 'Решения'"), ПунктыМеню));
	КонецЕсли;
	
КонецПроцедуры

Функция НастройкиКадровыхРешений() Экспорт
	Возврат РегистрыСведений.НастройкиКадровыхРешений.Настройки();
КонецФункции

Процедура УстановитьНастройкиКадровыхРешений(Настройки) Экспорт
	РегистрыСведений.НастройкиКадровыхРешений.УстановитьНастройки(Настройки);
КонецПроцедуры

#Область КадровыеДокументы

Процедура ПриЗаполненииПриемаНаРаботу(ПриемНаРаботуОбъект, ДанныеЗаполнения, СтандартнаяОбработка) Экспорт

	Если ТипЗнч(ДанныеЗаполнения) = Тип("СправочникСсылка.Сотрудники") Тогда
		// Проверим, есть ли по этому сотруднику решение о приеме на работу?
		Решение = Документы.РешениеОПриемеНаРаботу.РешениеОПриемеНаРаботуПоСотруднику(ДанныеЗаполнения);
		Если Решение = Неопределено Тогда
			Возврат;
		КонецЕсли;
		Сотрудник = ДанныеЗаполнения;
	ИначеЕсли ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.РешениеОПриемеНаРаботу") Тогда
		Решение = ДанныеЗаполнения;
		Сотрудник = Документы.РешениеОПриемеНаРаботу.СотрудникПоРешениюОПриемеНаРаботу(Решение);
	Иначе
		Возврат;
	КонецЕсли;

	ФизическоеЛицо = КадровыйУчет.ФизическиеЛицаСотрудников(
		ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Сотрудник))[0];
	
	СтруктураЗаполнения = Документы.РешениеОПриемеНаРаботу.ДанныеЗаполненияПриемаНаРаботуПоДокументуРешения(
		Решение.ПолучитьОбъект(), Сотрудник, ФизическоеЛицо);
	
	ПриемНаРаботуОбъект.Заполнить(СтруктураЗаполнения);
	
	СтандартнаяОбработка = Ложь;
	
КонецПроцедуры

Процедура ОбработкаЗаполненияКадровогоПриказа(ДокументОбъект, ДанныеЗаполнения, СтандартнаяОбработка) Экспорт
	
	Если ДанныеЗаполнения = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТипДанныхЗаполнения = ТипЗнч(ДанныеЗаполнения);
	
	Если Не Метаданные.ОпределяемыеТипы.КадровоеРешение.Тип.СодержитТип(ТипДанныхЗаполнения) Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипДанныхЗаполнения = Тип("ДокументСсылка.РешениеОКадровомПереводе") Тогда
		КопируемыеРеквизиты = Новый Массив;
		КопируемыеРеквизиты.Добавить("ДатаНачала");
		КопируемыеРеквизиты.Добавить("ДатаОкончания");
		КопируемыеРеквизиты.Добавить("Подразделение");
		КопируемыеРеквизиты.Добавить("Территория");
		КопируемыеРеквизиты.Добавить("ДолжностьПоШтатномуРасписанию");
		КопируемыеРеквизиты.Добавить("ОбособленноеПодразделение");
		КопируемыеРеквизиты.Добавить("Организация");
		КопируемыеРеквизиты.Добавить("Сотрудник"); 
		КопируемыеРеквизиты.Добавить("ФизическоеЛицо");
		КопируемыеРеквизиты.Добавить("РабочееМесто");
		КопируемыеРеквизиты.Добавить("РаботаетДистанционно");
		КопируемыеРеквизиты.Добавить("ИзменитьПодразделениеИДолжность");
		КопируемыеРеквизиты.Добавить("ИзменитьТерриторию");
		КопируемыеРеквизиты.Добавить("ИзменитьРабочееМесто");
		КопируемыеРеквизиты.Добавить("ИзменитьДистанционнуюРаботу");
		// ЗУПК
		КопируемыеРеквизиты.Добавить("РежимДистанционнойРаботы");
		// ЗУПК
		ЗаполнитьЗначенияСвойств(ДокументОбъект, 
			ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеЗаполнения, КопируемыеРеквизиты));
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.РешениеОбУвольнении") Тогда
		КопируемыеРеквизиты = Новый Массив;
		КопируемыеРеквизиты.Добавить("ДатаУвольнения");
		КопируемыеРеквизиты.Добавить("Организация");
		КопируемыеРеквизиты.Добавить("Сотрудник");
		КопируемыеРеквизиты.Добавить("ФизическоеЛицо");
		ЗаполнитьЗначенияСвойств(ДокументОбъект, 
			ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеЗаполнения, КопируемыеРеквизиты));
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.РешениеОбОтпускеПоУходуЗаРебенком") Тогда
		КопируемыеРеквизиты = Новый Массив;
		КопируемыеРеквизиты.Добавить("ДатаНачала");
		КопируемыеРеквизиты.Добавить("Организация");
		КопируемыеРеквизиты.Добавить("ОсновнойСотрудник");
		КопируемыеРеквизиты.Добавить("ФизическоеЛицо");
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеЗаполнения, КопируемыеРеквизиты);
		ЗаполнитьЗначенияСвойств(ДокументОбъект, ЗначенияРеквизитов);
		ДокументОбъект.Сотрудник = ЗначенияРеквизитов.ФизическоеЛицо;
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.РешениеОВосстановленииВДолжности") Тогда
		КопируемыеРеквизиты = Новый Массив;
		КопируемыеРеквизиты.Добавить("ДатаВосстановления"); 
		КопируемыеРеквизиты.Добавить("Организация"); 
		КопируемыеРеквизиты.Добавить("Сотрудник"); 
		КопируемыеРеквизиты.Добавить("ФизическоеЛицо"); 
		КопируемыеРеквизиты.Добавить("ДолжностьПоШтатномуРасписанию");
		КопируемыеРеквизиты.Добавить("ДокументОснование");
		
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеЗаполнения, КопируемыеРеквизиты);
		ЗаполнитьЗначенияСвойств(ДокументОбъект, ЗначенияРеквизитов);
		
		РеквизитыПозиции = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЗначенияРеквизитов.ДолжностьПоШтатномуРасписанию, "Подразделение, Должность");
		ЗаполнитьЗначенияСвойств(ДокументОбъект, РеквизитыПозиции);
		
		ПриказСвязанныйСОснованием = СвязанныйСРешениемПриказ(ЗначенияРеквизитов.ДокументОснование); // ДокументСсылка.Увольнение
		Если ЗначениеЗаполнено(ПриказСвязанныйСОснованием) Тогда
			ДокументОбъект.ДокументУвольнения = ПриказСвязанныйСОснованием;
			ДокументОбъект.ДатаУвольнения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ПриказСвязанныйСОснованием, "ДатаУвольнения");
		КонецЕсли;
	ИначеЕсли ТипДанныхЗаполнения = Тип("ДокументСсылка.РешениеОВозвратеИзОтпускаПоУходуЗаРебенком") Тогда
		КопируемыеРеквизиты = Новый Массив;
		КопируемыеРеквизиты.Добавить("ДатаВозврата");
		КопируемыеРеквизиты.Добавить("Организация"); 
		КопируемыеРеквизиты.Добавить("ОсновнойСотрудник");
		КопируемыеРеквизиты.Добавить("ФизическоеЛицо");
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеЗаполнения, КопируемыеРеквизиты);
		ЗаполнитьЗначенияСвойств(ДокументОбъект, ЗначенияРеквизитов);
		ДокументОбъект.Сотрудник = ЗначенияРеквизитов.ФизическоеЛицо;
		ПриказСвязанныйСОснованием = СвязанныйСРешениемПриказ(ДанныеЗаполнения.ДокументОснование);
		Если ЗначениеЗаполнено(ПриказСвязанныйСОснованием) Тогда
			ДокументОбъект.ДокументОснование = ПриказСвязанныйСОснованием;
		КонецЕсли;
	КонецЕсли;

	ДокументОбъект.Решение = ДанныеЗаполнения;
	
КонецПроцедуры

#КонецОбласти

