// Очищает таблицу и дерево ошибок текущей формы отчетности.
//
// Параметры:
//   Форма – объект формы, для которой выполняется очистка.
//   СкрытьВидимость (необязательный, Булево) – если Истина, скрывает элемент дерева ошибок после очистки. 
//       Значение по умолчанию: Истина.
Процедура ОчиститьТаблицуОшибок(Форма, СкрытьВидимость = Истина) Экспорт
	Форма.ТаблицаОшибокОтчетность1С.Очистить();
	Форма.ДеревоОшибокОтчетность1С.ПолучитьЭлементы().Очистить();
	Форма.КоличествоОшибокВсегоОтчетность1С = 0;
	Форма.КоличествоОшибокКритичныхОтчетность1С = 0;
	Если СкрытьВидимость Тогда
		Форма.Элементы.ДеревоОшибокОтчетность1С.Видимость = Ложь;
	КонецЕсли;
КонецПроцедуры

