// Возвращает статус отправки формы
Функция СтатусОтправки_ФормаУжеОтправлена(Форма) Экспорт
	ФормаДоставлена = ?(Форма.СтатусПриемаОтчетность1С = ПредопределенноеЗначение("Перечисление.СтатусыПриемаОтчетность1С.Принят"), Истина, Ложь);;
	ФормаВОбработке = ?(Форма.СтатусПриемаОтчетность1С = ПредопределенноеЗначение("Перечисление.СтатусыПриемаОтчетность1С.ВОбработке"), Истина, Ложь);
	ФормаУжеОтправлена = ФормаВОбработке ИЛИ ФормаДоставлена;

	Возврат ФормаУжеОтправлена;
КонецФункции

