// Возвращает строку фильтра для диалогов выбора и сохранения файлов регламентированной отчетности.  
// Используется при выгрузке отчетов в формате JSON.
//
// Возвращаемое значение:  
//   Строка - фильтр формата файлов для диалогов выбора/сохранения,  
//   например: "json-файл|*.json".
//
Функция ФильтрДиалоговВыбораИСохраненияРегламентированногоОтчета() Экспорт
	
	Фильтр = НСтр("ru = 'json-файл|*.json'");	
	Возврат Фильтр;
	
КонецФункции

// Возвращает пустое значение для указанного типа данных.  
// Используется для инициализации переменных или заполнения структур значениями по умолчанию.
//
// Параметры:  
//   ЗаданныйТип - Тип - тип значения, для которого требуется получить пустое значение.
//
// Возвращаемое значение:  
//   Произвольный - пустое значение соответствующего типа:  
//     * Число  →  0  
//     * Строка →  "" (пустая строка)  
//     * Дата   →  '00010101000000' (начальная дата)  
//     * Булево →  Ложь  
//     * Иной тип → Новый экземпляр указанного типа.
//
Функция ПустоеЗначениеТипа(ЗаданныйТип) Экспорт

	Если ЗаданныйТип = Тип("Число") Тогда
		Возврат 0;

	ИначеЕсли ЗаданныйТип = Тип("Строка") Тогда
		Возврат "";

	ИначеЕсли ЗаданныйТип = Тип("Дата") Тогда
		Возврат '00010101000000';

	ИначеЕсли ЗаданныйТип = Тип("Булево") Тогда
		Возврат Ложь;

	Иначе
		Возврат Новый (ЗаданныйТип);

	КонецЕсли;

КонецФункции

// Возвращает строку формата для отображения номера строки в многострочной форме.  
// Формат определяет количество цифр и правила выравнивания при выводе номера.
//
// Возвращаемое значение:  
//   Строка - формат номера строки, используемый при выводе данных в многострочной форме.  
//   По умолчанию: "ЧЦ=6; ЧВН=; ЧГ=".
//
Функция ФорматНомераСтрокиМногострочнойФормы(ЗначениеСвойстваJSON="") Экспорт
	ФорматНомераСтрокиМногострочнойФормы = "ЧЦ=6; ЧВН=; ЧГ=";
	
	Если ЗначениеЗаполнено(ЗначениеСвойстваJSON) Тогда
		ФорматНомераСтрокиМногострочнойФормы = "ЧЦ=" + Строка(СтрДлина(ЗначениеСвойстваJSON)) + "; ЧВН=; ЧГ=";
	КонецЕсли;
	
	Возврат ФорматНомераСтрокиМногострочнойФормы;
КонецФункции

// Отображает пользователю сообщение с указанным текстом.  
// При необходимости связывает сообщение с конкретным полем формы.
//
// Параметры:  
//   Текст - Строка - текст сообщения, отображаемого пользователю.  
//   Поле - Произвольный (необязательный) - элемент формы, с которым связано сообщение.  
//     Если указано, сообщение будет отображено в контексте данного поля.
//
Процедура СообщитьПользователю(Знач ТекстСообщенияПользователю,	УникальныйИдентификатор="", Знач КлючДанных = Неопределено,
	Знач Поле = "", Знач ПутьКДанным = "", Отказ = Ложь, ЭтоОбъект = Ложь) Экспорт
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = ТекстСообщенияПользователю;
	Сообщение.Поле = Поле;
	
	Если НЕ ПустаяСтрока(УникальныйИдентификатор) Тогда	
		Сообщение.ИдентификаторНазначения = УникальныйИдентификатор;
	КонецЕсли;
	
	Если ЭтоОбъект Тогда
		Сообщение.УстановитьДанные(КлючДанных);
	Иначе
		Сообщение.КлючДанных = КлючДанных;
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(ПутьКДанным) Тогда
		Сообщение.ПутьКДанным = ПутьКДанным;
	КонецЕсли;
	
	Отказ = Истина;
	
	Сообщение.Сообщить();
КонецПроцедуры

