// Формирует JSON-представление переданного значения.
//
// Параметры:
//   Значение – любое значение 1С, которое требуется сериализовать в JSON.
//
// Возвращаемое значение:
//   Строка – JSON-представление переданного значения.
Функция Отчетность1С_ЗаписатьЗначениеJSON(Значение)Экспорт
	
	Результат = Неопределено;
	#Если ВебКлиент Тогда
		Результат = Отчетность1СВызовСервера.Отчетность1С_ЗаписатьЗначениеJSON(Значение);
	#Иначе
		Запись = Новый ЗаписьJSON;
		Запись.УстановитьСтроку();
		ЗаписатьJSON(Запись, Значение);
		Результат = Запись.Закрыть();
	#КонецЕсли
	
	Возврат Результат;
	
КонецФункции

// Преобразует JSON-строку в соответствующее значение 1С.
//
// Параметры:
//   Значение – строка JSON, которую необходимо преобразовать в значение 1С.
//
// Возвращаемое значение:
//   Любое значение 1С, соответствующее структуре данных JSON.
Функция Отчетность1С_ПрочитатьЗначениеJSON(Значение) Экспорт
	Результат = Неопределено;
	#Если ВебКлиент Тогда
		Результат = Отчетность1СВызовСервера.Отчетность1С_ПрочитатьЗначениеJSON(Значение);
	#Иначе
		Чтение = Новый ЧтениеJSON;
		Чтение.УстановитьСтроку(Значение);
		Результат = ПрочитатьJSON(Чтение);
		Чтение.Закрыть();
	#КонецЕсли
	
	Возврат Результат;
КонецФункции

