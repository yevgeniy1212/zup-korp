		|	ЕСТЬNULL(НалогообложениеНачислений.ДоходНеПодлежащийНалогообложениюОПВ, ЗНАЧЕНИЕ(Справочник.ДоходыНеПодлежащиеНалогообложениюЧастично.ПустаяСсылка)),
		|	ЕСТЬNULL(НалогообложениеНачислений.ДоходНеПодлежащийНалогообложениюВОСМС, ЗНАЧЕНИЕ(Справочник.ДоходыНеПодлежащиеНалогообложениюЧастично.ПустаяСсылка)),
		|	ЕСТЬNULL(НалогообложениеНачислений.ДоходНеПодлежащийНалогообложениюИПН, ЗНАЧЕНИЕ(Справочник.ДоходыНеПодлежащиеНалогообложениюЧастично.ПустаяСсылка))
		|ИЗ
		|	ВТРегистрРасчета_Начисления КАК Начисления
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНалогообложениеНачислений КАК НалогообложениеНачислений
		|		ПО Начисления.ВидРасчета = НалогообложениеНачислений.Начисление
		|ГДЕ
		|	Начисления.Регистратор = &ВременныйРегистратор
		|	И (НЕ Начисления.ФиксСторно
		|			И НЕ Начисления.Сторно
		|			И НЕ Начисления.ПериодДействия < &МесяцНачисления)
		// условие необходимо для корректного расчета проведенного документа 
		// в проведенном документе в ВТРегистрРасчета_Начисления будут содержаться строки с минусом по начислениям этого документа
		|	И Начисления.СторнируемыйДокумент <> &ИсключаемыйРегистратор
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТЗарегистрированныеНачисления_Выбор.Сотрудник КАК Сотрудник,
		|	ВТЗарегистрированныеНачисления_Выбор.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТЗарегистрированныеНачисления_Выбор.ПериодРегистрации КАК ПериодРегистрации,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ОтОбратногоНачисленияВсего) КАК ОтОбратногоНачисленияВсего,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ПрямыеНачисленияВсего) КАК ПрямыеНачисленияВсего,
		|	ВТЗарегистрированныеНачисления_Выбор.ВидДохода КАК ВидДохода,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ОбщаяСуммаДоходаПрямыеНачисления) КАК ОбщаяСуммаДоходаПрямыеНачисления,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ПрямыеНачисленияОблагаемыеОПВ) КАК ПрямыеНачисленияОблагаемыеОПВ,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ПрямыеНачисленияОблагаемыеВОСМС) КАК ПрямыеНачисленияОблагаемыеВОСМС,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ПрямыеНачисленияОблагаемыеИПН) КАК ПрямыеНачисленияОблагаемыеИПН,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ОтОбратногоНачисленияОблагаемыеОПВ) КАК ОтОбратногоНачисленияОблагаемыеОПВ,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ОтОбратногоНачисленияОблагаемыеВОСМС) КАК ОтОбратногоНачисленияОблагаемыеВОСМС,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ОтОбратногоНачисленияОблагаемыеИПН) КАК ОтОбратногоНачисленияОблагаемыеИПН,
		|	ВТЗарегистрированныеНачисления_Выбор.ДоходНеПодлежащийНалогообложениюОПВ КАК ДоходНеПодлежащийНалогообложениюОПВ,
		|	ВТЗарегистрированныеНачисления_Выбор.ДоходНеПодлежащийНалогообложениюВОСМС КАК ДоходНеПодлежащийНалогообложениюВОСМС,
		|	ВТЗарегистрированныеНачисления_Выбор.ДоходНеПодлежащийНалогообложениюИПН КАК ДоходНеПодлежащийНалогообложениюИПН
		|ПОМЕСТИТЬ ВТЗарегистрированныеНачисления
		|ИЗ
		|	ВТЗарегистрированныеНачисления_Выбор КАК ВТЗарегистрированныеНачисления_Выбор
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТЗарегистрированныеНачисления_Выбор.Сотрудник,
		|	ВТЗарегистрированныеНачисления_Выбор.ФизическоеЛицо,
		|	ВТЗарегистрированныеНачисления_Выбор.ПериодРегистрации,
		|	ВТЗарегистрированныеНачисления_Выбор.ВидДохода,
		|	ВТЗарегистрированныеНачисления_Выбор.ДоходНеПодлежащийНалогообложениюОПВ,
		|	ВТЗарегистрированныеНачисления_Выбор.ДоходНеПодлежащийНалогообложениюВОСМС,
		|	ВТЗарегистрированныеНачисления_Выбор.ДоходНеПодлежащийНалогообложениюИПН";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТОтборыРасчетыОтОбратного");
	УничтожитьВТ.Добавить("ВТЗарегистрированныеНачисления");
	УничтожитьВТ.Добавить("ВТЗарегистрированныеНачисления_Выбор");
	
	ЗарплатаКадрыОбщиеНаборыДанных.СоздатьВТИмяРегистраСрезПоследних(
		"ПлановыеУдержания",
		МенеджерВременныхТаблиц,
		Истина,
		ЗарплатаКадрыОбщиеНаборыДанных.ОписаниеФильтраДляСоздатьВТИмяРегистра("ВТПериодыПоФизлицам", "ФизическоеЛицо"));

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	УдержанияПоВидуНачисления.ПериодРегистрации КАК ПериодРегистрации,
		|	УдержанияПоВидуНачисления.Сотрудник КАК Сотрудник,
		|	УдержанияПоВидуНачисления.ФизическоеЛицо КАК ФизическоеЛицо,
		|	УдержанияПоВидуНачисления.Организация КАК Организация,
		|	СУММА(УдержанияПоВидуНачисления.СуммаУдержаний) КАК СуммаУдержаний
		|ПОМЕСТИТЬ ВТПлановыеУдержания
		|ИЗ
		|	(ВЫБРАТЬ
		|		ОтборыРасчетыОтОбратного.ПериодРегистрации КАК ПериодРегистрации,
		|		ОтборыРасчетыОтОбратного.Сотрудник КАК Сотрудник,
		|		ПлановыеУдержания.ДокументОснование КАК ДокументОснование,
		|		ПлановыеУдержания.ФизическоеЛицо КАК ФизическоеЛицо,
		|		ПлановыеУдержания.Организация КАК Организация,
		// используем МАКСИМУМ внутри потому что таблица ВТОтборыРасчетыОтОбратногоДляУдержаний содердит ВидРасчета, 
		// который при соединении с ВТОтборыРасчетыОтОбратногоДляУдержаний дает задвоение строк и сумм (при использовании конструкции СУММА)
		|		МАКСИМУМ(ПлановыеУдержания.Размер) КАК СуммаУдержаний
		|	ИЗ
		|		ВТПлановыеУдержанияСрезПоследних КАК ПлановыеУдержания
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТОтборыРасчетыОтОбратногоДляУдержаний КАК ОтборыРасчетыОтОбратного
		|			ПО ПлановыеУдержания.Период = ОтборыРасчетыОтОбратного.ПериодРегистрации
		|				И ПлановыеУдержания.ФизическоеЛицо = ОтборыРасчетыОтОбратного.ФизическоеЛицо
		|				И ПлановыеУдержания.Организация = ОтборыРасчетыОтОбратного.ГоловнаяОрганизация
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланВидовРасчета.Начисления.ОтОбратногоКомпенсируемыеУдержания КАК НачисленияОтОбратногоКомпенсируемыеУдержания
		|			ПО (ОтборыРасчетыОтОбратного.ВидРасчета = НачисленияОтОбратногоКомпенсируемыеУдержания.Ссылка)
		|				И ПлановыеУдержания.Удержание = НачисленияОтОбратногоКомпенсируемыеУдержания.ВидРасчета
