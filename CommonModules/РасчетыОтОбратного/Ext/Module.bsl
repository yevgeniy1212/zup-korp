		// условие необходимо для корректного расчета проведенного документа 
		// в проведенном документе в ВТРегистрРасчета_Начисления будут содержаться строки с минусом по начислениям этого документа
		|	И Начисления.СторнируемыйДокумент <> &ИсключаемыйРегистратор
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТЗарегистрированныеНачисления_Выбор.Сотрудник КАК Сотрудник,
		|	ВТЗарегистрированныеНачисления_Выбор.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТЗарегистрированныеНачисления_Выбор.ПериодРегистрации КАК ПериодРегистрации,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ОтОбратногоНачисленияВсего) КАК ОтОбратногоНачисленияВсего,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ПрямыеНачисленияВсего) КАК ПрямыеНачисленияВсего,
		|	ВТЗарегистрированныеНачисления_Выбор.ВидДохода КАК ВидДохода,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ОбщаяСуммаДоходаПрямыеНачисления) КАК ОбщаяСуммаДоходаПрямыеНачисления,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ПрямыеНачисленияОблагаемыеОПВ) КАК ПрямыеНачисленияОблагаемыеОПВ,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ПрямыеНачисленияОблагаемыеВОСМС) КАК ПрямыеНачисленияОблагаемыеВОСМС,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ПрямыеНачисленияОблагаемыеИПН) КАК ПрямыеНачисленияОблагаемыеИПН,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ОтОбратногоНачисленияОблагаемыеОПВ) КАК ОтОбратногоНачисленияОблагаемыеОПВ,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ОтОбратногоНачисленияОблагаемыеВОСМС) КАК ОтОбратногоНачисленияОблагаемыеВОСМС,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ОтОбратногоНачисленияОблагаемыеИПН) КАК ОтОбратногоНачисленияОблагаемыеИПН,
		|	ВТЗарегистрированныеНачисления_Выбор.ДоходНеПодлежащийНалогообложениюОПВ КАК ДоходНеПодлежащийНалогообложениюОПВ,
		|	ВТЗарегистрированныеНачисления_Выбор.ДоходНеПодлежащийНалогообложениюВОСМС КАК ДоходНеПодлежащийНалогообложениюВОСМС,
		|	ВТЗарегистрированныеНачисления_Выбор.ДоходНеПодлежащийНалогообложениюИПН КАК ДоходНеПодлежащийНалогообложениюИПН
		|ПОМЕСТИТЬ ВТЗарегистрированныеНачисления
		|ИЗ
		|	ВТЗарегистрированныеНачисления_Выбор КАК ВТЗарегистрированныеНачисления_Выбор
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТЗарегистрированныеНачисления_Выбор.Сотрудник,
		|	ВТЗарегистрированныеНачисления_Выбор.ФизическоеЛицо,
		|	ВТЗарегистрированныеНачисления_Выбор.ПериодРегистрации,
		|	ВТЗарегистрированныеНачисления_Выбор.ВидДохода,
		|	ВТЗарегистрированныеНачисления_Выбор.ДоходНеПодлежащийНалогообложениюОПВ,
		|	ВТЗарегистрированныеНачисления_Выбор.ДоходНеПодлежащийНалогообложениюВОСМС,
		|	ВТЗарегистрированныеНачисления_Выбор.ДоходНеПодлежащийНалогообложениюИПН";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТОтборыРасчетыОтОбратного");
	УничтожитьВТ.Добавить("ВТЗарегистрированныеНачисления");
	УничтожитьВТ.Добавить("ВТЗарегистрированныеНачисления_Выбор");
	
	ЗарплатаКадрыОбщиеНаборыДанных.СоздатьВТИмяРегистраСрезПоследних(
		"ПлановыеУдержания",
		МенеджерВременныхТаблиц,
		Истина,
		ЗарплатаКадрыОбщиеНаборыДанных.ОписаниеФильтраДляСоздатьВТИмяРегистра("ВТПериодыПоФизлицам", "ФизическоеЛицо"));

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	УдержанияПоВидуНачисления.ПериодРегистрации КАК ПериодРегистрации,
		|	УдержанияПоВидуНачисления.Сотрудник КАК Сотрудник,
		|	УдержанияПоВидуНачисления.ФизическоеЛицо КАК ФизическоеЛицо,
		|	УдержанияПоВидуНачисления.Организация КАК Организация,
		|	СУММА(УдержанияПоВидуНачисления.СуммаУдержаний) КАК СуммаУдержаний
		|ПОМЕСТИТЬ ВТПлановыеУдержания
		|ИЗ
		|	(ВЫБРАТЬ
		|		ОтборыРасчетыОтОбратного.ПериодРегистрации КАК ПериодРегистрации,
		|		ОтборыРасчетыОтОбратного.Сотрудник КАК Сотрудник,
		|		ПлановыеУдержания.ДокументОснование КАК ДокументОснование,
		|		ПлановыеУдержания.ФизическоеЛицо КАК ФизическоеЛицо,
		|		ПлановыеУдержания.Организация КАК Организация,
		// используем МАКСИМУМ внутри потому что таблица ВТОтборыРасчетыОтОбратногоДляУдержаний содердит ВидРасчета, 
		// который при соединении с ВТОтборыРасчетыОтОбратногоДляУдержаний дает задвоение строк и сумм (при использовании конструкции СУММА)
		|		МАКСИМУМ(ПлановыеУдержания.Размер) КАК СуммаУдержаний
		|	ИЗ
		|		ВТПлановыеУдержанияСрезПоследних КАК ПлановыеУдержания
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТОтборыРасчетыОтОбратногоДляУдержаний КАК ОтборыРасчетыОтОбратного
		|			ПО ПлановыеУдержания.Период = ОтборыРасчетыОтОбратного.ПериодРегистрации
		|				И ПлановыеУдержания.ФизическоеЛицо = ОтборыРасчетыОтОбратного.ФизическоеЛицо
		|				И ПлановыеУдержания.Организация = ОтборыРасчетыОтОбратного.ГоловнаяОрганизация
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланВидовРасчета.Начисления.ОтОбратногоКомпенсируемыеУдержания КАК НачисленияОтОбратногоКомпенсируемыеУдержания
		|			ПО (ОтборыРасчетыОтОбратного.ВидРасчета = НачисленияОтОбратногоКомпенсируемыеУдержания.Ссылка)
		|				И ПлановыеУдержания.Удержание = НачисленияОтОбратногоКомпенсируемыеУдержания.ВидРасчета
		|	ГДЕ
		|		ПлановыеУдержания.Используется
		|		И НЕ ПлановыеУдержания.Удержание.Рассчитывается
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ОтборыРасчетыОтОбратного.ПериодРегистрации,
		|		ОтборыРасчетыОтОбратного.Сотрудник,
		|		ПлановыеУдержания.ДокументОснование,
		|		ПлановыеУдержания.ФизическоеЛицо,
		|		ПлановыеУдержания.Организация) КАК УдержанияПоВидуНачисления
		|
		|СГРУППИРОВАТЬ ПО
		|	УдержанияПоВидуНачисления.ПериодРегистрации,
		|	УдержанияПоВидуНачисления.Сотрудник,
		|	УдержанияПоВидуНачисления.ФизическоеЛицо,
		|	УдержанияПоВидуНачисления.Организация";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТОтборыРасчетыОтОбратногоДляУдержаний");
	УничтожитьВТ.Добавить("ВТПлановыеУдержанияСрезПоследних");
	УничтожитьВТ.Добавить("ВТПлановыеУдержания");
	УничтожитьВТ.Добавить("ВТПериодыПоГодам");

КонецПроцедуры

Процедура ПодготовитьДанныеДляРасчетовОтОбратногоПосле2021(МенеджерВременныхТаблиц, Организация, МесяцНачисления, УничтожитьВТ, ОкончательныйРасчетЗарплаты, ИсключаемыйРегистратор, ВременныйРегистратор)
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("ИсключаемыйРегистратор", ИсключаемыйРегистратор);
	Запрос.УстановитьПараметр("ВременныйРегистратор", ВременныйРегистратор);
	Запрос.УстановитьПараметр("МесяцНачисления", МесяцНачисления);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ОкончательныйРасчетЗарплаты", ОкончательныйРасчетЗарплаты);
	
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Начисления.ПериодРегистрации КАК Период
		|ПОМЕСТИТЬ ВТДатыПоМесяцам
		|ИЗ
		|	ВТРегистрРасчета_Начисления КАК Начисления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Начисления.ФизическоеЛицо КАК ФизическоеЛицо
		|ПОМЕСТИТЬ ВТФизическиеЛица
		|ИЗ
		|	ВТРегистрРасчета_Начисления КАК Начисления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Начисления.ПериодРегистрации КАК МесяцНалоговогоПериода,
		|	Начисления.ПериодРегистрации КАК Период,
		|	НАЧАЛОПЕРИОДА(Начисления.ПериодРегистрации, ГОД) КАК НачалоГодаНалоговогоПериода,
		|	Начисления.ФизическоеЛицо КАК ФизическоеЛицо
		|ПОМЕСТИТЬ ВТПериодыПоФизлицам
		|ИЗ
		|	ВТРегистрРасчета_Начисления КАК Начисления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Начисления.Сотрудник КАК Сотрудник
		|ПОМЕСТИТЬ ВТСотрудники
		|ИЗ
		|	ВТРегистрРасчета_Начисления КАК Начисления
		|ГДЕ
		|	Начисления.ВидРасчета.ОтОбратного
		|	И НЕ Начисления.ФиксСторно
		|	И НЕ Начисления.Сторно
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Начисления.Регистратор КАК Регистратор,
		|	Начисления.НомерСтроки КАК НомерСтроки,
		|	Начисления.Сотрудник КАК Сотрудник,
		|	Начисления.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Начисления.ВидРасчета КАК ВидРасчета,
		|	Начисления.ВидРасчета.ОчередностьРасчета КАК ОчередностьРасчета,
		|	Начисления.Результат КАК ЦелевойРазмер
		|ПОМЕСТИТЬ ВТЦелевыеРазмерыНачислений
		|ИЗ
		|	ВТРегистрРасчета_Начисления КАК Начисления
		|ГДЕ
		|	Начисления.ВидРасчета.ОтОбратного
		|	И НЕ Начисления.ФиксСторно
		|	И НЕ Начисления.Сторно
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТЦелевыеРазмерыНачислений.ОчередностьРасчета КАК ОчередностьРасчета,
		|	СУММА(ВТЦелевыеРазмерыНачислений.ЦелевойРазмер) КАК ЦелевойРазмер,
		|	ВТЦелевыеРазмерыНачислений.Сотрудник КАК Сотрудник
		|ПОМЕСТИТЬ ВТЦелевойРазмерОчередностиВЦелом
		|ИЗ
		|	ВТЦелевыеРазмерыНачислений КАК ВТЦелевыеРазмерыНачислений
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТЦелевыеРазмерыНачислений.ОчередностьРасчета,
		|	ВТЦелевыеРазмерыНачислений.Сотрудник
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(ВТЦелевыеРазмерыНачислений.ЦелевойРазмер) КАК ЦелевойРазмер,
		|	ВТЦелевыеРазмерыНачислений.Сотрудник КАК Сотрудник
		|ПОМЕСТИТЬ ВТЦелевойРазмерПоСотрудникуВЦелом
		|ИЗ
		|	ВТЦелевыеРазмерыНачислений КАК ВТЦелевыеРазмерыНачислений
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТЦелевыеРазмерыНачислений.Сотрудник
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(ВТЦелевыеРазмерыНачисленийПоДругимМестам.ЦелевойРазмер) КАК ЦелевойРазмер,
		|	ВТЦелевыеРазмерыНачислений.Сотрудник КАК Сотрудник
		|ПОМЕСТИТЬ ВТЦелевойРазмерПоДругимМестам
		|ИЗ
		|	ВТЦелевыеРазмерыНачислений КАК ВТЦелевыеРазмерыНачислений
		|	ЛЕВОЕ СОЕДИНЕНИЕ ВТЦелевыеРазмерыНачислений КАК ВТЦелевыеРазмерыНачисленийПоДругимМестам
		|		ПО ВТЦелевыеРазмерыНачислений.ФизическоеЛицо = ВТЦелевыеРазмерыНачисленийПоДругимМестам.ФизическоеЛицо 
		|			И НЕ ВТЦелевыеРазмерыНачислений.Сотрудник = ВТЦелевыеРазмерыНачисленийПоДругимМестам.Сотрудник
		|ГДЕ			
		|	НЕ ВТЦелевыеРазмерыНачисленийПоДругимМестам.Сотрудник ЕСТЬ NULL
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТЦелевыеРазмерыНачислений.Сотрудник";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТДатыПоМесяцам");
	УничтожитьВТ.Добавить("ВТФизическиеЛица");
	УничтожитьВТ.Добавить("ВТПериодыПоФизлицам");
	УничтожитьВТ.Добавить("ВТСотрудники");
	УничтожитьВТ.Добавить("ВТЦелевыеРазмерыНачислений");
	УничтожитьВТ.Добавить("ВТЦелевойРазмерОчередностиВЦелом");
	УничтожитьВТ.Добавить("ВТЦелевойРазмерПоСотрудникуВЦелом");
	УничтожитьВТ.Добавить("ВТЦелевойРазмерПоДругимМестам");
	
	ОписательТаблиц = КадровыйУчет.ОписаниеВременнойТаблицыОтборовСотрудников("ВТСотрудники");
	ЗапросКадровыеДанные = КадровыйУчет.ЗапросВТПостоянныеКадровыеДанныеСотрудников(Истина,	ОписательТаблиц, "ДатаПриема,ДатаУвольнения",, "ВТКадровыеДанныеСотрудников");
	ЗапросКадровыеДанные.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	ЗапросКадровыеДанные.Выполнить();

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода,
		|	ПериодыПоФизлицам.НачалоГодаНалоговогоПериода,
		|	ПериодыПоФизлицам.ФизическоеЛицо,
		|	КадровыеДанныеСотрудников.Сотрудник,
		|	ЕСТЬNULL(КадровыеДанныеСотрудников.ДатаПриема, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаПриема,
		|	ЕСТЬNULL(КадровыеДанныеСотрудников.ДатаУвольнения, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаУвольнения
		|ПОМЕСТИТЬ ВТКадровыеДанныеСотрудниковПоПериодам
		|ИЗ
		|	ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТКадровыеДанныеСотрудников КАК КадровыеДанныеСотрудников
		|		ПО ПериодыПоФизлицам.ФизическоеЛицо = КадровыеДанныеСотрудников.ФизическоеЛицо
		|			И (НАЧАЛОПЕРИОДА(ПериодыПоФизлицам.МесяцНалоговогоПериода, МЕСЯЦ) >= НАЧАЛОПЕРИОДА(КадровыеДанныеСотрудников.ДатаПриема, МЕСЯЦ))
		|			И (ВЫБОР
		|				КОГДА КадровыеДанныеСотрудников.ДатаУвольнения <> ДАТАВРЕМЯ(1, 1, 1)
		|					ТОГДА НАЧАЛОПЕРИОДА(ПериодыПоФизлицам.МесяцНалоговогоПериода, МЕСЯЦ) <= НАЧАЛОПЕРИОДА(КадровыеДанныеСотрудников.ДатаУвольнения, МЕСЯЦ)
		|				ИНАЧЕ ИСТИНА
		|			КОНЕЦ)";
	
	Запрос.Выполнить(); 
	УничтожитьВТ.Добавить("ВТКадровыеДанныеСотрудников");
	УничтожитьВТ.Добавить("ВТКадровыеДанныеСотрудниковПоПериодам");
	
	// Налогообложение начислений
	УчетНалоговВзносовОтчислений.СоздатьВТНалогообложениеНачисленийПоПериодам(МенеджерВременныхТаблиц);
