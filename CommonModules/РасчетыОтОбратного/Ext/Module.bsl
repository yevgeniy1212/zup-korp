
#Область ПрограммныйИнтерфейс

Процедура ПередЗаписьюНачисления(Объект) Экспорт
	
	КатегорииНачисленийНеавтоматизированныеВРасчетахОтОбратного = КатегорииНачисленийНеавтоматизированныеВРасчетахОтОбратного();
	
	Если Объект.ОтОбратного
		И (НЕ Объект.Рассчитывается 
		ИЛИ Объект.Показатели.Количество() = 0)  Тогда
		
		Объект.ОтОбратного = Ложь;
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Признак расчета способом ""от обратного"" снят. Для расчетов ""от обратного"" необходимо использовать произвольную формулу с показателями расчета.'"));
		
	ИначеЕсли Объект.ОтОбратного
		И НЕ КатегорииНачисленийНеавтоматизированныеВРасчетахОтОбратного.Найти(Объект.КатегорияНачисленияИлиНеоплаченногоВремени) = Неопределено Тогда
		
		Объект.ОтОбратного = Ложь;
		
		ТекстСообщения = НСтр("ru = 'Признак расчета способом ""от обратного"" снят. Для вида начисления ""%1"" расчет способом ""от обратного"" не автоматизирован.'");
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, Объект.КатегорияНачисленияИлиНеоплаченногоВремени);
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		
	КонецЕсли;
	
	Если Объект.ОтОбратного И Объект.ТребуетсяРасчетБазы
		И (Объект.Рассчитывается 
		ИЛИ Объект.Показатели.Количество() > 0) Тогда
		
		Для каждого СтрокаВидаРасчета Из Объект.БазовыеВидыРасчета Цикл
			
			Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаВидаРасчета.ВидРасчета, "ОтОбратного") Тогда
				
				ТекстСообщения = НСтр("ru = 'Для базового начисления ""%1"", в качестве расчетной базы будет рассчитываться сумма ""на руки"".'");
				ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, СтрокаВидаРасчета.ВидРасчета);
				
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
				
			КонецЕсли;	
			
		КонецЦикла;	
	КонецЕсли;

	Если Объект.ОтОбратного Тогда
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	Зависимые.Ссылка КАК ВидРасчета
		|ИЗ
		|	ПланВидовРасчета.Начисления.ВедущиеВидыРасчета КАК Зависимые
		|ГДЕ
		|	Зависимые.ВидРасчета = &ВидРасчета
		|
		|УПОРЯДОЧИТЬ ПО
		|	Зависимые.Ссылка.Наименование";
		
		Запрос = Новый Запрос(ТекстЗапроса);
		Запрос.УстановитьПараметр("ВидРасчета", Объект.Ссылка);
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Выборка.ВидРасчета, "ОтОбратного")
				И ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Выборка.ВидРасчета, "ТребуетсяРасчетБазы") Тогда				
				ТекстСообщения = НСтр("ru = 'В расчетной базе начисления ""%1"" данное начисление будет учтено исходя из суммы ""на руки"".'");
				ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, Выборка.ВидРасчета);
				
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	ЗаполнитьОбязательныеПоказателиОтОбратного(Объект);
	
КонецПроцедуры

Процедура РассчитатьНачисленияОтОбратного(СтрокиРасчета, МенеджерВременныхТаблиц, Организация, МесяцНачисления, ОкончательныйРасчетЗарплаты, ИсключаемыйРегистратор, ВременныйРегистратор, КэшСтрокиНабораНачисленияПоИдентификаторам = Неопределено) Экспорт
	
	Если СтрокиРасчета.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
		
	Если МесяцНачисления >= Дата(2018,1,1) Тогда
		РассчитатьНачисленияОтОбратногоПосле2018(СтрокиРасчета, МенеджерВременныхТаблиц, Организация, МесяцНачисления, ОкончательныйРасчетЗарплаты, ИсключаемыйРегистратор, ВременныйРегистратор, КэшСтрокиНабораНачисленияПоИдентификаторам);
	Иначе	
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'В документе содержатся сотрудники, начисления которых рассчитываются от обратного (рассчеты не подерживаются в периодах до 2018 года)'"));
		Возврат;
	КонецЕсли;
	
КонецПроцедуры

// Настройки начислений

Процедура ОбновитьФормуПоНастройкамОтОбратного(Форма) Экспорт

	ВыводитьСообщениеОбОшибке = Ложь;
	
	Если Форма.ИспользоватьРасчетыОтОбратного Тогда
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("АктуальнаяДата", ТекущаяДатаСеанса());
		
		ФОИспользоватьШтатноеРасписание = ПолучитьФункциональнуюОпцию("ИспользоватьШтатноеРасписание");
		
		Если ФОИспользоватьШтатноеРасписание Тогда
			
			Запрос.Текст = Запрос.Текст + "ВЫБРАТЬ
			                              |	ШтатноеРасписание.Наименование КАК ПозицияШтатногоРасписания,
			                              |	ШтатноеРасписание.Ссылка КАК Ссылка
			                              |ИЗ
			                              |	Справочник.ШтатноеРасписание.Начисления КАК ШтатноеРасписаниеНачисления
			                              |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ШтатноеРасписание КАК ШтатноеРасписание
			                              |		ПО ШтатноеРасписаниеНачисления.Ссылка = ШтатноеРасписание.Ссылка
			                              |ГДЕ
			                              |	ШтатноеРасписаниеНачисления.Начисление В
			                              |			(ВЫБРАТЬ
			                              |				Начисления.Ссылка КАК Ссылка
			                              |			ИЗ
			                              |				ПланВидовРасчета.Начисления КАК Начисления
			                              |			ГДЕ
			                              |				Начисления.ОтОбратного)
			                              |	И НЕ ШтатноеРасписание.ПометкаУдаления
			                              |	И ШтатноеРасписание.Утверждена
			                              |	И НЕ ШтатноеРасписание.Закрыта";
			
			РезультатыЗапросаПоШтатномуРасписанию = Запрос.Выполнить();
			
		КонецЕсли;
			
		Запрос.Текст =
			"ВЫБРАТЬ
			|	ПлановыеНачисленияСрезПоследних.Начисление КАК Начисление,
			|	МАКСИМУМ(ПлановыеНачисленияСрезПоследних.ДействуетДо) КАК ДействуетДо
			|ПОМЕСТИТЬ ВТНачисления
			|ИЗ
			|	РегистрСведений.ПлановыеНачисления.СрезПоследних(
			|			&АктуальнаяДата,
			|			Начисление В
			|				(ВЫБРАТЬ
			|					Начисления.Ссылка КАК Ссылка
			|				ИЗ
			|					ПланВидовРасчета.Начисления КАК Начисления
			|				ГДЕ
			|					Начисления.ОтОбратного)) КАК ПлановыеНачисленияСрезПоследних
			|ГДЕ
			|	ПлановыеНачисленияСрезПоследних.Используется
			|
			|СГРУППИРОВАТЬ ПО
			|	ПлановыеНачисленияСрезПоследних.Начисление
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ ПЕРВЫЕ 1
			|	ИсользуемыеНачисленияОтОбратного.Начисление КАК Начисление
			|ИЗ
			|	(ВЫБРАТЬ ПЕРВЫЕ 1
			|		ВТНачисления.Начисление КАК Начисление
			|	ИЗ
			|		ВТНачисления КАК ВТНачисления
			|	ГДЕ
			|		ВТНачисления.ДействуетДо = ДАТАВРЕМЯ(1, 1, 1)
			|	
			|	ОБЪЕДИНИТЬ ВСЕ
			|	
			|	ВЫБРАТЬ ПЕРВЫЕ 1
			|		ВТНачисления.Начисление
			|	ИЗ
			|		ВТНачисления КАК ВТНачисления
			|	ГДЕ
			|		ВТНачисления.ДействуетДо <> ДАТАВРЕМЯ(1, 1, 1)
			|		И ВТНачисления.ДействуетДо >= &АктуальнаяДата) КАК ИсользуемыеНачисленияОтОбратного";
		
		РезультатыЗапросаПоПлановымНачислениям = Запрос.Выполнить();
		
		Если ФОИспользоватьШтатноеРасписание И НЕ РезультатыЗапросаПоШтатномуРасписанию.Пустой()
			Или НЕ РезультатыЗапросаПоПлановымНачислениям.Пустой() Тогда
			
			ВыводитьСообщениеОбОшибке = Истина;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если Форма.ИспользоватьРасчетыОтОбратного И ВыводитьСообщениеОбОшибке Тогда
		Форма.Элементы.ИспользоватьРасчетыОтОбратного.Доступность = Ложь;
		Форма.Элементы.ГруппаКомментарийИспользоватьРасчетОтОбратного.Видимость = Истина;
	Иначе
		Форма.Элементы.ИспользоватьРасчетыОтОбратного.Доступность = Истина;
		Форма.Элементы.ГруппаКомментарийИспользоватьРасчетОтОбратного.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Процедура УстановитьИспользованиеРасчетовОтОбратного(НастройкиРасчетаЗарплаты) Экспорт
	
	ИспользоватьРасчетыОтОбратного = НастройкиРасчетаЗарплаты.ИспользоватьРасчетыОтОбратного;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Начисления.Ссылка КАК Ссылка
		|ИЗ
		|	ПланВидовРасчета.Начисления КАК Начисления
		|ГДЕ
		|	Начисления.ОтОбратного
		|	И НЕ Начисления.ВАрхиве = &ВАрхиве";
	
	Запрос.УстановитьПараметр("ВАрхиве", НЕ ИспользоватьРасчетыОтОбратного);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		РасчетОтОбратного = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		РасчетОтОбратного.ВАрхиве = НЕ ИспользоватьРасчетыОтОбратного;
		РасчетОтОбратного.Записать();
		
	КонецЦикла;	
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаполнитьОбязательныеПоказателиОтОбратного(Объект) Экспорт

	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьРасчетыОтОбратного") Тогда
		Возврат;
	КонецЕсли;
	
	Если Объект.ОтОбратного Тогда

		ДобавитьОбязательныйПоказательОтОбратного(Объект, Справочники.ПоказателиРасчетаЗарплаты.ОтОбратногоСуммаНаРуки);
		
		ОтборВидаРасчета = Новый Структура("ВидРасчета", Перечисления.ВидыНалоговВзносовОтчислений.ОПВ);
		МассивВидаРасчета = Объект.ОтОбратногоКомпенсируемыеУдержания.НайтиСтроки(ОтборВидаРасчета);
		
		Если МассивВидаРасчета.Количество() > 0 Тогда
			ДобавитьОбязательныйПоказательОтОбратного(Объект, Справочники.ПоказателиРасчетаЗарплаты.ОтОбратногоОПВ);
		Иначе
			УдалитьОбязательныйПоказательОтОбратного(Объект, Справочники.ПоказателиРасчетаЗарплаты.ОтОбратногоОПВ);
		КонецЕсли;
			
		ОтборВидаРасчета = Новый Структура("ВидРасчета", Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС);
		МассивВидаРасчета = Объект.ОтОбратногоКомпенсируемыеУдержания.НайтиСтроки(ОтборВидаРасчета);
		
		Если МассивВидаРасчета.Количество() > 0 Тогда
			ДобавитьОбязательныйПоказательОтОбратного(Объект, Справочники.ПоказателиРасчетаЗарплаты.ОтОбратногоВОСМС);
		Иначе
			УдалитьОбязательныйПоказательОтОбратного(Объект, Справочники.ПоказателиРасчетаЗарплаты.ОтОбратногоВОСМС);
		КонецЕсли;
			
		ОтборВидаРасчета = Новый Структура("ВидРасчета", Перечисления.ВидыНалоговВзносовОтчислений.ИПН);
		МассивВидаРасчета = Объект.ОтОбратногоКомпенсируемыеУдержания.НайтиСтроки(ОтборВидаРасчета);
		
		Если МассивВидаРасчета.Количество() > 0 Тогда
			ДобавитьОбязательныйПоказательОтОбратного(Объект, Справочники.ПоказателиРасчетаЗарплаты.ОтОбратногоИПН);
		Иначе
			УдалитьОбязательныйПоказательОтОбратного(Объект, Справочники.ПоказателиРасчетаЗарплаты.ОтОбратногоИПН);
		КонецЕсли;
		
		ЕстьПоказателиУдержания = Ложь;
		
		// если присутствует хоть одно удержание
		Для Каждого СтрокаВидаРасчета Из Объект.ОтОбратногоКомпенсируемыеУдержания Цикл
			Если ТипЗнч(СтрокаВидаРасчета.ВидРасчета) = Тип("ПланВидовРасчетаСсылка.Удержания") Тогда 
				ДобавитьОбязательныйПоказательОтОбратного(Объект, Справочники.ПоказателиРасчетаЗарплаты.ОтОбратногоУдержания);
				ЕстьПоказателиУдержания = Истина;
			КонецЕсли;
		КонецЦикла;
		
		Если НЕ ЕстьПоказателиУдержания Тогда
			УдалитьОбязательныйПоказательОтОбратного(Объект, Справочники.ПоказателиРасчетаЗарплаты.ОтОбратногоУдержания);
		КонецЕсли;
		
	Иначе
		МассивУдаляемыхСтрок = Новый Массив;
		Для Каждого СтрокаПоказателя Из Объект.Показатели Цикл
			Если СтрокаПоказателя.Показатель = Справочники.ПоказателиРасчетаЗарплаты.ОтОбратногоСуммаНаРуки
				ИЛИ СтрокаПоказателя.Показатель = Справочники.ПоказателиРасчетаЗарплаты.ОтОбратногоИПН
				ИЛИ СтрокаПоказателя.Показатель = Справочники.ПоказателиРасчетаЗарплаты.ОтОбратногоОПВ
				ИЛИ СтрокаПоказателя.Показатель = Справочники.ПоказателиРасчетаЗарплаты.ОтОбратногоУдержания
				ИЛИ СтрокаПоказателя.Показатель = Справочники.ПоказателиРасчетаЗарплаты.ОтОбратногоВОСМС Тогда
				МассивУдаляемыхСтрок.Добавить(СтрокаПоказателя);
			КонецЕсли;
		КонецЦикла;
		
		Для Каждого СтрокаПоказателя Из МассивУдаляемыхСтрок Цикл
			Объект.Показатели.Удалить(СтрокаПоказателя);
		КонецЦикла;
		
		Объект.ОтОбратногоКомпенсируемыеУдержания.Очистить();
	КонецЕсли;
	
КонецПроцедуры

// Настройки начислений

Процедура ДобавитьОбязательныйПоказательОтОбратного(Объект, ОбязательныйПоказатель)
	
	СтруктураПоиска = Новый Структура("Показатель", ОбязательныйПоказатель);
	
	Если Объект.Показатели.НайтиСтроки(СтруктураПоиска).Количество() = 0 Тогда 
		
		СтрокаПоказателя = Объект.Показатели.Добавить();
		СтрокаПоказателя.Показатель = ОбязательныйПоказатель;
		СтрокаПоказателя.ИспользоватьПриРасчете = Истина;
		
	КонецЕсли;

КонецПроцедуры	

Процедура УдалитьОбязательныйПоказательОтОбратного(Объект, ОбязательныйПоказатель)
	
	СтруктураПоиска = Новый Структура("Показатель", ОбязательныйПоказатель);
	
	СтрокиОбязательногоПоказателя = Объект.Показатели.НайтиСтроки(СтруктураПоиска);
	
	Если СтрокиОбязательногоПоказателя.Количество() > 0 Тогда 
		
		Для Каждого СтрокаПоказателя Из СтрокиОбязательногоПоказателя Цикл
			
			Объект.Показатели.Удалить(СтрокаПоказателя);
			
		КонецЦикла;
		
	КонецЕсли;

КонецПроцедуры	

// Расчет начислений

Процедура РассчитатьНачисленияОтОбратногоПосле2018(СтрокиРасчета, МенеджерВременныхТаблиц, Организация, МесяцНачисления, ОкончательныйРасчетЗарплаты, ИсключаемыйРегистратор, ВременныйРегистратор, КэшСтрокиНабораНачисленияПоИдентификаторам = Неопределено)
	
	УничтожитьВТ = Новый Массив;

	ПодготовитьДанныеДляРасчетовОтОбратного(МенеджерВременныхТаблиц, Организация, МесяцНачисления, УничтожитьВТ, ОкончательныйРасчетЗарплаты, ИсключаемыйРегистратор, ВременныйРегистратор);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Начисления.ВидРасчета.ОчередностьРасчета КАК ОчередностьРасчета,
		|	МАКСИМУМ(Начисления.ВидРасчета.ОтОбратного) КАК ОтОбратного
		|ИЗ
		|	ВТРегистрРасчета_Начисления КАК Начисления
		|ГДЕ
		|	НЕ Начисления.ФиксСторно
		|	И НЕ Начисления.Сторно
		|
		|СГРУППИРОВАТЬ ПО
		|	Начисления.ВидРасчета.ОчередностьРасчета
		|
		|УПОРЯДОЧИТЬ ПО
		|	ОчередностьРасчета";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	РасчитанныеНачисленияПредыдущихИтераций = Новый Соответствие;
	
	НачисленияСКорректировкойДохода = Новый ТаблицаЗначений;
	НачисленияСКорректировкойДохода.Колонки.Добавить("Сотрудник", Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
	НачисленияСКорректировкойДохода.Колонки.Добавить("ИдентификаторСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(7, 0)));
	НачисленияСКорректировкойДохода.Колонки.Добавить("ВидРасчета", Новый ОписаниеТипов("ПланВидовРасчетаСсылка.Начисления"));
	НачисленияСКорректировкойДохода.Колонки.Добавить("ПересчитатьНачисление", Новый ОписаниеТипов("Булево"));
	НачисленияСКорректировкойДохода.Колонки.Добавить("СуммаПримененногоВычета", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)));	
	НачисленияСКорректировкойДохода.Индексы.Добавить("ИдентификаторСтроки");	
	НачисленияСКорректировкойДохода.Индексы.Добавить("Сотрудник");	
	
	Пока Выборка.Следующий() Цикл
		Если НЕ Выборка.ОтОбратного Тогда
			Продолжить;
		КонецЕсли;
		
	    // рассчитать начисления очередности
		РассчитатьНачисленияОчередности(МесяцНачисления, ОкончательныйРасчетЗарплаты, СтрокиРасчета, МенеджерВременныхТаблиц, Выборка.ОчередностьРасчета, РасчитанныеНачисленияПредыдущихИтераций, НачисленияСКорректировкойДохода, , Организация, КэшСтрокиНабораНачисленияПоИдентификаторам);
		
	КонецЦикла;
	
	Если ОкончательныйРасчетЗарплаты И НачисленияСКорректировкойДохода.НайтиСтроки(Новый Структура("ПересчитатьНачисление", Истина)).Количество() > 0 Тогда
		
	    // рассчитать начисления с превышением по корректировкам дохода
		РассчитатьНачисленияОчередности(МесяцНачисления, ОкончательныйРасчетЗарплаты, СтрокиРасчета, МенеджерВременныхТаблиц, -1, РасчитанныеНачисленияПредыдущихИтераций, НачисленияСКорректировкойДохода, Истина, Организация, КэшСтрокиНабораНачисленияПоИдентификаторам);
	КонецЕсли;
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
КонецПроцедуры

Процедура ПодготовитьДанныеДляРасчетовОтОбратного(МенеджерВременныхТаблиц, Организация, МесяцНачисления, УничтожитьВТ, ОкончательныйРасчетЗарплаты, ИсключаемыйРегистратор, ВременныйРегистратор)
    
    Если МесяцНачисления >= Дата(2026,1,1) Тогда
        ПодготовитьДанныеДляРасчетовОтОбратногоПосле2026(МенеджерВременныхТаблиц, Организация, МесяцНачисления, УничтожитьВТ, ОкончательныйРасчетЗарплаты, ИсключаемыйРегистратор, ВременныйРегистратор);
    ИначеЕсли МесяцНачисления >= Дата(2023,1,1) Тогда
        ПодготовитьДанныеДляРасчетовОтОбратногоПосле2023(МенеджерВременныхТаблиц, Организация, МесяцНачисления, УничтожитьВТ, ОкончательныйРасчетЗарплаты, ИсключаемыйРегистратор, ВременныйРегистратор);
    ИначеЕсли МесяцНачисления >= Дата(2022,7,1) Тогда
        ПодготовитьДанныеДляРасчетовОтОбратногоПосле072022(МенеджерВременныхТаблиц, Организация, МесяцНачисления, УничтожитьВТ, ОкончательныйРасчетЗарплаты, ИсключаемыйРегистратор, ВременныйРегистратор);
    ИначеЕсли МесяцНачисления >= Дата(2021,1,1) Тогда
        ПодготовитьДанныеДляРасчетовОтОбратногоПосле2021(МенеджерВременныхТаблиц, Организация, МесяцНачисления, УничтожитьВТ, ОкончательныйРасчетЗарплаты, ИсключаемыйРегистратор, ВременныйРегистратор);
    Иначе
        ПодготовитьДанныеДляРасчетовОтОбратногоДо2021(МенеджерВременныхТаблиц, Организация, МесяцНачисления, УничтожитьВТ, ОкончательныйРасчетЗарплаты, ИсключаемыйРегистратор, ВременныйРегистратор);
    КонецЕсли;

КонецПроцедуры

Процедура ПодготовитьДанныеДляРасчетовОтОбратногоДо2021(МенеджерВременныхТаблиц, Организация, МесяцНачисления, УничтожитьВТ, ОкончательныйРасчетЗарплаты, ИсключаемыйРегистратор, ВременныйРегистратор)
	
	Запрос = Новый Запрос;
	
	Запрос.УстановитьПараметр("ИсключаемыйРегистратор", ИсключаемыйРегистратор);
	Запрос.УстановитьПараметр("ВременныйРегистратор", ВременныйРегистратор);
	Запрос.УстановитьПараметр("МесяцНачисления", МесяцНачисления);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ОкончательныйРасчетЗарплаты", ОкончательныйРасчетЗарплаты);
	
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Начисления.ПериодРегистрации КАК Период
		|ПОМЕСТИТЬ ВТДатыПоМесяцам
		|ИЗ
		|	ВТРегистрРасчета_Начисления КАК Начисления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Начисления.ФизическоеЛицо КАК ФизическоеЛицо
		|ПОМЕСТИТЬ ВТФизическиеЛица
		|ИЗ
		|	ВТРегистрРасчета_Начисления КАК Начисления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Начисления.ПериодРегистрации КАК МесяцНалоговогоПериода,
		|	Начисления.ПериодРегистрации КАК Период,
		|	НАЧАЛОПЕРИОДА(Начисления.ПериодРегистрации, ГОД) КАК НачалоГодаНалоговогоПериода,
		|	Начисления.ФизическоеЛицо КАК ФизическоеЛицо
		|ПОМЕСТИТЬ ВТПериодыПоФизлицам
		|ИЗ
		|	ВТРегистрРасчета_Начисления КАК Начисления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Начисления.Сотрудник КАК Сотрудник
		|ПОМЕСТИТЬ ВТСотрудники
		|ИЗ
		|	ВТРегистрРасчета_Начисления КАК Начисления
		|ГДЕ
		|	Начисления.ВидРасчета.ОтОбратного
		|	И НЕ Начисления.ФиксСторно
		|	И НЕ Начисления.Сторно
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Начисления.Регистратор КАК Регистратор,
		|	Начисления.НомерСтроки КАК НомерСтроки,
		|	Начисления.Сотрудник КАК Сотрудник,
		|	Начисления.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Начисления.ВидРасчета КАК ВидРасчета,
		|	Начисления.ВидРасчета.ОчередностьРасчета КАК ОчередностьРасчета,
		|	Начисления.Результат КАК ЦелевойРазмер
		|ПОМЕСТИТЬ ВТЦелевыеРазмерыНачислений
		|ИЗ
		|	ВТРегистрРасчета_Начисления КАК Начисления
		|ГДЕ
		|	Начисления.ВидРасчета.ОтОбратного
		|	И НЕ Начисления.ФиксСторно
		|	И НЕ Начисления.Сторно
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТЦелевыеРазмерыНачислений.ОчередностьРасчета КАК ОчередностьРасчета,
		|	СУММА(ВТЦелевыеРазмерыНачислений.ЦелевойРазмер) КАК ЦелевойРазмер,
		|	ВТЦелевыеРазмерыНачислений.Сотрудник КАК Сотрудник
		|ПОМЕСТИТЬ ВТЦелевойРазмерОчередностиВЦелом
		|ИЗ
		|	ВТЦелевыеРазмерыНачислений КАК ВТЦелевыеРазмерыНачислений
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТЦелевыеРазмерыНачислений.ОчередностьРасчета,
		|	ВТЦелевыеРазмерыНачислений.Сотрудник
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(ВТЦелевыеРазмерыНачислений.ЦелевойРазмер) КАК ЦелевойРазмер,
		|	ВТЦелевыеРазмерыНачислений.Сотрудник КАК Сотрудник
		|ПОМЕСТИТЬ ВТЦелевойРазмерПоСотрудникуВЦелом
		|ИЗ
		|	ВТЦелевыеРазмерыНачислений КАК ВТЦелевыеРазмерыНачислений
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТЦелевыеРазмерыНачислений.Сотрудник";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТДатыПоМесяцам");
	УничтожитьВТ.Добавить("ВТФизическиеЛица");
	УничтожитьВТ.Добавить("ВТПериодыПоФизлицам");
	УничтожитьВТ.Добавить("ВТСотрудники");
	УничтожитьВТ.Добавить("ВТЦелевыеРазмерыНачислений");
	УничтожитьВТ.Добавить("ВТЦелевойРазмерОчередностиВЦелом");
	УничтожитьВТ.Добавить("ВТЦелевойРазмерПоСотрудникуВЦелом");
	
	ОписательТаблиц = КадровыйУчет.ОписаниеВременнойТаблицыОтборовСотрудников("ВТСотрудники");
	ЗапросКадровыеДанные = КадровыйУчет.ЗапросВТПостоянныеКадровыеДанныеСотрудников(Истина,	ОписательТаблиц, "ДатаПриема,ДатаУвольнения",, "ВТКадровыеДанныеСотрудников");
	ЗапросКадровыеДанные.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	ЗапросКадровыеДанные.Выполнить();

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода,
		|	ПериодыПоФизлицам.НачалоГодаНалоговогоПериода,
		|	ПериодыПоФизлицам.ФизическоеЛицо,
		|	КадровыеДанныеСотрудников.Сотрудник,
		|	ЕСТЬNULL(КадровыеДанныеСотрудников.ДатаПриема, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаПриема,
		|	ЕСТЬNULL(КадровыеДанныеСотрудников.ДатаУвольнения, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаУвольнения
		|ПОМЕСТИТЬ ВТКадровыеДанныеСотрудниковПоПериодам
		|ИЗ
		|	ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТКадровыеДанныеСотрудников КАК КадровыеДанныеСотрудников
		|		ПО ПериодыПоФизлицам.ФизическоеЛицо = КадровыеДанныеСотрудников.ФизическоеЛицо
		|			И (НАЧАЛОПЕРИОДА(ПериодыПоФизлицам.МесяцНалоговогоПериода, МЕСЯЦ) >= НАЧАЛОПЕРИОДА(КадровыеДанныеСотрудников.ДатаПриема, МЕСЯЦ))
		|			И (ВЫБОР
		|				КОГДА КадровыеДанныеСотрудников.ДатаУвольнения <> ДАТАВРЕМЯ(1, 1, 1)
		|					ТОГДА НАЧАЛОПЕРИОДА(ПериодыПоФизлицам.МесяцНалоговогоПериода, МЕСЯЦ) <= НАЧАЛОПЕРИОДА(КадровыеДанныеСотрудников.ДатаУвольнения, МЕСЯЦ)
		|				ИНАЧЕ ИСТИНА
		|			КОНЕЦ)";
	
	Запрос.Выполнить(); 
	УничтожитьВТ.Добавить("ВТКадровыеДанныеСотрудников");
	УничтожитьВТ.Добавить("ВТКадровыеДанныеСотрудниковПоПериодам");
	
	// Налогообложение начислений
	УчетНалоговВзносовОтчислений.СоздатьВТНалогообложениеНачисленийПоПериодам(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТНалогообложениеНачислений");
	
	// Таблица ВТНакопленныеДанныеПоВычетам
	УчетНалоговВзносовОтчислений.СоздатьВТРазмерыМЗППоПериодам(МенеджерВременныхТаблиц);
	УчетНалоговВзносовОтчислений.СоздатьВТРазмерыМРППоПериодам(МенеджерВременныхТаблиц);
	УчетНалоговВзносовОтчислений.СоздатьВТНакопленныеДанныеПоВычетам(Организация, ИсключаемыйРегистратор, МенеджерВременныхТаблиц, НачалоМесяца(МесяцНачисления), КонецМесяца(МесяцНачисления), Истина, Истина); 
	УничтожитьВТ.Добавить("ВТРазмерыМЗППоПериодам");
	УничтожитьВТ.Добавить("ВТРазмерыМРППоПериодам");
	УничтожитьВТ.Добавить("ВТНакопленныеДанныеПоВычетам");
	УничтожитьВТ.Добавить("ВТВычетыПримененныеУДругогоРаботодателя");
    
   	// Статусы физлиц
	УчетНалоговВзносовОтчислений.СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");

	// Таблица ВТДанныеДляРасчетаВычетовИПН
	УчетНалоговВзносовОтчислений.СоздатьВТДанныеДляРасчетаВычетовИПН(МенеджерВременныхТаблиц, Организация, , МесяцНачисления);
	УничтожитьВТ.Добавить("ВТДанныеДляРасчетаВычетовИПН");
	УничтожитьВТ.Добавить("ВТНастройкиВычетовПоВидамДохода");
	УничтожитьВТ.Добавить("ВТИсчисленныеОПВ");
	Если НЕ ЗарплатаКадрыРКПовтИсп.ПрименятьКорректировкуПрочихНалоговВзносовОтчислений(ЗарплатаКадрыПовтИсп.ГоловнаяОрганизация(Организация), МесяцНачисления) Тогда
		УничтожитьВТ.Добавить("ВТИсчисленныеВОСМС");
	КонецЕсли;
	
	Запрос.Текст = "ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(ДоходыПредыдущегоМестаРаботы.МесяцНалоговогоПериода, МЕСЯЦ) КАК МесяцНалоговогоПериода,
		|	ДоходыПредыдущегоМестаРаботы.ФизическоеЛицо,
		|	СУММА(ДоходыПредыдущегоМестаРаботы.ВОСМС) КАК ВОСМС
		|ПОМЕСТИТЬ ВТДанныеДругогоРаботодателя
		|ИЗ
		|	РегистрСведений.ДоходыПредыдущегоМестаРаботы КАК ДоходыПредыдущегоМестаРаботы
		|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ПО ПериодыПоФизлицам.МесяцНалоговогоПериода >= ДоходыПредыдущегоМестаРаботы.МесяцНалоговогоПериода
		|			И ПериодыПоФизлицам.ФизическоеЛицо = ДоходыПредыдущегоМестаРаботы.ФизическоеЛицо
		|ГДЕ
		|	ДоходыПредыдущегоМестаРаботы.Организация = &Организация
		|
		|СГРУППИРОВАТЬ ПО
		|	НАЧАЛОПЕРИОДА(ДоходыПредыдущегоМестаРаботы.МесяцНалоговогоПериода, МЕСЯЦ),
		|	ДоходыПредыдущегоМестаРаботы.ФизическоеЛицо
		|";
	
	Запрос.Выполнить(); 
	УничтожитьВТ.Добавить("ВТДанныеДругогоРаботодателя");

	// Исключаемые лица
	УчетНалоговВзносовОтчислений.СоздатьВТИсключаемыеФизическиеЛицаПриРасчетеОПВ(МенеджерВременныхТаблиц, МесяцНачисления);
	УчетНалоговВзносовОтчислений.СоздатьВТИсключаемыеЛицаОСМС(МенеджерВременныхТаблиц, "ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеОПВ");
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС");

	// Таблица ВТПериодыПоГодам: список налоговых периодов (в виде даты начала года), в которых выполняется расчет.
