		|		ИНАЧЕ 0
		|	КОНЕЦ КАК ОбщаяСуммаДоходаПрямыеНачисления,
		|	ЕСТЬNULL(НалогообложениеНачислений.ДоходНеПодлежащийНалогообложениюОПВ, ЗНАЧЕНИЕ(Справочник.ДоходыНеПодлежащиеНалогообложениюЧастично.ПустаяСсылка)),
		|	ЕСТЬNULL(НалогообложениеНачислений.ДоходНеПодлежащийНалогообложениюВОСМС, ЗНАЧЕНИЕ(Справочник.ДоходыНеПодлежащиеНалогообложениюЧастично.ПустаяСсылка)),
		|	ЕСТЬNULL(НалогообложениеНачислений.ДоходНеПодлежащийНалогообложениюИПН, ЗНАЧЕНИЕ(Справочник.ДоходыНеПодлежащиеНалогообложениюЧастично.ПустаяСсылка)),
		|	0,
		|	0
		|ИЗ
		|	ВТРегистрРасчета_Начисления КАК Начисления
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНалогообложениеНачислений КАК НалогообложениеНачислений
		|		ПО Начисления.ВидРасчета = НалогообложениеНачислений.Начисление
		|		И Начисления.ПериодРегистрации = НалогообложениеНачислений.МесяцналоговогоПериода
		|ГДЕ
		|	Начисления.Регистратор = &ВременныйРегистратор
		|	И (НЕ Начисления.ФиксСторно
		|			И НЕ Начисления.Сторно
		|			И НЕ Начисления.ПериодДействия < &МесяцНачисления)
		// условие необходимо для корректного расчета проведенного документа 
		// в проведенном документе в ВТРегистрРасчета_Начисления будут содержаться строки с минусом по начислениям этого документа
		|	И Начисления.СторнируемыйДокумент <> &ИсключаемыйРегистратор
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТЗарегистрированныеНачисления_Выбор.Сотрудник КАК Сотрудник,
		|	ВТЗарегистрированныеНачисления_Выбор.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТЗарегистрированныеНачисления_Выбор.ПериодРегистрации КАК ПериодРегистрации,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ОтОбратногоНачисленияВсего) КАК ОтОбратногоНачисленияВсего,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ПрямыеНачисленияВсего) КАК ПрямыеНачисленияВсего,
		|	ВТЗарегистрированныеНачисления_Выбор.ВидДохода КАК ВидДохода,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ОбщаяСуммаДоходаПрямыеНачисления) КАК ОбщаяСуммаДоходаПрямыеНачисления,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ПрямыеНачисленияОблагаемыеОПВ) КАК ПрямыеНачисленияОблагаемыеОПВ,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ПрямыеНачисленияОблагаемыеВОСМС) КАК ПрямыеНачисленияОблагаемыеВОСМС,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ПрямыеНачисленияОблагаемыеИПН) КАК ПрямыеНачисленияОблагаемыеИПН,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ОтОбратногоНачисленияОблагаемыеОПВ) КАК ОтОбратногоНачисленияОблагаемыеОПВ,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ОтОбратногоНачисленияОблагаемыеВОСМС) КАК ОтОбратногоНачисленияОблагаемыеВОСМС,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ОтОбратногоНачисленияОблагаемыеИПН) КАК ОтОбратногоНачисленияОблагаемыеИПН,
		|	ВТЗарегистрированныеНачисления_Выбор.ДоходНеПодлежащийНалогообложениюОПВ КАК ДоходНеПодлежащийНалогообложениюОПВ,
		|	ВТЗарегистрированныеНачисления_Выбор.ДоходНеПодлежащийНалогообложениюВОСМС КАК ДоходНеПодлежащийНалогообложениюВОСМС,
		|	ВТЗарегистрированныеНачисления_Выбор.ДоходНеПодлежащийНалогообложениюИПН КАК ДоходНеПодлежащийНалогообложениюИПН,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ОтОбратногоНачисленияСторноВсего) КАК ОтОбратногоНачисленияСторноВсего,
		|	СУММА(ВТЗарегистрированныеНачисления_Выбор.ПрямыеНачисленияСторноВсего) КАК ПрямыеНачисленияСторноВсего
		|ПОМЕСТИТЬ ВТЗарегистрированныеНачисления
		|ИЗ
		|	ВТЗарегистрированныеНачисления_Выбор КАК ВТЗарегистрированныеНачисления_Выбор
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТЗарегистрированныеНачисления_Выбор.Сотрудник,
		|	ВТЗарегистрированныеНачисления_Выбор.ФизическоеЛицо,
		|	ВТЗарегистрированныеНачисления_Выбор.ПериодРегистрации,
		|	ВТЗарегистрированныеНачисления_Выбор.ВидДохода,
		|	ВТЗарегистрированныеНачисления_Выбор.ДоходНеПодлежащийНалогообложениюОПВ,
		|	ВТЗарегистрированныеНачисления_Выбор.ДоходНеПодлежащийНалогообложениюВОСМС,
		|	ВТЗарегистрированныеНачисления_Выбор.ДоходНеПодлежащийНалогообложениюИПН";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТОтборыРасчетыОтОбратного");
	УничтожитьВТ.Добавить("ВТЗарегистрированныеНачисления");
	УничтожитьВТ.Добавить("ВТЗарегистрированныеНачисления_Выбор");
	
	ЗарплатаКадрыОбщиеНаборыДанных.СоздатьВТИмяРегистраСрезПоследних(
		"ПлановыеУдержания",
		МенеджерВременныхТаблиц,
		Истина,
		ЗарплатаКадрыОбщиеНаборыДанных.ОписаниеФильтраДляСоздатьВТИмяРегистра("ВТПериодыПоФизлицам", "ФизическоеЛицо"));

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	УдержанияПоВидуНачисления.ПериодРегистрации КАК ПериодРегистрации,
		|	УдержанияПоВидуНачисления.Сотрудник КАК Сотрудник,
		|	УдержанияПоВидуНачисления.ФизическоеЛицо КАК ФизическоеЛицо,
		|	УдержанияПоВидуНачисления.Организация КАК Организация,
		|	СУММА(УдержанияПоВидуНачисления.СуммаУдержаний) КАК СуммаУдержаний
		|ПОМЕСТИТЬ ВТПлановыеУдержания
		|ИЗ
		|	(ВЫБРАТЬ
		|		ОтборыРасчетыОтОбратного.ПериодРегистрации КАК ПериодРегистрации,
		|		ОтборыРасчетыОтОбратного.Сотрудник КАК Сотрудник,
		|		ПлановыеУдержания.ДокументОснование КАК ДокументОснование,
		|		ПлановыеУдержания.ФизическоеЛицо КАК ФизическоеЛицо,
		|		ПлановыеУдержания.Организация КАК Организация,
		// используем МАКСИМУМ внутри потому что таблица ВТОтборыРасчетыОтОбратногоДляУдержаний содердит ВидРасчета, 
		// который при соединении с ВТОтборыРасчетыОтОбратногоДляУдержаний дает задвоение строк и сумм (при использовании конструкции СУММА)
		|		МАКСИМУМ(ПлановыеУдержания.Размер) КАК СуммаУдержаний
		|	ИЗ
		|		ВТПлановыеУдержанияСрезПоследних КАК ПлановыеУдержания
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТОтборыРасчетыОтОбратногоДляУдержаний КАК ОтборыРасчетыОтОбратного
		|			ПО ПлановыеУдержания.Период = ОтборыРасчетыОтОбратного.ПериодРегистрации
		|				И ПлановыеУдержания.ФизическоеЛицо = ОтборыРасчетыОтОбратного.ФизическоеЛицо
		|				И ПлановыеУдержания.Организация = ОтборыРасчетыОтОбратного.ГоловнаяОрганизация
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланВидовРасчета.Начисления.ОтОбратногоКомпенсируемыеУдержания КАК НачисленияОтОбратногоКомпенсируемыеУдержания
		|			ПО (ОтборыРасчетыОтОбратного.ВидРасчета = НачисленияОтОбратногоКомпенсируемыеУдержания.Ссылка)
		|				И ПлановыеУдержания.Удержание = НачисленияОтОбратногоКомпенсируемыеУдержания.ВидРасчета
		|	ГДЕ
		|		ПлановыеУдержания.Используется
		|		И НЕ ПлановыеУдержания.Удержание.Рассчитывается
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ОтборыРасчетыОтОбратного.ПериодРегистрации,
		|		ОтборыРасчетыОтОбратного.Сотрудник,
		|		ПлановыеУдержания.ДокументОснование,
		|		ПлановыеУдержания.ФизическоеЛицо,
		|		ПлановыеУдержания.Организация) КАК УдержанияПоВидуНачисления
		|
		|СГРУППИРОВАТЬ ПО
		|	УдержанияПоВидуНачисления.ПериодРегистрации,
		|	УдержанияПоВидуНачисления.Сотрудник,
		|	УдержанияПоВидуНачисления.ФизическоеЛицо,
		|	УдержанияПоВидуНачисления.Организация";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТОтборыРасчетыОтОбратногоДляУдержаний");
	УничтожитьВТ.Добавить("ВТПлановыеУдержанияСрезПоследних");
	УничтожитьВТ.Добавить("ВТПлановыеУдержания");
	УничтожитьВТ.Добавить("ВТПериодыПоГодам");

КонецПроцедуры

Процедура РассчитатьНачисленияОчередности(МесяцНачисления, ОкончательныйРасчетЗарплаты, СтрокиРасчета, МенеджерВременныхТаблиц, ОчередностьРасчета, РасчитанныеНачисленияПредыдущихИтераций, НачисленияСКорректировкой, ЭтоРасчетКорректировокДохода = Ложь, Организация, КэшСтрокиНабораНачисленияПоИдентификаторам)
	
  	Если МесяцНачисления >= Дата(2026,1,1) Тогда
		РассчитатьНачисленияОчередностиПосле2026(МесяцНачисления, ОкончательныйРасчетЗарплаты, СтрокиРасчета, МенеджерВременныхТаблиц, ОчередностьРасчета, РасчитанныеНачисленияПредыдущихИтераций, НачисленияСКорректировкой, ЭтоРасчетКорректировокДохода, Организация, КэшСтрокиНабораНачисленияПоИдентификаторам);
  	ИначеЕсли МесяцНачисления >= Дата(2025,1,1) Тогда
		РассчитатьНачисленияОчередностиПосле2025(МесяцНачисления, ОкончательныйРасчетЗарплаты, СтрокиРасчета, МенеджерВременныхТаблиц, ОчередностьРасчета, РасчитанныеНачисленияПредыдущихИтераций, НачисленияСКорректировкой, ЭтоРасчетКорректировокДохода, Организация, КэшСтрокиНабораНачисленияПоИдентификаторам);
  	ИначеЕсли МесяцНачисления >= Дата(2022,7,1) Тогда
		РассчитатьНачисленияОчередностиПосле072022(МесяцНачисления, ОкончательныйРасчетЗарплаты, СтрокиРасчета, МенеджерВременныхТаблиц, ОчередностьРасчета, РасчитанныеНачисленияПредыдущихИтераций, НачисленияСКорректировкой, ЭтоРасчетКорректировокДохода, Организация, КэшСтрокиНабораНачисленияПоИдентификаторам);
  	ИначеЕсли МесяцНачисления >= Дата(2021,1,1) Тогда
		РассчитатьНачисленияОчередностиПосле2021(МесяцНачисления, ОкончательныйРасчетЗарплаты, СтрокиРасчета, МенеджерВременныхТаблиц, ОчередностьРасчета, РасчитанныеНачисленияПредыдущихИтераций, НачисленияСКорректировкой, ЭтоРасчетКорректировокДохода, Организация, КэшСтрокиНабораНачисленияПоИдентификаторам);
    ИначеЕсли МесяцНачисления >= Дата(2020,1,1) Тогда
		РассчитатьНачисленияОчередностиПосле2020(МесяцНачисления, ОкончательныйРасчетЗарплаты, СтрокиРасчета, МенеджерВременныхТаблиц, ОчередностьРасчета, РасчитанныеНачисленияПредыдущихИтераций, НачисленияСКорректировкой, ЭтоРасчетКорректировокДохода, Организация, КэшСтрокиНабораНачисленияПоИдентификаторам);
	Иначе
		РассчитатьНачисленияОчередностиДо2020(МесяцНачисления, ОкончательныйРасчетЗарплаты, СтрокиРасчета, МенеджерВременныхТаблиц, ОчередностьРасчета, РасчитанныеНачисленияПредыдущихИтераций, НачисленияСКорректировкой, ЭтоРасчетКорректировокДохода, КэшСтрокиНабораНачисленияПоИдентификаторам);
	КонецЕсли;

КонецПроцедуры

Процедура РассчитатьНачисленияОчередностиДо2020(МесяцНачисления, ОкончательныйРасчетЗарплаты, СтрокиРасчета, МенеджерВременныхТаблиц, ОчередностьРасчета, РасчитанныеНачисленияПредыдущихИтераций, НачисленияСКорректировкой, ЭтоРасчетКорректировокДохода = Ложь, КэшСтрокиНабораНачисленияПоИдентификаторам = Неопределено)
	
	УничтожитьВТ = Новый Массив;
	
	ПоказательСуммаНаРуки = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ОтОбратногоСуммаНаРуки");
	ПоказательОтОбратногоОПВ = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ОтОбратногоОПВ");
	ПоказательОтОбратногоВОСМС = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ОтОбратногоВОСМС");
	ПоказательОтОбратногоИПН = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ОтОбратногоИПН");
	ПоказательОтОбратногоУдержания = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ОтОбратногоУдержания");
	
	ВычисляемыеПоказатели = Новый Массив;
	ВычисляемыеПоказатели.Добавить(ПоказательСуммаНаРуки);
	ВычисляемыеПоказатели.Добавить(ПоказательОтОбратногоОПВ);
	ВычисляемыеПоказатели.Добавить(ПоказательОтОбратногоВОСМС);
	ВычисляемыеПоказатели.Добавить(ПоказательОтОбратногоИПН);
	ВычисляемыеПоказатели.Добавить(ПоказательОтОбратногоУдержания);
	ТочностьПоказателей = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(ВычисляемыеПоказатели, "Точность");
	
	РассчитанныеНачисления = Новый ТаблицаЗначений;
	РассчитанныеНачисления.Колонки.Добавить("Сотрудник", Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
	РассчитанныеНачисления.Колонки.Добавить("ЦелевойРазмер", Новый ОписаниеТипов("Число"));
	РассчитанныеНачисления.Колонки.Добавить("Сумма", Новый ОписаниеТипов("Число"));
	РассчитанныеНачисления.Колонки.Добавить("СуммаОблагаемаяОПВ", Новый ОписаниеТипов("Число"));
	РассчитанныеНачисления.Колонки.Добавить("СуммаОблагаемаяВОСМС", Новый ОписаниеТипов("Число"));
	РассчитанныеНачисления.Колонки.Добавить("СуммаОблагаемаяИПН", Новый ОписаниеТипов("Число"));
	// проиндексируем для быстрого поиска
	РассчитанныеНачисления.Индексы.Добавить("Сотрудник");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ОчередностьРасчета", ОчередностьРасчета);
	Запрос.УстановитьПараметр("ЭтоРасчетКорректировокДохода", ЭтоРасчетКорректировокДохода);
	
	Если ЭтоРасчетКорректировокДохода Тогда
	
		Запрос.УстановитьПараметр("НачисленияСКорректировкой", НачисленияСКорректировкой);
	
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	НачисленияСКорректировкой.ИдентификаторСтроки КАК ИдентификаторСтроки,
			|	НачисленияСКорректировкой.Сотрудник КАК Сотрудник
			|ПОМЕСТИТЬ ВТ_НачисленияСКорректировкой
			|ИЗ
			|	&НачисленияСКорректировкой КАК НачисленияСКорректировкой
			|ГДЕ
			|   НачисленияСКорректировкой.ПересчитатьНачисление
			|";
		
		Запрос.Выполнить();
	
	КонецЕсли;
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Начисления.Регистратор КАК Регистратор,
