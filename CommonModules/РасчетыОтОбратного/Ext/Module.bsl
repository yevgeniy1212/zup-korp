		|	ЕСТЬNULL(ЗарегистрированныеНачисления.ПрямыеНачисленияОблагаемыеОПВ, 0) КАК ПрямыеНачисленияОблагаемыеОПВ,
		|	ЕСТЬNULL(ЗарегистрированныеНачисления.ПрямыеНачисленияОблагаемыеВОСМС, 0) КАК ПрямыеНачисленияОблагаемыеВОСМС,
		|	ЕСТЬNULL(ЗарегистрированныеНачисления.ПрямыеНачисленияОблагаемыеИПН, 0) КАК ПрямыеНачисленияОблагаемыеИПН,
		|	ЕСТЬNULL(ЗарегистрированныеНачисления.ОбщаяСуммаДоходаПрямыеНачисления, 0) КАК ОбщаяСуммаДоходаПрямыеНачисления,
		|	ЕСТЬNULL(ЗарегистрированныеНачисления.ОтОбратногоНачисленияВсего, 0) КАК ОтОбратногоНачисленияВсего,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ЗарегистрированныеНачисления.ОтОбратногоНачисленияОблагаемыеОПВ, 0) > 0
		// не уменьшаем ДанныеДокументовСторно.СуммаСторно, тк необходимо ограничения по НВО
		|			ТОГДА ЕСТЬNULL(ЗарегистрированныеНачисления.ОтОбратногоНачисленияОблагаемыеОПВ, 0)
		|		ИНАЧЕ 0 
		|	КОНЕЦ КАК ОтОбратногоНачисленияОблагаемыеОПВ,
		|	ВЫБОР
		// не уменьшаем ДанныеДокументовСторно.СуммаСторно, тк необходимо ограничения по НВО
		|		КОГДА ЕСТЬNULL(ЗарегистрированныеНачисления.ОтОбратногоНачисленияОблагаемыеВОСМС, 0) > 0
		|			ТОГДА ЕСТЬNULL(ЗарегистрированныеНачисления.ОтОбратногоНачисленияОблагаемыеВОСМС, 0) 
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК ОтОбратногоНачисленияОблагаемыеВОСМС,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(ЗарегистрированныеНачисления.ОтОбратногоНачисленияОблагаемыеИПН, 0) > 0
		|			ТОГДА ЕСТЬNULL(ЗарегистрированныеНачисления.ОтОбратногоНачисленияОблагаемыеИПН, 0)
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК ОтОбратногоНачисленияОблагаемыеИПН,
		|	ЕСТЬNULL(ДанныеДругогоРаботодателя.ВОСМС, 0) КАК ВОСМСДругогоРаботодателя,
		|	НастройкиНачислений.ФиксРасчет КАК ФиксРасчет,
		|	ЕСТЬNULL(СпособыОкругления.ИПНПравилоОкругления, ЗНАЧЕНИЕ(Перечисление.ПравилаОкругленияПриРасчетеЗарплаты.Авто)) КАК ИПНПравилоОкругления,
		|	ЕСТЬNULL(СпособыОкругления.ОПВПравилоОкругления, ЗНАЧЕНИЕ(Перечисление.ПравилаОкругленияПриРасчетеЗарплаты.Авто)) КАК ОПВПравилоОкругления,
		|	ЕСТЬNULL(СпособыОкругления.ИПНТочностьОкругления, 0.01) КАК ИПНТочностьОкругления,
		|	ЕСТЬNULL(СпособыОкругления.ОПВТочностьОкругления, 0.01) КАК ОПВТочностьОкругления,
		|	ЕСТЬNULL(ДанныеДокументовСторно.ПримененныйВычетСторно, 0) КАК ПримененныйВычетОтОбратногоСторно,
		|	ЕСТЬNULL(ДанныеДокументовСторно.СуммаСторно, 0) КАК СуммаСторно,
		|	ЕСТЬNULL(ЗарегистрированныеНачисления.ОтОбратногоНачисленияСторноВсего, 0) КАК ОтОбратногоНачисленияСторноВсего,
		|	ЕСТЬNULL(ЗарегистрированныеНачисления.ПрямыеНачисленияСторноВсего, 0) КАК ПрямыеНачисленияСторноВсего
		|ИЗ
		|	ВТ_НастройкиНачислений КАК НастройкиНачислений
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТЦелевыеРазмерыНачислений КАК ЦелевыеРазмерыНачислений
		|		ПО НастройкиНачислений.НомерСтроки = ЦелевыеРазмерыНачислений.НомерСтроки
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТЦелевойРазмерОчередностиВЦелом КАК ЦелевойРазмерОчередности
		|		ПО (ЦелевойРазмерОчередности.ОчередностьРасчета = &ОчередностьРасчета
		|		" + ?(ЭтоРасчетКорректировокДохода, " ИЛИ ЦелевойРазмерОчередности.ОчередностьРасчета = НастройкиНачислений.ОчередностьРасчета)", ")") + "
		|			И НастройкиНачислений.Сотрудник = ЦелевойРазмерОчередности.Сотрудник
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТЦелевойРазмерПоСотрудникуВЦелом КАК ЦелевойРазмерПоСотруднику
		|		ПО НастройкиНачислений.Сотрудник = ЦелевойРазмерПоСотруднику.Сотрудник
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТЦелевойРазмерПоДругимМестам КАК ЦелевойРазмерПоДругимМестам
		|		ПО НастройкиНачислений.Сотрудник = ЦелевойРазмерПоДругимМестам.Сотрудник
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТПредоставляемыеВычеты КАК ПредоставляемыеВычеты
		|		ПО НастройкиНачислений.НомерСтроки = ПредоставляемыеВычеты.НомерСтроки
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсключаемыеФизическиеЛицаПриРасчетеОПВ КАК ИсключаемыеФизическиеЛицаПриРасчетеОПВ
		|		ПО НастройкиНачислений.ФизическоеЛицо = ИсключаемыеФизическиеЛицаПриРасчетеОПВ.ФизическоеЛицо
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС КАК ИсключаемыеФизическиеЛицаПриРасчетеВОСМС
		|		ПО НастройкиНачислений.ФизическоеЛицо = ИсключаемыеФизическиеЛицаПриРасчетеВОСМС.ФизическоеЛицо
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтатусыФизическихЛицКакНалогоплательщиков КАК СтатусыФизическихЛицКакНалогоплательщиков
		|		ПО НастройкиНачислений.ФизическоеЛицо = СтатусыФизическихЛицКакНалогоплательщиков.ФизическоеЛицо
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОПВ КАК СтавкиОПВ
		|		ПО НастройкиНачислений.ПериодРегистрации = СтавкиОПВ.МесяцНалоговогоПериода
		|			И НастройкиНачислений.ВидДохода = СтавкиОПВ.ВидДохода
		|			И (СтавкиОПВ.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ОПВ))
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМС КАК СтавкиВОСМС
		|		ПО НастройкиНачислений.ПериодРегистрации = СтавкиВОСМС.МесяцНалоговогоПериода
		|			И НастройкиНачислений.ВидДохода = СтавкиВОСМС.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиИПН КАК СтавкиИПН
		|		ПО НастройкиНачислений.ПериодРегистрации = СтавкиИПН.МесяцНалоговогоПериода
		|			И НастройкиНачислений.ВидДохода = СтавкиИПН.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|		ПО НастройкиНачислений.ПериодРегистрации = РазмерыМЗППоПериодам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыМРППоПериодам КАК РазмерыМРППоПериодам
		|		ПО НастройкиНачислений.ПериодРегистрации = РазмерыМРППоПериодам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТПлановыеУдержания КАК ПлановыеУдержания
		|		ПО НастройкиНачислений.ПериодРегистрации = ПлановыеУдержания.ПериодРегистрации
		|			И НастройкиНачислений.Сотрудник = ПлановыеУдержания.Сотрудник
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТЗарегистрированныеНачисления КАК ЗарегистрированныеНачисления
		|		ПО НастройкиНачислений.ПериодРегистрации = ЗарегистрированныеНачисления.ПериодРегистрации
		|			И НастройкиНачислений.Сотрудник = ЗарегистрированныеНачисления.Сотрудник
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ДанныеДокументовСторно КАК ДанныеДокументовСторно
		|		ПО НастройкиНачислений.ПериодРегистрации = ДанныеДокументовСторно.ПериодРегистрации
		|			И НастройкиНачислений.Сотрудник = ДанныеДокументовСторно.Сотрудник
		|			И НастройкиНачислений.НомерСтроки = ДанныеДокументовСторно.НомерСтроки
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДанныеДругогоРаботодателя КАК ДанныеДругогоРаботодателя
		|		ПО НастройкиНачислений.ПериодРегистрации = ДанныеДругогоРаботодателя.МесяцНалоговогоПериода
		|			И НастройкиНачислений.ФизическоеЛицо = ДанныеДругогоРаботодателя.ФизическоеЛицо
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СпособыОкругления КАК СпособыОкругления
		|       ПО ИСТИНА
		|
		|УПОРЯДОЧИТЬ ПО
		|	НомерСтроки";
	
	ИсходныеДанные = Запрос.Выполнить().Выбрать();
	УничтожитьВТ.Добавить("ВТ_НачисленияОчередности");
	УничтожитьВТ.Добавить("ВТ_НастройкиНачислений");
	УничтожитьВТ.Добавить("ВТПредоставляемыеВычеты");
	УничтожитьВТ.Добавить("ВТ_СпособыОкругленияОрганизации");
	УничтожитьВТ.Добавить("ВТ_СпособыОкругления");
	
	ДатаПримененияКорректировкиДохода = Дата(2019, 1, 1);
	ОграничениеКорректировкиДохода25МРП = 25 * ЗарплатаКадрыПовтИсп.МесячныйРасчетныйПоказатель(НачалоГода(МесяцНачисления));
	ПрименятьКорректировкуИПН = ОкончательныйРасчетЗарплаты И МесяцНачисления >= Дата('20190101');
	
	ТаблицаСтавокНалогов = Новый ТаблицаЗначений;
	ТаблицаСтавокНалогов.Колонки.Добавить("СуммаДоходаС",  Новый ОписаниеТипов("Число"));
	ТаблицаСтавокНалогов.Колонки.Добавить("СуммаДоходаПо", Новый ОписаниеТипов("Число"));
	ТаблицаСтавокНалогов.Колонки.Добавить("СтавкаИПН",     Новый ОписаниеТипов("Число"), Новый КвалификаторыЧисла(10, 1));
	ТаблицаСтавокНалогов.Колонки.Добавить("СтавкаОПВ",     Новый ОписаниеТипов("Число"), Новый КвалификаторыЧисла(10, 1));
	
	Пока ИсходныеДанные.Следующий() Цикл 
		
		ЗаполнитьСтавкиНалоговКорректировкиДохода25МРП(ТаблицаСтавокНалогов, ИсходныеДанные, ОграничениеКорректировкиДохода25МРП, ПрименятьКорректировкуИПН);
		
		СтрокаРасчитанныеНачисленияПредыдущихОчередностей = РасчитанныеНачисленияПредыдущихИтераций.Получить(ИсходныеДанные.Сотрудник);
		СтрокаРасчитанныеНачисления = РассчитанныеНачисления.Найти(ИсходныеДанные.Сотрудник, "Сотрудник");
		
		УчитыватьИтерацииПредыдущихОчередностей = (СтрокаРасчитанныеНачисленияПредыдущихОчередностей <> Неопределено);
		УчитыватьИтерацииТекущейОчередности 	= (СтрокаРасчитанныеНачисления <> Неопределено);
		
		Строка = СтрокиРасчета[ИсходныеДанные.ИдентификаторСтроки];
		
		Если Строка = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СуммаСторно = ИсходныеДанные.ОтОбратногоНачисленияСторноВсего + ?(ИсходныеДанные.УчитыватьПрямыеНачисления, ИсходныеДанные.ПрямыеНачисленияСторноВсего, 0);
		
		Если ИсходныеДанные.КомпенсироватьОПВ Тогда
			ОграничениеОПВ = ИсходныеДанные.МаксимальноеОграничениеОПВ 
						   - (?(ИсходныеДанные.УчитыватьПрямыеНачисления, ИсходныеДанные.ПрямыеНачисленияОблагаемыеОПВ, 0) 
						   + ИсходныеДанные.ОтОбратногоНачисленияОблагаемыеОПВ + СуммаСторно) * ИсходныеДанные.СтавкаОПВ
						   - ?(УчитыватьИтерацииПредыдущихОчередностей, СтрокаРасчитанныеНачисленияПредыдущихОчередностей.СуммаОблагаемаяОПВ, 0) * ИсходныеДанные.СтавкаОПВ
						   - ?(УчитыватьИтерацииТекущейОчередности, СтрокаРасчитанныеНачисления.СуммаОблагаемаяОПВ, 0) * ИсходныеДанные.СтавкаОПВ;
			МаксимальноеОграничениеОПВ = Макс(ОграничениеОПВ, 0);
			// заполняем из УчитыватьОПВ (учтем статус физического лица)
			ПризнакРасчетаОПВ = ИсходныеДанные.УчитыватьОПВ;
			ПризнакПрименятьОграничениеПоДоходамОПВ = 0;
		Иначе
			МаксимальноеОграничениеОПВ = 0;
			ПризнакРасчетаОПВ = 0;
			ПризнакПрименятьОграничениеПоДоходамОПВ = 0;
		КонецЕсли;
        СтатусРезидента = 1;
        Если ИсходныеДанные.СтатусРезидента Тогда
            СтатусРезидента = 1;
        Иначе
            СтатусРезидента = 0;
        КонецЕсли;
        
		Если ИсходныеДанные.КомпенсироватьВОСМС Тогда
			ОграничениеВОСМС = ИсходныеДанные.МаксимальноеОграничениеВОСМС
							 - (?(ИсходныеДанные.УчитыватьПрямыеНачисления, ИсходныеДанные.ПрямыеНачисленияОблагаемыеВОСМС, 0)
							 + ИсходныеДанные.ОтОбратногоНачисленияОблагаемыеВОСМС + СуммаСторно) * ИсходныеДанные.СтавкаВОСМС
							 - ?(УчитыватьИтерацииПредыдущихОчередностей, СтрокаРасчитанныеНачисленияПредыдущихОчередностей.СуммаОблагаемаяВОСМС, 0) * ИсходныеДанные.СтавкаВОСМС
							 - ?(УчитыватьИтерацииТекущейОчередности, СтрокаРасчитанныеНачисления.СуммаОблагаемаяВОСМС, 0) * ИсходныеДанные.СтавкаВОСМС
							 - ИсходныеДанные.ВОСМСДругогоРаботодателя;
			МаксимальноеОграничениеВОСМС = Макс(ОграничениеВОСМС, 0);
			
			// для срабатывания максимального ограничения без тиын, округлим максимальную сумму
			Если (МаксимальноеОграничениеВОСМС - Цел(МаксимальноеОграничениеВОСМС)) > 0 Тогда
				
				МаксимальноеОграничениеВОСМС = Окр(МаксимальноеОграничениеВОСМС, 0, РежимОкругления.Окр15как20);
				
			КонецЕсли;
			
			// заполняем из УчитыватьВОСМС (учтем статус физического лица)
			ПризнакРасчетаВОСМС = ИсходныеДанные.УчитыватьВОСМС;
			ПризнакПрименятьОграничениеПоДоходамВОСМС = 0;
			ПризнакПрименятьОкруглениеВОСМС	= 0;
			ИсчисленныйВОСМСПослеОкругления = 0;	
		Иначе
			МаксимальноеОграничениеВОСМС = 0;
			ПризнакРасчетаВОСМС = 0;
			ПризнакПрименятьОграничениеПоДоходамВОСМС = 0;
			ПризнакПрименятьОкруглениеВОСМС	= 0;
			ИсчисленныйВОСМСПослеОкругления = 0;	
		КонецЕсли;

		ПримененныйВычетИПН = 0;
		
		// Определим приблизитуельную сумму для применения ставки ИПН = ОбщаяСуммаДоходаПрямыеНачисления + ОтОбратного + (-)Сторно + целевые размеры + налоги предыдущих очередностей + налоги предыдущих начислений от обратного текущей очередности (текущего документа)
		СуммаДоходаСотрудникаДоРасчета = ИсходныеДанные.ОбщаяСуммаДоходаПрямыеНачисления + ИсходныеДанные.ОтОбратногоНачисленияВсего + СуммаСторно + ИсходныеДанные.ЦелевойРазмерПоСотруднику + ИсходныеДанные.ЦелевойРазмерПоДругимМестам 
										// налоги предыдущих очередностей
										+ ?(УчитыватьИтерацииПредыдущихОчередностей, СтрокаРасчитанныеНачисленияПредыдущихОчередностей.Сумма - СтрокаРасчитанныеНачисленияПредыдущихОчередностей.ЦелевойРазмер, 0)
										// налоги предыдущих начислений от обратного текущей очередности
										+ ?(УчитыватьИтерацииТекущейОчередности, СтрокаРасчитанныеНачисления.Сумма - СтрокаРасчитанныеНачисления.ЦелевойРазмер, 0); 
											
		Если ИсходныеДанные.КомпенсироватьИПН Тогда
			
			Если СтатусРезидента Тогда
				ПрименяемыеВычеты = ИсходныеДанные.ОстатокВычетов + ИсходныеДанные.РазрешенныеВычеты 
								  - ?(ИсходныеДанные.УчитыватьПрямыеНачисления, ИсходныеДанные.ПрямыеНачисленияОблагаемыеИПН 
								  	- ?(ПризнакРасчетаОПВ, ЗарплатаКадрыКлиентСервер.Округлить(ИсходныеДанные.ПрямыеНачисленияОблагаемыеИПН * ИсходныеДанные.СтавкаОПВ, ИсходныеДанные.ОПВТочностьОкругления, ИсходныеДанные.ОПВПравилоОкругления), 0)
									- ?(ПризнакРасчетаВОСМС, Окр(ИсходныеДанные.ПрямыеНачисленияОблагаемыеИПН * ИсходныеДанные.СтавкаВОСМС, 0, РежимОкругления.Окр15как20), 0), 0)
								  - (ИсходныеДанные.ОтОбратногоНачисленияОблагаемыеИПН - ?(ПризнакРасчетаОПВ, ЗарплатаКадрыКлиентСервер.Округлить(ИсходныеДанные.ОтОбратногоНачисленияОблагаемыеИПН * ИсходныеДанные.СтавкаОПВ, ИсходныеДанные.ОПВТочностьОкругления, ИсходныеДанные.ОПВПравилоОкругления), 0) - ?(ПризнакРасчетаВОСМС, Окр(ИсходныеДанные.ОтОбратногоНачисленияОблагаемыеИПН * ИсходныеДанные.СтавкаВОСМС, 0, РежимОкругления.Окр15как20), 0))
								  - ?(УчитыватьИтерацииПредыдущихОчередностей, СтрокаРасчитанныеНачисленияПредыдущихОчередностей.ПримененныйВычетИПН, 0) 
								  - ?(УчитыватьИтерацииТекущейОчередности, СтрокаРасчитанныеНачисления.ПримененныйВычетИПН, 0);
		    Иначе
				ПрименяемыеВычеты = 0;					  
			КонецЕсли;
								  
			// учтем вычеты, примененные при расчете начисления до перерасчета корректировки дохода				  
			Если ИсходныеДанные.ЭтоРасчетКорректировокДохода И ИсходныеДанные.ОстатокВычетов + ИсходныеДанные.РазрешенныеВычеты > 0 Тогда
				
				СтрокиКорректировки = НачисленияСКорректировкой.НайтиСтроки(Новый Структура("ИдентификаторСтроки, Сотрудник", ИсходныеДанные.ИдентификаторСтроки, ИсходныеДанные.Сотрудник));
				
				Если СтрокиКорректировки.Количество() > 0 Тогда
					ВычетыИПН = СтрокиКорректировки[0].СуммаПримененногоВычета;
				Иначе
					ВычетыИПН = 0;
				КонецЕсли;
				
			Иначе
				
				// при наличии корректировок пересчитываем с учетом сторнированной суммы вычета
				// распределение использовать не можем, при сторнировании должны взять сумму изначально примененного вычета
				Если ИсходныеДанные.ПримененныйВычетОтОбратногоСторно > 0 Тогда
					ВычетыИПН = ИсходныеДанные.ПримененныйВычетОтОбратногоСторно;	
				Иначе
					ВычетыИПН = Макс(ПрименяемыеВычеты, 0);
				КонецЕсли
				
			КонецЕсли;
		
			ПризнакРасчетаИПН = 1;

		Иначе
			
			ВычетыИПН = 0;
			ПризнакРасчетаИПН = 0;
			
		КонецЕсли;
		
		Итерация = 0;	
		МаксимальноеЧислоИтераций = 100;
		
		ИндексСтавки = 0;
		Для ИндексСтавки = 0 По ТаблицаСтавокНалогов.Количество() - 1 Цикл
			// если сумма сотрудника до расчета налогов уже выше предела, то для расчета сразу используем ставку 10%
			Если СуммаДоходаСотрудникаДоРасчета >= ТаблицаСтавокНалогов[ИндексСтавки].СуммаДоходаС 
				 И СуммаДоходаСотрудникаДоРасчета <= ТаблицаСтавокНалогов[ИндексСтавки].СуммаДоходаПо Тогда
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		РезультатПолучен = Ложь;
		Пока Не РезультатПолучен И (Итерация < МаксимальноеЧислоИтераций) Цикл
                     
			Итерация = Итерация + 1;
			Если СтатусРезидента И ПрименятьКорректировкуИПН Тогда
				ПроцентИПН 				 = ТаблицаСтавокНалогов[ИндексСтавки].СтавкаИПН;
			Иначе
				ПроцентИПН 				 = ИсходныеДанные.СтавкаИПН;
			КонецЕсли;
			
			ПроцентОПВ   = ИсходныеДанные.СтавкаОПВ;
			
			ПроцентВОСМС = ИсходныеДанные.СтавкаВОСМС;
			
			КорректировкаОПВ = ПризнакРасчетаОПВ * ПризнакПрименятьОграничениеПоДоходамОПВ * МаксимальноеОграничениеОПВ;
			КорректировкаВОСМС = ПризнакРасчетаВОСМС * ПризнакПрименятьОграничениеПоДоходамВОСМС * МаксимальноеОграничениеВОСМС;
			Если ПризнакПрименятьОкруглениеВОСМС Тогда
				КорректировкаВОСМС = ПризнакРасчетаВОСМС * ПризнакПрименятьОкруглениеВОСМС * ИсчисленныйВОСМСПослеОкругления;
			КонецЕсли;
			КорректировкаИПН = ПризнакРасчетаИПН * (0 - ВычетыИПН - СтатусРезидента * КорректировкаОПВ - СтатусРезидента * КорректировкаВОСМС) * ПроцентИПН;

			Если НЕ ИсходныеДанные.ФиксРасчет Тогда
				
				Числитель = ИсходныеДанные.ЦелевойРазмер + ИсходныеДанные.КомпенсироватьУдержания * ИсходныеДанные.СуммаУдержаний
							+ КорректировкаОПВ * ИсходныеДанные.КомпенсироватьОПВ * ИсходныеДанные.УчитыватьОПВ 
							+ КорректировкаВОСМС * ИсходныеДанные.КомпенсироватьВОСМС * ИсходныеДанные.УчитыватьВОСМС 
							+ КорректировкаИПН * ИсходныеДанные.КомпенсироватьИПН * ИсходныеДанные.УчитыватьИПН;
			
				Знаменатель = 1 - (ПризнакРасчетаИПН * ИсходныеДанные.КомпенсироватьИПН * ИсходныеДанные.УчитыватьИПН * ПроцентИПН * 
							  (1 - ПризнакРасчетаОПВ * СтатусРезидента * ИсходныеДанные.КомпенсироватьОПВ * ИсходныеДанные.УчитыватьОПВ * ПроцентОПВ * (1 - ПризнакПрименятьОграничениеПоДоходамОПВ) - 
							   ПризнакРасчетаВОСМС * СтатусРезидента * ИсходныеДанные.КомпенсироватьВОСМС * ИсходныеДанные.УчитыватьВОСМС * ПроцентВОСМС * (1 - ПризнакПрименятьОграничениеПоДоходамВОСМС - ПризнакПрименятьОкруглениеВОСМС))) -
							  (ПризнакРасчетаОПВ * ИсходныеДанные.КомпенсироватьОПВ * ИсходныеДанные.УчитыватьОПВ * ПроцентОПВ) * (1 - ПризнакПрименятьОграничениеПоДоходамОПВ) -
							  (ПризнакРасчетаВОСМС * ИсходныеДанные.КомпенсироватьВОСМС * ИсходныеДанные.УчитыватьВОСМС * ПроцентВОСМС) * (1 - ПризнакПрименятьОграничениеПоДоходамВОСМС - ПризнакПрименятьОкруглениеВОСМС);
			
				Результат = ?(Знаменатель <> 0, Числитель / Знаменатель, 0);
				ЦелевойРазмер = ИсходныеДанные.ЦелевойРазмер;
			Иначе
				Результат = ИсходныеДанные.ЦелевойРазмер;
			КонецЕсли;
			
			РезультатПолучен = Истина;
			
			КомпенсированоОПВ = КорректировкаОПВ + Результат * ПризнакРасчетаОПВ * ИсходныеДанные.КомпенсироватьОПВ * ИсходныеДанные.УчитыватьОПВ * ПроцентОПВ * (1 - ПризнакПрименятьОграничениеПоДоходамОПВ);
			КомпенсированоВОСМС = КорректировкаВОСМС + Результат * ПризнакРасчетаВОСМС * ИсходныеДанные.КомпенсироватьВОСМС * ИсходныеДанные.УчитыватьВОСМС * ПроцентВОСМС * (1 - ПризнакПрименятьОграничениеПоДоходамВОСМС - ПризнакПрименятьОкруглениеВОСМС); 
			КомпенсированоИПН = КорректировкаИПН + Результат * ПризнакРасчетаИПН  * ИсходныеДанные.КомпенсироватьИПН * ИсходныеДанные.УчитыватьИПН * ПроцентИПН  
							  * (1 - ПризнакРасчетаОПВ * СтатусРезидента * (1 - ПризнакПрименятьОграничениеПоДоходамОПВ) * ИсходныеДанные.КомпенсироватьОПВ * ИсходныеДанные.УчитыватьОПВ * ПроцентОПВ 
								   - ПризнакРасчетаВОСМС * СтатусРезидента * (1 - ПризнакПрименятьОграничениеПоДоходамВОСМС - ПризнакПрименятьОкруглениеВОСМС) * ИсходныеДанные.КомпенсироватьВОСМС * ИсходныеДанные.УчитыватьВОСМС * ПроцентВОСМС);
		    КомпенсированоУдержаний = ИсходныеДанные.СуммаУдержаний;
			
			Если ИсходныеДанные.ФиксРасчет Тогда
				ЦелевойРазмер = Результат - КомпенсированоОПВ - КомпенсированоВОСМС - КомпенсированоИПН - КомпенсированоУдержаний;
			КонецЕсли;
			
			// перед ОПВ анализируем ВОСМС (предел ниже)
			Если ИсходныеДанные.КомпенсироватьВОСМС Тогда
				Если РезультатПолучен Тогда
					Если ИсходныеДанные.УчитыватьВОСМС Тогда 
						Если Результат > 0 Тогда
							Если ПризнакРасчетаВОСМС <> 1 Тогда
								РезультатПолучен = Ложь;
							КонецЕсли;
							ПризнакРасчетаВОСМС = 1;
						Иначе
							Если ПризнакРасчетаВОСМС <> 0 Тогда
								РезультатПолучен = Истина;
							КонецЕсли;
							ПризнакРасчетаВОСМС = 0;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			
				// Макс сумма облагаемых ВОСМС доходов
				Если РезультатПолучен Тогда
					Если КомпенсированоВОСМС >= МаксимальноеОграничениеВОСМС
						ИЛИ (КомпенсированоВОСМС = МаксимальноеОграничениеВОСМС
							И ПризнакПрименятьОграничениеПоДоходамВОСМС = 1) Тогда
						Если ПризнакПрименятьОграничениеПоДоходамВОСМС <> 1 Тогда
							РезультатПолучен = Ложь;
						КонецЕсли;
						ПризнакПрименятьОграничениеПоДоходамВОСМС = 1;
						ИсчисленныйВОСМСПослеОкругления = 0;
						ПризнакПрименятьОкруглениеВОСМС = 0;	
					// проверим наличие сотой части в исчисленном ВОСМС	
					ИначеЕсли (КомпенсированоВОСМС - Цел(КомпенсированоВОСМС)) > 0 Тогда
						ПризнакПрименятьОграничениеПоДоходамВОСМС = 0;
						ПризнакПрименятьОкруглениеВОСМС = 1;
						ИсчисленныйВОСМСПослеОкругления = Окр(КомпенсированоВОСМС, 0, РежимОкругления.Окр15как20);
						РезультатПолучен = Ложь;
					Иначе
						Если ПризнакПрименятьОграничениеПоДоходамВОСМС <> 0 Тогда
							РезультатПолучен = Ложь;
						КонецЕсли;
						ПризнакПрименятьОграничениеПоДоходамВОСМС = 0;
						ПризнакПрименятьОкруглениеВОСМС = 0;	
						ИсчисленныйВОСМСПослеОкругления = 0;
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
				
			Если ИсходныеДанные.КомпенсироватьОПВ Тогда
				Если РезультатПолучен Тогда
					Если ИсходныеДанные.УчитыватьОПВ Тогда 
						Если Результат > 0 Тогда
							Если ПризнакРасчетаОПВ <> 1 Тогда
								РезультатПолучен = Ложь;
							КонецЕсли;
							ПризнакРасчетаОПВ = 1;
						Иначе
							Если ПризнакРасчетаОПВ <> 0 Тогда
								РезультатПолучен = Ложь;
							КонецЕсли;
							ПризнакРасчетаОПВ = 0;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			
				// Макс сумма облагаемых ОПВ доходов
				Если РезультатПолучен Тогда
					Если КомпенсированоОПВ > МаксимальноеОграничениеОПВ
						ИЛИ (КомпенсированоОПВ = МаксимальноеОграничениеОПВ
							И ПризнакПрименятьОграничениеПоДоходамОПВ = 1) Тогда
						Если ПризнакПрименятьОграничениеПоДоходамОПВ <> 1 Тогда
							РезультатПолучен = Ложь;
						КонецЕсли;
						ПризнакПрименятьОграничениеПоДоходамОПВ = 1;
					Иначе
						Если ПризнакПрименятьОграничениеПоДоходамОПВ <> 0 Тогда
							РезультатПолучен = Ложь;
						КонецЕсли;
						ПризнакПрименятьОграничениеПоДоходамОПВ = 0;
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
			
			Если ИсходныеДанные.КомпенсироватьИПН Тогда  // Граничные условия, возникающие при расчете ИПН
				// проверка на то, чтобы ИПН не был отрицательным, если обл. доходы за месяц < 0
				Если РезультатПолучен Тогда
					Если ИсходныеДанные.УчитыватьИПН Тогда
						ОблагаемаяИПНСумма = Результат - КомпенсированоОПВ - КомпенсированоВОСМС - ВычетыИПН * ИсходныеДанные.КомпенсироватьИПН; 
						Если ОблагаемаяИПНСумма < 0 Тогда
							// ранее налог считался, но облагаемая сумма за месяц < 0 - на следующем шаге не считаем
							Если ПризнакРасчетаИПН <> 0 Тогда
								РезультатПолучен = Ложь;
							КонецЕсли;
							ПризнакРасчетаИПН = 0;
						Иначе
							// ранее налог не считался, но теперь облагаемая сумма > 0 и налог есть с чего считать
							Если ПризнакРасчетаИПН <> 1 Тогда
								РезультатПолучен = Ложь;
							КонецЕсли;
							ПризнакРасчетаИПН = 1;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				
			КонецЕсли;
			
			// Соответствие общего дохода сотрудника применямой ставке 
			Если РезультатПолучен И СтатусРезидента И (ПрименятьКорректировкуИПН И ИсходныеДанные.КомпенсироватьИПН) Тогда
					
				ВремИндекс = 0;
				
				СуммаДоходаСотрудникаПослеРасчета = СуммаДоходаСотрудникаДоРасчета 
				                                    // налог текущего начисления
													+ (Результат - ИсходныеДанные.ЦелевойРазмер);
					
				Для ВремИндекс = 0 По ТаблицаСтавокНалогов.Количество() - 1 Цикл
					
					Если СуммаДоходаСотрудникаПослеРасчета >= ТаблицаСтавокНалогов[ВремИндекс].СуммаДоходаС
						 И СуммаДоходаСотрудникаПослеРасчета <= ТаблицаСтавокНалогов[ВремИндекс].СуммаДоходаПо Тогда
						
						Если ВремИндекс <> ИндексСтавки Тогда
							
							РезультатПолучен = Ложь;
							
							СтрокиКорректировок = НачисленияСКорректировкой.НайтиСтроки(Новый Структура("Сотрудник", ИсходныеДанные.Сотрудник));
							
							Если НЕ СтрокиКорректировок.Количество() = 0 Тогда
								
								Для Каждого СтрокаКорректировки Из СтрокиКорректировок Цикл
									СтрокаКорректировки.ПересчитатьНачисление = Истина;	
								КонецЦикла;
								
							КонецЕсли;
							
						КонецЕсли;

						ИндексСтавки = ВремИндекс;
						
						Прервать;
						
					КонецЕсли;
						
				КонецЦикла;
				
				// зафиксируем начисления, в которых была применена корректировка дохода; 
				// список таких начислений будет перерасчитан, в случае превышения 
				// в очередном виде расчета "от обратного" суммы предела корректировки
				Если СуммаДоходаСотрудникаПослеРасчета <= ОграничениеКорректировкиДохода25МРП Тогда
					
					СтрокаСКорректировкойДохода = НачисленияСКорректировкой.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаСКорректировкойДохода, ИсходныеДанные);
					СтрокаСКорректировкойДохода.СуммаПримененногоВычета = ВычетыИПН;
						
				КонецЕсли;
				
				Если НЕ ИсходныеДанные.ЭтоРасчетКорректировокДохода
					// данные применнного вычета из сторнируемого начисления
					И НЕ ИсходныеДанные.ПримененныйВычетОтОбратногоСторно
					И ВычетыИПН > 0 Тогда
					
					ПримененныйВычетИПН = ?(ИсходныеДанные.УчитыватьИПН, ?(КомпенсированоИПН > 0, Результат - КомпенсированоИПН - КомпенсированоВОСМС - КомпенсированоОПВ, Результат - КомпенсированоВОСМС - КомпенсированоОПВ), 0);
					
				Иначе
					
					ПримененныйВычетИПН = 0;
					
				КонецЕсли;

			КонецЕсли;

		КонецЦикла;
							   
		// На руки
		СтрокаПоказателя = РасчетЗарплатыРасширенный.СтрокаЗначенияПоказателяПоИдентификатору(Строка.Показатели, "ОтОбратногоСуммаНаРуки");
		Если СтрокаПоказателя = Неопределено Тогда 
			
			Если Строка.Показатели.Количество() = 0 Тогда
				Строка.Показатели = Обработки.МенеджерРасчетаЗарплаты.ТаблицаПоказателей();
			КонецЕсли;

			СтрокаПоказателя = Строка.Показатели.Добавить();
			СтрокаПоказателя.Показатель = ПоказательСуммаНаРуки;
			
		КонецЕсли;
		Точность = ТочностьПоказателей.Получить(ПоказательСуммаНаРуки);
		СтрокаПоказателя.Значение = Окр(ЦелевойРазмер, Точность);
		ЦелевойРазмер = Окр(ЦелевойРазмер, Точность);
		
		Если ЗначениеЗаполнено(ИсходныеДанные.ОПВТочностьОкругления) Тогда
			КомпенсированоОПВ = ЗарплатаКадрыКлиентСервер.Округлить(КомпенсированоОПВ, ИсходныеДанные.ОПВТочностьОкругления, ИсходныеДанные.ОПВПравилоОкругления);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ИсходныеДанные.ИПНТочностьОкругления) Тогда
			КомпенсированоИПН = ЗарплатаКадрыКлиентСервер.Округлить(КомпенсированоИПН, ИсходныеДанные.ИПНТочностьОкругления, ИсходныеДанные.ИПНПравилоОкругления);
		КонецЕсли;
		
		// ОПВ
		Если ИсходныеДанные.КомпенсироватьОПВ Тогда
			СтрокаПоказателя = РасчетЗарплатыРасширенный.СтрокаЗначенияПоказателяПоИдентификатору(Строка.Показатели, "ОтОбратногоОПВ");
			Если СтрокаПоказателя = Неопределено Тогда 
				СтрокаПоказателя = Строка.Показатели.Добавить();
				СтрокаПоказателя.Показатель = ПоказательОтОбратногоОПВ;
			КонецЕсли;
			Точность = ТочностьПоказателей.Получить(ПоказательОтОбратногоОПВ);
			СтрокаПоказателя.Значение = Окр(КомпенсированоОПВ, Точность);
			КомпенсированоОПВ = Окр(КомпенсированоОПВ, Точность);
		КонецЕсли;
		
		// ВОСМС
		Если ИсходныеДанные.КомпенсироватьВОСМС Тогда
			СтрокаПоказателя = РасчетЗарплатыРасширенный.СтрокаЗначенияПоказателяПоИдентификатору(Строка.Показатели, "ОтОбратногоВОСМС");
			Если СтрокаПоказателя = Неопределено Тогда 
				СтрокаПоказателя = Строка.Показатели.Добавить();
				СтрокаПоказателя.Показатель = ПоказательОтОбратногоВОСМС;
			КонецЕсли;
			Точность = ТочностьПоказателей.Получить(ПоказательОтОбратногоВОСМС);
			СтрокаПоказателя.Значение = Окр(КомпенсированоВОСМС, Точность);
			КомпенсированоВОСМС = Окр(КомпенсированоВОСМС, Точность);
		КонецЕсли;
		
		// ИПН
		Если ИсходныеДанные.КомпенсироватьИПН Тогда
			СтрокаПоказателя = РасчетЗарплатыРасширенный.СтрокаЗначенияПоказателяПоИдентификатору(Строка.Показатели, "ОтОбратногоИПН");
			Если СтрокаПоказателя = Неопределено Тогда 
				СтрокаПоказателя = Строка.Показатели.Добавить();
				СтрокаПоказателя.Показатель = ПоказательОтОбратногоИПН;
			КонецЕсли;
			Точность = ТочностьПоказателей.Получить(ПоказательОтОбратногоИПН);
			СтрокаПоказателя.Значение = Окр(КомпенсированоИПН, Точность);
			КомпенсированоИПН = Окр(КомпенсированоИПН, Точность);
		КонецЕсли;
		
		//Удержания
		Если ИсходныеДанные.КомпенсироватьУдержания Тогда
			СтрокаПоказателя = РасчетЗарплатыРасширенный.СтрокаЗначенияПоказателяПоИдентификатору(Строка.Показатели, "ОтОбратногоУдержания");
			Если СтрокаПоказателя = Неопределено Тогда 
				СтрокаПоказателя = Строка.Показатели.Добавить();
				СтрокаПоказателя.Показатель = ПоказательОтОбратногоУдержания;
			КонецЕсли;
			Точность = ТочностьПоказателей.Получить(ПоказательОтОбратногоУдержания);
			СтрокаПоказателя.Значение = Окр(КомпенсированоУдержаний, Точность);
			КомпенсированоУдержаний = Окр(КомпенсированоУдержаний, Точность);
		КонецЕсли;
		
		ОбщаяСуммаКомпенсируемыхУдержаний = КомпенсированоИПН + КомпенсированоОПВ + КомпенсированоВОСМС + КомпенсированоУдержаний;
		Разность = ЦелевойРазмер - (Результат - ОбщаяСуммаКомпенсируемыхУдержаний);
		
		// при округлении одновременн ОПВ, ИПН и ВОСМС могут быть разности более единицы для списания
		Если Разность > -2 И Разность < 2 Тогда
			Результат = Результат + Разность;
		КонецЕсли;
		
		// Результат					   
		Строка.Результат = Результат;
		// изменение 3.1.26
		Если НЕ Строка.ЗаписьРасчета = Неопределено Тогда
			Строка.ЗаписьРасчета.Результат = Результат;
		КонецЕсли;
		Если НЕ КэшСтрокиНабораНачисленияПоИдентификаторам = Неопределено Тогда
			
			СтрокаКэша = КэшСтрокиНабораНачисленияПоИдентификаторам[Строка.ИдентификаторСтроки];
			
			Если НЕ СтрокаКэша = Неопределено Тогда
				СтрокаКэша.Результат = Результат;	
			КонецЕсли;
			
		КонецЕсли;
		// изменение 3.1.26
		
		Если СтрокаРасчитанныеНачисления = Неопределено Тогда
			СтрокаРасчитанныеНачисления = РассчитанныеНачисления.Добавить();
			СтрокаРасчитанныеНачисления.Сотрудник = ИсходныеДанные.Сотрудник;
		КонецЕсли;
		
		СтрокаРасчитанныеНачисления.ЦелевойРазмер = СтрокаРасчитанныеНачисления.ЦелевойРазмер + ИсходныеДанные.ЦелевойРазмер;
		СтрокаРасчитанныеНачисления.Сумма = СтрокаРасчитанныеНачисления.Сумма + Результат;
		СтрокаРасчитанныеНачисления.СуммаОблагаемаяОПВ = СтрокаРасчитанныеНачисления.СуммаОблагаемаяОПВ + ?(ИсходныеДанные.УчитыватьОПВ, Результат, 0);
		СтрокаРасчитанныеНачисления.СуммаОблагаемаяВОСМС = СтрокаРасчитанныеНачисления.СуммаОблагаемаяВОСМС + ?(ИсходныеДанные.УчитыватьВОСМС, Результат, 0);
		СтрокаРасчитанныеНачисления.СуммаОблагаемаяИПН = СтрокаРасчитанныеНачисления.СуммаОблагаемаяИПН + ?(ИсходныеДанные.УчитыватьИПН, Результат, 0);
		// определим сумму использованного вычета без вычетов ОПВ и ВОСМС
		СтрокаРасчитанныеНачисления.ПримененныйВычетИПН = СтрокаРасчитанныеНачисления.ПримененныйВычетИПН + ПримененныйВычетИПН; 
		
	КонецЦикла;
	
	Для Каждого СтрокаРезультата Из РассчитанныеНачисления Цикл
		НайденнаяСтрока = РасчитанныеНачисленияПредыдущихИтераций.Получить(СтрокаРезультата.Сотрудник);
		Если НайденнаяСтрока = Неопределено Тогда
			РасчитанныеНачисленияПредыдущихИтераций.Вставить(СтрокаРезультата.Сотрудник, Новый Структура("Сумма, ЦелевойРазмер, СуммаОблагаемаяОПВ, СуммаОблагаемаяВОСМС, СуммаОблагаемаяИПН, ПримененныйВычетИПН", СтрокаРезультата.Сумма, СтрокаРезультата.ЦелевойРазмер, СтрокаРезультата.СуммаОблагаемаяОПВ, СтрокаРезультата.СуммаОблагаемаяВОСМС, СтрокаРезультата.СуммаОблагаемаяИПН, СтрокаРезультата.ПримененныйВычетИПН));
		Иначе
			НайденнаяСтрока.Сумма = НайденнаяСтрока.Сумма + СтрокаРезультата.Сумма; 
			НайденнаяСтрока.ЦелевойРазмер = НайденнаяСтрока.ЦелевойРазмер + СтрокаРезультата.ЦелевойРазмер; 
			НайденнаяСтрока.СуммаОблагаемаяОПВ = НайденнаяСтрока.СуммаОблагаемаяОПВ + СтрокаРезультата.СуммаОблагаемаяОПВ; 
			НайденнаяСтрока.СуммаОблагаемаяВОСМС = НайденнаяСтрока.СуммаОблагаемаяВОСМС + СтрокаРезультата.СуммаОблагаемаяВОСМС; 
			НайденнаяСтрока.СуммаОблагаемаяИПН = НайденнаяСтрока.СуммаОблагаемаяИПН + СтрокаРезультата.СуммаОблагаемаяИПН; 
			НайденнаяСтрока.ПримененныйВычетИПН = НайденнаяСтрока.ПримененныйВычетИПН + ПримененныйВычетИПН; 
		КонецЕсли;
	КонецЦикла;
	
 	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);

КонецПроцедуры

Процедура РассчитатьНачисленияОчередностиПосле2025(МесяцНачисления, ОкончательныйРасчетЗарплаты, СтрокиРасчета, МенеджерВременныхТаблиц, ОчередностьРасчета, РасчитанныеНачисленияПредыдущихИтераций, НачисленияСКорректировкой, ЭтоРасчетКорректировокДохода = Ложь, Организация, КэшСтрокиНабораНачисленияПоИдентификаторам = Неопределено)
	
	УничтожитьВТ = Новый Массив;
	
	ПоказательСуммаНаРуки = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ОтОбратногоСуммаНаРуки");
	ПоказательОтОбратногоОПВ = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ОтОбратногоОПВ");
	ПоказательОтОбратногоВОСМС = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ОтОбратногоВОСМС");
	ПоказательОтОбратногоИПН = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ОтОбратногоИПН");
	ПоказательОтОбратногоУдержания = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ОтОбратногоУдержания");
	
	ВычисляемыеПоказатели = Новый Массив;
	ВычисляемыеПоказатели.Добавить(ПоказательСуммаНаРуки);
	ВычисляемыеПоказатели.Добавить(ПоказательОтОбратногоОПВ);
	ВычисляемыеПоказатели.Добавить(ПоказательОтОбратногоВОСМС);
	ВычисляемыеПоказатели.Добавить(ПоказательОтОбратногоИПН);
	ВычисляемыеПоказатели.Добавить(ПоказательОтОбратногоУдержания);
	ТочностьПоказателей = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(ВычисляемыеПоказатели, "Точность");
	
	РассчитанныеНачисления = Новый ТаблицаЗначений;
	РассчитанныеНачисления.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РассчитанныеНачисления.Колонки.Добавить("ЦелевойРазмер", Новый ОписаниеТипов("Число"));
	РассчитанныеНачисления.Колонки.Добавить("Сумма", Новый ОписаниеТипов("Число"));
	РассчитанныеНачисления.Колонки.Добавить("СуммаОблагаемаяОПВ", Новый ОписаниеТипов("Число"));
	РассчитанныеНачисления.Колонки.Добавить("СуммаОблагаемаяВОСМС", Новый ОписаниеТипов("Число"));
	РассчитанныеНачисления.Колонки.Добавить("СуммаОблагаемаяИПН", Новый ОписаниеТипов("Число"));
	РассчитанныеНачисления.Колонки.Добавить("ПримененныйВычетИПН", Новый ОписаниеТипов("Число"));
	// проиндексируем для быстрого поиска
	РассчитанныеНачисления.Индексы.Добавить("ФизическоеЛицо");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ОчередностьРасчета", ОчередностьРасчета);
	Запрос.УстановитьПараметр("ЭтоРасчетКорректировокДохода", ЭтоРасчетКорректировокДохода);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("МесяцНачисления", МесяцНачисления);
	
	Если ЭтоРасчетКорректировокДохода Тогда
	
		Запрос.УстановитьПараметр("НачисленияСКорректировкой", НачисленияСКорректировкой);
	
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	НачисленияСКорректировкой.ИдентификаторСтроки КАК ИдентификаторСтроки,
