// @strict-types

////////////////////////////////////////////////////////////////////////////////
// Подсистема "Синхронизация данных".
// Серверные процедуры, обслуживающие правила регистрации объектов.
//
////////////////////////////////////////////////////////////////////////////////

#Область СлужебныйПрограммныйИнтерфейс

#Область ОбработчикиПравилРегистрации

// Заполняет настройки обработчиков правил регистрации для объекта метаданных.
// 
// Параметры:
//  Настройки - см. СинхронизацияДанныхЗарплатаКадрыСервер.НоваяТаблицаНастроекОбработчиковПравилРегистрации
//  ОбъектМетаданных - ОбъектМетаданных
Процедура ПриЗаполненииНастроекОбработчиковПравилРегистрации(Настройки, ОбъектМетаданных) Экспорт
	
	// ЗарплатаКадрыПриложения.БазовыеСправочныеДанные
	Если ОбъектМетаданных = Метаданные.Справочники.СпособыОтраженияЗарплатыВБухУчете
		Или ОбъектМетаданных = Метаданные.РегистрыСведений.НастройкиСистемыНалогообложения Тогда
		
		ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляРегламентированныхДанных(Настройки);
	
	ИначеЕсли ОбъектМетаданных = Метаданные.Справочники.Организации Тогда
		
		Настройка = Настройки.Добавить();
		Настройка.ПриОбработкеПослеИзменения = Истина;
		Настройка.ПриОбработкеПередИзменением = Истина;
		Настройка.ПослеОбработки = Истина;
		Настройка.Модуль = СинхронизацияДанныхЗарплатаКадрыПриложения;
	
	// ЗарплатаКадрыПриложения.ВнешниеХозяйственныеОперации.ВзаиморасчетыССотрудникамиВХО
	ИначеЕсли ОбъектМетаданных = Метаданные.Справочники.ПлатежноеПоручениеПрисоединенныеФайлы Тогда
		
		ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляСправочникаПрисоединенныхФайлов(Настройки);
	
	ИначеЕсли ОбъектМетаданных = Метаданные.Документы.ПлатежноеПоручение Тогда
		
		ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОтбораПоОрганизации(Настройки);
		ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОбъектаСПрисоединеннымиФайлами(Настройки);
	
	// ЗарплатаКадрыПриложения.ОценочныеОбязательстваЗарплатаКадры
	ИначеЕсли ОбъектМетаданных =
		Метаданные.Справочники.НачислениеОценочныхОбязательствПоОтпускамПрисоединенныеФайлы Тогда
		
		ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляСправочникаПрисоединенныхФайлов(Настройки);
	
	ИначеЕсли ОбъектМетаданных = Метаданные.Документы.НачислениеОценочныхОбязательствПоОтпускам Тогда
		
		ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОтбораПоОрганизации(Настройки);
		ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОбъектаСПрисоединеннымиФайлами(Настройки);
			
	ИначеЕсли ОбъектМетаданных = Метаданные.РегистрыСведений.ЗарплатаКадрыДолиСписанияКосвенныхРасходов
		Или ОбъектМетаданных = Метаданные.РегистрыСведений.НастройкиРасчетаРезервовОтпусков Тогда
		
		ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОтбораПоОрганизации(Настройки);
	
	ИначеЕсли ОбъектМетаданных = Метаданные.РегистрыСведений.РасчетРезерваОтпусков
		Или ОбъектМетаданных = Метаданные.РегистрыНакопления.ОценочныеОбязательства
		Или ОбъектМетаданных = Метаданные.РегистрыНакопления.ОценочныеОбязательстваПоСотрудникам Тогда
		
		ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляРегистраПодчиненногоРегистратору(Настройки);
		
	ИначеЕсли ОбъектМетаданных =
		Метаданные.Справочники.РезервыПоОплатеТрудаПрисоединенныеФайлы Тогда
		
		ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляСправочникаПрисоединенныхФайлов(Настройки);
		
	ИначеЕсли ОбъектМетаданных = Метаданные.Документы.РезервыПоОплатеТруда Тогда
		
		ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОтбораПоОрганизации(Настройки);
		ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОбъектаСПрисоединеннымиФайлами(Настройки);
		
	ИначеЕсли ОбъектМетаданных = Метаданные.Справочники.НастройкиРасчетаРезервовПоОплатеТруда
		Или ОбъектМетаданных = Метаданные.Справочники.ВидыРасчетовРезервовПоОплатеТруда Тогда
		
		ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОтбораПоОрганизации(Настройки);
		
	ИначеЕсли ОбъектМетаданных = Метаданные.РегистрыСведений.НазначениеПоказателейРасчетаРезервов
		Или ОбъектМетаданных = Метаданные.РегистрыСведений.ЗначенияПоказателейРасчетаРезервов Тогда
		
		ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОтбораПоОрганизации(Настройки);
	
	// ЗарплатаКадрыПриложения.ПодразделенияОрганизаций
	ИначеЕсли ОбъектМетаданных = Метаданные.Справочники.ПодразделенияОрганизаций Тогда
		
		ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОтбораПоОрганизации(Настройки, "Владелец",
			СинхронизацияДанныхЗарплатаКадрыСервер.ИдентификаторыРазделовДанных().ОбщиеДанные);
	
	// ЗарплатаКадрыПриложения.УчетДепонированнойЗарплаты
	ИначеЕсли ОбъектМетаданных = Метаданные.Справочники.ДепонированиеЗарплатыПрисоединенныеФайлы
		Или ОбъектМетаданных = Метаданные.Справочники.СписаниеДепонированнойЗарплатыПрисоединенныеФайлы Тогда
		
		ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляСправочникаПрисоединенныхФайлов(Настройки);
	
	ИначеЕсли ОбъектМетаданных = Метаданные.Документы.ДепонированиеЗарплаты
		Или ОбъектМетаданных = Метаданные.Документы.СписаниеДепонированнойЗарплаты Тогда
		
		ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОтбораПоОрганизации(Настройки);
		ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОбъектаСПрисоединеннымиФайлами(Настройки);
		
	ИначеЕсли ОбъектМетаданных = Метаданные.РегистрыНакопления.ВзаиморасчетыСДепонентами Тогда
		
		ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляРегистраПодчиненногоРегистратору(Настройки);
	
	КонецЕсли;
	
КонецПроцедуры

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ШаблонОбработчикаПриОбработкеПередИзменением
Процедура ПриОбработкеПравилаРегистрацииПередИзменениемОбъекта(Объект, Отказ, Параметры) Экспорт
	
	ОбъектМетаданных = Метаданные.НайтиПоПолномуИмени(Параметры.ПРО.ОбъектМетаданныхИмя);
	
	Если ОбъектМетаданных = Метаданные.Справочники.Организации Тогда
		
		ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Ссылка,
			"ЕстьОбособленныеПодразделения, ГоловнаяОрганизация");
		ПриОбработкеПравилаРегистрацииОрганизации(Объект, Отказ, ЗначенияРеквизитов.ЕстьОбособленныеПодразделения,
			ЗначенияРеквизитов.ГоловнаяОрганизация, Параметры);
			
	Иначе
		
		Сообщение = СтрШаблон(НСтр("ru = 'Для объекта вида %1 не реализован обработчик.'"),
			ОбъектМетаданных.ПолноеИмя());
		Контекст = НСтр(
			"ru = 'СинхронизацияДанныхЗарплатаКадрыПриложения.ПриОбработкеПравилаРегистрацииПередИзменениемОбъекта'");
		ОбщегоНазначенияКлиентСервер.Проверить(Ложь, Сообщение, Контекст);
		
	КонецЕсли;
	
КонецПроцедуры

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ШаблонОбработчикаПриОбработкеПослеИзменения
Процедура ПриОбработкеПравилаРегистрацииПослеИзмененияОбъекта(Объект, Отказ, Параметры) Экспорт
	
	ОбъектМетаданных = Метаданные.НайтиПоПолномуИмени(Параметры.ПРО.ОбъектМетаданныхИмя);
	
	Если ОбъектМетаданных = Метаданные.Справочники.Организации Тогда
		
		ПриОбработкеПравилаРегистрацииОрганизации(Объект, Отказ, Объект.ЕстьОбособленныеПодразделения,
			Объект.ГоловнаяОрганизация, Параметры);
			
	Иначе
		
		Сообщение = СтрШаблон(НСтр("ru = 'Для объекта вида %1 не реализован обработчик.'"),
			ОбъектМетаданных.ПолноеИмя());
		Контекст = НСтр(
			"ru = 'СинхронизацияДанныхЗарплатаКадрыПриложения.ПриОбработкеПравилаРегистрацииПослеИзмененияОбъекта'");
		ОбщегоНазначенияКлиентСервер.Проверить(Ложь, Сообщение, Контекст);
		
	КонецЕсли;
	
КонецПроцедуры

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ШаблонОбработчикаПослеОбработки
Процедура ПослеОбработкиПравилаРегистрации(Объект, Отказ, Параметры) Экспорт
	
	ОбъектМетаданных = Метаданные.НайтиПоПолномуИмени(Параметры.ПРО.ОбъектМетаданныхИмя);
	
	Если ОбъектМетаданных = Метаданные.Справочники.Организации Тогда
		
		ПослеОбработкиПравилаРегистрацииОрганизации(Объект, Отказ, Параметры);
		
	Иначе
		
		Сообщение = СтрШаблон(НСтр("ru = 'Для объекта вида %1 не реализован обработчик.'"),
			ОбъектМетаданных.ПолноеИмя());
		Контекст = НСтр("ru = 'СинхронизацияДанныхЗарплатаКадрыПриложения.ПослеОбработкиПравилаРегистрации'");
		ОбщегоНазначенияКлиентСервер.Проверить(Ложь, Сообщение, Контекст);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#ОБласть ОбработчикиОбъектов

Процедура ПриОбработкеПравилаРегистрацииОрганизации(Объект, Отказ, ЕстьОбособленныеПодразделения, ГоловнаяОрганизация,
	Параметры)

	Если ЕстьОбособленныеПодразделения Тогда
		СинхронизацияДанныхЗарплатаКадры.ОграничитьРегистрациюОбъектаОтборомПоГоловнымОрганизациям(Объект,
			ГоловнаяОрганизация, Отказ, Параметры);
	Иначе
		Организации = Новый Массив;
		Организации.Добавить(Объект.Ссылка);
		Если ЗначениеЗаполнено(Объект.ГоловнаяОрганизация) Тогда
			Организации.Добавить(Объект.ГоловнаяОрганизация);
		КонецЕсли;
		СинхронизацияДанныхЗарплатаКадры.ОграничитьРегистрациюОбъектаОтборомПоОрганизациям(Объект, Организации, Отказ,
			Параметры);
	КонецЕсли;

КонецПроцедуры

Процедура ПослеОбработкиПравилаРегистрацииОрганизации(Объект, Отказ, Параметры)
	
	СинхронизацияДанныхЗарплатаКадры.ОбъектыСПрисоединеннымиФайламиПослеОбработкиПравилаРегистрации(Объект, Отказ,
		Параметры);
	
	Если ЗначениеЗаполнено(Объект.ГоловнаяОрганизация) И ОбщегоНазначения.СсылкаСуществует(Объект.ГоловнаяОрганизация)
		И Объект.Ссылка <> Объект.ГоловнаяОрганизация Тогда
			
		ПланыОбмена.ЗарегистрироватьИзменения(Параметры.Получатели, Объект.ГоловнаяОрганизация);
		СинхронизацияДанныхЗарплатаКадры.ЗарегистрироватьСвязанныеРегистрыСведенийОбъекта(Параметры.ПРО.ИмяПланаОбмена,
			Отказ, Объект.ГоловнаяОрганизация, Параметры.Выгрузка, Параметры.Получатели);
			
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#КонецОбласти
