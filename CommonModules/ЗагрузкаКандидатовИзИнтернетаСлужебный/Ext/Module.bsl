#Область СлужебныеПроцедурыИФункции

Функция ЗагрузкаКандидатовИзИнтернетаДоступна() Экспорт
	Возврат Истина;
КонецФункции

Функция ПользовательПоТокену(Токен) Экспорт
	Возврат РегистрыСведений.ДоступДляЗагрузкиКандидатовИзИнтернета.ПользовательПоТокену(Токен);
КонецФункции

Функция ОписаниеПрофиляИспользованиеЗагрузкиКандидатовИзИнтернета() Экспорт
	
	ОписаниеПрофиля = УправлениеДоступом.НовоеОписаниеПрофиляГруппДоступа();
	ОписаниеПрофиля.Идентификатор = ИдентификаторПрофиляЗагрузкаКандидатовИзИнтернета();
	ОписаниеПрофиля.Наименование  = НСтр("ru = 'Загрузка кандидатов из Интернета'");

	ЗагрузкаКандидатовИзИнтернета.ДополнитьОписаниеПрофиля(ОписаниеПрофиля);

	ОписаниеПрофиля.ВидыДоступа.Добавить("Пользователи");

	Возврат ОписаниеПрофиля;

КонецФункции

Функция ИдентификаторПрофиляЗагрузкаКандидатовИзИнтернета()
	Возврат "4bcbdba3-2846-469f-af26-27918a0b7fc9";
КонецФункции

#Область ЗагрузкаКандидатов

Процедура ОбработатьОчередьЗагрузкиКандидатов() Экспорт
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.ЗагрузкаКандидатовИзИнтернета);
	ЗагрузитьКандидатовИзИнтернета();
КонецПроцедуры

Процедура ЗагрузитьКандидатовИзИнтернета(Пользователь = Неопределено) Экспорт

	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Загрузки.Идентификатор КАК Идентификатор,
		|	Загрузки.АдресРезюме КАК АдресРезюме,
		|	Загрузки.Пользователь КАК Пользователь,
		|	Загрузки.Вакансия КАК Вакансия,
		|	Загрузки.ГруппаДоступаКандидата КАК ГруппаДоступаКандидата,
		|	Загрузки.КомментарийПользователя КАК КомментарийПользователя,
		|	Загрузки.ДоступностьКомментария КАК ДоступностьКомментария
		|ИЗ
		|	РегистрСведений.ЗагрузкаКандидатовИзИнтернета КАК Загрузки
		|ГДЕ
		|	Загрузки.Пользователь = &Пользователь
		|	И Загрузки.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияЗагрузкиКандидатовИзИнтернета.Зарегистрирован)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Загрузки.Пользователь,
		|	Загрузки.ДатаРегистрации";
	Если Пользователь = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "Загрузки.Пользователь = &Пользователь", "ИСТИНА");
	КонецЕсли;
	
	Обход = Обработки.ОбходКоллекции.НовыйОбход(Запрос.Выполнить().Выгрузить());
	Пока Обход.СледующийПоЗначениюПоля("Пользователь") Цикл
		Пока Обход.Следующий() Цикл
			ДанныеЗагрузки = Обход.ТекущиеДанные();
			Попытка
				ЗагрузитьКандидата(ДанныеЗагрузки);
			Исключение
				ЗаписатьОшибкуВЖурналРегистрации(НСтр("ru = 'Обработка очереди загрузок'"), 
					ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
				// Записываем проблему в регистр, чтобы можно было обработать повторно
				УстановитьСостояниеЗагрузки(ДанныеЗагрузки.Идентификатор, 
					Перечисления.СостоянияЗагрузкиКандидатовИзИнтернета.ОшибкаЗагрузки, 
					ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			КонецПопытки;
		КонецЦикла;
	КонецЦикла;

КонецПроцедуры

Процедура ЗагрузитьКандидата(ДанныеЗагрузки)

	// 1. Скачиваем резюме с рекрутингового сайта (вне транзакции).
	ДанныеКандидата = РекрутинговыеСайты.ДанныеКандидатаССайта(ДанныеЗагрузки.АдресРезюме, ДанныеЗагрузки.Пользователь);
	
	// 2. Уточняем данные кандидата.
	ДанныеКандидата.Вакансия = ДанныеЗагрузки.Вакансия;
	ДанныеКандидата.Ответственный = ДанныеЗагрузки.Пользователь;
	ДанныеКандидата.АдресРезюме = ДанныеЗагрузки.АдресРезюме;
	ДанныеКандидата.ГруппаДоступаКандидата = ДанныеЗагрузки.ГруппаДоступаКандидата;
	РекрутинговыеСайты.ДобавитьКомментарийПользователя(ДанныеКандидата, ДанныеЗагрузки.Пользователь, 
		ДанныеЗагрузки.КомментарийПользователя, ДанныеЗагрузки.ДоступностьКомментария);

	// Отметка успешно обработанной загрузки будет установлена при записи кандидата по этому доп. свойству.
	ЗначенияЗаполнения = Новый Структура();
	ЗначенияЗаполнения.Вставить("ДляЗаписи", Новый Структура("ИдентификаторЗагрузки", ДанныеЗагрузки.Идентификатор));

	// 3. Создаем кандидата.
	Блокировка = Новый БлокировкаДанных();
	Блокировка.Добавить(Метаданные.РегистрыСведений.ЗагрузкаКандидатовИзИнтернета.ПолноеИмя())
		.УстановитьЗначение("Идентификатор", ДанныеЗагрузки.Идентификатор);
	НачатьТранзакцию();
	Попытка
		Блокировка.Заблокировать();
		Если ДанныеКандидата.ДоступностьКонтактов.КонтактыОткрыты Или Не ПустаяСтрока(ФИОКандидата(ДанныеКандидата)) Тогда
			ЕстьОднофамильцы = Ложь;
			ДругиеКандидаты = ДанныеКандидатовПоАдресуРезюме(ДанныеКандидата.АдресРезюме); // ТаблицаЗначений
			Если ДругиеКандидаты.Количество() > 0 Тогда
				ДругиеКандидаты.Сортировать("ДатаРегистрации Убыв");
				ЛичныеДанныеКандидата = ДругиеКандидаты[0].ЛичныеДанныеКандидата; // СправочникСсылка.ЛичныеДанныеКандидатов
				ГруппаДоступа = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЛичныеДанныеКандидата, "ГруппаДоступа");
				Если ДанныеЗагрузки.ГруппаДоступаКандидата <> ГруппаДоступа Тогда
					Если ЛичныеДанныеКандидатаДоступныПользователю(ЛичныеДанныеКандидата,
						ДанныеЗагрузки.Пользователь) <> Истина Тогда
						// Не можем "повесить" резюме на эти личные данные кандидата,
						// т.к. к ним или нет доступа, или не смогли определить, есть ли доступ,
						// а группа доступа изменяется, поэтому есть риск, что недоступные данные станут доступными.
						ЕстьОднофамильцы = Истина;
					КонецЕсли;
				КонецЕсли;
				ДанныеКандидата.ЛичныеДанныеКандидата = ЛичныеДанныеКандидата;
			КонецЕсли;
			Если Не ЕстьОднофамильцы Тогда
				КандидатОбъект = Справочники.Кандидаты.СоздатьЭлемент();
				КандидатОбъект.Заполнить(ДанныеКандидата);
				КандидатОбъект.Заполнить(ЗначенияЗаполнения);
				
				СвязанныеЛичныеДанныеКандидата =
					КандидатОбъект.ДополнительныеСвойства.СвязанныеОбъекты.ЛичныеДанныеКандидата;
				
				ПараметрыПоиска = СотрудникиКлиентСервер.ПараметрыПоискаПохожих();
				ПараметрыПоиска.Фамилия = СвязанныеЛичныеДанныеКандидата.Фамилия;
				ПараметрыПоиска.Имя = СвязанныеЛичныеДанныеКандидата.Имя;
				ПараметрыПоиска.Отчество = СвязанныеЛичныеДанныеКандидата.Отчество;
				
				РезультатПроверкиФизическихЛиц = СотрудникиФормы.ПодобратьСписокФизЛиц(ПараметрыПоиска);
					
				ПараметрыПоискаКандидатов = ПодборПерсоналаФормы.ПараметрыПоискаПохожихКандидатов();
				ЗаполнитьЗначенияСвойств(ПараметрыПоискаКандидатов, СвязанныеЛичныеДанныеКандидата,
					"Фамилия,Имя,Отчество,УточнениеНаименования");
				ПараметрыПоискаКандидатов.Ссылка = СвязанныеЛичныеДанныеКандидата.Ссылка;
				Телефон = "";
				АдресЭлектроннойПочты = "";
				Для Каждого ЭлементКИ Из ДанныеКандидата.КонтактнаяИнформация Цикл
					Если ЭлементКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон Тогда
						Телефон = ЭлементКИ.Представление;
					КонецЕсли;
					Если ЭлементКИ.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты Тогда
						АдресЭлектроннойПочты = ЭлементКИ.Представление;
					КонецЕсли;
				КонецЦикла;
				ПараметрыПоискаКандидатов.Телефон = Телефон;
				ПараметрыПоискаКандидатов.EMail = АдресЭлектроннойПочты;
				
				РезультатПроверкиКандидатов = ПодборПерсоналаФормы.ПодобратьПохожихКандидатов(
					ПараметрыПоискаКандидатов, Истина);
					
				Если РезультатПроверкиКандидатов.КандидатУникален
					И РезультатПроверкиФизическихЛиц.ФизическоеЛицоУникально Тогда
					КандидатОбъект.Записать();
					ПроверитьДоступностьКандидата(КандидатОбъект, ДанныеЗагрузки);
				Иначе
					ЕстьОднофамильцы = Истина;
				КонецЕсли;
			КонецЕсли;
			Если ЕстьОднофамильцы Тогда
				УстановитьСостояниеЗагрузки(ДанныеЗагрузки.Идентификатор, 
					Перечисления.СостоянияЗагрузкиКандидатовИзИнтернета.ЕстьОднофамильцы);
			КонецЕсли;
					
		Иначе
			// Контакты не открыты, пока не можем загрузить этого кандидата.
			УстановитьСостояниеЗагрузки(ДанныеЗагрузки.Идентификатор, 
				Перечисления.СостоянияЗагрузкиКандидатовИзИнтернета.КонтактыЗакрыты);
		КонецЕсли;
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры

Процедура ПроверитьДоступностьКандидата(КандидатОбъект, ДанныеЗагрузки)
	
	Если КандидатДоступенПользователю(КандидатОбъект, ДанныеЗагрузки.Пользователь) <> Истина Тогда
		ТекстСообщения = СтрШаблон(
			НСтр("ru = 'Нарушение прав доступа при попытке записать кандидата.
				 |Пользователь: %1,
				 |вакансия: %2,
				 |группа доступа: %3,
				 |адрес резюме: %4'"), 
			ДанныеЗагрузки.Пользователь, 
			ДанныеЗагрузки.Вакансия, 
			ДанныеЗагрузки.ГруппаДоступаКандидата, 
			ДанныеЗагрузки.АдресРезюме);
		ВызватьИсключение ТекстСообщения;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьПроизводительныйВариант()
	
	Если Не УправлениеДоступом.ПроизводительныйВариант() Тогда
		ВызватьИсключение НСтр("ru = 'Невозможно проверить права доступа, 
				 |требуется перейти в «Производительный» вариант работы ограничения на уровне записей.'");
	КонецЕсли;
	
КонецПроцедуры

Функция КандидатДоступенПользователю(КандидатОбъект, Пользователь)

	Если Не УправлениеДоступом.ОграничиватьДоступНаУровнеЗаписей() Тогда
		Возврат Истина;
	КонецЕсли;

	ПроверитьПроизводительныйВариант();

	Возврат УправлениеДоступом.ИзменениеРазрешено(КандидатОбъект, Пользователь);
	
КонецФункции

Функция ЛичныеДанныеКандидатаДоступныПользователю(ЛичныеДанныеКандидата, Пользователь)

	Если Не ПолучитьФункциональнуюОпцию("ОграничиватьДоступНаУровнеЗаписейЛичныеДанныеКандидатов") Тогда
		Возврат Истина;
	КонецЕсли;

	ПроверитьПроизводительныйВариант();

	Возврат УправлениеДоступом.ИзменениеРазрешено(ЛичныеДанныеКандидата, Пользователь);

КонецФункции

Процедура УстановитьСостояниеЗагрузки(Идентификатор, Состояние, Комментарий = "")
	ДанныеСостояния = РегистрыСведений.ЗагрузкаКандидатовИзИнтернета.НовыеДанныеСостояния();
	ДанныеСостояния.Состояние = Состояние;
	ДанныеСостояния.Комментарий = Комментарий;
	РегистрыСведений.ЗагрузкаКандидатовИзИнтернета.УстановитьСостояниеЗагрузкиКандидата(Идентификатор, ДанныеСостояния);
КонецПроцедуры

Функция ФИОКандидата(ДанныеКандидата)
	Возврат ("" + ДанныеКандидата.Фамилия + ДанныеКандидата.Имя + ДанныеКандидата.Отчество); 
КонецФункции

#КонецОбласти

#Область Кандидаты

Функция КандидатыПоURLJSON(URLРезюме) Экспорт
	Возврат ДанныеКандидатовJSON(ДанныеКандидатовПоАдресуРезюме(URLРезюме));
КонецФункции

Функция ДанныеКандидатовПоАдресуРезюме(АдресРезюме)
	Возврат Справочники.Кандидаты.ДанныеКандидатов(
		Справочники.Кандидаты.КандидатыПоОтбору(
			Новый Структура("АдресРезюме", РекрутинговыеСайтыКлиентСервер.АдресРезюмеПоUrlРезюме(АдресРезюме))));
КонецФункции

Функция ДанныеКандидатовJSON(ДанныеКандидатов)
	
	ДанныеJSON = Новый Массив;
	
	ДанныеВакансий = Справочники.Вакансии.ДанныеВакансий(ДанныеКандидатов.ВыгрузитьКолонку("Вакансия"));
	
	Ответственные = Новый Массив; // Массив Из СправочникСсылка.Пользователи
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Ответственные, 
		ДанныеВакансий.ВыгрузитьКолонку("Ответственный"), Истина);
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Ответственные, 
		ДанныеКандидатов.ВыгрузитьКолонку("Ответственный"), Истина);
	
	ОтветственныеФизическиеЛица = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(Ответственные, "ФизическоеЛицо"); // Соответствие
	
	ФизическиеЛица = Новый Массив;
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ФизическиеЛица, 
		ОбщегоНазначения.ВыгрузитьКолонку(ОтветственныеФизическиеЛица, "Значение"), Истина);
	
	КадровыеДанные = КадровыйУчет.КадровыеДанныеФизическихЛиц(Истина, ФизическиеЛица, "ФИО, Пол");
	
	Для Каждого ДанныеКандидата Из ДанныеКандидатов Цикл
		ДанныеJSON.Добавить(
			КандидатВJSON(ДанныеКандидата, ДанныеВакансий, ОтветственныеФизическиеЛица, КадровыеДанные));
	КонецЦикла;
	
	Возврат ДанныеJSON;
	
КонецФункции

Функция КандидатВJSON(ДанныеКандидата, ДанныеВакансий, ОтветственныеФизическиеЛица, КадровыеДанные)

	Данные = ОписаниеКандидата();
	Данные.ID = Строка(ДанныеКандидата.Кандидат.УникальныйИдентификатор());
	Данные.vacancy = ВакансияВJSON(ДанныеКандидата.Вакансия, ДанныеВакансий, ОтветственныеФизическиеЛица, КадровыеДанные);
	Данные.dateCreated = ДанныеКандидата.ДатаРегистрации;
	Данные.name = ДанныеКандидата.ФИО;
	Данные.gender = ПолВJSON(ДанныеКандидата.Пол);
	Данные.recruiter = ОтветственныйВJSON(ДанныеКандидата.Ответственный, ОтветственныеФизическиеЛица, КадровыеДанные);

	Возврат Данные;

КонецФункции

Функция ОписаниеКандидата()
	
	Описание = Новый Структура();
	Описание.Вставить("ID", "");
	Описание.Вставить("type", "applicant");
	Описание.Вставить("name", "");
	Описание.Вставить("gender", "");
	Описание.Вставить("dateCreated");
	Описание.Вставить("vacancy");
	Описание.Вставить("recruiter");
	
	Возврат Описание;
	
КонецФункции

#КонецОбласти

#Область Вакансии

Функция ОткрытыеВакансииПользователяJSON(Пользователь) Экспорт
	
	Отбор = Новый ОтборКомпоновкиДанных();
	ГруппаИЛИ = ОбщегоНазначенияКлиентСервер.СоздатьГруппуЭлементовОтбора(Отбор, 
		НСтр("ru = 'Вакансии пользователя'"), ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли);
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ГруппаИЛИ, "Ответственный", Пользователь);
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ГруппаИЛИ, "Заявитель", Пользователь);
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Отбор, 
		"Состояние", Перечисления.СостоянияВакансии.Действующие(), ВидСравненияКомпоновкиДанных.ВСписке);
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Отбор, "ПометкаУдаления", Ложь);
	
	Возврат ДанныеВакансийJSON(
		Справочники.Вакансии.ДанныеВакансий(Справочники.Вакансии.ВакансииПоОтбору(Отбор.Элементы)));

КонецФункции

Функция ДанныеВакансийJSON(ДанныеВакансий)
	
	ДанныеJSON = Новый Массив;

	ОтветственныеЗаВакансии = ОбщегоНазначения.ВыгрузитьКолонку(ДанныеВакансий, "Ответственный", Истина); // Массив Из СправочникСсылка.Пользователи
	ОтветственныеФизическиеЛица = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(ОтветственныеЗаВакансии, "ФизическоеЛицо");

	КадровыеДанные = КадровыйУчет.КадровыеДанныеФизическихЛиц(Истина, 
		ОбщегоНазначения.ВыгрузитьКолонку(ОтветственныеФизическиеЛица, "Значение"), "ФИО, Пол");
	
	Для Каждого ДанныеВакансии Из ДанныеВакансий Цикл
		ДанныеJSON.Добавить(
			ВакансияВJSON(ДанныеВакансии.Вакансия, ДанныеВакансий, ОтветственныеФизическиеЛица, КадровыеДанные));
	КонецЦикла;
	
	Возврат ДанныеJSON;
	
КонецФункции

Функция ВакансияВJSON(Вакансия, ДанныеВакансий, ОтветственныеФизическиеЛица, КадровыеДанные)
	
	Если Не ЗначениеЗаполнено(Вакансия) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	НайденныеСтроки = ДанныеВакансий.НайтиСтроки(Новый Структура("Вакансия", Вакансия));
	Если НайденныеСтроки.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Данные = ОписаниеВакансии();
	Данные.ID = Строка(НайденныеСтроки[0].Вакансия.УникальныйИдентификатор());
	Данные.code = НайденныеСтроки[0].Код;
	Данные.description = НайденныеСтроки[0].Наименование;
	Данные.job = Строка(НайденныеСтроки[0].ПрофильДолжности);
	Данные.division = Строка(НайденныеСтроки[0].Подразделение);
	Данные.recruiter = ОтветственныйВJSON(
		НайденныеСтроки[0].Ответственный, ОтветственныеФизическиеЛица, КадровыеДанные);
	
	Возврат Данные;
	
КонецФункции

Функция ОписаниеВакансии()

	Описание = Новый Структура();
	Описание.Вставить("ID", "");
	Описание.Вставить("code", "");
	Описание.Вставить("description", "");
	Описание.Вставить("job");
	Описание.Вставить("division");
	Описание.Вставить("recruiter");
	
	Возврат Описание;
	
КонецФункции

