Функция ОтветственныйВJSON(Ответственный, ОтветственныеФизическиеЛица, КадровыеДанные)
	
	Если Не ЗначениеЗаполнено(Ответственный) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ФИО = ФИООтветственного(Ответственный, ОтветственныеФизическиеЛица, КадровыеДанные);
	Пол = ПолОтветственного(Ответственный, ОтветственныеФизическиеЛица, КадровыеДанные);
	
	ТворительныйПадеж = "";
	Если ЗначениеЗаполнено(ФИО) Тогда
		ФизическиеЛицаЗарплатаКадры.Просклонять(ФИО, 5, ТворительныйПадеж, Пол, ОтветственныеФизическиеЛица[Ответственный]);
	КонецЕсли;
	
	Данные = ОписаниеПользователя();
	Данные.ID = Строка(Ответственный.УникальныйИдентификатор());
	Данные.name = ФИО;
	Если ЗначениеЗаполнено(ТворительныйПадеж) Тогда
		Данные.creativeCase = ФизическиеЛицаЗарплатаКадрыКлиентСервер.ФамилияИнициалы(ТворительныйПадеж);
	КонецЕсли;
	
	Возврат Данные;
	
КонецФункции

Функция ФИООтветственного(Ответственный, ОтветственныеФизическиеЛица, КадровыеДанные)
	
	Если Не ЗначениеЗаполнено(Ответственный) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ФИОФизическогоЛица(ОтветственныеФизическиеЛица[Ответственный], КадровыеДанные);
	
КонецФункции

Функция ПолОтветственного(Ответственный, ОтветственныеФизическиеЛица, КадровыеДанные)
	
	Если Не ЗначениеЗаполнено(Ответственный) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ПолФизическогоЛица(ОтветственныеФизическиеЛица[Ответственный], КадровыеДанные);
	
КонецФункции

Функция ФИОФизическогоЛица(ФизическоеЛицо, КадровыеДанные)
	
	Если Не ЗначениеЗаполнено(ФизическоеЛицо) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	НайденныеСтроки = КадровыеДанные.НайтиСтроки(Новый Структура("ФизическоеЛицо", ФизическоеЛицо));
	Если НайденныеСтроки.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат НайденныеСтроки[0].ФИО;
	
КонецФункции

Функция ПолФизическогоЛица(ФизическоеЛицо, КадровыеДанные)
	
	Если Не ЗначениеЗаполнено(ФизическоеЛицо) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	НайденныеСтроки = КадровыеДанные.НайтиСтроки(Новый Структура("ФизическоеЛицо", ФизическоеЛицо));
	Если НайденныеСтроки.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат НайденныеСтроки[0].Пол;
	
КонецФункции

Функция ПолВJSON(Пол)
	
	ПолВJSON = Новый Соответствие;
	ПолВJSON.Вставить(Перечисления.ПолФизическогоЛица.Мужской, "male");
	ПолВJSON.Вставить(Перечисления.ПолФизическогоЛица.Женский, "female");
	
	Возврат ПолВJSON[Пол];
	
КонецФункции

