	Возврат ОперацииЗагрузкиВJSON(РегистрыСведений.ЗагрузкаКандидатовИзИнтернета.ЗависшиеОперацииЗагрузки(URLРезюме));
КонецФункции

Функция ОперацииЗагрузкиВJSON(Операции)
	
	ОперацииJSON = Новый Массив;
	
	ДанныеВакансий = Справочники.Вакансии.ДанныеВакансий(Операции.ВыгрузитьКолонку("Вакансия"));

	Ответственные = Операции.ВыгрузитьКолонку("Пользователь"); // Массив Из СправочникСсылка.Пользователи
	ОтветственныеФизическиеЛица = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(Ответственные, "ФизическоеЛицо"); // Соответствие

	КадровыеДанные = КадровыйУчет.КадровыеДанныеФизическихЛиц(Истина, 
		ОбщегоНазначения.ВыгрузитьКолонку(ОтветственныеФизическиеЛица, "Значение", Истина), "ФИО, Пол");
	
	Для Каждого Операция Из Операции Цикл
		ОперацииJSON.Добавить(ОперацияЗагрузкиВJSON(Операция, ДанныеВакансий, ОтветственныеФизическиеЛица, КадровыеДанные));
	КонецЦикла;
	
	Возврат ОперацииJSON;
	
КонецФункции

Функция ОперацияЗагрузкиКандидатаJSON(ИдентификаторЗагрузки) Экспорт

	Возврат ОперацияЗагрузкиВJSON(
		РегистрыСведений.ЗагрузкаКандидатовИзИнтернета.СостояниеЗагрузкиКандидата(ИдентификаторЗагрузки));
	
КонецФункции

Функция ОперацияЗагрузкиВJSON(ДанныеОперации, 
	ДанныеВакансий = Неопределено, ОтветственныеФизическиеЛица = Неопределено, КадровыеДанные = Неопределено)
	
	Если ДанныеОперации = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Результат = ОписаниеОперации(ДанныеВакансий <> Неопределено, ОтветственныеФизическиеЛица <> Неопределено);
	Результат.ID = Строка(ДанныеОперации.Идентификатор);
	Результат.dateCreated = ДанныеОперации.ДатаРегистрации;
	Результат.status = СостояниеОперацииВJSON(ДанныеОперации.Состояние);
	Результат.changedAt = ДанныеОперации.ДатаСостояния;
	Результат.note = ДанныеОперации.КомментарийСостояния;
	
	Если ДанныеВакансий <> Неопределено Тогда
		Результат.vacancy = ВакансияВJSON(ДанныеОперации.Вакансия, ДанныеВакансий, ОтветственныеФизическиеЛица, КадровыеДанные);
	КонецЕсли;

	Если ОтветственныеФизическиеЛица <> Неопределено Тогда
		Результат.recruiter = ОтветственныйВJSON(ДанныеОперации.Пользователь, ОтветственныеФизическиеЛица, КадровыеДанные);
	КонецЕсли;

	Возврат Результат;

КонецФункции

Функция ИдентификаторСсылки(ИдентификаторСтрокой, МенеджерОбъекта)
	
	Результат = Новый Структура();
	Результат.Вставить("ОК", Истина);
	Результат.Вставить("Ссылка");
	Результат.Вставить("Ошибка");
	
	Попытка
		Результат.Ссылка = МенеджерОбъекта.ПолучитьСсылку(Новый УникальныйИдентификатор(ИдентификаторСтрокой));
	Исключение
		Результат.ОК = Ложь;
		Результат.Ошибка = ВидыОшибок().НеверныйИдентификатор;
		Возврат Результат;
	КонецПопытки;

	Если Не ОбщегоНазначения.СсылкаСуществует(Результат.Ссылка) Тогда
		Результат.ОК = Ложь;
		Результат.Ошибка = ВидыОшибок().ОбъектНеНайден;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ВидыОшибок() Экспорт
	
	ВидыОшибок = Новый Структура();
	ВидыОшибок.Вставить("СостояниеНеактуально", "СостояниеНеактуально");
	ВидыОшибок.Вставить("НеверныйИдентификатор", "НеверныйИдентификатор");
	ВидыОшибок.Вставить("ОбъектНеНайден", "ОбъектНеНайден");
	ВидыОшибок.Вставить("КонфликтПриЗаписи", "КонфликтПриЗаписи");
	
	Возврат ВидыОшибок;
	
КонецФункции

Функция ОписаниеОперации(СВакансией = Ложь, СПользователем = Ложь)
	
	Описание = Новый Структура();
	Описание.Вставить("ID", "");
	Описание.Вставить("type", "import-operation");
	Описание.Вставить("status", "");
	Описание.Вставить("dateCreated", Дата(1, 1, 1));
	Описание.Вставить("changedAt", Дата(1, 1, 1));
	Описание.Вставить("note", "");
	Если СВакансией Тогда
		Описание.Вставить("vacancy");
	КонецЕсли;
	Если СПользователем Тогда
		Описание.Вставить("recruiter");
	КонецЕсли;
	
	Возврат Описание;
	
КонецФункции

Функция СостояниеОперацииВJSON(Состояние)
	
	Соответствие = Новый Соответствие();
	Соответствие.Вставить(Перечисления.СостоянияЗагрузкиКандидатовИзИнтернета.Зарегистрирован, "pending");
	Соответствие.Вставить(Перечисления.СостоянияЗагрузкиКандидатовИзИнтернета.Загружен, "processed");
	Соответствие.Вставить(Перечисления.СостоянияЗагрузкиКандидатовИзИнтернета.КонтактыЗакрыты, "missingContacts");
	Соответствие.Вставить(Перечисления.СостоянияЗагрузкиКандидатовИзИнтернета.ЕстьОднофамильцы, "namesakesDetected");
	Соответствие.Вставить(Перечисления.СостоянияЗагрузкиКандидатовИзИнтернета.ОшибкаЗагрузки, "error");
	
	Возврат Соответствие[Состояние];
	
КонецФункции

Функция ДоступностьКомментарияИзJSON(ДоступностьJSON)

