Функция НоваяОперацияЗагрузкиJSON(Пользователь, ДанныеКандидата, СостояниеСписка) Экспорт

	Результат = Новый Структура();
	Результат.Вставить("ОК", Истина);
	Результат.Вставить("Результат");
	Результат.Вставить("Ошибка");
	Результат.Вставить("Поле");
	
	ДанныеЗагрузки = РегистрыСведений.ЗагрузкаКандидатовИзИнтернета.НовыеДанныеЗагрузки();
	ДанныеЗагрузки.АдресРезюме = РекрутинговыеСайтыКлиентСервер.АдресРезюмеПоUrlРезюме(ДанныеКандидата.url);
	
	Вакансия = ИдентификаторСсылки(ДанныеКандидата.vacancyID, Справочники.Вакансии);
	Если Не Вакансия.ОК Тогда
		Результат.ОК = Ложь;
		Результат.Ошибка = Вакансия.Ошибка;
		Результат.Поле = "vacancyID";
		Возврат Результат;
	КонецЕсли;
	ДанныеЗагрузки.Вакансия = Вакансия.Ссылка;
	
	Если ДанныеКандидата.Свойство("accessGroupID") Тогда
		ГруппаДоступа = ИдентификаторСсылки(ДанныеКандидата.accessGroupID, Справочники.ГруппыДоступаКандидатов);
		Если Не ГруппаДоступа.ОК Тогда
			Результат.ОК = Ложь;
			Результат.Ошибка = ГруппаДоступа.Ошибка;
			Результат.Поле = "accessGroupID";
			Возврат Результат;
		КонецЕсли;
		ДанныеЗагрузки.ГруппаДоступаКандидата = ГруппаДоступа.Ссылка;
	КонецЕсли;

	ДанныеЗагрузки.КомментарийПользователя = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДанныеКандидата, "note", "");
	Если ДанныеКандидата.Свойство("noteAccess") Тогда
		ДанныеЗагрузки.ДоступностьКомментария = ДоступностьКомментарияИзJSON(ДанныеКандидата.noteAccess);
	КонецЕсли;
	
	Блокировка = Новый БлокировкаДанных();
	Элемент = Блокировка.Добавить(Метаданные.РегистрыСведений.СостояниеЗагрузкиКандидатовИзИнтернета.ПолноеИмя());
	Элемент.УстановитьЗначение("Пользователь", Пользователь);
	
	НачатьТранзакцию();
	Попытка
		Блокировка.Заблокировать();
		Состояние = РегистрыСведений.СостояниеЗагрузкиКандидатовИзИнтернета.ТекущаяЗаписьСостояния(Пользователь);
		Если Строка(Состояние) <> СостояниеСписка Тогда
			ОтменитьТранзакцию();
			Результат.ОК = Ложь;
			Результат.Ошибка = ВидыОшибок().СостояниеНеактуально;
			Возврат Результат;
		КонецЕсли;
		ИдентификаторЗагрузки = РегистрыСведений.ЗагрузкаКандидатовИзИнтернета.НоваяЗагрузкаКандидата(ДанныеЗагрузки, Пользователь);
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		Результат.ОК = Ложь;
		Результат.Ошибка = ВидыОшибок().КонфликтПриЗаписи;
		ЗаписатьОшибкуВЖурналРегистрации(НСтр("ru = 'Регистрация загрузки в очереди'"), 
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат Результат;
	КонецПопытки;

	Результат.Результат = ОперацияЗагрузкиКандидатаJSON(ИдентификаторЗагрузки);

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне();
	ДлительныеОперации.ВыполнитьПроцедуру(ПараметрыВыполнения, 
		"ЗагрузкаКандидатовИзИнтернета.ЗагрузитьКандидатовИзИнтернета", Пользователь);
	
	Возврат Результат;
	
КонецФункции

