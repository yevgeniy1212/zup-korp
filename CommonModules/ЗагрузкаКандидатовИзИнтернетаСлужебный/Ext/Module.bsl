КонецФункции

Процедура ДополнитьШаблонамиСтраниц(ДанныеИсточников, Пользователь)
	
	ШаблоныСтраниц = РекрутинговыеСайты.ШаблоныСтраницСайтов(Пользователь);
	
	ДанныеИсточников.Колонки.Добавить("ГлавнаяСтраницаСайта", Новый ОписаниеТипов("Строка"));
	ДанныеИсточников.Колонки.Добавить("Логотип", Новый ОписаниеТипов("Картинка"));
	ДанныеИсточников.Колонки.Добавить("ШаблонURLРезюме", Новый ОписаниеТипов("Строка"));
	ДанныеИсточников.Колонки.Добавить("РегулярноеВыражениеURLСайта", Новый ОписаниеТипов("Строка"));
	ДанныеИсточников.Колонки.Добавить("РегулярноеВыражениеURLРезюме", Новый ОписаниеТипов("Строка"));
	
	Для Каждого СтрокаИсточника Из ДанныеИсточников Цикл
		ШаблоныСайта = ШаблоныСтраниц.НайтиСтроки(Новый Структура("Сайт", СтрокаИсточника.Ссылка));
		ОбщегоНазначенияКлиентСервер.Проверить(ШаблоныСайта.Количество() > 0 И ЗначениеЗаполнено(ШаблоныСайта[0].РегулярноеВыражениеURLСайта), 
			НСтр("ru = 'Для используемого сайта %1 не обнаружено шаблонов url страниц, 
				 |их использование необходимо для корректной работы расширения'"));
		СтрокаИсточника.ГлавнаяСтраницаСайта = ШаблоныСайта[0].ГлавнаяСтраница;
		
		СтрокаИсточника.Логотип = ШаблоныСайта[0].Логотип;
		СтрокаИсточника.ШаблонURLРезюме = ШаблоныСайта[0].ШаблонURLРезюме;
		СтрокаИсточника.РегулярноеВыражениеURLСайта = ШаблоныСайта[0].РегулярноеВыражениеURLСайта;
		СтрокаИсточника.РегулярноеВыражениеURLРезюме = ШаблоныСайта[0].РегулярноеВыражениеURLРезюме;
	КонецЦикла;
	
КонецПроцедуры

