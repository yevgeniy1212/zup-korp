#Область СКД

Функция СформироватьТекстУдаленнаяРаботаПрием(РежимДистанционнойРаботы, УсловияПриема) Экспорт

	ТекстРежимДистанционнойРаботы = "";
	
	Если ЗначениеЗаполнено(РежимДистанционнойРаботы) Тогда
		
		ТекстРежимДистанционнойРаботы = ?(ЗначениеЗаполнено(УсловияПриема), ", ", "") + ?(ЗначениеЗаполнено(УсловияПриема), НРег(РежимДистанционнойРаботы), РежимДистанционнойРаботы);
		
	КонецЕсли;

	Возврат ТекстРежимДистанционнойРаботы;
	
КонецФункции

Функция СформироватьТекстУдаленнаяРаботаПеревод(РежимДистанционнойРаботы, НовыйРежимДистанционнойРаботы, ПричинаПеревода) Экспорт
	
	ТекстРежимДистанционнойРаботы = "";
	
	Если НовыйРежимДистанционнойРаботы <> РежимДистанционнойРаботы Тогда
		
		Если НЕ ЗначениеЗаполнено(НовыйРежимДистанционнойРаботы) Тогда
			
			Если РежимДистанционнойРаботы = Перечисления.РежимыДистанционнойРаботы.КомбинированнаяДистанционнаяРабота Тогда
				ТекстРежимДистанционнойРаботы = НСтр("ru = 'комбинированной дистанционной работы'")	
			Иначе
				ТекстРежимДистанционнойРаботы = НСтр("ru = 'дистанционной работы'")	
			КонецЕсли;
			
			ТекстРежимДистанционнойРаботы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = '%1 %2 %3'"), ?(ЗначениеЗаполнено(ПричинаПеревода), ",", ""),
							        ?(ЗначениеЗаполнено(ПричинаПеревода), НСтр("ru = 'возврат с'"), НСтр("ru = 'Возврат с'")), ТекстРежимДистанционнойРаботы);
		Иначе
			
			Если НовыйРежимДистанционнойРаботы = Перечисления.РежимыДистанционнойРаботы.КомбинированнаяДистанционнаяРабота Тогда
				ТекстРежимДистанционнойРаботы = НСтр("ru = 'комбинированную дистанционную работу'")	
			Иначе
				ТекстРежимДистанционнойРаботы = НСтр("ru = 'дистанционную работу'")	
			КонецЕсли;
			
			ТекстРежимДистанционнойРаботы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = '%1 %2 %3'"), ?(ЗначениеЗаполнено(ПричинаПеревода), ",", ""),
							        ?(ЗначениеЗаполнено(ПричинаПеревода), НСтр("ru = 'перевод на'"), НСтр("ru = 'Перевод на'")), ТекстРежимДистанционнойРаботы);
		КонецЕсли;
		
	КонецЕсли;

	Возврат ТекстРежимДистанционнойРаботы;
	
КонецФункции

Функция СформироватьТекстУдаленнаяРаботаПереводСписком(РежимДистанционнойРаботы, НовыйРежимДистанционнойРаботы) Экспорт
	
	ТекстРежимДистанционнойРаботы = "";
	
    Если НовыйРежимДистанционнойРаботы <> РежимДистанционнойРаботы Тогда
        Если НЕ ЗначениеЗаполнено(НовыйРежимДистанционнойРаботы) Тогда
            
            Если РежимДистанционнойРаботы = Перечисления.РежимыДистанционнойРаботы.КомбинированнаяДистанционнаяРабота Тогда
                ТекстРежимДистанционнойРаботы = НСтр("ru = 'комбинированной дистанционной работы'")	
            Иначе
                ТекстРежимДистанционнойРаботы = НСтр("ru = 'дистанционной работы'")	
            КонецЕсли;
            
            ТекстРежимДистанционнойРаботы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = ', %1 %2'"), НСтр("ru = 'возврат с'"), ТекстРежимДистанционнойРаботы);
        Иначе
            
            Если НовыйРежимДистанционнойРаботы = Перечисления.РежимыДистанционнойРаботы.КомбинированнаяДистанционнаяРабота Тогда
                ТекстРежимДистанционнойРаботы = НСтр("ru = 'комбинированную дистанционную работу'")	
            Иначе
                ТекстРежимДистанционнойРаботы = НСтр("ru = 'дистанционную работу'")	
            КонецЕсли;
            
            ТекстРежимДистанционнойРаботы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = ', %1 %2'"), НСтр("ru = 'перевод на'"), ТекстРежимДистанционнойРаботы);
        КонецЕсли;
    КонецЕсли;
	
	Возврат ТекстРежимДистанционнойРаботы;
	
КонецФункции

Функция СформироватьТекстУдаленнаяРаботаПереводСпискомПрежнее(РежимДистанционнойРаботы) Экспорт
	
	ТекстРежимДистанционнойРаботы = "";
	
	Если ЗначениеЗаполнено(РежимДистанционнойРаботы) Тогда
		
		ТекстРежимДистанционнойРаботы = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = ', %1 %2'"), НСтр("ru = 'перевод на'"), НРег(РежимДистанционнойРаботы));
		
	КонецЕсли;

	Возврат ТекстРежимДистанционнойРаботы;
	
КонецФункции

