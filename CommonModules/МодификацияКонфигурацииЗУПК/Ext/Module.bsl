			НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "НалогообложениеНачислений.ВидДохода";
			НовыйЭлемент.СписокВыбора.ЗагрузитьЗначения(Справочники.ВидыДоходов.ВыплатыБывшимСотрудникам());
