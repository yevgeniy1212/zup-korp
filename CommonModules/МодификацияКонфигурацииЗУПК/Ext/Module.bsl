#КонецОбласти

#Область ГрупповоеРедактированиеНачислений
	
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ГрупповоеРедактированиеНачислений") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("Форма") Тогда
			
			Форма.Заголовок = НСтр("ru = 'Настройка налогообложения, среднего заработка и пр.'");
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницаСреднийЗаработокОбщий", "Заголовок", НСтр("ru = 'Средний заработок (больничные, отпуска и др.)'"));
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницаНДФЛ", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницаСреднийЗаработокФСС2010", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницаПФРФССФОМС", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницаСтатистическаяОтчетность", "Видимость", Ложь);
			
			ГруппаНалогиВзносыОтчисления = Элементы.Добавить("ГруппаНалогиВзносыОтчисления", Тип("ГруппаФормы"), Элементы.СтраницыРасчетныеБазы);
			ГруппаНалогиВзносыОтчисления.Вид = ВидГруппыФормы.Страница;
			ГруппаНалогиВзносыОтчисления.Заголовок  = НСтр("ru = 'Налоги, взносы, отчисления'");
			
			ГруппаРеквизитыНалогиВзносыОтчисления = Элементы.Добавить("ГруппаРеквизитыНалогиВзносыОтчисления", Тип("ГруппаФормы"), ГруппаНалогиВзносыОтчисления);
			ГруппаРеквизитыНалогиВзносыОтчисления.Вид = ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаРеквизитыНалогиВзносыОтчисления.Отображение = ОтображениеОбычнойГруппы.СлабоеВыделение;
			ГруппаРеквизитыНалогиВзносыОтчисления.ОтображатьЗаголовок = Ложь;
			ГруппаРеквизитыНалогиВзносыОтчисления.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
			
			НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияПериод", Тип("ПолеФормы"), ГруппаРеквизитыНалогиВзносыОтчисления);
			НовыйЭлемент.Вид				 = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным		 = "НалогиВзносыОтчисленияПериодСтрокой";
			НовыйЭлемент.КнопкаВыбора		 = Истина;
			НовыйЭлемент.КнопкаРегулирования = Истина;
			НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_НалогиВзносыОтчисленияПериодПриИзменении");
			НовыйЭлемент.УстановитьДействие("НачалоВыбора", "Подключаемый_НалогиВзносыОтчисленияПериодНачалоВыбора");
			НовыйЭлемент.УстановитьДействие("Регулирование", "Подключаемый_НалогиВзносыОтчисленияПериодРегулирование");
			НовыйЭлемент.УстановитьДействие("ОбработкаВыбора", "Подключаемый_НалогиВзносыОтчисленияПериодОбработкаВыбора");
			НовыйЭлемент.УстановитьДействие("АвтоПодбор", "Подключаемый_НалогиВзносыОтчисленияПериодАвтоПодбор");
			НовыйЭлемент.УстановитьДействие("ОкончаниеВводаТекста", "Подключаемый_НалогиВзносыОтчисленияПериодОкончаниеВводаТекста");
			
			НовыйЭлемент = Элементы.Добавить("ВидДохода", Тип("ПолеФормы"), ГруппаРеквизитыНалогиВзносыОтчисления);
			НовыйЭлемент.Вид		 = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "ВидДохода";
			НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_ВидДоходаПриИзменении");
			
			ГруппаСтраницыНалогиВзносыОтчисления = Элементы.Добавить("ГруппаСтраницыНалогиВзносыОтчисления", Тип("ГруппаФормы"), ГруппаНалогиВзносыОтчисления);
			ГруппаСтраницыНалогиВзносыОтчисления.Вид = ВидГруппыФормы.Страницы;
			
			СоздатьЭлементыРеквизитовНВОБазаНачислений(Форма, ГруппаСтраницыНалогиВзносыОтчисления, "ОПВ", "обязательных пенсионных взносов");
			СоздатьЭлементыРеквизитовНВОБазаНачислений(Форма, ГруппаСтраницыНалогиВзносыОтчисления, "ВОСМС", "взносов на обязательное медицинское страхование");
			СоздатьЭлементыРеквизитовНВОБазаНачислений(Форма, ГруппаСтраницыНалогиВзносыОтчисления, "ИПН", "индивидуального подоходного налога");
			СоздатьЭлементыРеквизитовНВОБазаНачислений(Форма, ГруппаСтраницыНалогиВзносыОтчисления, "СО", "обязательных социальных отчислений");
			СоздатьЭлементыРеквизитовНВОБазаНачислений(Форма, ГруппаСтраницыНалогиВзносыОтчисления, "СН", "социального налога");
			СоздатьЭлементыРеквизитовНВОБазаНачислений(Форма, ГруппаСтраницыНалогиВзносыОтчисления, "ООСМС", "отчислений на обязательное медицинское страхование");
			СоздатьЭлементыРеквизитовНВОБазаНачислений(Форма, ГруппаСтраницыНалогиВзносыОтчисления, "ОПВР", "обязательных пенсионных взносов работодателя");
			СоздатьЭлементыРеквизитовНВОБазаНачислений(Форма, ГруппаСтраницыНалогиВзносыОтчисления, "ОППВ", "обязательных профессиональных пенсионных взносов");

		КонецЕсли;
		
#КонецОбласти

	КонецЕсли;

	МодификацияКонфигурацииЗУПКПереопределяемый.ОбработатьСобытияФормПриСозданииОбработки(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);

КонецПроцедуры

Процедура ОбработатьСобытияФормПриСозданииЧтенииСправочник(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры)

	Элементы = Форма.Элементы;

#Область Организации

	Если ДополнительныеПараметры.ИмяОбъекта = ВРег("Организации") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаЭлемента") Тогда
			
			// РФ данные
			
			МассивСкрываемыхРеквизитов = Новый Массив;
			
			МассивСкрываемыхРеквизитов.Добавить("ГруппаТерриториальныеУсловияПФР");
			МассивСкрываемыхРеквизитов.Добавить("УчетнаяПолитикаОрганизацийГруппа");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаКодОГРН");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаОсновныеСведенияПравая");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаОКВЭД2");
            МассивСкрываемыхРеквизитов.Добавить("ОрганизацияОКПОКартинка");
            МассивСкрываемыхРеквизитов.Добавить("ОрганизацияОКПОНадпись");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаФонды");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаЭДО");
			Для Каждого СкрываемыйРеквизит из МассивСкрываемыхРеквизитов Цикл
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, СкрываемыйРеквизит, "Видимость", Ложь);
			КонецЦикла;	
			
			НовыйЭлемент = Элементы.Добавить("КБЕ", Тип("ПолеФормы"), Элементы.ГруппаИНН);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным 		= "Объект.КБЕ";
			НовыйЭлемент.АвтоОтметкаНезаполненного = Истина;
            НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_КБЕПриИзменении");
			
			НовыйЭлемент = Элементы.Вставить("СтранаРегистрации", Тип("ПолеФормы"), Элементы.Главное, Элементы.ГруппаРегистрацияВНалоговомОргане);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным 		= "Объект.СтранаРегистрации";
			НовыйЭлемент.АвтоОтметкаНезаполненного = Истина;
			
			НовыйЭлемент = Элементы.Добавить("СоответствиеРеквизитовПечатиНаРусскомИГосударственномЯзыках", Тип("КнопкаФормы"), Элементы.ГруппаНастройкиОрганизации);
			НовыйЭлемент.Вид = ВидКнопкиФормы.Гиперссылка;
			НовыйЭлемент.ИмяКоманды = "СоответствиеРеквизитовПечатиНаРусскомИГосударственномЯзыках";
			НовыйЭлемент.РасширеннаяПодсказка.Заголовок = НСтр("ru = 'Используются для печатных форм, утвержденных ПП РК ""Об утверждении Правил документирования, управления документацией и использования систем электронного документооборота в государственных и негосударственных организациях"".'");
			НовыйЭлемент.ОтображениеПодсказки = ОтображениеПодсказки.ОтображатьСнизу;
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "КодОКВЭДExtendedTooltip", "Заголовок", НСтр("ru = 'Код по Общему классификатору видов экономической деятельности (ОКЭД).'"));
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "КодОКВЭД", "Заголовок", НСтр("ru = 'ОКЭД'"));

		КонецЕсли;
			
#КонецОбласти

#Область ПодразделенияОрганизаций

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ПодразделенияОрганизаций") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаЭлемента") Тогда
			
			// РФ данные
			
			МассивСкрываемыхРеквизитов = Новый Массив;
			
			МассивСкрываемыхРеквизитов.Добавить("ТерриториальныеУсловияПФРТерриториальныеУсловияПФР");
			МассивСкрываемыхРеквизитов.Добавить("ГруппаТерриториальныеУсловияПФРПериодИстория");
			МассивСкрываемыхРеквизитов.Добавить("ГруппаПроцентЗаОсобыеКлиматическиеУсловия");
			МассивСкрываемыхРеквизитов.Добавить("ГруппаДетализацияМестВыплат");
			МассивСкрываемыхРеквизитов.Добавить("РКГруппа");
			Для Каждого СкрываемыйРеквизит из МассивСкрываемыхРеквизитов Цикл
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, СкрываемыйРеквизит, "Видимость", Ложь);
			КонецЦикла;	
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "КодОКВЭДExtendedTooltip", "Заголовок", НСтр("ru = 'Код по Общему классификатору видов экономической деятельности (ОКЭД).'"));
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "КодОКВЭД", "Заголовок", НСтр("ru = 'ОКЭД'"));
			
			// налогообложение начислений
			ГруппаУчетВремениПриРасчетеСреднегоЗаработка = Элементы.Добавить("УчетВремениПриРасчетеСреднегоЗаработка", Тип("ГруппаФормы"), Элементы.ЛеваяКолонкаШапка);
			ГруппаУчетВремениПриРасчетеСреднегоЗаработка.Вид = ВидГруппыФормы.ОбычнаяГруппа;
            ГруппаУчетВремениПриРасчетеСреднегоЗаработка.Заголовок = НСтр("ru = 'Учет рабочего времени при расчете среднего заработка'"); 
            ГруппаУчетВремениПриРасчетеСреднегоЗаработка.Отображение = ОтображениеОбычнойГруппы.Нет;

			НовыйЭлемент = Элементы.Добавить("РасчетСреднегоЗаработкаПодразделенийУчетРабочегоВремени", Тип("ПолеФормы"), ГруппаУчетВремениПриРасчетеСреднегоЗаработка);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным 		= "РасчетСреднегоЗаработкаПодразделений.УчетРабочегоВремени";
            НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_РасчетСреднегоЗаработкаПодразделенийУчетРабочегоВремениПриИзменении");

			НовыйЭлемент = Элементы.Добавить("РасчетСреднегоЗаработкаПодразделенийУчетРабочегоВремениДляСуммированногоУчета", Тип("ПолеФормы"), ГруппаУчетВремениПриРасчетеСреднегоЗаработка);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным 		= "РасчетСреднегоЗаработкаПодразделений.УчетРабочегоВремениДляСуммированногоУчета";
	        НовыйЭлемент.СписокВыбора.Добавить(Перечисления.УчетРабочегоВремениПриРасчетеСреднегоЗаработка.ПустаяСсылка(), НСтр("ru = 'По фактическим графикам сотрудников'"));
            НовыйЭлемент.ПодсказкаВвода     = НСтр("ru = 'По фактическим графикам сотрудников'");
			НовыйЭлемент.КнопкаОчистки 		= Истина;
            НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_РасчетСреднегоЗаработкаПодразделенийУчетРабочегоВремениДляСуммированногоУчетаПриИзменении");

            ГруппаДатаУчетаРабочегоВремени = Элементы.Добавить("ДатаУчетаРабочегоВремени", Тип("ГруппаФормы"), ГруппаУчетВремениПриРасчетеСреднегоЗаработка);
			ГруппаДатаУчетаРабочегоВремени.Вид = ВидГруппыФормы.ОбычнаяГруппа;
  			ГруппаДатаУчетаРабочегоВремени.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
  			ГруппаДатаУчетаРабочегоВремени.ОтображатьЗаголовок = Ложь;
			
			НовыйЭлемент = Элементы.Добавить("РасчетСреднегоЗаработкаПодразделенийПериодСтрокой", Тип("ПолеФормы"), ГруппаДатаУчетаРабочегоВремени);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.Заголовок 			= НСтр("ru = 'действует с'");
			НовыйЭлемент.КнопкаВыбора 		= Истина;
			НовыйЭлемент.КнопкаРегулирования = Истина;
			НовыйЭлемент.Ширина 			= 14;
			НовыйЭлемент.ПутьКДанным 		= "РасчетСреднегоЗаработкаПодразделенийПериодСтрокой";
            НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_РасчетСреднегоЗаработкаПодразделенийПериодСтрокойПриИзменении");
            НовыйЭлемент.УстановитьДействие("НачалоВыбора", "Подключаемый_РасчетСреднегоЗаработкаПодразделенийПериодСтрокойНачалоВыбора");
            НовыйЭлемент.УстановитьДействие("Регулирование", "Подключаемый_РасчетСреднегоЗаработкаПодразделенийПериодСтрокойРегулирование");
            НовыйЭлемент.УстановитьДействие("АвтоПодбор", "Подключаемый_РасчетСреднегоЗаработкаПодразделенийПериодСтрокойАвтоПодбор");
            НовыйЭлемент.УстановитьДействие("ОкончаниеВводаТекста", "Подключаемый_РасчетСреднегоЗаработкаПодразделенийПериодСтрокойОкончаниеВводаТекста");

			НовыйЭлемент = Элементы.Добавить("РасчетСреднегоЗаработкаПодразделенийИстория", Тип("КнопкаФормы"), ГруппаДатаУчетаРабочегоВремени);
			НовыйЭлемент.Вид = ВидКнопкиФормы.Гиперссылка;
			НовыйЭлемент.ИмяКоманды = "РасчетСреднегоЗаработкаПодразделенийИстория";

		КонецЕсли;

#КонецОбласти

#Область РегистрацииВНалоговомОргане
		
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("РегистрацииВНалоговомОргане") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаЭлемента") Тогда
			
			НовыйЭлемент = Элементы.Вставить("ИНН", Тип("ПолеФормы"), Форма, Элементы.КПП);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным 		= "Объект.ИНН";
            НовыйЭлемент.УстановитьДействие("ОкончаниеВводаТекста", "Подключаемый_ИННОкончаниеВводаТекста");
			
		ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("ФормаПредставителя") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Доверенность", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаПодсказкаДоверенность", "Видимость", Ложь);
			
		КонецЕсли;
			
#КонецОбласти

#Область БанковскиеСчетаКонтрагентов
		
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("БанковскиеСчетаКонтрагентов") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаЭлемента") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "БИКБанка", "Маска", "UUUUUUUU");
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаПроверка", "Видимость", Ложь);
			
		КонецЕсли;
		
#КонецОбласти

#Область Контрагенты

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("Контрагенты") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаЭлемента") Тогда
			
			ГруппаКодПоОКПОКБЕ = Элементы.Вставить("КодПоОКПОКБЕ", Тип("ГруппаФормы"), , Элементы.КодПоОКПО);
			ГруппаКодПоОКПОКБЕ.Вид = ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаКодПоОКПОКБЕ.ОтображатьЗаголовок = Ложь;
			ГруппаКодПоОКПОКБЕ.Отображение = ОтображениеОбычнойГруппы.Нет;
			
			Элементы.Переместить(Элементы.КодПоОКПО, ГруппаКодПоОКПОКБЕ);
			
			Элементы.ИНН.АвтоОтметкаНезаполненного = Истина;
			
			НовыйЭлемент = Элементы.Добавить("КБЕ", Тип("ПолеФормы"), ГруппаКодПоОКПОКБЕ);
			НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "Объект.КБЕ";
			НовыйЭлемент.АвтоОтметкаНезаполненного = Истина;
            НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_КБЕПриИзменении");
			
			НовыйЭлемент = Элементы.Вставить("СтранаРегистрации", Тип("ПолеФормы"), Форма, Элементы.БанковскийСчет);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным 		= "Объект.СтранаРегистрации";
			НовыйЭлемент.АвтоОтметкаНезаполненного = Истина;
			
		ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("ФормаСписка") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "КПП", "Видимость", Ложь);
			
		КонецЕсли;

#КонецОбласти

#Область ОбразованиеФизическихЛиц

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ОбразованиеФизическихЛиц") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаЭлемента") Тогда
			
			// РФ данные
			
			МассивСкрываемыхРеквизитов = Новый Массив;
			
			МассивСкрываемыхРеквизитов.Добавить("ЗаПределамиРФ");
			Для Каждого СкрываемыйРеквизит из МассивСкрываемыхРеквизитов Цикл
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, СкрываемыйРеквизит, "Видимость", Ложь);
			КонецЦикла;
			
			НовыйЭлемент = Элементы.Вставить("ФормаОбучения", Тип("ПолеФормы"), Элементы.ГруппаВидОбразования, Элементы.ВидПрофессиональногоОбучения);
			НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "Объект.ФормаОбучения";
			
		КонецЕсли;

#КонецОбласти

#Область СоставыВоеннослужащих

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("СоставыВоеннослужащих") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаЭлемента") Тогда
			
			ГруппаКатегорияСоставаВоеннослужащихОфицерскийСостав = Элементы.Вставить("КатегорияСоставаВоеннослужащихОфицерскийСостав", Тип("ГруппаФормы"), , Элементы.ОфицерскийСостав);
			ГруппаКатегорияСоставаВоеннослужащихОфицерскийСостав.Вид = ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаКатегорияСоставаВоеннослужащихОфицерскийСостав.ОтображатьЗаголовок = Ложь;
			ГруппаКатегорияСоставаВоеннослужащихОфицерскийСостав.Отображение = ОтображениеОбычнойГруппы.Нет;
			
			НовыйЭлемент = Элементы.Добавить("КатегорияСоставаВоеннослужащих", Тип("ПолеФормы"), ГруппаКатегорияСоставаВоеннослужащихОфицерскийСостав);
			НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "Объект.КатегорияСоставаВоеннослужащих";
			
			Элементы.Переместить(Элементы.ОфицерскийСостав, ГруппаКатегорияСоставаВоеннослужащихОфицерскийСостав);
			
		ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("ФормаСписка") Тогда
			
			НовыйЭлемент = Элементы.Добавить("КатегорияСоставаВоеннослужащих", Тип("ПолеФормы"), Элементы.Список);
			НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "Список.КатегорияСоставаВоеннослужащих";
			
		КонецЕсли;

#КонецОбласти

#Область Валюты

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("Валюты") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаСписка") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Форма.Команды, "ЗагрузитьКурсыВалют", "Подсказка", НСтр("ru = 'Загрузить курсы валют с веб-сайта Национального банка РК'"));
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Форма.Команды, "ПодборИзКлассификатора", "Подсказка", НСтр("ru = 'Подобрать валюты из классификатора валют'"));
			
		КонецЕсли;

#КонецОбласти

