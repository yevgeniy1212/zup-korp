Процедура ОбработатьСобытияФормПриСозданииЧтенииПланаОбмена(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры)

	Элементы = Форма.Элементы;

#Область СинхронизацияДанныхЧерезУниверсальныйФормат

    Если ДополнительныеПараметры.ИмяОбъекта = ВРег("СинхронизацияДанныхЧерезУниверсальныйФормат") Тогда
    
        Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаУзла") Тогда 
            Группа = Элементы.Добавить("ГруппаВыгружатьСДетализациейПоФизическимЛицам", Тип("ГруппаФормы"), Элементы.ГруппаПрочее);
            Группа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
            Группа.Отображение = ОтображениеОбычнойГруппы.Нет;
            Группа.ОтображатьЗаголовок = Ложь;
            
            
            НовыйЭлемент = Элементы.Вставить("ВыгружатьСДетализациейПоФизическимЛицам", Тип("ПолеФормы"), Элементы.ГруппаВыгружатьСДетализациейПоФизическимЛицам);
            НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеФлажка; 
            НовыйЭлемент.ПоложениеЗаголовка	= ПоложениеЗаголовкаЭлементаФормы.Право;
            НовыйЭлемент.ПутьКДанным 		= "Объект.ВыгружатьСДетализациейПоФизическимЛицам"; 
            НовыйЭлемент.Заголовок 			= НСтр("ru = 'Выгружать с детализацией по физическим лицам'");
            НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_ВыгружатьСДетализациейПоФизическимЛицамПриИзменении");

            НовыйЭлемент = Элементы.Вставить("ВыгружатьСДетализациейПоФизическимЛицамНезарплатныеДоходы", Тип("ПолеФормы"), Элементы.ГруппаВыгружатьСДетализациейПоФизическимЛицам);
            НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеФлажка; 
            НовыйЭлемент.ПоложениеЗаголовка	= ПоложениеЗаголовкаЭлементаФормы.Право;
            НовыйЭлемент.ПутьКДанным 		= "Объект.ВыгружатьСДетализациейПоФизическимЛицамНезарплатныеДоходы"; 
            НовыйЭлемент.Заголовок 			= НСтр("ru = 'Выгружать с детализацией по физическим лицам (незарплатные доходы)'");

            НовыйЭлемент = Элементы.Вставить("ПутьКМенеджеруОбмена", Тип("ПолеФормы"), Элементы.ГруппаСлужебнаяИнформацияПрочее);
            НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода; 
            НовыйЭлемент.ПутьКДанным 		= "Объект.ПутьКМенеджеруОбмена"; 
            НовыйЭлемент.Заголовок 			= НСтр("ru = 'Путь к менеджеру обмена'");
            НовыйЭлемент.КнопкаВыбора 		= Истина;
            НовыйЭлемент.УстановитьДействие("НачалоВыбора", "Подключаемый_ПутьКМенеджеруОбменаНачалоВыбора");

            ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаРежимВыгрузкиПроводок", "Видимость", Ложь);
            ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаОтправкаВедомостейОтчетов", "Видимость", Ложь);
       КонецЕсли;		
        
 #КонецОбласти
    
    КонецЕсли;

	МодификацияКонфигурацииЗУПКПереопределяемый.ОбработатьСобытияФормПриСозданииЧтенииПланаОбмена(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);

КонецПроцедуры

