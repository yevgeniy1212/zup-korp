			НовыйЭлемент = Элементы.Вставить("КлассыУсловийТрудаПоДолжностямОсуществляютсяОППВ", Тип("ПолеФормы"), Элементы.ГруппаСпецоценкаУсловийТрудаКлассыУсловийТруда, Элементы.КлассыУсловийТрудаПоДолжностямПериод);
			НовыйЭлемент.Вид = ВидПоляФормы.ПолеФлажка;
			НовыйЭлемент.ПутьКДанным = "КлассыУсловийТрудаПоДолжностям.ОсуществляютсяОППВ";
			НовыйЭлемент.Заголовок = НСтр("ru = 'Осуществляются ОППВ за занятых на работах с вредными условиями труда'");
			НовыйЭлемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
			
		КонецЕсли;
	
#КонецОбласти

#Область НастройкиРасчетаРезервовПоОплатеТруда
		
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("НастройкиРасчетаРезервовПоОплатеТруда") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаЭлемента") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "КлассУсловийТрудаИстория", "Заголовок", НСтр("ru = 'История изменения особенностей исчисления ПВ'"));
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаСпецоценкаУсловийТруда", "Заголовок", НСтр("ru = 'Особенности исчисления пенсионных взносов'"));
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "КлассыУсловийТрудаПоДолжностямПериод", "Заголовок", НСтр("ru = 'Условия труда установлены с'"));
			
		КонецЕсли;

#КонецОбласти

#Область ПроизводственныеКалендари
		
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ПроизводственныеКалендари") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаСписка") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Создать", "Видимость", Ложь);
			
		ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("ФормаЭлемента") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ФормаСкопировать", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ФормаУстановитьПометкуУдаления", "Видимость", Ложь);
			
		КонецЕсли;

#КонецОбласти

#Область НастройкиОбменСБанками
		
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("НастройкиОбменСБанками") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаЭлемента") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Организация", "ТолькоПросмотр", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Банк", "ТолькоПросмотр", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ВерсияФормата", "РежимВыбораИзСписка", Истина);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ВерсияФормата", "ВыбиратьТип", Истина);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ВерсияФормата", "БыстрыйВыбор", Истина);
			
			Элементы.Банк.УстановитьДействие("ПриИзменении", "Подключаемый_БанкПриИзменении");
			
		КонецЕсли;

#КонецОбласти

	КонецЕсли;
  
	МодификацияКонфигурацииЗУПКПереопределяемый.ОбработатьСобытияФормПриСозданииЧтенииСправочник(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);

КонецПроцедуры

Процедура ОбработатьСобытияФормПриСозданииЧтенииДокумент(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры)

	Элементы = Форма.Элементы;

#Область НачислениеЗарплаты

	Если ДополнительныеПараметры.ИмяОбъекта = ВРег("НачислениеЗарплаты") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаДокумента") Тогда
			
			СоздатьБлокРеквизитовНВОМногосотрудниковыхДокументов(Форма, "Страницы", "ГруппаНачисленияПерерасчеты");

			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Начисления", "ПоложениеСтрокиПоиска", ПоложениеСтрокиПоиска.Авто);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НачисленияПоДоговорам", "ПоложениеСтрокиПоиска", ПоложениеСтрокиПоиска.Авто);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "УправленческиеНачисления", "ПоложениеСтрокиПоиска", ПоложениеСтрокиПоиска.Авто);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Удержания", "ПоложениеСтрокиПоиска", ПоложениеСтрокиПоиска.Авто);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПогашениеЗаймов", "ПоложениеСтрокиПоиска", ПоложениеСтрокиПоиска.Авто);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НачисленияПерерасчет", "ПоложениеСтрокиПоиска", ПоложениеСтрокиПоиска.Авто);
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаПособия", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаВзносы", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПособияПерерасчетСтраницы", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НачисленияСкидкаПоВзносам", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НачисленияПоДоговорамСкидкаПоВзносам", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НачисленияПерерасчетСкидкаПоВзносам", "Видимость", Ложь);
			
		КонецЕсли;

#КонецОбласти

#Область РазовоеНачисление

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("РазовоеНачисление") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаДокумента") Тогда
			
			СоздатьЭлементыРеквизитовНВОМежрасчетМногосотрудниковыйДокумент(Форма);
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НачисленияНДФЛ", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НачисленияКорректировкаВыплаты", "Видимость", Ложь);
			
		КонецЕсли;

#КонецОбласти

#Область Премия

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("Премия") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаДокумента") Тогда
			
			СоздатьЭлементыРеквизитовНВОМежрасчетМногосотрудниковыйДокумент(Форма, "ГруппаКолонокНачисленияМежрасчетныйПериод");
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НачисленияКорректировкаВыплаты", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НачисленияНДФЛ", "Видимость", Ложь);
			
		КонецЕсли;

#КонецОбласти

#Область Отпуск

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("Отпуск") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаДокумента") Тогда
			
			СоздатьЭлементыРеквизитовНВОМежрасчетОдносотрудниковыйДокумент(Форма);
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НачисленияКорректировкаВыплаты", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НачисленияНДФЛ", "Видимость", Ложь);
			
		КонецЕсли;

#КонецОбласти

#Область ОтпускаСотрудников

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ОтпускаСотрудников") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаДокумента") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СотрудникиПечатьТ6", "Заголовок", НСтр("ru = 'Приказ о предоставлении отпуска работникам'"));
			
		КонецЕсли;

#КонецОбласти

#Область ОтпускБезСохраненияОплаты
		
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ОтпускБезСохраненияОплатыСписком") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаДокумента") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СотрудникиПечатьТ6", "Заголовок", НСтр("ru = 'Приказ о предоставлении отпуска работникам'"));
			
		КонецЕсли;

#КонецОбласти

#Область БольничныйЛист

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("БольничныйЛист") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаСписка") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЭтоЭЛН", "Видимость", Ложь);

		ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("ФормаДокумента") Тогда
			
			СоздатьЭлементыРеквизитовНВОМежрасчетОдносотрудниковыйДокумент(Форма);
			
			НовыйЭлемент = Элементы.Добавить("НомерЛисткаНетрудоспособностиРК", Тип("ПолеФормы"), Элементы.ОбязательныеРеквизиты);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным 		= "Объект.НомерЛисткаНетрудоспособности";
			
			НовыйЭлемент = Элементы.Добавить("ОтсутствиеПоДругимМестамРаботы", Тип("ДекорацияФормы"), Элементы.ПричинаНетрудоспособностиГруппа);
			НовыйЭлемент.Вид 				= ВидДекорацииФормы.Надпись;
			НовыйЭлемент.Гиперссылка 		= Истина;
			НовыйЭлемент.Заголовок	 		= НСтр("ru = 'Физическое лицо оформлено по совместительству, необходимо проверить наличие больничного листа по совместительству'");
        	НовыйЭлемент.УстановитьДействие("Нажатие", "Подключаемый_ОтсутствиеПоДругимМестамРаботыНажатие");
			
			НовыйЭлемент = Элементы.Добавить("ПричинаНетрудоспособности", Тип("ПолеФормы"), Элементы.Группа1);
			НовыйЭлемент.ПутьКДанным 		= "Объект.ПричинаНетрудоспособности";
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
        	НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_ПричинаНетрудоспособностиПриИзменении");

			НовыйЭлемент = Элементы.Добавить("СлучайУходаЗаБольнымРебенком", Тип("ПолеФормы"), Элементы.Группа1);
			НовыйЭлемент.ПутьКДанным 		= "Объект.СлучайУходаЗаБольнымРебенком";
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;

			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НадписьСтаж", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтажиНеЗаданыГруппа", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаНомерЛисткаНетрудоспособности", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "УходЗаРодственникамиСтраница", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "УчитыватьЗаработокПредыдущихСтрахователей", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДнейПриостановленияТДГруппа", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПредставлениеПричиныНетрудоспособности", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПереключательПричиныНетрудоспособности01", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПереключательПричиныНетрудоспособности02", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПодменюЭЛН", "Видимость", Ложь);
			
		КонецЕсли;

#КонецОбласти

#Область ИзменениеАванса

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ИзменениеАванса") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("УстановитьРазмер") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "РазмерВРублях", "Заголовок", НСтр("ru = 'Размер аванса в тенге'"));
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДекорацияРубли", "Заголовок", НСтр("ru = 'тг.'"));
			
		КонецЕсли;

#КонецОбласти

#Область ИсполнительныйЛист

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ИсполнительныйЛист") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаДокумента") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Сумма", "Подсказка", НСтр("ru = 'тенге'"));
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДекорацияПредел", "Заголовок", НСтр("ru = 'тенге'"));
			Для Каждого ЭлементСписка Из Элементы.СпособРасчетаПроцентом.СписокВыбора Цикл
				ЭлементСписка.Представление = НСтр("ru = 'Процентом от заработка'");
				Прервать;
			КонецЦикла;
			Для Каждого ЭлементСписка Из Элементы.СпособРасчетаДолей.СписокВыбора Цикл
				ЭлементСписка.Представление = НСтр("ru = 'Долей от заработка'");
				Прервать;
			КонецЦикла;
			
			РолиФизическихЛиц = Новый Массив;
			РолиФизическихЛиц.Добавить(ПредопределенноеЗначение("Перечисление.РолиФизическихЛиц.Сотрудник"));
			РолиФизическихЛиц.Добавить(ПредопределенноеЗначение("Перечисление.РолиФизическихЛиц.БывшийСотрудник"));
			РолиФизическихЛиц.Добавить(ПредопределенноеЗначение("Перечисление.РолиФизическихЛиц.ПрочийПолучательДоходов"));
			МассивПараметровВыбора = Новый Массив();
			ПараметрВыбора = Новый ПараметрВыбора("Отбор.Роль", РолиФизическихЛиц);
			МассивПараметровВыбора.Добавить(ПараметрВыбора);
			Элементы.Сотрудник.ПараметрыВыбора = Новый ФиксированныйМассив(МассивПараметровВыбора);
			
			ГруппаСпособРасчетаПоМРП = Элементы.Вставить("СпособРасчетаПоМРПГруппа", Тип("ГруппаФормы"), Элементы.СпособРасчетаГруппа, Элементы.СпособРасчетаПроцентомГруппа);
			ГруппаСпособРасчетаПоМРП.Вид = ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаСпособРасчетаПоМРП.ОтображатьЗаголовок = Ложь;
			ГруппаСпособРасчетаПоМРП.Отображение = ОтображениеОбычнойГруппы.Нет;
			ГруппаСпособРасчетаПоМРП.Объединенная = Ложь;
			
