#Область ПрограммныйИнтерфейс

Процедура ПриСозданииНаСервере(Форма, Отказ, СтандартнаяОбработка, ТолькоСозданиеРеквизитов) Экспорт

	Если ТолькоСозданиеРеквизитов = Неопределено Тогда

		ОбработатьСозданиеМетаданныхФормы(Форма, Отказ, СтандартнаяОбработка);
		ОбработатьСобытияФормПриСозданииЧтении(Форма, Отказ, СтандартнаяОбработка);

		ДанныеЗУПКИнициализированы(Форма);
		
	ИначеЕсли ТолькоСозданиеРеквизитов = Истина Тогда
		
		ОбработатьСозданиеМетаданныхФормы(Форма, Отказ, СтандартнаяОбработка);
		
	Иначе
		
		ОбработатьСобытияФормПриСозданииЧтении(Форма);
 		ДанныеЗУПКИнициализированы(Форма);

	КонецЕсли;

КонецПроцедуры

Процедура ПриЧтенииНаСервере(Форма) Экспорт

	// данные формы перечитываются
	Если ДанныеЗУПКИнициализированы(Форма) Тогда
		Возврат;
	КонецЕсли;
		
	ОбработатьСозданиеМетаданныхФормы(Форма);
	ОбработатьСобытияФормПриСозданииЧтении(Форма);
	
КонецПроцедуры

Функция ПодменитьЗначениеНедоступногоЭлементаРФ(ИмяЭлемента, ИмяСвойства, Значение) Экспорт

	ЗначениеПодмены = Неопределено;
	
	Если (СтрНайти(ВРег(ИмяЭлемента), ВРег("СкидкаПоВзносам")) > 0
		ИЛИ СтрНайти(ВРег(ИмяЭлемента), ВРег("МестоПолученияДохода")) > 0
		ИЛИ СтрНайти(ВРег(ИмяЭлемента), ВРег("КорректировкиВыплаты")) > 0
		ИЛИ СтрНайти(ВРег(ИмяЭлемента), ВРег("КорректировкаВыплатыГруппа")) > 0
		ИЛИ СтрНайти(ВРег(ИмяЭлемента), ВРег("ГруппаКорректировкиВыплаты")) > 0
		ИЛИ СтрНайти(ВРег(ИмяЭлемента), ВРег("УчитыватьМРОТПриОплатеПоСреднемуЗаработку")) > 0)
		И ИмяСвойства = "Видимость" Тогда
		ЗначениеПодмены = Ложь;
	КонецЕсли;
	
	Возврат ?(ЗначениеЗаполнено(ЗначениеПодмены), ЗначениеПодмены, Значение);
	
КонецФункции

