		НовыйРеквизит = Новый РеквизитФормы("ПериодВзаиморасчетовСтрокой", Новый ОписаниеТипов("Строка", Новый КвалификаторыСтроки(15)), "Выплаты", НСтр("ru = 'Период взаиморасчетов'")); 
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		НовыйРеквизит = Новый РеквизитФормы("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"),"Выплаты"); 
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
        
   		Форма.ИзменитьРеквизиты(МассивДобавляемыхРеквизитов);
        
#КонецОбласти

	КонецЕсли;

#Область ИмяОбщейФормы

#КонецОбласти

	МодификацияКонфигурацииЗУПКПереопределяемый.ОбработатьСозданиеМетаданныхФормыОбщаяФорма(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);

КонецПроцедуры

#КонецОбласти

Процедура ОбработатьСобытияФормПриСозданииЧтении(Форма, Отказ = Ложь, СтандартнаяОбработка = Истина)

	Если ТипЗнч(Форма) = Тип("ФормаКлиентскогоПриложения") Тогда
		
		ДополнительныеПараметры = РазобратьИмяФормы(Форма);
		
        // внутри процедур выстаривать порядок если необходимо с учетом приоритетности документа (например, документ НачислениеЗарплаты используют чаще документа БольничныйЛист)
		Если СтрНайти(ДополнительныеПараметры.ТипОбъекта, ВРег("ЖурналДокументов")) > 0 Тогда
			ОбработатьСобытияФормПриСозданииЧтенииЖурналДокументов(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);	
		ИначеЕсли СтрНайти(ДополнительныеПараметры.ТипОбъекта, ВРег("Документ")) > 0 Тогда
			ОбработатьСобытияФормПриСозданииЧтенииДокумент(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);	
		ИначеЕсли СтрНайти(ДополнительныеПараметры.ТипОбъекта, ВРег("Справочник")) > 0 Тогда
			ОбработатьСобытияФормПриСозданииЧтенииСправочник(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);	
		ИначеЕсли СтрНайти(ДополнительныеПараметры.ТипОбъекта, ВРег("ОбщаяФорма")) > 0 Тогда
			ОбработатьСобытияФормПриСозданииЧтенииОбщаяФорма(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);	
		ИначеЕсли СтрНайти(ДополнительныеПараметры.ТипОбъекта, ВРег("РегистрСведений")) > 0 Тогда
			ОбработатьСобытияФормПриСозданииЧтенииРегистрСведений(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);	
		ИначеЕсли СтрНайти(ДополнительныеПараметры.ТипОбъекта, ВРег("ПланВидовРасчета")) > 0 Тогда
			ОбработатьСобытияФормПриСозданииЧтенииПланВидовРасчета(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);	
		ИначеЕсли СтрНайти(ДополнительныеПараметры.ТипОбъекта, ВРег("Обработка")) > 0 Тогда
			ОбработатьСобытияФормПриСозданииОбработки(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);	
		ИначеЕсли СтрНайти(ДополнительныеПараметры.ТипОбъекта, ВРег("ПланОбмена")) > 0 Тогда
			ОбработатьСобытияФормПриСозданииЧтенииПланаОбмена(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);	
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьСобытияФормПриСозданииЧтенииЖурналДокументов(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры)

	Элементы = Форма.Элементы;
	
#Область ВедомостиНаВыплатуЗарплаты

	Если ДополнительныеПараметры.ИмяОбъекта = ВРег("ВедомостиНаВыплатуЗарплаты") Тогда

		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПеречислениеНДФЛРеквизиты", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Месяц", "Заголовок", НСтр("ru = 'Месяц выплаты'"));

#КонецОбласти

#Область ВедомостиПрочихДоходов

	ИначеЕсли ВРег(ДополнительныеПараметры.ИмяОбъекта) = ВРег("ВедомостиПрочихДоходов") Тогда

		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПеречислениеНДФЛРеквизиты", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Месяц", "Заголовок", НСтр("ru = 'Месяц выплаты'"));

#КонецОбласти

#Область Командировки

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("Командировки") Тогда
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ФормаУтвердить", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Список", "ОтображениеПодсказки", ОтображениеПодсказки.Нет);
		
		НовыйЭлемент = Элементы.Добавить("СоздатьКомандировкуГруппы", Тип("КнопкаФормы"), Элементы.ФормаГруппаФормаСоздатьТ9аДополнительная);
		НовыйЭлемент.Вид = ВидКнопкиФормы.КнопкаКоманднойПанели;
		НовыйЭлемент.ИмяКоманды = "СоздатьКомандировкуГруппы";
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ФормаСоздатьТ9аДополнительная", "Видимость", Ложь);

#КонецОбласти

#Область Отсутствия

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("Отсутствия") Тогда
		
		ТекстЗапроса = Форма.Список.ТекстЗапроса;
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "КОГДА НЕ ЖурналДокументовОтсутствия.ПометкаУдаления", 
								  "КОГДА НЕ ТИПЗНАЧЕНИЯ(ЖурналДокументовОтсутствия.Ссылка) = ТИП(Документ.Командировка)
									|И НЕ ТИПЗНАЧЕНИЯ(ЖурналДокументовОтсутствия.Ссылка) = ТИП(Документ.КомандировкиСотрудников)
									|И НЕ ЖурналДокументовОтсутствия.ПометкаУдаления");
		
		Форма.Список.ТекстЗапроса = ТекстЗапроса;

#КонецОбласти

	КонецЕсли;

	МодификацияКонфигурацииЗУПКПереопределяемый.ОбработатьСобытияФормПриСозданииЧтенииЖурналДокументов(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);
	
КонецПроцедуры

Процедура ОбработатьСобытияФормПриСозданииЧтенииПланВидовРасчета(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры)

	Элементы = Форма.Элементы;

#Область Удержания

	Если ДополнительныеПараметры.ИмяОбъекта = ВРег("Удержания") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаВидаРасчета") Тогда
			
			ГруппаНастройкиНалоговВзносовОтРасчетнойБазы = Элементы.Вставить("НастройкиНалоговВзносовОтРасчетнойБазы", Тип("ГруппаФормы"), Элементы.СтраницаРезультатРассчитывается);
			ГруппаНастройкиНалоговВзносовОтРасчетнойБазы.Вид = ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаНастройкиНалоговВзносовОтРасчетнойБазы.ОтображатьЗаголовок = Ложь;

			НовыйЭлемент = Элементы.Добавить("ВычитатьИзРасчетнойБазыНалогиВзносы", Тип("ПолеФормы"), ГруппаНастройкиНалоговВзносовОтРасчетнойБазы);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеФлажка;
			НовыйЭлемент.ПоложениеЗаголовка	= ПоложениеЗаголовкаЭлементаФормы.Право;
			НовыйЭлемент.ПутьКДанным 		= "Объект.ВычитатьИзРасчетнойБазыНалогиВзносы";
			НовыйЭлемент.РасширеннаяПодсказка.Заголовок = НСтр("ru = 'Если установлены флажки, то при расчете базовая сумма начислений, с которой производится удержание, будет уменьшена на величину выбранного налога/взноса за расчетный месяц.
																|В расчете базы для алиментов не участвуют налоги и взносы, исчисленные с сумм начислений, не входящих в базу для расчета исполнительного листа (профсоюзных взносов).'");
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЯвляетсяВзысканием", "Подсказка", НСтр("ru = 'Размер удержания ограничивается согласно ст. 115 ТК РК'"));
			
			Элементы.ИнфоНадписьИсполнительныйЛист.Заголовок = НСтр("ru = 'Удержание рассчитывается в соответствии с условиями, указанными в исполнительном документе. В расчете базы для алиментов не участвуют налоги и взносы, исчисленные с сумм начислений, не входящих в базу для расчета исполнительного листа (профсоюзных взносов)'");
			
		КонецЕсли;		

#КонецОбласти

#Область Начисления

	ИначеЕсли  ДополнительныеПараметры.ИмяОбъекта = ВРег("Начисления") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаВидаРасчета") Тогда
			
			// РФ данные
			МассивСкрываемыхРеквизитов = Новый Массив;
			МассивСкрываемыхРеквизитов.Добавить("СреднийЗаработокФСС");
			МассивСкрываемыхРеквизитов.Добавить("СреднийЗаработокФССИспользовать");
			МассивСкрываемыхРеквизитов.Добавить("ПредставлениеВидаНачисленияПоНКРФ");
			МассивСкрываемыхРеквизитов.Добавить("ОблагаетсяНДФЛЧисло0");
			МассивСкрываемыхРеквизитов.Добавить("ОблагаетсяНДФЛЧисло1");
			МассивСкрываемыхРеквизитов.Добавить("ВключаетсяВРасходыПоСт255НКРФЧисло0");
			МассивСкрываемыхРеквизитов.Добавить("ВключаетсяВРасходыПоСт255НКРФЧисло1");
			МассивСкрываемыхРеквизитов.Добавить("ВидНачисленияДляНУ");
			МассивСкрываемыхРеквизитов.Добавить("СтатистическаяОтчетность");
			МассивСкрываемыхРеквизитов.Добавить("ГруппаКатегорияСтатистическогоНаблюдения57Т");
			МассивСкрываемыхРеквизитов.Добавить("ГруппаКатегорияСтатистическогоНаблюденияЗП");
			МассивСкрываемыхРеквизитов.Добавить("ГруппаКатегорияСтатистическогоНаблюдения");
			МассивСкрываемыхРеквизитов.Добавить("СтраницаБухучетПособияФСС");
			МассивСкрываемыхРеквизитов.Добавить("ГруппаНДФЛ");
			МассивСкрываемыхРеквизитов.Добавить("КатегорияДохода");
			МассивСкрываемыхРеквизитов.Добавить("СтрокаРаздела2Расчета6НДФЛ");
			МассивСкрываемыхРеквизитов.Добавить("СтраницыПорядкаОпределенияМесяцаДоходаВВидеОплатыТруда");
			МассивСкрываемыхРеквизитов.Добавить("ГруппаВзносы");
			МассивСкрываемыхРеквизитов.Добавить("ГруппаСтатья255НКРФ");
			МассивСкрываемыхРеквизитов.Добавить("ГруппаСтатья255НКРФ");
			МассивСкрываемыхРеквизитов.Добавить("ГруппаИсполнительноеПроизводство");
            МассивСкрываемыхРеквизитов.Добавить("УчитыватьВесьЗаработок");
			Для Каждого СкрываемыйРеквизит из МассивСкрываемыхРеквизитов Цикл
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, СкрываемыйРеквизит, "Видимость", Ложь);
			КонецЦикла;	

			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПостоянныеПоказателиСтраницы", "ОтображениеПодсказки", ОтображениеПодсказки.Нет);

			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаСреднийЗаработокОбщий", "Заголовок", НСтр("ru = 'Расчет оплаты отпусков, больничных и др.'"));
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СреднийЗаработокОбщийИспользовать", "Заголовок", НСтр("ru = 'Учитывать при расчете среднего заработка для целей оплаты отпусков, больничных и пр.'"));
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПоказательПремированияРасширеннаяПодсказка", "Заголовок", НСтр("ru = 'Используется для определения дублирующих премий с целью их исключения при расчете среднего заработка.'"));
			
			ВидыНВО = Новый Массив;
			ВидыНВО.Добавить("ИПН");
			ВидыНВО.Добавить("ОПВ");
			ВидыНВО.Добавить("ОПВР");
			ВидыНВО.Добавить("ОППВ");
			ВидыНВО.Добавить("СО");
			ВидыНВО.Добавить("СН");
			ВидыНВО.Добавить("ВОСМС");
			ВидыНВО.Добавить("ООСМС");
			ВидыНВО.Добавить("ЕП");
			
			// "от обратного"
			ГруппаИспользованиеОтОбратного = Элементы.Вставить("ИспользованиеОтОбратного", Тип("ГруппаФормы"), Элементы.СтраницаРезультатРассчитывается, Элементы.ПостоянныеПоказателиСтраницы);
			ГруппаИспользованиеОтОбратного.Вид = ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаИспользованиеОтОбратного.ОтображатьЗаголовок = Ложь; 
			
			НовыйЭлемент = Элементы.Добавить("ОтОбратного", Тип("ПолеФормы"), ГруппаИспользованиеОтОбратного);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеФлажка;
			НовыйЭлемент.ПоложениеЗаголовка	= ПоложениеЗаголовкаЭлементаФормы.Право;
			НовыйЭлемент.ПутьКДанным 		= "Объект.ОтОбратного";
			НовыйЭлемент.Подсказка 		    = НСтр("ru = 'Если флажок установлен, то при расчете результат начисления будет увеличен на сумму компенсации удержаний.'");
            НовыйЭлемент.ОтображениеПодсказки = ОтображениеПодсказки.ОтображатьСнизу;
            НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_ОтОбратногоПриИзменении");

			ГруппаНастройкиОтОбратного = Элементы.Вставить("НастройкиОтОбратного", Тип("ГруппаФормы"), Элементы.Страницы, Элементы.СреднийЗаработок);
			ГруппаНастройкиОтОбратного.Вид = ВидГруппыФормы.Страница;
			ГруппаНастройкиОтОбратного.Заголовок = НСтр("ru = 'От обратного'"); 
			
			НовыйЭлемент = Элементы.Добавить("ОтОбратногоУчетПрямыхНачислений", Тип("ПолеФормы"), ГруппаНастройкиОтОбратного);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеФлажка;
			НовыйЭлемент.ПоложениеЗаголовка	= ПоложениеЗаголовкаЭлементаФормы.Право;
			НовыйЭлемент.ПутьКДанным 		= "Объект.ОтОбратногоУчетПрямыхНачислений";
			НовыйЭлемент.Подсказка 		    = НСтр("ru = 'Если флажок установлен, то при расчете данного начисления и определении для него размеров вычетов, льгот и ограничений, будут учтены суммы ""прямых"" ранее исчисленных начислений, в формулах которых не использован метод ""от обратного"".'");
            НовыйЭлемент.ОтображениеПодсказки = ОтображениеПодсказки.ОтображатьСнизу;

			НоваяТаблица = Элементы.Добавить("ОтОбратногоКомпенсируемыеУдержания", Тип("ТаблицаФормы"), ГруппаНастройкиОтОбратного);
			НоваяТаблица.ПутьКДанным 		= "Объект.ОтОбратногоКомпенсируемыеУдержания";

			НовыйЭлемент = Элементы.Добавить("ОтОбратногоКомпенсируемыеУдержанияНомерСтроки", Тип("ПолеФормы"), НоваяТаблица);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеНадписи;
			НовыйЭлемент.ПутьКДанным 		= "Объект.ОтОбратногоКомпенсируемыеУдержания.НомерСтроки";

			НовыйЭлемент = Элементы.Добавить("ОтОбратногоКомпенсируемыеУдержанияВидРасчета", Тип("ПолеФормы"), НоваяТаблица);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным 		= "Объект.ОтОбратногоКомпенсируемыеУдержания.ВидРасчета";
            НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_ОтОбратногоКомпенсируемыеУдержанияВидРасчетаПриИзменении");
            НовыйЭлемент.УстановитьДействие("НачалоВыбора", "Подключаемый_ОтОбратногоКомпенсируемыеУдержанияВидРасчетаНачалоВыбора");

			// налогообложение начислений
			ГруппаНалогообложениеНачислений = Элементы.Добавить("ГруппаНалогообложениеНачислений", Тип("ГруппаФормы"), Элементы.ГруппаНалогиИВзносы);
			ГруппаНалогообложениеНачислений.Вид = ВидГруппыФормы.ОбычнаяГруппа;
            ГруппаНалогообложениеНачислений.Заголовок = НСтр("ru = 'Налогообложение начислений'"); 
            ГруппаНалогообложениеНачислений.Отображение = ОтображениеОбычнойГруппы.Нет;

			ГруппаРедактированиеИсторииНалогообложенияНачислений = Элементы.Добавить("ГруппаРедактированиеИсторииНалогообложенияНачислений", Тип("ГруппаФормы"), ГруппаНалогообложениеНачислений);
			ГруппаРедактированиеИсторииНалогообложенияНачислений.Вид = ВидГруппыФормы.ОбычнаяГруппа;
  			ГруппаРедактированиеИсторииНалогообложенияНачислений.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
  			ГруппаРедактированиеИсторииНалогообложенияНачислений.ОтображатьЗаголовок = Ложь;
			
			НовыйЭлемент = Элементы.Добавить("НалогообложениеНачисленийПериод", Тип("ПолеФормы"), ГруппаРедактированиеИсторииНалогообложенияНачислений);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным 		= "НалогообложениеНачислений.Период";
            НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_НалогообложениеНачисленийПериодПриИзменении");

			НовыйЭлемент = Элементы.Добавить("РедактированиеИсторииНалогообложениеНачислений", Тип("КнопкаФормы"), ГруппаРедактированиеИсторииНалогообложенияНачислений);
			НовыйЭлемент.Вид = ВидКнопкиФормы.Гиперссылка;
			НовыйЭлемент.ИмяКоманды = "РедактированиеИсторииНалогообложениеНачислений";
			
			НовыйЭлемент = Элементы.Добавить("НалогообложениеНачисленийВидДохода", Тип("ПолеФормы"), ГруппаНалогообложениеНачислений);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным 		= "НалогообложениеНачислений.ВидДохода";
			
			НовыйЭлемент.СписокВыбора.ЗагрузитьЗначения(Справочники.ВидыДоходов.ВидыНачисленияПВР());
			НовыйЭлемент.РежимВыбораИзСписка = Истина;
			НовыйЭлемент.КнопкаСоздания = Ложь;
            НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_НалогообложениеНачисленийВидДоходаПриИзменении");
			
			Для Каждого ВидНВО Из ВидыНВО Цикл
				
				НовыйЭлемент = Элементы.Добавить("НалогообложениеНачисленийСпособОбложения" + ВидНВО, Тип("ПолеФормы"), ГруппаНалогообложениеНачислений);
				НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеФлажка;
				НовыйЭлемент.ПутьКДанным 		= "НалогообложениеНачислений.СпособОбложения" + ВидНВО;
            	НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_НалогообложениеНачисленийСпособОбложенияПриИзменении");
				
				НовыйЭлемент = Элементы.Добавить("НалогообложениеНачисленийДоходНеПодлежащийНалогообложению" + ВидНВО, Тип("ПолеФормы"), ГруппаНалогообложениеНачислений);
				НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеФлажка;
				НовыйЭлемент.ПутьКДанным 		= "НалогообложениеНачислений.ДоходНеПодлежащийНалогообложению" + ВидНВО;
            	НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_НалогообложениеНачисленийДоходНеПодлежащийНалогообложениюПриИзменении");
				
			КонецЦикла;

			// статистика
			НовыйЭлемент = Элементы.Добавить("КатегорияФондаЗаработнойПлаты1ТГод", Тип("ПолеФормы"), Элементы.ГруппаОтражениеВБухучетеИСтатистика);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным 		= "Объект.КатегорияФондаЗаработнойПлаты1ТГод";

		ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("ФормаСписка") Тогда
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "КодДоходаСтраховыеВзносы", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ФормаНастройкаСреднегоЗаработка", "Заголовок", НСтр("ru = 'Настройка среднего заработка и др.'"));
		КонецЕсли;

#КонецОбласти
	
	КонецЕсли;

	МодификацияКонфигурацииЗУПКПереопределяемый.ОбработатьСобытияФормПриСозданииЧтенииПланВидовРасчета(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);
	
КонецПроцедуры

Процедура ОбработатьСобытияФормПриСозданииОбработки(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры)

	Элементы = Форма.Элементы;

#Область ПанельНастроекЗарплатаКадры

	Если ДополнительныеПараметры.ИмяОбъекта = ВРег("ПанельНастроекЗарплатаКадры") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("РасчетЗарплаты") Тогда
			
			// РФ данные
			
			МассивСкрываемыхРеквизитов = Новый Массив;
			
			МассивСкрываемыхРеквизитов.Добавить("ГруппаИспользоватьУчетПоСтатьямФинансирования");
			МассивСкрываемыхРеквизитов.Добавить("ГруппаНастройкиСтатистикиПерсонала");
            МассивСкрываемыхРеквизитов.Добавить("Декорация8");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаПереноситьДанныеВДругойУчетСреднегоЗаработка");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаКомпенсацияЗаЗадержкуЗарплаты");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаПризыПодарки");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаВыделятьНерабочиеДниОтдельнымВидомВремени");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаНастройкиИспользованияСтатейРасходов");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаНастройкаСреднемесячныхПоказателей");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаСтатьиФинансированияСтатистикаПерсонала");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаИспользованиеИФО");
            МассивСкрываемыхРеквизитов.Добавить("ДекорацияОтступ");
            МассивСкрываемыхРеквизитов.Добавить("ПорядокУчетаДоговоровГПХ");
			
			Для Каждого СкрываемыйРеквизит из МассивСкрываемыхРеквизитов Цикл
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, СкрываемыйРеквизит, "Видимость", Ложь);
			КонецЦикла;	

			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Декорация4", "Заголовок", НСтр("ru = 'Выплаты бывшим сотрудникам, такие как выплата материальной помощи пенсионерам, также необходимо фиксировать в программе (для формирования налоговой отчетности и т.п.)'"));
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДекорацияОграничиватьСуммуУдержанийПроцентомОтЗаработнойПлаты", "Заголовок", НСтр("ru = 'Ограничивать общий размер удержаний процентом от заработной платы.'"));

			ГруппаИспользованиеОтОбратного = Элементы.Вставить("ГруппаОтОбратного", Тип("ГруппаФормы"), Элементы.ГруппаНастройки, Элементы.ГруппаИндексация);
			ГруппаИспользованиеОтОбратного.Вид = ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаИспользованиеОтОбратного.ОтображатьЗаголовок = Ложь; 
  			ГруппаИспользованиеОтОбратного.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
			
			НовыйЭлемент = Элементы.Добавить("ИспользоватьРасчетыОтОбратного", Тип("ПолеФормы"), ГруппаИспользованиеОтОбратного);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеФлажка;
			НовыйЭлемент.ПоложениеЗаголовка	= ПоложениеЗаголовкаЭлементаФормы.Право;
			НовыйЭлемент.ПутьКДанным 		= "ИспользоватьРасчетыОтОбратного";
			НовыйЭлемент.Заголовок 		    = НСтр("ru = 'Использовать расчеты ""от обратного""'");
            НовыйЭлемент.ОтображениеПодсказки = ОтображениеПодсказки.ОтображатьСнизу;
            НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_ИспользоватьРасчетыОтОбратногоПриИзменении");

			НовыйЭлемент = Элементы.Добавить("ИнфоНадписьРасчетыОтОбратного", Тип("ДекорацияФормы"), ГруппаИспользованиеОтОбратного);
			НовыйЭлемент.Вид 				= ВидДекорацииФормы.Надпись;
			НовыйЭлемент.Заголовок 		    = НСтр("ru = 'Позволяет использовать начисления, результатом расчета которых является сумма, увеличенная на сумму компенсации удержаний.'");
			НовыйЭлемент.ЦветТекста 		= ЦветаСтиля.ПоясняющийТекст;
			НовыйЭлемент.Ширина 			= 75;

			ГруппаКомментарийИспользоватьРасчетОтОбратного = Элементы.Добавить("ГруппаКомментарийИспользоватьРасчетОтОбратного", Тип("ГруппаФормы"), ГруппаИспользованиеОтОбратного);
			ГруппаКомментарийИспользоватьРасчетОтОбратного.Вид = ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаКомментарийИспользоватьРасчетОтОбратного.ОтображатьЗаголовок = Ложь; 
			
			НовыйЭлемент = Элементы.Добавить("ДекорацияРасчетыОтОбратного", Тип("ДекорацияФормы"), ГруппаКомментарийИспользоватьРасчетОтОбратного);
			НовыйЭлемент.Вид 				= ВидДекорацииФормы.Картинка;
			НовыйЭлемент.Картинка		 	= БиблиотекаКартинок.ИнформацияПоНедоступнымПолям;
			
			НовыйЭлемент = Элементы.Добавить("КомментарийИспользоватьРасчетыОтОбратного", Тип("ДекорацияФормы"), ГруппаКомментарийИспользоватьРасчетОтОбратного);
			НовыйЭлемент.Вид 				= ВидДекорацииФормы.Надпись;
			НовыйЭлемент.Заголовок 		    = НСтр("ru = 'Начисления ""от обратного"" используются в программе, для отключения настройки необходимо отменить плановые начисления сотрудников с видом ""от обратного"".'");
			НовыйЭлемент.ЦветТекста 		= ЦветаСтиля.ПоясняющийТекст;
			НовыйЭлемент.Ширина 			= 75;
			
			ГруппаИспользоватьРегистрациюПрочихВыплат = Элементы.Вставить("ГруппаИспользоватьРегистрациюПрочихВыплат", Тип("ГруппаФормы"), Элементы.ГруппаНастройки, Элементы.ГруппаБывшиеСотрудники);
			ГруппаИспользоватьРегистрациюПрочихВыплат.Вид = ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаИспользоватьРегистрациюПрочихВыплат.ОтображатьЗаголовок = Ложь; 
  			ГруппаИспользоватьРегистрациюПрочихВыплат.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;

			НовыйЭлемент = Элементы.Добавить("ИспользоватьРегистрациюПрочихВыплат", Тип("ПолеФормы"), ГруппаИспользоватьРегистрациюПрочихВыплат);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеФлажка;
			НовыйЭлемент.ПоложениеЗаголовка	= ПоложениеЗаголовкаЭлементаФормы.Право;
			НовыйЭлемент.ПутьКДанным 		= "ИспользоватьРегистрациюПрочихВыплат";
			НовыйЭлемент.Заголовок 		    = НСтр("ru = 'Регистрируются прочие выплаты физическим лицам'");
            НовыйЭлемент.ОтображениеПодсказки = ОтображениеПодсказки.ОтображатьСнизу;
            НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_ИспользоватьРегистрациюПрочихВыплатПриИзменении");

			НовыйЭлемент = Элементы.Добавить("ИнфоНадписьИспользоватьРегистрациюПрочихВыплат", Тип("ДекорацияФормы"), ГруппаИспользоватьРегистрациюПрочихВыплат);
			НовыйЭлемент.Вид 				= ВидДекорацииФормы.Надпись;
			НовыйЭлемент.Заголовок 		    = НСтр("ru = 'Необходимо включить, если на предприятии регистрируются прочие выплаты, не являющиеся доходом физического лица (например, профессиональные выплаты).'");
			НовыйЭлемент.ЦветТекста 		= ЦветаСтиля.ПоясняющийТекст;
			НовыйЭлемент.Ширина 			= 75;
				
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПроверятьЗаполнениеСпособаРасчетовВВедомостях", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПроверятьЗаполнениеСпособаРасчетовВВедомостяхРасширеннаяПодсказка", "Заголовок", НСтр("ru = 'Включите, если ведомости на выплату зарплаты ведутся по способам расчетов с персоналом. Заполнение способа расчета будет обязательным.'"));
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Декорация5", "Заголовок", НСтр("ru = 'Если на предприятии выдаются займы сотрудникам, их необходимо регистрировать для целей погашения займа из зарплаты.'"));
			
			// ЗУП КОРП
			ТекстРасширеннаяПодсказка = Элементы.НастройкиУчетаВремениОтражатьЧасыВДеньНачалаСменыРасширеннаяПодсказка.Заголовок;
			ТекстРасширеннаяПодсказка = СтрЗаменить(ТекстРасширеннаяПодсказка, "Т-13", НСтр("ru = 'Табеле учета рабочего времени'"));
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НастройкиУчетаВремениОтражатьЧасыВДеньНачалаСменыРасширеннаяПодсказка", "Заголовок", ТекстРасширеннаяПодсказка);
			// ЗУП КОРП
			
		ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("КадровыйУчет") Тогда
			
			// РФ данные
			
			МассивСкрываемыхРеквизитов = Новый Массив;
			
			МассивСкрываемыхРеквизитов.Добавить("ИспользоватьИнтеграциюСРаботаВРоссииГруппа");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаМедицинскоеСтрахованиеСотрудников");
			МассивСкрываемыхРеквизитов.Добавить("ГруппаИспользоватьПодработки");
			МассивСкрываемыхРеквизитов.Добавить("ГруппаПечататьТ6ДляОтпусковПоБеременностиИРодам");
            МассивСкрываемыхРеквизитов.Добавить("ПояснениеИспользоватьБронированиеГраждан");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаВоинскийУчетСоставы");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаЗаполнятьСТДРВсемиМероприятиямиДо2020Года");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаСоциальныеВыплатыРаботаСКоронавирусом");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаСервис1СКабинетСотрудника");
            МассивСкрываемыхРеквизитов.Добавить("БронированиеКомандировокГруппа");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаРаботаВМедицинскомУчреждении");
			Для Каждого СкрываемыйРеквизит из МассивСкрываемыхРеквизитов Цикл
				ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, СкрываемыйРеквизит, "Видимость", Ложь);
			КонецЦикла;	

		ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("НастройкаНачисленийУдержаний") Тогда
			
			// РФ данные
			
			МассивСкрываемыхРеквизитов = Новый Массив;
			
			МассивСкрываемыхРеквизитов.Добавить("УчитыватьВечерниеЧасы");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаОтпускЧернобыльский");
			МассивСкрываемыхРеквизитов.Добавить("ОплачиватьДлительныеКомандировкиПомесячно");
			МассивСкрываемыхРеквизитов.Добавить("ГруппаДоплатаБЛ");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаДоплатаДенежноеСодержание");
            МассивСкрываемыхРеквизитов.Добавить("ГруппаЕдиновременнаяВыплатаКОтпуску");
