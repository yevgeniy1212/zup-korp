#Область СлужебныеПроцедурыИФункции

Функция ДанныеЗУПКИнициализированы(Форма)

	ДанныеФормы = Новый Структура("ДанныеЗУПКИнициализированы");
	
	ЗаполнитьЗначенияСвойств(ДанныеФормы, Форма);
	
	Если ДанныеФормы.ДанныеЗУПКИнициализированы = Неопределено Тогда
		
		МассивДобавляемыхРеквизитов = Новый Массив;
		НовыйРеквизит = Новый РеквизитФормы("ДанныеЗУПКИнициализированы", Новый ОписаниеТипов("Булево"));
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		
		Форма.ИзменитьРеквизиты(МассивДобавляемыхРеквизитов);
		Форма.ДанныеЗУПКИнициализированы = Истина;
		
		Возврат Ложь;
		
	Иначе
		
		Возврат Истина;

	КонецЕсли;
	
КонецФункции

Функция РазобратьИмяФормы(Форма)

	ИмяФормыМассив = СтрРазделить(Форма.ИмяФормы, ".", Ложь);
	
	Если ИмяФормыМассив.Количество() = 4 Тогда 
		ДополнительныеПараметры = Новый Структура("ТипОбъекта, ИмяОбъекта, ИмяФормы", ВРег(ИмяФормыМассив[0]), ВРег(ИмяФормыМассив[1]), ВРег(ИмяФормыМассив[3]));
	ИначеЕсли ИмяФормыМассив.Количество() = 2 Тогда 
		ДополнительныеПараметры = Новый Структура("ТипОбъекта, ИмяОбъекта, ИмяФормы", ВРег(ИмяФормыМассив[0]), "", ВРег(ИмяФормыМассив[1]));
	Иначе
		ДополнительныеПараметры = Новый Структура("ТипОбъекта, ИмяОбъекта, ИмяФормы", "", "", "");
	КонецЕсли;

	Возврат ДополнительныеПараметры;
	
КонецФункции

#Область СозданиеМетаданныхФормы

Процедура ОбработатьСозданиеМетаданныхФормы(Форма, Отказ = Ложь, СтандартнаяОбработка = Истина)

	Если ТипЗнч(Форма) = Тип("ФормаКлиентскогоПриложения") Тогда
		
		ДополнительныеПараметры = РазобратьИмяФормы(Форма);
		
        // внутри процедур выстаривать порядок если необходимо с учетом приоритетности документа (например, документ НачислениеЗарплаты используют чаще документа БольничныйЛист)
		Если СтрНайти(ДополнительныеПараметры.ТипОбъекта, ВРег("ЖурналДокументов")) > 0 Тогда
			ОбработатьСозданиеМетаданныхФормыЖурналДокументов(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);	
		ИначеЕсли СтрНайти(ДополнительныеПараметры.ТипОбъекта, ВРег("Документ")) > 0 Тогда
			ОбработатьСозданиеМетаданныхФормыДокумент(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);	
		ИначеЕсли СтрНайти(ДополнительныеПараметры.ТипОбъекта, ВРег("Справочник")) > 0 Тогда
			ОбработатьСозданиеМетаданныхФормыСправочник(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);	
		ИначеЕсли СтрНайти(ДополнительныеПараметры.ТипОбъекта, ВРег("ОбщаяФорма")) > 0 Тогда
			ОбработатьСозданиеМетаданныхФормыОбщаяФорма(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);	
		ИначеЕсли СтрНайти(ДополнительныеПараметры.ТипОбъекта, ВРег("РегистрСведений")) > 0 Тогда
			ОбработатьСозданиеМетаданныхФормыРегистрСведений(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);	
		ИначеЕсли СтрНайти(ДополнительныеПараметры.ТипОбъекта, ВРег("ПланВидовРасчета")) > 0 Тогда
			ОбработатьСозданиеМетаданныхФормыПланВидовРасчета(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);	
		ИначеЕсли СтрНайти(ДополнительныеПараметры.ТипОбъекта, ВРег("Обработка")) > 0 Тогда
			ОбработатьСозданиеМетаданныхФормыОбработки(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);	
		КонецЕсли;
		
	КонецЕсли;

	МодификацияКонфигурацииЗУПКПереопределяемый.ОбработатьСозданиеМетаданныхФормы(Форма, Отказ, СтандартнаяОбработка);
	
КонецПроцедуры

Процедура ОбработатьСозданиеМетаданныхФормыЖурналДокументов(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры)

	Элементы = Форма.Элементы;

#Область Командировки

	Если ДополнительныеПараметры.ИмяОбъекта = ВРег("Командировки") Тогда
		
		НоваяКоманда = Форма.Команды.Добавить("СоздатьКомандировкуГруппы");
		НоваяКоманда.Действие = "СоздатьТ9а";
		НоваяКоманда.Заголовок = НСтр("ru = 'Создать командировку группы'");
		
	КонецЕсли;

#КонецОбласти

	МодификацияКонфигурацииЗУПКПереопределяемый.ОбработатьСозданиеМетаданныхФормыЖурналДокументов(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);
	
КонецПроцедуры

Процедура ОбработатьСозданиеМетаданныхФормыПланВидовРасчета(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры)

	Элементы = Форма.Элементы;

#Область Начисления

	Если  ДополнительныеПараметры.ИмяОбъекта = ВРег("Начисления") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаВидаРасчета") Тогда
			
			ВидыНВО = Новый Массив;
			ВидыНВО.Добавить("ИПН");
			ВидыНВО.Добавить("ОПВ");
			ВидыНВО.Добавить("ОППВ");
			ВидыНВО.Добавить("СО");
			ВидыНВО.Добавить("СН");
			ВидыНВО.Добавить("ВОСМС");
			ВидыНВО.Добавить("ООСМС");
			ВидыНВО.Добавить("ОПВР");
			ВидыНВО.Добавить("ЕП");
			
			// новые реквизиты формы
			
			НоваяКоманда = Форма.Команды.Добавить("РедактированиеИсторииНалогообложениеНачислений");
			НоваяКоманда.Действие = "Подключаемый_РедактированиеИсторииНалогообложениеНачислений";
			НоваяКоманда.Заголовок = НСтр("ru = 'История изменения налогообложения начисления'");
			
			МассивДобавляемыхРеквизитов = Новый Массив;

			НовыйРеквизит = Новый РеквизитФормы("НалогообложениеНачислений", Новый ОписаниеТипов("РегистрСведенийМенеджерЗаписи.НалогообложениеНачислений"));
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("НалогообложениеНачисленийНаборЗаписей", Новый ОписаниеТипов("РегистрСведенийНаборЗаписей.НалогообложениеНачислений"));
			НовыйРеквизит.СохраняемыеДанные = Истина;
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("НалогообложениеНачисленийНаборЗаписейПрочитан", Новый ОписаниеТипов("Булево"));
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("НалогообложениеНачисленийНоваяЗапись", Новый ОписаниеТипов("Булево"));
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("НалогообложениеНачисленийПрежняя", Новый ОписаниеТипов());
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
            Для Каждого ВидНВО из ВидыНВО Цикл
				НовыйРеквизит = Новый РеквизитФормы("НалогообложениеНачисленийУчитывать" + ВидНВО, Новый ОписаниеТипов("Булево"));
				МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			КонецЦикла;	
			НовыйРеквизит = Новый РеквизитФормы("ОплатаБольничногоБезФормулы", Новый ОписаниеТипов("Булево"));
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			
			Форма.ИзменитьРеквизиты(МассивДобавляемыхРеквизитов);
			
		КонецЕсли;
	
	КонецЕсли;

#КонецОбласти

	МодификацияКонфигурацииЗУПКПереопределяемый.ОбработатьСозданиеМетаданныхФормыПланВидовРасчета(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);
	
КонецПроцедуры

Процедура ОбработатьСозданиеМетаданныхФормыОбработки(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры)

	Элементы = Форма.Элементы;

#Область ПанельНастроекЗарплатаКадры

	Если ДополнительныеПараметры.ИмяОбъекта = ВРег("ПанельНастроекЗарплатаКадры") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("РасчетЗарплаты") Тогда
			
			// новые реквизиты формы
			
			МассивДобавляемыхРеквизитов = Новый Массив;

			НовыйРеквизит = Новый РеквизитФормы("ИспользоватьРасчетыОтОбратного", Новый ОписаниеТипов("Булево"));
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);

			НовыйРеквизит = Новый РеквизитФормы("ИспользоватьРегистрациюПрочихВыплат", Новый ОписаниеТипов("Булево"));
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			
			Форма.ИзменитьРеквизиты(МассивДобавляемыхРеквизитов);

		КонецЕсли;
			
#КонецОбласти

#Область РедактированиеЗаконодательныхЗначений
	
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("РедактированиеЗаконодательныхЗначений") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("Форма") Тогда
			
			НоваяКоманда = Форма.Команды.Добавить("МесячныйРасчетныйПоказательИстория");
			НоваяКоманда.Действие = "Подключаемый_МесячныйРасчетныйПоказательИстория";
			НоваяКоманда.Заголовок = НСтр("ru = 'История изменений ...'");
			
			// новые реквизиты формы
			
			МассивДобавляемыхРеквизитов = Новый Массив;
			
			НовыйРеквизит = Новый РеквизитФормы("МесячныйРасчетныйПоказатель",Новый ОписаниеТипов("РегистрСведенийМенеджерЗаписи.МесячныйРасчетныйПоказатель"), , , Истина);
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("МесячныйРасчетныйПоказательНаборЗаписей",Новый ОписаниеТипов("РегистрСведенийНаборЗаписей.МесячныйРасчетныйПоказатель"), , , Истина);
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("МесячныйРасчетныйПоказательНаборЗаписейПрочитан",Новый ОписаниеТипов("Булево"));
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("МесячныйРасчетныйПоказательНоваяЗапись",Новый ОписаниеТипов("Булево"));
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("МесячныйРасчетныйПоказательПрежняя",Новый ОписаниеТипов());
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("МесячныйРасчетныйПоказательПериодСтрокой", Новый ОписаниеТипов("Строка")); 
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			
			Форма.ИзменитьРеквизиты(МассивДобавляемыхРеквизитов);
			
		КонецЕсли;
	
#КонецОбласти

#Область ОбменСБанкамиПоЗарплатнымПроектам

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ОбменСБанкамиПоЗарплатнымПроектам") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ЛицевыеСчета") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НомерЛицевогоСчета", "Маска", "");

		КонецЕсли;
			
#КонецОбласти

#Область ПлатежиПоРезультатамРасчетаЗарплаты
	
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ПлатежиПоРезультатамРасчетаЗарплаты") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("Форма") Тогда
			
			// новые реквизиты формы
			
			МассивДобавляемыхРеквизитов = Новый Массив;
			
			НовыйРеквизит = Новый РеквизитФормы("ИтогНалогиРК",Новый ОписаниеТипов("Число", , , Новый КвалификаторыЧисла(15,2)));
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("НалогиРК",Новый ОписаниеТипов("ТаблицаЗначений"));
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("НалоговыйОрган",Новый ОписаниеТипов("СправочникСсылка.РегистрацииВНалоговомОргане"),"НалогиРК", "Налоговый орган");
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("Сумма",Новый ОписаниеТипов("Число", , , Новый КвалификаторыЧисла(15,2)),"НалогиРК");
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("МесяцНалоговогоПериода",Новый ОписаниеТипов("Дата", , , , , Новый КвалификаторыДаты(ЧастиДаты.Дата)),"НалогиРК", "Месяц налогового периода");
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("ВидНалогаВзносаОтчисления", Новый ОписаниеТипов("ПеречислениеСсылка.ВидыНалоговВзносовОтчислений"),"НалогиРК", "Вид налога, взноса, отчисления");
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("Организация",Новый ОписаниеТипов("СправочникСсылка.Организации"),"НалогиРК");
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			
			Форма.ИзменитьРеквизиты(МассивДобавляемыхРеквизитов);
			
		КонецЕсли;
	
#КонецОбласти

#Область НачальнаяНастройкаПрограммы
	
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("НачальнаяНастройкаПрограммы") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаНастройкиПрограммы") Тогда
			
			МассивДобавляемыхРеквизитов = Новый Массив;
			
			НовыйРеквизит = Новый РеквизитФормы("ИспользоватьРасчетыОтОбратного",Новый ОписаниеТипов("Булево"),,, Истина);
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("УчетнаяПолитикаПоНалоговомуУчету", Новый ОписаниеТипов("РегистрСведенийМенеджерЗаписи.УчетнаяПолитикаПоНалоговомуУчету"),,, Истина); 
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("НастройкиВзаиморасчетовПоПрочимДоходам", Новый ОписаниеТипов("РегистрСведенийМенеджерЗаписи.НастройкиВзаиморасчетовПоПрочимДоходам"),,, Истина); 
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("ИспользоватьРегистрациюПрочихВыплат", Новый ОписаниеТипов("Булево"),,, Истина);
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("ИспользоватьВедомостиДляВыплатыПрочихДоходов", Новый ОписаниеТипов("Булево"),,, Истина);
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			
			Форма.ИзменитьРеквизиты(МассивДобавляемыхРеквизитов);
			
		КонецЕсли;
	
#КонецОбласти

#Область ОбщиеОбъектыРеглОтчетности
	
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ОбщиеОбъектыРеглОтчетности") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("НастройкиОтчета") Тогда
				
			МассивДобавляемыхРеквизитов = Новый Массив;
			
			НовыйРеквизит = Новый РеквизитФормы("мСписокСтруктурныхЕдиниц",Новый ОписаниеТипов("СписокЗначений"));
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("мСписокРегистраций",Новый ОписаниеТипов("СписокЗначений"));
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("СтруктурныеЕдиницы",Новый ОписаниеТипов("Строка"));
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			НовыйРеквизит = Новый РеквизитФормы("НалоговыйКомитет", Новый ОписаниеТипов("СправочникСсылка.РегистрацииВНалоговомОргане")); 
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		
			Форма.ИзменитьРеквизиты(МассивДобавляемыхРеквизитов);

		КонецЕсли;

#КонецОбласти

#Область ПомощникПереходаСПрежнихПрограммЗарплатаКадры
	
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ПомощникПереходаСПрежнихПрограммЗарплатаКадры") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаПомощника") Тогда
			
			МассивДобавляемыхРеквизитов = Новый Массив;
			
			НовыйРеквизит = Новый РеквизитФормы("ОграничиватьПереносКоэффициентовИндексации",Новый ОписаниеТипов("Булево"));
			МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
			
			Форма.ИзменитьРеквизиты(МассивДобавляемыхРеквизитов);
			
		КонецЕсли;
	
#КонецОбласти

#Область ГрупповоеРедактированиеНачислений
	
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ГрупповоеРедактированиеНачислений") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("Форма") Тогда
			
			НоваяКоманда = Форма.Команды.Добавить("НалогиВзносыОтчисленияПраво1");
			НоваяКоманда.Действие = "Подключаемый_НалогиВзносыОтчисленияПраво1";
			НоваяКоманда.Заголовок = НСтр("ru = '>'");
			
			НоваяКоманда = Форма.Команды.Добавить("НалогиВзносыОтчисленияПраво2");
			НоваяКоманда.Действие = "Подключаемый_НалогиВзносыОтчисленияПраво2";
			НоваяКоманда.Заголовок = НСтр("ru = '>'");
			
			НоваяКоманда = Форма.Команды.Добавить("НалогиВзносыОтчисленияЛево1");
			НоваяКоманда.Действие = "Подключаемый_НалогиВзносыОтчисленияЛево1";
			НоваяКоманда.Заголовок = НСтр("ru = '<'");
			
			НоваяКоманда = Форма.Команды.Добавить("НалогиВзносыОтчисленияЛево2");
			НоваяКоманда.Действие = "Подключаемый_НалогиВзносыОтчисленияЛево2";
			НоваяКоманда.Заголовок = НСтр("ru = '<'");
			
			МассивДобавляемыхРеквизитов = Новый Массив;
			
			СоздатьБлокРеквизитовНВОБазаНачислений(Форма, МассивДобавляемыхРеквизитов, Истина, "ИсходнаяБаза", Истина, "Начисления", Истина);
			
			Форма.ИзменитьРеквизиты(МассивДобавляемыхРеквизитов);

		КонецЕсли;
		
#КонецОбласти

#Область СозданиеВедомостейПрочихДоходов

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("СозданиеВедомостейПрочихДоходов") Тогда
        
        Если ДополнительныеПараметры.ИмяФормы = ВРег("ВедомостиПоРасчетномуДокументу") Тогда
            
            МассивДобавляемыхРеквизитов = Новый Массив;
            
			НовыйРеквизит = Новый РеквизитФормы("ВРазрезеПодразделений", Новый ОписаниеТипов("Булево"),,, Истина);
            МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);

 			НовыйРеквизит = Новый РеквизитФормы("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"), "Ведомости", "Подразделение");
            МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);

            Форма.ИзменитьРеквизиты(МассивДобавляемыхРеквизитов);
            
        КонецЕсли;
        
#КонецОбласти

	КонецЕсли;
	
	МодификацияКонфигурацииЗУПКПереопределяемый.ОбработатьСозданиеМетаданныхФормыОбработки(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);

КонецПроцедуры

Процедура ОбработатьСозданиеМетаданныхФормыСправочник(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры)

	Элементы = Форма.Элементы;

#Область Организациия

	Если ДополнительныеПараметры.ИмяОбъекта = ВРег("Организации") Тогда
		
