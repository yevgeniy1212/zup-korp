			МассивСкрываемыхКоманд.Добавить("ПроверитьОтчет");
			МассивСкрываемыхКоманд.Добавить("ЗашифроватьИОтправить");
			СкрытьОбъектыКоманд(Форма, МассивСкрываемыхКоманд);
			
		КонецЕсли;

#КонецОбласти

#Область НачислениеОценочныхОбязательствПоОтпускам

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("НачислениеОценочныхОбязательствПоОтпускам") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаДокумента") Тогда
			
			СоздатьЭлементыРеквизитовНВОРезервы(Форма, "РасчетРезерваОтпусков");
			
		КонецЕсли;

#КонецОбласти

#Область РезервыПоОплатеТруда

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("РезервыПоОплатеТруда") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаДокумента") Тогда
			
			СоздатьЭлементыРеквизитовНВОРезервы(Форма);
			
			ВидыНВО = Новый Массив;
			ВидыНВО.Добавить("СО");
			ВидыНВО.Добавить("СН");
			ВидыНВО.Добавить("ОтчисленияОСМС");
			ВидыНВО.Добавить("ОПВР");
			ВидыНВО.Добавить("ОППВ");
			
			Для Каждого ВидНВО Из ВидыНВО Цикл
				
				// Результат
				НовыйЭлемент = Элементы.Вставить("ВзносыСумма" + ВидНВО, Тип("ПолеФормы"), Элементы.ВзносыГруппаРезультаты, Элементы.ВзносыГруппаРезультатСтраховыеВзносы);
				НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
				НовыйЭлемент.ПутьКДанным 		= "Объект.Взносы.Сумма" + ВидНВО;
				НовыйЭлемент.ПутьКДаннымПодвала = "Объект.Взносы.ИтогСумма" + ВидНВО;
                НовыйЭлемент.Ширина 			= 12;
                НовыйЭлемент.РастягиватьПоГоризонтали = Ложь;
				НовыйЭлемент.Заголовок 			= СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("%1", СтрЗаменить(ВидНВО, "ОтчисленияОСМС", "ООСМС"));
				
                // Показатели
				ГруппаНВО = Элементы.Вставить("ВзносыГруппа" + ВидНВО, Тип("ГруппаФормы"), Элементы.ВзносыГруппаПоказателиРасчета, Элементы.ВзносыГруппаСтраховыеВзносы);
				ГруппаНВО.Группировка 			= ГруппировкаКолонок.Горизонтальная; 
				ГруппаНВО.Заголовок 			= СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("%1", СтрЗаменить(ВидНВО, "ОтчисленияОСМС", "ООСМС")); 
		
				НовыйЭлемент = Элементы.Добавить("Взносы" + ВидНВО, Тип("ПолеФормы"), ГруппаНВО);
				НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
				НовыйЭлемент.ПутьКДанным 		= "Объект.Взносы." + ВидНВО;
				НовыйЭлемент.ПутьКДаннымПодвала = "Объект.Взносы.Итог" + ВидНВО;
				НовыйЭлемент.Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("%1 (расч. месяц)", СтрЗаменить(ВидНВО, "ОтчисленияОСМС", "ООСМС")); 
                НовыйЭлемент.Ширина 			= 12;
                НовыйЭлемент.РастягиватьПоГоризонтали = Ложь;

				ГруппаВзносыГруппа = Элементы.Добавить("ВзносыГруппаСтавка" + ВидНВО, Тип("ГруппаФормы"), ГруппаНВО);
				ГруппаВзносыГруппа.Группировка 	= ГруппировкаКолонок.Горизонтальная; 
				
				НовыйЭлемент = Элементы.Добавить("ВзносыТекущаяСтавка" + ВидНВО, Тип("ПолеФормы"), ГруппаВзносыГруппа);
				НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
				НовыйЭлемент.ПутьКДанным 		= "Объект.Взносы.ТекущаяСтавка" + ВидНВО;
				НовыйЭлемент.Заголовок 			= "%"; 
                НовыйЭлемент.Ширина 			= 5;
                НовыйЭлемент.РастягиватьПоГоризонтали = Ложь;
                НовыйЭлемент.ОтображатьВШапке = Ложь;
				
				НовыйЭлемент = Элементы.Добавить("ВзносыНормативОтчисленийВРезерв" + ВидНВО, Тип("ПолеФормы"), ГруппаВзносыГруппа);
				НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
				НовыйЭлемент.ПутьКДанным 		= "Объект.Взносы.НормативОтчисленийВРезерв" + ВидНВО;
				НовыйЭлемент.Заголовок 			= "%"; 
                НовыйЭлемент.Ширина 			= 5;
                НовыйЭлемент.РастягиватьПоГоризонтали = Ложь;
                НовыйЭлемент.ОтображатьВШапке = Ложь;
				
			КонецЦикла;
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаВзносы", "Заголовок", НСтр("ru = 'Налоги, взносы, отчисления'"));

		КонецЕсли;

#КонецОбласти

#Область ПодтверждениеЗачисленияЗарплаты
		
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ПодтверждениеЗачисленияЗарплаты") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаДокумента") Тогда

  			Элементы.Сотрудники.УстановитьДействие("ПередНачаломДобавления", "Подключаемый_СотрудникиПередНачаломДобавления");
			Элементы.СотрудникиФизическоеЛицо.УстановитьДействие("ПриИзменении", "Подключаемый_СотрудникиФизическоеЛицоПриИзменении");

		КонецЕсли;
		
#КонецОбласти

#Область ДоходВНатуральнойФорме
		
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ДоходВНатуральнойФорме") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаСписка") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Удержано", "Видимость", Ложь);
			
		ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("ФормаДокумента") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НачисленияСкидкаПоВзносам", "Видимость", Ложь);
			
		КонецЕсли;

#КонецОбласти

#Область НачальнаяШтатнаяРасстановка
		
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("НачальнаяШтатнаяРасстановка") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаДокумента") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СотрудникиПредставлениеАванса", "Заголовок", НСтр("ru = 'Аванс'"));
			
		ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("ФормаВыбораЕжегодныхОтпусков") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЕжегодныеОтпускаДнейОтсутствия", "Видимость", Ложь);
			
		КонецЕсли;

#КонецОбласти

#Область ВводНачальныхОстатковОтпусков
		
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ВводНачальныхОстатковОтпусков") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаДокумента") Тогда

			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЕжегодныеОтпускаДнейОтсутствия", "Видимость", Ложь);
			
		КонецЕсли;

#КонецОбласти

#Область ВозвратИзОтпускаПоУходуЗаРебенком
		
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ВозвратИзОтпускаПоУходуЗаРебенком") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаДокумента") Тогда

			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СпособРасчетаАванса", "Заголовок", НСтр("ru = 'Аванс'"));
			
		КонецЕсли;

#КонецОбласти

#Область СведенияОНезачисленныхВзносахОтчислениях
		
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("СведенияОНезачисленнойЗарплате") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаДокумента") Тогда

			НовыйЭлемент = Элементы.Вставить("Подразделение", Тип("ПолеФормы"), Элементы.Основное, Элементы.Ведомость);
			НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "Объект.Подразделение";
			НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_ПодразделениеПриИзменении");
			
			Элементы.Организация.УстановитьДействие("ПриИзменении", "Подключаемый_ОрганизацияПриИзменении");
			
		КонецЕсли;

#КонецОбласти

#Область СторнированиеНачислений
		
	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("СторнированиеНачислений") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаДокумента") Тогда

			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДоначисленияИПерерасчетыСкидкаПоВзносам", "Видимость", Ложь);
			
		КонецЕсли;

#КонецОбласти

#Область ДанныеДляРасчетаЗарплаты

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ДанныеДляРасчетаЗарплаты") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаДокумента") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ВыполненныеРаботыПоСотрудникам", "ПоложениеСтрокиПоиска", ПоложениеСтрокиПоиска.Авто);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеСводно", "ПоложениеСтрокиПоиска", ПоложениеСтрокиПоиска.Авто);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДанныеДетально", "ПоложениеСтрокиПоиска", ПоложениеСтрокиПоиска.Авто);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ВыполненныеРаботы", "ПоложениеСтрокиПоиска", ПоложениеСтрокиПоиска.Авто);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ИсполнителиРабот", "ПоложениеСтрокиПоиска", ПоложениеСтрокиПоиска.Авто);

			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДекорацияРуб", "Заголовок",  НСтр("ru = 'тг.'"));
			
		КонецЕсли;

#КонецОбласти

	КонецЕсли;
  
	МодификацияКонфигурацииЗУПКПереопределяемый.ОбработатьСобытияФормПриСозданииЧтенииДокумент(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);

КонецПроцедуры

Процедура ОбработатьСобытияФормПриСозданииЧтенииРегистрСведений(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры)

	Элементы = Форма.Элементы;

#Область ИсторияРегистрацийВНалоговомОргане

	Если ДополнительныеПараметры.ИмяОбъекта = ВРег("ИсторияРегистрацийВНалоговомОргане") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("РедактированиеИстории") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НаборЗаписейРегистрацияВНалоговомОрганеКод", "Заголовок", НСтр("ru = 'Код налогового органа'"));
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НаборЗаписейРегистрацияВНалоговомОрганеНаименование", "Заголовок", НСтр("ru = 'Наименование налогового органа'"));
			
		КонецЕсли;

#КонецОбласти
		
#Область МинимальнаяОплатаТрудаРФ

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("МинимальнаяОплатаТрудаРФ") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаСписка") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Период", "Заголовок", НСтр("ru = 'Дата, на которую установлен МЗП'"));
			
		КонецЕсли;

#КонецОбласти

#Область КлассыУсловийТрудаПоДолжностям

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("КлассыУсловийТрудаПоДолжностям") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаСписка") Тогда
			
			НовыйЭлемент = Элементы.Вставить("ОсуществляютсяОППВ", Тип("ПолеФормы"), Элементы.Список, Элементы.КлассУсловийТруда);
			НовыйЭлемент.Вид		 = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "Список.ОсуществляютсяОППВ";
			
		ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("РедактированиеИстории") Тогда
			
			НовыйЭлемент = Элементы.Вставить("ОсуществляютсяОППВ", Тип("ПолеФормы"), Элементы.НаборЗаписей, Элементы.НаборЗаписейКлассУсловийТруда);
			НовыйЭлемент.Вид		 = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "НаборЗаписей.ОсуществляютсяОППВ";
			
		КонецЕсли;

#КонецОбласти

#Область НастройкиРасчетаРезервовОтпусков

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("НастройкиРасчетаРезервовОтпусков") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("РедактированиеИстории") Тогда
			
			НовыйЭлемент = Элементы.Добавить("КоэффициентРасчетаОплачиваемыхДнейОтпуска", Тип("ПолеФормы"), Элементы.НаборЗаписей);
			НовыйЭлемент.Вид		 = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "НаборЗаписей.КоэффициентРасчетаОплачиваемыхДнейОтпуска";
			
		КонецЕсли;

#КонецОбласти

#Область СведенияОбИнвалидностиФизическихЛиц

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("СведенияОбИнвалидностиФизическихЛиц") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаСписка") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Период", "Подсказка", НСтр("ru = 'Период'"));
			
			НовыйЭлемент = Элементы.Вставить("ФизическоеЛицо", Тип("ПолеФормы"), Элементы.Список, Элементы.КолонкиИнвалидности);
			НовыйЭлемент.Вид		 = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "Список.ФизическоеЛицо";
			
			НовыйЭлемент = Элементы.Вставить("ОтношениеКИнвалидности", Тип("ПолеФормы"), Элементы.КолонкиСправки, Элементы.ГруппаИнвалидности);
			НовыйЭлемент.Вид		 = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "Список.ОтношениеКИнвалидности";
			
			НовыйЭлемент = Элементы.Вставить("ИсчислятьОПВ", Тип("ПолеФормы"), Элементы.КолонкиСправки, Элементы.ГруппаИнвалидности);
			НовыйЭлемент.Вид		 = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "Список.ИсчислятьОПВ";
			
		ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("РедактированиеИстории") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "КолонкиИнвалидности", "Заголовок", НСтр("ru = 'Инвалидность с ... по'"));
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "НаборЗаписейПериод", "Подсказка", НСтр("ru = 'Период'"));
			
		КонецЕсли;

#КонецОбласти

#Область ВоинскийУчет

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ВоинскийУчет") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("РедактированиеИстории") Тогда
			
			НовыйЭлемент = Элементы.Вставить("НаборЗаписейГруппаУчета", Тип("ПолеФормы"), Элементы.НаборЗаписей, Элементы.НаборЗаписейКатегорияЗапаса);
			НовыйЭлемент.Вид		 = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "НаборЗаписей.ГруппаУчета";
			
		КонецЕсли;

#КонецОбласти

#Область ДанныеОВремениДляРасчетаСреднегоОбщийКорректировка

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("ДанныеОВремениДляРасчетаСреднегоОбщийКорректировка") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаСписка") Тогда
			
			НовыйЭлемент = Элементы.Вставить("ОтработаноЧасовШестидневка", Тип("ПолеФормы"), Элементы.Список, Элементы.ОтработаноЧасовПятидневка);
			НовыйЭлемент.Вид		 = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "Список.ОтработаноЧасовШестидневка";
			
			Элементы.Переместить(Элементы.ОтработаноДнейПятидневка, Элементы.Список, Элементы.ОтработаноДнейШестидневка);
			
		ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("ФормаЗаписи") Тогда
			
			НовыйЭлемент = Элементы.Вставить("ОтработаноЧасовШестидневка", Тип("ПолеФормы"), , Элементы.ОтработаноДнейКалендарных);
			НовыйЭлемент.Вид		 = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "Запись.ОтработаноЧасовШестидневка";
			
			Элементы.Переместить(Элементы.ОтработаноДнейШестидневка, Форма, НовыйЭлемент);
			
		КонецЕсли;

#КонецОбласти

#Область АдресныеОбъекты

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("АдресныеОбъекты") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ЗагрузкаАдресногоКлассификатора") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЗагружатьИсториюИзмененийАдресныхОбъектов", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЗагружатьИсториюИзмененийАдресныхОбъектов", "Доступность", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаЗагрузкиССайта", "Видимость", Ложь);
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаЗагрузкиССайта", "Доступность", Ложь);

			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТекстОписанияЗагрузкиРасширеннаяПодсказка", "Заголовок", НСтр("ru = 'Загрузка адресного классификатора может занять длительное время, которое зависит от количества выбранных регионов.'"));

		ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("ОчисткаАдресногоКлассификатора") Тогда
			
			ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТекстОписанияОчисткиРасширеннаяПодсказка", "Заголовок", НСтр("ru = 'Очистка адресного классификатора может занять длительное время, которое зависит от количества выбранных регионов.'"));

		КонецЕсли;
		
#КонецОбласти

#Область КоэффициентИндексацииЗаработка

	ИначеЕсли ДополнительныеПараметры.ИмяОбъекта = ВРег("КоэффициентИндексацииЗаработка") Тогда
		
		Если ДополнительныеПараметры.ИмяФормы = ВРег("ФормаДокументовИндексацииСотрудника") Тогда
			
			НовыйЭлемент = Элементы.Добавить("ДатаИндексации", Тип("ПолеФормы"), Элементы.Список);
			НовыйЭлемент.Вид		 = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "Список.ДатаИндексации";
			
			НовыйЭлемент = Элементы.Добавить("Коэффициент", Тип("ПолеФормы"), Элементы.Список);
			НовыйЭлемент.Вид		 = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "Список.Коэффициент";
			
			НовыйЭлемент = Элементы.Добавить("КоэффициентИндексации", Тип("ПолеФормы"), Элементы.Список);
			НовыйЭлемент.Вид		 = ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным = "Список.КоэффициентИндексации";
			
		КонецЕсли;

#КонецОбласти

	КонецЕсли;
  
	МодификацияКонфигурацииЗУПКПереопределяемый.ОбработатьСобытияФормПриСозданииЧтенииРегистрСведений(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);

КонецПроцедуры

Процедура ОбработатьСобытияФормПриСозданииЧтенииОбщаяФорма(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры)

	Элементы = Форма.Элементы;

#Область РедактированиеРегистрацииВНалоговомОргане

	Если ДополнительныеПараметры.ИмяФормы = ВРег("РедактированиеРегистрацииВНалоговомОргане") Тогда
		НовыйЭлемент = Элементы.Вставить("ИНН", Тип("ПолеФормы"), Элементы.ГруппаКППКодВертикальная, Элементы.КПП);
		НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
		НовыйЭлемент.ПутьКДанным 		= "РегистрацияВНалоговомОргане.ИНН";
        НовыйЭлемент.УстановитьДействие("ОкончаниеВводаТекста", "Подключаемый_ИННОкончаниеВводаТекста");
			
#КонецОбласти

#Область ВводДанныхДляРасчетаСреднегоЗаработкаОбщий

	ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("ВводДанныхДляРасчетаСреднегоЗаработкаОбщий") Тогда
		
		НовыйЭлемент = Элементы.Добавить("СреднийЗаработокИнформационныйТекст", Тип("ДекорацияФормы"), Элементы.СреднийЗаработокЕдинственныйСпособ);
		НовыйЭлемент.Вид 				= ВидДекорацииФормы.Надпись;
		НовыйЭлемент.ЦветТекста 		= ЦветаСтиля.ПоясняющийТекст;
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаДатаУчетаРабочегоВремени", "Группировка", ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда);

#КонецОбласти
		
#Область ОрганизацияУчетнаяПолитика

	ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("ОрганизацияУчетнаяПолитика") Тогда

		ОбработатьСобытияФормПриСозданииЧтенииОбщаяФормаОрганизацияУчетнаяПолитика(Форма, Отказ, СтандартнаяОбработка, ДополнительныеПараметры);

#КонецОбласти

#Область ВводМестаРождения

	ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("ВводМестаРождения") Тогда
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ОсобоеМестоРождения", "Видимость", Ложь);

#КонецОбласти

#Область НастройкиРегистрацииСобытийДоступаКПерсональнымДанным

	ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("НастройкиРегистрацииСобытийДоступаКПерсональнымДанным") Тогда
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ДекорацияРегистрацияСобытияДоступНадпись", "Заголовок", НСтр("ru = 'Для выбранных областей данных выполняется регистрация событий доступа в соответствии с требованиями закона Республики Казахстан от 21 мая 2013 года N 94-V ""О персональных данных и их защите"".'"));

#КонецОбласти

#Область ОрганизацияВоинскийУчет

	ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("ОрганизацияВоинскийУчет") Тогда
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ПланРаботыПоОсуществлениюВоинскогоУчета", "Видимость", Ложь);

#КонецОбласти

#Область ОрганизацияНастройкиРасчетаРезервовОтпусков

	ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("ОрганизацияНастройкиРасчетаРезервовОтпусков") Тогда
		
		Группа7 = Элементы.Добавить("Группа7", Тип("ГруппаФормы"), Элементы.Группа2);
		Группа7.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		Группа7.Отображение = ОтображениеОбычнойГруппы.Нет;
		Группа7.ОтображатьЗаголовок = Ложь;
		
		НовыйЭлемент = Элементы.Добавить("Декорация4", Тип("ДекорацияФормы"), Группа7);
		
		НовыйЭлемент = Элементы.Добавить("КоэффициентРасчетаОплачиваемыхДнейОтпуска", Тип("ПолеФормы"), Группа7);
		НовыйЭлемент.Вид = ВидПоляФормы.ПолеВвода;
		НовыйЭлемент.ПутьКДанным = "НастройкиРасчетаРезервовОтпусков.КоэффициентРасчетаОплачиваемыхДнейОтпуска";

#КонецОбласти

#Область РедактированиеЗарплатыСтрокиВедомости

	ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("РедактированиеЗарплатыСтрокиВедомости") Тогда
			
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЗарплатаВидДохода", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ЗарплатаСтатьяРасходов", "Видимость", Ложь);

#КонецОбласти
		
#Область РедактированиеВыплатыСтрокиВедомости

	ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("РедактированиеВыплатыСтрокиВедомости") Тогда
			
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ВыплатыСтатьяРасходов", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ВыплатыВидДохода", "Видимость", Ложь);

        НовыйЭлемент = Элементы.Добавить("ВыплатыПодразделение", Тип("ПолеФормы"), Элементы.Выплаты);
        НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
        НовыйЭлемент.ПутьКДанным 		= "Выплаты.Подразделение";
        НовыйЭлемент.Заголовок 			= НСтр("ru = 'Подразделение'");
        НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_ВыплатыПодразделениеПриИзменении");
        НовыйЭлемент.КнопкаВыбора = Истина;

        НовыйЭлемент = Элементы.Добавить("ВыплатыПериодВзаиморасчетовСтрокой", Тип("ПолеФормы"), Элементы.Выплаты);
        НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
        НовыйЭлемент.ПутьКДанным 		= "Выплаты.ПериодВзаиморасчетовСтрокой";
        НовыйЭлемент.Заголовок 			= НСтр("ru = 'Период взаиморасчетов'");
        НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_ВыплатыПериодВзаиморасчетовСтрокойПриИзменении");
        НовыйЭлемент.УстановитьДействие("НачалоВыбора", "Подключаемый_ВыплатыПериодВзаиморасчетовСтрокойНачалоВыбора");
        НовыйЭлемент.УстановитьДействие("Регулирование", "Подключаемый_ВыплатыПериодВзаиморасчетовСтрокойРегулирование");
        НовыйЭлемент.УстановитьДействие("АвтоПодбор", "Подключаемый_ВыплатыПериодВзаиморасчетовСтрокойАвтоПодбор");
        НовыйЭлемент.УстановитьДействие("ОкончаниеВводаТекста", "Подключаемый_ВыплатыПериодВзаиморасчетовСтрокойОкончаниеВводаТекста");
        НовыйЭлемент.КнопкаВыбора = Истина;
        НовыйЭлемент.КнопкаРегулирования = Истина;
        
#КонецОбласти

#Область ФормаСтрокиДокументаИзмененияШтатногоРасписания

	ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("ФормаСтрокиДокументаИзмененияШтатногоРасписания") Тогда
		
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "КлассУсловийТрудаИстория", "Заголовок", НСтр("ru = 'История изменения особенностей исчисления ПВ'"));
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаСпецоценкаУсловийТруда", "Заголовок", НСтр("ru = 'Особенности исчисления пенсионных взносов'"));
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "КлассыУсловийТрудаПоДолжностямПериод", "Заголовок", НСтр("ru = 'Условия труда установлены с'"));
		
		НовыйЭлемент = Элементы.Вставить("КлассыУсловийТрудаПоДолжностямОсуществляютсяОППВ", Тип("ПолеФормы"), Элементы.ГруппаСпецоценкаУсловийТрудаКлассыУсловийТруда, Элементы.КлассыУсловийТрудаПоДолжностямПериод);
		НовыйЭлемент.Вид = ВидПоляФормы.ПолеФлажка;
		НовыйЭлемент.ПутьКДанным = "КлассыУсловийТрудаПоДолжностям.ОсуществляютсяОППВ";
		НовыйЭлемент.Заголовок = НСтр("ru = 'Осуществляются ОППВ за занятых на работах с вредными условиями труда'");
		НовыйЭлемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;

#КонецОбласти
 
#Область РегламентированнаяОтчетность

	ИначеЕсли ДополнительныеПараметры.ИмяФормы = ВРег("РегламентированнаяОтчетность") Тогда
		
		Форма.Заголовок = НСтр("ru = 'Регламентированная отчетность'"); 
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаПанельИнформацииСКнопкой", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГиперссылкаНовое", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГиперссылкаУведомления", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГиперссылкаПисьма", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГиперссылкаСверки", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГиперссылкаВходящие", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГиперссылкаЕГРЮЛ", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГиперссылкаВходящие", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГиперссылкаСервисы", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницаНовое", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ОтчетыГруппаПроверка", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтатусГосорган", "Видимость", Ложь);
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "СтраницаУведомления", "Видимость", Ложь);
