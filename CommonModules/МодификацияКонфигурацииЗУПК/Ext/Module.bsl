Процедура СоздатьБлокРеквизитовНВОМежрасчетОдносотрудниковыйДокумент(Форма, МассивДобавляемыхРеквизитов, ДобавитьРеквизитыНВОРаботодателя = Ложь, ПрефиксНВО = "", ДобавлятьКоманды = Истина)
	
	ВидыНВО = Новый Массив;
	ВидыНВО.Добавить(ПрефиксНВО + "ВОСМС");
	ВидыНВО.Добавить(ПрефиксНВО + "ИПН");
	ВидыНВО.Добавить(ПрефиксНВО + "ОПВ");
	ВидыНВО.Добавить(ПрефиксНВО + "ЕП");
	
	Если ДобавитьРеквизитыНВОРаботодателя Тогда
		ВидыНВО.Добавить("ИсчисленоСО");
		ВидыНВО.Добавить("ИсчисленоСН");
		ВидыНВО.Добавить("ИсчисленоООСМС");
		ВидыНВО.Добавить("ИсчисленоОППВ");
		ВидыНВО.Добавить("ИсчисленоЕП");
		ВидыНВО.Добавить("ИсчисленоОПВР");
	КонецЕсли;
	
	Для Каждого ВидНВО Из ВидыНВО Цикл
		
		НовыйРеквизит = Новый РеквизитФормы(ВидНВО, Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)),,, Истина);
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		
		Если ДобавлятьКоманды Тогда
			НоваяКоманда = Форма.Команды.Добавить("ПодробнееОРасчете" + ВидНВО);
			НоваяКоманда.Действие = "Подключаемый_ПодробнееОРасчете" + ВидНВО;
			НоваяКоманда.Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Подробнее о расчете %1'"), ВидНВО);
			НоваяКоманда.Картинка = БиблиотекаКартинок.Изменить;
			НоваяКоманда.Отображение = ОтображениеКнопки.Картинка;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура СоздатьБлокРеквизитовНВОМежрасчетМногосотрудниковыйДокумент(Форма, МассивДобавляемыхРеквизитов)
	
	ВидыНВО = Новый Массив;
	ВидыНВО.Добавить("ВОСМС");
	ВидыНВО.Добавить("ИПН");
	ВидыНВО.Добавить("ОПВ");
	ВидыНВО.Добавить("ЕП");

	Для Каждого ВидНВО Из ВидыНВО Цикл
		
		НовыйРеквизит = Новый РеквизитФормы("Итог" + ВидНВО, Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)));
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		
		НовыйРеквизит = Новый РеквизитФормы(ВидНВО, Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)), "Объект.Начисления", , Истина);
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура СоздатьБлокРеквизитовНВОМногосотрудниковыхДокументов(Форма, ИмяСтраницыФорма, ИмяЭлементаДляВставки, ДобавитьПредставлениеРазрешенныеВычеты = Истина)

	Элементы = Форма.Элементы;
	
	Если ЗначениеЗаполнено(ИмяЭлементаДляВставки) Тогда
		ГруппаНалогиВзносыОтчисления = Элементы.Вставить("ГруппаНалогиВзносыОтчисления", Тип("ГруппаФормы"), Элементы[ИмяСтраницыФорма], Элементы[ИмяЭлементаДляВставки]);
	Иначе
		ГруппаНалогиВзносыОтчисления = Элементы.Добавить("ГруппаНалогиВзносыОтчисления", Тип("ГруппаФормы"), Элементы[ИмяСтраницыФорма]);
	КонецЕсли;
	ГруппаНалогиВзносыОтчисления.Вид = ВидГруппыФормы.Страница;
	ГруппаНалогиВзносыОтчисления.Заголовок = НСтр("ru = 'Налоги, взносы, отчисления'"); 

	НоваяТаблица = Элементы.Добавить("НалогиВзносыОтчисления", Тип("ТаблицаФормы"), ГруппаНалогиВзносыОтчисления);
	НоваяТаблица.ПутьКДанным		= "Объект.НалогиВзносыОтчисления";
	НоваяТаблица.УстановитьДействие("Выбор", "Подключаемый_НалогиВзносыОтчисленияВыбор");
	НоваяТаблица.УстановитьДействие("ПриАктивизацииСтроки", "Подключаемый_НалогиВзносыОтчисленияПриАктивизацииСтроки");
	НоваяТаблица.УстановитьДействие("ПередУдалением", "Подключаемый_НалогиВзносыОтчисленияПередУдалением");
	НоваяТаблица.УстановитьДействие("ПриОкончанииРедактирования", "Подключаемый_НалогиВзносыОтчисленияПриОкончанииРедактирования");
	НоваяТаблица.УстановитьДействие("ПослеУдаления", "Подключаемый_НалогиВзносыОтчисленияПослеУдаления");

	НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияНайти", Тип("КнопкаФормы"), Элементы.НалогиВзносыОтчисленияКоманднаяПанель);
	НовыйЭлемент.Вид 				= ВидКнопкиФормы.КнопкаКоманднойПанели;
	НовыйЭлемент.ИмяКоманды  		= "НалогиВзносыОтчисленияНайти";
	НовыйЭлемент.Видимость  		= Ложь;
	
	НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияОтменитьПоиск", Тип("КнопкаФормы"), Элементы.НалогиВзносыОтчисленияКоманднаяПанель);
	НовыйЭлемент.Вид 				= ВидКнопкиФормы.КнопкаКоманднойПанели;
	НовыйЭлемент.ИмяКоманды 		= "НалогиВзносыОтчисленияОтменитьПоиск";
	НовыйЭлемент.Видимость  		= Ложь;

	НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияАвтоКоманды", Тип("ГруппаФормы"), Элементы.НалогиВзносыОтчисленияКоманднаяПанель);
	НовыйЭлемент.Вид 				= ВидГруппыФормы.ГруппаКнопок;

	НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияНомерСтроки", Тип("ПолеФормы"), НоваяТаблица);
	НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеНадписи;
	НовыйЭлемент.ПутьКДанным 		= "Объект.НалогиВзносыОтчисления.НомерСтроки";

	НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияФизическоеЛицо", Тип("ПолеФормы"), НоваяТаблица);
	НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным 		= "Объект.НалогиВзносыОтчисления.ФизическоеЛицо";

	НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияПодразделение", Тип("ПолеФормы"), НоваяТаблица);
	НовыйЭлемент.Вид				= ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным		= "Объект.НалогиВзносыОтчисления.Подразделение";

	НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияМесяцНалоговогоПериода", Тип("ПолеФормы"), НоваяТаблица);
	НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным 		= "Объект.НалогиВзносыОтчисления.МесяцНалоговогоПериода";
    НовыйЭлемент.Формат 			= "ДФ='ММММ гггг'";
	
	НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияВидДохода", Тип("ПолеФормы"), НоваяТаблица);
	НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным 		= "Объект.НалогиВзносыОтчисления.ВидДохода";

	НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияВидНалогаВзносаОтчисления", Тип("ПолеФормы"), НоваяТаблица);
	НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным 		= "Объект.НалогиВзносыОтчисления.ВидНалогаВзносаОтчисления";

	НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияОблагаемыйДоход", Тип("ПолеФормы"), НоваяТаблица);
	НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным 		= "Объект.НалогиВзносыОтчисления.ОблагаемыйДоход";

    // в многосотрудниковых документах расчет необлагаемого дохода довольно редкий, данную информацию можно получить в подробной форме 
	//НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияНеоблагаемыйДоход", Тип("ПолеФормы"), НоваяТаблица);
	//НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
	//НовыйЭлемент.ПутьКДанным 		= "Объект.НалогиВзносыОтчисления.НеоблагаемыйДоход";

	НалогВзносГруппа = Элементы.Добавить("НалогиВзносыОтчисленияНалогВзносГруппа", Тип("ГруппаФормы"), НоваяТаблица);
	НалогВзносГруппа.Вид 				= ВидГруппыФормы.ГруппаКолонок;
	НалогВзносГруппа.Группировка		= ГруппировкаКолонок.Горизонтальная;
	НалогВзносГруппа.Заголовок			= НСтр("ru = 'Налог / взнос'");
	НалогВзносГруппа.ОтображатьВШапке   = Истина;

	НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияНалогВзнос", Тип("ПолеФормы"), НалогВзносГруппа);
	НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным 		= "Объект.НалогиВзносыОтчисления.НалогВзнос";
 	НовыйЭлемент.ОтображатьВШапке	= Ложь;

	НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияНалогВзносСПревышения", Тип("ПолеФормы"), НалогВзносГруппа);
	НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным 		= "Объект.НалогиВзносыОтчисления.НалогВзносСПревышения";
	НовыйЭлемент.ОтображатьВШапке	= Ложь;

	НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияОбъектИсчисления", Тип("ПолеФормы"), НоваяТаблица);
	НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным 		= "Объект.НалогиВзносыОтчисления.ОбъектИсчисления";

	НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияРазрешенныйВычет", Тип("ПолеФормы"), НоваяТаблица);
	НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным 		= "Объект.НалогиВзносыОтчисления.РазрешенныйВычет";

	НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияПримененныйВычет", Тип("ПолеФормы"), НоваяТаблица);
	НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным 		= "Объект.НалогиВзносыОтчисления.ПримененныйВычет";

	НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияПримененнаяЛьгота", Тип("ПолеФормы"), НоваяТаблица);
	НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным 		= "Объект.НалогиВзносыОтчисления.ПримененнаяЛьгота";

	НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияПрочиеВычеты", Тип("ПолеФормы"), НоваяТаблица);
	НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным 		= "Объект.НалогиВзносыОтчисления.ПрочиеВычеты";

	НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияПредставлениеПримененныеВычеты", Тип("ПолеФормы"), НоваяТаблица);
	НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным 		= "Объект.НалогиВзносыОтчисления.ПредставлениеПримененныеВычеты";
	НовыйЭлемент.ГиперссылкаЯчейки 	= Истина;
	НовыйЭлемент.ЦветТекста		 	= ЦветаСтиля.ЦветГиперссылкиБРО;

	Если ДобавитьПредставлениеРазрешенныеВычеты Тогда
		НовыйЭлемент = Элементы.Добавить("НалогиВзносыОтчисленияПредставлениеРазрешенныеВычеты", Тип("ПолеФормы"), НоваяТаблица);
		НовыйЭлемент.Вид				= ВидПоляФормы.ПолеВвода;
		НовыйЭлемент.ПутьКДанным		= "Объект.НалогиВзносыОтчисления.ПредставлениеРазрешенныеВычеты";
		НовыйЭлемент.ГиперссылкаЯчейки	= Истина;
		НовыйЭлемент.ЦветТекста			= ЦветаСтиля.ЦветГиперссылкиБРО;
	КонецЕсли;

КонецПроцедуры

Процедура СоздатьБлокРеквизитовСреднегоЗаработка(Форма, МассивДобавляемыхРеквизитов, ЕстьИспользуетсяСреднечасовойЗаработок = Ложь)
	
    Если НЕ ЕстьИспользуетсяСреднечасовойЗаработок Тогда
		НовыйРеквизит = Новый РеквизитФормы("ИспользуетсяСреднечасовойЗаработок", Новый ОписаниеТипов("Булево")); 
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
	КонецЕсли;
	НовыйРеквизит = Новый РеквизитФормы("ПорядокУчетаРабочегоВремени", Новый ОписаниеТипов("ПеречислениеСсылка.УчетРабочегоВремениПриРасчетеСреднегоЗаработка")); 
	МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
	
КонецПроцедуры

Процедура СоздатьБлокРеквизитовНВОБазаНачислений(Форма, МассивДобавляемыхРеквизитов, ДобавитьРеквизитыНВОБазы = Ложь, ПрефиксНВОБазы = "", ДобавитьРеквизитыНВОНачислений = Ложь, ПрефиксНВОНачислений = "", ДобавитьДополнительныеРеквизитыНВО = Ложь)
	
	ВидыНВОБазы = Новый Массив;
	Если ДобавитьРеквизитыНВОБазы Тогда
		ВидыНВОБазы.Добавить(ПрефиксНВОБазы + "ОПВ");
		ВидыНВОБазы.Добавить(ПрефиксНВОБазы + "ВОСМС");
		ВидыНВОБазы.Добавить(ПрефиксНВОБазы + "ИПН");
		ВидыНВОБазы.Добавить(ПрефиксНВОБазы + "СО");
		ВидыНВОБазы.Добавить(ПрефиксНВОБазы + "СН");
		ВидыНВОБазы.Добавить(ПрефиксНВОБазы + "ООСМС");
		ВидыНВОБазы.Добавить(ПрефиксНВОБазы + "ОПВР");
		ВидыНВОБазы.Добавить(ПрефиксНВОБазы + "ОППВ");
	КонецЕсли;
	
	Для Каждого ВидНВО Из ВидыНВОБазы Цикл
		
		НовыйРеквизит = Новый РеквизитФормы(ВидНВО, Новый ОписаниеТипов("ТаблицаЗначений"));
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		НовыйРеквизит = Новый РеквизитФормы("ВидРасчета", Новый ОписаниеТипов("ПланВидовРасчетаСсылка.Начисления"), ВидНВО);
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		НовыйРеквизит = Новый РеквизитФормы("СпособОбложения", Новый ОписаниеТипов("ПеречислениеСсылка.СпособыНалогообложенияДоходов"), ВидНВО);
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		НовыйРеквизит = Новый РеквизитФормы("ДоходНеПодлежащийНалогообложению", Новый ОписаниеТипов("СправочникСсылка.ДоходыНеПодлежащиеНалогообложениюЧастично"), ВидНВО);
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		
	КонецЦикла;
	
	ВидыНВОНачислений = Новый Массив;
	Если ДобавитьРеквизитыНВОНачислений Тогда
		ВидыНВОНачислений.Добавить(ПрефиксНВОНачислений + "ОПВ");
		ВидыНВОНачислений.Добавить(ПрефиксНВОНачислений + "ВОСМС");
		ВидыНВОНачислений.Добавить(ПрефиксНВОНачислений + "ИПН");
		ВидыНВОНачислений.Добавить(ПрефиксНВОНачислений + "СО");
		ВидыНВОНачислений.Добавить(ПрефиксНВОНачислений + "СН");
		ВидыНВОНачислений.Добавить(ПрефиксНВОНачислений + "ООСМС");
		ВидыНВОНачислений.Добавить(ПрефиксНВОНачислений + "ОПВР");
		ВидыНВОНачислений.Добавить(ПрефиксНВОНачислений + "ОППВ");
	КонецЕсли;
	
	Для Каждого ВидНВО Из ВидыНВОНачислений Цикл
		
		НовыйРеквизит = Новый РеквизитФормы(ВидНВО, Новый ОписаниеТипов("ТаблицаЗначений"),,, Истина);
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		НовыйРеквизит = Новый РеквизитФормы("ВидРасчета", Новый ОписаниеТипов("ПланВидовРасчетаСсылка.Начисления"), ВидНВО);
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		НовыйРеквизит = Новый РеквизитФормы("РеквизитДопУпорядочивания", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(5,0)), ВидНВО);
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		НовыйРеквизит = Новый РеквизитФормы("ТолькоПросмотр", Новый ОписаниеТипов("Булево"), ВидНВО);
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		
		НовыйРеквизит = Новый РеквизитФормы(ВидНВО + "НеОблагаются", Новый ОписаниеТипов("ТаблицаЗначений"),,, Истина);
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		НовыйРеквизит = Новый РеквизитФормы("ВидРасчета", Новый ОписаниеТипов("ПланВидовРасчетаСсылка.Начисления"), ВидНВО + "НеОблагаются");
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		НовыйРеквизит = Новый РеквизитФормы("РеквизитДопУпорядочивания", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(5,0)), ВидНВО + "НеОблагаются");
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		НовыйРеквизит = Новый РеквизитФормы("ТолькоПросмотр", Новый ОписаниеТипов("Булево"), ВидНВО + "НеОблагаются");
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		
		НовыйРеквизит = Новый РеквизитФормы(ВидНВО + "НеОблагаютсяЧастично", Новый ОписаниеТипов("ТаблицаЗначений"),,, Истина);
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		НовыйРеквизит = Новый РеквизитФормы("ВидРасчета", Новый ОписаниеТипов("ПланВидовРасчетаСсылка.Начисления"), ВидНВО + "НеОблагаютсяЧастично");
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		НовыйРеквизит = Новый РеквизитФормы("ДоходНеПодлежащийНалогообложению", Новый ОписаниеТипов("СправочникСсылка.ДоходыНеПодлежащиеНалогообложениюЧастично"), ВидНВО + "НеОблагаютсяЧастично");
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		НовыйРеквизит = Новый РеквизитФормы("РеквизитДопУпорядочивания", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(5,0)), ВидНВО + "НеОблагаютсяЧастично");
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		НовыйРеквизит = Новый РеквизитФормы("ТолькоПросмотр", Новый ОписаниеТипов("Булево"), ВидНВО + "НеОблагаютсяЧастично");
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		
	КонецЦикла;
	
	Если ДобавитьДополнительныеРеквизитыНВО Тогда
		НовыйРеквизит = Новый РеквизитФормы("НалогиВзносыОтчисленияПериод", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		НовыйРеквизит = Новый РеквизитФормы("НалогиВзносыОтчисленияПериодСтрокой", Новый ОписаниеТипов("Строка", Новый КвалификаторыСтроки(15)),, НСтр("ru = 'Период изменений'"));
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		НовыйРеквизит = Новый РеквизитФормы("НалогиВзносыОтчисленияТаблицаИсточник", Новый ОписаниеТипов("Строка"));
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		НовыйРеквизит = Новый РеквизитФормы("НалогиВзносыОтчисленияТаблицаПриемник", Новый ОписаниеТипов("Строка"));
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
		НовыйРеквизит = Новый РеквизитФормы("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"),, НСтр("ru = 'Вид дохода'"));
		МассивДобавляемыхРеквизитов.Добавить(НовыйРеквизит);
	КонецЕсли;
	
КонецПроцедуры

Процедура СоздатьЭлементыРеквизитовНВОМежрасчетОдносотрудниковыйДокумент(Форма, ЭлементВставки = "УдержанияИзменить", ДобавитьРеквизитыНВОРаботодателя = Ложь, ПрефиксНВО = "", ДобавлятьКоманды = Истина)

	Элементы = Форма.Элементы;
	
	ВидыНВО = Новый Массив;
	ВидыНВО.Добавить(ПрефиксНВО + "ЕП");
	ВидыНВО.Добавить(ПрефиксНВО + "ОПВ");
	ВидыНВО.Добавить(ПрефиксНВО + "ВОСМС");
	ВидыНВО.Добавить(ПрефиксНВО + "ИПН");
	
	Если ДобавитьРеквизитыНВОРаботодателя Тогда
		ВидыНВО.Добавить("ИсчисленоЕП");
		ВидыНВО.Добавить("ИсчисленоСО");
		ВидыНВО.Добавить("ИсчисленоСН");
		ВидыНВО.Добавить("ИсчисленоОППВ");
		ВидыНВО.Добавить("ИсчисленоООСМС");
		ВидыНВО.Добавить("ИсчисленоОПВР");
	КонецЕсли;
	
	Элементы = Форма.Элементы;
	
	Для Каждого ВидНВО Из ВидыНВО Цикл

        Если ВидНВО = "ИсчисленоСО" ИЛИ ВидНВО = "ИсчисленоСН" ИЛИ ВидНВО = "ИсчисленоООСМС" ИЛИ ВидНВО = "ИсчисленоОППВ" ИЛИ ВидНВО = "ИсчисленоОПВР" ИЛИ ВидНВО = "ИсчисленоЕП" Тогда
			ГруппаВидНВО = Элементы.Добавить(ВидНВО + "Изменить", Тип("ГруппаФормы"), Элементы.ИсчисленоГруппа);
		Иначе
			ГруппаВидНВО = Элементы.Вставить(ВидНВО + "Изменить", Тип("ГруппаФормы"), Элементы.УдержаноГруппа, Элементы[ЭлементВставки]);
		КонецЕсли;
		ГруппаВидНВО.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		ГруппаВидНВО.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
		ГруппаВидНВО.ОтображатьЗаголовок = Ложь;
        ГруппаВидНВО.Отображение = ОтображениеОбычнойГруппы.Нет;
		
		НовыйЭлемент = Элементы.Добавить(ВидНВО, Тип("ПолеФормы"), ГруппаВидНВО);
		НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
		НовыйЭлемент.ПутьКДанным 		= ВидНВО;
		
		Если ВидНВО = ПрефиксНВО + "ЕП" ИЛИ ВидНВО = "ИсчисленоЕП" Тогда
			Если ВидНВО = ПрефиксНВО + "ЕП" Тогда
				Заголовок = НСтр("ru = 'ЕП (за счет работника)'");
			Иначе
				Заголовок = НСтр("ru = 'ЕП (за счет работодателя)'");
			КонецЕсли;
		Иначе
			Заголовок = ВидНВО;
			Заголовок = СтрЗаменить(Заголовок, "Исчислено", "");
			Заголовок = СтрЗаменить(Заголовок, ПрефиксНВО, "");
		КонецЕсли;
		
		НовыйЭлемент.Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = '%1'"), Заголовок);	
		НовыйЭлемент.ТолькоПросмотр		= Истина;
		
		Если ДобавлятьКоманды Тогда
			НовыйЭлемент.Ширина 			= 10;
			
			НовыйЭлемент = Элементы.Добавить("ПодробнееОРасчете" + ВидНВО, Тип("КнопкаФормы"), ГруппаВидНВО);
			НовыйЭлемент.Вид = ВидКнопкиФормы.Гиперссылка;
			НовыйЭлемент.ИмяКоманды = "ПодробнееОРасчете" + ВидНВО;
			НовыйЭлемент.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Центр;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура СоздатьЭлементыРеквизитовНВОМежрасчетМногосотрудниковыйДокумент(Форма, ИмяЭлементаВставки = "Начисления")

	Элементы = Форма.Элементы;
	
	ВидыНВО = Новый Массив;
	ВидыНВО.Добавить("ВОСМС");
	ВидыНВО.Добавить("ИПН");
	ВидыНВО.Добавить("ОПВ");
	ВидыНВО.Добавить("ЕП");

	Для Каждого ВидНВО Из ВидыНВО Цикл
		
		НовыйЭлемент = Элементы.Вставить("Начисления" + ВидНВО, Тип("ПолеФормы"), Элементы[ИмяЭлементаВставки], Элементы.НачисленияУдержания);
		НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеНадписи;
		НовыйЭлемент.Формат 			= "ЧДЦ=2; ЧН=0,00";
		НовыйЭлемент.ПутьКДанным 		= "Объект.Начисления." + ВидНВО;
		НовыйЭлемент.ПутьКДаннымПодвала = "Итог" + ВидНВО;
		НовыйЭлемент.ЦветТекста 		= ЦветаСтиля.ТекстИнформационнойНадписи;
		НовыйЭлемент.Гиперссылка 		= Истина;
		НовыйЭлемент.ГиперссылкаЯчейки  = Истина;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура СоздатьЭлементыРеквизитовНВОРезервы(Форма, ИмяТЧРасчетРезерва = "РасчетРезервов")

	Элементы = Форма.Элементы;
	
	ВидыНВО = Новый Массив;
	ВидыНВО.Добавить("СО");
	ВидыНВО.Добавить("СН");
	ВидыНВО.Добавить("ОтчисленияОСМС");
	ВидыНВО.Добавить("ОПВР");
	ВидыНВО.Добавить("ОППВ");
	
    // документ НачислениеОценочныхОбязательствПоОтпускам - РасчетРезерваОтпусков
    // документ РезервыПоОплатеТруда - РасчетРезервов
	Если ИмяТЧРасчетРезерва = "РасчетРезервов" Тогда
		ИмяЭлементаВставки1 = "РасчетРезерваОтпусковГруппаРезервСтраховыеВзносы";	
		ИмяЭлементаВставки2 = "РасчетРезервовФиксРасчет";	
		ИмяЭлементаВставки3 = "ОценочныеОбязательстваФиксРасчет";	
	Иначе
		ИмяЭлементаВставки1 = "РасчетРезерваОтпусковГруппаПоказатели";	
		ИмяЭлементаВставки2 = "РасчетРезерваОтпусковОтступ";	
		ИмяЭлементаВставки3 = "ОценочныеОбязательстваОтступ";	
	КонецЕсли;
	
	МассивДанных = Новый Массив;
	МассивДанных.Добавить("Исчислено");
	МассивДанных.Добавить("Накоплено");
	МассивДанных.Добавить("");
	
	Для Каждого ВидНВО Из ВидыНВО Цикл
		
        // резервы
        Если НЕ ИмяТЧРасчетРезерва = "РасчетРезервов" Тогда
			
			НовыйЭлемент = Элементы.Вставить("РасчетРезерваОтпусков" + ВидНВО, Тип("ПолеФормы"), Элементы[ИмяТЧРасчетРезерва], Элементы[ИмяЭлементаВставки1]);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным 		= "Объект." + ИмяТЧРасчетРезерва + "." + ВидНВО;
			НовыйЭлемент.ПутьКДаннымПодвала = "Объект." + ИмяТЧРасчетРезерва + ".Итог" + ВидНВО;
			НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_РасчетРезерваОтпусков" + СтрЗаменить(ВидНВО, "ОтчисленияОСМС", "ООСМС") + "ПриИзменении");
            НовыйЭлемент.РастягиватьПоГоризонтали = Ложь;
            НовыйЭлемент.Ширина = 10;
			
		КонецЕсли;
		
		ГруппаНВО = Элементы.Вставить("РасчетРезерваГруппа" + ВидНВО, Тип("ГруппаФормы"), Элементы[ИмяТЧРасчетРезерва], Элементы[ИмяЭлементаВставки2]);
		ГруппаНВО.Группировка = ГруппировкаКолонок.Горизонтальная; 
		ГруппаНВО.Заголовок = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("%1 %2", СтрЗаменить(ВидНВО, "ОтчисленияОСМС", "ООСМС"), НСтр("ru = 'обязательства (резерва)'")); 
        ГруппаНВО.ОтображатьВШапке = Истина;
		
		Для Каждого СтрокаДанных Из МассивДанных Цикл
			
			ГруппаИсчислено = Элементы.Добавить("РасчетРезервовГруппаСуммаРезерва" + ВидНВО + СтрокаДанных, Тип("ГруппаФормы"), ГруппаНВО);
			ГруппаИсчислено.Группировка = ГруппировкаКолонок.Вертикальная; 
			ГруппаИсчислено.Заголовок = ?(ЗначениеЗаполнено(СтрокаДанных), НРег(СтрокаДанных), НСтр("ru = 'зачтено'")); 
            ГруппаИсчислено.ОтображатьВШапке = Истина;
			
			НовыйЭлемент = Элементы.Добавить("РасчетРезервовСуммаРезерва" + ВидНВО + СтрокаДанных, Тип("ПолеФормы"), ГруппаИсчислено);
			НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
			НовыйЭлемент.ПутьКДанным 		= "Объект." + ИмяТЧРасчетРезерва + ".СуммаРезерва" + ВидНВО + СтрокаДанных;
			НовыйЭлемент.ПутьКДаннымПодвала = "Объект." + ИмяТЧРасчетРезерва + ".ИтогСуммаРезерва" + ВидНВО + СтрокаДанных;
            НовыйЭлемент.ОтображатьВШапке 	= Ложь;
            НовыйЭлемент.РастягиватьПоГоризонтали = Ложь;
            НовыйЭлемент.Ширина = 10;
            Если ИмяТЧРасчетРезерва = "РасчетРезерваОтпусков" Тогда
				НовыйЭлемент.УстановитьДействие("ПриИзменении", "Подключаемый_РасчетРезерваОтпусковСуммаРезерва" + ВидНВО + СтрокаДанных + "ПриИзменении");
			КонецЕсли;
			
		КонецЦикла;		

		// ОценочныеОбязательстваПоСотрудникам
		НовыйЭлемент = Элементы.Вставить("ОценочныеОбязательстваПоСотрудникамСуммаРезерва" + ВидНВО, Тип("ПолеФормы"), Элементы.ОценочныеОбязательстваПоСотрудникам, Элементы.ОценочныеОбязательстваПоСотрудникамКорректировкаОбязательств);
		НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
		НовыйЭлемент.ПутьКДанным 		= "Объект.ОценочныеОбязательстваПоСотрудникам.СуммаРезерва" + ВидНВО;
		НовыйЭлемент.ПутьКДаннымПодвала = "Объект.ОценочныеОбязательстваПоСотрудникам.ИтогСуммаРезерва" + ВидНВО;
        НовыйЭлемент.РастягиватьПоГоризонтали = Ложь;
        НовыйЭлемент.Ширина = 17;
		
		// ОценочныеОбязательства 
		ГруппаНВООценочныеОбязательства = Элементы.Вставить("ОценочныеОбязательстваГруппаРезерв" + ВидНВО, Тип("ГруппаФормы"), Элементы.ОценочныеОбязательства, Элементы[ИмяЭлементаВставки3]);
		ГруппаНВООценочныеОбязательства.Группировка = ГруппировкаКолонок.Вертикальная; 
		ГруппаНВООценочныеОбязательства.Заголовок = СтрЗаменить(ВидНВО, "ОтчисленияОСМС", "ООСМС"); 
        ГруппаНВООценочныеОбязательства.ОтображатьВШапке = Истина;
        ГруппаНВООценочныеОбязательства.РастягиватьПоГоризонтали = Ложь;
        ГруппаНВООценочныеОбязательства.Ширина = 17;

		НовыйЭлемент = Элементы.Добавить("ОценочныеОбязательстваСуммаРезерва" + ВидНВО, Тип("ПолеФормы"), ГруппаНВООценочныеОбязательства);
		НовыйЭлемент.Вид 				= ВидПоляФормы.ПолеВвода;
		НовыйЭлемент.ПутьКДанным 		= "Объект.ОценочныеОбязательства.СуммаРезерва" + ВидНВО;
		НовыйЭлемент.ПутьКДаннымПодвала = "Объект.ОценочныеОбязательства.ИтогСуммаРезерва" + ВидНВО;
        НовыйЭлемент.ОтображатьВШапке 	= Ложь;
        НовыйЭлемент.РастягиватьПоГоризонтали = Ложь;
        НовыйЭлемент.Ширина = 17;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура СоздатьЭлементыРеквизитовНВОБазаНачислений(Форма, ГруппаСтраниц, ИмяЭлементаВставки, ПодсказкаЭлементаВставки)
	
	Элементы = Форма.Элементы;
	
	СтраницаНВО = Элементы.Добавить("Страница" + ИмяЭлементаВставки, Тип("ГруппаФормы"), ГруппаСтраниц);
	СтраницаНВО.Вид = ВидГруппыФормы.Страница;
	СтраницаНВО.Заголовок = НСтр("ru = '"+ИмяЭлементаВставки+"'");
	СтраницаНВО.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	
	ГруппаОблагаетсяНВО = Элементы.Добавить("ГруппаОблагается" + ИмяЭлементаВставки, Тип("ГруппаФормы"), СтраницаНВО);
	ГруппаОблагаетсяНВО.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаОблагаетсяНВО.Отображение = ОтображениеОбычнойГруппы.Нет;
	ГруппаОблагаетсяНВО.Заголовок  = НСтр("ru = 'Облагается "+ИмяЭлементаВставки+"'");
	ГруппаОблагаетсяНВО.ОтображатьЗаголовок = Истина;
	ГруппаОблагаетсяНВО.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	
	НоваяТаблица = Элементы.Добавить("Начисления" + ИмяЭлементаВставки, Тип("ТаблицаФормы"), ГруппаОблагаетсяНВО);
	НоваяТаблица.ПутьКДанным = "Начисления" + ИмяЭлементаВставки;
	НоваяТаблица.Подсказка = НСтр("ru = 'Список начислений, определяющих базу " + ПодсказкаЭлементаВставки + "'");
	НоваяТаблица.ОтображениеПодсказки = ОтображениеПодсказки.ОтображатьСверху;
	НоваяТаблица.Шапка = Ложь;
	НоваяТаблица.ПоложениеКоманднойПанели = ПоложениеКоманднойПанелиЭлементаФормы.Нет;
	НоваяТаблица.УстановитьДействие("Выбор", "Подключаемый_НалогиВзносыОтчисленияВыбор");
	НоваяТаблица.УстановитьДействие("НачалоПеретаскивания", "Подключаемый_НалогиВзносыОтчисленияНачалоПеретаскивания");
	НоваяТаблица.УстановитьДействие("Перетаскивание", "Подключаемый_НалогиВзносыОтчисленияПеретаскивание");
	
	НовыйЭлемент = Элементы.Добавить("Начисления" + ИмяЭлементаВставки + "ВидРасчета", Тип("ПолеФормы"), НоваяТаблица);
	НовыйЭлемент.Вид		 = ВидПоляФормы.ПолеВвода;
	НовыйЭлемент.ПутьКДанным = "Начисления" + ИмяЭлементаВставки + ".ВидРасчета";
	
	ГруппаНВОПравая = Элементы.Добавить("Группа" + ИмяЭлементаВставки + "Правая", Тип("ГруппаФормы"), СтраницаНВО);
	ГруппаНВОПравая.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаНВОПравая.Отображение = ОтображениеОбычнойГруппы.Нет;
	ГруппаНВОПравая.ОтображатьЗаголовок = Ложь;
	ГруппаНВОПравая.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	
	ГруппаНеОблагаетсяНВО = Элементы.Добавить("ГруппаНеОблагается" + ИмяЭлементаВставки, Тип("ГруппаФормы"), ГруппаНВОПравая);
	ГруппаНеОблагаетсяНВО.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаНеОблагаетсяНВО.Отображение = ОтображениеОбычнойГруппы.Нет;
	ГруппаНеОблагаетсяНВО.Заголовок  = НСтр("ru = '            Не облагается "+ИмяЭлементаВставки+"'");
	ГруппаНеОблагаетсяНВО.ОтображатьЗаголовок = Истина;
