// АПК:1297-выкл Статистика, не локализуется

Функция СтатистикаРассылокУведомлений()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ РассылкиУведомлений.Ссылка) КАК Рассылок,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ АктивныеРассылкиУведомлений.Ссылка) КАК АктивныхРассылок
		|ИЗ
		|	Справочник.РассылкиУведомлений КАК РассылкиУведомлений
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.РассылкиУведомлений КАК АктивныеРассылкиУведомлений
		|		ПО РассылкиУведомлений.Ссылка = АктивныеРассылкиУведомлений.Ссылка
		|			И (АктивныеРассылкиУведомлений.Подготовлена = ИСТИНА)
		|ГДЕ
		|	РассылкиУведомлений.ПометкаУдаления = ЛОЖЬ";
	
	ТаблицаРассылок = Запрос.Выполнить().Выгрузить();
	
	ПоказателиСтатистики = Новый Соответствие;
	ПоказателиСтатистики.Вставить("Рассылок", ТаблицаРассылок.ВыгрузитьКолонку("Рассылок")[0]);
	ПоказателиСтатистики.Вставить("Активных рассылок", ТаблицаРассылок.ВыгрузитьКолонку("АктивныхРассылок")[0]);
	
	Возврат ПоказателиСтатистики;
	
КонецФункции

Функция СтатистикаУведомлений(НачалоПериода)
	
	Таблица = Метаданные.РегистрыСведений.Уведомления;
	ДанныеСтатистики = СборСтатистики.ДанныеСбораСтатистики();
	
	ДанныеСтатистики.ДанныеОбъекта.Объект = Таблица.Измерения.Рассылка;
	ДанныеСтатистики.ДанныеОбъекта.ПредставлениеОбъектов = "Рассылок";
	
	ДанныеСтатистики.ДанныеПериода.Период = Таблица.Измерения.ДатаСобытия;
	ДанныеСтатистики.ДанныеПериода.НачалоПериода = НачалоПериода;
	
	ДанныеГруппировок = Новый Массив;
	
	ДанныеГруппировки = СборСтатистики.ДанныеГруппировки();
	ДанныеГруппировки.Группировка = Таблица.Ресурсы.Состояние;
	ДанныеГруппировки.ПредставлениеГруппировки = "Состояний";
	ДанныеГруппировки.Перечисление = Истина;
	ДанныеГруппировок.Добавить(ДанныеГруппировки);
	
	ДанныеГруппировки = СборСтатистики.ДанныеГруппировки();
	ДанныеГруппировки.Группировка = Таблица.Реквизиты.ВидТранспорта;
	ДанныеГруппировки.ПредставлениеГруппировки = "Видов транспорта";
	ДанныеГруппировки.Перечисление = Истина;
	ДанныеГруппировок.Добавить(ДанныеГруппировки);
	
	ДанныеСтатистики.ДанныеГруппировок = ДанныеГруппировок;
	
	ПоказателиСтатистики = СборСтатистики.СтандартныеПоказателиПоТаблице(Таблица, ДанныеСтатистики);
	
	Возврат ПоказателиСтатистики;
	
КонецФункции

