	ЗащищенноеСоединение = ОбщегоНазначенияКлиентСервер.НовоеЗащищенноеСоединение();
	
	Попытка
		Соединение = Новый HTTPСоединение("tagger.1c.ai",,,, Прокси, Таймаут, ЗащищенноеСоединение);
	Исключение
		ИмяСобытия = НСтр("ru = 'Разбор резюме.Сервис семантического анализа'", ОбщегоНазначения.КодОсновногоЯзыка());
