
#Область СлужебныйПрограммныйИнтерфейс

// Сбрасывает ключи доступа к сервису семантического анализа.
Процедура СброситьКлючиДоступаСервиса() Экспорт
	
	КлючиДоступа = РегистрыСведений.КлючиДоступаСервисаСемантическогоАнализа.КлючиДоступа();
	КлючиДоступа.КлючДоступа = "";
	КлючиДоступа.КлючИзменения = "";
	РегистрыСведений.КлючиДоступаСервисаСемантическогоАнализа.УстановитьКлючиДоступа(КлючиДоступа);
	
КонецПроцедуры

// Устанавливает видимость использования сервиса семантического анализа.
// 
// Параметры:
//  Элемент - ЭлементФормы - элемент формы или группа формы.
Процедура УстановитьВидимостьЭлементаФормы(Элемент) Экспорт
	
	Элемент.Видимость = ИспользоватьСервисСемантическогоАнализа();
	
КонецПроцедуры

// Определяет использовать ли сервис семантического анализа.
// 
// Возвращаемое значение: 
//  Булево - Истина, если сервис семантического анализа используется.
//
Функция ИспользоватьСервисСемантическогоАнализа() Экспорт
	
	ИспользоватьСервисСемантическогоАнализа =
		ПодборПерсонала.УстановленныеНастройки().ИспользоватьСервисСемантическогоАнализа;
		
	Возврат ИспользоватьСервисСемантическогоАнализа;
	
КонецФункции

// Запрос к сервису семантического анализа
//
// Параметры:
//  ТекстыРезюме - Массив - массив содержащий тексты резюме.
// 
// Возвращаемое значение:
//  Результат - Структура - см. ОписаниеРезультатаЗапросаКСервису().
//
Функция ЗапросКСервису(ТекстыРезюме) Экспорт
	
	Результат = ОписаниеРезультатаЗапросаКСервису();
	КоличествоРезюме = ТекстыРезюме.Количество();
	
	Попытка
		Соединение = HTTPСоединениеССервисом(КоличествоРезюме);
	Исключение
		Результат.ОшибкаСервиса = Истина;
		Результат.ОписаниеОшибки = НСтр("ru = 'Невозможно соединиться с сервисом семантического анализа.'");
		Возврат Результат;
	КонецПопытки;
	
	КлючиДоступа = РегистрыСведений.КлючиДоступаСервисаСемантическогоАнализа.КлючиДоступа();
	Если Не ЗначениеЗаполнено(КлючиДоступа.КлючДоступа) Тогда
		ПолучитьКлючиДоступа(Результат, КлючиДоступа, Соединение);
		Если ЗначениеЗаполнено(Результат.ОписаниеОшибки) Тогда
			Возврат Результат;
		КонецЕсли;
	КонецЕсли;
	
	КлючДоступа = КлючиДоступа.КлючДоступа;
	
	Попытка
		ТелоЗапроса = РезюмеВJSON(ТекстыРезюме, КоличествоРезюме);
	Исключение
		Результат.ОписаниеОшибки = НСтр("ru = 'Невозможно сформировать текст резюме для сервиса семантического анализа.'");
		Возврат Результат;
	КонецПопытки;
	
	Заголовки = ЗаголовкиHTTPЗапроса(КлючДоступа);
	
	Попытка
		Ответ = HTTPЗапросКСервисуОтправить(Соединение, АдресРесурса(КоличествоРезюме), Заголовки, ТелоЗапроса);
	Исключение
		Результат.ОшибкаСервиса = Истина;
		Результат.ОписаниеОшибки = ТекстОшибкиПолученияОтветаОтСервиса();
		Возврат Результат;
	КонецПопытки;
	
	Если Ответ.КодСостояния <> 202 Тогда
		Результат.ОшибкаСервиса = Истина;
		Результат.ОписаниеОшибки = ТекстОшибкиОграниченияДоступаКСервису();
		Возврат Результат;
	КонецЕсли;
	
	Попытка
		Идентификатор = ДанныеИзJSON(Ответ);
	Исключение
		Результат.ОписаниеОшибки = ТекстОшибкиЧтенияДанныхОтСервиса();
		Возврат Результат;
	КонецПопытки;
	
	ПолучитьРезультатРаботыСервиса(Результат, Соединение, Идентификатор, Заголовки);
	
	Возврат Результат;
	
КонецФункции

// Заполнение структуры резюме результатами запроса к сервису семантического анализа
//
// Параметры:
//  Данные - Соответствие - соответствие с сущностями(ents) и фактами(facts).
//  ДанныеКандидатов - Структура - структура данных кандидатов.
//  ТекстыРезюме - Массив - массив содержащий тексты резюме.
//
Процедура ПрочитатьРезультатЗапроса(Данные, ДанныеКандидатов) Экспорт
	
	Если ТипЗнч(Данные) = Тип("Соответствие") Тогда
		ЗаполнитьДанныеКандидатов(Данные, ДанныеКандидатов[0]);
	КонецЕсли;
	
	Если ТипЗнч(Данные) = Тип("Массив") Тогда
		НомерТекста = 0;
		Для Каждого ЭлементЗапроса Из Данные Цикл
			ЗаполнитьДанныеКандидатов(ЭлементЗапроса, ДанныеКандидатов[НомерТекста]);
			НомерТекста = НомерТекста + 1;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПолучитьКлючиДоступа(Результат, КлючиДоступа, Соединение)
	
	Тикет = ТикетДляСервисаСемантическогоАнализа();
	Если Тикет = Неопределено Тогда
		Результат.ОшибкаСервиса = Истина;
		Результат.ОписаниеОшибки = НСтр("ru = 'Интернет-поддержка пользователей недоступна.'");
		Возврат;
	КонецЕсли;
	
	Попытка
		ТелоЗапроса = ТикетВJSON(Тикет, КлючиДоступа.ИдентификаторПриложения);
	Исключение
		Результат.ОписаниеОшибки = ТекстОшибкиПолученияКлючаДоступа();
		Возврат;
	КонецПопытки;
	
	Заголовки = ЗаголовкиHTTPЗапроса();
	
	Попытка
		Ответ = HTTPЗапросКСервисуОтправить(Соединение, АдресРегистрацииПриложения(), Заголовки, ТелоЗапроса);
	Исключение
		Результат.ОшибкаСервиса = Истина;
		Результат.ОписаниеОшибки = ТекстОшибкиПолученияКлючаДоступа();
		Возврат;
	КонецПопытки;
	
	Если Ответ.КодСостояния <> 200 Тогда
		Результат.ОшибкаСервиса = Истина;
		Результат.ОписаниеОшибки = ТекстОшибкиОграниченияДоступаКСервису();
		Возврат;
	КонецЕсли;
	
	Попытка
		Данные = ДанныеИзJSON(Ответ);
		КлючиДоступа.КлючДоступа = Данные.Получить("access_token");
		КлючиДоступа.КлючИзменения = Данные.Получить("refresh_token");
		КлючиДоступа.ИдентификаторПриложения = Данные.Получить("application_uuid");
		РегистрыСведений.КлючиДоступаСервисаСемантическогоАнализа.УстановитьКлючиДоступа(КлючиДоступа);
	Исключение
		Результат.ОписаниеОшибки = ТекстОшибкиПолученияКлючаДоступа();
		Возврат;
	КонецПопытки;
	
КонецПроцедуры

Процедура ПрочитатьСущности(Сущности, Резюме)
	
	Если Сущности.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	КонтактнаяИнформация = Новый Массив;
	ЗнаниеЯзыков = Новый Массив;
	СостояниеВБраке = Новый Массив;
	Гражданство = Новый Массив;
	ИспользуемыеСущности = ИспользуемыеСущности();
	Резюме.ВалютаДохода = ЗарплатаКадры.ВалютаУчетаЗаработнойПлаты();
	Резюме.ПериодичностьДохода = Перечисления.ПериодичностьОжидаемогоДоходаКандидатов.Месяц;
	
	Для Каждого Сущность Из Сущности Цикл
		Если ИспользуемыеСущности.Найти(Сущность["type"]) = Неопределено Тогда
			Продолжить;
		ИначеЕсли Сущность["type"] = "$ФИО" Тогда
			Если ЗначениеЗаполнено(Резюме.Фамилия) Тогда
				Продолжить;
			КонецЕсли;
			ФИО = Сущность["spec"]["$sys_persons"]["spec"];
			Резюме.Фамилия = ФИО["surname"];
			Резюме.Имя = ФИО["name"];
			Резюме.Отчество = ФИО["patronym"];
		ИначеЕсли Сущность["type"] = "$Ожидаемый_доход" Тогда
			Доход = Сущность["spec"]["$sys_money"]["spec"];
			Резюме.ОжидаемыйДоход = Число(Доход["amount"]);
			Резюме.ВалютаДохода = ВалютаПоЗнаку(Доход["currency"]);
		ИначеЕсли Сущность["type"] = "$Телефон" Тогда
			Если СтрДлина(Сущность["asis"]) < 10 Тогда
				Продолжить;
			КонецЕсли;
			ОписаниеКонтактнойИнформации = ОписаниеКонтактнойИнформации();
			ОписаниеКонтактнойИнформации.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон;
			ОписаниеКонтактнойИнформации.Вид = Справочники.ВидыКонтактнойИнформации.ТелефонМобильныйФизическиеЛица;
			ОписаниеКонтактнойИнформации.Представление = Сущность["asis"];
			КонтактнаяИнформация.Добавить(ОписаниеКонтактнойИнформации);
		ИначеЕсли Сущность["type"] = "$АдресЭлПочты" Тогда
			ОписаниеКонтактнойИнформации = ОписаниеКонтактнойИнформации();
			ОписаниеКонтактнойИнформации.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
			ОписаниеКонтактнойИнформации.Вид = Справочники.ВидыКонтактнойИнформации.EMailФизическиеЛица;
			ОписаниеКонтактнойИнформации.Представление = Сущность["asis"];
			КонтактнаяИнформация.Добавить(ОписаниеКонтактнойИнформации);
		ИначеЕсли Сущность["type"] = "$МестоЖительства" Тогда
			ОписаниеКонтактнойИнформации = ОписаниеКонтактнойИнформации();
			ОписаниеКонтактнойИнформации.Тип = Перечисления.ТипыКонтактнойИнформации.Адрес;
			ОписаниеКонтактнойИнформации.Вид = Справочники.ВидыКонтактнойИнформации.АдресМестаПроживанияФизическиеЛица;
			ОписаниеКонтактнойИнформации.Представление = Сущность["spec"].Получить("$sys_loc+")["asis"];
			КонтактнаяИнформация.Добавить(ОписаниеКонтактнойИнформации);
		ИначеЕсли Сущность["type"] = "$ДатаРождения" Тогда
			ДатаРожденияСтрока = Сущность["norm"]["$Дата"]["$sys_date"];
			ДатаРожденияСтрока = СтрЗаменить(ДатаРожденияСтрока , "-", "");
			Резюме.ДатаРождения = Дата(ДатаРожденияСтрока);
		ИначеЕсли Сущность["type"] = "$Пол" Тогда
			Резюме.Пол = Сущность["asis"];
		ИначеЕсли Сущность["type"] = "$СемейноеПоложение" Тогда
			СоответствиеСемейногоПоложения = РазборРезюме.СписокСоответствийСемейноеПоложение();
			СостояниеВБраке.Добавить(Новый Структура("СостояниеВБраке, Дата",
				СоответствиеСемейногоПоложения.Получить(НРег(Сущность["asis"]))));
		ИначеЕсли Сущность["type"] = "$Гражданство" Тогда
			Гражданство.Добавить(Новый Структура("Страна, Дата", Строка(Сущность["norm"]["$sys_loc"])));
		ИначеЕсли Сущность["type"] = "$ЯзыкКанд" Тогда
			ОписаниеЗнанияЯзыков = ОписаниеЗнанияЯзыков();
			ОписаниеЗнанияЯзыков.Язык = Сущность["norm"]["$Язык"]["$КонкретныйЯзык"];
			ОписаниеЗнанияЯзыков.СтепеньЗнанияЯзыка = СтепеньЗнанияЯзыка(Сущность["norm"]["$УровеньВладенияЯзыком"]);
			ОписаниеЗнанияЯзыков.Содержание = Сущность["asis"];
			ЗнаниеЯзыков.Добавить(ОписаниеЗнанияЯзыков);
		ИначеЕсли Сущность["type"] = "$Язык" Тогда
			ОписаниеЗнанияЯзыков = ОписаниеЗнанияЯзыков();
			ОписаниеЗнанияЯзыков.Язык = Сущность["norm"]["$КонкретныйЯзык"];
			ОписаниеЗнанияЯзыков.СтепеньЗнанияЯзыка = Справочники.СтепениЗнанияЯзыка.НайтиПоКоду(1);
			ОписаниеЗнанияЯзыков.Содержание = Сущность["asis"];
			ЗнаниеЯзыков.Добавить(ОписаниеЗнанияЯзыков);
		КонецЕсли;
	КонецЦикла;
	
	Резюме.КонтактнаяИнформация = КонтактнаяИнформация;
	Резюме.ЗнаниеЯзыков = ЗнаниеЯзыков;
	Резюме.СостояниеВБраке = СостояниеВБраке;
	Резюме.Гражданство = Гражданство;
	
КонецПроцедуры

Процедура ПрочитатьФакты(Факты, Резюме)
	
	Если Факты.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ОпытРаботы = Новый Массив;
	Образование = Новый Массив;
	
	Для Каждого Факт Из Факты Цикл
		Если Факт["type"] = "@РаботаОпыт2" Тогда
			ОписаниеОпытаРаботы = ОписаниеОпытаРаботы();
			ОписаниеОпытаРаботы.Период = Факт["$ПериодРаботы"][0]["asis"];
			Если Факт["$ПериодРаботы"][0]["norm"]["$sys_interval"][0] = Неопределено Тогда
				ОписаниеОпытаРаботы.ДатаНачала = 
					Факт["$ПериодРаботы"][0]["norm"]["$sys_interval"].Получить("start").Получить("date");
			Иначе
				ОписаниеОпытаРаботы.ДатаНачала = Факт["$ПериодРаботы"][0]["norm"]["$sys_interval"][0]["start"].Получить("date");
				ОписаниеОпытаРаботы.ДатаОкончания = Факт["$ПериодРаботы"][0]["norm"]["$sys_interval"][1]["start"].Получить("date");
			КонецЕсли;
			ОписаниеОпытаРаботы.Организация = Факт["$Организация"][0]["asis"]; 
			ОписаниеОпытаРаботы.Обязанности = Факт["free_strings"];
			ОпытРаботы.Добавить(ОписаниеОпытаРаботы);
		ИначеЕсли Факт["type"] = "@Образование" Тогда
			ОписаниеОбразования = ОписаниеОбразования();
			ОписаниеОбразования.ВидОбразования =
				Справочники.ВидыОбразованияФизическихЛиц.НайтиПоНаименованию(Факт["$УровеньОбразования"][0]["asis"]);
			ОписаниеОбразования.Окончание =
				РазборРезюме.СтрокаКакЧисло(Факт["$ДатаОкончания"][0]["spec"].Получить("$sys_interval")["asis"]);
			ОписаниеОбразования.УчебноеЗаведение = Факт["$ВУЗ"][0]["norm"].Получить("$sys_org");
			Если ТипЗнч(Факт["$ФакультетИСпециальность"][0]["norm"].Получить("$sys_any")) = Тип("Строка") Тогда
				ОписаниеОбразования.Факультет = Факт["$ФакультетИСпециальность"][0]["norm"].Получить("$sys_any");
			Иначе
				ОписаниеОбразования.Факультет = Факт["$ФакультетИСпециальность"][0]["norm"].Получить("$sys_any")[0];
				ОписаниеОбразования.Специальность = Факт["$ФакультетИСпециальность"][0]["norm"].Получить("$sys_any")[1];
			КонецЕсли;
			Образование.Добавить(ОписаниеОбразования);
		ИначеЕсли Факт["type"] = "@Образование2" Тогда
			ОписаниеОбразования = ОписаниеОбразования();
			ОписаниеОбразования.УчебноеЗаведение = Факт["$ОбразованиеПолное"][0]["norm"].Получить("$sys_org");
			ОписаниеОбразования.ВидОбразования = Справочники.ВидыОбразованияФизическихЛиц.НайтиПоНаименованию(
				Факт["$ОбразованиеПолное"][0]["norm"].Получить("$УровеньОбразования"));
			Если Факт["$ОбразованиеПолное"][0]["norm"].Получить("$sys_interval") <> Неопределено Тогда
				ОписаниеОбразования.Окончание =
					РазборРезюме.СтрокаКакЧисло(Факт["$ОбразованиеПолное"][0]["spec"].Получить("$sys_interval")["asis"]);
			ИначеЕсли Факт["$ОбразованиеПолное"][0]["norm"].Получить("$sys_number") <> Неопределено Тогда
				ОписаниеОбразования.Окончание = Число(Факт["$ОбразованиеПолное"][0]["norm"].Получить("$sys_number"));
			КонецЕсли;
			Образование.Добавить(ОписаниеОбразования);
		ИначеЕсли Факт["type"] = "@Образование3" Тогда
			ОписаниеОбразования = ОписаниеОбразования();
			ОписаниеОбразования.УчебноеЗаведение = Факт["$Организация"][0]["asis"];
			Если ТипЗнч(Факт["$ФакультетИСпециальность"][0]["norm"].Получить("$sys_any")) = Тип("Строка") Тогда
				ОписаниеОбразования.Факультет = Факт["$ФакультетИСпециальность"][0]["norm"].Получить("$sys_any");
			Иначе
				ОписаниеОбразования.Факультет = Факт["$ФакультетИСпециальность"][0]["norm"].Получить("$sys_any")[0];
				ОписаниеОбразования.Специальность = Факт["$ФакультетИСпециальность"][0]["norm"].Получить("$sys_any")[1];
			КонецЕсли;
			Образование.Добавить(ОписаниеОбразования);
		Иначе
			ОписаниеОбразования = ОписаниеОбразования();
		КонецЕсли;
	КонецЦикла;
	
	Резюме.ТрудоваяДеятельность = ОпытРаботы;
	Резюме.Образование = Образование;
	
КонецПроцедуры

Процедура ПолучитьРезультатРаботыСервиса(Результат, Соединение, Идентификатор, Заголовки)
	
	ПараметрыОжидания = ПараметрыОжидания();
	ОжидатьРезультатРаботыСервиса = Истина;
	ТекущийПрогресс = 0;
	
	Пока ОжидатьРезультатРаботыСервиса Цикл
		Попытка
			Ответ = HTTPЗапросКСервисуПолучить(Соединение, АдресРезультатаРаботыСервиса(Идентификатор), Заголовки);
		Исключение
			Результат.ОшибкаСервиса = Истина;
			Результат.ОписаниеОшибки = ТекстОшибкиПолученияОтветаОтСервиса();
			Возврат;
		КонецПопытки;
		
		Если Ответ.КодСостояния = 200 Тогда
			ОжидатьРезультатРаботыСервиса = Ложь;
			Прервать;
		КонецЕсли;
		
		Если Ответ.КодСостояния <> 202 Тогда
			Результат.ОшибкаСервиса = Истина;
			Результат.ОписаниеОшибки = ТекстОшибкиПолученияОтветаОтСервиса();
			Возврат;
		КонецЕсли;
		
		УвеличитьТекущийПрогресс(ТекущийПрогресс);
		ДлительныеОперации.СообщитьПрогресс(ТекущийПрогресс, НСтр("ru = 'Получение результата работы сервиса'"));
		
		ОбщегоНазначенияБТС.Пауза(ПараметрыОжидания.ТекущееВремяОжидания);
		УвеличитьТекущееВремяОжидания(ПараметрыОжидания)
	КонецЦикла;
	
	Попытка
		ДанныеИзJSON = ДанныеИзJSON(Ответ);
		Результат.Данные = ДанныеИзJSON["result"];
	Исключение
		Результат.ОписаниеОшибки = ТекстОшибкиЧтенияДанныхОтСервиса();
		Возврат;
	КонецПопытки;
	
КонецПроцедуры

Процедура ЗаполнитьДанныеКандидатов(ЭлементЗапроса, ДанныеКандидата)
	
	Сущности = ЭлементЗапроса.Получить("ents");
	ПрочитатьСущности(Сущности, ДанныеКандидата);
	
	Факты = ЭлементЗапроса.Получить("facts");
	ПрочитатьФакты(Факты, ДанныеКандидата);
	
КонецПроцедуры

Процедура УвеличитьТекущееВремяОжидания(ПараметрыОжидания)
	
	ПараметрыОжидания.ТекущееВремяОжидания =
		ПараметрыОжидания.ТекущееВремяОжидания * ПараметрыОжидания.КоэффициентУвеличенияВремениОжидания;
	
КонецПроцедуры

Процедура УвеличитьТекущийПрогресс(ТекущийПрогресс)
	
	МаксимальныйПрогресс = 100;
	ПрогрессНаОбработкуРезультата = 4;
	
	ТекущийПрогресс = Окр(ТекущийПрогресс + ((МаксимальныйПрогресс - ТекущийПрогресс) / ПрогрессНаОбработкуРезультата - 1));
	
КонецПроцедуры

Функция ТикетДляСервисаСемантическогоАнализа()
	
	ДанныеЗаполнены = Ложь;
	Если ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей") Тогда
		МодульИнтернетПоддержкаПользователей = ОбщегоНазначения.ОбщийМодуль("ИнтернетПоддержкаПользователей");
		ДанныеЗаполнены = МодульИнтернетПоддержкаПользователей.ЗаполненыДанныеАутентификацииПользователяИнтернетПоддержки();
	КонецЕсли;
	
	Если Не ДанныеЗаполнены Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Если ОбщегоНазначения.ПодсистемаСуществует("ИнтернетПоддержкаПользователей.БазоваяФункциональностьБИП") Тогда
		УстановитьПривилегированныйРежим(Истина);
		СтруктураТикета = МодульИнтернетПоддержкаПользователей.ТикетАутентификацииНаПорталеПоддержки(Тариф());
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтруктураТикета.КодОшибки) Тогда
		ИмяСобытия = НСтр("ru = 'Разбор резюме.Сервис семантического анализа'", ОбщегоНазначения.КодОсновногоЯзыка());
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,,, СтруктураТикета.ИнформацияОбОшибке);
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат СтруктураТикета.Тикет;
	 
КонецФункции

