// См. ЦентрМониторингаПереопределяемый.ПриСбореПоказателейСтатистикиКонфигурации.
Процедура ПриСбореПоказателейСтатистикиКонфигурации() Экспорт
	
	ИмяКонфигурации = КонфигурацииЗарплатаКадры.КраткоеНазваниеПрограммыСлужебный();
	// АПК:1297-выкл Имя подсистемы для статистики, не локализуется
	ИмяПодсистемы = "Подбор персонала";
	// АПК:1297-вкл
	
	ВидСтатистики = СборСтатистики.ВидыСтатистики().Накопительная;
	
	Статистика = Новый Соответствие;
	Статистика.Вставить("Участники этапа работы с кандидатом", СтатистикаУчастниковЭтапов());
	Статистика.Вставить("Состояния вакансий", СтатистикаСостоянийВакансий());
	Статистика.Вставить("Публикация вакансий", СтатистикаПубликацийВакансий());
	Статистика.Вставить("Этапы работы с кандидатами(Профили должностей)", СтатистикаЭтаповРаботыСКандидатами());
	СборСтатистики.ЗаписатьСтатистикуПоОбъектам(ИмяКонфигурации, ИмяПодсистемы, Статистика, ВидСтатистики);
	
	НачалоПериода = СборСтатистики.НачалоПериодаСбораСтатистики();
	ВидСтатистики = СборСтатистики.ВидыСтатистики().Периодическая;
	
	Статистика = Новый Соответствие;
	Статистика.Вставить("Заявка на подбор персонала", СтатистикаЗаявокНаПодборПерсонала(НачалоПериода));
	Статистика.Вставить("Вакансии", СтатистикаВакансий(НачалоПериода));
	Статистика.Вставить("Кандидаты", СтатистикаКандидатов(НачалоПериода));
	Статистика.Вставить("Программа обучения(Профили должностей)", СтатистикаПрограммОбучения(НачалоПериода));
	Статистика.Вставить("Текущие этапы работы с кандидатами", СтатистикаТекущихЭтапов(НачалоПериода));
	Статистика.Вставить("Работа с кандидатами", СтатистикаРаботыСКандидатами(НачалоПериода));
	СборСтатистики.ЗаписатьСтатистикуПоОбъектам(ИмяКонфигурации, ИмяПодсистемы, Статистика, ВидСтатистики);
	
КонецПроцедуры

