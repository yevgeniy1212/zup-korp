Процедура ПолучитьДанныеСотрудникаЗУП(ДанныеСотрудника, Знач Период, Сотрудник)
	
	ДанныеУчета = КадровыйУчет.КадровыеДанныеСотрудников(Истина, Сотрудник, "Организация, ВидЗанятости, ИНН, ВидСобытия, ДолжностьПоШтатномуРасписанию, Должность, ДатаПриема, ДоляНеполногоРабочегоВремени, ТрудовойДоговорНомер, ТрудовойДоговорДата, СрочныйДоговор, СезонныйДоговор, ДатаОкончания", Период);
	
	Если ДанныеУчета.Количество() > 0 Тогда
		
		ДанныеУчетаСотрудника = ДанныеУчета[0];
		
		Если Период < ДанныеУчетаСотрудника.ДатаПриема Тогда // дата начала трудового договора указана неверно
			Период = ДанныеУчетаСотрудника.ДатаПриема;
			ДанныеУчета = КадровыйУчет.КадровыеДанныеСотрудников(Истина, Сотрудник, "Организация, ВидЗанятости, ИНН, ВидСобытия, ДолжностьПоШтатномуРасписанию, Должность, ДатаПриема, ДоляНеполногоРабочегоВремени, ТрудовойДоговорНомер, ТрудовойДоговорДата, СрочныйДоговор, СезонныйДоговор, ДатаОкончания", Период);
			ДанныеУчетаСотрудника = ДанныеУчета[0];
		КонецЕсли;
		
		ДанныеДолжностиЭТД = ЭТДСервер.ПолучитьИнформациюОКодеДолжности(Период, ДанныеУчетаСотрудника.Должность, ДанныеУчетаСотрудника.ДолжностьПоШтатномуРасписанию, ДанныеУчетаСотрудника.Организация);
		
		ДанныеПрофильНавыков = ЭТДСервер.ПолучитьПрофильНавыков(Период, ДанныеУчетаСотрудника.ДолжностьПоШтатномуРасписанию, Сотрудник, ДанныеУчетаСотрудника.Организация);
		
		ДанныеСотрудника.Вставить("РежимРабочегоВремени", "1");
		
		ДанныеСотрудника.Вставить("ДоляНеполногоРабочегоВремени", "1");
		
		ДанныеСотрудника.Вставить("СрокДействия", "1");
		
		Если ЗначениеЗаполнено(ДанныеУчетаСотрудника.ДолжностьПоШтатномуРасписанию) Тогда
			ДанныеСотрудника.Вставить("ДолжностьПоШтатномуРасписанию", ДанныеУчетаСотрудника.ДолжностьПоШтатномуРасписанию);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеУчетаСотрудника.Должность) Тогда
			ДанныеСотрудника.Вставить("Должность", ДанныеУчетаСотрудника.Должность);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеДолжностиЭТД.КодДолжности) Тогда
			ДанныеСотрудника.Вставить("КодДолжности", ДанныеДолжностиЭТД.КодДолжности);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеДолжностиЭТД.НаименованиеДолжности) Тогда
			ДанныеСотрудника.Вставить("НаименованиеДолжности", ДанныеДолжностиЭТД.НаименованиеДолжности);
		КонецЕсли;
		
		Если ДанныеПрофильНавыков.ОбщиеНавыки.Количество() > 0 Тогда
			ДанныеСотрудника.Вставить("ОбщиеНавыки", ДанныеПрофильНавыков.ОбщиеНавыки.Выгрузить());
		КонецЕсли;
		
		Если ДанныеПрофильНавыков.ПрофессиональныеНавыки.Количество() > 0 Тогда
			ДанныеСотрудника.Вставить("СпециальныеНавыки", ДанныеПрофильНавыков.ПрофессиональныеНавыки.Выгрузить());
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеУчетаСотрудника.ВидЗанятости) Тогда
			ДанныеСотрудника.Вставить("ПоСовместительству", ?(ДанныеУчетаСотрудника.ВидЗанятости = Перечисления.ВидыЗанятости.Совместительство 
													ИЛИ ДанныеУчетаСотрудника.ВидЗанятости = Перечисления.ВидыЗанятости.ВнутреннееСовместительство, Истина, Ложь));
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеУчетаСотрудника.СрочныйДоговор) И ЗначениеЗаполнено(ДанныеУчетаСотрудника.ДатаОкончания) Тогда
			ДанныеСотрудника.Вставить("ДатаОкончания", ДанныеУчетаСотрудника.ДатаОкончания);
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеУчетаСотрудника.ТрудовойДоговорНомер) Тогда
			ДанныеСотрудника.Вставить("НомерДоговора", ДанныеУчетаСотрудника.ТрудовойДоговорНомер);	
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеУчетаСотрудника.ДоляНеполногоРабочегоВремени) Тогда
			Если ДанныеУчетаСотрудника.ДоляНеполногоРабочегоВремени = 1 Тогда
				ДанныеСотрудника.Вставить("РежимРабочегоВремени", "1");	
			ИначеЕсли ДанныеУчетаСотрудника.ДоляНеполногоРабочегоВремени < 1 Тогда
				ДанныеСотрудника.Вставить("РежимРабочегоВремени", "3");
			КонецЕсли;
			ДанныеСотрудника.Вставить("ДоляНеполногоРабочегоВремени", ДанныеУчетаСотрудника.ДоляНеполногоРабочегоВремени);	
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеУчетаСотрудника.ИНН) Тогда
			ДанныеСотрудника.Вставить("ИИНРаботника", ДанныеУчетаСотрудника.ИНН)
		КонецЕсли;
		
		Если ЗначениеЗаполнено(ДанныеУчетаСотрудника.ВидСобытия) 
			И (ДанныеУчетаСотрудника.ВидСобытия = Перечисления.ВидыКадровыхСобытий.Прием
			ИЛИ ДанныеУчетаСотрудника.ВидСобытия = Перечисления.ВидыКадровыхСобытий.НачальныеДанные) Тогда
			Если ЗначениеЗаполнено(ДанныеУчетаСотрудника.ТрудовойДоговорДата) Тогда
				ДанныеСотрудника.Вставить("ДатаЗаключения", ДанныеУчетаСотрудника.ТрудовойДоговорДата);
			Иначе
				ДанныеСотрудника.Вставить("ДатаЗаключения", ДанныеУчетаСотрудника.ДатаПриема);
			КонецЕсли;
			ДанныеСотрудника.Вставить("ДатаНачала", ДанныеУчетаСотрудника.ДатаПриема)
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура СформироватьЗапросОсновныеДоговорыЗУП(Запрос)
	
	ДатаКадровыхДанных = ТекущаяДатаСеанса();
	ПараметрыПолучения = КадровыйУчет.ПараметрыПолученияСотрудниковОрганизацийПоСпискуФизическихЛиц();
	ПараметрыПолучения.Организация = Запрос.Параметры.Организация;
	ПараметрыПолучения.ОтбиратьПоГоловнойОрганизации = Ложь;
	ПараметрыПолучения.РаботникиПоДоговорамГПХ = Ложь;
	ПараметрыПолучения.НачалоПериода = ДатаКадровыхДанных;
	ПараметрыПолучения.ОкончаниеПериода = ДатаКадровыхДанных;
	ПараметрыПолучения.КадровыеДанные = "ДатаПриема";
	
	КадровыйУчет.СоздатьВТСотрудникиОрганизации(
		Запрос.МенеджерВременныхТаблиц,
		Истина,
		ПараметрыПолучения);
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ДанныеДокументов.Сотрудник КАК Сотрудник,
	|	ДанныеДокументов.ДатаПриема КАК Период
	|ПОМЕСТИТЬ ВТСотрудникиИПериод
	|ИЗ
	|	ВТСотрудникиОрганизации КАК ДанныеДокументов";
	Запрос.Выполнить();
	
	ОписательВТ = 
		КадровыйУчет.ОписательВременныхТаблицДляСоздатьВТКадровыеДанныеСотрудников(
			Запрос.МенеджерВременныхТаблиц,
			"ВТСотрудникиИПериод");
			
	КадровыйУчет.СоздатьВТКадровыеДанныеСотрудников(
		ОписательВТ, Истина, "РабочееМестоРегистратор,ТрудовойДоговорНомер,ТрудовойДоговорДата,ДатаПриема,ДатаОкончания,СрочныйДоговор,СезонныйДоговор,ВидЗанятости,ДоляНеполногоРабочегоВремени,Должность,ДолжностьПоШтатномуРасписанию");
		
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	СотрудникиОрганизации.Сотрудник КАК Сотрудник,
		|	СотрудникиОрганизации.Должность КАК Должность,
		|	СотрудникиОрганизации.ДолжностьПоШтатномуРасписанию КАК ДолжностьПоШтатномуРасписанию,
		|	МАКСИМУМ(СопоставлениеДолжностейЭТД.Период) КАК СопоставлениеДолжностейЭТДПериод
		|ПОМЕСТИТЬ ВТ_СопоставлениеДолжностейПериод
		|ИЗ
		|	ВТКадровыеДанныеСотрудников КАК СотрудникиОрганизации
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СопоставлениеДолжностейЭТД КАК СопоставлениеДолжностейЭТД
		|		ПО СотрудникиОрганизации.Должность = СопоставлениеДолжностейЭТД.ДолжностьОрганизации
		|			И СотрудникиОрганизации.ДолжностьПоШтатномуРасписанию = СопоставлениеДолжностейЭТД.ДолжностьПоШтатномуРасписанию
		|			И СотрудникиОрганизации.Период >= СопоставлениеДолжностейЭТД.Период
		|
		|СГРУППИРОВАТЬ ПО
		|	СотрудникиОрганизации.Сотрудник,
		|	СотрудникиОрганизации.Должность,
		|	СотрудникиОрганизации.ДолжностьПоШтатномуРасписанию
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	СотрудникиОрганизации.Сотрудник КАК Сотрудник,
		|	СотрудникиОрганизации.Должность КАК Должность,
		|	СотрудникиОрганизации.ДолжностьПоШтатномуРасписанию КАК ДолжностьПоШтатномуРасписанию,
		|	СотрудникиОрганизации.РабочееМестоРегистратор КАК ДокументОснование,
		|	ЕСТЬNULL(ЭТД.Ссылка, ЗНАЧЕНИЕ(Документ.ЭТД.ПустаяСсылка)) КАК ЭТДСсылка,
		|	ЕСТЬNULL(ЭТД.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыЭТД.ПустаяСсылка)) КАК Статус,
		|	ЕСТЬNULL(ЭТД.НомерДоговора, СотрудникиОрганизации.ТрудовойДоговорНомер) КАК НомерДоговора,
		|	ЕСТЬNULL(ЭТД.ДатаЗаключения, СотрудникиОрганизации.ТрудовойДоговорДата) КАК ДатаЗаключения,
		|	ЕСТЬNULL(ЭТД.ДатаЗаключения, СотрудникиОрганизации.ДатаПриема) КАК ДатаНачала,
		|	ЕСТЬNULL(ЭТД.МестоРаботы, """") КАК МестоРаботы,
		|	ЕСТЬNULL(ЭТД.КодРегиона, """") КАК КодРегиона,
		|	ЕСТЬNULL(ЭТД.СрокДействия, """") КАК СрокДействия,
		|	ЕСТЬNULL(ЭТД.КодДолжности, ЕСТЬNULL(СопоставлениеДолжностейЭТД.КодДолжностиЭТД, ЕСТЬNULL(СопоставлениеДолжностейЭТДАктуальное.КодДолжностиЭТД, """"))) КАК ЭТДКодДолжности,
		|	ЕСТЬNULL(ЭТД.НаименованиеДолжности, ЕСТЬNULL(СопоставлениеДолжностейЭТД.НаименованиеЭТД, ЕСТЬNULL(СопоставлениеДолжностейЭТДАктуальное.НаименованиеЭТД, """"))) КАК ЭТДДолжность,
		|	ЕСТЬNULL(ЭТД.РежимРабочегоВремени, ВЫБОР
		|			КОГДА СотрудникиОрганизации.ДоляНеполногоРабочегоВремени < 1
		|				ТОГДА ""3""
		|			ИНАЧЕ ""1""
		|		КОНЕЦ) КАК РежимРабочегоВремени,
		|	ВЫБОР
		|		КОГДА ЭТД.Статус ЕСТЬ NULL
		|			ТОГДА 0
		|		ИНАЧЕ 1
		|	КОНЕЦ КАК Порядок,
		|	ВЫБОР
		|		КОГДА СотрудникиОрганизации.ВидЗанятости ЕСТЬ NULL
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ВЫБОР
		|				КОГДА СотрудникиОрганизации.ВидЗанятости В (ЗНАЧЕНИЕ(Перечисление.ВидыЗанятости.Совместительство), ЗНАЧЕНИЕ(Перечисление.ВидыЗанятости.ВнутреннееСовместительство))
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ЛОЖЬ
		|			КОНЕЦ
		|	КОНЕЦ КАК ПоСовместительству,
		|	ЭТД.Ссылка КАК Ссылка,
		|	Сотрудники.Наименование
		|ИЗ
		|	ВТКадровыеДанныеСотрудников КАК СотрудникиОрганизации
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЭТД КАК ЭТД
		|		ПО СотрудникиОрганизации.Сотрудник = ЭТД.Сотрудник
		|			И (НЕ ЭТД.ПометкаУдаления)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СопоставлениеДолжностейЭТД.СрезПоследних(&Период, Организация = &Организация) КАК СопоставлениеДолжностейЭТДАктуальное
		|		ПО СотрудникиОрганизации.Должность = СопоставлениеДолжностейЭТДАктуальное.ДолжностьОрганизации
		|			И СотрудникиОрганизации.ДолжностьПоШтатномуРасписанию = СопоставлениеДолжностейЭТДАктуальное.ДолжностьПоШтатномуРасписанию
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СопоставлениеДолжностейПериод КАК СопоставлениеДолжностейПериод
		|		ПО СотрудникиОрганизации.Сотрудник = СопоставлениеДолжностейПериод.Сотрудник
		|			И СотрудникиОрганизации.Должность = СопоставлениеДолжностейПериод.Должность
		|			И СотрудникиОрганизации.ДолжностьПоШтатномуРасписанию = СопоставлениеДолжностейПериод.ДолжностьПоШтатномуРасписанию
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СопоставлениеДолжностейЭТД КАК СопоставлениеДолжностейЭТД
		|		ПО (СопоставлениеДолжностейПериод.Должность = СопоставлениеДолжностейЭТД.ДолжностьОрганизации)
		|			И (СопоставлениеДолжностейПериод.ДолжностьПоШтатномуРасписанию = СопоставлениеДолжностейЭТД.ДолжностьПоШтатномуРасписанию)
		|			И (СопоставлениеДолжностейПериод.СопоставлениеДолжностейЭТДПериод = СопоставлениеДолжностейЭТД.Период)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
		|		ПО СотрудникиОрганизации.Сотрудник = Сотрудники.Ссылка
		|ГДЕ
		|	(ЭТД.Ссылка ЕСТЬ NULL
		|			ИЛИ НЕ ЭТД.ЭтоДополнительноеСоглашение)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Сотрудники.Наименование";
	
КонецПроцедуры

Процедура СформироватьЗапросДопСоглашенияЗУП(Запрос)
	
	ДатаКадровыхДанных = ТекущаяДатаСеанса();
	ПараметрыПолучения = КадровыйУчет.ПараметрыПолученияСотрудниковОрганизацийПоСпискуФизическихЛиц();
	ПараметрыПолучения.Организация = Запрос.Параметры.Организация;
	ПараметрыПолучения.ОтбиратьПоГоловнойОрганизации = Ложь;
	ПараметрыПолучения.РаботникиПоДоговорамГПХ = Ложь;
	ПараметрыПолучения.НачалоПериода = ДатаКадровыхДанных;
	ПараметрыПолучения.ОкончаниеПериода = ДатаКадровыхДанных;
	ПараметрыПолучения.КадровыеДанные = "ДатаПриема";
	
	КадровыйУчет.СоздатьВТСотрудникиОрганизации(
		Запрос.МенеджерВременныхТаблиц,
		Истина,
		ПараметрыПолучения);
	
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ДанныеДокументов.Сотрудник КАК Сотрудник,
	|	ДанныеДокументов.ДатаПриема КАК Период,
	|	&Период КАК ПериодПо
	|ПОМЕСТИТЬ ВТСотрудникиИПериод
	|ИЗ
	|	ВТСотрудникиОрганизации КАК ДанныеДокументов";
	Запрос.Выполнить();
	
	ОписательВТ = 
		КадровыйУчет.ОписательВременныхТаблицДляСоздатьВТКадровыеДанныеСотрудников(
			Запрос.МенеджерВременныхТаблиц,
			"ВТСотрудникиИПериод");
			
	КадровыйУчет.СоздатьВТКадровыеДанныеСотрудников(
		ОписательВТ, Истина, "РабочееМестоРегистратор,ТрудовойДоговорНомер,ТрудовойДоговорДата,ДатаПриема,ДатаОкончания,СрочныйДоговор,СезонныйДоговор,ВидЗанятости,ДоляНеполногоРабочегоВремени,Должность,ДолжностьПоШтатномуРасписанию");
	
	ОписаниеФильтра = ЗарплатаКадрыОбщиеНаборыДанных.ОписаниеФильтраДляСоздатьВТИмяРегистра(
		"ВТСотрудникиИПериод", 
		"Сотрудник");
	
	ОписаниеФильтра.СоответствиеИзмеренийРегистраИзмерениямФильтра.Вставить("ДатаНачала", "Период");
	ОписаниеФильтра.СоответствиеИзмеренийРегистраИзмерениямФильтра.Вставить("ДатаОкончания", "ПериодПо");
	
	ЗарплатаКадрыПериодическиеРегистры.СоздатьВТИмяРегистраПериоды(
		"КадроваяИсторияСотрудников",
		Запрос.МенеджерВременныхТаблиц,
		Истина,
		ОписаниеФильтра,
		,
		"ВТИнтервалыКадроваяИсторияСотрудников");
	
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	КадроваяИсторияСотрудниковЗаписи.Сотрудник КАК Сотрудник,
		|	КадроваяИсторияСотрудниковЗаписи.Должность КАК Должность,
		|	КадроваяИсторияСотрудниковЗаписи.ДолжностьПоШтатномуРасписанию КАК ДолжностьПоШтатномуРасписанию,
		|	КадроваяИсторияСотрудниковЗаписи.Регистратор КАК ДокументОснование,
		|	КадроваяИсторияСотрудниковЗаписи.Период КАК ДатаИзменения,
		|	МАКСИМУМ(СопоставлениеДолжностейЭТД.Период) КАК СопоставлениеДолжностейЭТДПериод
		|ПОМЕСТИТЬ ВТ_ИзмененныеДолжности
		|ИЗ
		|	ВТИнтервалыКадроваяИсторияСотрудников КАК КадроваяИсторияСотрудниковЗаписи
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИнтервалыКадроваяИсторияСотрудников КАК КадроваяИсторияСотрудниковПредыдущиеЗаписи
		|		ПО КадроваяИсторияСотрудниковЗаписи.Сотрудник = КадроваяИсторияСотрудниковПредыдущиеЗаписи.Сотрудник
		|			И (КадроваяИсторияСотрудниковЗаписи.НачалоПериода = ДОБАВИТЬКДАТЕ(НАЧАЛОПЕРИОДА(КадроваяИсторияСотрудниковПредыдущиеЗаписи.КонецПериода, ДЕНЬ), ДЕНЬ, 1))
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СопоставлениеДолжностейЭТД КАК СопоставлениеДолжностейЭТД
		|		ПО КадроваяИсторияСотрудниковЗаписи.Должность = СопоставлениеДолжностейЭТД.ДолжностьОрганизации
		|			И КадроваяИсторияСотрудниковЗаписи.ДолжностьПоШтатномуРасписанию = СопоставлениеДолжностейЭТД.ДолжностьПоШтатномуРасписанию
		|			И КадроваяИсторияСотрудниковЗаписи.Период >= СопоставлениеДолжностейЭТД.Период
		|ГДЕ
		|	НЕ КадроваяИсторияСотрудниковПредыдущиеЗаписи.Период ЕСТЬ NULL
		|	И КадроваяИсторияСотрудниковЗаписи.Должность <> КадроваяИсторияСотрудниковПредыдущиеЗаписи.Должность
		|
		|СГРУППИРОВАТЬ ПО
		|	КадроваяИсторияСотрудниковЗаписи.Сотрудник,
		|	КадроваяИсторияСотрудниковЗаписи.Должность,
		|	КадроваяИсторияСотрудниковЗаписи.ДолжностьПоШтатномуРасписанию,
		|	КадроваяИсторияСотрудниковЗаписи.Регистратор,
		|	КадроваяИсторияСотрудниковЗаписи.Период
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	ВТ_ИзмененныеДолжности.Сотрудник КАК Сотрудник,
		|	ВТ_ИзмененныеДолжности.Должность КАК Должность,
		|	ВТ_ИзмененныеДолжности.ДолжностьПоШтатномуРасписанию КАК ДолжностьПоШтатномуРасписанию,
		|	ВТ_ИзмененныеДолжности.ДокументОснование КАК ДокументОснование,
		|	ЕСТЬNULL(ЭТДДопСоглашение.Ссылка, ЗНАЧЕНИЕ(Документ.ЭТД.ПустаяСсылка)) КАК ДопСоглашениеСсылка,
		|	ЕСТЬNULL(ЭТДОсновной.Ссылка, ЗНАЧЕНИЕ(Документ.ЭТД.ПустаяСсылка)) КАК ОсновнойДоговорСсылка,
		|	ВЫБОР
		|		КОГДА ЭТДДопСоглашение.Ссылка ЕСТЬ NULL
		|			ТОГДА ЕСТЬNULL(ЭТДОсновной.МестоРаботы, """")
		|		ИНАЧЕ ЭТДДопСоглашение.МестоРаботы
		|	КОНЕЦ КАК МестоРаботы,
		|	ВЫБОР
		|		КОГДА ЭТДДопСоглашение.Ссылка ЕСТЬ NULL
		|			ТОГДА ЕСТЬNULL(ЭТДОсновной.КодРегиона, """")
		|		ИНАЧЕ ЭТДДопСоглашение.КодРегиона
		|	КОНЕЦ КАК КодРегиона,
		|	ВЫБОР
		|		КОГДА ЭТДДопСоглашение.Ссылка ЕСТЬ NULL
		|			ТОГДА ЕСТЬNULL(ЭТДОсновной.СрокДействия, """")
		|		ИНАЧЕ ЭТДДопСоглашение.СрокДействия
		|	КОНЕЦ КАК СрокДействия,
		|	ЕСТЬNULL(ЭТДДопСоглашение.НомерДоговора, ЕСТЬNULL(ЭТДОсновной.НомерДоговора + ""/"", """")) КАК НомерДоговора,
		|	ЕСТЬNULL(ЭТДДопСоглашение.ДатаЗаключения, ВТ_ИзмененныеДолжности.ДатаИзменения) КАК ДатаНачала,
		|	ЕСТЬNULL(ЭТДДопСоглашение.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыЭТД.ПустаяСсылка)) КАК ДопСоглашениеСтатус,
		|	ЕСТЬNULL(ЭТДОсновной.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыЭТД.ПустаяСсылка)) КАК ОсновнойДоговорСтатус,
		|	ВЫБОР
		|		КОГДА ЭТДДопСоглашение.Ссылка ЕСТЬ NULL
		|			ТОГДА 0
		|		ИНАЧЕ 1
		|	КОНЕЦ КАК Порядок,
		|	ЕСТЬNULL(ЭТДДопСоглашение.КодДолжности, ЕСТЬNULL(СопоставлениеДолжностейЭТД.КодДолжностиЭТД, ЕСТЬNULL(СопоставлениеДолжностейЭТДАктуальное.КодДолжностиЭТД, """"))) КАК ЭТДКодДолжности,
		|	ЕСТЬNULL(ЭТДДопСоглашение.НаименованиеДолжности, ЕСТЬNULL(СопоставлениеДолжностейЭТД.НаименованиеЭТД, ЕСТЬNULL(СопоставлениеДолжностейЭТДАктуальное.НаименованиеЭТД, """"))) КАК ЭТДДолжность,
		|	ЕСТЬNULL(ЭТДОсновной.КодТяжелыхУсловийТруда, """") КАК КодТяжелыхУсловийТруда,
		|	Сотрудники.Наименование КАК Наименование
		|ИЗ
		|	ВТ_ИзмененныеДолжности КАК ВТ_ИзмененныеДолжности
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЭТД КАК ЭТДДопСоглашение
		|		ПО ВТ_ИзмененныеДолжности.Сотрудник = ЭТДДопСоглашение.Сотрудник
		|			И (НАЧАЛОПЕРИОДА(ВТ_ИзмененныеДолжности.ДатаИзменения, ДЕНЬ) = ЭТДДопСоглашение.ДатаЗаключения)
		|			И (ЭТДДопСоглашение.ЭтоДополнительноеСоглашение)
		|			И (НЕ ЭТДДопСоглашение.ПометкаУдаления)
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СопоставлениеДолжностейЭТД.СрезПоследних(&Период, Организация = &Организация) КАК СопоставлениеДолжностейЭТДАктуальное
		|		ПО ВТ_ИзмененныеДолжности.Должность = СопоставлениеДолжностейЭТДАктуальное.ДолжностьОрганизации
		|			И ВТ_ИзмененныеДолжности.ДолжностьПоШтатномуРасписанию = СопоставлениеДолжностейЭТДАктуальное.ДолжностьПоШтатномуРасписанию
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СопоставлениеДолжностейЭТД КАК СопоставлениеДолжностейЭТД
		|		ПО ВТ_ИзмененныеДолжности.Должность = СопоставлениеДолжностейЭТД.ДолжностьОрганизации
		|			И ВТ_ИзмененныеДолжности.ДолжностьПоШтатномуРасписанию = СопоставлениеДолжностейЭТД.ДолжностьПоШтатномуРасписанию
		|			И ВТ_ИзмененныеДолжности.СопоставлениеДолжностейЭТДПериод = СопоставлениеДолжностейЭТД.Период
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТКадровыеДанныеСотрудников КАК СотрудникиОрганизации
		|		ПО ВТ_ИзмененныеДолжности.Сотрудник = СотрудникиОрганизации.Сотрудник
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЭТД КАК ЭТДОсновной
		|		ПО (СотрудникиОрганизации.РабочееМестоРегистратор = ЭТДОсновной.ДокументОснование)
		|			И (НЕ ЭТДОсновной.ЭтоДополнительноеСоглашение)
		|			И (НЕ ЭТДОсновной.ПометкаУдаления)
		|			И (СотрудникиОрганизации.Сотрудник = ЭТДОсновной.Сотрудник)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
		|		ПО ВТ_ИзмененныеДолжности.Сотрудник = Сотрудники.Ссылка
		|ГДЕ
		|	НЕ ЭТДОсновной.Ссылка ЕСТЬ NULL
		|	И ЭТДОсновной.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЭТД.Зарегистрирован)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Наименование";
	
КонецПроцедуры

Процедура СформироватьЗапросСопоставлениеДолжностейЗУП(Запрос)
	
	Если ИспользоватьШтатноеРасписание() Тогда
		
		ПараметрыПостроения = УправлениеШтатнымРасписанием.ПараметрыПостроенияВТШтатноеРасписание(Запрос.Параметры.ПериодАктуальности, Запрос.Параметры.Организация);
		
		УправлениеШтатнымРасписанием.СоздатьВТШтатноеРасписание(Запрос.МенеджерВременныхТаблиц, Истина, ПараметрыПостроения, , "ВТДанныеШтатногоРасписания");
		
		Запрос.Текст =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	ДанныеШтатногоРасписания.Должность КАК Должность,
			|	ДанныеШтатногоРасписания.ПозицияШтатногоРасписания КАК ДолжностьПоШтатномуРасписанию
			|ПОМЕСТИТЬ ВТ_Должности
			|ИЗ
			|	ВТДанныеШтатногоРасписания КАК ДанныеШтатногоРасписания
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	МИНИМУМ(ЕСТЬNULL(СопоставлениеДолжностейЭТД.Период, ЕСТЬNULL(КадроваяИсторияСотрудниковСрезПервых.Период, ДАТАВРЕМЯ(1900, 1, 1)))) КАК Период,
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.Организация, &Организация) КАК Организация,
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.ДолжностьОрганизации, ВТ_Должности.Должность) КАК ДолжностьОрганизации,
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.ДолжностьПоШтатномуРасписанию, ВТ_Должности.ДолжностьПоШтатномуРасписанию) КАК ДолжностьПоШтатномуРасписанию,
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.КодДолжностиЭТД, """") КАК КодДолжностиЭТД,
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.НаименованиеЭТД, """") КАК НаименованиеЭТД
			|ИЗ
			|	ВТ_Должности КАК ВТ_Должности
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СопоставлениеДолжностейЭТД.СрезПоследних(&ПериодАктуальности, Организация = &Организация) КАК СопоставлениеДолжностейЭТД
			|		ПО СопоставлениеДолжностейЭТД.ДолжностьПоШтатномуРасписанию = ВТ_Должности.ДолжностьПоШтатномуРасписанию
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КадроваяИсторияСотрудников.СрезПервых(, ) КАК КадроваяИсторияСотрудниковСрезПервых
			|		ПО ВТ_Должности.ДолжностьПоШтатномуРасписанию = КадроваяИсторияСотрудниковСрезПервых.ДолжностьПоШтатномуРасписанию
			|
			|СГРУППИРОВАТЬ ПО
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.Организация, &Организация),
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.ДолжностьОрганизации, ВТ_Должности.Должность),
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.ДолжностьПоШтатномуРасписанию, ВТ_Должности.ДолжностьПоШтатномуРасписанию),
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.КодДолжностиЭТД, """"),
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.НаименованиеЭТД, """")";
		
	Иначе
		
		ДатаКадровыхДанных = ТекущаяДатаСеанса();
		ПараметрыПолучения = КадровыйУчет.ПараметрыПолученияСотрудниковОрганизацийПоСпискуФизическихЛиц();
		ПараметрыПолучения.Организация = Запрос.Параметры.Организация;
		ПараметрыПолучения.ОтбиратьПоГоловнойОрганизации = Ложь;
		ПараметрыПолучения.РаботникиПоДоговорамГПХ = Ложь;
		ПараметрыПолучения.НачалоПериода = ДатаКадровыхДанных;
		ПараметрыПолучения.ОкончаниеПериода = ДатаКадровыхДанных;
		
		КадровыйУчет.СоздатьВТСотрудникиОрганизации(
			Запрос.МенеджерВременныхТаблиц,
			Истина,
			ПараметрыПолучения);
		
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	ДанныеДокументов.Сотрудник КАК Сотрудник,
		|	&ПериодАктуальности КАК Период
		|ПОМЕСТИТЬ ВТСотрудникиИПериод
		|ИЗ
		|	ВТСотрудникиОрганизации КАК ДанныеДокументов";
		Запрос.Выполнить();
		
		ОписательВТ = 
			КадровыйУчет.ОписательВременныхТаблицДляСоздатьВТКадровыеДанныеСотрудников(
				Запрос.МенеджерВременныхТаблиц,
				"ВТСотрудникиИПериод");
		КадровыйУчет.СоздатьВТКадровыеДанныеСотрудников(
			ОписательВТ, Истина, "Должность, ДолжностьПоШтатномуРасписанию");
			
		Запрос.Текст =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	КадроваяИсторияСотрудников.Должность КАК Должность,
			|	КадроваяИсторияСотрудников.Организация КАК Организация
			|ПОМЕСТИТЬ ВТ_Должности
			|ИЗ
			|	ВТКадровыеДанныеСотрудников КАК КадроваяИсторияСотрудников
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ
			|	МИНИМУМ(ЕСТЬNULL(СопоставлениеДолжностейЭТД.Период, ЕСТЬNULL(КадроваяИсторияСотрудниковСрезПервых.Период, ДАТАВРЕМЯ(1900, 1, 1)))) КАК Период,
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.Организация, &Организация) КАК Организация,
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.ДолжностьОрганизации, ВТ_Должности.Должность) КАК ДолжностьОрганизации,
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.ДолжностьПоШтатномуРасписанию, ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка)) КАК ДолжностьПоШтатномуРасписанию,
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.КодДолжностиЭТД, """") КАК КодДолжностиЭТД,
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.НаименованиеЭТД, """") КАК НаименованиеЭТД
			|ИЗ
			|	ВТ_Должности КАК ВТ_Должности
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СопоставлениеДолжностейЭТД.СрезПоследних(&ПериодАктуальности, Организация = &Организация) КАК СопоставлениеДолжностейЭТД
			|		ПО СопоставлениеДолжностейЭТД.ДолжностьОрганизации = ВТ_Должности.Должность
			|			И СопоставлениеДолжностейЭТД.Организация = ВТ_Должности.Организация
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КадроваяИсторияСотрудников.СрезПервых() КАК КадроваяИсторияСотрудниковСрезПервых
			|		ПО ВТ_Должности.Должность = КадроваяИсторияСотрудниковСрезПервых.Должность
			|		И ВТ_Должности.Организация = КадроваяИсторияСотрудниковСрезПервых.Организация
			|
			|СГРУППИРОВАТЬ ПО
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.Организация, &Организация),
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.ДолжностьОрганизации, ВТ_Должности.Должность),
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.ДолжностьПоШтатномуРасписанию, ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка)),
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.КодДолжностиЭТД, """"),
			|	ЕСТЬNULL(СопоставлениеДолжностейЭТД.НаименованиеЭТД, """")";
		
	КонецЕсли;
	
КонецПроцедуры

