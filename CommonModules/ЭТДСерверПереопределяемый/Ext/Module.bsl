// Возвращает организацию по умолчанию
// 
// Возвращаемое значение:
//  СправочникСсылка.Организации - Организация по умолчанию
//
Функция ОрганизацияПоУмолчанию() Экспорт
	
	Результат = Неопределено;
	
	ОрганизацияПоУмолчанию = Справочники.Организации.ПустаяСсылка();
	СтруктураЗначений = Новый Структура("Организация");
	ЗарплатаКадры.ПолучитьЗначенияПоУмолчанию(СтруктураЗначений);
	СтруктураЗначений.Свойство("Организация", ОрганизацияПоУмолчанию);
	Результат = СтруктураЗначений.Организация;
	
	Возврат Результат;
	
КонецФункции

