	Возврат Результат;
	
КонецФункции

Функция ПолучитьСотрудникаПоИИНЗУП(ИИН, Организация, ДатаЗаключения)
	
	Сотрудник = Справочники.Сотрудники.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	ПараметрыПолучения = КадровыйУчет.ПараметрыПолученияСотрудниковОрганизацийПоСпискуФизическихЛиц();
	ПараметрыПолучения.Организация = Организация;
	ПараметрыПолучения.ОтбиратьПоГоловнойОрганизации = Ложь;
	ПараметрыПолучения.РаботникиПоДоговорамГПХ = Ложь;
	ПараметрыПолучения.НачалоПериода = ДатаЗаключения;
	ПараметрыПолучения.ОкончаниеПериода = ДатаЗаключения;
	
	КадровыйУчет.СоздатьВТСотрудникиОрганизации(
		Запрос.МенеджерВременныхТаблиц,
		Истина,
		ПараметрыПолучения);
	
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ЕСТЬNULL(СотрудникиОрганизации.Сотрудник, ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)) КАК Сотрудник
		|ИЗ
		|	Справочник.ФизическиеЛица КАК ФизическиеЛица
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСотрудникиОрганизации КАК СотрудникиОрганизации
		|		ПО ФизическиеЛица.Ссылка = СотрудникиОрганизации.ФизическоеЛицо
		|ГДЕ
		|	ФизическиеЛица.ИНН = &ИИН
		|
		|УПОРЯДОЧИТЬ ПО
		|	Сотрудник УБЫВ";
	
	Запрос.УстановитьПараметр("ИИН", ИИН);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Сотрудник = ВыборкаДетальныеЗаписи.Сотрудник;
	КонецЦикла;
	
	Возврат Сотрудник;
	
КонецФункции

Функция ПолучитьИИНПоСотрудникуЗУП(Сотрудник)
	
	ИИН = "";
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЕСТЬNULL(ФизическиеЛица.ИНН, """") КАК ИИН
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизическиеЛица
		|		ПО Сотрудники.ФизическоеЛицо = ФизическиеЛица.Ссылка
		|ГДЕ
		|	Сотрудники.Ссылка = &Сотрудник";
	
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ИИН = ВыборкаДетальныеЗаписи.ИИН;
	КонецЦикла;
	
	Возврат ИИН;
	
КонецФункции

Процедура ПолучитьДанныеДляАвтозаполненияЗУП(Организация, Период, СтруктураДанныхДляАвтозаполнения)
	
	СписокПоказателей = Новый Массив;
	СписокПоказателей.Добавить("ОКАТО");
	СписокПоказателей.Добавить("ПолныйАдрЮР");
	СписокПоказателей.Добавить("ЭтоЮридическоеЛицо");
	Если Организация = Справочники.Организации.ПустаяСсылка() Тогда
		СведенияОбОрганизации = Новый Структура("ПолныйАдрЮР,ОКАТО,ЭтоЮридическоеЛицо", "", "", "");
	Иначе
		СведенияОбОрганизации = ЗарплатаКадрыБазовый.ПолучитьСведенияОбОрганизации(Организация, Период, СписокПоказателей);
	КонецЕсли;
	
	МестоРаботы = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(Организация, Справочники.ВидыКонтактнойИнформации.ФактАдресОрганизации, Период);
	Если НЕ ЗначениеЗаполнено(МестоРаботы) Тогда
		МестоРаботы = СведенияОбОрганизации.ПолныйАдрЮР;
	КонецЕсли;
	КодРегиона = "";
	Если СведенияОбОрганизации.ОКАТО <> ",,,,,,,,," Тогда
		КодРегиона = Лев(СведенияОбОрганизации.ОКАТО, 9);
	КонецЕсли;
	
	ТипРаботодателя = "";
	Если СведенияОбОрганизации.ЭтоЮридическоеЛицо = Истина Тогда
		ТипРаботодателя = "1";
	ИначеЕсли СведенияОбОрганизации.ЭтоЮридическоеЛицо = Ложь Тогда
		ТипРаботодателя = "2";
	КонецЕсли;
	
	СтруктураДанныхДляАвтозаполнения.МестоРаботы = МестоРаботы;
	СтруктураДанныхДляАвтозаполнения.КодРегиона = КодРегиона;
	СтруктураДанныхДляАвтозаполнения.КодРегионаРабочегоМеста = КодРегиона;
	СтруктураДанныхДляАвтозаполнения.ТипРаботодателя = ТипРаботодателя;
	
КонецПроцедуры

Процедура ЗаполнитьНаборыЗначенийДоступаЗУП(ДокументОбъект, Таблица)
	
	ЗарплатаКадры.ЗаполнитьНаборыПоОрганизацииИСотрудникам(ДокументОбъект, Таблица, "Организация", "Сотрудник");
	
КонецПроцедуры

Функция ИдентификаторЭТДЗУП(Документ)
	
	Результат = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Документ, "Идентификатор");
	
	Возврат Результат;
	
КонецФункции

Функция СотрудникПодходитДляПрофессиональнойВыплатыЗУП(Сотрудник, ПериодДанных)
	
	КадровыеДанные = КадровыйУчет.КадровыеДанныеСотрудника(Истина, Сотрудник, "Возраст,СведенияОПенсионномОбеспеченииПенсионерПоВозрасту", ПериодДанных);
	Если КадровыеДанные <> Неопределено И КадровыеДанные.Возраст <> NULL И КадровыеДанные.Возраст >= 55
		И КадровыеДанные.СведенияОПенсионномОбеспеченииПенсионерПоВозрасту <> Истина Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

Функция ПолучитьПризнакГражданстваРКЗУП(Сотрудник, ПериодДанных)
	
	Страна = "";
	КадровыеДанные = КадровыйУчет.КадровыеДанныеСотрудника(Истина, Сотрудник, "Страна", ПериодДанных);
	Если КадровыеДанные <> Неопределено Тогда
		Страна = КадровыеДанные.Страна;
	КонецЕсли;
	
	Если Страна = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.СтраныМира.Казахстан") Тогда
		Возврат Истина;
	ИначеЕсли ТипЗнч(Страна) = Тип("СправочникСсылка.СтраныМира") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Функция ПолучитьПараметрыСотрудникаДляСоциальногоОтпускаЗУП(Сотрудник, Знач ДатаПолученияДанных)
	
	Если ДатаПолученияДанных = Неопределено Тогда
		ДатаПолученияДанных = ТекущаяДатаСеанса();
	КонецЕсли;
	
	КадровыеДанныеСотрудника = КадровыйУчет.КадровыеДанныеСотрудника(Истина, Сотрудник, "ФИО,Подразделение", ДатаПолученияДанных);
	ПараметрыСотрудника = Новый Структура("ФИОРаботника,ПодразделениеНаРусскомЯзыке,ПодразделениеНаКазахскомЯзыке",
											КадровыеДанныеСотрудника.ФИО,
											ОбщегоНазначения.ЗначениеРеквизитаОбъекта(КадровыеДанныеСотрудника.Подразделение, "Наименование"),
											"");
	
	Возврат ПараметрыСотрудника;
	
КонецФункции

Функция ПолучитьКоличествоВыходныхДнейЗаПериодЗУП(Сотрудник, НачалоПериода, КонецПериода)
	
	КадровыеДанные = КадровыйУчет.КадровыеДанныеСотрудника(Истина, Сотрудник, "ГрафикРаботы", НачалоПериода);
	ВидУчетаВремени = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыИспользованияРабочегоВремени.ВыходныеДни");
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("График", КадровыеДанные.ГрафикРаботы);
	Запрос.УстановитьПараметр("ВидУчетаВремени", ВидУчетаВремени);
	Запрос.УстановитьПараметр("ДатаНачала", НачалоПериода);
	Запрос.УстановитьПараметр("ДатаОкончания", КонецПериода);
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	КОЛИЧЕСТВО(ДанныеГрафикаРаботы.Дата) КАК Дней
		|ИЗ
		|	РегистрСведений.ГрафикиРаботыПоВидамВремени КАК ДанныеГрафикаРаботы
		|ГДЕ
		|	ДанныеГрафикаРаботы.ГрафикРаботы = &График
		|	И ДанныеГрафикаРаботы.ВидУчетаВремени = &ВидУчетаВремени
		|	И ДанныеГрафикаРаботы.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания";
	
	Результат = Запрос.Выполнить().Выгрузить();
	Возврат Результат.ВыгрузитьКолонку("Дней")[0];
	
КонецФункции

#КонецОбласти
