Процедура ЗаполнитьИсточникиДанныхДляПроверкиЗапретаИзменения(ИсточникиДанных) Экспорт
	
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.СопоставлениеДолжностейЭТД",			"Период",	"КадровыйУчет", "Организация");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.СопоставлениеПричинРасторженияЭТД",	"Период",	"КадровыйУчет", "Организация");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.СопоставлениеПрофилейНавыковЭТД",		"Период",	"КадровыйУчет", "Организация");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "Документ.ЭТД",										"Дата",		"КадровыйУчет", "Организация");
	
КонецПроцедуры

Процедура ПриЗаполненииВидовОграниченийПравОбъектовМетаданных(Описание) Экспорт
	
	Описание = Описание + "
	|РегистрСведений.СопоставлениеДолжностейЭТД.Чтение.Организации
	|РегистрСведений.СопоставлениеДолжностейЭТД.Изменение.Организации
	|РегистрСведений.СопоставлениеПричинРасторженияЭТД.Чтение.Организации
	|РегистрСведений.СопоставлениеПричинРасторженияЭТД.Изменение.Организации
	|РегистрСведений.СопоставлениеПрофилейНавыковЭТД.Чтение.Организации
	|РегистрСведений.СопоставлениеПрофилейНавыковЭТД.Изменение.Организации
	|РегистрСведений.СопоставлениеПрофилейНавыковЭТД.Чтение.ГруппыФизическихЛиц
	|РегистрСведений.СопоставлениеПрофилейНавыковЭТД.Изменение.ГруппыФизическихЛиц
	|Документ.ЭТД.Чтение.Организации
	|Документ.ЭТД.Чтение.ГруппыФизическихЛиц";
	
КонецПроцедуры

Процедура ПриЗаполненииСписковСОграничениемДоступа(Списки) Экспорт
	
	Списки.Вставить(Метаданные.РегистрыСведений.СопоставлениеДолжностейЭТД, Истина);
	Списки.Вставить(Метаданные.РегистрыСведений.СопоставлениеПричинРасторженияЭТД, Истина);
	Списки.Вставить(Метаданные.РегистрыСведений.СопоставлениеПрофилейНавыковЭТД, Истина);
	Списки.Вставить(Метаданные.Документы.ЭТД, Истина);
	
КонецПроцедуры

Процедура ПриЗаполненииОграниченияДоступаРегистраСведений(Ограничение, НаименованиеОбъекта) Экспорт
	
	ТекстОграничения = "";
	
	Если НаименованиеОбъекта = "СопоставлениеДолжностейЭТД" Тогда
		ТекстОграничения =
		"РазрешитьЧтениеИзменение
		|ГДЕ
		|	ЗначениеРазрешено(Организация)";
	ИначеЕсли НаименованиеОбъекта = "СопоставлениеПричинРасторженияЭТД" Тогда
		ТекстОграничения =
		"РазрешитьЧтениеИзменение
		|ГДЕ
		|	ЗначениеРазрешено(Организация)
		|	ИЛИ Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)";
	ИначеЕсли НаименованиеОбъекта = "СопоставлениеПрофилейНавыковЭТД" Тогда
		ТекстОграничения =
		"РазрешитьЧтениеИзменение
		|ГДЕ
		|	ЗначениеРазрешено(Организация)
		|	И (ТИПЗНАЧЕНИЯ(ВладелецПрофиля) <> ТИП(Справочник.Сотрудники) ИЛИ ЗначениеРазрешено(ВладелецПрофиля))";
	КонецЕсли;
	
	Ограничение.Текст = ТекстОграничения;
	
КонецПроцедуры

