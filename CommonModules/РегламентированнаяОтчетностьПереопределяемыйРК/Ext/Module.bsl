#Область ПрограммныйИнтерфейс

#Область ПроцедурыИФункцииМеханизмаАтозаполнения

// Процедура заполняет переданную в виде контейнера структуру данных отчета.
//
// Пример:
//	Если ИДОтчета = "РегламентированныйОтчет210Форма" Тогда
//		Если ИДРедакцииОтчета = "ФормаОтчета2102016Кв1" Тогда
//			ЗаполнитьФорма2102016Кв1(ПараметрыОтчета, Контейнер);
//		КонецЕсли;
//	КонецЕсли;
//
Процедура ЗаполнитьОтчетРК(ИДОтчета, ИДРедакцииОтчета, ПараметрыОтчета, Контейнер) Экспорт
	
	РегламентированнаяОтчетностьЗарплатаКадры.ЗаполнитьОтчетЗарплатаКадры(ИДОтчета, ИДРедакцииОтчета, ПараметрыОтчета, Контейнер);
	Если ПолучитьФункциональнуюОпцию("ИспользоватьВоинскийУчет") Тогда
		РегламентированнаяОтчетностьВоинскийУчетВызовСервера.ЗаполнитьОтчетВоинскийУчет(ИДОтчета, ИДРедакцииОтчета, ПараметрыОтчета, Контейнер);
	КонецЕсли;
		
КонецПроцедуры

Функция ПолучитьСписокРегламентированныхОтчетовРК(СписокРегламентированныхОтчетов) Экспорт
	
	//Налоговая отчетность
	СписокРегламентированныхОтчетов.Добавить("РегламентированныйОтчет200Форма");
	СписокРегламентированныхОтчетов.Добавить("РегламентированныйОтчет210Форма");
	//Статистическая отчетность
	СписокРегламентированныхОтчетов.Добавить("РегламентированныйОтчетСтатистика1ТКвартальная");
	СписокРегламентированныхОтчетов.Добавить("РегламентированныйОтчетСтатистика1ТЗП");
	СписокРегламентированныхОтчетов.Добавить("РегламентированныйОтчетСтатистика2ТПРОФ");
	СписокРегламентированныхОтчетов.Добавить("РегламентированныйОтчетСтатистика1ТГодовая");
    СписокРегламентированныхОтчетов.Добавить("РегламентированныйОтчетСтатистика2ТОплатаТруда");
    
	Если ПолучитьФункциональнуюОпцию("ИспользоватьВоинскийУчет") Тогда
		
		СписокРегламентированныхОтчетов.Добавить("РегламентированныйОтчетВУСписокПризывников");
		СписокРегламентированныхОтчетов.Добавить("РегламентированныйОтчетВУСписокПринятыхУволенных");
		СписокРегламентированныхОтчетов.Добавить("РегламентированныйОтчетВУСведенияОЧисленностиПризывников");
		
	КонецЕсли; 
	
	// Свернем список отчетов
	ТаблицаОтчетов = Новый ТаблицаЗначений;
	ТаблицаОтчетов.Колонки.Добавить("Отчет", Новый ОписаниеТипов("Строка"));
	
	Для Каждого ТекОтчет Из СписокРегламентированныхОтчетов Цикл
		ТаблицаОтчетов.Добавить().Отчет = ТекОтчет.Значение;
	КонецЦикла;
	
	ТаблицаОтчетов.Свернуть("Отчет", "");
	
	СписокРегламентированныхОтчетов.ЗагрузитьЗначения(ТаблицаОтчетов.ВыгрузитьКолонку("Отчет"));
	
	Возврат СписокРегламентированныхОтчетов;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СформироватьСписокСтруктурныхЕдиниц(РежимВыбораСтруктурныхЕдиниц = "ПоГоловнымОрганизациям", Налогоплательщик = Неопределено, НалоговыйКомитет = Неопределено, Дата = Неопределено) Экспорт
	
	Если РежимВыбораСтруктурныхЕдиниц = "ПоГоловнымОрганизациям" Тогда
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Организация",  Налогоплательщик);
		
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	1 КАК ВидСтроки,
		|	Организации.Ссылка КАК Ссылка,
		|	Организации.ГоловнаяОрганизация КАК ГоловнаяОрганизация,
		|	Организации.Наименование
		|ИЗ
		|	Справочник.Организации КАК Организации
		|ГДЕ
		|	Организации.Ссылка = &Организация
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	2,
		|	Организации.Ссылка,
		|	Организации.ГоловнаяОрганизация,
		|	Организации.Наименование
		|ИЗ
		|	Справочник.Организации КАК Организации
		|ГДЕ
		|	Организации.ГоловнаяОрганизация = &Организация
		|	И Организации.ЕстьОбособленныеПодразделения = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВидСтроки";
		
		СписокСтруктурныхЕдиниц = Новый СписокЗначений;
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			НовыйЭлемент 				= СписокСтруктурныхЕдиниц.Добавить();
			НовыйЭлемент.Значение 		= Выборка.Ссылка;
			НовыйЭлемент.Представление 	= Выборка.Наименование;
		КонецЦикла;
		
	ИначеЕсли РежимВыбораСтруктурныхЕдиниц = "ПоНалогоплательщику" Тогда
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Налогоплательщик",  Налогоплательщик);
		Запрос.УстановитьПараметр("Дата", Дата);
		
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	ВЫБОР
		|		КОГДА РегистрацииВНалоговомОргане.НаименованиеОбособленногоПодразделения = """"
		|			ТОГДА ВЫРАЗИТЬ(ИсторияРегистрацийВНалоговомОрганеСрезПоследних.СтруктурнаяЕдиница КАК Справочник.Организации).Наименование
		|		ИНАЧЕ РегистрацииВНалоговомОргане.НаименованиеОбособленногоПодразделения
		|	КОНЕЦ КАК Наименование,
		|	1 КАК ВидСтроки,
		|	РегистрацииВНалоговомОргане.Владелец КАК Владелец,
		|	РегистрацииВНалоговомОргане.Ссылка КАК Ссылка
		|ИЗ
		|	РегистрСведений.ИсторияРегистрацийВНалоговомОргане.СрезПоследних(&Дата, ТИПЗНАЧЕНИЯ(СтруктурнаяЕдиница) = ТИП(Справочник.Организации)) КАК ИсторияРегистрацийВНалоговомОрганеСрезПоследних
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.РегистрацииВНалоговомОргане КАК РегистрацииВНалоговомОргане
		|		ПО ИсторияРегистрацийВНалоговомОрганеСрезПоследних.РегистрацияВНалоговомОргане = РегистрацииВНалоговомОргане.Ссылка
		|ГДЕ
		|	ИсторияРегистрацийВНалоговомОрганеСрезПоследних.СтруктурнаяЕдиница.ГоловнаяОрганизация = &Налогоплательщик
		|   ИЛИ ИсторияРегистрацийВНалоговомОрганеСрезПоследних.СтруктурнаяЕдиница = &Налогоплательщик
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВЫБОР
		|		КОГДА РегистрацииВНалоговомОргане.НаименованиеОбособленногоПодразделения = """"
		|			ТОГДА ВЫРАЗИТЬ(ИсторияРегистрацийВНалоговомОрганеСрезПоследних.СтруктурнаяЕдиница КАК Справочник.ПодразделенияОрганизаций).Наименование
		|		ИНАЧЕ РегистрацииВНалоговомОргане.НаименованиеОбособленногоПодразделения
		|	КОНЕЦ,
		|	2,
		|	РегистрацииВНалоговомОргане.Владелец,
		|	РегистрацииВНалоговомОргане.Ссылка
		|ИЗ
		|	РегистрСведений.ИсторияРегистрацийВНалоговомОргане.СрезПоследних(
		|			&Дата,
		|			ТИПЗНАЧЕНИЯ(СтруктурнаяЕдиница) = ТИП(Справочник.ПодразделенияОрганизаций)
		|				И ВЫРАЗИТЬ(СтруктурнаяЕдиница КАК Справочник.ПодразделенияОрганизаций).ОбособленноеПодразделение) КАК ИсторияРегистрацийВНалоговомОрганеСрезПоследних
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.РегистрацииВНалоговомОргане КАК РегистрацииВНалоговомОргане
		|		ПО ИсторияРегистрацийВНалоговомОрганеСрезПоследних.РегистрацияВНалоговомОргане = РегистрацииВНалоговомОргане.Ссылка
		|ГДЕ
		|	ИсторияРегистрацийВНалоговомОрганеСрезПоследних.СтруктурнаяЕдиница.ГоловнаяОрганизация = &Налогоплательщик
		|   ИЛИ ИсторияРегистрацийВНалоговомОрганеСрезПоследних.СтруктурнаяЕдиница = &Налогоплательщик
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВидСтроки,
		|	Владелец,
		|	Наименование";
		
		СписокСтруктурныхЕдиниц = Новый СписокЗначений;
		
		Выборка = Запрос.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			НовыйЭлемент 				= СписокСтруктурныхЕдиниц.Добавить();
			НовыйЭлемент.Значение 		= Выборка.Ссылка;
			НовыйЭлемент.Представление 	= Выборка.Наименование;
		КонецЦикла;
		
	КонецЕсли; 
	
	Возврат СписокСтруктурныхЕдиниц;
	
КонецФункции

Функция РегистрацияВНалоговомОргане(СтруктурнаяЕдиница, Знач ДатаАктуальности = Неопределено, РегистрацияВНалоговомОргане = Неопределено) Экспорт
	
	Возврат ЗарплатаКадры.РегистрацияВНалоговомОргане(СтруктурнаяЕдиница, ДатаАктуальности);
	
КонецФункции

Функция ИндивидуальныйПредприниматель(Организация) Экспорт
	
	Возврат Организация.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо;
	
КонецФункции

Функция ЮридическоеЛицо(Организация) Экспорт
	
	Возврат Организация.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо;
	
КонецФункции

Функция ТекстЗапросаЗадолженностьПоДоходамДо2017() Экспорт

	ИспользоватьВедомостиДляВыплатыПрочихДоходов = Ложь;
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьВедомостиДляВыплатыПрочихДоходов")
		ИЛИ НЕ ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.Дивиденды") Тогда
		ИспользоватьВедомостиДляВыплатыПрочихДоходов = Истина;
	КонецЕсли;

	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ВзаиморасчетыССотрудникамиОстатки.СуммаВзаиморасчетовОстаток КАК ЗадолженностьПоДоходам
	|ИЗ
	|	РегистрНакопления.ВзаиморасчетыССотрудниками.Остатки(
	|			КОНЕЦПЕРИОДА(&парамПериодПо, МЕСЯЦ),
	|			Организация В
	|					(ВЫБРАТЬ
	|						ВТ_СписокОрганизаций.Ссылка
	|					ИЗ
	|						ВТ_СписокОрганизаций)
	|				И ФизическоеЛицо <> &парамИндивидуальныйПредприниматель
	|				И ФизическоеЛицо В
	|					(ВЫБРАТЬ
	|						ВТ_Гражданство.ФИО
	|					ИЗ
	|						ВТ_Гражданство)) КАК ВзаиморасчетыССотрудникамиОстатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИсторияРегистрацийВНалоговомОргане.СрезПоследних(КОНЕЦПЕРИОДА(&парамПериодПо, МЕСЯЦ),) КАК ИсторияРегистрацийВНалоговомОрганеПоОрганизациям
	|		ПО ВзаиморасчетыССотрудникамиОстатки.Организация = ИсторияРегистрацийВНалоговомОрганеПоОрганизациям.СтруктурнаяЕдиница
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИсторияРегистрацийВНалоговомОргане.СрезПоследних(КОНЕЦПЕРИОДА(&парамПериодПо, МЕСЯЦ),) КАК ИсторияРегистрацийВНалоговомОрганеПоПодразделениям
	|		ПО ВзаиморасчетыССотрудникамиОстатки.Подразделение = ИсторияРегистрацийВНалоговомОрганеПоПодразделениям.СтруктурнаяЕдиница
	|ГДЕ
	|	ИсторияРегистрацийВНалоговомОрганеПоОрганизациям.РегистрацияВНалоговомОргане В (&парамСписокСтруктурныхЕдиниц)
	|	ИЛИ ИсторияРегистрацийВНалоговомОрганеПоПодразделениям.РегистрацияВНалоговомОргане В (&парамСписокСтруктурныхЕдиниц)
	|
	// в УПК исключим регистр ВзаиморасчетыСДепонентами
	|" + ?(ИспользоватьВедомостиДляВыплатыПрочихДоходов, "", "
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВзаиморасчетыСДепонентамиОстатки.СуммаОстаток
	|ИЗ
	|	РегистрНакопления.ВзаиморасчетыСДепонентами.Остатки(
	|			КОНЕЦПЕРИОДА(&парамПериодПо, МЕСЯЦ),
	|			Организация В
	|					(ВЫБРАТЬ
	|						ВТ_СписокОрганизаций.Ссылка
	|					ИЗ
	|						ВТ_СписокОрганизаций)
	|				И ФизическоеЛицо <> &парамИндивидуальныйПредприниматель
	|				И ФизическоеЛицо В
	|					(ВЫБРАТЬ
	|						ВТ_Гражданство.ФИО
	|					ИЗ
	|						ВТ_Гражданство)) КАК ВзаиморасчетыСДепонентамиОстатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИсторияРегистрацийВНалоговомОргане.СрезПоследних(КОНЕЦПЕРИОДА(&парамПериодПо, МЕСЯЦ),) КАК ИсторияРегистрацийВНалоговомОрганеПоОрганизациям
	|		ПО ВзаиморасчетыСДепонентамиОстатки.Организация = ИсторияРегистрацийВНалоговомОрганеПоОрганизациям.СтруктурнаяЕдиница
	|ГДЕ
	|	ИсторияРегистрацийВНалоговомОрганеПоОрганизациям.РегистрацияВНалоговомОргане В (&парамСписокСтруктурныхЕдиниц)
	|");
	
	Возврат ТекстЗапроса;

КонецФункции

Функция ТекстЗапросаЗадолженностьПоДоходамДо2023() Экспорт

	ИспользоватьВедомостиДляВыплатыПрочихДоходов = Ложь;
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьВедомостиДляВыплатыПрочихДоходов")
		ИЛИ НЕ ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.Дивиденды") Тогда
		ИспользоватьВедомостиДляВыплатыПрочихДоходов = Истина;
	КонецЕсли;

	// 200.01 - остатки (в 200.01 - остатки на конец отчетного квартала, в 200.02, 200.05 только за отчетный квартал)	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ВзаиморасчетыССотрудникамиОстатки.СуммаВзаиморасчетовОстаток КАК ЗадолженностьПоДоходам
	|ИЗ
	|	РегистрНакопления.ВзаиморасчетыССотрудниками.Остатки(
	|			&парамПериодПо,
	|			Организация В
	|					(ВЫБРАТЬ
	|						ВТ_СписокОрганизаций.Ссылка
	|					ИЗ
	|						ВТ_СписокОрганизаций)
	|				И ФизическоеЛицо <> &парамИндивидуальныйПредприниматель) КАК ВзаиморасчетыССотрудникамиОстатки
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИсторияРегистрацийВНалоговомОргане.СрезПоследних(КОНЕЦПЕРИОДА(&парамПериодПо, МЕСЯЦ),) КАК ИсторияРегистрацийВНалоговомОрганеПоОрганизациям
	|		ПО ВзаиморасчетыССотрудникамиОстатки.Организация = ИсторияРегистрацийВНалоговомОрганеПоОрганизациям.СтруктурнаяЕдиница
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИсторияРегистрацийВНалоговомОргане.СрезПоследних(КОНЕЦПЕРИОДА(&парамПериодПо, МЕСЯЦ),) КАК ИсторияРегистрацийВНалоговомОрганеПоПодразделениям
	|		ПО ВзаиморасчетыССотрудникамиОстатки.Подразделение = ИсторияРегистрацийВНалоговомОрганеПоПодразделениям.СтруктурнаяЕдиница
	|ГДЕ
	|	ИсторияРегистрацийВНалоговомОрганеПоОрганизациям.РегистрацияВНалоговомОргане В (&парамСписокСтруктурныхЕдиниц)
	|	ИЛИ ИсторияРегистрацийВНалоговомОрганеПоПодразделениям.РегистрацияВНалоговомОргане В (&парамСписокСтруктурныхЕдиниц)
	// в УПК исключим регистр ВзаиморасчетыСДепонентами
	|" + ?(ИспользоватьВедомостиДляВыплатыПрочихДоходов, "
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
