
////////////////////////////////////////////////////////////////////////////////
// ОбменСБанкамиПереопределяемый: механизм обмена электронными документами с банками.
//
////////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

// Заполняет массив актуальными видами электронных документов для прикладного решения.
//
// Параметры:
//  Массив - Массив из ПеречислениеСсылка.ВидыЭДОбменСБанками  - виды актуальных ЭД
//   Добавлять можно только следующие значения:
//    - Перечисления.ВидыЭДОбменСБанками.ЗапросВыписки
//    - Перечисления.ВидыЭДОбменСБанками.ПлатежноеПоручение
//    - Перечисления.ВидыЭДОбменСБанками.ПлатежноеТребование
//    - Перечисления.ВидыЭДОбменСБанками.ПоручениеНаПереводВалюты
//    - Перечисления.ВидыЭДОбменСБанками.ПоручениеНаПокупкуВалюты
//    - Перечисления.ВидыЭДОбменСБанками.ПоручениеНаПродажуВалюты
//    - Перечисления.ВидыЭДОбменСБанками.РаспоряжениеНаОбязательнуюПродажуВалюты
//    - Перечисления.ВидыЭДОбменСБанками.СписокНаЗачислениеДенежныхСредствНаСчетаСотрудников
//    - Перечисления.ВидыЭДОбменСБанками.СписокНаОткрытиеСчетовПоЗарплатномуПроекту
//    - Перечисления.ВидыЭДОбменСБанками.СписокУволенныхСотрудников
//    - Перечисления.ВидыЭДОбменСБанками.Письмо
//    - Перечисления.ВидыЭДОбменСБанками.РеестрВыплатСамозанятым
//
Процедура ПолучитьАктуальныеВидыЭД(Массив) Экспорт
	ОбменСБанкамиБЗК.ПолучитьАктуальныеВидыЭД(Массив);
КонецПроцедуры

// Используется для получения номеров счетов в виде массив строк
//
// Параметры:
//  Организация - СправочникСсылка.Организации - отбор по организации.
//  Банк - СправочникСсылка.КлассификаторБанков - отбор по банку.
//  МассивНомеровБанковскихСчетов - Массив - Массив возврата, в элементах строки с номерами счетов.
//
Процедура ПолучитьНомераБанковскихСчетов(Организация, Банк, МассивНомеровБанковскихСчетов) Экспорт
	
КонецПроцедуры

// Определяет параметры электронного документа по типу владельца.
//
// Параметры:
//  Источник - ДокументСсылка, ДокументОбъект - Источник объекта, либо ссылка документа/справочника-источника.
//  ПараметрыЭД - Структура - структура параметров источника, необходимых для определения
//                настроек обмена ЭД. Обязательные параметры: ВидЭД, Банк, Организация.
//
Процедура ЗаполнитьПараметрыЭДПоИсточнику(Источник, ПараметрыЭД) Экспорт
	// ЗУПК
	ТипИсточника = ТипЗнч(Источник);	
	Если ТипИсточника = Тип("ДокументСсылка.ПлатежноеПоручение")
		ИЛИ ТипИсточника = Тип("ДокументОбъект.ПлатежноеПоручение") 
		ИЛИ ТипИсточника = Тип("ДокументСсылка.ПеречислениеВзносовИОтчислений")
		ИЛИ ТипИсточника = Тип("ДокументОбъект.ПеречислениеВзносовИОтчислений") Тогда	
		ПараметрыЭД.ВидЭД = Перечисления.ВидыЭДОбменСБанками.ПлатежноеПоручение;
		ПараметрыЭД.Организация = Источник.Организация;
		ПараметрыЭД.Банк = Источник.БанковскийСчет.Банк; 	
	КонецЕсли;
	// ЗУПК
КонецПроцедуры

// Подготавливает данные для электронного документа типа Платежное поручение.
//
// Параметры:
//  МассивСсылок - Массив - содержит ссылки на документы информационной базы, на основании которых будут созданы электронные документы.
//  ДанныеДляЗаполнения - Массив - содержит пустые деревья значений, которые необходимо заполнить данными.
//           Дерево значений повторяет структуру макета ПлатежноеПоручение из обработки ОбменСБанками.
//           Если по какому-либо документу не удалось получить данные, то текст ошибки необходимо поместить вместо дерева значений.
//           ВНИМАНИЕ! Порядок элементов массива ДанныеДляЗаполнения соответствует порядку элементов массива МассивСсылок.
//
Процедура ЗаполнитьДанныеПлатежныхПоручений(МассивСсылок, ДанныеДляЗаполнения) Экспорт
	
	// ЗУПК
	
	ТекДокумент = МассивСсылок[0];
	
	ДанныеДокументаСтруктура = Новый Структура("Организация, БанковскийСчет, Получатель, БанковскийСчетПолучателя, 
											|Дата, Номер, КодНазначенияПлатежа, НазначениеПлатежа, СтруктурноеПодразделение, ФактическийПлательщик", 
											ТекДокумент.Организация, ТекДокумент.БанковскийСчет, ТекДокумент.Контрагент, ТекДокумент.БанковскийСчетКонтрагента,
											ТекДокумент.Дата, ТекДокумент.Номер, ТекДокумент.КодНазначенияПлатежа, ТекДокумент.НазначениеПлатежа, ТекДокумент.Подразделение, ТекДокумент.ФактическийПлательщик); 

	
	ДанныеДокумента = Новый Структура("ВидОперации, ВидНалогаВзносаОтчисления, Дата, Номер, КодНазначенияПлатежа, НазначениеПлатежа, Ведомости, БуквенныйКодВалюты,
									|Организация, БанковскийСчет, ОрганизацияНаименованиеСокращенное, ОрганизацияИдентификационныйНомер, ОрганизацияКодСтраныРегистрации,
									|ОрганизацияНомерСчета, ОрганизацияБИК, ОрганизацияПризнакРезидентства, ОрганизацияСекторЭкономики,
									|Получатель, БанковскийСчетПолучателя, ПолучательНаименованиеПолное, ПолучательИдентификационныйНомер, ПолучательКодСтраныРегистрации,
									|ПолучательПризнакРезидентства, ПолучательСекторЭкономики, ПолучательНомерСчета, ПолучательБИК,
									|ФИОРуководителя, ДолжностьРуководителя, ФИОГлавногоБухгалтера, 
									|СтруктурноеПодразделение, СтруктурноеПодразделениеИдентификационныйНомер, СтруктурноеПодразделениеНаименование, 
									|ФактическийПлательщик, ФактическийПлательщикНаименованиеСокращенное, ФактическийПлательщикИдентификационныйНомер");
	
	ЗаполнитьЗначенияСвойств(ДанныеДокумента, ДанныеДокументаСтруктура);
	
	СтруктураРеквизитовОрганизации                     = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеДокумента.Организация, "ИНН, НаименованиеСокращенное, КБЕ, СтранаРегистрации, ЮридическоеФизическоеЛицо, ИндивидуальныйПредприниматель");
	ДанныеДокумента.ОрганизацияИдентификационныйНомер  = СтруктураРеквизитовОрганизации.ИНН;
	ДанныеДокумента.ОрганизацияНаименованиеСокращенное = СтруктураРеквизитовОрганизации.НаименованиеСокращенное;
	ДанныеДокумента.ОрганизацияПризнакРезидентства     = Лев(СтруктураРеквизитовОрганизации.КБЕ, 1);
	ДанныеДокумента.ОрганизацияСекторЭкономики         = Прав(СтруктураРеквизитовОрганизации.КБЕ, 1);
	
	Если СтруктураРеквизитовОрганизации.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо Тогда
		
		ГражданствоФизическихЛиц = РегистрыСведений.ГражданствоФизическихЛиц.СрезПоследних(ДанныеДокумента.Дата, Новый Структура("ФизическоеЛицо", СтруктураРеквизитовОрганизации.ИндивидуальныйПредприниматель));
		
		Если ГражданствоФизическихЛиц.Количество() > 0 Тогда
			
			СтранаРегистрации = ГражданствоФизическихЛиц[0].Страна;
			ДанныеДокумента.ОрганизацияКодСтраныРегистрации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтранаРегистрации, "КодАльфа2");
			
		КонецЕсли;
		
	ИначеЕсли ЗначениеЗаполнено(СтруктураРеквизитовОрганизации.СтранаРегистрации) Тогда
		
		ДанныеДокумента.ОрганизацияКодСтраныРегистрации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтруктураРеквизитовОрганизации.СтранаРегистрации, "КодАльфа2");
		
	Иначе
		
		ДанныеДокумента.ОрганизацияКодСтраныРегистрации = "KZ";
		
	КонецЕсли;
	
	СтруктураРеквизитовПолучателя                      = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеДокумента.Получатель, "ИНН, НаименованиеПолное, КБЕ, СтранаРегистрации");
	ДанныеДокумента.ПолучательНаименованиеПолное       = СтруктураРеквизитовПолучателя.НаименованиеПолное;
	ДанныеДокумента.ПолучательИдентификационныйНомер   = СтруктураРеквизитовПолучателя.ИНН;
	ДанныеДокумента.ПолучательПризнакРезидентства      = Лев(СтруктураРеквизитовПолучателя.КБЕ, 1);
	ДанныеДокумента.ПолучательСекторЭкономики          = Прав(СтруктураРеквизитовПолучателя.КБЕ, 1);
	Если ЗначениеЗаполнено(СтруктураРеквизитовПолучателя.СтранаРегистрации) Тогда
		
		ДанныеДокумента.ПолучательКодСтраныРегистрации = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтруктураРеквизитовПолучателя.СтранаРегистрации, "КодАльфа2");
		
	Иначе
		
		ДанныеДокумента.ПолучательКодСтраныРегистрации = "KZ";

	КонецЕсли;
	
    Если ЗначениеЗаполнено(ДанныеДокумента.СтруктурноеПодразделение) Тогда
		
		Регистрация = ЗарплатаКадры.РегистрацияВНалоговомОргане(ДанныеДокумента.СтруктурноеПодразделение, ДанныеДокумента.Дата);
		ДанныеДокумента.СтруктурноеПодразделениеИдентификационныйНомер  = Регистрация.ИНН;
		ДанныеДокумента.СтруктурноеПодразделениеНаименование = Регистрация.НаименованиеОбособленногоПодразделения;
		
	КонецЕсли;
	
    Если ЗначениеЗаполнено(ДанныеДокумента.ФактическийПлательщик) Тогда
		
		Если ТипЗнч(ДанныеДокумента.ФактическийПлательщик) = Тип("СправочникСсылка.ПодразделенияОрганизаций") 
			И ЗначениеЗаполнено(ДанныеДокумента.ФактическийПлательщик) Тогда
			
			Регистрация = ЗарплатаКадры.РегистрацияВНалоговомОргане(ДанныеДокумента.ФактическийПлательщик, ДанныеДокумента.Дата);
			ДанныеДокумента.ФактическийПлательщикИдентификационныйНомер  = Регистрация.ИНН;
			ДанныеДокумента.ФактическийПлательщикНаименованиеСокращенное = Регистрация.НаименованиеОбособленногоПодразделения;
			
		Иначе
			
			СтруктураРеквизитовОрганизации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеДокумента.ФактическийПлательщик, "ИНН, НаименованиеСокращенное");
			ДанныеДокумента.ФактическийПлательщикИдентификационныйНомер  = СтруктураРеквизитовОрганизации.ИНН;
			ДанныеДокумента.ФактическийПлательщикНаименованиеСокращенное = СтруктураРеквизитовОрганизации.НаименованиеСокращенное;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПодсистемы") Тогда
		МодульЗарплатаКадры                            = ОбщегоНазначения.ОбщийМодуль("ЗарплатаКадры");
		ДанныеДокумента.БуквенныйКодВалюты             = МодульЗарплатаКадры.ВалютаУчетаЗаработнойПлаты();
		МодульЗарплатаКадрыПереопределяемый            = ОбщегоНазначения.ОбщийМодуль("ЗарплатаКадрыПереопределяемый");
		СтруктураОтветственных                         = МодульЗарплатаКадрыПереопределяемый.СведенияОбОтветственныхЛицах(
			ДанныеДокумента.Организация,"Руководитель, ДолжностьРуководителя, ГлавныйБухгалтер", ДанныеДокумента.Дата);
		ДанныеДокумента.ФИОРуководителя                = СтруктураОтветственных.Руководитель;
		ДанныеДокумента.ДолжностьРуководителя          = СтруктураОтветственных.ДолжностьРуководителя;
		ДанныеДокумента.ФИОГлавногоБухгалтера          = СтруктураОтветственных.ГлавныйБухгалтер;
	Иначе
		МодульЗначениеНастроекПовтИсп = ОбщегоНазначения.ОбщийМодуль("ЗначениеНастроекПовтИсп");
		ДанныеДокумента.БуквенныйКодВалюты             = МодульЗначениеНастроекПовтИсп.ПолучитьВалютуРегламентированногоУчета();
		
		МодульОтветственныеЛицаСервер = ОбщегоНазначения.ОбщийМодуль("ОтветственныеЛицаСервер");
		СтруктураОтветственных                         = МодульОтветственныеЛицаСервер.ПолучитьОтветственныеЛицаОрганизации(ДанныеДокумента.Организация, ДанныеДокумента.Дата);
		ДанныеДокумента.ФИОРуководителя                = СтруктураОтветственных.РуководительНаименование;
		ДанныеДокумента.ДолжностьРуководителя          = СтруктураОтветственных.РуководительДолжность;
		ДанныеДокумента.ФИОГлавногоБухгалтера          = СтруктураОтветственных.ГлавныйБухгалтерНаименование;
	КонецЕсли;
	
	СтруктураРеквизитовБанкаОрганизации                = Справочники.БанковскиеСчетаОрганизаций.ПолучитьРеквизитыБанковскогоСчетаОрганизации(ДанныеДокумента.БанковскийСчет);
	ДанныеДокумента.ОрганизацияНомерСчета              = СтруктураРеквизитовБанкаОрганизации.НомерСчета;
	ДанныеДокумента.ОрганизацияБИК                     = СтруктураРеквизитовБанкаОрганизации.БИК;
	
	СтруктураРеквизитовБанкаКонтрагента                = Справочники.БанковскиеСчетаКонтрагентов.ПолучитьРеквизитыБанковскогоСчета(ДанныеДокумента.БанковскийСчетПолучателя);
	ДанныеДокумента.ПолучательНомерСчета               = СтруктураРеквизитовБанкаКонтрагента.НомерСчета;
	ДанныеДокумента.ПолучательБИК                      = СтруктураРеквизитовБанкаКонтрагента.БИК;

	Если ТипЗнч(ТекДокумент) = Тип("ДокументСсылка.ПлатежноеПоручение") Тогда
		Если ТекДокумент.ВидОперации = Перечисления.ВидыОперацийПлатежногоПоручения.ПеречислениеЗарплаты
			ИЛИ ТекДокумент.ВидОперации = Перечисления.ВидыОперацийПлатежногоПоручения.ПеречислениеПрочихДоходов Тогда
			Ведомости = ТекДокумент.Ведомости.Выгрузить(,"Ведомость").ВыгрузитьКолонку("Ведомость");
		Иначе
			Ведомости = ТекДокумент.ВедомостиПрочие.Выгрузить(,"Ведомость").ВыгрузитьКолонку("Ведомость");
		КонецЕсли;
	ИначеЕсли ТипЗнч(ТекДокумент) = Тип("ДокументСсылка.ПеречислениеВзносовИОтчислений") Тогда
		Ведомости = ТекДокумент.ВедомостиНаПеречислениеВзносовИОтчислений.Выгрузить(,"Ведомость").ВыгрузитьКолонку("Ведомость");	
	КонецЕсли;
	
	Если Ведомости.Количество() = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'В табличной части платежного поручения должна быть выбрана как минимум одна ведомость'"));
		Возврат;
	КонецЕсли;
	
	СуммаКПеречислению = 0;
	
	Для каждого ТекВедомость из Ведомости Цикл
		
		Если ТипЗнч(ТекВедомость)= Тип("ДокументСсылка.ВедомостьНаВыплатуЗарплатыПеречислением") Тогда
			ВидОперации = "ВыплатаЗарплатыПеречислением";  
		ИначеЕсли ТипЗнч(ТекВедомость)= Тип("ДокументСсылка.ВедомостьНаПеречислениеПрочихВыплат") Тогда
			ВидОперации = "ПеречислениеПрочихВыплат";
		ИначеЕсли ТипЗнч(ТекВедомость)= Тип("ДокументСсылка.ВедомостьПрочихДоходовВБанк") Тогда
			ВидОперации = "ВедомостьПрочихДоходовВБанк";
		ИначеЕсли ТипЗнч(ТекВедомость)= Тип("ДокументСсылка.ВедомостьПрочихДоходовПеречислением") Тогда
			ВидОперации = "ВедомостьПрочихДоходовПеречислением";
		Иначе
			ВидОперации = "ВыплатаЗарплатыПоЗарплатномуПроекту";
		КонецЕсли; 
		
		Если ТипЗнч(ТекДокумент) = Тип("ДокументСсылка.ПеречислениеВзносовИОтчислений") Тогда
			ВидОперации = "ПеречислениеВзносов";
		КонецЕсли;
		
		Если ВидОперации = "ПеречислениеВзносов" И Ведомости.Количество() > 0 Тогда
			ВидНалогаВзносаОтчисления = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекВедомость, "ВидНалогаВзносаОтчисления");
		Иначе
			ВидНалогаВзносаОтчисления = Неопределено;
		КонецЕсли;
		
		РазделятьСуммыПоПериодуЗадолженности  = Ложь;
		
