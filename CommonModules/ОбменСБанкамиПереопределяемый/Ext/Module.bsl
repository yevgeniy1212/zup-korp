				|	МАКСИМУМ(СписокКПеречислению.ВключаетСО) КАК СО,
				|	МАКСИМУМ(СписокКПеречислению.ВключаетООСМС) КАК ООСМС,
				|	МАКСИМУМ(СписокКПеречислению.ВключаетОПВР) КАК ОПВР,
				|	СУММА(ВЫБОР КОГДА СписокКПеречислению.Ссылка.ВидПлатежа В (&ВидыПлатежейПени) ТОГДА СписокКПеречислению.НалогВзнос ИНАЧЕ СписокКПеречислению.СуммаПлатежа КОНЕЦ) КАК СуммаПлатежа";
				
			КонецЕсли;
			
			ПоляГруппировки = "
			|	СписокКПеречислению.Ссылка.ВидНалогаВзносаОтчисления,
			|	СписокКПеречислению.Ссылка.ВидПлатежа,
			|	СписокКПеречислению.ФизическоеЛицо.ДатаРождения";
			
			Если РазделятьСуммыПоПериодуЗадолженности ИЛИ ТекДокумент.ВидНалогаВзносаОтчисления = "ЕП"
				ИЛИ ТекДокумент.ВидНалогаВзносаОтчисления = "ВОСМС" ИЛИ ТекДокумент.ВидНалогаВзносаОтчисления = "ООСМС" Тогда
				
				Если ТекДокумент.ВидНалогаВзносаОтчисления = "ВОСМС" ИЛИ ТекДокумент.ВидНалогаВзносаОтчисления = "ООСМС" Тогда
					
					ПоляГруппировки = ПоляГруппировки + ",
					|	ВЫБОР КОГДА СписокКПеречислению.МесяцПериода = ДАТАВРЕМЯ(1, 1, 1) ТОГДА СписокКПеречислению.МесяцНалоговогоПериода ИНАЧЕ СписокКПеречислению.МесяцПериода КОНЕЦ";
					
				Иначе
					
					ПоляГруппировки = ПоляГруппировки + ",
					|	СписокКПеречислению.МесяцНалоговогоПериода";
					
				КонецЕсли;	
				
			КонецЕсли;
			
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "КВыплате", "НалогВзнос");
			
			Если ТекДокумент.ВидНалогаВзносаОтчисления = "ВОСМС" ИЛИ ТекДокумент.ВидНалогаВзносаОтчисления = "ООСМС" Тогда
				
				ПоляУпорядочивания = ПоляУпорядочивания + ", ВЫБОР КОГДА СписокКПеречислению.МесяцПериода = ДАТАВРЕМЯ(1, 1, 1) ТОГДА СписокКПеречислению.МесяцНалоговогоПериода ИНАЧЕ СписокКПеречислению.МесяцПериода КОНЕЦ";
				
			КонецЕсли;
			
		ИначеЕсли ВидОперации = "ПеречислениеДенежныхСредствПодотчетникам" Тогда
			Источник1 = "Документ.СписаниеБезналичныхДенежныхСредств.РасшифровкаПлатежа";
			ПоляВыборки = "
			|	СписокКПеречислению.БанковскийСчетПодотчетногоЛица.НомерСчета КАК РасчСчет";
			
			ПоляГруппировки = "
			|	СписокКПеречислению.БанковскийСчетПодотчетногоЛица.НомерСчета";
			
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "СписокКПеречислению.ФизическоеЛицо", "СписокКПеречислению.ПодотчетноеЛицо");
			
		ИначеЕсли ВидОперации = "ПеречислениеПрочихВыплат" Тогда
			Источник1 = "Документ.ВедомостьНаПеречислениеПрочихВыплат.ПрочиеВыплаты";
			ПоляВыборки = "
			|	СписокКПеречислению.Ссылка.ВидПрочихВыплат КАК ВидОперации,
			|	""ПеречислениеПрочихВыплат"" КАК ВидПлатежа,
			|	СписокКПеречислению.ФизическоеЛицо.ДатаРождения КАК ДатаРождения,";
			
			Если РазделятьСуммыПоПериодуЗадолженности Тогда
				ПоляВыборки = ПоляВыборки + "
				|	СписокКПеречислению.ПериодВзаиморасчетов КАК ПериодПлатежа";
				
			Иначе
				ПоляВыборки = ПоляВыборки + "
				|	МИНИМУМ(СписокКПеречислению.ПериодВзаиморасчетов) КАК ПериодПлатежа";
			КонецЕсли;
			
			ПоляГруппировки = "
			|	СписокКПеречислению.Ссылка.ВидПрочихВыплат,
			|	""ПеречислениеПрочихВыплат"",
			|	СписокКПеречислению.ФизическоеЛицо.ДатаРождения";
			
			Если РазделятьСуммыПоПериодуЗадолженности Тогда
				ПоляГруппировки = ПоляГруппировки + ",
				|	СписокКПеречислению.ПериодВзаиморасчетов";
			КонецЕсли;
			
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "КВыплате", "Сумма");
		КонецЕсли;
		
		ТекстЗапросаДопДанные = ТекстЗапроса;
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&Источник", Источник1);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПоляВыборки", ПоляВыборки);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПоляГруппировки", ПоляГруппировки);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПолеФизическоеЛицоНаименование", ПолеФизическоеЛицоНаименование);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПолеФизическоеЛицо", ПолеФизическоеЛицо);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПолеИИН", ПолеИИН);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПоляФИО", ПоляФИО);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПоляДанныеФИО", ПоляДанныеФИО);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПрисоединяемыеТаблицы", ПрисоединяемыеТаблицы);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ГруппировкаФизическоеЛицоНаименование", ГруппировкаФизическоеЛицоНаименование);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ГруппировкаФизическоеЛицо", ГруппировкаФизическоеЛицо);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ГруппировкаИИН", ГруппировкаИИН);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ГруппировкиФИО", ГруппировкиФИО);
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ГруппировкиДанныеФИО", ГруппировкиДанныеФИО);
		
		// дополним ВедомостьПрочихДоходовВБанк
		Если ПолучитьФункциональнуюОпцию("ИспользоватьВзаиморасчетыПоПрочимДоходам") 
			И (ВидОперации = "ВедомостьПрочихДоходовВБанк"
			ИЛИ ВидОперации = "ВедомостьПрочихДоходовПеречислением") Тогда
			
			Если ВидОперации = "ВедомостьПрочихДоходовПеречислением" Тогда
				ПрисоединяемыеТаблицы = 
				"ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.МестаВыплатыЗарплатыСотрудников КАК МестаВыплатыЗарплатыСотрудников
				|		ПО ЛОЖЬ
				|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФИОФизическихЛиц.СрезПоследних(&ДатаДокумента, ) КАК ФИОТретьегоЛица
				|		ПО ЛОЖЬ
				|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГражданствоФизическихЛиц.СрезПоследних(&ДатаДокумента, ) КАК ГражданствоТретьегоЛица
				|		ПО ЛОЖЬ
				|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СтраныМира КАК СтранаТретьегоЛица
				|		ПО ЛОЖЬ"; // перечисление третьему лицу для доходов ГПХ не поддерживается
			КонецЕсли;
			
			ТекстЗапросаДопДанные = СтрЗаменить(ТекстЗапросаДопДанные, "&Источник", Источник2);
			ТекстЗапросаДопДанные = СтрЗаменить(ТекстЗапросаДопДанные, "РАЗРЕШЕННЫЕ", "");
			ТекстЗапросаДопДанные = СтрЗаменить(ТекстЗапросаДопДанные, "&ПоляВыборки", ПоляВыборки);
			ТекстЗапросаДопДанные = СтрЗаменить(ТекстЗапросаДопДанные, "&ПоляГруппировки", ПоляГруппировки);
			ТекстЗапросаДопДанные = СтрЗаменить(ТекстЗапросаДопДанные, "&ПолеФизическоеЛицоНаименование", ПолеФизическоеЛицоНаименование);
			ТекстЗапросаДопДанные = СтрЗаменить(ТекстЗапросаДопДанные, "&ПолеФизическоеЛицо", ПолеФизическоеЛицо);
			ТекстЗапросаДопДанные = СтрЗаменить(ТекстЗапросаДопДанные, "&ПолеИИН", ПолеИИН);
			ТекстЗапросаДопДанные = СтрЗаменить(ТекстЗапросаДопДанные, "&ПоляФИО", ПоляФИО);
			ТекстЗапросаДопДанные = СтрЗаменить(ТекстЗапросаДопДанные, "&ПоляДанныеФИО", ПоляДанныеФИО);
			ТекстЗапросаДопДанные = СтрЗаменить(ТекстЗапросаДопДанные, "&ПрисоединяемыеТаблицы", ПрисоединяемыеТаблицы);
			ТекстЗапросаДопДанные = СтрЗаменить(ТекстЗапросаДопДанные, "&ГруппировкаФизическоеЛицоНаименование", ГруппировкаФизическоеЛицоНаименование);
			ТекстЗапросаДопДанные = СтрЗаменить(ТекстЗапросаДопДанные, "&ГруппировкаФизическоеЛицо", ГруппировкаФизическоеЛицо);
			ТекстЗапросаДопДанные = СтрЗаменить(ТекстЗапросаДопДанные, "&ГруппировкаИИН", ГруппировкаИИН);
			ТекстЗапросаДопДанные = СтрЗаменить(ТекстЗапросаДопДанные, "&ГруппировкиФИО", ГруппировкиФИО);
			ТекстЗапросаДопДанные = СтрЗаменить(ТекстЗапросаДопДанные, "&ГруппировкиДанныеФИО", ГруппировкиДанныеФИО);
			
			ТекстЗапроса = ТекстЗапроса + "
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|"
			+ ТекстЗапросаДопДанные + "
			|
			|УПОРЯДОЧИТЬ ПО
			|	&ПоляУпорядочивания";
			
		Иначе
			
			ТекстЗапроса = ТекстЗапроса + "
			|
			|УПОРЯДОЧИТЬ ПО
			|	&ПоляУпорядочивания";
			
		КонецЕсли;
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&ПоляУпорядочивания", ПоляУпорядочивания);
		
		Запрос.УстановитьПараметр("ДатаДокумента", ДатаДокумента);
		Запрос.Текст = ТекстЗапроса;
		Результат = Запрос.Выполнить();
		
		ТаблицаСписокСотрудников = Результат.Выгрузить();
				
	КонецЦикла;

	ДеревоДокумента = ДанныеДляЗаполнения[МассивСсылок.Найти(ТекДокумент)];  
		
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "Дата", ДанныеДокумента.Дата);  
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "Сумма", СуммаКПеречислению); 
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "Организация", ДанныеДокумента.Организация);  
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "СтруктурноеПодразделениеОтправитель", ДанныеДокумента.СтруктурноеПодразделениеНаименование); 
	ПечатныйНомерДокумента = "";
	ЭлектронноеВзаимодействиеПереопределяемый.ПолучитьПечатныйНомерДокумента(ТекДокумент, ПечатныйНомерДокумента); 
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "Номер", ПечатныйНомерДокумента); 
		
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПлатежа.ВидОплаты", ВидОплаты); 
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПлатежа.НазначениеПлатежа", ДанныеДокумента.НазначениеПлатежа); 
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПлатежа.ВалютаДокумента", ДанныеДокумента.БуквенныйКодВалюты);
		
	// Плательщик.
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПлательщика.Наименование", ДанныеДокумента.Организация.НаименованиеПолное); 
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПлательщика.ИНН", ДанныеДокумента.ОрганизацияИдентификационныйНомер);
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПлательщика.КБЕ", ДанныеДокумента.Организация.КБЕ);  
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПлательщика.РасчСчет", ДанныеДокумента.БанковскийСчет.НомерСчета);
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПлательщика.ФактическийПлательщик", ДанныеДокумента.ФактическийПлательщик); 
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПлательщика.ПлательщикКодСтраныРегистрации", ДанныеДокумента.ОрганизацияКодСтраныРегистрации);
		
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПлательщика.Банк.БИК", СокрЛП(ДанныеДокумента.ОрганизацияБИК));
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПлательщика.Банк.Наименование", ДанныеДокумента.БанковскийСчет.Банк.Наименование);
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПлательщика.Банк.Город", ДанныеДокумента.БанковскийСчет.Банк.Город);
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПлательщика.Банк.КоррСчет", ДанныеДокумента.БанковскийСчет.Банк.КоррСчет);
		
	// Получатель.
	Контрагент = ДанныеДокумента.Получатель;
		
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "Получатель", Контрагент); 
	
	Если Контрагент.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо Тогда 
		ТипКонтрагента = "ЮрЛицо";	
	Иначе 
		ТипКонтрагента = "ФизЛицо";
	КонецЕсли;	
	
	Если ТипКонтрагента = "ФизЛицо" И Контрагент.КБЕ = "" Тогда 
		Если Контрагент.СтранаРегистрации.КодАльфа2 <> "KZ" Тогда
			ПолучательКБЕ = "29";
		Иначе
			ПолучательКБЕ = "19";
		КонецЕсли;
	Иначе
		ПолучательКБЕ = Контрагент.КБЕ;
	КонецЕсли;	
	
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПолучателя.ТипКонтрагента", ТипКонтрагента);

	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПолучателя.Наименование", ДанныеДокумента.ПолучательНаименованиеПолное); 
	Если НЕ ЗначениеЗаполнено(ДанныеДокумента.ПолучательИдентификационныйНомер) Тогда
		ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПолучателя.ИНН", СокрЛП(Контрагент.ИНН));
	Иначе
		ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПолучателя.ИНН", СокрЛП(ДанныеДокумента.ПолучательИдентификационныйНомер));
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ПолучательКБЕ) Тогда
		ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПолучателя.КБЕ", СокрЛП(Контрагент.КБЕ)); 
	Иначе
		ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПолучателя.КБЕ", СокрЛП(ПолучательКБЕ));
	КонецЕсли;
	
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПолучателя.РасчСчет", ДанныеДокумента.ПолучательНомерСчета);
	
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПолучателя.Банк.БИК", СокрЛП(ДанныеДокумента.ПолучательБИК)); 
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПолучателя.Банк.Наименование", ДанныеДокумента.БанковскийСчетПолучателя.Банк.Наименование);
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПолучателя.Банк.Город", ДанныеДокумента.БанковскийСчетПолучателя.Банк.Город);
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПолучателя.Банк.КоррСчет", ДанныеДокумента.БанковскийСчетПолучателя.Банк.КоррСчет);
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПолучателя.ПолучательКодСтраныРегистрации", ДанныеДокумента.ПолучательКодСтраныРегистрации);
		
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПлатежа.ПеречислениеНалога", Ложь);
	
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПлатежа.КодНазначенияПлатежа", ДанныеДокумента.КодНазначенияПлатежа);
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПлатежа.ДатаВалютирования", ДанныеДокумента.Дата);
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "РеквизитыПлатежа.ДатаПолученияТовара", Дата(1,1,1));
	
	// Списочные платежи.
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("ПлатежныйДокумент", ТекДокумент);
	
	Если ТаблицаСписокСотрудников.Количество() <> 0 Тогда
		СписокСотрудников = ТаблицаСписокСотрудников.Скопировать();
	Иначе
		СписокСотрудников = Новый ТаблицаЗначений;
	КонецЕсли;
	ЭлектронноеВзаимодействие.ЗаполнитьЗначениеРеквизитаВДереве(ДеревоДокумента, "ПереданСписокСотрудников", СписокСотрудников.Количество() <> 0);
	Если СписокСотрудников.Количество() <> 0 Тогда
		ЭлектронноеВзаимодействие.ЗагрузитьТаблицуВДерево(ДеревоДокумента, СписокСотрудников, "СписокСотрудников");
	КонецЕсли; 
	
	// ЗУПК
	
КонецПроцедуры

