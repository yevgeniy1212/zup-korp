#Область СлужебныйПрограммныйИнтерфейс

// Дополняет параметры рассылки при наличии подсистемы «Шаблоны сообщений».
//   РассылатьПоШаблону - Булево - установите Истина, если рассылка будет выполняться по шаблонам писем.
//   ПредметШаблона - Строка - полное имя типа метаданных, являющегося предметом шаблона, например, Справочник.Кандидаты.
//   ВладелецШаблона - ОпределяемыйТип.ВладелецШаблонаСообщения - значение используемое для отбора контекстных шаблонов.
// 
// Параметры:
//  ПараметрыРассылки - см. РассылкаДокументовКлиент.ПараметрыРассылки.
//
Процедура ДополнитьПараметрыРассылки(ПараметрыРассылки) Экспорт
	
	ПараметрыРассылки.Вставить("РассылатьПоШаблону", Ложь);
	ПараметрыРассылки.Вставить("ПредметШаблона", "");
	ПараметрыРассылки.Вставить("ВладелецШаблона", Неопределено);
	
КонецПроцедуры

#КонецОбласти