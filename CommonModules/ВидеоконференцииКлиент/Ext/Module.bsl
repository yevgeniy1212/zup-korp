//@strict-types

#Область СлужебныйПрограммныйИнтерфейс

// См. Видеоконференции.ДанныеСервиса
Функция ДанныеСервиса(СервисИлиУчетнаяЗапись) Экспорт
	
	Возврат ВидеоконференцииВызовСервера.ДанныеСервиса(СервисИлиУчетнаяЗапись);
	
КонецФункции

// См. Видеоконференции.НастроенныеУчетныеЗаписи
Функция НастроенныеУчетныеЗаписи() Экспорт
	
	Возврат ВидеоконференцииВызовСервера.НастроенныеУчетныеЗаписи();
	
КонецФункции

// Параметры:
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиВидеоконференций
//  Ссылка - Строка
//  ИдентификаторВидеоконференции - Строка
Процедура НачатьВидеоконференцию(УчетнаяЗапись, Ссылка, ИдентификаторВидеоконференции) Экспорт
	
	ДанныеСервиса = ДанныеСервиса(УчетнаяЗапись);
	
	Если ДанныеСервиса.ЭтоСистемаВзаимодействия Тогда
		КоллекцияИдентификаторовПользователей =
			Вычислить("Новый КоллекцияИдентификаторовПользователейСистемыВзаимодействия()");
		ИдентификаторОбсужденияСистемыВзаимодействия =
			Новый ИдентификаторОбсужденияСистемыВзаимодействия(ИдентификаторВидеоконференции);
			
		ТекстИсполняемогоКода =
			"СистемаВзаимодействия.НачатьВидеоконференцию(, " +
			"КоллекцияИдентификаторовПользователей, ИдентификаторОбсужденияСистемыВзаимодействия, Истина)";
		#Если ВебКлиент Тогда
		Результат = Вычислить(ТекстИсполняемогоКода);
		#Иначе
		Выполнить(ТекстИсполняемогоКода);
		#КонецЕсли
	ИначеЕсли ДанныеСервиса.СтартПоСсылке Тогда
		ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(Ссылка);
	Иначе
		ПерейтиВВидеоконференцию(Ссылка);
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  Ссылка - Строка
Процедура ПерейтиВВидеоконференцию(Ссылка) Экспорт
	
	ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(Ссылка);
	
КонецПроцедуры

#КонецОбласти