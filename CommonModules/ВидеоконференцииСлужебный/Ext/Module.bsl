	ДанныеПользователя.Вставить("АдресЭП", "");
	ДанныеПользователя.Вставить("ИдентификаторПользователяИБ", Новый УникальныйИдентификатор());
	
	Возврат ДанныеПользователя;
	
КонецФункции

// Возвращаемое значение:
//  Структура:
// * Сервис - Строка
// * УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиВидеоконференций -
// * ПриветственноеСообщение - Строка -
// * ТокенДоступа - Строка -
// * ТокенОбновления - Строка -
