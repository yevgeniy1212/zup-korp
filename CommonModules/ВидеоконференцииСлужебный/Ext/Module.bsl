#Область СлужебныеПроцедурыИФункции

// Параметры:
//  УчетныеЗаписи - Массив из СправочникСсылка.УчетныеЗаписиВидеоконференций
// 
// Возвращаемое значение:
//  Соответствие Из КлючИЗначение:
// * Ключ - СправочникСсылка.УчетныеЗаписиВидеоконференций
// * Значение - См. НовыеРеквизитыУчетнойЗаписи
Функция РеквизитыУчетныхЗаписей(УчетныеЗаписи)

	РеквизитыУчетныхЗаписей = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	УчетныеЗаписиВидеоконференций.Ссылка КАК УчетнаяЗапись,
	|	УчетныеЗаписиВидеоконференций.Сервис КАК Сервис,
	|	УчетныеЗаписиВидеоконференций.ПриветственноеСообщение,
	|	НастройкиУчетныхЗаписей.ТокенДоступа КАК ТокенДоступа,
	|	НастройкиУчетныхЗаписей.ТокенОбновления КАК ТокенОбновления,
	|	НастройкиУчетныхЗаписей.ДатаОкончанияДействияТокена КАК ДатаОкончанияДействияТокена,
	|	НастройкиУчетныхЗаписей.ИмяПользователя КАК ИмяПользователя
	|ИЗ
	|	Справочник.УчетныеЗаписиВидеоконференций КАК УчетныеЗаписиВидеоконференций
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НастройкиУчетныхЗаписейВидеоконференций КАК НастройкиУчетныхЗаписей
	|		ПО (НастройкиУчетныхЗаписей.УчетнаяЗапись = УчетныеЗаписиВидеоконференций.Ссылка)
	|ГДЕ
	|	УчетныеЗаписиВидеоконференций.Ссылка В (&УчетныеЗаписи)";

	Запрос.УстановитьПараметр("УчетныеЗаписи", УчетныеЗаписи);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		РеквизитыУчетнойЗаписи = НовыеРеквизитыУчетнойЗаписи();
		ЗаполнитьЗначенияСвойств(РеквизитыУчетнойЗаписи, Выборка);
		РеквизитыУчетныхЗаписей.Вставить(Выборка.УчетнаяЗапись, РеквизитыУчетнойЗаписи);
	КонецЦикла;
	
	Возврат РеквизитыУчетныхЗаписей;

КонецФункции

Процедура ПрочитатьТелоОтвета(РезультатЗапроса, ПрочитатьВСоответствие = Ложь)
	
	ОтветОбъект = Неопределено;
	
	СтрокаJSON = РезультатЗапроса.ТелоОтвета;
	
	Если Не ЗначениеЗаполнено(СтрокаJSON) Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		ОтветОбъект = ПарсерJSON(СтрокаJSON, ПрочитатьВСоответствие);
	Исключение
		ОписаниеОшибки = СтрШаблон(
			НСтр("ru = 'Невозможно прочитать тело запроса JSON:
						|Читаемый объект(первые 500 символов): %1
						|Исходный запрос:
						|Метод: %2
						|Адрес ресурса: %3
						|Тело запроса: %4
						|Код состояния: %5
						|Информация об ошибке: %6'"),
			Лев(Строка(СтрокаJSON), 500),
			РезультатЗапроса.Метод,
			РезультатЗапроса.АдресРесурса,
			РезультатЗапроса.ТекстЗапроса,
			РезультатЗапроса.КодСостояния,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ЗаписьЖурналаРегистрации(
			СтрШаблон(НСтр("ru = 'Чтение ответа от %1'", ОбщегоНазначения.КодОсновногоЯзыка()), РезультатЗапроса.Сервис),
			УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки);
		
		ВызватьИсключение ТекстИсключения(
			СтрШаблон(НСтр("ru = 'Не удалось прочитать ответ сервиса %1'"), РезультатЗапроса.Сервис));
	КонецПопытки;
	
	РезультатЗапроса.ОтветОбъект = ОтветОбъект;
	
КонецПроцедуры

#КонецОбласти