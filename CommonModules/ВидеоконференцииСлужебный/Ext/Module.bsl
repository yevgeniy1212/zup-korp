// * ИмяПользователя - Строка -
// * ИдентификаторПользователя - Строка -
// * Предупреждение - Строка -
Функция НовыеРеквизитыУчетнойЗаписи() Экспорт
	
	РеквизитыУчетнойЗаписи = Новый Структура();
	РеквизитыУчетнойЗаписи.Вставить("Сервис", "");
	РеквизитыУчетнойЗаписи.Вставить("УчетнаяЗапись", Справочники.УчетныеЗаписиВидеоконференций.ПустаяСсылка());
