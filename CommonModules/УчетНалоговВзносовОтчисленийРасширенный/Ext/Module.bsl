Функция ДоходыНеПодлежащиеНалогообложению(Форма, ВидНалогаВзносаОтчисления = Неопределено) Экспорт
	
	ДоходыНеПодлежащиеНалогообложению = Новый Структура;
	
	ТаблицаВычетыДоходыНеПодлежащиеНалогообложению = Форма.Объект.ДоходыНеПодлежащиеНалогообложению.Выгрузить();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТаблицаДоходыНеПодлежащиеНалогообложению", ТаблицаВычетыДоходыНеПодлежащиеНалогообложению);
	Если ВидНалогаВзносаОтчисления = Неопределено Тогда
		БезОтбораПоВиду = Истина;
		Запрос.УстановитьПараметр("БезОтбораПоВиду", БезОтбораПоВиду);
	Иначе
		БезОтбораПоВиду = Ложь;
		Запрос.УстановитьПараметр("БезОтбораПоВиду", БезОтбораПоВиду);
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ВидНалогаВзносаОтчисления", ВидНалогаВзносаОтчисления);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТаблицаДоходыНеПодлежащиеНалогообложению.Подразделение,
	|	ТаблицаДоходыНеПодлежащиеНалогообложению.ФизическоеЛицо,
	|	ТаблицаДоходыНеПодлежащиеНалогообложению.МесяцНалоговогоПериода,
	|	ТаблицаДоходыНеПодлежащиеНалогообложению.ДоходНеПодлежащийНалогообложению,
	|	ТаблицаДоходыНеПодлежащиеНалогообложению.ВидНалогаВзносаОтчисления,
	|	ТаблицаДоходыНеПодлежащиеНалогообложению.Начисление,
	|	ТаблицаДоходыНеПодлежащиеНалогообложению.СуммаДохода,
	|	ТаблицаДоходыНеПодлежащиеНалогообложению.НеоблагаемыйДоход,
	|	ТаблицаДоходыНеПодлежащиеНалогообложению.ФиксСтрока,
	|	ТаблицаДоходыНеПодлежащиеНалогообложению.ФиксРасчет
	|ПОМЕСТИТЬ ВТ_ТаблицаДоходыНеПодлежащиеНалогообложению
	|ИЗ
	|	&ТаблицаДоходыНеПодлежащиеНалогообложению КАК ТаблицаДоходыНеПодлежащиеНалогообложению
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ДоходыНеПодлежащиеНалогообложению.Подразделение,
	|	ДоходыНеПодлежащиеНалогообложению.ФизическоеЛицо,
	|	ДоходыНеПодлежащиеНалогообложению.МесяцНалоговогоПериода,
	|	ДоходыНеПодлежащиеНалогообложению.ДоходНеПодлежащийНалогообложению,
	|	ДоходыНеПодлежащиеНалогообложению.ВидНалогаВзносаОтчисления,
	|	ДоходыНеПодлежащиеНалогообложению.Начисление,
	|	ДоходыНеПодлежащиеНалогообложению.СуммаДохода,
	|	ДоходыНеПодлежащиеНалогообложению.НеоблагаемыйДоход,
	|	ДоходыНеПодлежащиеНалогообложению.ФиксСтрока,
	|	ДоходыНеПодлежащиеНалогообложению.ФиксРасчет
	|ИЗ
	|	ВТ_ТаблицаДоходыНеПодлежащиеНалогообложению КАК ДоходыНеПодлежащиеНалогообложению
	|ГДЕ 
	|	ДоходыНеПодлежащиеНалогообложению.ВидНалогаВзносаОтчисления = &ВидНалогаВзносаОтчисления
	|	ИЛИ &БезОтбораПоВиду";
	
	ДоходыНеПодлежащиеНалогообложению.Вставить("ДоходыНеПодлежащиеНалогообложению", Запрос.Выполнить().Выгрузить());
	
	Возврат ПоместитьВоВременноеХранилище(ДоходыНеПодлежащиеНалогообложению, Форма.УникальныйИдентификатор);
	
КонецФункции

Процедура УдалитьДанныеПоНалогамВзносамОтчислениямФизическоголица(Объект, ФизическоеЛицо) Экспорт
	
	СтрокиНалогиВзносыОтчисления = Объект.НалогиВзносыОтчисления.НайтиСтроки(Новый Структура("ФизическоеЛицо", ФизическоеЛицо));
	Для Каждого СтрокаНалогиВзносыОтчисления Из СтрокиНалогиВзносыОтчисления Цикл
		
		СтрокиВычетовИПН = Объект.ВычетыИПН.НайтиСтроки(
			Новый Структура("ИдентификаторСтрокиНалогиВзносыОтчисления", СтрокаНалогиВзносыОтчисления.ИдентификаторСтрокиНалогиВзносыОтчисления));
			
		Для Каждого СтрокаВычетов Из СтрокиВычетовИПН Цикл
			Объект.ВычетыИПН.Удалить(СтрокаВычетов);
		КонецЦикла;
		
		Объект.НалогиВзносыОтчисления.Удалить(СтрокаНалогиВзносыОтчисления);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура УдалитьДанныеПоНалогамВзносамОтчислениямПоИдентификатору(Объект, ИдентификаторСтрокиНалогиВзносыОтчисления) Экспорт
	
	СтрокиВычетовИПН = Объект.ВычетыИПН.НайтиСтроки(
		Новый Структура("ИдентификаторСтрокиНалогиВзносыОтчисления", ИдентификаторСтрокиНалогиВзносыОтчисления));
		
	Для Каждого СтрокаВычетов Из СтрокиВычетовИПН Цикл
		Объект.ВычетыИПН.Удалить(СтрокаВычетов);
	КонецЦикла;
	
КонецПроцедуры

Процедура НалогиВзносыОтчисленияДанныеВМенеджераРасчета(ТаблицаНалогиВзносыОтчисления, ТаблицаВычетыИПН, ТаблицаДоходыНеПодлежащиеНалогообложению, МенеджерРасчета, Отбор = Неопределено, ПозицииВставки = Неопределено, ДанныеРезультатовРаспределения = Неопределено) Экспорт
	
	НалогиВзносыОтчисления = МенеджерРасчета.Зарплата.НалогиВзносыОтчисления;
	СтрокиРасчетаНалогиВзносыОтчисления = Новый Массив;
	СтрокиРасчетаВычетыИПН = Новый Массив;
	СтрокиРасчетаДоходыНеПодлежащиеНалогообложению = Новый Массив;
	ИдентификаторыСтрокФизическихЛицНВО = Новый Соответствие;
	ИдентификаторыСтрокФизическихЛицДНП = Новый Соответствие;
	
	Для Каждого СтрокаФормы Из ТаблицаНалогиВзносыОтчисления Цикл
		
		Если Отбор <> Неопределено Тогда
			ФизическоеЛицо = Отбор.ФизическиеЛицаОтбор[СтрокаФормы.ФизическоеЛицо];
			Если ФизическоеЛицо = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			РасчетЗарплатыРасширенныйКлиентСервер.ДобавитьИдентификаторСтрокиСотрудника(ИдентификаторыСтрокФизическихЛицНВО, СтрокаФормы.ФизическоеЛицо, СтрокаФормы.ПолучитьИдентификатор());
			СтрокиРасчетаНалогиВзносыОтчисления.Добавить(СтрокаФормы);
			
		КонецЕсли;
		
		СтруктураПоиска = Новый Структура("ИдентификаторСтрокиНалогиВзносыОтчисления", СтрокаФормы.ИдентификаторСтрокиНалогиВзносыОтчисления);
		СтрокиВычетыИПН = ТаблицаВычетыИПН.НайтиСтроки(СтруктураПоиска);
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокиРасчетаВычетыИПН, СтрокиВычетыИПН);
		ЗаполнитьЗначенияСвойств(МенеджерРасчета.Зарплата.НалогиВзносыОтчисления.Добавить(), СтрокаФормы);
		Для Каждого СтрокаВычетов Из СтрокиВычетыИПН Цикл
			ЗаполнитьЗначенияСвойств(МенеджерРасчета.Зарплата.ВычетыИПН.Добавить(), СтрокаВычетов);
		КонецЦикла;
		
	КонецЦикла;
		
	Если ПозицииВставки <> Неопределено Тогда	
		ПозицииВставки.Вставить("НалогиВзносыОтчисления", ИдентификаторыСтрокФизическихЛицНВО);
	КонецЕсли;
	
	Для Каждого СтрокаФормы Из ТаблицаДоходыНеПодлежащиеНалогообложению Цикл
		Если Отбор <> Неопределено Тогда
			ФизическоеЛицо = Отбор.ФизическиеЛицаОтбор[СтрокаФормы.ФизическоеЛицо];
			Если ФизическоеЛицо = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			РасчетЗарплатыРасширенныйКлиентСервер.ДобавитьИдентификаторСтрокиСотрудника(ИдентификаторыСтрокФизическихЛицДНП, СтрокаФормы.ФизическоеЛицо, СтрокаФормы.ПолучитьИдентификатор());
			СтрокиРасчетаДоходыНеПодлежащиеНалогообложению.Добавить(СтрокаФормы);
			
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(МенеджерРасчета.Зарплата.ДоходыНеПодлежащиеНалогообложению.Добавить(), СтрокаФормы);
	КонецЦикла;
	
	Если ПозицииВставки <> Неопределено Тогда	
		ПозицииВставки.Вставить("ДоходыНеПодлежащиеНалогообложению", ИдентификаторыСтрокФизическихЛицДНП);
	КонецЕсли;
	
	УдалитьСтрокиРасчета(ТаблицаНалогиВзносыОтчисления, СтрокиРасчетаНалогиВзносыОтчисления, Отбор = Неопределено);
	УдалитьСтрокиРасчета(ТаблицаВычетыИПН, СтрокиРасчетаВычетыИПН, Отбор = Неопределено);
	УдалитьСтрокиРасчета(ТаблицаДоходыНеПодлежащиеНалогообложению, СтрокиРасчетаДоходыНеПодлежащиеНалогообложению, Отбор = Неопределено);
	
КонецПроцедуры

Функция ОписаниеКолонокТаблицыНВО(ТаблицаИсточник) Экспорт
	Если ТипЗнч(ТаблицаИсточник) = Тип("ТаблицаЗначений") Тогда
		 Колонки = ТаблицаИсточник.Колонки
	Иначе
		 Колонки = ТаблицаИсточник.Выгрузить().Колонки
	КонецЕсли;
	КолонкиПоиска = "";
	КолонкиСвязиТаблиц = "";
	КолонкиСуммирования = "";
	Для каждого ОписаниеКолонки Из Колонки Цикл
		ТипыКолонки = ОписаниеКолонки.ТипЗначения;
		Если ОписаниеКолонки.Имя = "НомерСтроки" Или ОписаниеКолонки.Имя = "ФизическоеЛицо" Или ОписаниеКолонки.Имя = "МесяцНалоговогоПериода" Или ОписаниеКолонки.Имя = "ВидНалогаВзносаОтчисления" Или ОписаниеКолонки.Имя = "ДоходНеПодлежащийНалогообложению" Или ОписаниеКолонки.Имя = "ФиксСтрока" Или ОписаниеКолонки.Имя = "ФиксРасчет" Тогда
			КолонкиСвязиТаблиц = КолонкиСвязиТаблиц + ?(Не ЗначениеЗаполнено(КолонкиСвязиТаблиц),"",",") + ОписаниеКолонки.Имя;
		ИначеЕсли СтрНачинаетсяС(НРег(ОписаниеКолонки.Имя),"удалить") Тогда
		ИначеЕсли ТипыКолонки.СодержитТип(Тип("Число")) Тогда
			КолонкиСуммирования = КолонкиСуммирования + ?(Не ЗначениеЗаполнено(КолонкиСуммирования),"",",") + ОписаниеКолонки.Имя;
		Иначе
			КолонкиПоиска = КолонкиПоиска + ?(Не ЗначениеЗаполнено(КолонкиПоиска),"",",") + ОписаниеКолонки.Имя;
			КолонкиСвязиТаблиц = КолонкиСвязиТаблиц + ?(Не ЗначениеЗаполнено(КолонкиСвязиТаблиц),"",",") + ОписаниеКолонки.Имя;
		КонецЕсли;
	КонецЦикла; 
	Возврат Новый Структура("КолонкиПоиска,КолонкиСуммирования,КолонкиСвязиТаблиц",КолонкиПоиска,КолонкиСуммирования,КолонкиСвязиТаблиц)
КонецФункции

Функция ОписаниеКолонокТаблицыДНПН(ТаблицаИсточник) Экспорт
	Если ТипЗнч(ТаблицаИсточник) = Тип("ТаблицаЗначений") Тогда
		 Колонки = ТаблицаИсточник.Колонки
	Иначе
		 Колонки = ТаблицаИсточник.Выгрузить().Колонки
	КонецЕсли;
	КолонкиПоиска = "";
	КолонкиСвязиТаблиц = "";
	КолонкиСуммирования = "";
	Для каждого ОписаниеКолонки Из Колонки Цикл
		ТипыКолонки = ОписаниеКолонки.ТипЗначения;
		Если ОписаниеКолонки.Имя = "ИдентификаторСтрокиНалогиВзносыОтчисления" Или ОписаниеКолонки.Имя = "ФиксСтрока" Или ОписаниеКолонки.Имя = "ФиксРасчет" Тогда
			КолонкиСвязиТаблиц = КолонкиСвязиТаблиц + ?(Не ЗначениеЗаполнено(КолонкиСвязиТаблиц),"",",") + ОписаниеКолонки.Имя;
		ИначеЕсли СтрНачинаетсяС(НРег(ОписаниеКолонки.Имя),"удалить") Тогда
		ИначеЕсли ТипыКолонки.СодержитТип(Тип("Число")) Тогда
			КолонкиСуммирования = КолонкиСуммирования + ?(Не ЗначениеЗаполнено(КолонкиСуммирования),"",",") + ОписаниеКолонки.Имя;
		Иначе
			КолонкиПоиска = КолонкиПоиска + ?(Не ЗначениеЗаполнено(КолонкиПоиска),"",",") + ОписаниеКолонки.Имя;
			КолонкиСвязиТаблиц = КолонкиСвязиТаблиц + ?(Не ЗначениеЗаполнено(КолонкиСвязиТаблиц),"",",") + ОписаниеКолонки.Имя;
		КонецЕсли;
	КонецЦикла; 
	Возврат Новый Структура("КолонкиПоиска,КолонкиСуммирования,КолонкиСвязиТаблиц",КолонкиПоиска,КолонкиСуммирования,КолонкиСвязиТаблиц)
КонецФункции

Функция ЕстьДанныеВСтроке(СтрокаКоллекции, ИменаРесурсов)
	Для каждого ИмяРесурса Из ИменаРесурсов Цикл
		Если ЗначениеЗаполнено(СтрокаКоллекции[ИмяРесурса]) Тогда
			Возврат Истина	
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь	
КонецФункции

Функция ТаблицаНВО(ТаблицаИсточник, ОписаниеКолонок) Экспорт
	
	Если ТаблицаИсточник.Количество() = 1 Тогда
		Возврат ТаблицаИсточник.Скопировать()
	КонецЕсли;
	
	ТаблицаРезультат = ТаблицаИсточник.СкопироватьКолонки();
	СтруктураПоиска = Новый Структура(ОписаниеКолонок.КолонкиСвязиТаблиц);
	КопияТаблицы = ТаблицаИсточник.Скопировать();
	КопияТаблицы.Свернуть(ОписаниеКолонок.КолонкиСвязиТаблиц, ОписаниеКолонок.КолонкиСуммирования);
	ИменаКолонокСуммирования = СтрРазделить(ОписаниеКолонок.КолонкиСуммирования, ",", Ложь);
	Для каждого СтрокаТЗ Из КопияТаблицы Цикл
		Если ЕстьДанныеВСтроке(СтрокаТЗ, ИменаКолонокСуммирования) Тогда
			ЗаполнитьЗначенияСвойств(СтруктураПоиска, СтрокаТЗ);
			СтрокиДанных = ТаблицаИсточник.НайтиСтроки(СтруктураПоиска);
			НоваяСтрока = ТаблицаРезультат.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТЗ);
		КонецЕсли;
	КонецЦикла;
	
	Возврат ТаблицаРезультат
	
КонецФункции

Процедура РасчетЗарплатыНалогиВзносыОтчисленияВДанныеФормы(ДанныеДляЗаполнения, Объект, ПозицииВставки = Неопределено) Экспорт
	
	ИспользуютсяКомпонентыЕП = (НЕ ДанныеДляЗаполнения.КомпонентыЕП = Неопределено);

    // НалогиВзносыОтчисления, ВычетыИПН
	МаксимальныйИдентификаторСтрокиНалогиВзносыОтчисления = УчетНалоговВзносовОтчислений.МаксимальныйИдентификаторСтрокиНалогиВзносыОтчисления(Объект.НалогиВзносыОтчисления) + 1;
    ТаблицаНВО = Объект.НалогиВзносыОтчисления;
    ТаблицаИсточникНВО = ДанныеДляЗаполнения.НалогиВзносыОтчисления;
	
	ОписаниеКолонок = ОписаниеКолонокТаблицыНВО(ТаблицаИсточникНВО);

	ИсточникСИндексами = ТаблицаИсточникНВО.Скопировать();
	ИсточникСИндексами.Индексы.Добавить(ОписаниеКолонок.КолонкиСвязиТаблиц);
	ИсточникСИндексами.Индексы.Добавить(ОписаниеКолонок.КолонкиПоиска);
	НВО = ТаблицаНВО(ИсточникСИндексами, ОписаниеКолонок);
	ПозицииФизическихЛицНВО = Неопределено;
	ПозицииДоходыНеПодлежащиеНалогообложению = Неопределено;
	ПозицииВычетовИПН = Неопределено;
	ПозицииКомпонентовЕП = Неопределено;
	СоответствиеОбходовФизическихЛиц = Неопределено;	
	
	Если ПозицииВставки <> Неопределено Тогда
		Если Не ПозицииВставки.Свойство("НалогиВзносыОтчисления", ПозицииФизическихЛицНВО) Тогда
			ПозицииФизическихЛицНВО = Новый Соответствие;
			ПозицииВставки.Вставить("НалогиВзносыОтчисления", ПозицииФизическихЛицНВО);
		КонецЕсли;
		Если Не ПозицииВставки.Свойство("ДоходыНеПодлежащиеНалогообложению", ПозицииДоходыНеПодлежащиеНалогообложению) Тогда
    		ПозицииДоходыНеПодлежащиеНалогообложению = Новый Соответствие;
    		ПозицииВставки.Вставить("ДоходыНеПодлежащиеНалогообложению", ПозицииДоходыНеПодлежащиеНалогообложению);
        КонецЕсли;
		Если Не ПозицииВставки.Свойство("ВычетыИПН", ПозицииВычетовИПН) Тогда
			ПозицииВычетовИПН = Новый Соответствие;
			ПозицииВставки.Вставить("ВычетыИПН", ПозицииВычетовИПН);
		КонецЕсли;
		Если Не ПозицииВставки.Свойство("КомпонентыЕП", ПозицииКомпонентовЕП) Тогда
			ПозицииКомпонентовЕП = Новый Соответствие;
			ПозицииВставки.Вставить("КомпонентыЕП", ПозицииКомпонентовЕП);
		КонецЕсли;
		СоответствиеОбходовФизическихЛиц = Новый Соответствие;
	КонецЕсли;

	Для Каждого СтрокаИсточник Из НВО Цикл
		
		ИдентификаторПоискаВычетов = СтрокаИсточник.ИдентификаторСтрокиНалогиВзносыОтчисления;

		СтрокаИсточник.ИдентификаторСтрокиНалогиВзносыОтчисления = МаксимальныйИдентификаторСтрокиНалогиВзносыОтчисления;
		ОбходТаблицыИдентификаторов = РасчетЗарплатыРасширенныйФормы.ОбходТаблицыИдентификаторов(СоответствиеОбходовФизическихЛиц, ПозицииФизическихЛицНВО, СтрокаИсточник.ФизическоеЛицо);
		СтрокаНВО = РасчетЗарплатыРасширенныйКлиентСервер.СтрокаТаблицыПоНачальнойПозиции(ТаблицаНВО, ОбходТаблицыИдентификаторов);

		Если СтрокаИсточник.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ИПН
			ИЛИ СтрокаИсточник.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ЕП Тогда

			ПараметрыОтбора = Новый Структура("ИдентификаторСтрокиНалогиВзносыОтчисления", ИдентификаторПоискаВычетов);
			МассивСтрокВычетыИПН = ДанныеДляЗаполнения.ВычетыИПН.НайтиСтроки(ПараметрыОтбора);
			
			Если ИспользуютсяКомпонентыЕП Тогда
				ПараметрыОтбора = Новый Структура("ИдентификаторСтрокиНалогиВзносыОтчисления", ИдентификаторПоискаВычетов);
				МассивСтрокКомпонентыЕП = ДанныеДляЗаполнения.КомпонентыЕП.НайтиСтроки(ПараметрыОтбора);
			КонецЕсли;
			
			СтрокаИсточник.ИдентификаторСтрокиНалогиВзносыОтчисления = МаксимальныйИдентификаторСтрокиНалогиВзносыОтчисления;
			
			СтрокаНалогиВзносыОтчисленияВДанныеФормы(СтрокаНВО, СтрокаИсточник, МассивСтрокВычетыИПН, Объект,, ПозицииВычетовИПН);
			
			Если ИспользуютсяКомпонентыЕП Тогда
				СтрокаНалогиВзносыОтчисленияВДанныеФормы(СтрокаНВО, СтрокаИсточник, МассивСтрокКомпонентыЕП, Объект, "КомпонентыЕП", ПозицииКомпонентовЕП);
			КонецЕсли;
			
		Иначе
			
			ЗаполнитьЗначенияСвойств(СтрокаНВО, СтрокаИсточник);
			
		КонецЕсли;
		
		МаксимальныйИдентификаторСтрокиНалогиВзносыОтчисления = МаксимальныйИдентификаторСтрокиНалогиВзносыОтчисления + 1;

	КонецЦикла;
	
	РасчетЗарплатыРасширенныйФормы.УдалитьНеактуальныеСтрокиФормы(ТаблицаНВО, СоответствиеОбходовФизическихЛиц, ПозицииФизическихЛицНВО);


	// ДоходыНеПодлежащиеНалогообложению
    ТаблицаДНПН = Объект.ДоходыНеПодлежащиеНалогообложению;
    ТаблицаИсточникДНПН = ДанныеДляЗаполнения.ДоходыНеПодлежащиеНалогообложению;

	ОписаниеКолонок = ОписаниеКолонокТаблицыДНПН(ТаблицаИсточникДНПН);
	ИсточникСИндексами = ТаблицаИсточникДНПН.Скопировать();
	ИсточникСИндексами.Индексы.Добавить(ОписаниеКолонок.КолонкиСвязиТаблиц);
	ИсточникСИндексами.Индексы.Добавить(ОписаниеКолонок.КолонкиПоиска);
	ДНПН = ТаблицаНВО(ИсточникСИндексами, ОписаниеКолонок);
	
	Если СоответствиеОбходовФизическихЛиц <> Неопределено Тогда
        СоответствиеОбходовФизическихЛиц = Новый Соответствие;	    
    КонецЕсли;	

	Для Каждого СтрокаИсточник Из ДНПН Цикл
		
		ОбходТаблицыИдентификаторов = РасчетЗарплатыРасширенныйФормы.ОбходТаблицыИдентификаторов(СоответствиеОбходовФизическихЛиц, ПозицииДоходыНеПодлежащиеНалогообложению, СтрокаИсточник.ФизическоеЛицо);
		СтрокаДНПН = РасчетЗарплатыРасширенныйКлиентСервер.СтрокаТаблицыПоНачальнойПозиции(ТаблицаДНПН, ОбходТаблицыИдентификаторов);

		ЗаполнитьЗначенияСвойств(СтрокаДНПН, СтрокаИсточник);

	КонецЦикла;
	
	РасчетЗарплатыРасширенныйФормы.УдалитьНеактуальныеСтрокиФормы(ТаблицаДНПН, СоответствиеОбходовФизическихЛиц, ПозицииДоходыНеПодлежащиеНалогообложению);
	
КонецПроцедуры

Процедура НалогиВзносыОтчисленияВДанныеМенеджераРасчета(ТаблицаНалогиВзносыОтчисления, ТаблицаВычетыИПН, ТаблицаДоходыНеПодлежащиеНалогообложению, МенеджерРасчета, Отбор = Неопределено, ПозицииВставки = Неопределено, ТаблицаКомпонентыЕП = Неопределено) Экспорт
	
	НалогиВзносыОтчисления = МенеджерРасчета.Зарплата.НалогиВзносыОтчисления;
	ДоходыНеПодлежащиеНалогообложению = МенеджерРасчета.Зарплата.ДоходыНеПодлежащиеНалогообложению;
	
	СтрокиРасчетаНалогиВзносыОтчисления = Новый Массив;
	СтрокиРасчетаВычетыИПН = Новый Массив;
	СтрокиРасчетаКомпонентыЕП = Новый Массив;
	ПозицииСотрудников = Новый Соответствие;
	ИдентификаторыСтрокФизическихЛиц = Новый Соответствие;
	
	Для Каждого СтрокаФормы Из ТаблицаНалогиВзносыОтчисления Цикл
		
		Если Отбор <> Неопределено Тогда
			ФизическоеЛицо = Отбор.ФизическиеЛицаОтбор[СтрокаФормы.ФизическоеЛицо];
			Если ФизическоеЛицо = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			РасчетЗарплатыРасширенныйКлиентСервер.ДобавитьИдентификаторСтрокиСотрудника(ИдентификаторыСтрокФизическихЛиц, СтрокаФормы.ФизическоеЛицо, СтрокаФормы.ПолучитьИдентификатор());
			СтрокиРасчетаНалогиВзносыОтчисления.Добавить(СтрокаФормы);
			
		КонецЕсли;
		
		СтруктураПоиска = Новый Структура("ИдентификаторСтрокиНалогиВзносыОтчисления", СтрокаФормы.ИдентификаторСтрокиНалогиВзносыОтчисления);
		СтрокиПримененныеВычеты = ТаблицаВычетыИПН.НайтиСтроки(СтруктураПоиска);
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокиРасчетаВычетыИПН, СтрокиПримененныеВычеты);
		Если НЕ ТаблицаКомпонентыЕП = Неопределено Тогда
			СтрокиКомпоненты = ТаблицаКомпонентыЕП.НайтиСтроки(СтруктураПоиска);
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(СтрокиРасчетаКомпонентыЕП, СтрокиКомпоненты);
		КонецЕсли;
		СтрокаНалогиВзносыОтчисленияВДанныеМенеджераРасчета(МенеджерРасчета, СтрокаФормы, СтрокиПримененныеВычеты);
		
	КонецЦикла;
	
	ИдентификаторыСтрокФизическихЛиц.Очистить();
	
	Если ПозицииВставки <> Неопределено Тогда
		ПозицииВставки.Вставить("НалогиВзносыОтчисления", ПозицииСотрудников);
	КонецЕсли;
	
	СтрокиРасчетаДоходыНеПодлежащиеНалогообложению = Новый Массив;
	ПозицииСотрудников = Новый Соответствие;
	
	Для Каждого СтрокаФормы Из ТаблицаДоходыНеПодлежащиеНалогообложению Цикл
		
		Если Отбор <> Неопределено Тогда
			ФизическоеЛицо = Отбор.ФизическиеЛицаОтбор[СтрокаФормы.ФизическоеЛицо];
			Если ФизическоеЛицо = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			
			РасчетЗарплатыРасширенныйКлиентСервер.ДобавитьИдентификаторСтрокиСотрудника(ИдентификаторыСтрокФизическихЛиц, СтрокаФормы.ФизическоеЛицо, СтрокаФормы.ПолучитьИдентификатор());
			СтрокиРасчетаДоходыНеПодлежащиеНалогообложению.Добавить(СтрокаФормы);
			
		КонецЕсли;
		
		СтрокаДоходыНеПодлежащиеНалогообложениюВДанныеМенеджераРасчета(МенеджерРасчета, СтрокаФормы);
		
	КонецЦикла;
	
	Если ПозицииВставки <> Неопределено Тогда
		ПозицииВставки.Вставить("ДоходыНеПодлежащиеНалогообложению", ПозицииСотрудников);
	КонецЕсли;
	
	УдалитьСтрокиРасчета(ТаблицаНалогиВзносыОтчисления, СтрокиРасчетаНалогиВзносыОтчисления, Отбор = Неопределено);
	УдалитьСтрокиРасчета(ТаблицаДоходыНеПодлежащиеНалогообложению, СтрокиРасчетаДоходыНеПодлежащиеНалогообложению, Отбор = Неопределено);
	УдалитьСтрокиРасчета(ТаблицаВычетыИПН, СтрокиРасчетаВычетыИПН, Отбор = Неопределено);
	Если НЕ ТаблицаКомпонентыЕП = Неопределено Тогда
		УдалитьСтрокиРасчета(ТаблицаКомпонентыЕП, СтрокиРасчетаКомпонентыЕП, Отбор = Неопределено);
	КонецЕсли;
	
КонецПроцедуры

Процедура СтрокаНалогиВзносыОтчисленияВДанныеМенеджераРасчета(МенеджерРасчета, СтрокаИсточник, СтрокиПримененныеВычеты) Экспорт
	
	СтрокаПриемник = МенеджерРасчета.Зарплата.НалогиВзносыОтчисления.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаПриемник, СтрокаИсточник);
   	Для Каждого СтрокаВычета Из СтрокиПримененныеВычеты Цикл
        СтрокаПриемник = МенеджерРасчета.Зарплата.ВычетыИПН.Добавить();
        ЗаполнитьЗначенияСвойств(СтрокаПриемник, СтрокаВычета); 
	КонецЦикла;
	
КонецПроцедуры

Процедура СтрокаДоходыНеПодлежащиеНалогообложениюВДанныеМенеджераРасчета(МенеджерРасчета, СтрокаИсточник) Экспорт
	
	СтрокаПриемник = МенеджерРасчета.Зарплата.ДоходыНеПодлежащиеНалогообложению.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаПриемник, СтрокаИсточник);
	
КонецПроцедуры

Процедура СтрокаНалогиВзносыОтчисленияВДанныеФормы(СтрокаНалогиВзносыОтчисления, СтрокаИсточник, МассивСтрок, Объект, ИмяТаблицы = "ВычетыИПН", ПозицииДанных = Неопределено)
	
	ЗаполнитьЗначенияСвойств(СтрокаНалогиВзносыОтчисления, СтрокаИсточник);
	
	Для Каждого СтрокаИсточникМассив Из МассивСтрок Цикл
		СтрокаДанных = Объект[ИмяТаблицы].Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаДанных, СтрокаИсточникМассив);
		СтрокаДанных.ИдентификаторСтрокиНалогиВзносыОтчисления = СтрокаИсточник.ИдентификаторСтрокиНалогиВзносыОтчисления;
		Если ПозицииДанных <> Неопределено Тогда
			РасчетЗарплатыРасширенныйКлиентСервер.ДобавитьИдентификаторСтрокиСотрудника(
				ПозицииДанных, СтрокаИсточник.ФизическоеЛицо, СтрокаДанных.ПолучитьИдентификатор());
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура УдалитьСтрокиРасчета(Таблица, СтрокиРасчета, ПолноеУдаление = Ложь)
	
	Если ПолноеУдаление Тогда
		Таблица.Очистить();
	Иначе
		Для Каждого СтрокаУдаления Из СтрокиРасчета Цикл
			Таблица.Удалить(СтрокаУдаления);
		КонецЦикла;	
	КонецЕсли;
	
КонецПроцедуры

