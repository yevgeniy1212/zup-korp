	ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных("НалогиВзносыОтчисленияРазрешенныйВычет");
	ОформляемоеПоле = ЭлементУсловногоОформления.Поля.Элементы.Добавить(); 
	ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных("НалогиВзносыОтчисленияПримененныйВычет");
	ОформляемоеПоле = ЭлементУсловногоОформления.Поля.Элементы.Добавить(); 
	ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных("НалогиВзносыОтчисленияПрочиеВычеты");
	ОформляемоеПоле = ЭлементУсловногоОформления.Поля.Элементы.Добавить(); 
	ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных("НалогиВзносыОтчисленияПредставлениеПримененныеВычеты");
	ОформляемоеПоле = ЭлементУсловногоОформления.Поля.Элементы.Добавить(); 
	ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных("НалогиВзносыОтчисленияПредставлениеРазрешенныеВычеты");
	ОформляемоеПоле = ЭлементУсловногоОформления.Поля.Элементы.Добавить(); 
	ОформляемоеПоле.Поле = Новый ПолеКомпоновкиДанных("НалогиВзносыОтчисленияПримененнаяЛьгота");
	
КонецПроцедуры

// Формирует сторно записи отменяющие движения исправленного документа по регистрам подсистемы.
//
// Параметры:
//  Движения				 - КоллекцияДвижений, Структура	 - Коллекция движений в которую будут добавлены сторно записи.
//  ИсправленныйДокумент	 - ДокументСсылка				 - Документ, записи которого необходимо сторнировать.
//  ПараметрыИсправления	 - Структура					 - Свойства см. в описании функции СторнироватьПоУчетам модулей менеджеров документов.
//  ИсключаемыйРегистратор	 - ДокументСсылка				 - Документ, движения которого не следует учитывать при расчете движений.
//  Записывать				 - Булево						 - Если Истина, то наборы будут записаны сразу, если Ложь, то наборам будет установлен признак Записывать = Истина.
//
Процедура СторнироватьДвиженияДокумента(Движения, ИсправленныйДокумент, ПараметрыИсправления = Неопределено, ИсключаемыйРегистратор = Неопределено, Записывать = Ложь) Экспорт
	
	ИмяУчета = "УчетНалоговВзносовОтчисленийРасширенный";
	МетаданныеРегистров = МетаданныеРегистровПодсистемы();
	
	ДвиженияВСтруктуре = ТипЗнч(Движения) = Тип("Структура");
	Набор = Неопределено;
	
	Для Каждого МетаданныеРегистра Из МетаданныеРегистров Цикл
		
		ИмяРегистра = МетаданныеРегистра.Имя;
		
		Если ДвиженияВСтруктуре Тогда
			Движения.Свойство(ИмяРегистра, Набор);
		Иначе
			Набор = Движения.Найти(ИмяРегистра);
		КонецЕсли;
		
		Если Набор = Неопределено Или Не ИсправлениеДокументовЗарплатаКадры.ИзолироватьУчетом(Набор, ИмяУчета) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ОбщегоНазначения.ЭтоРегистрНакопления(МетаданныеРегистра) Тогда
			ИсправлениеДокументовЗарплатаКадры.СторнироватьДвиженияВРегистреНакопления(Набор, ИсправленныйДокумент, МетаданныеРегистра, Записывать);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗарегистрироватьУдержанныеНалогиВзносы(Документ, Отказ) Экспорт
	
	Если Документ.Метаданные().ТабличныеЧасти.Найти("НалогиВзносы") = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", Документ.Ссылка);
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	НалогиВзносы.ФизическоеЛицо,
	|	НалогиВзносы.МесяцНалоговогоПериода,
	|	НалогиВзносы.РегистрацияВНалоговомОргане,
	|	НалогиВзносы.ВидНалогаВзносаОтчисления,
	|	НалогиВзносы.ВидДохода,
	|	НалогиВзносы.НалогВзнос
	|ПОМЕСТИТЬ ВТ_ДокументНалогиВзносы
	|ИЗ
	|	#Документ КАК НалогиВзносы
	|ГДЕ
	|	НалогиВзносы.Ссылка = &Ссылка";
	Запрос.Текст = СтрЗаменить(ТекстЗапроса, "#Документ", Документ.Метаданные().ПолноеИмя() + ".НалогиВзносы");
	Запрос.Выполнить();
	
	УчетНалоговВзносовОтчислений.СформироватьУдержаниеНалогиВзносыПоВременнойТаблице(Документ.Движения, Отказ, Документ.Организация, Документ.ПериодРегистрации, МенеджерВременныхТаблиц, Истина);
	
КонецПроцедуры

Процедура УстановитьПараметрыВыбораСотрудниковВДокументахПредоставленияВычетов(Форма, ИмяЭлементаСотрудник) Экспорт
	
	ЭлементФормы = Форма.Элементы.Найти(ИмяЭлементаСотрудник);
	Если ЭлементФормы <> Неопределено Тогда
		
		ОтборУстановлен = Ложь;
		
		ПараметрыВыбора = Новый Массив(ЭлементФормы.ПараметрыВыбора);
		Для каждого ПараметрВыбора Из ПараметрыВыбора Цикл
			
			Если ВРег(ПараметрВыбора.Имя) = ВРег("Отбор.Роль") Тогда
				
				ОтборУстановлен = Истина;
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если Не ОтборУстановлен Тогда
			
			РолиСотрудника = Новый Массив;
			РолиСотрудника.Добавить(Перечисления.РолиФизическихЛиц.Сотрудник);
			РолиСотрудника.Добавить(Перечисления.РолиФизическихЛиц.БывшийСотрудник);
			РолиСотрудника.Добавить(Перечисления.РолиФизическихЛиц.ПрочийПолучательДоходов);
			
			ПараметрыВыбора.Добавить(Новый ПараметрВыбора("Отбор.Роль", Новый ФиксированныйМассив(РолиСотрудника)));
			
			ЭлементФормы.ПараметрыВыбора = Новый ФиксированныйМассив(ПараметрыВыбора);
			
		КонецЕсли; 
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьНазначениеПлатежаСервер(Контрагент, БанковскийСчетКонтрагента, ВедомостиНаПеречисление, НазначениеПлатежа, КодНазначенияПлатежа, СуммаДокумента = 0, ВидОперации = Неопределено) Экспорт
	
	ОбменСБанкамиПоЗарплатнымПроектамПереопределяемый.ЗаполнитьНазначениеПлатежа(Контрагент, БанковскийСчетКонтрагента, ВедомостиНаПеречисление, НазначениеПлатежа, КодНазначенияПлатежа, СуммаДокумента, ВидОперации);
	
КонецПроцедуры

Процедура ЗаменитьСтрокиНалогиВзносыОтчисления(ОбновляемаяКоллекцияНВО, ОбновляемаяКоллекцияВычетыИПН, ОбновляемаяКоллекцияДНН, ПараметрыДанных, КонтролируемыеПоля, ОписаниеДокумента, ОтборСтрок = Неопределено, СохранятьИсправления = Истина, КлючевыеКолонки = "ФизическоеЛицо", ОбновляемаяКоллекцияКомпонентыЕП = Неопределено) Экспорт
	
	НалогиВзносыОтчисления = ПараметрыДанных.НалогиВзносыОтчисления;
	ВычетыИПН = ПараметрыДанных.ВычетыИПН;
	ДоходыНеПодлежащиеНалогообложению = ПараметрыДанных.ДоходыНеПодлежащиеНалогообложению;
	КомпонентыЕП = Неопределено;
	
	Если НЕ ОписаниеДокумента.КомпонентыЕПИмя = Неопределено Тогда
		КомпонентыЕП = ПараметрыДанных.КомпонентыЕП;	
	КонецЕсли;
	
	Если НЕ ОтборСтрок = Неопределено
		И ОтборСтрок.Свойство("ВидНалогаВзносаОтчисления") Тогда
		
		ВидНалогаВзносаОтчисления = ОтборСтрок.ВидНалогаВзносаОтчисления;
		
	Иначе
		
		ВидНалогаВзносаОтчисления = Неопределено;
		
	КонецЕсли;
	
	МаксимальныйИдентификаторСтрокиНВО = УчетНалоговВзносовОтчислений.МаксимальныйИдентификаторСтрокиНалогиВзносыОтчисления(ОбновляемаяКоллекцияНВО);
	
	// Заполняем строки идентификатором увеличенным на единицу, относительно максимального.
	УчетНалоговВзносовОтчислений.НазначитьИдентификаторыНовымСтрокамТаблицамНалогиВзносыОтчисленияИВычетыИПН(
		МаксимальныйИдентификаторСтрокиНВО + 1, НалогиВзносыОтчисления, ВычетыИПН, КомпонентыЕП);
			
	УсловияЗаменыСтрок = Неопределено;
	
	// Сохранение идентификаторов заменяемых строк НалогиВзносыОтчисления.
	ИдентификаторыСтрокНВО = Новый Массив;
	
	Если ОтборСтрок = Неопределено Тогда
		ЗаменяемыеСтрокиНВО = ОбновляемаяКоллекцияНВО;
	Иначе
		ЗаменяемыеСтрокиНВО = РасчетЗарплатыРасширенный.НайтиСтрокиОтборПоМассиву(ОбновляемаяКоллекцияНВО, "ФизическоеЛицо", ОтборСтрок.ФизическоеЛицо);
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ИдентификаторыСтрокНВО, 
		ОбщегоНазначения.ВыгрузитьКолонку(ЗаменяемыеСтрокиНВО, "ИдентификаторСтрокиНалогиВзносыОтчисления"));
		
	// Обновление строк таблицы НалогиВзносыОтчисления.
	Если СохранятьИсправления Тогда
		УсловияЗаменыСтрок = РасчетЗарплатыРасширенный.УсловияЗаменыСтрокКонтролируемымиПолями(КонтролируемыеПоля, ОписаниеДокумента.НалогиВзносыОтчисленияИмя);
	КонецЕсли;
	
	// Таблица ПримененныеВычеты, является расширением строк таблицы НалогиВзносыОтчисления,
	// поэтому замена строк в таблицы ПримененныеВычеты, должна выполняться на тех же условиях, что
	// и замена строк таблицы НалогиВзносыОтчисления.
	
	// Сбор информации об идентификаторах строка НалогиВзносыОтчисления принимающих участие в замене.
	ИдентификаторыСтрокНВОУчаствующихВЗамене = ОбщегоНазначения.ВыгрузитьКолонку(ЗаменяемыеСтрокиНВО, "ИдентификаторСтрокиНалогиВзносыОтчисления");
	
	РасчетЗарплатыРасширенный.ЗаменитьСтрокиНаНовыеДанные(ОбновляемаяКоллекцияНВО, НалогиВзносыОтчисления, КлючевыеКолонки, УсловияЗаменыСтрок, ОтборСтрок);
	
	Если НЕ ОписаниеДокумента.ВычетыИПНИмя = Неопределено
		И ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ИПН Тогда
		
		// Удаление из коллекции ИдентификаторыСтрокНВОУчаствующихВЗамене, идентификаторов
		// строк, не подвергшихся замене, добавление в коллекцию идентификаторов 
		// новых строк НалогиВзносыОтчисления.
		
		Если ОтборСтрок = Неопределено Тогда
			ЗаменяемыеСтрокиНВО = ОбновляемаяКоллекцияНВО;
		Иначе
			ЗаменяемыеСтрокиНВО = РасчетЗарплатыРасширенный.НайтиСтрокиОтборПоМассиву(ОбновляемаяКоллекцияНВО, "ФизическоеЛицо", ОтборСтрок.ФизическоеЛицо);
		КонецЕсли;
		
		ОбновленныеИдентификаторыСтрокНВОУчаствующихВЗамене = ОбщегоНазначения.ВыгрузитьКолонку(ЗаменяемыеСтрокиНВО, "ИдентификаторСтрокиНалогиВзносыОтчисления");
		Для каждого ИдентификаторСтрокиНВО Из ОбновленныеИдентификаторыСтрокНВОУчаствующихВЗамене Цикл
			
			ИндексЭлемента = ИдентификаторыСтрокНВОУчаствующихВЗамене.Найти(ИдентификаторСтрокиНВО);
			Если ИндексЭлемента = Неопределено Тогда
				ИдентификаторыСтрокНВОУчаствующихВЗамене.Добавить(ИдентификаторСтрокиНВО);
			Иначе
				ИдентификаторыСтрокНВОУчаствующихВЗамене.Удалить(ИндексЭлемента);
			КонецЕсли;
			
		КонецЦикла;
			
		// Обновление строк таблицы ПримененныеВычеты.
		РасчетЗарплатыРасширенный.ЗаменитьСтрокиНаНовыеДанные(
			ОбновляемаяКоллекцияВычетыИПН, 
			ВычетыИПН, 
			"ИдентификаторСтрокиНалогиВзносыОтчисления", , 
			Новый Структура("ИдентификаторСтрокиНалогиВзносыОтчисления", ИдентификаторыСтрокНВОУчаствующихВЗамене));
			
	КонецЕсли;
	
	Если НЕ ОписаниеДокумента.КомпонентыЕПИмя = Неопределено
		И ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ЕП Тогда

		// Удаление из коллекции ИдентификаторыСтрокНВОУчаствующихВЗамене, идентификаторов
		// строк, не подвергшихся замене, добавление в коллекцию идентификаторов 
		// новых строк НалогиВзносыОтчисления.
		
		Если ОтборСтрок = Неопределено Тогда
			ЗаменяемыеСтрокиНВО = ОбновляемаяКоллекцияНВО;
		Иначе
			ЗаменяемыеСтрокиНВО = РасчетЗарплатыРасширенный.НайтиСтрокиОтборПоМассиву(ОбновляемаяКоллекцияНВО, "ФизическоеЛицо", ОтборСтрок.ФизическоеЛицо);
		КонецЕсли;
		
		ОбновленныеИдентификаторыСтрокНВОУчаствующихВЗамене = ОбщегоНазначения.ВыгрузитьКолонку(ЗаменяемыеСтрокиНВО, "ИдентификаторСтрокиНалогиВзносыОтчисления");
		Для каждого ИдентификаторСтрокиНВО Из ОбновленныеИдентификаторыСтрокНВОУчаствующихВЗамене Цикл
			
			ИндексЭлемента = ИдентификаторыСтрокНВОУчаствующихВЗамене.Найти(ИдентификаторСтрокиНВО);
			Если ИндексЭлемента = Неопределено Тогда
				ИдентификаторыСтрокНВОУчаствующихВЗамене.Добавить(ИдентификаторСтрокиНВО);
			Иначе
				ИдентификаторыСтрокНВОУчаствующихВЗамене.Удалить(ИндексЭлемента);
			КонецЕсли;
			
		КонецЦикла;
			
		Если НЕ КомпонентыЕП = Неопределено Тогда	
			// Обновление строк таблицы КомпонентыЕП.
			РасчетЗарплатыРасширенный.ЗаменитьСтрокиНаНовыеДанные(
				ОбновляемаяКоллекцияКомпонентыЕП, 
				КомпонентыЕП, 
				"ИдентификаторСтрокиНалогиВзносыОтчисления", , 
				Новый Структура("ИдентификаторСтрокиНалогиВзносыОтчисления", ИдентификаторыСтрокНВОУчаствующихВЗамене));
		КонецЕсли;
			
	КонецЕсли;
	
	Если НЕ ОписаниеДокумента.ДоходыНеПодлежащиеНалогообложениюИмя = Неопределено Тогда
		
		// Удаление из коллекции ИдентификаторыСтрокНВОУчаствующихВЗамене, идентификаторов
		// строк, не подвергшихся замене, добавление в коллекцию идентификаторов 
		// новых строк НалогиВзносыОтчисления.
		
		// Обновление строк таблицы ДоходыНеПодлежащиеНалогообложениюИмя.
		РасчетЗарплатыРасширенный.ЗаменитьСтрокиНаНовыеДанные(
			ОбновляемаяКоллекцияДНН, 
			ДоходыНеПодлежащиеНалогообложению,
            КлючевыеКолонки, ,
            ОтборСтрок);
			
	КонецЕсли;
	
КонецПроцедуры

Функция КонтролируемыеПоляДляФиксацииРезультатов() Экспорт

	НалогиВзносыОтчисленияФиксРасчет = Новый Массив;
	НалогиВзносыОтчисленияФиксРасчет.Добавить("Налог");
	НалогиВзносыОтчисленияФиксРасчет.Добавить("ЗачтеноАвансовыхПлатежей");
	НалогиВзносыОтчисленияФиксРасчет.Добавить("НалогКЗачетуВозврату");
	НалогиВзносыОтчисленияФиксРасчет.Добавить("ПримененныйВычетЛичный");
	НалогиВзносыОтчисленияФиксРасчет.Добавить("ПримененныйВычетЛичныйКодВычета");
	НалогиВзносыОтчисленияФиксРасчет.Добавить("ПримененныйВычетЛичныйКЗачетуВозврату");
	НалогиВзносыОтчисленияФиксРасчет.Добавить("ПримененныйВычетЛичныйКЗачетуВозвратуКодВычета");

	НалогиВзносыОтчисленияФиксСтрока = Новый Массив;
	НалогиВзносыОтчисленияФиксСтрока.Добавить("ФизическоеЛицо");
	НалогиВзносыОтчисленияФиксСтрока.Добавить("МесяцНалоговогоПериода");
	НалогиВзносыОтчисленияФиксСтрока.Добавить("Подразделение");
	
	Возврат Новый Структура("ФиксРасчет, ФиксСтрока", НалогиВзносыОтчисленияФиксРасчет, НалогиВзносыОтчисленияФиксСтрока)
	
КонецФункции

Процедура ЗаполнитьТаблицуСтавкиНалоговВзносовОтчисленийДляОценочныхОбязательств(ТаблицаСтавкиНалоговВзносовОтчислений, Организация,ПериодРегистрации) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	// Заполняем ставки
    УчетНалоговВзносовОтчислений.ЗаполнитьТаблицуСтавкиНалоговВзносовОтчисленийДляОценочныхОбязательств(ТаблицаСтавкиНалоговВзносовОтчислений, Организация, ПериодРегистрации);
	
	УстановитьПривилегированныйРежим(Ложь);
			
КонецПроцедуры

Процедура ПроверитьЗаполнениеИсправленногоДокумента(Объект, ПроверяемыеРеквизиты, Отказ, ПолеПериодРегистрации, ПериодРегистрацииИсправленногоДокумента) Экспорт
	
	Если ПериодРегистрацииИсправленногоДокумента <> НеОпределено Тогда
		
		ПорядокОбложенияДоходовРаботников = ЗарплатаКадрыРКПовтИсп.ПорядокОбложенияДоходовРаботников(Объект.Организация, Объект[ПолеПериодРегистрации]);
		
		Если ПорядокОбложенияДоходовРаботников = Перечисления.ПорядокОбложенияДоходовРаботников.ЕдиныйПлатеж Тогда
		
			// Если допустимо исправление в текущем периоде
			Если НЕ ПериодРегистрацииИсправленногоДокумента = Объект[ПолеПериодРегистрации] Тогда
				ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'При едином платеже не рекомендуется производить исправление в последующих периодах. Если единый платеж за исправляемый период был перечислен, данные корректировок документа-исправления могут отличаться от фактического распределения сумм Госкорпорацией'"),
					Формат(ПериодРегистрацииИсправленногоДокумента, "ДФ='ММММ гггг'"));
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,ПолеПериодРегистрации);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;

КонецПроцедуры

Функция ПолучитьСтатусРезидентства(МесяцНачисления, СотрудникФизическоеЛицо)
	
	Если ТипЗнч(СотрудникФизическоеЛицо) = Тип("СправочникСсылка.Сотрудники") Тогда
		ФизическоеЛицо = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СотрудникФизическоеЛицо, "ФизическоеЛицо");	
	Иначе
		ФизическоеЛицо = СотрудникФизическоеЛицо;	
	КонецЕсли;
	
	СтатусФизическихЛицКакНалогоплательщиков = РегистрыСведений.СтатусФизическихЛицКакНалогоплательщиков.СрезПоследних(МесяцНачисления, Новый Структура("ФизическоеЛицо", ФизическоеЛицо));
	
	Если СтатусФизическихЛицКакНалогоплательщиков.Количество() > 0 Тогда
		Статус = СтатусФизическихЛицКакНалогоплательщиков[0].Статус;
	Иначе
		Статус = Перечисления.СтатусыФизическихЛицНалогоплательщиков.ПустаяСсылка();
	КонецЕсли;
		
	Возврат Статус;
		
КонецФункции

Процедура ПроставитьРегистрациюВНалоговомОрганеВТаблице(Организация, ТаблицаДанных, ДатаАктуальности) Экспорт

	Если ТаблицаДанных.Колонки.Найти("Подразделение") = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТаблицаДанных.Колонки.Найти("РегистрацияВНалоговомОргане") = Неопределено Тогда
		ТаблицаДанных.Колонки.Добавить("РегистрацияВНалоговомОргане", Новый ОписаниеТипов("СправочникСсылка.РегистрацииВНалоговомОргане"));
	КонецЕсли;
	
	СоответствиеПодразделенийИРегистраций = ПолучитьРегистрацииПодразделенийВНалоговомОргане(ТаблицаДанных.ВыгрузитьКолонку("Подразделение"), ДатаАктуальности);
	РегистрацияВНалоговомОргане = ЗарплатаКадры.РегистрацияВНалоговомОргане(Организация, ДатаАктуальности);
	
	Для Каждого СтрокаДанных Из ТаблицаДанных Цикл
		УчетНалоговВзносовОтчислений.ПроставитьРегистрациюВНалоговомОрганеВСтроке(СтрокаДанных, СоответствиеПодразделенийИРегистраций.Получить(СтрокаДанных.Подразделение), РегистрацияВНалоговомОргане);
	КонецЦикла;

КонецПроцедуры

Функция ПолучитьРегистрацииПодразделенийВНалоговомОргане(Подразделения, ДатаАктуальности = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(ДатаАктуальности) Тогда
		ДатаАктуальности = '00010101'
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаАктуальности", ДатаАктуальности);
	Запрос.УстановитьПараметр("МассивСсылок", Подразделения);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ИсторияРегистрацийВНалоговомОрганеСрезПоследних.СтруктурнаяЕдиница КАК Ссылка,
	|	ИсторияРегистрацийВНалоговомОрганеСрезПоследних.РегистрацияВНалоговомОргане
	|ИЗ
	|	РегистрСведений.ИсторияРегистрацийВНалоговомОргане.СрезПоследних(&ДатаАктуальности, СтруктурнаяЕдиница В (&МассивСсылок)) КАК ИсторияРегистрацийВНалоговомОрганеСрезПоследних";
	
	СоответствиеРегистраций = Новый Соответствие;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		СоответствиеРегистраций.Вставить(Выборка.Ссылка, Выборка.РегистрацияВНалоговомОргане);		
	КонецЦикла;	
	Возврат СоответствиеРегистраций;
КонецФункции	

#КонецОбласти

#Область РедактированиеВФормахДокументов

Процедура ОбъектПриЧтенииНаСервере(Форма, Организация, МесяцНачисления, ДобавлятьЭлементыФормы = Истина, ДобавлятьРеквизитыФормы = Истина, ОтложенноеИзменение = Ложь) Экспорт
	
	Объект = Форма.Объект;
	
	ПорядокОбложенияДоходовРаботников = ЗарплатаКадрыРКПовтИсп.ПорядокОбложенияДоходовРаботников(Организация, МесяцНачисления);
	
	Сотрудник = Неопределено;
	
	Если Форма.Объект.Свойство("Сотрудник", Сотрудник) Тогда
		
		Нерезидент = (ПолучитьСтатусРезидентства(МесяцНачисления, Сотрудник) = Перечисления.СтатусыФизическихЛицНалогоплательщиков.Нерезидент);
		Форма.Нерезидент = Нерезидент;
		
	КонецЕсли;
	
	// Доозначиваем то, что не означили в случае отложенного создания.
	Форма.ОрганизацияПорядокОбложенияДоходовРаботников = ПорядокОбложенияДоходовРаботников;

КонецПроцедуры

Процедура ОбработатьИзменениеОрганизации(Форма, Организация, МесяцНачисления) Экспорт
	
	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьРасчетЗарплатыРасширенная") Тогда 
		Возврат;
	КонецЕсли;
	
	ПорядокОбложенияДоходовРаботников = ЗарплатаКадрыРКПовтИсп.ПорядокОбложенияДоходовРаботников(Организация, МесяцНачисления);
	
	// Доозначиваем то, что не означили в случае отложенного создания.
	Форма.ОрганизацияПорядокОбложенияДоходовРаботников = ПорядокОбложенияДоходовРаботников;
	
КонецПроцедуры

Процедура ОбработатьИзменениеМесяцНачисления(Форма, Организация, МесяцНачисления) Экспорт
	
	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьРасчетЗарплатыРасширенная") Тогда
		Возврат;
	КонецЕсли;
	
	Объект = Форма.Объект;
	
	Сотрудник = Неопределено;
	
	Если Форма.Объект.Свойство("Сотрудник", Сотрудник) Тогда
		
		Нерезидент = (ПолучитьСтатусРезидентства(МесяцНачисления, Сотрудник) = Перечисления.СтатусыФизическихЛицНалогоплательщиков.Нерезидент);
		Форма.Нерезидент = Нерезидент;
		
	КонецЕсли;
	
	ПорядокОбложенияДоходовРаботников = ЗарплатаКадрыРКПовтИсп.ПорядокОбложенияДоходовРаботников(Организация, МесяцНачисления);
	
	// Доозначиваем то, что не означили в случае отложенного создания.
	Форма.ОрганизацияПорядокОбложенияДоходовРаботников = ПорядокОбложенияДоходовРаботников;
	
КонецПроцедуры

Процедура ОбработатьИзменениеСотрудника(Форма, МесяцНачисления) Экспорт
	
	Если НЕ ПолучитьФункциональнуюОпцию("ИспользоватьРасчетЗарплатыРасширенная") Тогда 
		Возврат;
	КонецЕсли;
	
	Объект = Форма.Объект;
	
	Сотрудник = Неопределено;
	
	Если Форма.Объект.Свойство("Сотрудник", Сотрудник) Тогда
		
		Нерезидент = (ПолучитьСтатусРезидентства(МесяцНачисления, Сотрудник) = Перечисления.СтатусыФизическихЛицНалогоплательщиков.Нерезидент);
		Форма.Нерезидент = Нерезидент;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ВспомогательныеФункцииИПроцедуры

Функция МетаданныеРегистровПодсистемы()
	
	Регистры = Новый Массив;
	Регистры.Добавить(Метаданные.РегистрыНакопления.НалогиВзносыОтчисленияРасчетыСБюджетомИФондами);
	Регистры.Добавить(Метаданные.РегистрыНакопления.СведенияОбИсчисленииНалоговВзносовОтчислений);
	Регистры.Добавить(Метаданные.РегистрыНакопления.СведенияОДоходахФизическихЛиц);
	Регистры.Добавить(Метаданные.РегистрыНакопления.СведенияОНеоблагаемыхДоходахФизическихЛиц);
	Регистры.Добавить(Метаданные.РегистрыНакопления.СведенияОбИсчисленииВычетовИПН);
	
	Возврат Регистры;
	
КонецФункции

#КонецОбласти