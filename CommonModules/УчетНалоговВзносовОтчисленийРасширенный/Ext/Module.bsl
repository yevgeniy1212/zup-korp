#Область СлужебныйПрограммныйИнтерфейс

//См. РасчетЗарплатыРасширенный.СоздатьДанныеДляПроведенияНачисленияЗарплаты
Процедура ДополнитьПоляСтруктурыДляПроведения(ПоляСтруктуры) Экспорт
	
	ПоляСтруктуры = ПоляСтруктуры + ",
		|НалогиВзносыОтчисления,
		|ДоходыНеПодлежащиеНалогообложению,
		|ВычетыИПН,
		|КомпонентыЕП";
	
КонецПроцедуры

//См. РасчетЗарплатыРасширенный.СоздатьДанныеДляПроведенияНачисленияЗарплаты
Процедура ДополнитьОписаниеДанныхДляПроведения(ДанныеДляПроведения) Экспорт
	
	ДанныеДляПроведения.Вставить("СведенияОбИсчисленииНалоговВзносовОтчислений");
	ДанныеДляПроведения.Вставить("НалогиВзносыОтчисленияРасчетыСБюджетомИФондами");
	ДанныеДляПроведения.Вставить("СведенияОНеоблагаемыхДоходахФизическихЛиц");
	ДанныеДляПроведения.Вставить("СведенияОбИсчисленииВычетовИПН");
	ДанныеДляПроведения.Вставить("ЕПКомпоненты");
	
КонецПроцедуры

//См. РасчетЗарплатыРасширенный.ОписаниеДанныхДляЗаполненияТаблицДокумента
Процедура ДополнитьОписаниеДанныхДляЗаполненияТаблицДокумента(ДанныеЗаполнения) Экспорт
	
	ДанныеЗаполнения.Вставить("НалогиВзносыОтчисления",Новый ТаблицаЗначений);
	ДанныеЗаполнения.Вставить("ДоходыНеПодлежащиеНалогообложению",Новый ТаблицаЗначений);
	ДанныеЗаполнения.Вставить("ВычетыИПН",Новый ТаблицаЗначений);
	ДанныеЗаполнения.Вставить("КомпонентыЕП",Новый ТаблицаЗначений);
	
КонецПроцедуры

// Обход очистки нескольких или всех (Ctrl + A) строк в документах прочих доходов ЗУП РФ
Процедура ОчиститьДанныеНВОВДокументахПрочихДоходов(Объект, РежимЗаписи) Экспорт

	Если НЕ РежимЗаписи = РежимЗаписиДокумента.Проведение Тогда
		Возврат;	
	КонецЕсли;

	Если ЗарплатаКадрыРКПовтИсп.ЭтоКонфигурацияЗарплатногоУчета() Тогда
		ИмяДокументаДивиденды = "ДивидендыФизическимЛицам";	
	Иначе
		ИмяДокументаДивиденды = "НачислениеДивидендов";	
	КонецЕсли;
	
	Если ТипЗнч(Объект) = Тип("ДокументОбъект.РегистрацияПрочихДоходов")
		 ИЛИ ТипЗнч(Объект) = Тип("ДокументОбъект.ВыплатаБывшимСотрудникам") Тогда
		 
		 ИмяТабличнойЧастиПоиска = "НачисленияУдержанияВзносы";	
		 ИмяПоляПоиска = "ФизическоеЛицо";
		
	ИначеЕсли ТипЗнч(Объект) = Тип("ДокументОбъект." + ИмяДокументаДивиденды) Тогда
		
		Если ЗарплатаКадрыРКПовтИсп.ЭтоКонфигурацияЗарплатногоУчета() Тогда
			
			ИмяТабличнойЧастиПоиска = "Начисления";	
			ИмяПоляПоиска = "Акционер";
			
		Иначе
			
			ИмяТабличнойЧастиПоиска = "ФизическиеЛица";	
			ИмяПоляПоиска = "ФизическоеЛицо";
			
		КонецЕсли;
		
	КонецЕсли;
	
	СтруктураОтбора = Новый Структура(ИмяПоляПоиска);
	
	ФизическиеЛицаПрошедшиеПроверку = Новый Массив;
	
	ФизическиеЛицаКУдалению = Новый Массив;
	
	Если Объект.НалогиВзносыОтчисления.Количество() > 0 Тогда 
		
		Для Каждого СтрокаНВО Из Объект.НалогиВзносыОтчисления Цикл
			
			Если ФизическиеЛицаПрошедшиеПроверку.Найти(СтрокаНВО.ФизическоеЛицо) = Неопределено Тогда
				
				ФизическиеЛицаПрошедшиеПроверку.Добавить(СтрокаНВО.ФизическоеЛицо);
				
			Иначе
				
				Продолжить;
				
			КонецЕсли;
			
			СтруктураОтбора[ИмяПоляПоиска] = СтрокаНВО.ФизическоеЛицо;
			МассивСтрокНВО = Объект[ИмяТабличнойЧастиПоиска].НайтиСтроки(СтруктураОтбора);
			
			Если МассивСтрокНВО.Количество() = 0 Тогда
				
				ФизическиеЛицаКУдалению.Добавить(СтрокаНВО.ФизическоеЛицо);
				
			КонецЕсли;
			
		КонецЦикла;
	
	    СтруктураПоискаДНПН = Новый Структура("ФизическоеЛицо");

		Для Каждого ФизическоеЛицо Из ФизическиеЛицаКУдалению Цикл
			
			СтруктураПоискаДНПН.ФизическоеЛицо = ФизическоеЛицо;
	        МассивСтрокНеоблагаемые = Объект.ДоходыНеПодлежащиеНалогообложению.НайтиСтроки(СтруктураПоискаДНПН);
			
			Если МассивСтрокНеоблагаемые.Количество() > 0 Тогда
				
				Для Каждого СтрокаНеоблагаемые Из МассивСтрокНеоблагаемые Цикл
					Объект.ДоходыНеПодлежащиеНалогообложению.Удалить(СтрокаНеоблагаемые);	
				КонецЦикла;
				
			КонецЕсли;
			
			УчетНалоговВзносовОтчисленийРасширенный.УдалитьДанныеПоНалогамВзносамОтчислениямФизическоголица(Объект, ФизическоеЛицо);
			
		КонецЦикла;
		
	Иначе
		
		Объект.ДоходыНеПодлежащиеНалогообложению.Очистить();
		Объект.ВычетыИПН.Очистить();
		
	КонецЕсли;
	
КонецПроцедуры

Функция РассчитатьНалогиВзносыОтчисления(ОкончательныйРасчетЗарплаты, НаборыЗаписей,Организация,ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, Начисления, ДоговорыПодряда, УдалитьВТ, ИсправленныйДокумент = Неопределено, ДоходыНеПодлежащиеНалогообложению = Неопределено) Экспорт
	
	РезультатРасчетаНалоговВзносовОтчислений = РезультатРасчетаНалоговВзносовОтчислений(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты, ДоходыНеПодлежащиеНалогообложению);
	
	Возврат РезультатРасчетаНалоговВзносовОтчислений;
	
КонецФункции

Функция СформироватьСведенияОДоходах(ОкончательныйРасчетЗарплаты, НаборыЗаписей,Организация,ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, Начисления, ДоговорыПодряда, УдалитьВТ, ИсправленныйДокумент = Неопределено) Экспорт
	
	СоздатьВТНачисленияДляРассчетаНалоговВзносовОтчислений(Начисления, МенеджерВременныхТаблиц, УдалитьВТ, ДокументСсылка, ИсправленныйДокумент);
	СоздатьВТДоговорыПодрядаДляРассчетаНалоговВзносовОтчислений(ДоговорыПодряда, МенеджерВременныхТаблиц, УдалитьВТ, ДокументСсылка);
	
	УчетНалоговВзносовОтчислений.СформироватьСведенияОДоходах(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты, НаборыЗаписей);
	ЗарплатаКадры.СоздатьВТПоНаборуЗаписей(МенеджерВременныхТаблиц, НаборыЗаписей.СведенияОДоходахФизическихЛиц, Истина);
	
	УчетНалоговВзносовОтчислений.ПодготовитьДанныеДляРасчетаНалоговВзносов(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты);
	
	// Расчитать необлагаемые доходы начислений
	ДоходыНеПодлежащиеНалогообложению = УчетНалоговВзносовОтчислений.РассчитатьНеоблагаемыеДоходы(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты);
	ЗарплатаКадры.СоздатьВТПоНаборуЗаписей(МенеджерВременныхТаблиц, НаборыЗаписей.СведенияОНеоблагаемыхДоходахФизическихЛиц, Истина);

	Возврат ДоходыНеПодлежащиеНалогообложению;
	
КонецФункции 

Процедура СоздатьВТНачисленияДляРассчетаНалоговВзносовОтчислений(Начисления, МенеджерВременныхТаблиц, УдалитьВТ, ДокументСсылка, ИсправленныйДокумент)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Начисления", Начисления);
	МетаданныеДокумента = ДокументСсылка.Метаданные();
	Если ЗначениеЗаполнено(ИсправленныйДокумент) Тогда
		Запрос.УстановитьПараметр("ИсправленныйДокумент", ИсправленныйДокумент);
	ИначеЕсли ОбщегоНазначения.ЕстьРеквизитОбъекта("ИсправленныйДокумент", МетаданныеДокумента) Тогда
		ИсправленныйДокументСсылка = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка,"ИсправленныйДокумент");
		Если ЗначениеЗаполнено(ИсправленныйДокументСсылка) Тогда
			Запрос.УстановитьПараметр("ИсправленныйДокумент", ИсправленныйДокументСсылка);
		Иначе 
			Запрос.УстановитьПараметр("ИсправленныйДокумент", Документы[МетаданныеДокумента.Имя].ПустаяСсылка())
		КонецЕсли;
	Иначе	
		Запрос.УстановитьПараметр("ИсправленныйДокумент", Документы[МетаданныеДокумента.Имя].ПустаяСсылка())
	КонецЕсли;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Начисления.Сотрудник КАК Сотрудник,
	|	Начисления.ФизическоеЛицо КАК ФизическоеЛицо,
	|	Начисления.Начисление КАК Начисление,
	|	Начисления.ДатаНачала КАК ДатаНачала,
	|	ВЫБОР
	|		КОГДА Начисления.Сторно
	|				ИЛИ Начисления.ФиксСторно
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Сторно,
	|	Начисления.СторнируемыйДокумент КАК СторнируемыйДокумент,
	|	Начисления.Результат КАК СуммаДохода,
	|	Начисления.Подразделение КАК Подразделение
	|ПОМЕСТИТЬ ВТНачисленияТаблица
	|ИЗ
	|	&Начисления КАК Начисления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТНачисленияТаблица.Сотрудник КАК Сотрудник,
	|	ВТНачисленияТаблица.ФизическоеЛицо КАК ФизическоеЛицо,
	|	ВТНачисленияТаблица.Начисление КАК Начисление,
	|	ВТНачисленияТаблица.ДатаНачала КАК ДатаНачала,
	|	ВТНачисленияТаблица.Сторно КАК Сторно,
	|	ВТНачисленияТаблица.СторнируемыйДокумент КАК СторнируемыйДокумент,
	|	ВТНачисленияТаблица.СуммаДохода КАК СуммаДохода,
	|	&ИсправленныйДокумент КАК ИсправленныйДокумент,
	|	ВТНачисленияТаблица.Подразделение КАК Подразделение
	|ПОМЕСТИТЬ ВТНачисления
	|ИЗ
	|	ВТНачисленияТаблица КАК ВТНачисленияТаблица";
	
	Запрос.Выполнить();
	УдалитьВТ.Добавить("ВТНачисленияТаблица");
	УдалитьВТ.Добавить("ВТНачисления");
	
КонецПроцедуры

Процедура СоздатьВТДоговорыПодрядаДляРассчетаНалоговВзносовОтчислений(ДоговорыПодряда, МенеджерВременныхТаблиц, УдалитьВТ, ДокументСсылка)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ДоговорыПодряда", ДоговорыПодряда);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НачисленияПоДоговорам.ФизическоеЛицо КАК ФизическоеЛицо,
	|	НачисленияПоДоговорам.Результат КАК Сумма,
	|	НачисленияПоДоговорам.Подразделение,
	|	НачисленияПоДоговорам.Сотрудник,
	|	НачисленияПоДоговорам.ВидДохода
	|ПОМЕСТИТЬ ВТНачисленияПоДоговорам
	|ИЗ
	|	&ДоговорыПодряда КАК НачисленияПоДоговорам";
	
	Запрос.Выполнить();
	УдалитьВТ.Добавить("ВТНачисленияПоДоговорам");
	
КонецПроцедуры

Функция РезультатРасчетаНалоговВзносовОтчислений(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты = Истина, ДоходыНеПодлежащиеНалогообложению = Неопределено)
	
	УстановитьПривилегированныйРежим(Истина);
	
	// ОПВ
	РезультатРасчетаОПВ = РезультатРасчетаОПВ(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты);
	
	Если ЗарплатаКадрыРКПовтИсп.ПрименятьКорректировкуПрочихНалоговВзносовОтчислений(ЗарплатаКадрыПовтИсп.ГоловнаяОрганизация(Организация), МесяцНачисления) Тогда
		
		Если ЗарплатаКадрыРКПовтИсп.ПрименятьВычетОПВиВОСМСДляГПХ(ЗарплатаКадрыПовтИсп.ГоловнаяОрганизация(Организация), МесяцНачисления) Тогда
			ДополнительныеПараметры = Новый Структура;
			ДополнительныеПараметры.Вставить("ТолькоДоходОтНалоговогоАгента", Истина);
			УчетНалоговВзносовОтчислений.РассчитатьВОСМСПосле2020(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты,, ДополнительныеПараметры);	
			ДополнительныеПараметры.Удалить("ТолькоДоходОтНалоговогоАгента");
		КонецЕсли;		
		
		Если ОкончательныйРасчетЗарплаты Тогда
			РезультатРасчетаСО = РезультатРасчетаСО(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты);
		ИначеЕсли Тип("ДокументСсылка.НачислениеПоДоговорам") = ТипЗнч(ДокументСсылка) Тогда
			РезультатРасчетаСО = РезультатРасчетаСО(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты);
		КонецЕсли;
		
		РезультатРасчетаИПН = РезультатРасчетаИПН(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты);
		РезультатРасчетаВОСМС = РезультатРасчетаВОСМС(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты);

	Иначе
		
		РезультатРасчетаВОСМС = РезультатРасчетаВОСМС(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты);

		Если ОкончательныйРасчетЗарплаты Тогда
			РезультатРасчетаСО = РезультатРасчетаСО(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты);
		ИначеЕсли Тип("ДокументСсылка.НачислениеПоДоговорам") = ТипЗнч(ДокументСсылка) Тогда
			РезультатРасчетаСО = РезультатРасчетаСО(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты);
		КонецЕсли;

		РезультатРасчетаИПН = РезультатРасчетаИПН(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты);

	КонецЕсли;
		
	НалогиВзносыОтчисления = РезультатРасчетаИПН.ИПН.СкопироватьКолонки();
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(РезультатРасчетаИПН.ИПН, НалогиВзносыОтчисления);
	
	УчетНалоговВзносовОтчислений.ДополнитьТаблицуНалогиВзносыОтчисления(РезультатРасчетаОПВ.ОПВ, НалогиВзносыОтчисления);
	
	Если РезультатРасчетаВОСМС <> Неопределено Тогда
		УчетНалоговВзносовОтчислений.ДополнитьТаблицуНалогиВзносыОтчисления(РезультатРасчетаВОСМС.ВОСМС, НалогиВзносыОтчисления);
	КонецЕсли;	

	// Налоги, взносы и отчисления за счет работодателя расчитываются 
	// только при окончательном расчете начислений
	// только в документе "Начисление зарплаты" и "Увольнение"
	Если ОкончательныйРасчетЗарплаты Тогда
		// СО
		УчетНалоговВзносовОтчислений.ДополнитьТаблицуНалогиВзносыОтчисления(РезультатРасчетаСО.СО, НалогиВзносыОтчисления);
		// СН
		РезультатРасчетаСН = РезультатРасчетаСН(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты);
		УчетНалоговВзносовОтчислений.ДополнитьТаблицуНалогиВзносыОтчисления(РезультатРасчетаСН.СН, НалогиВзносыОтчисления);
		// ОППВ
		Если ПолучитьФункциональнуюОпцию("ПлательщикОППВЗарплатаКадры", Новый Структура("Организация", Организация)) Тогда
			РезультатРасчетаОППВ = РезультатРасчетаОППВ(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты);
			УчетНалоговВзносовОтчислений.ДополнитьТаблицуНалогиВзносыОтчисления(РезультатРасчетаОППВ.ОППВ, НалогиВзносыОтчисления);
		КонецЕсли;
		//ООСМС
		РезультатРасчетаООСМС = РезультатРасчетаООСМС(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты);
		Если РезультатРасчетаООСМС <> Неопределено Тогда
			УчетНалоговВзносовОтчислений.ДополнитьТаблицуНалогиВзносыОтчисления(РезультатРасчетаООСМС.ООСМС, НалогиВзносыОтчисления);
		КонецЕсли;
		// ОПВР
		РезультатРасчетаОПВР = РезультатРасчетаОПВР(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты);
		Если РезультатРасчетаОПВР <> Неопределено Тогда
			УчетНалоговВзносовОтчислений.ДополнитьТаблицуНалогиВзносыОтчисления(РезультатРасчетаОПВР.ОПВР, НалогиВзносыОтчисления);
		КонецЕсли;

	ИначеЕсли Тип("ДокументСсылка.НачислениеПоДоговорам") = ТипЗнч(ДокументСсылка) Тогда
		
		// СО
		УчетНалоговВзносовОтчислений.ДополнитьТаблицуНалогиВзносыОтчисления(РезультатРасчетаСО.СО, НалогиВзносыОтчисления);
		
	КонецЕсли;
	
	// ЕП
	ПорядокОбложенияДоходовРаботников = ЗарплатаКадрыРКПовтИсп.ПорядокОбложенияДоходовРаботников(Организация, МесяцНачисления);
	
	Если ПорядокОбложенияДоходовРаботников = Перечисления.ПорядокОбложенияДоходовРаботников.ЕдиныйПлатеж Тогда
		
		РезультатРасчетаЕП = РезультатРасчетаЕП(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты);
		
		Если РезультатРасчетаЕП <> Неопределено Тогда
			УчетНалоговВзносовОтчислений.ДополнитьТаблицуНалогиВзносыОтчисления(РезультатРасчетаЕП.ЕП, НалогиВзносыОтчисления, РезультатРасчетаЕП.КомпонентыЕП);
		КонецЕсли;
		
	КонецЕсли;

	УстановитьПривилегированныйРежим(Ложь);
	
	// Упорядочим таблицу налогов, взносов и отчислений по тем же правилам, что и начисления (для этого получаем основных сотрудников).
	Физлица = ОбщегоНазначения.ВыгрузитьКолонку(НалогиВзносыОтчисления, "ФизическоеЛицо", Истина);
	СотрудникиФизическиеЛица = КадровыйУчет.ОсновныеСотрудникиФизическихЛиц(Физлица, Истина, Организация, МесяцНачисления);
	Сотрудники = ОбщегоНазначения.ВыгрузитьКолонку(СотрудникиФизическиеЛица, "Сотрудник", Истина);
	
	// По основным сотрудникам запрашиваем сведения о рабочих местах на конец месяца.
	МенеджерВТУпорядочивания = Новый МенеджерВременныхТаблиц;
	КадровыйУчет.СоздатьНаДатуВТКадровыеДанныеСотрудников(МенеджерВТУпорядочивания, Истина, Сотрудники, "Подразделение,Должность", КонецМесяца(МесяцНачисления));
	
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	КадровыеДанныеСотрудников.Сотрудник,
	|	Сотрудники.ФизическоеЛицо КАК ФизическоеЛицо,
	|	КадровыеДанныеСотрудников.Подразделение,
	|	КадровыеДанныеСотрудников.Должность,
	|	Должности.РеквизитДопУпорядочивания КАК ПорядокДолжности,
	|	Подразделения.РеквизитДопУпорядочивания КАК ПорядокПодразделения,
	|	Сотрудники.Наименование
	|ИЗ
	|	ВТКадровыеДанныеСотрудников КАК КадровыеДанныеСотрудников
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Должности КАК Должности
	|		ПО (Должности.Ссылка = КадровыеДанныеСотрудников.Должность)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ПодразделенияОрганизаций КАК Подразделения
	|		ПО (Подразделения.Ссылка = КадровыеДанныеСотрудников.Подразделение)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК Сотрудники
	|		ПО (Сотрудники.Ссылка = КадровыеДанныеСотрудников.Сотрудник)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ПорядокДолжности,
	|	ПорядокПодразделения,
	|	Сотрудники.Наименование";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.МенеджерВременныхТаблиц = МенеджерВТУпорядочивания;
	Выборка = Запрос.Выполнить().Выбрать();
	
	ПорядокПоФизическимЛицам = Новый Соответствие;
	Порядок = 0;
	Пока Выборка.Следующий() Цикл
		ПорядокПоФизическимЛицам.Вставить(Выборка.ФизическоеЛицо, Порядок);
		Порядок = Порядок + 1;
	КонецЦикла;

    // Добавляем колонки, для обновления изменяемых строк документов
    НалогиВзносыОтчисления.Колонки.Добавить("ФиксРасчет", Новый ОписаниеТипов("Булево"));
	НалогиВзносыОтчисления.Колонки.Добавить("ФиксСтрока", Новый ОписаниеТипов("Булево"));

	// На основе полученного соответствия сортируем строки таблицы.
	НалогиВзносыОтчисления.Колонки.Добавить("ПорядокСтрок");
	Для Каждого Строка Из НалогиВзносыОтчисления Цикл
		Строка.ПорядокСтрок = ПорядокПоФизическимЛицам[Строка.ФизическоеЛицо];
	КонецЦикла;
	НалогиВзносыОтчисления.Сортировать("ПорядокСтрок,МесяцНалоговогоПериода,Подразделение,ВидНалогаВзносаОтчисления");

	СтруктураВозврата = Новый Структура("НалогиВзносыОтчисления, ДоходыНеПодлежащиеНалогообложению, ВычетыИПН, КомпонентыЕП");
	СтруктураВозврата.НалогиВзносыОтчисления = НалогиВзносыОтчисления;
	СтруктураВозврата.ДоходыНеПодлежащиеНалогообложению = ДоходыНеПодлежащиеНалогообложению;
	
	Если НЕ РезультатРасчетаЕП = Неопределено Тогда
		СтруктураВозврата.КомпонентыЕП = РезультатРасчетаЕП.КомпонентыЕП;
	КонецЕсли;
	СтруктураВозврата.ВычетыИПН = РезультатРасчетаИПН.ВычетыИПН;
		
	Возврат СтруктураВозврата;
	
КонецФункции

