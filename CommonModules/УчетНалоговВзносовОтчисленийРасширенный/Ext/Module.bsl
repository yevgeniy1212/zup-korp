//См. РасчетЗарплатыРасширенный.СодержимоеДокументаРасчетаЗарплаты
Процедура ДополнитьСодержимоеДокументаРасчетаЗарплаты(СодержимоеДокумента) Экспорт
	
	СодержимоеДокумента.Вставить("НалогиВзносыОтчисления", ПустаяТаблицаНалогиВзносыОтчисления());
	СодержимоеДокумента.Вставить("ДоходыНеПодлежащиеНалогообложению", ПустаяТаблицаДоходыНеПодлежащиеНалогообложению());
	СодержимоеДокумента.Вставить("ВычетыИПН", ПустаяТаблицаВычетыИПН());
	СодержимоеДокумента.Вставить("КомпонентыЕП", ПустаяТаблицаКомпонентыЕП());
	
КонецПроцедуры

Функция ОписаниеТиповЧисло()

	ОписаниеТиповЧисло = Новый Структура;
	ОписаниеТиповЧисло.Вставить("ТипЧисло15_2", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)));
	ОписаниеТиповЧисло.Вставить("ТипЧисло7_2", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(7, 2)));
	ОписаниеТиповЧисло.Вставить("ТипЧисло15_3", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 3)));
	ОписаниеТиповЧисло.Вставить("ТипЧисло7_0", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(7, 0)));
	ОписаниеТиповЧисло.Вставить("ТипЧисло10_0", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(10, 0)));
	ОписаниеТиповЧисло.Вставить("ТипЧисло12_2", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(12, 2)));
	
	Возврат ОписаниеТиповЧисло;

КонецФункции

Функция ПустаяТаблицаНалогиВзносыОтчисления() Экспорт
	
	ОписаниеТиповЧисло = ОписаниеТиповЧисло();
	
	ТаблицаНалогиВзносыОтчисления = Новый ТаблицаЗначений;
	ТаблицаНалогиВзносыОтчисления.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	ТаблицаНалогиВзносыОтчисления.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	ТаблицаНалогиВзносыОтчисления.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата"));
	ТаблицаНалогиВзносыОтчисления.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов")); 
	ТаблицаНалогиВзносыОтчисления.Колонки.Добавить("ВидНалогаВзносаОтчисления", Новый ОписаниеТипов("ПеречислениеСсылка.ВидыНалоговВзносовОтчислений")); 
	ТаблицаНалогиВзносыОтчисления.Колонки.Добавить("ОблагаемыйДоход", ОписаниеТиповЧисло.ТипЧисло15_2);
	ТаблицаНалогиВзносыОтчисления.Колонки.Добавить("НеоблагаемыйДоход", ОписаниеТиповЧисло.ТипЧисло15_2);
	ТаблицаНалогиВзносыОтчисления.Колонки.Добавить("НалогВзнос", ОписаниеТиповЧисло.ТипЧисло15_2);
	ТаблицаНалогиВзносыОтчисления.Колонки.Добавить("НалогВзносСПревышения", ОписаниеТиповЧисло.ТипЧисло15_2);
	ТаблицаНалогиВзносыОтчисления.Колонки.Добавить("ОбъектИсчисления", ОписаниеТиповЧисло.ТипЧисло15_2);
	ТаблицаНалогиВзносыОтчисления.Колонки.Добавить("РазрешенныйВычет", ОписаниеТиповЧисло.ТипЧисло15_2);
	ТаблицаНалогиВзносыОтчисления.Колонки.Добавить("ПримененныйВычет", ОписаниеТиповЧисло.ТипЧисло15_2);
