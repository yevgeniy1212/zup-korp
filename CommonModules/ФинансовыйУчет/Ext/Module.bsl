Функция ПланируемыеРасходыПоДаннымКадровогоПлана(Подразделение, Сценарий, ПериодПланирования, Периодичность) Экспорт
	
	ПланируемыеРасходы = ПустаяТаблицаПланируемыхРасходов();
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ПоказателиКадровогоПланаОбороты.Период,
		|	ПоказателиКадровогоПланаОбороты.Позиция,
		|	ПоказателиКадровогоПланаОбороты.Подразделение,
		|	ПоказателиКадровогоПланаОбороты.Сотрудник,
		|	ПоказателиКадровогоПланаОбороты.Показатель.Категория КАК Категория,
		|	СУММА(ПоказателиКадровогоПланаОбороты.ЗначениеОборот) КАК СуммаРасходов
		|ПОМЕСТИТЬ ВТСотрудникиПериоды
		|ИЗ
		|	РегистрНакопления.ПоказателиКадровогоПлана.Обороты(&НачалоПериода, &КонецПериода, Месяц, Сценарий = &Сценарий
		|	И НЕ Показатель.Категория = &Категория
		|	И (&ПоВсемПодразделениям
		|	ИЛИ Подразделение В ИЕРАРХИИ (&Подразделение))) КАК ПоказателиКадровогоПланаОбороты
		|СГРУППИРОВАТЬ ПО
		|	ПоказателиКадровогоПланаОбороты.Период,
		|	ПоказателиКадровогоПланаОбороты.Позиция,
		|	ПоказателиКадровогоПланаОбороты.Подразделение,
		|	ПоказателиКадровогоПланаОбороты.Сотрудник,
		|	ПоказателиКадровогоПланаОбороты.Показатель,
		|	ПоказателиКадровогоПланаОбороты.Показатель.Категория";
	
	Запрос.УстановитьПараметр("НачалоПериода", ПериодПланирования);
	Запрос.УстановитьПараметр("КонецПериода",
		ДобавитьМесяц(ПериодПланирования, ЗарплатаКадрыРасширенный.КоличествоМесяцевПериодичности(Периодичность)) - 1);
	Запрос.УстановитьПараметр("ПоВсемПодразделениям", Не ЗначениеЗаполнено(Подразделение));
	Запрос.УстановитьПараметр("Подразделение", Подразделение);
	Запрос.УстановитьПараметр("Сценарий", Сценарий);
	Запрос.УстановитьПараметр("Категория", Перечисления.КатегорииРасходовНаПерсонал.КоличествоСтавок);
	
	Запрос.Выполнить();
	
	ОтражениеРасходовНаПерсонал.СоздатьВТСведенияОФинансовомУчетеСотрудников(
		МенеджерВременныхТаблиц, "ВТСотрудникиПериоды", , Истина);
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	Сотрудники.Период КАК Период,
		|	Сотрудники.Подразделение КАК Подразделение,
		|	Сотрудники.Категория КАК Категория,
		|	ВЫБОР
		|		КОГДА ФинансовыйУчетСотрудников.ЕстьФинансовыйУчетСотрудника
		|				ИЛИ ФинансовыйУчетСотрудников.ЕстьФинансовыйУчетПозицииКадровогоПлана
		|				ИЛИ ФинансовыйУчетСотрудников.ЕстьФинансовыйУчетПодразделения
		|				ИЛИ ФинансовыйУчетСотрудников.ЕстьФинансовыйУчетПоУмолчанию
		|			ТОГДА ФинансовыйУчетСотрудников.СпособОтражения
		|		ИНАЧЕ НЕОПРЕДЕЛЕНО
		|	КОНЕЦ КАК СпособОтражения,
		|	СУММА(Сотрудники.СуммаРасходов / 100 * ФинансовыйУчетСотрудников.ДоляРаспределения) КАК СуммаРасходов
		|ПОМЕСТИТЬ ВТРасходыПоКатегориям
		|ИЗ
		|	ВТСотрудникиПериоды КАК Сотрудники
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСведенияОФинансовомУчетеСотрудников КАК ФинансовыйУчетСотрудников
		|		ПО Сотрудники.Период = ФинансовыйУчетСотрудников.Период
		|			И Сотрудники.Подразделение = ФинансовыйУчетСотрудников.Подразделение
		|			И Сотрудники.Сотрудник = ФинансовыйУчетСотрудников.Сотрудник
		|			И Сотрудники.Позиция = ФинансовыйУчетСотрудников.Позиция
		|
		|СГРУППИРОВАТЬ ПО
		|	Сотрудники.Период,
		|	Сотрудники.Подразделение,
		|	Сотрудники.Категория,
		|	ВЫБОР
		|		КОГДА ФинансовыйУчетСотрудников.ЕстьФинансовыйУчетСотрудника
		|				ИЛИ ФинансовыйУчетСотрудников.ЕстьФинансовыйУчетПозицииКадровогоПлана
		|				ИЛИ ФинансовыйУчетСотрудников.ЕстьФинансовыйУчетПодразделения
		|				ИЛИ ФинансовыйУчетСотрудников.ЕстьФинансовыйУчетПоУмолчанию
		|			ТОГДА ФинансовыйУчетСотрудников.СпособОтражения
		|		ИНАЧЕ НЕОПРЕДЕЛЕНО
		|	КОНЕЦ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РасходыПоКатегориям.Период КАК Период,
		|	РасходыПоКатегориям.Подразделение КАК Подразделение,
		|	РасходыПоКатегориям.Категория КАК КатегорияРасходов,
		|	ВЫРАЗИТЬ(РасходыПоКатегориям.СпособОтражения КАК Справочник.СпособыОтраженияВФинансовомУчете).НаправлениеДеятельности КАК НаправлениеДеятельности,
		|	ВЫРАЗИТЬ(РасходыПоКатегориям.СпособОтражения КАК Справочник.СпособыОтраженияВФинансовомУчете).АналитикаРасходов КАК АналитикаРасходов,
		|	ЕСТЬNULL(КатегорииСтатейРасходов.СтатьяРасходов, НЕОПРЕДЕЛЕНО) КАК СтатьяРасходов,
		|	СУММА(РасходыПоКатегориям.СуммаРасходов) КАК СуммаРасходов
		|ИЗ
		|	ВТРасходыПоКатегориям КАК РасходыПоКатегориям
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СпособыОтраженияВФинансовомУчете.КатегорииСтатейРасходов КАК КатегорииСтатейРасходов
		|		ПО РасходыПоКатегориям.СпособОтражения = КатегорииСтатейРасходов.Ссылка
		|			И РасходыПоКатегориям.Категория = КатегорииСтатейРасходов.КатегорияРасходов
		|
		|СГРУППИРОВАТЬ ПО
		|	РасходыПоКатегориям.Период,
		|	РасходыПоКатегориям.Подразделение,
		|	РасходыПоКатегориям.Категория,
		|	ВЫРАЗИТЬ(РасходыПоКатегориям.СпособОтражения КАК Справочник.СпособыОтраженияВФинансовомУчете).НаправлениеДеятельности,
		|	ВЫРАЗИТЬ(РасходыПоКатегориям.СпособОтражения КАК Справочник.СпособыОтраженияВФинансовомУчете).АналитикаРасходов,
		|	ЕСТЬNULL(КатегорииСтатейРасходов.СтатьяРасходов, НЕОПРЕДЕЛЕНО)
		|
		|ИМЕЮЩИЕ
		|	СУММА(РасходыПоКатегориям.СуммаРасходов) > 0
		|
		|УПОРЯДОЧИТЬ ПО
		|	Подразделение,
		|	НаправлениеДеятельности,
		|	КатегорияРасходов,
		|	Период
		|АВТОУПОРЯДОЧИВАНИЕ";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НоваяСтрока = ПланируемыеРасходы.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, ВыборкаДетальныеЗаписи);
		НоваяСтрока.ПериодСтрокой = ЗарплатаКадрыКлиентСервер.ПолучитьПредставлениеМесяца(НоваяСтрока.Период);
	КонецЦикла;
	
	Возврат ПланируемыеРасходы;
	
КонецФункции

Функция ПустаяТаблицаПланируемыхРасходов()
	
	ПланируемыеРасходы = Новый ТаблицаЗначений;
	ПланируемыеРасходы.Колонки.Добавить("Период", ОбщегоНазначения.ОписаниеТипаДата(ЧастиДаты.Дата));
	ПланируемыеРасходы.Колонки.Добавить("ПериодСтрокой", ОбщегоНазначения.ОписаниеТипаСтрока(20));
	ПланируемыеРасходы.Колонки.Добавить("СтатьяРасходов", Новый ОписаниеТипов("ПланВидовХарактеристикСсылка.СтатьиРасходов"));
	ПланируемыеРасходы.Колонки.Добавить("НаправлениеДеятельности", Новый ОписаниеТипов("СправочникСсылка.НаправленияДеятельности"));
	ПланируемыеРасходы.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.СтруктураПредприятия"));
	ПланируемыеРасходы.Колонки.Добавить("КатегорияРасходов", Новый ОписаниеТипов("ПеречислениеСсылка.КатегорииРасходовНаПерсонал"));
	ПланируемыеРасходы.Колонки.Добавить("АналитикаРасходов", Новый ОписаниеТипов("СправочникСсылка.Проекты"));
	ПланируемыеРасходы.Колонки.Добавить("СуммаРасходов", ОбщегоНазначения.ОписаниеТипаЧисло(15, 2));
	
	Возврат ПланируемыеРасходы;
	
КонецФункции

// Возвращает структуру с настройкой финансового учета сотрудника на указанную дату.
//
// Параметры:
//  Сотрудник - Тип СправочникСсылка.Сотрудник
//  ДатаАктуальности - Тип Дата, дата на которую получаем способ отражения.
//
// Возвращаемое значение: Структура, ключи СпособОтражения, Период
//		СпособОтражения, тип Справочник.СпособыОтраженияВФинансовомУчете
//		Период, дата на которую установлено значение.
//
Функция НастройкаФинансовогоУчетаЗарплатыСотрудника(Сотрудник, ДатаАктуальности)
	
	ФинансовыйУчетСотрудника = Новый Структура("СпособОтраженияЗарплатыВФинансовомУчете, Период");
	ФинансовыйУчетСотрудника.СпособОтраженияЗарплатыВФинансовомУчете =
		Справочники.СпособыОтраженияВФинансовомУчете.ПустаяСсылка();
	ФинансовыйУчетСотрудника.Период = Дата(1,1,1);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаСреза", ДатаАктуальности);
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ФинансовыйУчетСотрудников.Период,
		|	ФинансовыйУчетСотрудников.СпособОтражения КАК СпособОтраженияЗарплатыВФинансовомУчете
		|ИЗ
		|	РегистрСведений.ФинансовыйУчетСотрудников.СрезПоследних(&ДатаСреза, Сотрудник = &Сотрудник) КАК
		|		ФинансовыйУчетСотрудников";
	Результат = Запрос.Выполнить();
	Если Не Результат.Пустой() Тогда
		Выборка = Результат.Выбрать();
		Выборка.Следующий();
		ЗаполнитьЗначенияСвойств(ФинансовыйУчетСотрудника, Выборка);
	КонецЕсли;
	
	Возврат ФинансовыйУчетСотрудника;
	
КонецФункции

#Область НачальноеЗаполнениеЗначенийПоУмолчанию

Функция СпособОтраженияОбъектПоУмолчанию()
	
	СпособОтражения = Справочники.СпособыОтраженияВФинансовомУчете.СоздатьЭлемент();
	СпособОтражения.Наименование = НСтр("ru = 'По умолчанию'");
	СпособОтражения.НаправлениеДеятельности = НаправлениеДеятельностиПоУмолчанию();
	СпособОтражения.АналитикаРасходов = АналитикаРасходовПоУмолчанию();
	
	Для Каждого Категория Из КатегорииФинансовогоУчета() Цикл
		НоваяСтрокаКатегория = СпособОтражения.КатегорииСтатейРасходов.Добавить();
		НоваяСтрокаКатегория.КатегорияРасходов = Категория;
		НоваяСтрокаКатегория.СтатьяРасходов = СтатьяРасходовПоУмолчанию(Категория);
	КонецЦикла;
	
	ОбновлениеИнформационнойБазы.ЗаписатьОбъект(СпособОтражения);
	
	Возврат СпособОтражения;
	
КонецФункции

Функция НаправлениеДеятельностиПоУмолчанию()
	
	НаправлениеДеятельности = Справочники.НаправленияДеятельности.СоздатьЭлемент();
	НаправлениеДеятельности.Наименование = НСтр("ru = 'По умолчанию'");
	ОбновлениеИнформационнойБазы.ЗаписатьОбъект(НаправлениеДеятельности);
	
	Возврат НаправлениеДеятельности.Ссылка;
	
КонецФункции

Функция АналитикаРасходовПоУмолчанию()
	
	Проект = Справочники.Проекты.СоздатьЭлемент();
	Проект.Наименование = НСтр("ru = 'По умолчанию'");
	ОбновлениеИнформационнойБазы.ЗаписатьОбъект(Проект);
	
	Возврат Проект.Ссылка;
	
КонецФункции

Функция СтатьяРасходовПоУмолчанию(Категория)
	
	СтатьяРасходов = ПланыВидовХарактеристик.СтатьиРасходов.СоздатьЭлемент();
	СтатьяРасходов.Наименование = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		НСтр("ru = '%1 по умолчанию'"), Строка(Категория));
	СтатьяРасходов.ТипЗначения = Новый ОписаниеТипов("СправочникСсылка.Проекты");

	ОбновлениеИнформационнойБазы.ЗаписатьОбъект(СтатьяРасходов);
	
	Возврат СтатьяРасходов.Ссылка;
	
КонецФункции

#КонецОбласти

#КонецОбласти
