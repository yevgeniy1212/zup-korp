КонецПроцедуры

Процедура НачальноеЗаполнение(ПараметрыОбновления = Неопределено) Экспорт
	
	ОбновлениеИБ = ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ФинансовыйУчетПоУмолчанию.Период
		|ИЗ
		|	РегистрСведений.ФинансовыйУчетПоУмолчанию КАК ФинансовыйУчетПоУмолчанию";
	
	Если Не Запрос.Выполнить().Пустой() Тогда
		ОбновлениеИБ.ЗавершитьОбработчик(ПараметрыОбновления);
		Возврат;
	КонецЕсли;
	
	ОбновлениеИБ.ПродолжитьОбработчик(ПараметрыОбновления);
	
	НаборЗаписей = РегистрыСведений.ФинансовыйУчетПоУмолчанию.СоздатьНаборЗаписей();
	ЗаписьНабора = НаборЗаписей.Добавить();
	
	Если Не ОбновлениеИБ.ПодготовитьОбновлениеДанных(ПараметрыОбновления, "РегистрСведений.ФинансовыйУчетПоУмолчанию", Неопределено, Неопределено) Тогда
		Возврат;
	КонецЕсли;
	
	ЗаписьНабора.Период = НачалоГода(ТекущаяДатаСеанса());
	
	СпособОтраженияОбъект = СпособОтраженияОбъектПоУмолчанию();
	ЗаписьНабора.СпособОтражения = СпособОтраженияОбъект.Ссылка;
	ЗаписьНабора.НаправлениеДеятельности = СпособОтраженияОбъект.НаправлениеДеятельности;
	ЗаписьНабора.АналитикаРасходов = СпособОтраженияОбъект.АналитикаРасходов;
	Для Каждого СтрокаСтатьяКатегории Из СпособОтраженияОбъект.КатегорииСтатейРасходов Цикл
		ИмяКатегории = ОбщегоНазначения.ИмяЗначенияПеречисления(СтрокаСтатьяКатегории.КатегорияРасходов);
		ЗаписьНабора[ИмяКатегории] = СтрокаСтатьяКатегории.СтатьяРасходов;
	КонецЦикла;
	
	ОбновлениеИнформационнойБазы.ЗаписатьДанные(НаборЗаписей);
	ОбновлениеИБ.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
	
КонецПроцедуры

Процедура ЗаполнитьДвиженияФинансовыйУчетОбучениеСотрудников(ПараметрыОбновления = Неопределено) Экспорт
	
	// АПК:1327-выкл используется при начальном заполнении ИБ.
	// АПК:1328-выкл используется при начальном заполнении ИБ.
	
	ОбновлениеИБ = ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый;
	
	Если ПараметрыОбновления = Неопределено Тогда
		ПараметрыОбновления = Новый Структура("ОбработкаЗавершена");
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Если Не ПараметрыОбновления.Свойство("Обработанные") Тогда
		Обработанные = Новый Массив;
		ПараметрыОбновления.Вставить("Обработанные");
	ИначеЕсли ПараметрыОбновления.Обработанные = Неопределено Тогда
		Обработанные = Новый Массив;
	Иначе
		Обработанные = ПараметрыОбновления.Обработанные;
	КонецЕсли;
	Запрос.УстановитьПараметр("Обработанные", Обработанные);
	
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1000
		|	ФизическиеЛица.Ссылка КАК ФизическоеЛицо,
		|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаНачала,
		|	ДАТАВРЕМЯ(1, 1, 1) КАК ДатаОкончания
		|ПОМЕСТИТЬ ВТФизическиеЛицаОтбор
		|ИЗ
		|	Справочник.ФизическиеЛица КАК ФизическиеЛица
		|ГДЕ
		|	НЕ ФизическиеЛица.Ссылка В (&Обработанные)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТФизическиеЛицаОтбор.ФизическоеЛицо
		|ИЗ
		|	ВТФизическиеЛицаОтбор КАК ВТФизическиеЛицаОтбор";
	
	РезультатЗапросаФизЛиц = Запрос.Выполнить();
	Если РезультатЗапросаФизЛиц.Пустой() Тогда
		ОбновлениеИБ.ЗавершитьОбработчик(ПараметрыОбновления);
		Возврат;
	КонецЕсли;
	ОбновлениеИБ.ПродолжитьОбработчик(ПараметрыОбновления);
	
	ОбучениеРазвитие.СоздатьВТОбучениеСотрудников(Запрос.МенеджерВременныхТаблиц);
	
	ФизическиеЛицаДляОбработки = РезультатЗапросаФизЛиц.Выгрузить().ВыгрузитьКолонку("ФизическоеЛицо");
	
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ОбучениеСотрудников.ДокументОбучения КАК Регистратор
		|ИЗ
		|	ВТОбучениеСотрудников КАК ОбучениеСотрудников
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФинансовыйУчетОбучениеСотрудников КАК ФинансовыйУчетОбучениеСотрудников
		|		ПО ОбучениеСотрудников.ДокументОбучения = ФинансовыйУчетОбучениеСотрудников.Регистратор
		|ГДЕ
		|	ФинансовыйУчетОбучениеСотрудников.Регистратор ЕСТЬ NULL";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		НаборЗаписейОбучениеСотрудников = РегистрыСведений.ОбучениеСотрудников.СоздатьНаборЗаписей();
		НаборЗаписейОбучениеСотрудников.Отбор.Регистратор.Установить(Выборка.Регистратор);
		НаборЗаписейОбучениеСотрудников.Прочитать();
		
		Если НаборЗаписейОбучениеСотрудников.Количество() > 0 Тогда
			Если Не ОбновлениеИБ.ПодготовитьОбновлениеДанных(ПараметрыОбновления,
					"РегистрСведений.ФинансовыйУчетОбучениеСотрудников.НаборЗаписей", "Регистратор", Выборка.Регистратор) Тогда
				Продолжить;
			КонецЕсли;
			
			НаборЗаписей = РегистрыСведений.ФинансовыйУчетОбучениеСотрудников.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Регистратор.Установить(Выборка.Регистратор);
			Для каждого СтрокаЗапись Из НаборЗаписейОбучениеСотрудников Цикл
				НоваяЗапись = НаборЗаписей.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяЗапись, СтрокаЗапись);
			КонецЦикла;
			
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(НаборЗаписей);
			
			Если ТипЗнч(Выборка.Регистратор) = Тип("ДокументСсылка.ПереносДанных") Тогда
				ДокументОбъект = Выборка.Регистратор.ПолучитьОбъект();
				НовыйРегистр = ДокументОбъект.ТаблицаРегистров.Добавить();
				НовыйРегистр.Имя = "ФинансовыйУчетОбучениеСотрудников";
				ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ДокументОбъект);
			КонецЕсли;
			
			ОбновлениеИБ.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
		КонецЕсли;
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Обработанные, ФизическиеЛицаДляОбработки);
	ОбновлениеИБ.УстановитьПараметрОбновления(ПараметрыОбновления, "Обработанные", Обработанные);
	
	// АПК:1327-вкл
	// АПК:1328-вкл
	
КонецПроцедуры

Процедура ПеренестиПрисоединенныеФайлы(ПараметрыОбновления = Неопределено) Экспорт
	
	ОбновлениеИБ = ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 100
		|	ПрисоединенныеФайлы.Ссылка КАК Файл,
		|	ПрисоединенныеФайлы.ВладелецФайла КАК ВладелецФайла
		|ИЗ
		|	Справочник.ОтражениеЗарплатыВФинансовомУчетеПрисоединенныеФайлы КАК ПрисоединенныеФайлы
		|ГДЕ
		|	НЕ ПрисоединенныеФайлы.ПометкаУдаления
		|	И ПрисоединенныеФайлы.ВладелецФайла ССЫЛКА Документ.ОтражениеРасходовНаПерсонал";	
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		ОбновлениеИБ.ЗавершитьОбработчик(ПараметрыОбновления);
		Возврат;
	КонецЕсли;
	
	ОбновлениеИБ.ПродолжитьОбработчик(ПараметрыОбновления);
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий()Цикл
		ИмяПространстваБлокировки = Выборка.Файл.Метаданные().ПолноеИмя();
		НачатьТранзакцию();
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить(ИмяПространстваБлокировки);
		ЭлементБлокировки.УстановитьЗначение("Ссылка", Выборка.Файл);
		Попытка 
			Блокировка.Заблокировать();
			ДанныеФайла = РаботаСФайлами.ДанныеФайла(Выборка.Файл, РаботаСФайламиКлиентСервер.ПараметрыДанныхФайла());
		
			ПараметрыДобавленияФайла = РаботаСФайлами.ПараметрыДобавленияФайла();
			ПараметрыДобавленияФайла.ИмяБезРасширения = ДанныеФайла.Наименование;
			ПараметрыДобавленияФайла.РасширениеБезТочки = ДанныеФайла.Расширение;
			ПараметрыДобавленияФайла.ВремяИзмененияУниверсальное = ДанныеФайла.ДатаМодификацииУниверсальная;
			ПараметрыДобавленияФайла.ВладелецФайлов = Выборка.ВладелецФайла;
				
			РаботаСФайлами.ДобавитьФайл(ПараметрыДобавленияФайла, ДанныеФайла.СсылкаНаДвоичныеДанныеФайла);
						
			ФайлКУдалению = Выборка.Файл.ПолучитьОбъект();
			ФайлКУдалению.ПометкаУдаления = Истина;
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ФайлКУдалению);
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ЗаписьЖурналаРегистрации(НСтр("ru = 'Обновление информационной базы.Не удалось скопировать присоединенный файл'",
				ОбщегоНазначения.КодОсновногоЯзыка()), УровеньЖурналаРегистрации.Предупреждение, , Выборка.Файл, ИмяПространстваБлокировки);
			Продолжить;
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

