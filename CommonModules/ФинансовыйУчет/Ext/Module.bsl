#Область СлужебныйПрограммныйИнтерфейс

Функция ИспользоватьФинансовыйУчет() Экспорт
	
	Возврат Константы.ИспользоватьФинансовыйУчет.Получить();
	
КонецФункции

Функция МожноРедактироватьФинансовыйУчет() Экспорт
	
	Возврат ПравоДоступа("Редактирование", Метаданные.РегистрыСведений.ФинансовыйУчетПоУмолчанию);
	
КонецФункции

Процедура СформироватьДвиженияДокументовГПХ(Движения, СтрокаДанныхДляПроведения, ПериодЗаписи) Экспорт
	
	Движения.ФинансовыйУчетПлановыеНачисленияПоДоговорам.Записывать = Истина;
	НоваяСтрока = Движения.ФинансовыйУчетПлановыеНачисленияПоДоговорам.Добавить();
	ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДанныхДляПроведения);
	НоваяСтрока.СпособОтражения = СтрокаДанныхДляПроведения.СпособОтраженияЗарплатыВФинансовомУчете;
	НоваяСтрока.Подразделение = СтрокаДанныхДляПроведения.МестоВСтруктуреПредприятия;
	НоваяСтрока.Период = ПериодЗаписи;
	
КонецПроцедуры

Процедура ДополнитьИменаКадровыхДанных(КадровыеДанные) Экспорт
	
	Если Не ИспользоватьФинансовыйУчет() Тогда
		Возврат;
	КонецЕсли; 
	
	КадровыеДанные = ?(ПустаяСтрока(КадровыеДанные), "", КадровыеДанные + ",") + "МестоВСтруктуреПредприятия";
	
КонецПроцедуры

Процедура ДополнитьНастройкиУчета(Сотрудник, НастройкиУчетов, КадровыеДанные) Экспорт
	
	Если Не ИспользоватьФинансовыйУчет() Тогда
		Возврат;
	КонецЕсли; 
	
	Если КадровыеДанные.Количество() > 0 Тогда
		НастройкиУчетов.Вставить("МестоВСтруктуреПредприятия", КадровыеДанные[0].МестоВСтруктуреПредприятия);
	КонецЕсли;
	
	Если Не ПравоДоступа("Чтение", Метаданные.РегистрыСведений.ФинансовыйУчетСотрудников) Тогда
		Возврат;
	КонецЕсли;
	
	ФинансовыйУчетСотрудника = НастройкаФинансовогоУчетаЗарплатыСотрудника(Сотрудник, ТекущаяДатаСеанса());
	НастройкиУчетов.Вставить("СпособОтраженияЗарплатыВФинансовомУчете", ФинансовыйУчетСотрудника.СпособОтраженияЗарплатыВФинансовомУчете);
	
КонецПроцедуры

Процедура ДополнитьДанныеДляПроведенияОбученияРазвитияСотрудников(ДокументСсылка, ДанныеДляПроведения) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(ОбучениеРазвитиеСотрудников.ДатаНачала, МЕСЯЦ) КАК Период,
		|	ОбучениеРазвитиеСотрудников.Ссылка КАК Регистратор,
		|	ОбучениеРазвитиеСотрудников.Подразделение КАК Подразделение,
		|	ОбучениеРазвитиеСотрудников.Мероприятие КАК Мероприятие,
		|	ОбучениеРазвитиеСотрудников.ДатаНачала КАК ДатаНачала,
		|	ОбучениеРазвитиеСотрудников.ДатаОкончания КАК ДатаОкончания,
		|	СправочникСотрудники.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ОбучениеРазвитиеСотрудниковСотрудники.СуммаНаСотрудника КАК СуммаРасходов,
		|	ОбучениеРазвитиеСотрудниковСотрудники.Сотрудник КАК Сотрудник,
		|	ОбучениеРазвитиеСотрудниковСотрудники.СпособОтражения КАК СпособОтражения
		|ИЗ
		|	Документ.ОбучениеРазвитиеСотрудников.Сотрудники КАК ОбучениеРазвитиеСотрудниковСотрудники
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОбучениеРазвитиеСотрудников КАК ОбучениеРазвитиеСотрудников
		|		ПО ОбучениеРазвитиеСотрудниковСотрудники.Ссылка = ОбучениеРазвитиеСотрудников.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Сотрудники КАК СправочникСотрудники
		|		ПО ОбучениеРазвитиеСотрудниковСотрудники.Сотрудник = СправочникСотрудники.Ссылка
		|ГДЕ
		|	ОбучениеРазвитиеСотрудников.Ссылка = &ДокументСсылка";
		
	ДанныеДляПроведения.Вставить("ФинансовыйУчетОбучениеСотрудников", Запрос.Выполнить().Выгрузить());
	
КонецПроцедуры

Процедура СформироватьДвиженияОбученияРазвитияСотрудников(Движения, ДанныеДляПроведения) Экспорт
	
	Перем ФинансовыйУчетОбучениеСотрудников;
	
	Если Не ДанныеДляПроведения.Свойство("ФинансовыйУчетОбучениеСотрудников", ФинансовыйУчетОбучениеСотрудников) Тогда
		Возврат;
	КонецЕсли;
	
	Движения.ФинансовыйУчетОбучениеСотрудников.Записывать = Истина;
	Для Каждого СтрокаДанныхДляПроведения Из ФинансовыйУчетОбучениеСотрудников Цикл
		НоваяСтрока = Движения.ФинансовыйУчетОбучениеСотрудников.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДанныхДляПроведения);
	КонецЦикла;
	
КонецПроцедуры

Процедура ДобавитьПоказательИспользоватьФинансовыйУчет(ТаблицаПоказателей) Экспорт
	
	Если Не ИспользоватьФинансовыйУчет() Тогда
		Возврат;
	КонецЕсли;
	
	Отчеты.НастройкиПрограммыЗарплатаКадры.ДобавитьПоказатель(ТаблицаПоказателей, "Константы", "ИспользоватьФинансовыйУчет", 
		НСтр("ru = 'Используется финансовый учет'"), НСтр("ru = 'Управление персоналом'"), НСтр("ru = 'Финансовый учет'"), "Ложь", 5, 12, 1);
	
КонецПроцедуры

// Добавляет запись о финансовом учете по документу основанию.
//
Процедура ЗарегистрироватьФинансовыйУчетПервичныхДокументов(Объект) Экспорт
	
	НаборЗаписей = РегистрыСведений.ФинансовыйУчетПервичныхДокументов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ДокументОснование.Установить(Объект.Ссылка);
	
	Для каждого СтрокаНачисления Из Объект.НачисленияУдержанияВзносы Цикл
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.ДокументОснование = Объект.Ссылка;
		НоваяЗапись.НачислениеУдержание = Объект.ВидВыплаты;
		НоваяЗапись.ПериодРегистрации = Объект.ПериодРегистрации;
		НоваяЗапись.СпособОтражения = Объект.СпособОтраженияЗарплатыВФинансовомУчете;
		НоваяЗапись.Подразделение = Объект.МестоВСтруктуреПредприятия;
		НоваяЗапись.ФизическоеЛицо = СтрокаНачисления.ФизическоеЛицо;
	КонецЦикла;
	
	НаборЗаписей.Записать();
	
КонецПроцедуры

#Область ОбновлениеИнформационнойБазы

