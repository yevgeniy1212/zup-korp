	РеквизитыТабличнойЧасти = МетаданныеОбъекта.ТабличныеЧасти.ИсчислениеПени.Реквизиты;
	НовыеСведения = ТаблицаСведений.Добавить();
	НовыеСведения.Объект = МетаданныеОбъекта.ПолноеИмя();
	НовыеСведения.ПолеСубъект = РеквизитыТабличнойЧасти.ФизическоеЛицо.ПолноеИмя();
	Поля = Новый Массив; // Массив из Строка
	Поля.Добавить(РеквизитыТабличнойЧасти.Сумма.ПолноеИмя());
	Поля.Добавить(РеквизитыТабличнойЧасти.СуммаЗадолженности.ПолноеИмя());
	Поля.Добавить(РеквизитыТабличнойЧасти.МесяцНалоговогоПериода.ПолноеИмя());
	Поля.Добавить(РеквизитыТабличнойЧасти.ПланируемаяДатаПеречисления.ПолноеИмя());
	НовыеСведения.Поля = Поля;
	НовыеСведения.КатегорияДанных = "Доходы";
	
	МетаданныеОбъекта = Метаданные.Документы.ПрекращениеПредоставленияВычетовИПН;
	НовыеСведения = ТаблицаСведений.Добавить();
	НовыеСведения.Объект = МетаданныеОбъекта.ПолноеИмя();
	НовыеСведения.ПолеСубъект = МетаданныеОбъекта.Реквизиты.Сотрудник.ПолноеИмя();
	Поля = Новый Массив; // Массив из Строка
	Поля.Добавить(МетаданныеОбъекта.Реквизиты.Месяц.ПолноеИмя());
	НовыеСведения.Поля = Поля;
	НовыеСведения.КатегорияДанных = "ЛичныеДанные";
	// ЗУПК
	
КонецПроцедуры

// Позволяет выполнить дополнительные действия перед уничтожением персональных данных субъектов. В том числе, отказаться
// от уничтожения персональных данных, добавив субъекта в таблицу исключений с указанием причины отказа от уничтожения.
// Или же добавить в массив субъектов других субъектов, данные которых тоже должны быть уничтожены. Например, если при 
