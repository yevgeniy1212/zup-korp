#Область ПрограммныйИнтерфейс

// Обработчик подписки на событие УстановитьИспользованиеЭлектронногоТестированияКандидатов
//
// Параметры:
//	Источник - КонстантаМенеджерЗначения.ИспользоватьШаблоныСообщений, КонстантаМенеджерЗначения.ИспользоватьВнешнихПользователей
//	Отказ - Булево - отказ от стандартной обработки
//
Процедура УстановитьИспользованиеЭлектронногоТестированияКандидатовПриЗаписи(Источник, Отказ) Экспорт

	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьЭлектронноеТестированиеКандидатов") Тогда
		Возврат;
	КонецЕсли;

	Если ЗарплатаКадры.ОтключитьБизнесЛогикуПриЗаписи(Источник) Тогда
		Возврат;
	КонецЕсли;

	Если Источник.Значение Тогда
		Возврат;
	КонецЕсли;
	
	// Следует отключить Электронное тестирование кандидатов,
	// т.к. ее использование невозможно без Внешних пользователей и Шаблонов сообщений
	Константы.ИспользоватьЭлектронноеТестированиеКандидатов.Установить(Ложь);

	ТекстСообщения = НСтр("ru = 'Использование Электронного тестирования кандидатов невозможно без использования Внешних пользователей и Шаблонов сообщений.
						  |Электронное тестирование кандидатов так же было выключено.'");

	ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);

КонецПроцедуры

#КонецОбласти 


