
#Область СлужебныеПроцедурыИФункции

Процедура ПередНачаломРаботыСистемы(Параметры) Экспорт
	
	Если ПользователиКлиент.ЭтоСеансВнешнегоПользователя() Тогда
		КлиентскоеПриложение.УстановитьРежимОсновногоОкна(РежимОсновногоОкнаКлиентскогоПриложения.ПолноэкранноеРабочееМесто);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьВариантыОтветов(Форма) Экспорт
	
	Элементы = Форма.Элементы;
	ВариантыОтветов = Форма.ВариантыОтветовЭлектронногоТеста;
	Характеристики = Форма.ХарактеристикиВариантовОтветов;
	
	ВариантыОтветов.Очистить();
	
	ТекущиеДанные = Элементы.ВопросыДляЭлектронногоТестирования.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Или Не ЗначениеЗаполнено(ТекущиеДанные.Ссылка) Тогда
		Возврат;
	КонецЕсли;
	
	ВариантыОтветовВопроса = ЭлектронноеТестированиеКандидатовВызовСервера.ВариантыОтветовВопроса(ТекущиеДанные.Ссылка);
	Для Каждого Строка Из ВариантыОтветовВопроса Цикл
		ВариантОтвета = ВариантыОтветов.Добавить(); 
		ВариантОтвета.Ссылка = Строка;
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("ВариантОтвета", Строка);
		Массив = Характеристики.НайтиСтроки(СтруктураПоиска);
		ВариантОтвета.КоличествоКлючей = Массив.Количество();
	КонецЦикла;
	
КонецПроцедуры

Процедура УстановитьОтборТаблицыХарактеристик(Форма) Экспорт
	
	Элементы = Форма.Элементы;
	ТекущиеДанные = Элементы.ВариантыОтветовЭлектронногоТеста.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		ОтборСтрок = Новый Структура;
		ОтборСтрок.Вставить("ВариантОтвета", ПредопределенноеЗначение("Справочник.ВариантыОтветовАнкет.ПустаяСсылка"));
		Элементы.ХарактеристикиВариантовОтветов.ОтборСтрок = Новый ФиксированнаяСтруктура(ОтборСтрок);
		УстановитьДоступность(Форма, Ложь);
		Возврат;
	КонецЕсли;
	
	ОтборСтрок = Новый Структура;
	ОтборСтрок.Вставить("ВариантОтвета", ТекущиеДанные.Ссылка);
	Элементы.ХарактеристикиВариантовОтветов.ОтборСтрок = Новый ФиксированнаяСтруктура(ОтборСтрок);
	УстановитьДоступность(Форма, Истина);
	
КонецПроцедуры

Процедура УстановитьДоступность(Форма, Доступность) 
	
	Элементы = Форма.Элементы;
	
	Элементы.ХарактеристикиВариантовОтветовДобавить.Доступность = Доступность;
	Элементы.ХарактеристикиВариантовОтветовУдалить.Доступность = Доступность;
	Элементы.ХарактеристикиВариантовОтветов.Доступность = Доступность;

КонецПроцедуры

#КонецОбласти
