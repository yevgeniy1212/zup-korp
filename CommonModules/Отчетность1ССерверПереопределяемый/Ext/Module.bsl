
#Область ПрограммныйИнтерфейс

#Область ВыгрузкаВJSON

// Формирует структуру данных налогоплательщика
// Возвращаемое значение
//	Структура:
//		* Налогоплательщик - СправочникСсылка.Организации
//		* ИдентификаторПользователя - Строка - БИН
Функция ОпределитьИдентификаторНалогоплательщика(Форма) Экспорт	
	ИдентификаторНалогоплательщика = Новый Структура;
		
	Налогоплательщик =  Форма.СтруктураРеквизитовФормы.Организация;
	ИдентификаторПользователя = Форма.СтруктураРеквизитовФормы.Организация.ИНН;
	НаименованиеПользователя = Форма.СтруктураРеквизитовФормы.Организация.НаименованиеПолное;		
	
	ИдентификаторНалогоплательщика.Вставить("Налогоплательщик", Налогоплательщик);
	ИдентификаторНалогоплательщика.Вставить("ИдентификаторПользователя", ИдентификаторПользователя);
	ИдентификаторНалогоплательщика.Вставить("НаименованиеПользователя", НаименованиеПользователя);
	
	Возврат ИдентификаторНалогоплательщика;
КонецФункции

// Формирует структуру данных (или массив структур) по многострочным разделам формы: 
// собирает строки, шапку/подвал и связанные реквизиты, 
// а также учитывает добавленные приложения, подготавливая данные для представления в JSON-виде.
//
// Параметры:
//  Форма –ФормаКлиентскогоПриложения - объект формы, содержащий данные для выгрузки.
//  ТекущееИмяФормы – Строка (Необязательный) - код формы, если не указан — берётся из Форма.КодФормы.
//  ДополнительныеПараметры – Структура (Необязательный) - дополнительные настройки обработки.
//
// Возвращаемое значение:
//  Структура или Массив:
//   * Если форма без приложений – Структура:
//      ** <ИмяГруппы> – Структура:
//         *** ШапкаИПодвал – Структура, общие элементы раздела (шапка и подвал формы)
//         *** Строки – ТаблицаЗначений, строки раздела формы
//         *** ИмяРеквизитаТаблицыСтрокГруппы – Строка, имя реквизита формы, хранящего таблицу строк
//   * Если форма содержит приложения – Массив структур (каждая структура в формате выше)
//      ** КодДопПриложения – Строка, код формы-приложения
Функция ПолучитьМногострочнуюСтруктуруJSON(Форма, ТекущееИмяФормы = Неопределено, ДополнительныеПараметры=Неопределено) Экспорт           
	
	ТаблицаМногострочнойФормы = ДополнительныеПараметры.ТаблицаВыгрузки;
	
	Если ТекущееИмяФормы <> Неопределено тогда
		
		ЭтоМногостраничнаяФорма = Ложь;
		Если Отчетность1ССервер.ЕстьРеквизитФормы(Форма, "ТаблицаСтраницы" + ТекущееИмяФормы) Тогда
			ЭтоМногостраничнаяФорма = Истина;
			МассивСтруктур = Новый Массив;
			ИмяТаблицы = "ТаблицаСтраницы" + ТекущееИмяФормы;
				
			ТаблицаТекущейФормы = Форма[ИмяТаблицы].Выгрузить();
		КонецЕсли;	
		
		МногострочнаяСтруктура = Новый Структура;
		
		ТекущийЛист = Неопределено;
		НомерСтроки = 0;
		
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("КодФормы", ТекущееИмяФормы);
		СтрокиТекущейФормы = ТаблицаМногострочнойФормы.НайтиСтроки(СтруктураПоиска);
		КоличествоСтрок = СтрокиТекущейФормы.Количество();
		
		Пока Истина Цикл 
			
			Если НомерСтроки >= КоличествоСтрок Тогда 
				Прервать;
			КонецЕсли;
			
			СтрокаТЗ = СтрокиТекущейФормы[НомерСтроки];
			
			Если ЗначениеЗаполнено(СтрокаТЗ.ИмяЛиста) И СтрокаТЗ.ИмяЛиста <> ТекущийЛист И СтрокаТЗ.КодФормы = ТекущееИмяФормы И ЗначениеЗаполнено(СтрокаТЗ.ИмяЯчейки) Тогда
				
				Если НЕ МногострочнаяСтруктура.Свойство(СтрокаТЗ.ИмяЛиста) Тогда
					
					// Заполнить данные строк
					Если ЭтоМногостраничнаяФорма Тогда
						
						Если СтрокаТЗ.КоличествоНаЛисте = 1 Тогда
							// 200.03		
							СтруктураПоиска = Новый Структура;
							СтруктураПоиска.Вставить("ИмяЛиста", СтрокаТЗ.ИмяЛиста);
							СтруктураПоиска.Вставить("КоличествоROW", "1");
							СтруктураПоиска.Вставить("КодФормы", ТекущееИмяФормы);
							СтрокиТаблицы = ТаблицаМногострочнойФормы.НайтиСтроки(СтруктураПоиска);
							
							ЕстьЗаписи = Ложь;
							
							МногострочнаяСтруктура.Вставить(СтрокаТЗ.ИмяЛиста, Новый Структура);
							МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста].Вставить("ИмяРеквизитаТаблицыСтрокГруппы", ИмяТаблицы);
							МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста].Вставить("Строки", Новый ТаблицаЗначений);
							МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста].Вставить("ШапкаИПодвал", Новый ТаблицаЗначений);
						
							МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["ШапкаИПодвал"].Колонки.Добавить("Значение");
							МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["ШапкаИПодвал"].Колонки.Добавить("ИмяОбласти");
							МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["ШапкаИПодвал"].Колонки.Добавить("ИмяПараметра");
							МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["ШапкаИПодвал"].Колонки.Добавить("Итог");
							     	
							Если НЕ Форма[ИмяТаблицы].Количество() = 0 Тогда
								
								ТекущийНомерДобавленнойФормы = 0;
							
								Для Каждого СтрокаФормы Из Форма[ИмяТаблицы] Цикл
									
									Для Каждого Строка Из СтрокиТаблицы Цикл
										ИмяЯчейки = ?(Лев(Строка.ИмяЯчейки, 4) = "П000", Сред(Строка.ИмяЯчейки, 1, 13), Строка.ИмяЯчейки);
										// При выгрузках JSON данные некоторых колонок дублируются источнии данных
										Если МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["Строки"].Колонки.Найти(ИмяЯчейки) = Неопределено Тогда
											МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["Строки"].Колонки.Добавить(ИмяЯчейки);
										КонецЕсли;
									КонецЦикла;
									
									ЕстьЗаписи = ДополнительныеПараметры.СписокПриложений.Получить(ТекущееИмяФормы);
								
									Если ЕстьЗаписи Тогда
										//Если записи обнаружены то заполняем таблицу значений
										Для Каждого СтрокаТаблицы Из Форма[ИмяТаблицы][ТекущийНомерДобавленнойФормы][СтрокаТЗ.ИмяЛиста] Цикл 
											НоваяСтрока = МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["Строки"].Добавить();
											ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы.Значение);
										КонецЦикла;
									КонецЕсли;
									ТекущийНомерДобавленнойФормы = ТекущийНомерДобавленнойФормы + 1;
								КонецЦикла;
								
							КонецЕсли;
						Иначе
							// 200.06, 700.02
							СтруктураПоиска = Новый Структура;
							СтруктураПоиска.Вставить("ИмяЛиста", СтрокаТЗ.ИмяЛиста);
							СтруктураПоиска.Вставить("КоличествоROW", "1");
							СтруктураПоиска.Вставить("КодФормы", ТекущееИмяФормы);
							СтрокиТаблицы = ТаблицаМногострочнойФормы.НайтиСтроки(СтруктураПоиска);
							
							ЕстьЗаписи = Ложь;
							
							Если НЕ Форма[ИмяТаблицы].Количество() = 0 Тогда
								ТекущийНомерДобавленнойФормы = 0;
							
								Для Каждого СтрокаФормы Из Форма[ИмяТаблицы] Цикл
									
									Если МассивСтруктур.Количество() = ТекущийНомерДобавленнойФормы Тогда
										// Первая итерация для структуры многостраничной формы, форма еще не добавлена	
										МассивСтруктур.Добавить(Новый Структура);	
									КонецЕсли;
									
									МногострочнаяСтруктура = МассивСтруктур[ТекущийНомерДобавленнойФормы];
									МногострочнаяСтруктура.Вставить(СтрокаТЗ.ИмяЛиста, Новый Структура);
									МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста].Вставить("Строки", Новый ТаблицаЗначений);
									
									Для Каждого Строка Из СтрокиТаблицы Цикл
										ИмяЯчейки = ?(Лев(Строка.ИмяЯчейки, 4) = "П000", Сред(Строка.ИмяЯчейки, 1, 13), Строка.ИмяЯчейки);
										// При выгрузках JSON данные некоторых колонок дублируются источнии данных
										Если МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["Строки"].Колонки.Найти(ИмяЯчейки) = Неопределено Тогда
											МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["Строки"].Колонки.Добавить(ИмяЯчейки);
										КонецЕсли;
									КонецЦикла;
									
									ЕстьЗаписи = ПроверитьЗаполненностьФормы(Форма, ТекущееИмяФормы);
									
									Если ЕстьЗаписи Тогда
										//Если записи обнаружены то заполняем таблицу значений
										Для Каждого СтрокаТаблицы Из Форма[ИмяТаблицы][ТекущийНомерДобавленнойФормы][СтрокаТЗ.ИмяЛиста] Цикл 
											НоваяСтрока = МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["Строки"].Добавить();
											ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы.Значение);
										КонецЦикла;
									КонецЕсли;
									
									МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста].Вставить("ШапкаИПодвал", Новый ТаблицаЗначений);
						
									МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["ШапкаИПодвал"].Колонки.Добавить("Значение");
									МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["ШапкаИПодвал"].Колонки.Добавить("ИмяОбласти");
									МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["ШапкаИПодвал"].Колонки.Добавить("ИмяПараметра");
									МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["ШапкаИПодвал"].Колонки.Добавить("Итог");
									
									МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста].Вставить("ИмяРеквизитаТаблицыСтрокГруппы", ИмяТаблицы);
										
									ТекущийНомерДобавленнойФормы = ТекущийНомерДобавленнойФормы + 1;
								КонецЦикла;	
							КонецЕсли;
							
						КонецЕсли;
	
					Иначе	
						МногострочнаяСтруктура.Вставить(СтрокаТЗ.ИмяЛиста, Новый Структура);
						МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста].Вставить("Строки", Новый ТаблицаЗначений);
						
						ИмяТаблицы = Сред(СтрокаТЗ.ИмяЯчейки, 1, 11);
							
						СтруктураПоиска = Новый Структура;
						СтруктураПоиска.Вставить("ИмяЛиста", СтрокаТЗ.ИмяЛиста);
						СтруктураПоиска.Вставить("КоличествоROW", "1");
						СтруктураПоиска.Вставить("КодФормы", ТекущееИмяФормы);
						СтрокиТаблицы = ТаблицаМногострочнойФормы.НайтиСтроки(СтруктураПоиска);
						
						ЕстьЗаписи = Ложь;
						Если Форма[ИмяТаблицы].Количество() = 1 Тогда
							Для Каждого Строка Из СтрокиТаблицы Цикл
								ИмяЯчейки = Сред(Строка.ИмяЯчейки, 1, 13);
								// При выгрузках JSON данные некоторых колонок дублируются источнии данных
								Если МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["Строки"].Колонки.Найти(ИмяЯчейки) = Неопределено Тогда
									МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["Строки"].Колонки.Добавить(ИмяЯчейки);
								КонецЕсли;
							КонецЦикла;
							СтрокаПервойСтраницы = Форма[ИмяТаблицы][0];
							ЕстьЗаписи = ЗначениеЗаполнено(СтрокаПервойСтраницы[ИмяТаблицы + "01"]) ИЛИ ЗначениеЗаполнено(СтрокаПервойСтраницы[ИмяТаблицы + "03"]);
						ИначеЕсли Не Форма[ИмяТаблицы].Количество() = 0 Тогда
							Для Каждого Строка Из СтрокиТаблицы Цикл
								ИмяЯчейки = Сред(Строка.ИмяЯчейки, 1, 13);
								// При выгрузках JSON данные некоторых колонок дублируются источнии данных
								Если МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["Строки"].Колонки.Найти(ИмяЯчейки) = Неопределено Тогда
									МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["Строки"].Колонки.Добавить(ИмяЯчейки);
								КонецЕсли;
							КонецЦикла;
							ЕстьЗаписи = Истина;
						КонецЕсли;
						
						ЕстьЗаписи = ДополнительныеПараметры.СписокПриложений.Получить(ТекущееИмяФормы);		
						
						Если ЕстьЗаписи Тогда
							//Если записи обнаружены то заполняем таблицу значений
							Для Каждого СтрокаТаблицы Из Форма[ИмяТаблицы] Цикл 
								НоваяСтрока = МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["Строки"].Добавить();
								ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
							КонецЦикла;
						КонецЕсли;
						
						МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста].Вставить("ШапкаИПодвал", Новый ТаблицаЗначений);
					
						МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["ШапкаИПодвал"].Колонки.Добавить("Значение");
						МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["ШапкаИПодвал"].Колонки.Добавить("ИмяОбласти");
						МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["ШапкаИПодвал"].Колонки.Добавить("ИмяПараметра");
						МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["ШапкаИПодвал"].Колонки.Добавить("Итог");
						
						МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста].Вставить("ИмяРеквизитаТаблицыСтрокГруппы", ИмяТаблицы);	
					КонецЕсли;
					
					
				КонецЕсли;
				
				ТекущийЛист = СтрокаТЗ.ИмяЛиста;
			КонецЕсли;
			
			// Заполнить итоги
			//Заполняем таблицу значений параметров шапки
			Если ЗначениеЗаполнено(СтрокаТЗ.ИмяЯчейки) И СтрокаТЗ.КодФормы = ТекущееИмяФормы Тогда
				Если ЭтоМногостраничнаяФорма Тогда
					Если СтрокаТЗ.КоличествоНаЛисте = 1 Тогда
						// 200.03	
					Иначе
						// 200.06, 700.02
						// Добавим значение Параметра СтраницаNИтоги и всех элементов структуры (квартал, год и т.д.)
						ТекущийНомерДобавленнойФормы = 0;						
						Для Каждого СтрокаФормы Из Форма[ИмяТаблицы] Цикл
							//Добавим новую строку в ТЗ значений шапки таблицы
							МногострочнаяСтруктура = МассивСтруктур[ТекущийНомерДобавленнойФормы];
									
							Если СтрокаФормы.Свойство(СтрокаТЗ.ИмяЯчейки) Тогда
								// Общие реквизиты формы		
								НоваяСтрока = МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["ШапкаИПодвал"].Добавить();
						
								НоваяСтрока.Значение 		= СтрокаФормы[СтрокаТЗ.ИмяЯчейки];
								НоваяСтрока.ИмяПараметра 	= СтрокаТЗ.ИмяЯчейки;
								НоваяСтрока.ИмяОбласти 		= СтрокаТЗ.ИмяЯчейки;
								НоваяСтрока.Итог 			= Ложь;
							ИначеЕсли Лев(СтрокаТЗ.ИмяЯчейки, 4) = "П000" Тогда
								// Строки итогов
								ИмяЛиста = СтрокаТЗ.ИмяЛиста;	
								НачалоРеквизита = Лев(СтрокаТЗ.ИмяЯчейки, СтрДлина(СтрокаТЗ.ИмяЯчейки)-3);
								КонецРеквизита = Прав(СтрокаТЗ.ИмяЯчейки, 2);
								ИмяЯчейки = НачалоРеквизита + "1" + КонецРеквизита;
								                                         
								Если СтрокаФормы.Свойство(ИмяЛиста+"Итоги") Тогда
									ЗначениеПараметра = ?(СтрокаФормы[ИмяЛиста+"Итоги"].Свойство(ИмяЯчейки), СтрокаФормы[ИмяЛиста+"Итоги"][ИмяЯчейки], Неопределено);		
									
									Если ЗначениеПараметра <> Неопределено Тогда 
										НоваяСтрока = МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["ШапкаИПодвал"].Добавить();
							
										НоваяСтрока.Значение 		= ЗначениеПараметра;
										НоваяСтрока.ИмяПараметра 	= СтрокаТЗ.ИмяЯчейки;
										НоваяСтрока.ИмяОбласти 		= СтрокаТЗ.ИмяЯчейки;
										НоваяСтрока.Итог 			= Истина;
									КонецЕсли;	
								КонецЕсли;	
							КонецЕсли;	
							
							ТекущийНомерДобавленнойФормы = ТекущийНомерДобавленнойФормы + 1;
						КонецЦикла;	
					КонецЕсли;
				Иначе	
					//Добавим новую строку в ТЗ значений шапки таблицы
					НоваяСтрока = МногострочнаяСтруктура[СтрокаТЗ.ИмяЛиста]["ШапкаИПодвал"].Добавить();
					
					//Получим значение параметра из структуры формы
					БуквыАлфавита = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
					ИмяЛиста = ?(Лев(СтрокаТЗ.ИмяЛиста, 8) = "Страница", СтрокаТЗ.ИмяЛиста, "Страница" + Строка(СтрНайти(БуквыАлфавита, Прав(СтрокаТЗ.ИмяЛиста, 1))));
					НачалоРеквизита = Лев(СтрокаТЗ.ИмяЯчейки, СтрДлина(СтрокаТЗ.ИмяЯчейки)-3);
					КонецРеквизита = Прав(СтрокаТЗ.ИмяЯчейки, 2);
					ИмяЯчейки = НачалоРеквизита + "1" + КонецРеквизита;
					
					СтруктураДанных = Форма["СтруктураДанных" + СтрокаТЗ.КодФормы + ИмяЛиста];
					ЗначениеПараметра = ?(СтруктураДанных.Свойство(ИмяЯчейки), СтруктураДанных[ИмяЯчейки], Неопределено);
					
					НоваяСтрока.Значение 		= ЗначениеПараметра;
					НоваяСтрока.ИмяПараметра 	= СтрокаТЗ.ИмяЯчейки;
					НоваяСтрока.ИмяОбласти 		= СтрокаТЗ.ИмяЯчейки;
					НоваяСтрока.Итог 			= Истина;
				КонецЕсли;		
			КонецЕсли;	
			
			НомерСтроки = НомерСтроки + 1;
			
		КонецЦикла;
	КонецЕсли;
	
	Если ЭтоМногостраничнаяФорма Тогда
		Если СтрокаТЗ.КоличествоНаЛисте = 1 Тогда
			// 200.03
			Возврат МногострочнаяСтруктура;
		Иначе
			// 200.06, 700.02
			Возврат МассивСтруктур;
		КонецЕсли;	
	Иначе
		Возврат МногострочнаяСтруктура;
	КонецЕсли;

КонецФункции

// Проверяет заполненность формы и возвращает результат в виде логического значения.
//
// Параметры:
//  Форма – ФормаКлиентскогоПриложения - объект формы, содержащий данные для проверки.
//  ТекущееИмяФормы – Строка (Необязательный) - код формы, используется для определения имени таблицы строк.
//
// Возвращаемое значение:
//  Булево:
//   * Истина – если хотя бы одно значение в таблице строк формы заполнено (кроме номера строки);
//   * Ложь – если таблица строк отсутствует или все строки формы пусты.
Функция ПроверитьЗаполненностьФормы(Форма, ТекущееИмяФормы = Неопределено) Экспорт            
	
	Если Отчетность1ССервер.ЕстьРеквизитФормы(Форма, "П000" + Прав(ТекущееИмяФормы,1) + "100002") Тогда
		ПерваяСтраницаФормы =  Форма.РеквизитФормыВЗначение("П000" + Прав(ТекущееИмяФормы,1) + "100002");
	ИначеЕсли Отчетность1ССервер.ЕстьРеквизитФормы(Форма, "П000" + Прав(ТекущееИмяФормы,1) + "100001") Тогда
		ПерваяСтраницаФормы =  Форма.РеквизитФормыВЗначение("П000" + Прав(ТекущееИмяФормы,1) + "100001");
	ИначеЕсли Отчетность1ССервер.ЕстьРеквизитФормы(Форма, "ТаблицаСтраницы"+ТекущееИмяФормы) Тогда
		ТаблицаСтраницыФормы = Форма.РеквизитФормыВЗначение("ТаблицаСтраницы"+ТекущееИмяФормы);
		Если ТаблицаСтраницыФормы.Количество() = 0 Тогда
		    Возврат Ложь;
		КонецЕсли;
		ПерваяСтраницаФормы = ТаблицаСтраницыФормы[0].Страница1[0].Значение;
		
		// В форме 200.03 всегда заполнены стандартные реквизиты по-умолчанию
		// Стандартная проверка на незаполненность всех реквизитов не сработает
		// Нужно составить список реквизитов, проверка которых не обязательна
		СписокНепроверяемыхРеквизитов = Новый Массив;
		Если ТекущееИмяФормы = "Форма200_03" Тогда
			СписокНепроверяемыхРеквизитов.Добавить("Квартал");
			СписокНепроверяемыхРеквизитов.Добавить("Год");
			СписокНепроверяемыхРеквизитов.Добавить("ИИН_БИН");
			СписокНепроверяемыхРеквизитов.Добавить("ОргНазв");
			СписокНепроверяемыхРеквизитов.Добавить("ОргНазв1");
			СписокНепроверяемыхРеквизитов.Добавить("ОргНазв2");
			СписокНепроверяемыхРеквизитов.Добавить("ОчереднаяПрил3");
		ИначеЕсли ТекущееИмяФормы = "Форма200_06" Тогда
			СписокНепроверяемыхРеквизитов.Добавить("П000610000201");
		КонецЕсли;	
	КонецЕсли;	
	
	Если ПерваяСтраницаФормы <> Неопределено Тогда
				
		Если ПерваяСтраницаФормы.Количество() > 0 Тогда
			
			Если Типзнч(ПерваяСтраницаФормы) = Тип("ТаблицаЗначений") Тогда
				ПустаяТЗ = Истина;
				Для Каждого СтрокаТЗ Из ПерваяСтраницаФормы Цикл
					НомерКолонки = 0;
					Для Каждого КолонкаТЗ Из ПерваяСтраницаФормы.Колонки Цикл
						Если НомерКолонки = 0 Тогда
							// Значение номера строки всегда заполнено, пропускаем
							НомерКолонки = НомерКолонки + 1;
							Продолжить;
						Иначе	
							Если ЗначениеЗаполнено(СтрокаТЗ[КолонкаТЗ.Имя]) Тогда
								ПустаяТЗ = Ложь;
								Прервать;
							КонецЕсли;
							НомерКолонки = НомерКолонки + 1;
						КонецЕсли;	
					КонецЦикла;		
				КонецЦикла;	
				
				Если НЕ ПустаяТЗ Тогда
					Возврат Истина;
				Иначе
					Возврат Ложь;
				КонецЕсли;
			ИначеЕсли Типзнч(ПерваяСтраницаФормы) = Тип("Структура") Тогда
				ПустаяТЗ = Истина;
				Для Каждого СтрокаТЗ Из ПерваяСтраницаФормы Цикл	
					Если НЕ СписокНепроверяемыхРеквизитов.Найти(СтрокаТЗ.Ключ) <> Неопределено И ЗначениеЗаполнено(СтрокаТЗ.Значение) Тогда
						ПустаяТЗ = Ложь;
						Прервать;
					КонецЕсли;	
				КонецЦикла;			
				
				Если НЕ ПустаяТЗ Тогда
					Возврат Истина;
				Иначе
					Возврат Ложь;
				КонецЕсли;	
			КонецЕсли;	
			
		Иначе
			Возврат Ложь;
		КонецЕсли; 
		
	КонецЕсли;
				
КонецФункции

// Получает значение указанного расчетного показателя на определённую дату.
//
// Параметры:
//  ИмяПоказателя – Строка - Имя расчетного показателя (например, "РазмерМЗПДляЦелейНалогообложения").
//  ДатаЗначения – Дата - Дата, на которую требуется определить актуальное значение показателя.
//
// Возвращаемое значение:
//  Число – значение расчетного показателя на указанную дату;
//  Неопределено – если показатель не найден или не поддерживается.
Функция ПолучитьЗначениеРасчетногоПоказателя(ИмяПоказателя, ДатаЗначения) Экспорт	
	ЗначениеПоказателя = Неопределено;
	
	Если ИмяПоказателя = "РазмерМЗП" Тогда
		ЗначениеПоказателя = ЗарплатаКадры.МинимальныйРазмерОплатыТрудаРФ(НачалоГода(ДатаЗначения));
	КонецЕсли;
	
	Если ИмяПоказателя = "РазмерМРП" Тогда
		ЗначениеПоказателя = ЗарплатаКадры.МесячныйРасчетныйПоказатель(НачалоГода(ДатаЗначения));
	КонецЕсли;
	
	Возврат ЗначениеПоказателя;	
КонецФункции

// Номер колонки для реквизита имя ячейки из макета ВыгрузкаJSONОтчетность1С, по которому необходимо формировать JSON структуру
// 5 - БК
// 6 - ERP
Функция ПолучитьНомерКолонки_ИмяЯчейки() Экспорт            
	
	Возврат 6;
	
КонецФункции

// Определяет, является ли налогоплательщик индивидуальным предпринимателем.
//
// Параметры:
//  Налогоплательщик – СправочникСсылка.Организации
//
// Возвращаемое значение:
//  Булево – Истина, если налогоплательщик является физическим лицом (индивидуальным предпринимателем),
//            Ложь – если налогоплательщик является юридическим лицом.
Функция ЭтоИП(Налогоплательщик) Экспорт
	
	Возврат ?(Налогоплательщик.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо, Истина, Ложь);
	
КонецФункции

// Определяет, является тип налогоплательщика.
//
// Параметры:
//  Налогоплательщик – СправочникСсылка.Организации
//
// Возвращаемое значение:
//  Строка – код идентификатора налогоплательщика.
Функция ТипНалогоплательщика(Налогоплательщик) Экспорт
	// UL - Юридическое лицо
	// UL_NR - Юридическое лицо-нерезидент
	// IP - Индивидуальный предприниматель
	// LZCHP - Лица, занимающиеся частной практикой
    ТипНалогоплательщика = "";
	
	Если Налогоплательщик.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо Тогда
		ТипНалогоплательщика = "IP";	
	ИначеЕсли Налогоплательщик.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ЮридическоеЛицо Тогда
		ТипНалогоплательщика = "UL";
	КонецЕсли;
	
	Возврат ТипНалогоплательщика;
КонецФункции

#КонецОбласти

#Область УправлениеИнтерфейсомФормы

// Активизирует элемент формы и выделяет реквизит по выбранной строке дерева ошибок.
//
// Параметры:
//   Форма – текущая форма отчета, в которой находится дерево ошибок.
//   ДеревоОшибокТекущиеДанные – структура, содержащая данные выбранной строки дерева ошибок, включая:
//     * ИндексВТаблицеОшибок – индекс строки в таблице ошибок;
//     * КодФормы – идентификатор формы;
//     * Страница – номер страницы или листа;
//     * НомерЛиста – конкретный лист документа (если применимо);
//     * Реквизит – имя реквизита в табличном документе.
Процедура ДеревоОшибокВыбор(Форма, ДеревоОшибокТекущиеДанные) Экспорт
	
	НайтиСтраницу = Ложь;
	Для Каждого ТекСтраница Из Форма.РазделыОтчета.ПолучитьЭлементы() Цикл
		ЭтоМногостраничныйРаздел = Ложь;
		Если ТекСтраница.Свойство("РазделМногостраничный") Тогда
			ЭтоМногостраничныйРаздел = ТекСтраница.РазделМногостраничный;
		КонецЕсли;	
		Если ТекСтраница.КолонкаРазделыОтчетаСокрНаим = ДеревоОшибокТекущиеДанные.КодФормы + ДеревоОшибокТекущиеДанные.Страница И (НЕ ЭтоМногостраничныйРаздел Или ТекСтраница.КолонкаНомерСтраницыРазделаОтчета = Число(ДеревоОшибокТекущиеДанные.НомерЛиста)) Тогда
			Форма.Элементы.РазделыОтчета.ТекущаяСтрока = ТекСтраница.ПолучитьИдентификатор();
			НайтиСтраницу = Истина;
			ИмяТекРаздела = ТекСтраница.КолонкаРазделыОтчетаСокрНаим;
			НомерСтраницыРазделаОтчета = ТекСтраница.КолонкаНомерСтраницыРазделаОтчета;
		Иначе
			Для Каждого ТекСтраницаВлож Из ТекСтраница.ПолучитьЭлементы() Цикл
				ЭтоМногостраничныйРаздел = Ложь;
				Если ТекСтраница.Свойство("РазделМногостраничный") Тогда
					ЭтоМногостраничныйРаздел = ТекСтраница.РазделМногостраничный;
				КонецЕсли;
				Если ТекСтраницаВлож.КолонкаРазделыОтчетаСокрНаим = ДеревоОшибокТекущиеДанные.КодФормы + ДеревоОшибокТекущиеДанные.Страница И (НЕ ЭтоМногостраничныйРаздел Или ТекСтраницаВлож.КолонкаНомерСтраницыРазделаОтчета = Число(ДеревоОшибокТекущиеДанные.НомерЛиста)) Тогда
					Форма.Элементы.РазделыОтчета.ТекущаяСтрока = ТекСтраницаВлож.ПолучитьИдентификатор();
					НайтиСтраницу = Истина;
					ИмяТекРаздела = ТекСтраницаВлож.КолонкаРазделыОтчетаСокрНаим;
					НомерСтраницыРазделаОтчета = ТекСтраницаВлож.КолонкаНомерСтраницыРазделаОтчета;
				Иначе
					Для Каждого ТекСтраницаВлож2 Из ТекСтраницаВлож.ПолучитьЭлементы() Цикл
						ЭтоМногостраничныйРаздел = Ложь;
						Если ТекСтраница.Свойство("РазделМногостраничный") Тогда
							ЭтоМногостраничныйРаздел = ТекСтраница.РазделМногостраничный;
						КонецЕсли;
						Если ТекСтраницаВлож2.КолонкаРазделыОтчетаСокрНаим = ДеревоОшибокТекущиеДанные.КодФормы + ДеревоОшибокТекущиеДанные.Страница И (НЕ ЭтоМногостраничныйРаздел Или ТекСтраницаВлож2.КолонкаНомерСтраницыРазделаОтчета = Число(ДеревоОшибокТекущиеДанные.НомерЛиста)) Тогда
							Форма.Элементы.РазделыОтчета.ТекущаяСтрока = ТекСтраницаВлож2.ПолучитьИдентификатор();
							НайтиСтраницу = Истина;
							ИмяТекРаздела = ТекСтраницаВлож2.КолонкаРазделыОтчетаСокрНаим;
							НомерСтраницыРазделаОтчета = ТекСтраницаВлож2.КолонкаНомерСтраницыРазделаОтчета;	
						КонецЕсли;
					КонецЦикла
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
		
	Если НайтиСтраницу Тогда
		Форма.РазделыОтчетаПриАктивизацииСтрокиНаСервереОтчетность1С(ИмяТекРаздела, НомерСтраницыРазделаОтчета);
		
		Форма.ТекущийЭлемент = Форма.Элементы.ТабличныйДокумент;
		
		МестноеИмяРеквизита = ДеревоОшибокТекущиеДанные.Реквизит;
		
		// в многострочном приложении в БК у имен полей лишние "хвосты"
		ПозицияДвойногоПодчерка = СтрНайти(МестноеИмяРеквизита, "__", НаправлениеПоиска.СКонца);
		Если ПозицияДвойногоПодчерка > 0 Тогда
			МестноеИмяРеквизита = Лев(МестноеИмяРеквизита, ПозицияДвойногоПодчерка - 1);
		КонецЕсли;
		
		МестныйНомерСтроки = ?(ДеревоОшибокТекущиеДанные.НомерСтроки, 
							   ДеревоОшибокТекущиеДанные.НомерСтроки - 1,
							   ДеревоОшибокТекущиеДанные.НомерСтроки);
		
		ОбластьРеквизита = Форма.ТабличныйДокумент.Области.Найти(МестноеИмяРеквизита + ?(МестныйНомерСтроки, "_" + Формат(МестныйНомерСтроки, "ЧГ=0"), ""));
		Если ОбластьРеквизита = Неопределено Тогда
			Если Не ПустаяСтрока(МестноеИмяРеквизита) Тогда
				ОбластьРеквизита = Форма.ТабличныйДокумент.Области.Найти(МестноеИмяРеквизита);
			КонецЕсли;
		КонецЕсли;
			
		Если ОбластьРеквизита <> Неопределено Тогда
		
			ОбластьРеквизита.Узор = ТипУзораТабличногоДокумента.Узор13;
			ОбластьРеквизита.ЦветУзора = Новый Цвет(255, 0, 0);
			ВыделенныеОбласти = Новый Массив;
			ВыделенныеОбласти.Добавить(ОбластьРеквизита);
			Форма.Элементы.ТабличныйДокумент.УстановитьВыделенныеОбласти(ВыделенныеОбласти);
				
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры

// Выполняется при создании формы на сервере. 
// Используется для инициализации данных формы, оформления дерева ошибок
// и управления доступностью реквизитов.
//
// Параметры:
//   Форма – ссылка на форму клиентского приложения.
//       Активная форма регламентированного отчета.
Процедура ПриСозданииНаСервере(Форма) Экспорт
	Если Форма.СтруктураРеквизитовФормы.мСохраненныйДок <> Неопределено Тогда
		СписокСохранения = Форма.СтруктураРеквизитовФормы.мСохраненныйДок.ДанныеОтчета.Получить();
		
		Если СписокСохранения.Свойство("СтруктураДополнительныхРеквизитовФормы") Тогда
			СтруктураДополнительныхРеквизитовФормы = СписокСохранения.СтруктураДополнительныхРеквизитовФормы;	
			
			Для Каждого СохраненныйРеквизит из СтруктураДополнительныхРеквизитовФормы Цикл
				// Для внутреннего использования
				Для Каждого РеквизитФормы Из Форма.ПолучитьРеквизиты() Цикл
					Если ВРег(РеквизитФормы.Имя) <> ВРег(СохраненныйРеквизит.Ключ) Тогда
						Продолжить;
					КонецЕсли;	                                                                                                                       
					
					Если РеквизитФормы.ТипЗначения.СодержитТип(Тип("ТабличныйДокумент")) Тогда
						Продолжить;
					КонецЕсли;				
					
					Если РеквизитФормы.ТипЗначения.СодержитТип(Тип("ДеревоЗначений")) ИЛИ РеквизитФормы.ТипЗначения.СодержитТип(Тип("ТаблицаЗначений")) Тогда					
						Форма.ЗначениеВРеквизитФормы(СохраненныйРеквизит.Значение, СохраненныйРеквизит.Ключ);
					Иначе
						Форма[РеквизитФормы.Имя] = СохраненныйРеквизит.Значение;
					КонецЕсли;			
					
				КонецЦикла;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры
	
Процедура Сохранить(Форма, ДокументРеглОтчет, СписокСохранения) Экспорт
	СтруктураДополнительныхРеквизитовФормы = Новый Структура;	
	МассивРеквизитовФормы = Форма.ПолучитьРеквизиты();
	Для Счетчик = 0 По МассивРеквизитовФормы.Количество()-1 Цикл		
		РеквизитФормы = МассивРеквизитовФормы[Счетчик];
		Если СтрНайти(РеквизитФормы.Имя, "Отчетность1С") = 0 Тогда
			Продолжить;
		КонецЕсли;	
		
		Если РеквизитФормы.ТипЗначения.СодержитТип(Тип("ДеревоЗначений")) ИЛИ РеквизитФормы.ТипЗначения.СодержитТип(Тип("ТаблицаЗначений")) Тогда
			СтруктураДополнительныхРеквизитовФормы.Вставить(РеквизитФормы.Имя, Форма.РеквизитФормыВЗначение(РеквизитФормы.Имя));
		Иначе
			СтруктураДополнительныхРеквизитовФормы.Вставить(РеквизитФормы.Имя, Форма[РеквизитФормы.Имя]);
		КонецЕсли;
	КонецЦикла;
	
	СписокСохранения.Вставить("СтруктураДополнительныхРеквизитовФормы", СтруктураДополнительныхРеквизитовФормы);	                  	
КонецПроцедуры

// Настраивает видимость и доступность реквизитов и элементов управления формы
// регламентированной отчетности в зависимости от статуса отправки и наличия ошибок.
//
// Параметры:
//   Форма – ссылка на форму клиентского приложения.
//       Активная форма регламентированного отчета.
Процедура УстановитьВидимостьДоступностьРеквизитов(Форма) Экспорт
	
	ФормаУжеОтправлена = Отчетность1СКлиентСервер.СтатусОтправки_ФормаУжеОтправлена(Форма);
	
	Если Форма.Элементы.Найти("ПодменюОчистить") <> Неопределено Тогда
		Форма.Элементы.ПодменюОчистить.Доступность = НЕ ФормаУжеОтправлена;	
	КонецЕсли;
	Если Форма.Элементы.Найти("Заполнить") <> Неопределено Тогда
		Форма.Элементы.Заполнить.Доступность = НЕ ФормаУжеОтправлена;
	КонецЕсли;
	Если Форма.Элементы.Найти("СтраницыОтчета") <> Неопределено Тогда
		Форма.Элементы.СтраницыОтчета.ТолькоПросмотр = ФормаУжеОтправлена;
	КонецЕсли;

КонецПроцедуры
 
#КонецОбласти

#Область ПроверкаФЛК

// Возвращает ставки налогов по выбранной организации на заданную дату
//
Функция ПолучитьСведенияОСтавкахНалогов(Форма) Экспорт	
	СтруктураНалогов = Новый Структура;
	
	СтруктураНалогов.Вставить("НеРассчитыватьСуммыКУплате", Ложь);
	СтруктураНалогов.Вставить("мСтавкаСО", 0);
	СтруктураНалогов.Вставить("мСтавкаОПВ", 0);
	СтруктураНалогов.Вставить("мСтавкаВОСМС", 0);	
	СтруктураНалогов.Вставить("мСтавкаОПВР", 0);
	
	ИдентификаторНалогоплательщика = Отчетность1ССервер.ОпределитьИдентификаторНалогоплательщика(Форма);
	Налогоплательщик = ИдентификаторНалогоплательщика.Налогоплательщик;
	Дата = Форма.СтруктураРеквизитовФормы.мДатаКонцаПериодаОтчета;
	
	ВидыНалогов = Новый Массив;
	ВидыНалогов.Добавить(Перечисления.ВидыНалоговВзносовОтчислений.ОПВ);
	ВидыНалогов.Добавить(Перечисления.ВидыНалоговВзносовОтчислений.СО);
	ВидыНалогов.Добавить(Перечисления.ВидыНалоговВзносовОтчислений.ОПВР);
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	МАКСИМУМ(СведенияОСтавкахНалоговСборовОтчислений.Период) КАК Период
	                      |ПОМЕСТИТЬ ВТМаксимальныйПериод
	                      |ИЗ
	                      |	РегистрСведений.СведенияОСтавкахНалоговСборовОтчислений.СрезПоследних(
	                      |			&Дата,
	                      |			(Организация = &Налогоплательщик
	                      |				ИЛИ Организация = &ПустойНалогоплательщик)
	                      |				И (ВидДохода = &ВидДохода
	                      |					ИЛИ ВидДохода = &ПустойВидДохода)
	                      |				И ВидНалогаВзносаОтчисления В (&ВидНалога)) КАК СведенияОСтавкахНалоговСборовОтчислений
	                      |;
	                      |
	                      |////////////////////////////////////////////////////////////////////////////////
	                      |ВЫБРАТЬ РАЗРЕШЕННЫЕ
	                      |	СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних.Период КАК Период,
	                      |	СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних.ВидДохода КАК ВидДохода,
	                      |	СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних.Организация КАК Организация,
	                      |	ЕСТЬNULL(СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних.Ставка, 0) КАК Ставка,
	                      |	ВЫБОР
	                      |		КОГДА СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних.Организация = &Налогоплательщик
	                      |				И СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних.ВидДохода = &ВидДохода
	                      |			ТОГДА 1
	                      |		КОГДА СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних.Организация = &Налогоплательщик
	                      |				И СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних.ВидДохода = &ПустойВидДохода
	                      |			ТОГДА 2
	                      |		КОГДА СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних.Организация = &ПустойНалогоплательщик
	                      |				И СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних.ВидДохода = &ВидДохода
	                      |			ТОГДА 3
	                      |		КОГДА СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних.Организация = &ПустойНалогоплательщик
	                      |				И СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних.ВидДохода = &ПустойВидДохода
	                      |			ТОГДА 4
	                      |	КОНЕЦ КАК Приоритет,
	                      |	СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления
	                      |ИЗ
	                      |	ВТМаксимальныйПериод КАК МаксимальныйПериод
	                      |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОСтавкахНалоговСборовОтчислений.СрезПоследних КАК СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних
	                      |		ПО (МаксимальныйПериод.Период = СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних.Период
	                      |					И СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних.Организация = &Налогоплательщик
	                      |				ИЛИ СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних.Организация = &ПустойНалогоплательщик
	                      |					И СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних.ВидДохода = &ВидДохода
	                      |				ИЛИ СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних.ВидДохода = &ПустойВидДохода
	                      |					И СведенияОСтавкахНалоговСборовОтчисленийСрезПоследних.ВидНалогаВзносаОтчисления В (&ВидНалога))
	                      |
	                      |ОБЪЕДИНИТЬ ВСЕ
	                      |
	                      |ВЫБРАТЬ
	                      |	СведенияОСтавкахОСМССрезПоследних.Период,
	                      |	СведенияОСтавкахОСМССрезПоследних.ВидДохода,
	                      |	СведенияОСтавкахОСМССрезПоследних.Организация,
	                      |	ЕСТЬNULL(СведенияОСтавкахОСМССрезПоследних.СтавкаВзносы, 0),
	                      |	ВЫБОР
	                      |		КОГДА СведенияОСтавкахОСМССрезПоследних.Организация = &Налогоплательщик
	                      |				И СведенияОСтавкахОСМССрезПоследних.ВидДохода = &ВидДохода
	                      |			ТОГДА 1
	                      |		КОГДА СведенияОСтавкахОСМССрезПоследних.Организация = &Налогоплательщик
	                      |				И СведенияОСтавкахОСМССрезПоследних.ВидДохода = &ПустойВидДохода
	                      |			ТОГДА 2
	                      |		КОГДА СведенияОСтавкахОСМССрезПоследних.Организация = &ПустойНалогоплательщик
	                      |				И СведенияОСтавкахОСМССрезПоследних.ВидДохода = &ВидДохода
	                      |			ТОГДА 3
	                      |		КОГДА СведенияОСтавкахОСМССрезПоследних.Организация = &ПустойНалогоплательщик
	                      |				И СведенияОСтавкахОСМССрезПоследних.ВидДохода = &ПустойВидДохода
	                      |			ТОГДА 4
	                      |	КОНЕЦ,
	                      |	ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ВОСМС)
	                      |ИЗ
	                      |	РегистрСведений.СведенияОСтавкахОСМС.СрезПоследних(
	                      |			&Дата,
	                      |			(Организация = &Налогоплательщик
	                      |				ИЛИ Организация = &ПустойНалогоплательщик)
	                      |				И (ВидДохода = &ВидДохода
	                      |					ИЛИ ВидДохода = &ПустойВидДохода)) КАК СведенияОСтавкахОСМССрезПоследних
	                      |
	                      |УПОРЯДОЧИТЬ ПО
	                      |	Приоритет");
	  
	Запрос.УстановитьПараметр("Дата", Дата);					  
	Запрос.УстановитьПараметр("Налогоплательщик", Налогоплательщик);					  
	Запрос.УстановитьПараметр("ПустойНалогоплательщик", Справочники.Организации.ПустаяСсылка());		
	Запрос.УстановитьПараметр("ПустойВидДохода", Справочники.ВидыДоходов.ПустаяСсылка());
	Запрос.УстановитьПараметр("ВидДохода", Справочники.ВидыДоходов.ДоходСубъектаПредпринимательства);
	Запрос.УстановитьПараметр("ВидНалога", ВидыНалогов);
	
	Результат = Запрос.Выполнить();
	Если НЕ Результат.Пустой() Тогда
		Выборка = Результат.Выбрать();
	
		Пока Выборка.Следующий() Цикл
			Если Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.СО Тогда
				СтруктураНалогов.Вставить("мСтавкаСО", Выборка.Ставка);
			ИначеЕсли Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ОПВ Тогда	
				СтруктураНалогов.Вставить("мСтавкаОПВ", Выборка.Ставка);
			ИначеЕсли Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ОПВР Тогда	
				СтруктураНалогов.Вставить("мСтавкаОПВР", Выборка.Ставка);
			ИначеЕсли Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС Тогда	
				СтруктураНалогов.Вставить("мСтавкаВОСМС", Выборка.Ставка);	
			КонецЕсли;	
		КонецЦикла;
	КонецЕсли;	
			
	Возврат СтруктураНалогов;
КонецФункции

