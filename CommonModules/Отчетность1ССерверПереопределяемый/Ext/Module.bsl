#Область Отправка

// Передает значение в структуру данных формы и при необходимости в табличное поле или многострочную часть.
//
// Назначение:
//   Процедура используется для записи значения в структуру формы, а также для отображения этого значения
//   в табличных полях или многострочных частях формы отчета. Это обеспечивает синхронизацию данных между
//   внутренними структурами и визуальными элементами формы.
//
// Параметры:
//   Форма – текущая форма отчета, в которую необходимо передать значение.
//   КодФормы – идентификатор формы, в структуру которой передается значение.
//   ИмяОбласти – имя реквизита или области формы, куда передается значение.
//   Значение – значение для передачи (по умолчанию пустая строка "").
//   ПередаватьВТабличноеПоле – логическое значение, указывающее, нужно ли передавать значение в табличное поле (по умолчанию Истина).
//   ПередаватьВМногострочнуюЧасть – логическое значение, указывающее, нужно ли передавать значение в многострочную часть формы (по умолчанию Ложь).
//   ПараметрРасшифровкиСтроки – дополнительный параметр для расшифровки строки (по умолчанию Неопределено).
//
Процедура ПередатьЗначениеВСтруктуру(Форма, КодФормы, ИмяОбласти, Значение = "", ПередаватьВТабличноеПоле = Истина, ПередаватьВМногострочнуюЧасть = Ложь, ПараметрРасшифровкиСтроки = Неопределено) Экспорт

	СписокФормБезИерархии = Форма.РеквизитФормыВЗначение("мСписокФормБезИерархии");
	
	НайденнаяСтрока = СписокФормБезИерархии.Строки.Найти(КодФормы,"КодФормы");
	
	ТаблицаДанных = НайденнаяСтрока.Значение;
			
	Строка = ТаблицаДанных.Найти(ИмяОбласти,"ИмяОбласти");
	Если Строка <> Неопределено Тогда
		Строка.Значение = Значение;
	Иначе
		Отчетность1СКлиентСервер.СообщитьПользователю(Отчетность1СКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'В структуре формы ""%1"" не найдена область ""%2"".'"), КодФормы, ИмяОбласти));
	КонецЕсли;
	
	Если ПередаватьВТабличноеПоле Тогда
		СтраницаОсновнойФормы = Форма.РазделыОтчета.ПолучитьЭлементы()[0]; 
		ПоследняяСтраницаОсновнойФормы = СтраницаОсновнойФормы.ПолучитьЭлементы()[СтраницаОсновнойФормы.ПолучитьЭлементы().Количество()-1];
		Форма.Элементы.РазделыОтчета.ТекущаяСтрока = ПоследняяСтраницаОсновнойФормы.ПолучитьИдентификатор();
		          	
		ТекОбласть = Форма.ТабличныйДокумент.Области.Найти(ИмяОбласти);
		Если ТекОбласть <> Неопределено Тогда 
			Если ТекОбласть.СодержитЗначение Тогда
				ТекОбласть.Значение = Значение;
			Иначе
				ТекОбласть.Текст = Значение;
			КонецЕсли; 
		КонецЕсли;	
	КонецЕсли;
	
	Если Отчетность1ССервер.ЕстьРеквизитФормы(Форма, "мСписокФормБезИерархии") Тогда
		Форма.ЗначениеВРеквизитФормы(СписокФормБезИерархии, "мСписокФормБезИерархии");
	КонецЕсли;
КонецПроцедуры

