// Заполняет список синонимов полей формы и соответствующих им полей из структуры json.
// 
// Параметры: 
//  Форма - ФормаКлиентскогоПриложения - форма отчета
//  ИмяМакетаВыгрузки - Строка - название макета выгрузки   
Процедура ЗаполнитьСоответствияСинонимовЭлементов(Форма, ИмяМакетаВыгрузки = "ВыгрузкаJSONОтчетность1С", ИдентификаторВидаФНО=Неопределено)
	
	МакетВыгрузки = Отчеты[Сред(Лев(Форма.ИмяФормы, СтрНайти(Форма.ИмяФормы, ".Форма.") - 1), 7)].ПолучитьМакет(ИмяМакетаВыгрузки);
	Префикс = Прав(Форма.СтруктураРеквизитовФормы.мВыбраннаяФорма, 7);

	СинонимыЭлементовJSON = Новый Соответствие;
	СинонимыЭлементовФормы = Новый Соответствие;
	
	СоответствиеЭлементовФормы = Новый Соответствие;
	СоответствиеАльтернативныхЭлементовФормы = Новый Соответствие;

	ОбластьВыгрузки = МакетВыгрузки.Область("Выгрузка" + Префикс);
	Для Ном = ОбластьВыгрузки.Верх По ОбластьВыгрузки.Низ Цикл
		ВладелецJSON = СокрП(МакетВыгрузки.Область(Ном, 3).Текст); 
		ИмяЭлементаJSON = СокрП(МакетВыгрузки.Область(Ном, 4).Текст); // Элемент в JSON
		ИмяЯчейкиНомерКолонки = Отчетность1ССерверПереопределяемый.ПолучитьНомерКолонки_ИмяЯчейки();
		ИмяЭлемента = СокрП(МакетВыгрузки.Область(Ном, ИмяЯчейкиНомерКолонки).Текст); // Элемент формы
		Синоним = СокрП(МакетВыгрузки.Область(Ном, 13).Текст); // Пользовательское представление
		
		ИмяОбласти = СокрП(МакетВыгрузки.Область(Ном, 5).Текст);
		ИмяОбластиСиноним = СокрП(МакетВыгрузки.Область(Ном, ИмяЯчейкиНомерКолонки).Текст); // Элемент формы
	
		СинонимыЭлементовJSON.Вставить(ВладелецJSON + "." + ИмяЭлементаJSON, ИмяЭлемента);  // для преобразования ошибок ФЛК, возвращаемых с сервера
		СинонимыЭлементовФормы.Вставить(ИмяЭлемента, Синоним);
		
		Если ЗначениеЗаполнено(ИмяОбласти) И ЗначениеЗаполнено(ИмяОбластиСиноним) Тогда
			ИмяОбласти = ?(ИмяОбласти = "Ф200_06БИНФилиала", "ИИН_БИНФилиала", ИмяОбласти);
			ИмяОбластиСиноним = ?(Лев(ИмяОбласти, 21) = "ЧисленностьРаботников", ИмяОбласти, ИмяОбластиСиноним);
			ИмяОбластиСиноним = ?(Лев(ИмяОбласти, 22) = "ЧисленностьИностранцев", ИмяОбласти, ИмяОбластиСиноним);
				
			СоответствиеЭлементовФормы.Вставить(ИмяОбласти, ИмяОбластиСиноним);
			СоответствиеАльтернативныхЭлементовФормы.Вставить(ИмяОбластиСиноним, ИмяОбласти);
		КонецЕсли;	
	КонецЦикла;

	МакетВыгрузки = Отчеты[Сред(Лев(Форма.ИмяФормы, СтрНайти(Форма.ИмяФормы, ".Форма.") - 1), 7)].ПолучитьМакет("СинонимыОтчетность1С");

	ОбластьВыгрузки = МакетВыгрузки.Область("Выгрузка" + Префикс);
	Для Ном = ОбластьВыгрузки.Верх По ОбластьВыгрузки.Низ Цикл
		ИмяЭлементаJSON = СокрП(МакетВыгрузки.Область(Ном, 1).Текст); // Элемент в JSON
		ИмяЭлемента = СокрП(МакетВыгрузки.Область(Ном, 2).Текст); // Элемент формы
		Синоним = СокрП(МакетВыгрузки.Область(Ном, 3).Текст); // Пользовательское представление
		Если ЗначениеЗаполнено(ИмяЭлементаJSON) Тогда
			СинонимыЭлементовJSON.Вставить(ИмяЭлементаJSON, ИмяЭлемента);  // для преобразования ошибок ФЛК, возвращаемых с сервера
		КонецЕсли;
		Если ЗначениеЗаполнено(ИмяЭлемента) Тогда
			СинонимыЭлементовФормы.Вставить(ИмяЭлемента, Синоним);
		КонецЕсли;
	КонецЦикла;
	
	Форма.СоответствиеСинонимовОтчетность1С.Вставить("СинонимыПолей", СинонимыЭлементовФормы);
	Форма.СоответствиеСинонимовОтчетность1С.Вставить("СинонимыЭлементовJSON", СинонимыЭлементовJSON);
	Форма.СоответствиеСинонимовОтчетность1С.Вставить("СоответствиеЭлементовФормы", СоответствиеЭлементовФормы);
	Форма.СоответствиеСинонимовОтчетность1С.Вставить("СоответствиеАльтернативныхЭлементовФормы", СоответствиеАльтернативныхЭлементовФормы);
КонецПроцедуры

// Устанавливает визуальный признак критичности для элементов дерева ошибок.
//
// Параметры:
//   Дерево – ДеревоЗначений, элементы которого необходимо обработать.
Процедура УстановитьПризнакКритичности(Дерево)
	Для Каждого Строка Из Дерево.ПолучитьЭлементы() Цикл
		Если Строка.ПолучитьЭлементы().Количество() > 0 Тогда
			УстановитьПризнакКритичности(Строка);
		КонецЕсли;
		Если Строка.Критичность = Истина Тогда
			Строка.КритичностьСимвол = НСтр("ru='Ошибка!'");
			Если ЗначениеЗаполнено(Строка.Страница) Тогда
			    Дерево.Критичность = Истина;
			КонецЕсли;
		Иначе
			Строка.КритичностьСимвол = НСтр("ru='i'");
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

// Подсчитывает количество ошибок и критичных ошибок в дереве ошибок и формирует текстовое представление.
//
// Параметры:
//   Дерево – ДеревоЗначений, элементы которого необходимо обработать.
//   ПоказыватьВсеОшибки – Булево, определяет, включать ли некритичные ошибки в текстовое отображение.
//   КоличествоВсегоДерева – Число, по ссылке возвращает суммарное количество некритичных ошибок дерева.
//   КоличествоКритичныхДерева – Число, по ссылке возвращает суммарное количество критичных ошибок дерева.
//
Процедура ПосчитатьОшибкиДерева(Дерево, ПоказыватьВсеОшибки, КоличествоВсегоДерева, КоличествоКритичныхДерева)
	КоличествоВсего = 0;
	КоличествоКритичных = 0;
	Для Каждого Строка Из Дерево.ПолучитьЭлементы() Цикл
		Если Строка.ПолучитьЭлементы().Количество() > 0 Тогда
			ПосчитатьОшибкиДерева(Строка, ПоказыватьВсеОшибки, КоличествоВсего, КоличествоКритичных);
		Иначе
			Если Строка.Критичность = Истина Тогда
				КоличествоКритичных = КоличествоКритичных + 1;
			Иначе
				КоличествоВсего = КоличествоВсего + 1;
			КонецЕсли;
		КонецЕсли;
		Если ЗначениеЗаполнено(Строка.Страница) Тогда
			Если (КоличествоВсего + КоличествоКритичных) > 0 Тогда
				Если ПоказыватьВсеОшибки Тогда
				    Дерево.Ошибка = Отчетность1СКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Ошибок: %1; Обратить внимание: %2.'"),Строка(КоличествоКритичных), Строка(КоличествоВсего));
				Иначе
					Дерево.Ошибка = Отчетность1СКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Ошибок: %1; '"),Строка(КоличествоКритичных));
				КонецЕсли;
		    Иначе
				Дерево.Ошибка = Неопределено;
			КонецЕсли;
	    КонецЕсли;
	КонецЦикла;
	КоличествоВсегоДерева = КоличествоВсегоДерева + КоличествоВсего;
	КоличествоКритичныхДерева = КоличествоКритичныхДерева + КоличествоКритичных;	
КонецПроцедуры

// Подсчитывает количество критичных и некритичных ошибок в таблице ошибок.
//
// Параметры:
//   ТаблицаОшибок – ТаблицаЗначений, содержащая строки с реквизитом "Критичность".
//   КоличествоВсегоТаблицы – Число, по ссылке возвращает количество некритичных ошибок.
//   КоличествоКритичныхТаблицы – Число, по ссылке возвращает количество критичных ошибок.
//
Процедура ПосчитатьКоличествоОшибокВТаблице(ТаблицаОшибок, КоличествоВсегоТаблицы, КоличествоКритичныхТаблицы)
	КоличествоВсегоТаблицы = 0;
	КоличествоКритичныхТаблицы = 0;
	Для Каждого Строка Из ТаблицаОшибок Цикл
		Если Строка.Критичность = Истина Тогда
			КоличествоКритичныхТаблицы = КоличествоКритичныхТаблицы + 1;
		Иначе
			КоличествоВсегоТаблицы = КоличествоВсегоТаблицы + 1;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

// Устанавливает отбор для отображения только строк первого уровня в дереве ошибок.
//
// Параметры:
//   ЭлементОформления – ЭлементОформленияКомпоновкиДанных, к которому добавляется отбор.
Процедура ДобавитьОтборДляОформленияСтрокПервогоУровняДереваОшибок(ЭлементОформления)
	ГруппаЭлементовОтбора = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаЭлементовОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;

	ЭлементОтбора = ГруппаЭлементовОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ДеревоОшибокОтчетность1С.Форма");
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Заполнено;
	ЭлементОтбора.Использование = Истина;

	ЭлементОтбора = ГруппаЭлементовОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ДеревоОшибокОтчетность1С.Страница");
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.НеЗаполнено;
	ЭлементОтбора.Использование = Истина;

	ЭлементОтбора = ГруппаЭлементовОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ДеревоОшибокОтчетность1С.Поле");
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.НеЗаполнено;
	ЭлементОтбора.Использование = Истина;
КонецПроцедуры

// Устанавливает отбор для отображения строк второго уровня в дереве ошибок.
//
// Параметры:
//   ЭлементОформления – ЭлементОформленияКомпоновкиДанных, к которому добавляется отбор.
Процедура ДобавитьОтборДляОформленияСтрокВторогоУровняДереваОшибок(ЭлементОформления)
	ГруппаЭлементовОтбора = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ГруппаЭлементовОтбораКомпоновкиДанных"));
	ГруппаЭлементовОтбора.ТипГруппы = ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ;

	ЭлементОтбора = ГруппаЭлементовОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ДеревоОшибокОтчетность1С.Страница");
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Заполнено;
	ЭлементОтбора.Использование = Истина;

	ЭлементОтбора = ГруппаЭлементовОтбора.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ДеревоОшибокОтчетность1С.Поле");
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.НеЗаполнено;
	ЭлементОтбора.Использование = Истина;
КонецПроцедуры

// Добавляет список полей для оформления строк дерева ошибок.
//
// Параметры:
//   ЭлементОформления – ЭлементОформленияКомпоновкиДанных, к которому добавляются поля.
Процедура ДобавитьСписокОформляемыхПолейДереваОшибок(ЭлементОформления)
	ПолеЭлементаОформления = ЭлементОформления.Поля.Элементы.Добавить();
	ПолеЭлементаОформления.Поле = Новый ПолеКомпоновкиДанных("КолонкаФорма");
	ПолеЭлементаОформления = ЭлементОформления.Поля.Элементы.Добавить();
	ПолеЭлементаОформления.Поле = Новый ПолеКомпоновкиДанных("КолонкаСтраница");
	ПолеЭлементаОформления = ЭлементОформления.Поля.Элементы.Добавить();
	ПолеЭлементаОформления.Поле = Новый ПолеКомпоновкиДанных("КолонкаНомерЛиста");
	ПолеЭлементаОформления = ЭлементОформления.Поля.Элементы.Добавить();
	ПолеЭлементаОформления.Поле = Новый ПолеКомпоновкиДанных("КолонкаПоле");
	ПолеЭлементаОформления = ЭлементОформления.Поля.Элементы.Добавить();
	ПолеЭлементаОформления.Поле = Новый ПолеКомпоновкиДанных("КолонкаОшибка");
	ПолеЭлементаОформления = ЭлементОформления.Поля.Элементы.Добавить();
	ПолеЭлементаОформления.Поле = Новый ПолеКомпоновкиДанных("КолонкаКритичностьСимвол");
	ПолеЭлементаОформления = ЭлементОформления.Поля.Элементы.Добавить();
	ПолеЭлементаОформления.Поле = Новый ПолеКомпоновкиДанных("КолонкаНомерСтроки");
КонецПроцедуры

#КонецОбласти

