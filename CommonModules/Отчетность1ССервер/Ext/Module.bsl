#Область ПрограммныйИнтерфейс

#Область ВыгрузкаВJSON

// Формирует структуру параметров формы регламентированной отчетности  
// для последующей выгрузки данных в формат JSON.
//
// Параметры:  
//   Форма - Форма клиентского приложения - активная форма регламентированного отчета.
//
// Возвращаемое значение:  
//   Структура - содержит все параметры, необходимые для выгрузки формы в JSON:  
//     * ПрефиксФормы - строка, обозначающая префикс текущей формы отчета (например, "2023Кв1", "2025Кв1").  
//     * ИмяФормыДляМакета - имя формы отчета из конфигурации (например, "РегламентированныйОтчет200").  
//     * мСписокФормБезИерархии - реквизит формы, содержащий список всех форм без иерархии.  
//     * СписокОбязательныхПриложений - перечень обязательных приложений (см. функцию СписокОбязательныхПриложений() в форме отчета).  
//     * СписокПриложений - перечень приложений, определяемых в функции  
//         Отчетность1ССерверПереопределяемый.ПроверитьЗаполненностьФормы().  
//     * СписокМногострочныхСтруктур - набор многострочных структур,  
//         получаемых функцией Отчетность1ССерверПереопределяемый.ПолучитьМногострочнуюСтруктуруJSON().  
//     * Налогоплательщик - структура, содержащая сведения о налогоплательщике  
//         (см. Отчетность1ССерверПереопределяемый.ОпределитьИдентификаторНалогоплательщика()).  
//     * ИдентификаторПользователя - идентификатор пользователя, выгружающего отчет.  
//     * СлужебныеРеквизитыФормы - служебные данные формы (см. функцию  
//         ЗаполнитьСлужебныеРеквизитыФормыОтчетность1С() в форме отчета).  
//     * ТаблицаВыгрузки - таблица данных, формируемая функцией ЗаполнитьТаблицуВыгрузки().
//
Функция СформироватьСтруктуруПараметров(Форма, ТипДействия, ТипФормы="fno") Экспорт	
	СтруктураПараметров = Новый Структура;
	
	мСписокФормБезИерархии = Форма.РеквизитФормыВЗначение("мСписокФормБезИерархии");
		
	СписокПриложений = Новый Соответствие;
	СписокМногострочныхСтруктур = Новый Соответствие;
	ПрефиксФормы = Прав(Форма.СтруктураРеквизитовФормы.мВыбраннаяФорма, 7);
	ИмяФормыДляМакета = Сред(Лев(Форма.ИмяФормы, СтрНайти(Форма.ИмяФормы, ".Форма.") - 1), 7);
	СписокОбязательныхПриложений = Форма.СписокОбязательныхПриложений(); // ВРЕМЕННО
	СлужебныеРеквизитыФормы = Форма.ЗаполнитьСлужебныеРеквизитыФормыОтчетность1С();
	
	Для Каждого СтрокаФормы Из мСписокФормБезИерархии.Строки Цикл
		Если СтрокаФормы.Выгружать Тогда
			Если СтрокаФормы.Многострочность Тогда	
				ФормаЗаполнена = Отчетность1ССерверПереопределяемый.ПроверитьЗаполненностьФормы(Форма, СтрокаФормы.КодФормы);
			Иначе	
				// проверка заполненности по отметке представленных приложений
				ОсновнаяФорма =  мСписокФормБезИерархии.Строки[0].Значение;
				
				СтрокаПредставленногоПриложения = ОсновнаяФорма.Найти("Приложение" + Прав(СтрокаФормы.КодФормы,2));
				
				Если СтрокаПредставленногоПриложения = Неопределено Тогда
					СтрокаПредставленногоПриложения = ОсновнаяФорма.Найти("Приложение" + Прав(СтрокаФормы.КодФормы,1));
				КонецЕсли;
				
				Если СтрокаПредставленногоПриложения <> Неопределено Тогда
					ФормаЗаполнена = ?(ЗначениеЗаполнено(СтрокаПредставленногоПриложения.Значение), Истина, Ложь);	
				КонецЕсли;
			КонецЕсли;
			
			Если ФормаЗаполнена <> Неопределено Тогда
				СписокПриложений.Вставить(СтрокаФормы.КодФормы, ФормаЗаполнена);
			КонецЕсли;
		Иначе
			СписокПриложений.Вставить(СтрокаФормы.КодФормы, Ложь);	
		КонецЕсли;
		
		Если СписокОбязательныхПриложений.Найти(СтрокаФормы.ИмяФормы) <> Неопределено Тогда // ВРЕМЕННО
			СписокПриложений.Вставить(СтрокаФормы.КодФормы, Истина);                        // ВРЕМЕННО
		КонецЕсли;                                                                          // ВРЕМЕННО
	КонецЦикла;

	СтруктураПараметровТаблицаВыгрузки = Новый Структура;
	СтруктураПараметровТаблицаВыгрузки.Вставить("ПрефиксФормы", ПрефиксФормы);
	СтруктураПараметровТаблицаВыгрузки.Вставить("мСписокФормБезИерархии", мСписокФормБезИерархии);
	СтруктураПараметровТаблицаВыгрузки.Вставить("СписокПриложений", СписокПриложений);
	МакетВыгрузки = Отчеты[ИмяФормыДляМакета].ПолучитьМакет("ВыгрузкаJSONОтчетность1С");
	ТаблицаВыгрузки = ЗаполнитьТаблицуВыгрузки(МакетВыгрузки, СтруктураПараметровТаблицаВыгрузки);
	
	Для Каждого СтрокаФормы Из мСписокФормБезИерархии.Строки Цикл
		Если СтрокаФормы.Многострочность Тогда
			СтруктураПараметровМногострочнаяСтруктура = Новый Структура;
			СтруктураПараметровМногострочнаяСтруктура.Вставить("ТаблицаВыгрузки", ТаблицаВыгрузки);
			СтруктураПараметровМногострочнаяСтруктура.Вставить("СписокПриложений", СписокПриложений);
			МногострочнаяСтруктура = Отчетность1ССерверПереопределяемый.ПолучитьМногострочнуюСтруктуруJSON(Форма, СтрокаФормы.КодФормы, 
																										   СтруктураПараметровМногострочнаяСтруктура);
			СписокМногострочныхСтруктур.Вставить(СтрокаФормы.КодФормы, МногострочнаяСтруктура); 
		КонецЕсли;	
	КонецЦикла;
	
	ИдентификаторНалогоплательщика = Отчетность1ССерверПереопределяемый.ОпределитьИдентификаторНалогоплательщика(Форма);
	
	Налогоплательщик =  ИдентификаторНалогоплательщика.Налогоплательщик;
	ИдентификаторПользователя = ИдентификаторНалогоплательщика.ИдентификаторПользователя;
	НаименованиеПользователя = ИдентификаторНалогоплательщика.НаименованиеПользователя;
	
	СтруктураПараметров.Вставить("ПрефиксФормы", ПрефиксФормы);
	СтруктураПараметров.Вставить("ИмяФормыДляМакета", ИмяФормыДляМакета);
	СтруктураПараметров.Вставить("мСписокФормБезИерархии", мСписокФормБезИерархии);
	СтруктураПараметров.Вставить("СписокПриложений", СписокПриложений);
	СтруктураПараметров.Вставить("СписокМногострочныхСтруктур", СписокМногострочныхСтруктур);	
	СтруктураПараметров.Вставить("Налогоплательщик", Налогоплательщик);
	СтруктураПараметров.Вставить("ИдентификаторПользователя", ИдентификаторПользователя);
	СтруктураПараметров.Вставить("НаименованиеПользователя", НаименованиеПользователя);
	СтруктураПараметров.Вставить("СлужебныеРеквизитыФормы", СлужебныеРеквизитыФормы);
	СтруктураПараметров.Вставить("ТаблицаВыгрузки", ТаблицаВыгрузки);
	СтруктураПараметров.Вставить("ТипФормы", ТипФормы);
	
	Если ТипДействия = Отчетность1СКлиентСервер.ТипЗапроса_ПроверкаФЛК() Тогда 
		СтруктураДобавляемыхПриПроверкеДанных = Форма.ПолучитьДополнительныеРеквизитыКПроверкеФЛКОтчетность1С();
		СинонимыЭлементовJSON = Форма.СоответствиеСинонимовОтчетность1С.СинонимыЭлементовJSON;
		УникальныйИдентификатор = Форма.УникальныйИдентификатор;
		СоответствиеЭлементовФормы = Форма.СоответствиеСинонимовОтчетность1С.СоответствиеЭлементовФормы;
		СоответствиеАльтернативныхЭлементовФормы = Форма.СоответствиеСинонимовОтчетность1С.СоответствиеАльтернативныхЭлементовФормы;
		
		ТаблицаОбщиеРеквизиты = ЗаполнитьТаблицуОбщихРеквизитов(МакетВыгрузки, ПрефиксФормы);
		ИмяФормыФЛК = ТаблицаОбщиеРеквизиты.Найти("flkName").ЗначениеАтрибута;
	
		СтруктураПараметров.Вставить("СтруктураДобавляемыхПриПроверкеДанных", СтруктураДобавляемыхПриПроверкеДанных);
		СтруктураПараметров.Вставить("СинонимыЭлементовJSON", СинонимыЭлементовJSON);
		СтруктураПараметров.Вставить("УникальныйИдентификатор", УникальныйИдентификатор);
		СтруктураПараметров.Вставить("ИмяФормыФЛК", ИмяФормыФЛК);
		СтруктураПараметров.Вставить("СоответствиеЭлементовФормы", СоответствиеЭлементовФормы);
		СтруктураПараметров.Вставить("СоответствиеАльтернативныхЭлементовФормы", СоответствиеАльтернативныхЭлементовФормы);
		
	ИначеЕсли ТипДействия = Отчетность1СКлиентСервер.ТипЗапроса_ОтправитьФорму() Тогда
		СписокОбязательныхПолей = Форма.СписокОбязательныхПолейОтчетность1С;
		
		ИдентификаторФормы = Форма.ИдентификаторФормыОтчетность1С;
		
	    СтруктураПараметров.Вставить("СписокОбязательныхПолей", СписокОбязательныхПолей);
		СтруктураПараметров.Вставить("ИдентификаторФормы", ИдентификаторФормы);
		
	КонецЕсли;	
	
	Возврат СтруктураПараметров;
	
КонецФункции

// Выполняет выгрузку данных регламентированного отчета в формат JSON  
// и помещает сформированный файл во временное хранилище.
//
// Параметры:  
//   СтруктураПараметровОтчетность1С - Структура - параметры формы отчета,  
//     сформированные функцией СформироватьСтруктуруПараметров().
//
// Возвращаемое значение:  
//   Строка - адрес во временном хранилище, по которому сохранен JSON-файл выгрузки.
//
Функция ВыгрузитьОтчетВJSONДляИСНА(СтруктураПараметровОтчетность1С, ТипДействия) Экспорт
	
	Результат = ПолучитьСтруктуруОтчетаДляВыгрузки(СтруктураПараметровОтчетность1С);
	ДанныеВыгрузки = Результат.ДанныеВыгрузки;
	
	Если ТипДействия = Отчетность1СКлиентСервер.ТипЗапроса_ВыгрузкаВJSON() Тогда
		ИмяВременногоФайла = ПолучитьИмяВременногоФайла("tmp");
				
		Запись = Новый ЗаписьJSON;
		Запись.УстановитьСтроку(Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Unix, Символы.Таб));
		ЗаписатьJSON(Запись, ДанныеВыгрузки); 
		Выгрузка = Запись.Закрыть();
			
		ТекстДок = Новый ТекстовыйДокумент;
		ТекстДок.УстановитьТекст(Выгрузка);
		ВыбФайл = Новый Файл(ИмяВременногоФайла);
		ТекстДок.Записать(ВыбФайл.Путь + ВыбФайл.ИмяБезРасширения + ВыбФайл.Расширение);
		
		АдресХранилища = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(ИмяВременногоФайла));
		
		УдалитьФайлы(ИмяВременногоФайла);
		
		Возврат АдресХранилища;
		
	ИначеЕсли ТипДействия = Отчетность1СКлиентСервер.ТипЗапроса_ОтправитьФорму() Тогда 
		КодФормы = Результат.КодФормы;
	
		СтруктураДляВыгрузки = Новый Структура;	
		СтруктураДляВыгрузки.Вставить("code", КодФормы);
		СтруктураДляВыгрузки.Вставить("externalFnoId", СтруктураПараметровОтчетность1С.ИдентификаторФормы);
		СтруктураДляВыгрузки.Вставить("fnoDto", ДанныеВыгрузки);
		
		Запись = Новый ЗаписьJSON;
		Запись.УстановитьСтроку(Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Unix, Символы.Таб));
		ЗаписатьJSON(Запись, СтруктураДляВыгрузки); 
		Выгрузка = Запись.Закрыть();
					
		ЗаписьXML = Новый ЗаписьXML();
		ЗаписьXML.УстановитьСтроку(Новый ПараметрыЗаписиXML("UTF-8", "1.0", Ложь, Ложь));
		ЗаписьXML.ЗаписатьОбъявлениеXML();
		ЗаписьXML.ЗаписатьНачалоЭлемента("root");
		ЗаписьXML.ЗаписатьНачалоЭлемента("data");
		ЗаписьXML.ЗаписатьСекциюCDATA(XMLСтрока(Выгрузка));
		ЗаписьXML.ЗаписатьКонецЭлемента();
		ЗаписьXML.ЗаписатьКонецЭлемента(); 
		
		Результат = ЗаписьXML.Закрыть();
			
		Возврат Результат;	
	КонецЕсли;	
		
КонецФункции   

// Проверяет наличие указанного реквизита в форме.  
// Сравнение выполняется без учета регистра символов.
//
// Параметры:  
//   Форма - Форма - форма, в которой выполняется поиск реквизита.  
//   ИмяРеквизита - Строка - имя реквизита, наличие которого необходимо проверить.
//
// Возвращаемое значение:  
//   Булево - Истина, если реквизит найден в форме;  
//             Ложь, если реквизит отсутствует.
//
Функция ЕстьРеквизитФормы(Форма, ИмяРеквизита) Экспорт
	
	Для Каждого РеквизитФормы Из Форма.ПолучитьРеквизиты() Цикл
		Если ВРег(РеквизитФормы.Имя) = ВРег(ИмяРеквизита) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

// см. Отчетность1ССерверПереопределяемый.ПолучитьЗначениеРасчетногоПоказателя()
