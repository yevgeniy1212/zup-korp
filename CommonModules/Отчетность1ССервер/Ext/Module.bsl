// Формирует структуру данных для выгрузки отчетности на шлюз в формате JSON.
// Функция собирает и подготавливает структуру данных всех форм, входящих в пакет отчетности,
// формирует вспомогательные таблицы ошибок и обязательных полей, а затем сериализует
// итоговую структуру в JSON. После сериализации выполняется кодирование в Base64 для передачи
// на шлюз 1С или внешний сервис проверки.
//
// Параметры:
//  СтруктураПараметровОтчетность1С – Структура
//     Структура, содержащая все необходимые данные и настройки для формирования выгружаемой отчетности:
//     • мСписокФормБезИерархии – список форм для выгрузки;
//     • СтруктураДобавляемыхПриПроверкеДанных – служебная структура для хранения данных проверки;
//     • СоответствиеЭлементовФормы – соответствие элементов форм;
//     • СоответствиеАльтернативныхЭлементовФормы – альтернативные элементы для передачи;
//     • ИдентификаторПользователя – идентификатор пользователя (БИН/ИНН);
//     • ИмяФормыФЛК – имя проверяемой формы;
//     • Налогоплательщик – организация, по которой выполняется выгрузка;
//     • УникальныйИдентификатор – уникальный идентификатор выгрузки.
//
// Возвращаемое значение:
//  Структура – содержит все данные, подготовленные к передаче на шлюз:
//     • Б64СтруктураФЛК – данные формы в Base64, закодированные из JSON;
//     • БИН – идентификатор пользователя (БИН организации);
//     • ИмяФормы – имя формы для шлюза;
//     • Организация – объект «Налогоплательщик»;
//     • АдресВременногоХранилища – ссылка во временное хранилище.
//
Функция ПолучитьСтруктуруКВыгрузке(СтруктураПараметровОтчетность1С) Экспорт
	СтруктураФормДляВыгрузки = Новый Структура;
	Для Каждого ЭлементФормы Из СтруктураПараметровОтчетность1С.мСписокФормБезИерархии.Строки Цикл
		СтруктураФормДляВыгрузки.Вставить(ЭлементФормы.КодФормы);
	КонецЦикла;

	СтруктураДобавляемыхПриПроверкеДанных = СтруктураПараметровОтчетность1С.СтруктураДобавляемыхПриПроверкеДанных;

	СписокОбязательныхПолейОтчетность1С = Новый Массив;
	СтруктураДобавляемыхПриПроверкеДанных.Вставить("СписокОбязательныхПолейОтчетность1С", СписокОбязательныхПолейОтчетность1С);

	ТаблицаОшибокОтчетность1С = Новый ТаблицаЗначений;
	ТаблицаОшибокОтчетность1С.Колонки.Добавить("КодФормы");
	ТаблицаОшибокОтчетность1С.Колонки.Добавить("Страница");
	ТаблицаОшибокОтчетность1С.Колонки.Добавить("НомерЛиста");
	ТаблицаОшибокОтчетность1С.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число"));
	ТаблицаОшибокОтчетность1С.Колонки.Добавить("Реквизит");
	ТаблицаОшибокОтчетность1С.Колонки.Добавить("НазваниеРеквизита");
	ТаблицаОшибокОтчетность1С.Колонки.Добавить("Ошибка");
	ТаблицаОшибокОтчетность1С.Колонки.Добавить("Критичность");

	СтруктураДобавляемыхПриПроверкеДанных.Вставить("ТаблицаОшибокОтчетность1С", ТаблицаОшибокОтчетность1С);

	СтруктураОбъектов = Новый Структура;
	СтруктураОбъектов.Вставить("СтруктураДобавляемыхПриПроверкеДанных", СтруктураДобавляемыхПриПроверкеДанных);
	Для Каждого СтрокаФорма Из СтруктураПараметровОтчетность1С.мСписокФормБезИерархии.Строки Цикл
		КодФормыОтправляемый = СтрЗаменить(СтрокаФорма.КодФормы, "Форма", "");
		ПолучитьСтруктуруФормыКВыгрузке(СтруктураПараметровОтчетность1С, СтруктураОбъектов, КодФормыОтправляемый);	
	КонецЦикла;
	
	СтруктураОбъектов.Вставить("СоответствиеАльтернативныхЭлементовФормы", СтруктураПараметровОтчетность1С.СоответствиеАльтернативныхЭлементовФормы);
	СтруктураОбъектов.Вставить("СоответствиеЭлементовФормы", СтруктураПараметровОтчетность1С.СоответствиеЭлементовФормы);
	
	СтруктураОбъектовКВыгрузке = ПреобразоватьТаблицыСтруктурыВМассивы(СтруктураОбъектов);

	JSONСтрокой = Отчетность1СКлиентСервер.Отчетность1С_ЗаписатьЗначениеJSON(СтруктураОбъектовКВыгрузке);

	Б64СтруктураФЛК = Base64Строка(ПолучитьДвоичныеДанныеИзСтроки(JSONСтрокой));
	ИдентификаторПользователя = СтруктураПараметровОтчетность1С.ИдентификаторПользователя;
	НаименованиеПользователя = СтруктураПараметровОтчетность1С.НаименованиеПользователя;

	СтруктураКОтправкеНаШлюз = Новый Структура;
	СтруктураКОтправкеНаШлюз.Вставить("Б64СтруктураФЛК", Б64СтруктураФЛК);
	СтруктураКОтправкеНаШлюз.Вставить("ИдентификаторПользователя",ИдентификаторПользователя);
	СтруктураКОтправкеНаШлюз.Вставить("НаименованиеПользователя", НаименованиеПользователя);

	СтруктураКОтправкеНаШлюз.Вставить("ИмяФормы", СтруктураПараметровОтчетность1С.ИмяФормыФЛК);
	СтруктураКОтправкеНаШлюз.Вставить("Организация",СтруктураПараметровОтчетность1С.Налогоплательщик);
	СтруктураКОтправкеНаШлюз.Вставить("ТипФормы",СтруктураПараметровОтчетность1С.ТипФормы);

	АдресВременногоХранилища = ПоместитьВоВременноеХранилище(Неопределено, СтруктураПараметровОтчетность1С.УникальныйИдентификатор);
	СтруктураКОтправкеНаШлюз.Вставить("АдресВременногоХранилища", АдресВременногоХранилища);
	
	Возврат СтруктураКОтправкеНаШлюз;

КонецФункции // ПолучитьСтруктуруКВыгрузке()

// Отправляет данные отчетности на валидацию (проверку) на шлюзе в фоновом режиме.
//
// Параметры:
//  СтруктураПараметров – Структура
//     Структура, содержащая подготовленные данные для передачи на шлюз,
//     включая сведения о формах, организации, идентификаторе пользователя и т.п.  
//
//  УникальныйИдентификатор – Строка
//     Уникальный идентификатор операции, используется для отслеживания
//     выполнения фонового задания и хранения временных данных.
//
// Возвращаемое значение:
//  Произвольный – результат выполнения фонового задания, возвращаемый методом
//  `ДлительныеОперации.ВыполнитьФункцию`. Обычно содержит объект результата
//  постановки задачи в очередь.
Функция ОтправитьДанныеНаВалидацию(СтруктураПараметров, УникальныйИдентификатор) Экспорт
	ИмяМетода = "Отчетность1ССервер.ОтправитьВОчередьВФоне";

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Валидация данных на шлюзе'");
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	ПараметрыВыполнения.ЗапуститьНеВФоне = Истина;

	РезультатЗадания = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, ИмяМетода, СтруктураПараметров); 

	Возврат РезультатЗадания;
КонецФункции

// Отправляет подготовленные данные в очередь фоновой обработки для передачи на шлюз.
//
// Параметры:
//  ПередаваемыеПараметры – Произвольный (необязательный)
//     Структура или иное значение, содержащее параметры и данные,
//     которые требуется отправить на обработку в фоне.
//
//  АдресХранилищаРезультата – Строка (необязательный)
//     Адрес временного хранилища, куда будет помещён результат обработки
//     (например, ответ шлюза или структура валидации).
//
//  АдресХранилищаДопРезультата – Строка (необязательный)
//     Адрес дополнительного временного хранилища для сопутствующих данных,
//     если операция возвращает несколько объектов.
//
// Возвращаемое значение:
//  Структура – результат вызова метода `ЭлектронноеВзаимодействиеССервисами.ОтправитьВОчередьВФоне`,
//  содержащая информацию о постановке задачи в очередь или об ошибке при выполнении.
Функция ОтправитьВОчередьВФоне(ПередаваемыеПараметры = Неопределено, АдресХранилищаРезультата = Неопределено, АдресХранилищаДопРезультата = Неопределено) Экспорт
	СтруктураРезультата = ЭлектронноеВзаимодействиеССервисами.ОтправитьВОчередьВФоне(ПередаваемыеПараметры, АдресХранилищаРезультата, АдресХранилищаДопРезультата);
	Возврат СтруктураРезультата;
КонецФункции

// Выполняет получение результата проверки (валидации) отчетности с шлюза в фоновом режиме.
//
// Параметры:
//  СтруктураПараметров – Структура
//     Набор параметров, необходимых для выполнения запроса к шлюзу.
//     Обычно содержит адрес временного хранилища, идентификатор задания и данные формы.
//
//  УникальныйИдентификатор – Строка
//     Уникальный идентификатор операции (используется для связи фоновых заданий
//     и формы, из которой был инициирован вызов).
//
// Возвращаемое значение:
//  РезультатЗадания – Структура
//     Результат постановки задания в фоновое выполнение.  
//     Содержит сведения о статусе, идентификаторе задания, возможной ошибке
//     или адресе хранилища, где сохранён результат.
Функция ПолучитьРезультатВалидации(СтруктураПараметров, УникальныйИдентификатор) Экспорт

	ИмяМетода = "Отчетность1ССервер.ПроверитьЗаполнениеВФоне";
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Получение результата валидации'");
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	ПараметрыВыполнения.ЗапуститьНеВФоне = Истина;
	
	РезультатЗадания = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, ИмяМетода, СтруктураПараметров); 

	Возврат РезультатЗадания;
	
КонецФункции

// Выполняет проверку (валидацию) данных отчетности на шлюзе 1С в фоновом режиме.
//
// Параметры:
//  ПередаваемыеПараметры – Структура (Необязательный)
//     Набор параметров, передаваемых на шлюз для выполнения валидации.
//     Обычно включает сведения об организации, отчетной форме, периоде и данных формы.
//
//  АдресХранилищаРезультата – Строка (Необязательный)
//     Адрес временного хранилища, в котором будет сохранён результат проверки.
//
//  АдресХранилищаДопРезультата – Строка (Необязательный)
//     Адрес временного хранилища для дополнительных данных результата (если шлюз возвращает несколько структур).
//
// Возвращаемое значение:
//  Результат – Структура
//     Содержит результат выполнения операции валидации.  
//     Как правило, включает:
//       • Статус выполнения (успешно / ошибка),
//       • Текст сообщения,
//       • Ссылку на хранилище с результатами,
//       • Вспомогательные данные (например, коды ошибок или предупреждений).
//
Функция ПроверитьЗаполнениеВФоне(ПередаваемыеПараметры = Неопределено, АдресХранилищаРезультата = Неопределено, АдресХранилищаДопРезультата = Неопределено) Экспорт	
	Результат = ЭлектронноеВзаимодействиеССервисами.ПроверитьЗаполнениеВФоне(ПередаваемыеПараметры, АдресХранилищаРезультата, АдресХранилищаДопРезультата);
	Возврат Результат;
КонецФункции

// Формирует визуальное дерево ошибок на форме по результатам валидации, полученным с шлюза 1С.
//
// Параметры:
//  Форма – УправляемаяФорма
//     Форма, на которой необходимо отобразить дерево ошибок и подсказки.
//
//  ТолькоКритичные – Булево (Необязательный, по умолчанию = Ложь)
//     Если Истина, формируются только критические ошибки.
//
//  ДанныеИзХранилищаПослеВалидации – Структура
//     Содержит данные, полученные после валидации с сервера/шлюза. Структура обычно включает:
//       • ДанныеПослеВалидации – результат проверки в виде Base64,
//       • ИдентификаторФормы – идентификатор сообщения для отслеживания,
//       • Другие служебные сведения.
Процедура СформироватьДеревоОшибокСоШлюза(Форма, ТолькоКритичные = Ложь, ДанныеИзХранилищаПослеВалидации) Экспорт 
	
	Если ДанныеИзХранилищаПослеВалидации.ПризнакОтправкаФормы Тогда
		Форма.ИдентификаторФормыОтчетность1С = ДанныеИзХранилищаПослеВалидации.ИдентификаторФормы;
		Форма.СтатусПриемаОтчетность1С = Перечисления.СтатусыПриемаОтчетность1С.Сформирован;
		
		Форма.ИдентификаторФормыВСистемеПриемаОтчетность1С = "";
		Форма.СтатусРазноскиОтчетность1С = "";
		Форма.УведомлениеОтчетность1С = "";
		Форма.НомерУведомленияОтчетность1С = "";
		Форма.ДатаУведомленияОтчетность1С = "";
		Форма.ИдентификаторПользователяОтчетность1С = "";
	КонецЕсли;	
	
	ДанныеПослеВалидации = ДанныеИзХранилищаПослеВалидации.ДанныеПослеВалидации; 
	
	ЗагрузитьДанныеПослеВалидацииНаФорму(Форма, ДанныеПослеВалидации);
	
	ЕстьОшибки = ДанныеПослеВалидации.СтруктураДобавляемыхПриПроверкеДанных.ТаблицаОшибокОтчетность1С.Количество() > 0;
	Если НЕ ЕстьОшибки ТОгда
		Отчетность1СКлиентСервер.СообщитьПользователю(НСтр("ru='Ошибок не обнаружено...'"), Форма.УникальныйИдентификатор);
	КонецЕсли;
	
	СформироватьДеревоОшибок(Форма);
	
	Форма.Элементы.ГруппаОшибокОтчетность1С.Видимость = ЕстьОшибки;
	Форма.Элементы.ДеревоОшибокОтчетность1С.Видимость = ЕстьОшибки;
	
КонецПроцедуры

// Формирует и заполняет дерево ошибок на форме на основе таблицы ошибок.
// Поддерживает фильтрацию по критичности ошибок.
//
// Параметры:
//   Форма – УправляемаяФорма
//       Форма, на которой необходимо отобразить дерево ошибок.
//
//   ТолькоКритичные – Булево (Необязательный, по умолчанию = Ложь)
//       Если Истина, в дерево будут добавлены только критические ошибки.
Процедура СформироватьДеревоОшибок(Форма, ТолькоКритичные = Ложь) Экспорт
	ДеревоОшибокОтчетность1С = Форма.РеквизитформыВЗначение("ДеревоОшибокОтчетность1С");
	ДеревоОшибокОтчетность1С.Строки.Очистить();
	Форма.ТаблицаОшибокОтчетность1С.Сортировать("КодФормы,Страница, НомерСтроки, Реквизит");
	//Заполняем Дерево ошибок
	Для Каждого СтрокаТаблицаОшибок Из Форма.ТаблицаОшибокОтчетность1С Цикл
		Если ТолькоКритичные и НЕ СтрокаТаблицаОшибок.Критичность Тогда
			Продолжить;
		КонецЕсли;

		КодФормы = СтрокаТаблицаОшибок.КодФормы;
		КодСтраницы = Форма.СоответствиеСинонимовОтчетность1С.СинонимыПолей.Получить(СтрокаТаблицаОшибок.Страница); // автосиноним

		РодительскаяСтрока = Неопределено;
		// Ищем ветку формы
		МассивРезультовПоиска = ДеревоОшибокОтчетность1С.Строки.НайтиСтроки(Новый Структура("Форма, Страница", КодФормы, ""));
		Если МассивРезультовПоиска.Количество() = 0 Тогда
			РодительскаяСтрока = ДеревоОшибокОтчетность1С.Строки.Добавить();
			РодительскаяСтрока.Форма = КодФормы;
			РодительскаяСтрока.Страница = Неопределено;
		Иначе
			РодительскаяСтрока = МассивРезультовПоиска[0];
		КонецЕсли;	

		// Ищем ветку Страницы
		МассивРезультовПоиска = РодительскаяСтрока.Строки.НайтиСтроки(Новый Структура("Страница, Реквизит", КодСтраницы, ""));
		Если МассивРезультовПоиска.Количество() = 0 Тогда
			РодительскаяСтрока = РодительскаяСтрока.Строки.Добавить();
			РодительскаяСтрока.Форма = КодФормы;
			
			РодительскаяСтрока.Страница = КодСтраницы;
		Иначе
			РодительскаяСтрока = МассивРезультовПоиска[0];
		КонецЕсли;

		СтрокаОшибки = РодительскаяСтрока.Строки.Добавить();
		СтрокаОшибки.ИндексВТаблицеОшибок = Форма.ТаблицаОшибокОтчетность1С.Индекс(СтрокаТаблицаОшибок);
		СтрокаОшибки.Реквизит           = СтрокаТаблицаОшибок.Реквизит;
		СтрокаОшибки.НомерСтроки		= СтрокаТаблицаОшибок.НомерСтроки;
		СтрокаОшибки.Форма 		        = КодФормы;
		СтрокаОшибки.Страница 		    = Форма.СоответствиеСинонимовОтчетность1С.СинонимыПолей.Получить(СтрокаТаблицаОшибок.Страница); // автосиноним
		СтрокаОшибки.НомерЛиста		    = СтрокаТаблицаОшибок.НомерЛиста;

		Если ЗначениеЗаполнено(СтрокаТаблицаОшибок.РеквизитНазвание) Тогда
			СтрокаОшибки.Поле	        = СтрокаТаблицаОшибок.РеквизитНазвание;
		Иначе
			ИмяРеквизита = СтрокаТаблицаОшибок.Реквизит;
			// в многострочных формах имя реквизита содержит номер строки в виде постфикса __1
			Если Найти(СтрокаТаблицаОшибок.Реквизит, "__") >0  И НЕ СтрокаТаблицаОшибок.КодФормы = "Форма300_06" Тогда // в 300.06 текстовые поля содержат __
				ИмяРеквизита = Лев(СтрокаТаблицаОшибок.Реквизит, Найти(СтрокаТаблицаОшибок.Реквизит, "__") -1);
			КонецЕсли;

			СтрокаОшибки.Поле	        = ?(Форма.СоответствиеСинонимовОтчетность1С.СинонимыПолей.Получить(ИмяРеквизита) <> Неопределено,
								   			Форма.СоответствиеСинонимовОтчетность1С.СинонимыПолей.Получить(ИмяРеквизита),
								   			Отчетность1СКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Неопознанное поле: %1'"), ИмяРеквизита));
		КонецЕсли;

		СтрокаОшибки.Ошибка			    = СтрокаТаблицаОшибок.Ошибка;
		СтрокаОшибки.Критичность 	    = СтрокаТаблицаОшибок.Критичность;
		СтрокаОшибки.КритичностьСимвол 	= Неопределено;
	КонецЦикла;

	Форма.ЗначениеВРеквизитФормы(ДеревоОшибокОтчетность1С, "ДеревоОшибокОтчетность1С");

	УстановитьПризнакКритичности(Форма.ДеревоОшибокОтчетность1С);
	Форма.КоличествоОшибокВсегоОтчетность1С = 0;
	Форма.КоличествоОшибокКритичныхОтчетность1С = 0;
	ПосчитатьОшибкиДерева(Форма.ДеревоОшибокОтчетность1С, Форма.ПоказыватьВсеОшибкиОтчетность1С, Форма.КоличествоОшибокВсегоОтчетность1С, Форма.КоличествоОшибокКритичныхОтчетность1С);
	ПосчитатьКоличествоОшибокВТаблице(Форма.ТаблицаОшибокОтчетность1С, Форма.КоличествоОшибокВсегоОтчетность1С, Форма.КоличествоОшибокКритичныхОтчетность1С);
	ОформлениеДереваОшибок(Форма);

	Форма.ПоказыватьВсеОшибкиОтчетность1С = НЕ ТолькоКритичные;
КонецПроцедуры

#КонецОбласти

#Область Отправка

// Формирует структуру параметров формы регламентированной отчетности
// для последующей выгрузки данных и отправки на сервер/шлюз.
//
// Параметры:
//   Форма – УправляемаяФорма
//       Активная форма регламентированного отчета, из которой будут
//       собраны все необходимые данные для выгрузки.
//
// Возвращаемое значение:
//   Структура – Структура, содержащая параметры формы для отправки:
//     * ПрефиксФормы – строка, обозначающая префикс текущей формы отчета
//       (например, "2023Кв1", "2025Кв1").
//     * ИмяФормыФЛК – имя формы отчета для макета выгрузки JSON.
//     * СоответствиеСинонимов – структура, содержащая соответствие
//       альтернативных и оригинальных элементов формы.
//     * ИсходящийОтчетДокумент – сохраненный документ формы для отправки.
//     * ИдентификаторФормы – идентификатор сообщения, связанный с отправкой формы.
//     * ИдентификаторФормыВСистемеПриема – внешний идентификатор формы на шлюзе.
//     * Налогоплательщик – структура с данными налогоплательщика.
//     * ИдентификаторПользователя – идентификатор пользователя, отправляющего форму.
//     * НаименованиеПользователя – имя пользователя, выполняющего отправку.
//     * УникальныйИдентификатор – уникальный идентификатор формы на клиенте.
Функция СформироватьСтруктуруПараметров_Отправка(Форма, ТипФормы="fno") Экспорт	
	СтруктураПараметров = Новый Структура;
	
	УникальныйИдентификатор = Форма.УникальныйИдентификатор;
	ИдентификаторФормыВСистемеПриема = Форма.ИдентификаторФормыВСистемеПриемаОтчетность1С;
	ИсходящийОтчетДокумент = Форма.СтруктураРеквизитовФормы.мСохраненныйДок;
	
	ИдентификаторФормы = Форма.ИдентификаторФормыОтчетность1С;	
	
	СоответствиеЭлементовФормы = Форма.СоответствиеСинонимовОтчетность1С;
	
	ПрефиксФормы = Прав(Форма.СтруктураРеквизитовФормы.мВыбраннаяФорма, 7);
	ИмяФормыДляМакета = Сред(Лев(Форма.ИмяФормы, СтрНайти(Форма.ИмяФормы, ".Форма.") - 1), 7);
	
	МакетВыгрузки = Отчеты[ИмяФормыДляМакета].ПолучитьМакет("ВыгрузкаJSONОтчетность1С");
	
	ТаблицаОбщиеРеквизиты = ЗаполнитьТаблицуОбщихРеквизитов(МакетВыгрузки, ПрефиксФормы);
	ИмяФормыФЛК = ТаблицаОбщиеРеквизиты.Найти("flkName").ЗначениеАтрибута;
	
	ИмяФормыОтчетаМассив = СтрРазделить(Форма.ИмяФормы, ".");
	ИмяФормыОтчета = ИмяФормыОтчетаМассив[ИмяФормыОтчетаМассив.Количество() - 1];
	
	ИдентификаторНалогоплательщика = Отчетность1ССерверПереопределяемый.ОпределитьИдентификаторНалогоплательщика(Форма);
	
	Налогоплательщик =  ИдентификаторНалогоплательщика.Налогоплательщик;
	ИдентификаторПользователя = ИдентификаторНалогоплательщика.ИдентификаторПользователя;
	НаименованиеПользователя = ИдентификаторНалогоплательщика.НаименованиеПользователя;	
	
	СтруктураПараметров.Вставить("Налогоплательщик", Налогоплательщик);
	СтруктураПараметров.Вставить("ИдентификаторПользователя", ИдентификаторПользователя);
	СтруктураПараметров.Вставить("НаименованиеПользователя", НаименованиеПользователя);
	СтруктураПараметров.Вставить("УникальныйИдентификатор", УникальныйИдентификатор);
	СтруктураПараметров.Вставить("ИмяФормыФЛК", ИмяФормыФЛК);
	СтруктураПараметров.Вставить("ТипФормы", ТипФормы);
	СтруктураПараметров.Вставить("СоответствиеСинонимов", СоответствиеЭлементовФормы);
	СтруктураПараметров.Вставить("ИсходящийОтчетДокумент", ИсходящийОтчетДокумент);
	СтруктураПараметров.Вставить("ИдентификаторФормы", ИдентификаторФормы);
	СтруктураПараметров.Вставить("ИдентификаторФормыВСистемеПриема", ИдентификаторФормыВСистемеПриема);
	
	Возврат СтруктураПараметров;
КонецФункции

// Проверяет, совпадает ли дата подачи формы с текущей датой.
//
// Параметры:
//   Форма – УправляемаяФорма
//       Активная форма регламентированного отчета, из которой извлекается
//       дата подачи.
//
// Возвращаемое значение:
//   Булево (Истина/Ложь)
//     * Истина – если дата подачи совпадает с текущей датой.
//     * Ложь – если дата подачи отсутствует или отличается от текущей даты.
Функция ПроверитьДатуПодачи(Форма) Экспорт	
	мСписокФормБезИерархии = Форма.РеквизитФормыВЗначение("мСписокФормБезИерархии").Строки;
	
	ТаблицаДанных = мСписокФормБезИерархии[0].Значение;
	СтрокаОбласти = ТаблицаДанных.Найти("ДатаПодачи","ИмяОбласти");
	Если СтрокаОбласти <> Неопределено Тогда
		ДатаПодачи = СтрокаОбласти.Значение;
	Иначе
		ДатаПодачи = 0;
	КонецЕсли;
	
	Если НЕ (НачалоДня(ДатаПодачи) = НачалоДня(ТекущаяДата())) Тогда
		Возврат Ложь
	КонецЕсли;
	
	Возврат Истина;
КонецФункции

// Устанавливает текущую дату в реквизиты формы, отвечающие за дату подачи и дату подписи.
//
// Параметры:
//   Форма – УправляемаяФорма
//       Активная форма регламентированного отчета, в которую требуется
//       передать текущую дату.
Процедура ЗаменитьДатуПодачиНаТекущую(Форма) Экспорт
	ТекДата = НачалоДня(ТекущаяДата());
	Если ЕстьРеквизитФормы(Форма, "КодФормы") Тогда
		КодФормы = Форма.КодФормы;
	Иначе     
		ИмяФормы = СтрЗаменить(Форма.СтруктураРеквизитовФормы.мВыбраннаяФорма, "Отчета", "");
		ПрефиксФормы = Прав(ИмяФормы, 7);
		КодФормы = СтрЗаменить(ИмяФормы, ПрефиксФормы, "");
	КонецЕсли;
	Отчетность1ССерверПереопределяемый.ПередатьЗначениеВСтруктуру(Форма, КодФормы, "ДатаПодачи", ТекДата);
	
	мСписокФормБезИерархии = Форма.РеквизитФормыВЗначение("мСписокФормБезИерархии").Строки;
	
	ОсновнаяФорма = мСписокФормБезИерархии[0].КодФормы;
	
	Если КодФормы = ОсновнаяФорма И ЕстьРеквизитФормы(Форма, "ДатаПодачи") Тогда
		Форма.ДатаПодачи = ТекДата;
	КонецЕсли;
	Если КодФормы = ОсновнаяФорма И ЕстьРеквизитФормы(Форма, "ДатаПодписи") Тогда
		Форма.ДатаПодписи = ТекДата;
		Форма.ОтчетОбъект.ДатаПодписи = ТекДата;
	КонецЕсли;
КонецПроцедуры

// Формирует таблицу ошибок ФЛК (Форма Листа Контроля) после получения структуры ошибок
// от сервера или шлюза для последующего отображения в форме отчета.
//
// Параметры:
//   Объект – УправляемаяФорма
//       Форма отчета, в которой необходимо заполнить таблицу ошибок.
//   ДополнительныеПараметры – Структура
//       Структура с дополнительными параметрами:
//         * МассивОшибокФЛК – массив ошибок, полученных после проверки ФЛК.
//         * СоответствиеСинонимов – структура с сопоставлением имен элементов формы и JSON.  
Процедура ЗаполнитьТаблицуФЛКОтчета(Объект, ДополнительныеПараметры) Экспорт
	
	Префикс = Прав(Объект.СтруктураРеквизитовФормы.мВыбраннаяФорма, 7);
	МакетВыгрузки = Отчеты[Сред(Лев(Объект.ИмяФормы, СтрНайти(Объект.ИмяФормы, ".Форма.") - 1), 7)].ПолучитьМакет("ВыгрузкаJSONОтчетность1С");
		
	ИдентификаторВидаФНО = Неопределено;
			
	// создадим таблицу для выгрузки
	ТаблицаВыгрузки = Новый ТаблицаЗначений;
	ТаблицаВыгрузки.Колонки.Добавить("ИмяФормы");
	ТаблицаВыгрузки.Колонки.Добавить("Страница");
	ТаблицаВыгрузки.Колонки.Добавить("ПутьКЯчейке");
	ТаблицаВыгрузки.Колонки.Добавить("ИмяЯчейки");
		
	ОбластьВыгрузки = МакетВыгрузки.Область("Выгрузка" + Префикс);
		
	Для Ном = ОбластьВыгрузки.Верх По ОбластьВыгрузки.Низ Цикл
		Строка = ТаблицаВыгрузки.Добавить();
		Строка.ИмяФормы        			= СокрП(МакетВыгрузки.Область(Ном, 1).Текст);
		Строка.Страница        			= СокрП(МакетВыгрузки.Область(Ном, 2).Текст);
		Строка.ПутьКЯчейке  		    = СокрП(МакетВыгрузки.Область(Ном, 3).Текст);
		Строка.ИмяЯчейки  				= СокрП(МакетВыгрузки.Область(Ном, 4).Текст);
	КонецЦикла;
		
	Объект.ТаблицаОшибокОтчетность1С.Очистить();
	Для Счетчик = 0 по ДополнительныеПараметры.МассивОшибокФЛК.Количество() - 1 Цикл		
		ОшибкаФЛК = ДополнительныеПараметры.МассивОшибокФЛК[Счетчик];		
		СтрокаТаблицы = Объект.ТаблицаОшибокОтчетность1С.Добавить();
		
		СоответствиеСинонимов = РазобратьОтветСервера(ОшибкаФЛК.fieldName, ТаблицаВыгрузки, ИдентификаторВидаФНО);
		СтрокаТаблицы.КодФормы         = ДополнительныеПараметры.СоответствиеСинонимов.СинонимыЭлементовJSON[СоответствиеСинонимов.ИмяФормы];
		СтрокаТаблицы.Страница         = ДополнительныеПараметры.СоответствиеСинонимов.СинонимыЭлементовJSON[СоответствиеСинонимов.Страница];
		Если СоответствиеСинонимов.Свойство("НомерСтроки") И ЗначениеЗаполнено(СоответствиеСинонимов.НомерСтроки) Тогда
			СтрокаТаблицы.НомерСтроки      = СоответствиеСинонимов.НомерСтроки
		КонецЕсли;
		СтрокаТаблицы.Реквизит = ?(ЗначениеЗаполнено(ДополнительныеПараметры.СоответствиеСинонимов.СинонимыЭлементовJSON[СоответствиеСинонимов.Реквизит]),
								   ДополнительныеПараметры.СоответствиеСинонимов.СинонимыЭлементовJSON[СоответствиеСинонимов.Реквизит],
								   СоответствиеСинонимов.Реквизит);
		Если ЗначениеЗаполнено(СтрокаТаблицы.НомерСтроки) И ЗначениеЗаполнено(СтрокаТаблицы.Реквизит) Тогда
			СтрокаТаблицы.Реквизит = СтрокаТаблицы.Реквизит + "__" + СокрЛП(Число(СтрокаТаблицы.НомерСтроки) - 1); //Корректируем нумерацию начиная с 002, так как 001 - итоги
		КонецЕсли;	
		СтрокаТаблицы.РеквизитНазвание = ДополнительныеПараметры.СоответствиеСинонимов.СинонимыПолей[СтрокаТаблицы.Реквизит];
		СтрокаТаблицы.Ошибка           = Отчетность1СКлиентСервер.ПодставитьПараметрыВСтроку(Нстр("ru = '%1'"), ОшибкаФЛК.message);
		СтрокаТаблицы.Критичность      = Истина;		
	КонецЦикла;		
КонецПроцедуры

// Отправляет данные отчетности на шлюзе в фоновом режиме.
//
// Параметры:
//  СтруктураПараметров – Структура
//     Структура, содержащая подготовленные данные для передачи на шлюз,
//     включая сведения о формах, организации, идентификаторе пользователя и т.п.  
//
//  УникальныйИдентификатор – Строка
//     Уникальный идентификатор операции, используется для отслеживания
//     выполнения фонового задания и хранения временных данных.
//
// Возвращаемое значение:
//  Произвольный – результат выполнения фонового задания, возвращаемый методом
//  `ДлительныеОперации.ВыполнитьФункцию`. Обычно содержит объект результата
//  постановки задачи в очередь.
Функция ОтправитьТранспортныйЗапрос(СтруктураПараметров, УникальныйИдентификатор) Экспорт
	ИмяМетода = "Отчетность1ССервер.ОтправитьТранспортныйЗапросОтчетность1С";

	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Валидация данных на шлюзе'");
	ПараметрыВыполнения.ОжидатьЗавершение = 0;
	ПараметрыВыполнения.ЗапуститьНеВФоне = Истина;

	РезультатЗадания = ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, ИмяМетода, СтруктураПараметров); 

	Возврат РезультатЗадания;
КонецФункции

// см. ЭлектронноеВзаимодействиеССервисами.ОтправитьТранспортныйЗапросОтчетность1С()
Функция ОтправитьТранспортныйЗапросОтчетность1С(ДополнительныеПараметры) Экспорт
	Результат = ЭлектронноеВзаимодействиеССервисами.ОтправитьТранспортныйЗапросОтчетность1С(ДополнительныеПараметры);
КонецФункции

#КонецОбласти

#Область ОбновитьСтатус

// Формирует табличный документ уведомления на основе переданного объекта уведомления.
//
// Параметры:
//   Уведомление – структура или объект
//       Объект уведомления, содержащий данные для формирования печатной формы.
//
// Возвращаемое значение:
//   ТабличныйДокумент – ТабличныйДокумент
//       Табличный документ, готовый к отображению или печати.
Функция СформироватьУведомление(СтруктураУведомления) Экспорт			
	Макет = Отчетность1ССерверПереопределяемый.МакетПечатнойФормы("ОбщийМакет.ПФ_MXL_УведомлениеПоФНООтчетность1С");
	
	ОбластьШапки = Макет.ПолучитьОбласть("Шапка");
	ОбластьШапкиОбработки = Макет.ПолучитьОбласть("ДанныеОбОбработкеФормы_Шапка");
	ОбластьСтрокиОбработки = Макет.ПолучитьОбласть("ДанныеОбОбработкеФормы_Строка");
	
	ОбластьШапкиРазноски = Макет.ПолучитьОбласть("ДанныеОРазноскеФормы_Шапка");
	ОбластьСтрокиРазноски = Макет.ПолучитьОбласть("ДанныеОРазноскеФормы_Строка");
	ОбластьСтрокиРазделителя = Макет.ПолучитьОбласть("СтрокаРазделитель");
	ОбластьДанныеОбОшибке = Макет.ПолучитьОбласть("ДанныеОбОшибке");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.КлючПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_УведомлениеОПриемеФНО";
		
	ЗаполнитьЗначенияСвойств(ОбластьШапки.Параметры, СтруктураУведомления);	
	
	Если СтруктураУведомления.Свойство("КодФормы") Тогда
		ОбластьШапки.Параметры.КодФормы = СтруктураУведомления.КодФормы;
	КонецЕсли;
	
	Если СтруктураУведомления.Свойство("Форма") Тогда
		ОбластьШапки.Параметры.НаименованиеДокумента = СтруктураУведомления.Форма;
	КонецЕсли;
	
	Уведомление = СтруктураУведомления.JSONДанныеУведомления;
	Если Уведомление.Свойство("КодНалоговогоОргана") Тогда 
		ОбластьШапки.Параметры.КодНалоговогоОргана	= Уведомление.КодНалоговогоОргана;
	КонецЕсли;
	ТабДокумент.Вывести(ОбластьШапки);
	
	Если Уведомление.Свойство("ПроцессРазноски") Тогда
		ТабДокумент.Вывести(ОбластьШапкиОбработки);
		ПроцессРазноски = Уведомление.ПроцессРазноски;
		Для Каждого ИзмененныйЭлемент Из ПроцессРазноски Цикл
			ЗаполнитьЗначенияСвойств(ОбластьСтрокиОбработки.Параметры, ИзмененныйЭлемент);
			ТабДокумент.Вывести(ОбластьСтрокиОбработки);                            
		КонецЦикла;
	КонецЕсли;
	
	ТабДокумент.Вывести(ОбластьСтрокиРазделителя);
	
	Если Уведомление.Свойство("Разноска") И ЗначениеЗаполнено(Уведомление.Разноска) Тогда 	
		ТабДокумент.Вывести(ОбластьШапкиРазноски);	
		Разноска = Уведомление.Разноска;		
		Для Каждого СтрокаРазноски Из Разноска Цикл
			ЗаполнитьЗначенияСвойств(ОбластьСтрокиРазноски.Параметры, СтрокаРазноски);
			ТабДокумент.Вывести(ОбластьСтрокиРазноски);
		КонецЦикла;
	КонецЕсли;	
	
	Если ЗначениеЗаполнено(СтруктураУведомления.ПричинаОшибки) Тогда
		ЗаполнитьЗначенияСвойств(ОбластьДанныеОбОшибке.Параметры, СтруктураУведомления);
		ТабДокумент.Вывести(ОбластьДанныеОбОшибке);	
	КонецЕсли;
	
	ТабДокумент.Вывести(ОбластьПодвал);
	
	ТабДокумент.Защита = Истина;
	
	Возврат ТабДокумент;
	
КонецФункции

#КонецОбласти

#Область ФункцииОбщегоНазначения

// Преобразует произвольное значение (структуру, массив, объект) в JSON-строку.
//
// Параметры:
//   Значение – любой тип (Структура, Массив, ТаблицаЗначений, Примитивные типы)
//       Значение, которое требуется сериализовать в JSON.
//
// Возвращаемое значение:
//   Строка – строка
//       JSON-представление переданного значения.
Функция Отчетность1С_ЗаписатьЗначениеJSON(Значение) Экспорт
	
	Запись = Новый ЗаписьJSON;
	Запись.УстановитьСтроку();
	ЗаписатьJSON(Запись, Значение);
	
	Возврат Запись.Закрыть();
	
КонецФункции

// Преобразует JSON-строку в объект 1С (Структуру, Массив, ТаблицуЗначений и др.)
//
// Параметры:
//   Значение – строка
//       JSON-строка, которую требуется десериализовать в объекты 1С.
//
// Возвращаемое значение:
//   Любой тип (Структура, Массив, ТаблицаЗначений, Примитивные типы)
//       Объект 1С, соответствующий структуре JSON.
Функция Отчетность1С_ПрочитатьЗначениеJSON(Значение) Экспорт
	
	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(Значение);
	Результат = ПрочитатьJSON(Чтение);
	Чтение.Закрыть();
	
	Возврат Результат;
	
КонецФункции

Процедура Сохранить(Форма, ДокументРеглОтчет, СписокСохранения) Экспорт
	
	Если ЕстьРеквизитФормы(Форма, "ИдентификаторФормыОтчетность1С") Тогда
		// установим значения реквизитов документа
		ДокументРеглОтчет.ИдентификаторПользователяОтчетность1С        = Форма.ИдентификаторПользователяОтчетность1С;
		ДокументРеглОтчет.ИдентификаторФормыВСистемеПриемаОтчетность1С = Форма.ИдентификаторФормыВСистемеПриемаОтчетность1С;
		ДокументРеглОтчет.ИдентификаторФормыОтчетность1С               = Форма.ИдентификаторФормыОтчетность1С;
		ДокументРеглОтчет.СтатусПриемаОтчетность1С                     = Форма.СтатусПриемаОтчетность1С;
		ДокументРеглОтчет.СтатусРазноскиОтчетность1С                   = Форма.СтатусРазноскиОтчетность1С;
		ДокументРеглОтчет.НомерУведомленияОтчетность1С                 = Форма.НомерУведомленияОтчетность1С;
		ДокументРеглОтчет.ДатаУведомленияОтчетность1С                  = Форма.ДатаУведомленияОтчетность1С;
		
		Отчетность1ССерверПереопределяемый.Сохранить(Форма, ДокументРеглОтчет, СписокСохранения);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти 

#Область УправлениеИнтерфейсомФормы

// Выполняется перед созданием формы на сервере. 
// Используется для добавления элементов управления на форму.
//
// Параметры:
//   Форма – ссылка на форму клиентского приложения.
//       Активная форма, для которой необходимо выполнить настройку элементов управления.
//   ГруппаКоманд – (не используется в данном коде, но может быть указана при расширении)
//       Ссылка на группу команд формы (например, Элементы.ГруппаКнопокОсновныеДействия).
Процедура ПередСозданиемНаСервере(Форма) Экспорт
	ДобавитьРеквизитФормы(Форма);
	ДобавитьЭлементыУправления_Кнопки(Форма, Форма.Элементы.ФормаКоманднаяПанель);
	ДобавитьЭлементыУправления_Реквизиты(Форма);
КонецПроцедуры

// Выполняется при создании формы на сервере. 
// Используется для инициализации данных формы, оформления дерева ошибок
// и управления доступностью реквизитов.
//
// Параметры:
//   Форма – ссылка на форму клиентского приложения.
//       Активная форма регламентированного отчета.
Процедура ПриСозданииНаСервере(Форма) Экспорт
	Отчетность1ССерверПереопределяемый.ПриСозданииНаСервере(Форма);
	
	// Заполнение данных по синонимам
	ЗаполнитьСоответствияСинонимовЭлементов(Форма);
	ОформлениеДереваОшибок(Форма);
	// Очистка при копировании
	Если НЕ ЗначениеЗаполнено(Форма.СтруктураРеквизитовФормы.мСохраненныйДок) Тогда
		Форма.ИдентификаторФормыВСистемеПриемаОтчетность1С = "";
		Форма.ИдентификаторФормыОтчетность1С = "";
		Форма.СтатусПриемаОтчетность1С = "";
		Форма.СтатусРазноскиОтчетность1С = "";
		Форма.УведомлениеОтчетность1С = "";
		Форма.НомерУведомленияОтчетность1С = "";
		Форма.ДатаУведомленияОтчетность1С = "";
		Форма.ИдентификаторПользователяОтчетность1С = "";
	КонецЕсли;

	// управление элементами
	СформироватьДеревоОшибок(Форма);
	УстановитьВидимостьДоступностьРеквизитовОтчетность1С(Форма);
	Форма.ПереопределитьОбработчикиФормы();
КонецПроцедуры

// Настраивает видимость и доступность реквизитов и элементов управления формы
// регламентированной отчетности в зависимости от статуса отправки и наличия ошибок.
//
// Параметры:
//   Форма – ссылка на форму клиентского приложения.
//       Активная форма регламентированного отчета.
Процедура УстановитьВидимостьДоступностьРеквизитовОтчетность1С(Форма) Экспорт
	ОбновитьСтатусПриемаОтчетность1С(Форма);
	// пока форма не прошла регистрацию, можно не показывать группу идентификатора
	ФормаСформирована = ЗначениеЗаполнено(Форма.ИдентификаторФормыОтчетность1С) ИЛИ ЗначениеЗаполнено(Форма.ИдентификаторФормыВСистемеПриемаОтчетность1С);
	ФормаВОбработке = ?(Форма.СтатусПриемаОтчетность1С = Перечисления.СтатусыПриемаОтчетность1С.ВОбработке, Истина, Ложь);
	ФормаДоставлена = ?(Форма.СтатусПриемаОтчетность1С = Перечисления.СтатусыПриемаОтчетность1С.Принят, Истина, Ложь);
		
	Отчетность1ССерверПереопределяемый.УстановитьВидимостьДоступностьРеквизитов(Форма);
	
	Форма.Элементы.ГруппаРеквизитовОтправкиОтчетность1С.Видимость = ФормаСформирована;
	Форма.Элементы.НомерУведомленияОтчетность1С.Видимость = ЗначениеЗаполнено(Форма.НомерУведомленияОтчетность1С);
	Форма.Элементы.ДатаУведомленияОтчетность1С.Видимость = ЗначениеЗаполнено(Форма.ДатаУведомленияОтчетность1С);
	Форма.Элементы.ИдентификаторФормыВСистемеПриемаОтчетность1С.Видимость = ЗначениеЗаполнено(Форма.ИдентификаторФормыВСистемеПриемаОтчетность1С);
	Форма.Элементы.ИдентификаторФормыОтчетность1С.Видимость = ФормаСформирована;
	Форма.Элементы.СтатусРазноскиОтчетность1С.Видимость = ЗначениеЗаполнено(Форма.СтатусРазноскиОтчетность1С);
	
	Если Форма.Элементы.Найти("ФормаОтправитьОтчетность1С") <> Неопределено Тогда
		Форма.Элементы.ФормаОтправитьОтчетность1С.Доступность = НЕ ФормаДоставлена И НЕ ФормаВОбработке;
	КонецЕсли;
	
	Если Форма.Элементы.Найти("ФормаОбновитьСтатусОтчетность1С") <> Неопределено Тогда
		Форма.Элементы.ФормаОбновитьСтатусОтчетность1С.Доступность = ФормаВОбработке ИЛИ ФормаДоставлена;
	КонецЕсли;
	
	// таблица ошибок
	ЕстьОшибки = Форма.ТаблицаОшибокОтчетность1С.Количество()>0;
	Форма.Элементы.ГруппаОшибокОтчетность1С.Видимость = ЕстьОшибки;
	Форма.Элементы.ГруппаДеревоОшибокОтчетность1С.ПодчиненныеЭлементы.ДеревоОшибокОтчетность1С.Видимость = ЕстьОшибки;
	
	Форма.Элементы.ГруппаДеревоОшибокОтчетность1С.ПодчиненныеЭлементы.ДеревоОшибокОтчетность1С.ПодчиненныеЭлементы.КолонкаРеквизит.Видимость = Ложь;
	Форма.Элементы.ГруппаДеревоОшибокОтчетность1С.ПодчиненныеЭлементы.ДеревоОшибокОтчетность1С.ПодчиненныеЭлементы.КолонкаКритичность.Видимость = Ложь;
	Форма.Элементы.ГруппаДеревоОшибокОтчетность1С.ПодчиненныеЭлементы.ДеревоОшибокОтчетность1С.ПодчиненныеЭлементы.КолонкаКритичностьСимвол.ПоложениеЗаголовка = 
	                                                    ПоложениеЗаголовкаЭлементаФормы.Нет;
КонецПроцедуры

// Обновляет статус приема формы регламентированной отчетности
// и отображение уведомления в зависимости от состояния отправки
// и наличия ошибок.
//
// Параметры:
//   Форма – ссылка на форму клиентского приложения.
//       Активная форма регламентированного отчета.
Процедура ОбновитьСтатусПриемаОтчетность1С(Форма) Экспорт
	Если ЗначениеЗаполнено(Форма.УведомлениеОтчетность1С) И ТипЗнч(Форма.УведомлениеОтчетность1С)= Тип("Структура") Тогда
		Форма.СтатусПриемаОтчетность1С = Форма.УведомлениеОтчетность1С.Статус;
		Форма.СтатусРазноскиОтчетность1С = ?(Форма.УведомлениеОтчетность1С.Свойство("СтатусРазноски"), Форма.УведомлениеОтчетность1С.СтатусРазноски, "");
	ИначеЕсли ЗначениеЗаполнено(Форма.ТаблицаОшибокОтчетность1С) И Форма.КоличествоОшибокКритичныхОтчетность1С <> 0 Тогда
		Форма.СтатусПриемаОтчетность1С = Перечисления.СтатусыПриемаОтчетность1С.НеПринят;
	ИначеЕсли Форма.СтатусПриемаОтчетность1С = Перечисления.СтатусыПриемаОтчетность1С.ВОбработке И НЕ ЗначениеЗаполнено(Форма.ИдентификаторФормыОтчетность1С) Тогда
		Форма.СтатусПриемаОтчетность1С = Перечисления.СтатусыПриемаОтчетность1С.НеПринят;
	ИначеЕсли ЗначениеЗаполнено(Форма.ИдентификаторФормыОтчетность1С) И НЕ ЗначениеЗаполнено(Форма.СтатусПриемаОтчетность1С) Тогда
		Форма.СтатусПриемаОтчетность1С = Перечисления.СтатусыПриемаОтчетность1С.Сформирован;
	КонецЕсли;
	
	// Цвет
	Если Форма.СтатусПриемаОтчетность1С = Перечисления.СтатусыПриемаОтчетность1С.НеПринят Тогда
		Форма.Элементы.СтатусПриемаОтчетность1С.ЦветТекста = Отчетность1СКлиентСервер.ЦветКрасный();
	ИначеЕсли Форма.СтатусПриемаОтчетность1С = Перечисления.СтатусыПриемаОтчетность1С.Принят Тогда
		Форма.Элементы.СтатусПриемаОтчетность1С.ЦветТекста = Отчетность1СКлиентСервер.ЦветЗеленый();
	Иначе
		Форма.Элементы.СтатусПриемаОтчетность1С.ЦветТекста = Отчетность1СКлиентСервер.ЦветСиний();
	КонецЕсли;                                                                                    
	
	Форма.Элементы.СтатусРазноскиОтчетность1С.ЦветТекста = Отчетность1СКлиентСервер.ЦветСиний();
	
	// Данные уведомления
	Если ЗначениеЗаполнено(Форма.УведомлениеОтчетность1С) И ТипЗнч(Форма.УведомлениеОтчетность1С)= Тип("Структура") Тогда 
		Форма.НомерУведомленияОтчетность1С = Отчетность1СКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='№ %1'"), СокрЛП(Форма.УведомлениеОтчетность1С.РегистрационныйНомер));
		Форма.ДатаУведомленияОтчетность1С = СокрЛП(Форма.УведомлениеОтчетность1С.Дата);	
	Иначе
		Форма.НомерУведомленияОтчетность1С = "";
		Форма.ДатаУведомленияОтчетность1С = "";
	КонецЕсли;
КонецПроцедуры

// Обрабатывает выбор строки в дереве ошибок формы регламентированной
// отчетности. При выборе строки происходит переход к соответствующему
// полю или элементу формы.
//
// Параметры:
//   Форма – ссылка на форму клиентского приложения.
//   ДеревоОшибокТекущиеДанные – ссылка на структуру/дерево ошибок, из которой
//                                производится выбор.
Процедура ДеревоОшибокВыбор(Форма, ДеревоОшибокТекущиеДанные) Экспорт
	Отчетность1ССерверПереопределяемый.ДеревоОшибокВыбор(Форма, ДеревоОшибокТекущиеДанные);	
КонецПроцедуры

#КонецОбласти

#Область ЗаявлениеОВвозеТоваров

// см. Отчетность1ССерверПереопределяемый.ОпределитьИдентификаторНалогоплательщикаДляЗаявленияОВвозеТоваров() 
Функция ОпределитьИдентификаторНалогоплательщикаДляЗаявленияОВвозеТоваров(Форма) Экспорт	
	Возврат Отчетность1ССерверПереопределяемый.ОпределитьИдентификаторНалогоплательщикаДляЗаявленияОВвозеТоваров(Форма);
КонецФункции

// см. Отчетность1ССерверПереопределяемый.СформироватьСтруктуруДопРеквизитов()
Функция СформироватьСтруктуруДопРеквизитов(ДокументДляВыгрузки, РевизияВыгрузки) Экспорт	
	Возврат Отчетность1ССерверПереопределяемый.СформироватьСтруктуруДопРеквизитов(ДокументДляВыгрузки, РевизияВыгрузки);
КонецФункции

// см. Отчетность1ССерверПереопределяемый.ПроверитьДокумент()
Процедура ПроверитьДокумент(ПараметрКоманды) Экспорт
