#Область СлужебныеПроцедурыИФункции

#Область ВыгрузкаВJSON

// Формирует структуру данных регламентированного отчета для последующей выгрузки в формат JSON.
//
// Параметры:  
//   СтруктураПараметровОтчетность1С - Структура - параметры отчета, полученные из функции СформироватьСтруктуруПараметров().
//
// Возвращаемое значение:  
//   Структура - содержит:  
//     * ДанныеВыгрузки - структура, подготовленная для сериализации в JSON;  
//     * КодФормы - строка, код формы, полученный из макета выгрузки.
//
Функция ПолучитьСтруктуруОтчетаДляВыгрузки(СтруктураПараметровОтчетность1С)

	Префикс = СтруктураПараметровОтчетность1С.ПрефиксФормы;

	МакетВыгрузки = Отчеты[СтруктураПараметровОтчетность1С.ИмяФормыДляМакета].ПолучитьМакет("ВыгрузкаJSONОтчетность1С");

	ТаблОбщиеРеквизиты = ЗаполнитьТаблицуОбщихРеквизитов(МакетВыгрузки, Префикс);
	
	ДанныеВыгрузки = Новый Структура;

	ТаблицаВыгрузки = СтруктураПараметровОтчетность1С.ТаблицаВыгрузки;	
	// Выгрузка в JSON.
	КоличествоСтрокВТаблице = ТаблицаВыгрузки.Количество();
	НомерСтроки = 0;

	ТекущаяФорма = Неопределено;

	СлужебныеРеквизитыДополнительныеПараметры = Новый Структура;
	СлужебныеРеквизитыДополнительныеПараметры.Вставить("Налогоплательщик", СтруктураПараметровОтчетность1С.Налогоплательщик);
	СлужебныеРеквизитыДополнительныеПараметры.Вставить("ИдентификаторПользователя", СтруктураПараметровОтчетность1С.ИдентификаторПользователя);
	
	СлужебныеРеквизитыФормы = ЗаполнитьСлужебныеРеквизитыФормыСтандартные(СлужебныеРеквизитыДополнительныеПараметры, СтруктураПараметровОтчетность1С.СлужебныеРеквизитыФормы);

	Пока Истина Цикл
		Если НомерСтроки >= КоличествоСтрокВТаблице Тогда
			Прервать;
		КонецЕсли;
		Если ТаблицаВыгрузки[НомерСтроки].Выгружать <> Неопределено И ТаблицаВыгрузки[НомерСтроки].Выгружать Тогда
			ВыгрузитьСтрокуВJSON(СтруктураПараметровОтчетность1С, ДанныеВыгрузки, ТаблицаВыгрузки, КоличествоСтрокВТаблице, НомерСтроки, ТекущаяФорма, СлужебныеРеквизитыФормы);	
		КонецЕсли;			                                                                                                  
		НомерСтроки = НомерСтроки + 1;
	КонецЦикла;
	
	КодФормы = ТаблОбщиеРеквизиты.Найти("code", "ИмяАтрибута").ЗначениеАтрибута;
	Результат = Новый Структура;
	Результат.Вставить("ДанныеВыгрузки", ДанныеВыгрузки);	
	Результат.Вставить("КодФормы", КодФормы);
	
	Возврат Результат;		
КонецФункции   

// Выгружает одну строку данных отчета в структуру JSON.
//
// Параметры:
//   СтруктураПараметровОтчетность1С – Структура – параметры отчета, полученные из функции СформироватьСтруктуруПараметров().
//   Запись – структура, в которую добавляются данные для формирования итогового JSON.
//   ТаблицаВыгрузки – ТаблицаЗначений – содержит строки макета выгрузки отчета.
//   КоличествоСтрокВТаблице – Число – общее количество строк в таблице выгрузки.
//   НомерСтроки – Число – индекс текущей обрабатываемой строки.
//   ТекущаяФорма – (Необязательный) Строка – имя текущей формы отчета, по умолчанию Неопределено.
//   СлужебныеРеквизитыФормы – ТаблицаЗначений – реквизиты, полученные из функции ЗаполнитьСлужебныеРеквизитыФормыСтандартные().
//
Процедура ВыгрузитьСтрокуВJSON(СтруктураПараметровОтчетность1С, Запись, ТаблицаВыгрузки, КоличествоСтрокВТаблице, НомерСтроки, ТекущаяФорма = Неопределено, СлужебныеРеквизитыФормы)
	
	СтрокаВыгрузки = ТаблицаВыгрузки.Получить(НомерСтроки);		
		
	НоваяФорма = СтрокаВыгрузки.Форма;
	ВладелецJSON = СокрЛП(СтрокаВыгрузки.ВладелецJSON); 
	
	Если НЕ ЗначениеЗаполнено(ВладелецJSON) И ЗначениеЗаполнено(СлужебныеРеквизитыФормы) Тогда
		Если ЗаполнитьСлужебныйРеквизитФормыJSON(СтруктураПараметровОтчетность1С, Запись, СтрокаВыгрузки, СлужебныеРеквизитыФормы) Тогда
			Возврат;
		КонецЕсли;			
	КонецЕсли;
	
	Если СтрокаВыгрузки.Многострочность <> Неопределено И СтрокаВыгрузки.Многострочность = 1 Тогда
		ВыгрузитьМногострочнуюФормуJSON(СтруктураПараметровОтчетность1С, Запись, ТаблицаВыгрузки, КоличествоСтрокВТаблице, НомерСтроки);
	Иначе
		 
		ТекущийВладелец = ПолучитьТекущийВладелец(Запись, СтрокаВыгрузки, ТаблицаВыгрузки);
		Если ТипЗнч(ТекущийВладелец) = Тип("Структура") Тогда
			ЗаписатьЗначениеЭлементаJSON(СтруктураПараметровОтчетность1С, Запись, СтрокаВыгрузки,,,,ТекущийВладелец);
		ИначеЕсли ТипЗнч(ТекущийВладелец) = Тип("Массив") Тогда 	
			
			// Выгрузка обычных форм с возможностью добавления приложений
			Если НЕ Найти(СтрокаВыгрузки.ВладелецJSON, "application_") > 0 ИЛИ НЕ СтрокаВыгрузки.Многострочность Тогда
				ЗаписатьЗначениеЭлементаJSON(СтруктураПараметровОтчетность1С, Запись, СтрокаВыгрузки,,,,ТекущийВладелец);				
			КонецЕсли; 
			
		КонецЕсли; 
	КонецЕсли;
	
	ТекущаяФорма = НоваяФорма;
	
КонецПроцедуры   

// Записывает значение элемента формы отчета в структуру JSON при формировании выгрузки.  
// Процедура выполняет преобразование значений ячеек, поддерживает работу с многострочными формами,  
// группами строк, шапкой и подвалом, а также добавление значений по умолчанию или служебных полей.
//
// Описание работы:
//  - Определяет значение ячейки отчета по макету выгрузки.
//  - Преобразует значение в корректный JSON-формат (через ПривестиЗначениеКФорматуJSON).
//  - Записывает значение в соответствующий атрибут структуры или массива JSON.
//  - Поддерживает многострочные формы, заголовки и подвал.
//  - При отсутствии данных подставляет значения по умолчанию или сообщает пользователю об ошибках.
//
// Параметры:
//  СтруктураПараметровОтчетность1С – Структура – параметры отчета, полученные из функции СформироватьСтруктуруПараметров(). 
//  Запись – структура, в которую добавляются данные для формирования итогового JSON.
//  СтрокаВыгрузки – СтрокаТаблицыЗначений – описание ячейки, содержащей настройки выгрузки (имя ячейки, атрибут JSON, тип свойства и т.д.).
//  МногСтруктура – Структура (Необязательный) – структура, содержащая данные многострочных разделов формы.
//  СтруктураПараметров – Структура (Необязательный) – параметры текущей выгрузки (номер листа, номер записи и пр.).
//  ТекущаяСтрокаJSON – Неопределено/Структура (Необязательный) – используется при вложенной записи значений в JSON.
//  ТекущийВладелецЭкземплярJSON – Структура/Массив – структура или массив JSON, в который записываются данные.
//  ЗначениеСвойстваJSON – ПроизвольныйТип (Необязательный) – предварительно вычисленное значение для записи в JSON.
//
Процедура ЗаписатьЗначениеЭлементаJSON(СтруктураПараметровОтчетность1С, Запись, СтрокаВыгрузки, МногСтруктура = Неопределено,  СтруктураПараметров = Неопределено, ТекущаяСтрокаJSON = Неопределено, ТекущийВладелецЭкземплярJSON = Неопределено, ЗначениеСвойстваJSON = Неопределено)	
	
	// Выгрузим значение ячейки, если оно есть в форме
	ИмяЯчейки = СтрокаВыгрузки.ИмяЯчейки;
	Если ЗначениеЗаполнено(ИмяЯчейки) Тогда
		//получаем и записываем значение из отчета
		Если СтрокаВыгрузки.Выгружать = 1 Тогда
			Если СтрокаВыгрузки.Многострочность Тогда
				// определим имя Листа по имени страницы
				ИмяЛиста = СтрокаВыгрузки.ИмяЛиста;
				СтруктураГруппы = Неопределено;
				//если в обычной форме, есть многострочность
				Если МногСтруктура = Неопределено Тогда
					МногСтруктура = СтрокаВыгрузки.Значение[0].Данные;
				КонецЕсли;
				
				Если ЗначениеЗаполнено(ИмяЛиста) И МногСтруктура.Свойство(ИмяЛиста) Тогда
					МногСтруктура.Свойство(ИмяЛиста,СтруктураГруппы);
				Иначе
					ТекстСообщения = Отчетность1СКлиентСервер.ПодставитьПараметрыВСтроку(
						НСтр("ru = '%1: Не заполнено ""Имя листа"" или ""Имя листа"" указано неверно для ячейки ""%2"" в макете для выгрузки значения в JSON'"),
						СтрокаВыгрузки.КодФормы,
						ИмяЯчейки);
					
					Отчетность1СКлиентСервер.СообщитьПользователю(ТекстСообщения);
				КонецЕсли;
				
				Если СтрокаВыгрузки.КоличествоНаЛисте = 1 Тогда
					Если СтруктураГруппы <> Неопределено
						И СтруктураГруппы.Строки.Количество() > 0 Тогда
						НомерЛиста = СтруктураПараметров.НомерЛиста;
						СтрокаЗначений = СтруктураГруппы.Строки[НомерЛиста];
						Попытка
							Строка = СтрокаЗначений[ИмяЯчейки];
							
							Если Строка = Неопределено И СтрокаВыгрузки.ТипСвойстваJSON = "БулевоСтрока" Тогда
								Строка = "";
							КонецЕсли;
						Исключение
							Строка = Неопределено;
						КонецПопытки;
						Если Строка <> Неопределено Тогда
							// Реквизит найден на форме
							Значение = Строка;
                            Значение = ПривестиЗначениеКФорматуJSON(СтруктураПараметровОтчетность1С, Значение, СтрокаВыгрузки, НомерЛиста + 1);
							Если ЗначениеЗаполнено(Значение)
								ИЛИ НЕ СтрокаВыгрузки.ТипСвойстваJSON = "БулевоСтрока" Тогда
								Если ТипЗнч(ТекущийВладелецЭкземплярJSON) = Тип("Структура") Тогда
									ТекущийВладелецЭкземплярJSON.Вставить(СтрокаВыгрузки.ИмяАтрибута, Значение);
							 	Иначе 
									ТекущийВладелецЭкземплярJSON.Добавить(Значение);
	                            КонецЕсли;
	                        КонецЕсли;
						Иначе
							// Реквизит не найден на форме - нужно добавить номер листа из структуры параметров
							Значение = ПривестиЗначениеКФорматуJSON(СтруктураПараметровОтчетность1С, СтрокаВыгрузки.ЗначениеJSON, СтрокаВыгрузки, НомерЛиста + 1); 
							Если ТипЗнч(ТекущийВладелецЭкземплярJSON) = Тип("Структура") Тогда
								ТекущийВладелецЭкземплярJSON.Вставить(СтрокаВыгрузки.ИмяАтрибута, Значение);
						 	Иначе 
								ТекущийВладелецЭкземплярJSON.Добавить(Значение);
                            КонецЕсли;
						КонецЕсли;
					КонецЕсли;
				// Строки многострочной формы - все, кроме итогов	
				ИначеЕсли ЗначениеЗаполнено(СтрокаВыгрузки.КоличествоROW) И СтрокаВыгрузки.КоличествоROW <> "0" И СтруктураПараметров.НомерЗаписи > 0 Тогда  // многострочная часть row
					НомерЗаписиНаЛисте = Неопределено;
					СтруктураПараметров.Свойство("НомерЗаписи", НомерЗаписиНаЛисте);	
					Если СтруктураГруппы <> Неопределено Тогда
						ТаблицаСтрокГруппы = СтруктураГруппы.Строки;
						// рассчитаем индекс строки и проверим есть ли такая строка в таблице данных
						ИндексСтроки = НомерЗаписиНаЛисте - 1;
						Если ИндексСтроки < ТаблицаСтрокГруппы.Количество() Тогда  // строк в таблице может быть меньше, чем выгружается в XML
							Строка = ТаблицаСтрокГруппы.Получить(ИндексСтроки);
							Если Строка <> Неопределено Тогда // найдена строка для выгрузки значения  
								
								Если СтруктураГруппы.Свойство("КодДопПриложения") Тогда
									ИмяЯчейки = СтрЗаменить(ИмяЯчейки, СтрЗаменить(СтрокаВыгрузки.КодФормы,"Форма", "Ф"), СтрЗаменить(СтруктураГруппы.КодДопПриложения, "Форма", "Ф"));	
								КонецЕсли;
								
								Если ТаблицаСтрокГруппы.Колонки.Найти(ИмяЯчейки) <> Неопределено Тогда 
									Значение = Строка[ИмяЯчейки];
									
									Если (СтрокаВыгрузки.ИмяАтрибута = "A" ИЛИ СтрокаВыгрузки.ИмяАтрибута = "А") Тогда
										Значение = Формат(Число(Значение), Отчетность1СКлиентСервер.ФорматНомераСтрокиМногострочнойФормы(СтрокаВыгрузки.ЗначениеJSON));
									Иначе
										// для числовых ячеек будем выгружать 0. Так как это обычно требуется в ФЛК суммовых полей
										Значение = ПривестиЗначениеКФорматуJSON(СтруктураПараметровОтчетность1С, Значение, СтрокаВыгрузки, СтруктураПараметров.НомерЗаписи); 	
									КонецЕсли;
									
									Если ТипЗнч(ТекущийВладелецЭкземплярJSON) = Тип("Структура") Тогда
										Если ТекущийВладелецЭкземплярJSON.Свойство(СтрокаВыгрузки.ИмяАтрибута) Тогда
											Значение = ?(НЕ ЗначениеЗаполнено(Значение), ТекущийВладелецЭкземплярJSON[СтрокаВыгрузки.ИмяАтрибута], Значение);
										КонецЕсли;		
										ТекущийВладелецЭкземплярJSON.Вставить(СтрокаВыгрузки.ИмяАтрибута, Значение);	
									Иначе
										Если Найти(СтрокаВыгрузки.ТипСвойстваJSON, "СтруктураЗначение") > 0  Тогда
											Если ТекущийВладелецЭкземплярJSON.Количество() > 0 Тогда
												ТекущийВладелецЭкземплярJSON[0].Вставить(СтрокаВыгрузки.ИмяАтрибута, Значение);	
											Иначе
												// добавляем строку только при наличии данных, в макете строка "основных" заполненных данных всегда должна быть выше по порядку
												Если ЗначениеЗаполнено(Значение) Тогда
													СтруктураДанных = Новый Структура("index, " + СтрокаВыгрузки.ИмяАтрибута, 0, Значение);
													ТекущийВладелецЭкземплярJSON.Добавить(СтруктураДанных);
												КонецЕсли;
											КонецЕсли;
										Иначе
											ТекущийВладелецЭкземплярJSON.Добавить(Значение);
										КонецЕсли;
									КонецЕсли;										
								КонецЕсли;
							КонецЕсли;
						Иначе 
							Значение = ПривестиЗначениеКФорматуJSON(СтруктураПараметровОтчетность1С, Значение, СтрокаВыгрузки);
							Если ТипЗнч(ТекущийВладелецЭкземплярJSON) = Тип("Структура") Тогда
								ТекущийВладелецЭкземплярJSON.Вставить(СтрокаВыгрузки.ИмяАтрибута, Значение);
							КонецЕсли;
						КонецЕсли;
					Иначе
						ТекущийВладелецЭкземплярJSON.Вставить(СтрокаВыгрузки.ИмяАтрибута, "");	 					 						 						
					КонецЕсли;
				// Первая строка - итоги	
				ИначеЕсли ЗначениеЗаполнено(СтрокаВыгрузки.КоличествоROW) И СтрокаВыгрузки.КоличествоROW <> "0" И СтруктураПараметров.НомерЗаписи = 0 Тогда  // многострочная часть row
					НомерЗаписиНаЛисте = Неопределено;
					СтруктураПараметров.Свойство("НомерЗаписи", НомерЗаписиНаЛисте);
					// Номер первой строки итогов
					Если (СтрокаВыгрузки.ИмяАтрибута = "A" ИЛИ СтрокаВыгрузки.ИмяАтрибута = "А") И НЕ ТекущийВладелецЭкземплярJSON.Свойство(СтрокаВыгрузки.ИмяАтрибута) Тогда
						ТекущийВладелецЭкземплярJSON.Вставить(СтрокаВыгрузки.ИмяАтрибута, Формат(1, Отчетность1СКлиентСервер.ФорматНомераСтрокиМногострочнойФормы(СтрокаВыгрузки.ЗначениеJSON)));	
					ИначеЕсли СтруктураГруппы <> Неопределено Тогда
						ТаблицаСтрокГруппы = СтруктураГруппы.ШапкаИПодвал;
						// рассчитаем индекс строки и проверим есть ли такая строка в таблице данных
						Если МногСтруктура[ИмяЛиста].Свойство("КодДопПриложения") Тогда
							ИмяЯчейкиДляЗамены = СтрЗаменить(МногСтруктура[ИмяЛиста].КодДопПриложения, "Форма", "Ф");
							ИмяЯчейкиПодстрокаПоиска = СтрЗаменить(ИмяЯчейкиДляЗамены, Прав(ИмяЯчейкиДляЗамены, 2), "");
							ИмяЯчейки = СтрЗаменить(ИмяЯчейки, ИмяЯчейкиПодстрокаПоиска, ИмяЯчейкиДляЗамены);
						КонецЕсли;
						
						Строка = ТаблицаСтрокГруппы.Найти(ИмяЯчейки);
						Если Строка <> Неопределено Тогда // найдена строка для выгрузки значения  
							
							Если СтруктураГруппы.Свойство("КодДопПриложения") Тогда
								ИмяЯчейки = СтрЗаменить(ИмяЯчейки, СтрЗаменить(СтрокаВыгрузки.КодФормы,"Форма", "Ф"), СтрЗаменить(СтруктураГруппы.КодДопПриложения, "Форма", "Ф"));	
							КонецЕсли;
							
							Значение = Строка.Значение;
							 
							// для числовых ячеек будем выгружать 0. Так как это обычно требуется в ФЛК суммовых полей
							Значение = ПривестиЗначениеКФорматуJSON(СтруктураПараметровОтчетность1С, Значение, СтрокаВыгрузки, СтруктураПараметров.НомерЗаписи); 
							Если ТипЗнч(ТекущийВладелецЭкземплярJSON) = Тип("Структура") Тогда
								ТекущийВладелецЭкземплярJSON.Вставить(СтрокаВыгрузки.ИмяАтрибута, Значение);
							Иначе
								Если Найти(СтрокаВыгрузки.ТипСвойстваJSON, "СтруктураЗначение") > 0  Тогда
									ЗаполнитьСтруктуруЗначений(ТекущийВладелецЭкземплярJSON, СтрокаВыгрузки, Значение);
								Иначе
									ТекущийВладелецЭкземплярJSON.Добавить(Значение);
								КонецЕсли;
							КонецЕсли;										
						Иначе                                                                 
							Значение = ПривестиЗначениеКФорматуJSON(СтруктураПараметровОтчетность1С, Неопределено, СтрокаВыгрузки);	
							Если ТипЗнч(ТекущийВладелецЭкземплярJSON) = Тип("Структура") Тогда
								ТекущийВладелецЭкземплярJSON.Вставить(СтрокаВыгрузки.ИмяАтрибута, Значение);
							Иначе	
								Если Найти(СтрокаВыгрузки.ТипСвойстваJSON, "СтруктураЗначение") > 0  Тогда
									ЗаполнитьСтруктуруЗначений(ТекущийВладелецЭкземплярJSON, СтрокаВыгрузки, Значение);	
								Иначе
									ТекущийВладелецЭкземплярJSON.Добавить(Значение);
								КонецЕсли;
							КонецЕсли;	
						КонецЕсли;
												
					Иначе
						ТекущийВладелецЭкземплярJSON.Вставить(СтрокаВыгрузки.ИмяАтрибута, "");	 					 						 						
					КонецЕсли;	
				Иначе // шапка или подвал
					
					// Создать структуру изначально пустых значений
					// Из шапки брать заполненные
					Если СтруктураГруппы <> Неопределено Тогда
						ОбщиеЭлементыГруппы = СтруктураГруппы.ШапкаИПодвал;
						
						Если СтруктураГруппы.Свойство("КодДопПриложения") Тогда
							ИмяЯчейки = СтрЗаменить(ИмяЯчейки, СтрЗаменить(СтрокаВыгрузки.КодФормы,"Форма", "Ф"), СтрЗаменить(СтруктураГруппы.КодДопПриложения, "Форма", "Ф"));	
						КонецЕсли;
						
						Строка = ОбщиеЭлементыГруппы.Найти(ИмяЯчейки,"ИмяОбласти");
						Если Строка <> Неопределено Тогда
							Значение = Строка.Значение;
							Значение = ПривестиЗначениеКФорматуJSON(СтруктураПараметровОтчетность1С, Значение, СтрокаВыгрузки); //СтрокаФорматов);
								
							// Обработка ячеек с типом СтруктураЗначение, которые входят в многострочные формы										
							Если ТипЗнч(ТекущийВладелецЭкземплярJSON) = Тип("Структура") Тогда
								ТекущийВладелецЭкземплярJSON.Вставить(СтрокаВыгрузки.ИмяАтрибута, Значение);
							Иначе
								
								Если Найти(СтрокаВыгрузки.ТипСвойстваJSON, "СтруктураЗначение") > 0 Тогда 
									
									Если Не ЗначениеЗаполнено(Значение) Тогда
										Значение = ПривестиЗначениеКФорматуJSON(СтруктураПараметровОтчетность1С, СтрокаВыгрузки.ЗначениеJSON, СтрокаВыгрузки);
									КонецЕсли; 
									
									ЗаполнитьСтруктуруЗначений(ТекущийВладелецЭкземплярJSON, СтрокаВыгрузки, Значение);
									
								Иначе
									ТекущийВладелецЭкземплярJSON.Добавить(Значение);
								КонецЕсли;
								
							КонецЕсли;
						Иначе
							ТекстСообщения = Отчетность1СКлиентСервер.ПодставитьПараметрыВСтроку(
								НСтр("ru = '%1: Не найден в структуре хранения данных показатель %2'"),
								СтрокаВыгрузки.КодФормы,
								ИмяЯчейки);
							
							Отчетность1СКлиентСервер.СообщитьПользователю(ТекстСообщения);
							Значение = "";
						КонецЕсли;
					КонецЕсли;
				 КонецЕсли;	
			Иначе
				ТаблицаДанных = СтрокаВыгрузки.Значение;
				СтрокаОбласти = ТаблицаДанных.Найти(ИмяЯчейки,"ИмяОбласти");
				Если СтрокаОбласти <> Неопределено Тогда
					Если НЕ ЗначениеСвойстваJSON = Неопределено Тогда
						
						Если ТипЗнч(ТекущийВладелецЭкземплярJSON) = Тип("Структура") Тогда
							ТекущийВладелецЭкземплярJSON.Вставить(СтрокаВыгрузки.ИмяАтрибута, ЗначениеСвойстваJSON);
						Иначе
							ТекущийВладелецЭкземплярJSON.Добавить(ЗначениеСвойстваJSON);
						КонецЕсли;
						
					Иначе
						
						Значение = СтрокаОбласти.Значение;
						Значение = ПривестиЗначениеКФорматуJSON(СтруктураПараметровОтчетность1С, Значение, СтрокаВыгрузки);
						
						Если ЗначениеЗаполнено(Значение)
							ИЛИ НЕ СтрокаВыгрузки.ТипСвойстваJSON = "БулевоСтрока" Тогда
							Если ТипЗнч(ТекущийВладелецЭкземплярJSON) = Тип("Структура") Тогда
								ТекущийВладелецЭкземплярJSON.Вставить(СтрокаВыгрузки.ИмяАтрибута, Значение);
							Иначе
								Если Найти(СтрокаВыгрузки.ТипСвойстваJSON, "СтруктураЗначение") > 0 Тогда 	
									ЗаполнитьСтруктуруЗначений(ТекущийВладелецЭкземплярJSON, СтрокаВыгрузки, Значение);	
								Иначе
									ТекущийВладелецЭкземплярJSON.Добавить(Значение);
								КонецЕсли;	
							КонецЕсли;
							
						КонецЕсли;
						
					КонецЕсли;
				Иначе
					Отчетность1СКлиентСервер.СообщитьПользователю(Отчетность1СКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Не найдена ячейка ""%1"" для выгрузки значения в JSON!'"), ИмяЯчейки));
				КонецЕсли;
			КонецЕсли;
		Иначе
			
			Значение = ПривестиЗначениеКФорматуJSON(СтруктураПараметровОтчетность1С, Значение, СтрокаВыгрузки);
			
			Если ЗначениеЗаполнено(Значение)
				ИЛИ НЕ СтрокаВыгрузки.ТипСвойстваJSON = "БулевоСтрока" Тогда
			
				Если ТипЗнч(ТекущийВладелецЭкземплярJSON) = Тип("Структура") Тогда
					ТекущийВладелецЭкземплярJSON.Вставить(СтрокаВыгрузки.ИмяАтрибута, Значение);
				Иначе
					Если ЗначениеЗаполнено(Значение) 
						ИЛИ НЕ Найти(СтрокаВыгрузки.ТипСвойстваJSON, "СтруктураЗначение") > 0 Тогда
						ТекущийВладелецЭкземплярJSON.Добавить(Значение); 
					КонецЕсли;
				КонецЕсли;  
			
			КонецЕсли;
			
		КонецЕсли;
	Иначе 

		// доработки для служебных структур отчетов (fnoYear, taxpayerCode и тд)
		Если НЕ ЗначениеСвойстваJSON = Неопределено Тогда
			Значение = ПривестиЗначениеКФорматуJSON(СтруктураПараметровОтчетность1С,ЗначениеСвойстваJSON, СтрокаВыгрузки);					
		Иначе
			// получим из макета из значений по умолчанию
			Значение = ПривестиЗначениеКФорматуJSON(СтруктураПараметровОтчетность1С, Неопределено, СтрокаВыгрузки); 	
		КонецЕсли;
			
		Если ТипЗнч(ТекущийВладелецЭкземплярJSON) = Тип("Структура") Тогда
			ТекущийВладелецЭкземплярJSON.Вставить(СтрокаВыгрузки.ИмяАтрибута, Значение);
		Иначе		
			
			Если Найти(СтрокаВыгрузки.ТипСвойстваJSON, "СтруктураЗначение") > 0  Тогда 
				
				Если НЕ ЗначениеЗаполнено(Значение) Тогда
					Значение = ПривестиЗначениеКФорматуJSON(СтруктураПараметровОтчетность1С, СтрокаВыгрузки.ЗначениеJSON, СтрокаВыгрузки);
				КонецЕсли; 
				
				ЗаполнитьСтруктуруЗначений(ТекущийВладелецЭкземплярJSON, СтрокаВыгрузки, Значение);
				
			Иначе
				ТекущийВладелецЭкземплярJSON.Добавить(Значение);
			КонецЕсли;

		КонецЕсли; 

	КонецЕсли;

КонецПроцедуры 

// Преобразует значение элемента формы к корректному формату JSON.  
// Функция используется при формировании структуры выгрузки, обеспечивает приведение типов  
// и обработку пустых, нулевых и специальных значений в зависимости от параметров выгрузки.
//
// Параметры:
//  СтруктураПараметровОтчетность1С – Структура – параметры отчета, полученные из функции СформироватьСтруктуруПараметров().  
//  Значение – ПроизвольныйТип – исходное значение, полученное из формы отчета или вычислений.  
//  СтрокаВыгрузки – СтрокаТаблицыЗначений – описание элемента выгрузки (тип JSON, имя ячейки, признак выгрузки нулей и т.д.).  
//  НомерЗаписи – Число (Необязательный) – индекс строки в многострочном разделе (используется для уникализации имен ячеек).
//
// Возвращаемое значение:
//  ПроизвольныйТип – значение, приведенное к типу, соответствующему формату JSON  
//  (Строка, Число, Булево, Дата, Структура, Массив, Неопределено).
//
Функция ПривестиЗначениеКФорматуJSON(СтруктураПараметровОтчетность1С, Значение, СтрокаВыгрузки, НомерЗаписи=Неопределено) Экспорт	
	СписокОбязательныхПолей = ?(СтруктураПараметровОтчетность1С.Свойство("СписокОбязательныхПолей"), 
								СтруктураПараметровОтчетность1С.СписокОбязательныхПолей, 
								Новый СписокЗначений);
	
	ВыгружатьНулевыеЗначения = СтрокаВыгрузки.ВыгружатьНулевыеЗначения;
	ТипЗначения = СтрокаВыгрузки.ТипСвойстваJSON;
	ЗначениеJSON = СтрокаВыгрузки.ЗначениеJSON;
		
	// В 910.02 E необходимо заполнять значения из справочника
	Если СтрокаВыгрузки.Форма = "form_910_02" И СтрокаВыгрузки.ВладелецJSON = "fnoContent.application_02" И СтрокаВыгрузки.ИмяАтрибута = "E" Тогда
		КлассификаторСтрокиE = Новый Соответствие;
		КлассификаторСтрокиE.Вставить("1", "A");
		КлассификаторСтрокиE.Вставить("2", "B");
		
		Значение = КлассификаторСтрокиE.Получить(Значение);
		Возврат Значение;
	КонецЕсли;
	
	//  В УПК/ЗУП в форме 200.02 I выгружается значение с пробелом "1 200" вместо "1200". 
	Если СтрокаВыгрузки.Форма = "form_200_02" И СтрокаВыгрузки.ВладелецJSON = "fnoContent.application_02" И СтрокаВыгрузки.ИмяАтрибута = "I" Тогда	
		Значение = СтрЗаменить(Значение, Символы.НПП, "");
		Возврат Значение;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЗначениеJSON)  
		И НЕ ВРег(ТипЗначения) = ВРег("БулевоСтрока")
		И Найти(ВРег(ТипЗначения), ВРег("СтруктураЗначение")) = 0		
		Тогда
		
		// задано фиксированное значение
        Значение = ЗначениеJSON;
		
		Если НЕ ЗначениеЗаполнено(ТипЗначения) ИЛИ ТипЗнч(ЗначениеJSON) = Тип(ТипЗначения) Тогда 		
			// задано фиксированное значение и его тип соответствует или не задан, дальнейшее преобразование не требуется
			Возврат Значение;                                                                    
		КонецЕсли;
		
	КонецЕсли;
	
	Если Найти(ВРег(ТипЗначения), ВРег("СтруктураЗначение")) > 0 Тогда
		
		СтруктураЗначениеСостав = СтрРазделить(ТипЗначения,"_");
		
		Если СтруктураЗначениеСостав.Количество() > 1 Тогда	    
			ТипЗначения = СтруктураЗначениеСостав[1];		
		Иначе
			Если ЗначениеЗаполнено(ЗначениеJSON) Тогда
				Значение = ЗначениеJSON;	
			ИначеЕсли НЕ ЗначениеЗаполнено(Значение) Тогда
				Значение = Неопределено;		
			КонецЕсли;	
		КонецЕсли;
	КонецЕсли;
	
	Если ВРег(ТипЗначения) = ВРег("БулевоСтрока") Тогда
		Если ЗначениеЗаполнено(Значение) Тогда
			Значение = ЗначениеJSON;
		Иначе
			Значение = "";
		КонецЕсли;
	ИначеЕсли ВРег(ТипЗначения) = ВРег("Булево") Тогда					
		Если ТипЗнч(Значение) = Тип("Строка") Тогда
			
			Если Значение = "1" ИЛИ ВРег(Значение) = "Х" ИЛИ ВРег(Значение) = "X" ИЛИ ВРег(Значение) = ВРег("true") Тогда
				Значение = Истина;	
			ИначеЕсли Значение = "0" ИЛИ Значение = "" ИЛИ ВРег(Значение) = ВРег("false") Тогда
				Значение = Ложь;
			Иначе
				Значение = Булево(Значение);
			КонецЕсли;		
		// пустая строка	
		ИначеЕсли Значение = Неопределено Тогда
			Значение = Ложь;
		КонецЕсли;
	ИначеЕсли ВРег(ТипЗначения) = ВРег("Дата")  Тогда
		Если НЕ ЗначениеЗаполнено(Значение) И ВыгружатьНулевыеЗначения Тогда
			Значение = "";
		ИначеЕсли НЕ ЗначениеЗаполнено(Значение) И НЕ ВыгружатьНулевыеЗначения Тогда
			Значение = Неопределено;	
		Иначе	
			Значение = Лев(Значение,10);
		КонецЕсли;
	ИначеЕсли ВРег(ТипЗначения) = ВРег("Строка") Тогда
		Если НЕ ЗначениеЗаполнено(Значение) И ВыгружатьНулевыеЗначения Тогда
			Значение = "";
		ИначеЕсли НЕ ЗначениеЗаполнено(Значение) И НЕ ВыгружатьНулевыеЗначения Тогда
			Значение = Неопределено;	
		Иначе
			Значение = СокрЛП(Строка(Значение));
		КонецЕсли;
	ИначеЕсли ВРег(ТипЗначения) = ВРег("Число") Тогда
		ИмяЯчейки = ?(НомерЗаписи=Неопределено,СтрокаВыгрузки.ИмяЯчейки,СтрокаВыгрузки.ИмяЯчейки + "__" + НомерЗаписи);
		Если ЗначениеЗаполнено(Значение) Тогда
			Значение = Число(Значение);	
		ИначеЕсли НЕ ЗначениеЗаполнено(Значение) И (ВыгружатьНулевыеЗначения ИЛИ СписокОбязательныхПолей.НайтиПоЗначению(ИмяЯчейки) <> Неопределено) Тогда
			Значение = 0;	
		Иначе
			Значение = Неопределено;
		КонецЕсли;
	ИначеЕсли ТипЗнч(Значение) = Тип("Число") И Значение = 0 Тогда
		ИмяЯчейки = ?(НомерЗаписи=Неопределено,СтрокаВыгрузки.ИмяЯчейки,СтрокаВыгрузки.ИмяЯчейки + "__" + НомерЗаписи);
		Если ВыгружатьНулевыеЗначения ИЛИ СписокОбязательныхПолей.НайтиПоЗначению(ИмяЯчейки) <> Неопределено Тогда
			Значение = 0;		
		Иначе
			Значение = Неопределено;
		КонецЕсли;	
	ИначеЕсли ТипЗнч(Значение) = Тип("СписокЗначений") Тогда	
	    МассивЗначение  = Значение.ВыгрузитьЗначения();
	    Значение = СтрСоединить(МассивЗначение, ";");    
    // для верхних уровней структур
	ИначеЕсли ВРег(ТипЗначения) = ВРег("Структура")
		И (Значение = Неопределено ИЛИ НЕ ЗначениеЗаполнено(Значение)) Тогда
		Значение = Новый Структура;
	ИначеЕсли ВРег(ТипЗначения) = ВРег("Массив")
		И Значение = Неопределено Тогда
		Значение = Новый Массив;
	ИначеЕсли ВРег(ТипЗначения) = ВРег("null") Тогда		
		Значение = Неопределено;	
	КонецЕсли;

	Возврат Значение;	
	
КонецФункции

// Заполняет служебный реквизит формы в структуре JSON.  
// Используется при формировании JSON-выгрузки для добавления значений служебных атрибутов формы.
//
// Параметры:
//  СтруктураПараметровОтчетность1С – Структура – параметры отчета, полученные из функции СформироватьСтруктуруПараметров().  
//  Запись – Структура – структура, в которую добавляются данные для формирования итогового JSON.  
//  СтрокаВыгрузки – СтрокаТаблицыЗначений – описание элемента выгрузки (имя атрибута, тип значения и др.).  
//  СлужебныеРеквизитыФормы – ТаблицаЗначений – реквизиты, полученные из функции ЗаполнитьСлужебныеРеквизитыФормыСтандартные().
//
// Возвращаемое значение:
//  Булево – Истина, если значение служебного реквизита найдено и записано;  
//            Ложь, если соответствующий реквизит не найден.
Функция ЗаполнитьСлужебныйРеквизитФормыJSON(СтруктураПараметровОтчетность1С, Запись, СтрокаВыгрузки, СлужебныеРеквизитыФормы) Экспорт	
	СтрокаСлужебногоРеквизита = СлужебныеРеквизитыФормы.Найти(СтрокаВыгрузки.ИмяАтрибута, "ИмяАтрибута");
	Если СтрокаСлужебногоРеквизита = Неопределено Тогда
		Возврат Ложь;
	Иначе
		Если ЗначениеЗаполнено(СтрокаВыгрузки.ИмяЯчейки) Тогда
			Возврат Ложь;		
		КонецЕсли;

		ЗаписатьЗначениеЭлементаJSON(СтруктураПараметровОтчетность1С, Запись, СтрокаВыгрузки,,,,Запись,СтрокаСлужебногоРеквизита.Значение);
		Возврат Истина;	
	КонецЕсли;	
КонецФункции 

// Выгружает многострочные формы в формат JSON.  
// Определяет тип формы (одностраничная или многостраничная), подготавливает структуру данных и  
// выполняет запись значений по каждой строке формы в итоговую JSON-структуру.
//
// Параметры:
//  СтруктураПараметровОтчетность1С – Структура – параметры отчета, полученные из функции СформироватьСтруктуруПараметров().  
//  Запись – Структура – структура, в которую добавляются данные для формирования итогового JSON.   
//  ТаблицаВыгрузки – ТаблицаЗначений – таблица описаний строк формы для выгрузки.  
//  КоличествоСтрокВТаблице – Число – общее количество строк в таблице выгрузки.  
//  НомерСтроки – Число – номер текущей строки формы, обрабатываемой при выгрузке.
Процедура ВыгрузитьМногострочнуюФормуJSON(СтруктураПараметровОтчетность1С, Запись, ТаблицаВыгрузки, КоличествоСтрокВТаблице, НомерСтроки)
	
	Перем СтруктураГруппы;
	
	СтрокаВыгрузки = ТаблицаВыгрузки.Получить(НомерСтроки);	
	
	Если СтрокаВыгрузки.КоличествоНаЛисте = 1 Тогда  // форма многостраничная
		
		// для многострочной = одностраничной
		
		НачальнаяСтрока = НомерСтроки - 1;
		КонечнаяСтрока = 0;
		
		ТекущаяФорма = СтрокаВыгрузки.Форма;
		СледСтрокаВыгрузки = ТаблицаВыгрузки.Получить(НомерСтроки);
		НоваяФорма = СледСтрокаВыгрузки.Форма;
		Пока НоваяФорма = ТекущаяФорма Цикл
			НомерСтроки = НомерСтроки+1;
			
			ТекущаяФорма = СледСтрокаВыгрузки.Форма;
			Если НомерСтроки+1 < КоличествоСтрокВТаблице Тогда
				СледСтрокаВыгрузки = ТаблицаВыгрузки.Получить(НомерСтроки+1);						
				НоваяФорма = СледСтрокаВыгрузки.Форма;
				КонечнаяСтрока = НомерСтроки;
			Иначе
				НоваяФорма = Неопределено;
				КонечнаяСтрока = НомерСтроки;
			КонецЕсли;
		КонецЦикла;    		
		
		МногСтруктура = СтруктураПараметровОтчетность1С.СписокМногострочныхСтруктур.Получить(СтрокаВыгрузки.КодФормы);	
		
		КоличествоЗаписей = 0;
		
		Для Каждого КлючИЗначение Из МногСтруктура Цикл
			ТаблицаСтрокГруппы = КлючИЗначение.Значение.Строки;
			КоличествоЗаписей =  ТаблицаСтрокГруппы.Количество();
			Прервать;
		КонецЦикла;
		
		ВсегоСтр = 0;
		
		Если КоличествоЗаписей <= 1 Тогда 
			ВсегоСтр = 0;
		Иначе 
			ВсегоСтр = КоличествоЗаписей - 1;	
		КонецЕсли;
				
		ОдинШаг = Истина;		
		
		МассивВладельцев = СтрРазделить(СтрокаВыгрузки.ВладелецJSON, ".", Истина);
		ТекущийВладелец = Запись;
		УровеньВладельца = 1;
		Пока УровеньВладельца <= МассивВладельцев.Количество() Цикл
			ИмяВладельца = СокрЛП(МассивВладельцев.Получить(УровеньВладельца - 1));
			Если ТипЗнч(ТекущийВладелец) = Тип("Структура") Тогда
				
				Если ТекущийВладелец.Свойство(ИмяВладельца) Тогда
					ТекущийВладелец = ТекущийВладелец[ИмяВладельца];
				КонецЕсли; 
				
				Если НЕ Найти(ИмяВладельца, "application_") > 0 Тогда
					
					УровеньВладельца = УровеньВладельца + 1;
					Продолжить;
					
				КонецЕсли;
				
				Для ШагФорм = 0 По ВсегоСтр Цикл  
					
					ЭкземплярJSON = Новый Структура; 
					УровеньВЭкземпляре = УровеньВладельца;
																			
					Для Шаг = НачальнаяСтрока По КонечнаяСтрока Цикл 
														
						Если Шаг = КонечнаяСтрока Тогда
							Прервать;
						КонецЕсли;
						
						СтрокаВыгрузкиТек = ТаблицаВыгрузки.Получить(Шаг);
						ТекущаяФорма 	  = СтрокаВыгрузкиТек.Форма; 
														
						СтрокаВыгрузкиСлед = ТаблицаВыгрузки.Получить(Шаг + 1);
						
						НоваяФорма 		   = СтрокаВыгрузкиСлед.Форма;
						
						Если ОдинШаг Тогда 
							НомерЛиста = Новый Структура;
							НомерЛиста.Вставить("НомерЛиста",ШагФорм);
							
							ТекущийВладелецВЭкземпляре = ПолучитьТекущийВладелец(ЭкземплярJSON, СтрокаВыгрузкиСлед, ТаблицаВыгрузки, УровеньВладельца + 1);
							
							ЗаписатьЗначениеЭлементаJSON(СтруктураПараметровОтчетность1С, Запись, СтрокаВыгрузкиСлед, МногСтруктура, НомерЛиста,,ТекущийВладелецВЭкземпляре);
							ОдинШаг = Ложь;
							Продолжить;
						КонецЕсли;
														
						НомерЛиста = Новый Структура;
						НомерЛиста.Вставить("НомерЛиста",ШагФорм);  
						
						ТекущийВладелецВЭкземпляре = ПолучитьТекущийВладелец(ЭкземплярJSON, СтрокаВыгрузкиСлед, ТаблицаВыгрузки, УровеньВладельца + 1);

						ЗаписатьЗначениеЭлементаJSON(СтруктураПараметровОтчетность1С, Запись, СтрокаВыгрузкиСлед, МногСтруктура, НомерЛиста,,ТекущийВладелецВЭкземпляре); 
						
						СтрокаВыгрузкиСлед = ТаблицаВыгрузки.Получить(Шаг + 1);  								
					
					КонецЦикла;
						
					ТекущийВладелец.Добавить(ЭкземплярJSON);
					
				КонецЦикла;

			КонецЕсли;
			УровеньВладельца = УровеньВладельца + 1;
		КонецЦикла;	
		
	Иначе // форма многострочная
		
		// Определяем одинаковое ли количество строк на всех страницах формы и создаем таблицу значений
		// например, в форме 300.07 и 300.08 одинаковое количество
		// а в других может быть неодинаковое - и там другой механизм выгрузки по строкам
		
		ТаблицаМногострочнойФормы = ТаблицаВыгрузки.СкопироватьКолонки();
		НоваяСтрока = ТаблицаМногострочнойФормы.Добавить();			
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаВыгрузки);
		
		ТекущаяФорма = СтрокаВыгрузки.Форма;
		СледСтрокаВыгрузки = ТаблицаВыгрузки.Получить(НомерСтроки+1);
		НоваяФорма = СледСтрокаВыгрузки.Форма;
		Пока НоваяФорма = ТекущаяФорма Цикл
			НомерСтроки = НомерСтроки+1;
			НоваяСтрока = ТаблицаМногострочнойФормы.Добавить();			
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СледСтрокаВыгрузки);
			ТекущаяФорма = СледСтрокаВыгрузки.Форма;
			Если НомерСтроки+1 < КоличествоСтрокВТаблице Тогда
				СледСтрокаВыгрузки = ТаблицаВыгрузки.Получить(НомерСтроки+1);						
				НоваяФорма = СледСтрокаВыгрузки.Форма;
			Иначе
				НоваяФорма = Неопределено;
			КонецЕсли;
		КонецЦикла;
		
		//Выгружаем многострочные данные, у которых одинаковое количество строк
		МногСтруктура = СтруктураПараметровОтчетность1С.СписокМногострочныхСтруктур.Получить(СтрокаВыгрузки.КодФормы);	
						
		Если ТипЗнч(МногСтруктура) = Тип("Структура") Тогда
			ВыгрузитьМногострочныеДанныеJSON(СтруктураПараметровОтчетность1С, МногСтруктура, СтрокаВыгрузки, Запись, ТаблицаМногострочнойФормы);
		ИначеЕсли ТипЗнч(МногСтруктура) = Тип("Массив") Тогда // 200.06, 910.02
			Для Каждого ЭлементМногСтруктуры Из МногСтруктура Цикл
				ВыгрузитьМногострочныеДанныеJSON(СтруктураПараметровОтчетность1С, ЭлементМногСтруктуры, СтрокаВыгрузки, Запись, ТаблицаМногострочнойФормы);
			КонецЦикла;
		КонецЕсли;				
						
	КонецЕсли;	
	
КонецПроцедуры // ВыгрузитьМногострочнуюФормуJSON()

// Выполняет выгрузку данных многострочных приложений формы в формат JSON.  
// Обрабатывает строки таблицы формы, формирует JSON-структуры для каждой записи и  
// добавляет их в соответствующие разделы итоговой структуры отчета.
//
// Параметры:
//  СтруктураПараметровОтчетность1С – Структура – параметры отчета, полученные из функции СформироватьСтруктуруПараметров().  
//  МногСтруктура – Структура или Массив – структура данных формы для выгрузки многострочных элементов.  
//  СтрокаВыгрузки – Структура – описание текущей строки формы (атрибут, тип значения, владелец и т.д.).  
//  Запись – Структура – структура, в которую добавляются данные для формирования итогового JSON.  
//  ТаблицаМногострочнойФормы – ТаблицаЗначений – содержит строки текущей многострочной формы для обработки.
Процедура ВыгрузитьМногострочныеДанныеJSON(СтруктураПараметровОтчетность1С, МногСтруктура, СтрокаВыгрузки, Запись, ТаблицаМногострочнойФормы)
	
	КоличествоЗаписей = 0;
	Для Каждого КлючИЗначение Из МногСтруктура Цикл
		ТаблицаСтрокГруппы = КлючИЗначение.Значение.Строки;
		КоличествоЗаписей =  ТаблицаСтрокГруппы.Количество();
		Прервать;
	КонецЦикла;
	
	//Для выгрузки пустых значений в JSON, если нет строк в приложении
	ДобавленаПустаяСтруктура = Ложь;

	МассивВладельцев = СтрРазделить(СтрокаВыгрузки.ВладелецJSON, ".", Истина);
	ВладелецПриложение = Запись;
	УровеньВладельца = 1;
	Пока УровеньВладельца <= МассивВладельцев.Количество() Цикл
		ИмяВладельца = СокрЛП(МассивВладельцев.Получить(УровеньВладельца - 1));
		Если ТипЗнч(ВладелецПриложение) = Тип("Структура") Тогда
			Если ВладелецПриложение.Свойство(ИмяВладельца) Тогда
				ВладелецПриложение = ВладелецПриложение[ИмяВладельца];
			Иначе
				ВладелецПриложение.Вставить(ИмяВладельца);
				МассивСтрок = ТаблицаМногострочнойФормы.НайтиСтроки(Новый Структура("ИмяАтрибута, ВладелецJSON", ИмяВладельца, СтрЗаменить(СтрокаВыгрузки.ВладелецJSON, "." + ИмяВладельца, "")));
				Если МассивСтрок.Количество() = 0 Тогда
					ВладелецПриложение[ИмяВладельца] = Новый Структура;
				Иначе
					ВладелецПриложение[ИмяВладельца] = Вычислить("Новый " + МассивСтрок[0].ТипСвойстваJSON);
				КонецЕсли;
				ВладелецПриложение = ВладелецПриложение[ИмяВладельца];
			КонецЕсли; 
			
			Если НЕ Найти(ИмяВладельца, "application_") > 0 Тогда
				
				УровеньВладельца = УровеньВладельца + 1;
				Продолжить;
				
			КонецЕсли;
			
			// многосторочные приложения могут быть нескольких видов (первые два почти одинаковы):
			// [{данные строки}, {данные строки}, ...] (200.02, 200.04, 200.05)
			// [{данные строки (приложения)}, {данные строки (приложения)}, ...] (200.03)
			// [{данные строки (приложения), {данные строки...}}, {данные строки (приложения), {данные строки...}}] (200.06)
			УровеньВЭкземпляре = УровеньВладельца;		
			ТекущийВладелец = ВладелецПриложение;
			ПутьПриложения = СтрокаВыгрузки.ВладелецJSON;
			НомерТаблицы = 0;
																
			Для Ном = 0 По ТаблицаМногострочнойФормы.Количество()-1 Цикл 						
																		
				СтрокаТаблицы = ТаблицаМногострочнойФормы[Ном];
											
				Если ЗначениеЗаполнено(СтрокаТаблицы.КоличествоROW) И СтрокаТаблицы.КоличествоROW <> "0" Тогда
					
					// если данных формы нет, то передаем пустую структуру
					Если НЕ КоличествоЗаписей = 0 Тогда
						НомерСтрокиВТаблице = 0;
						Для Н = 0 По КоличествоЗаписей Цикл											
							
							ЭкземплярJSON = Новый Структура; 
																																																
							Если Н = 0 Тогда
								ТаблицаМногострочныхТегов = ТаблицаМногострочнойФормы.СкопироватьКолонки();
								НоваяСтрока = ТаблицаМногострочныхТегов.Добавить();			
								ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
								
								// Проверим многострочная ли следующая строка
								СледСтрокаВыгрузки = ТаблицаМногострочнойФормы.Получить(Ном+1);
								Пока ЗначениеЗаполнено(СледСтрокаВыгрузки.КоличествоROW) И СледСтрокаВыгрузки.КоличествоROW <> "0" Цикл
									Ном = Ном+1;
									НоваяСтрока = ТаблицаМногострочныхТегов.Добавить();			
									ЗаполнитьЗначенияСвойств(НоваяСтрока, СледСтрокаВыгрузки);
									Если Ном + 1 = ТаблицаМногострочнойФормы.Количество() Тогда
										Прервать;
									КонецЕсли;
									СледСтрокаВыгрузки = ТаблицаМногострочнойФормы.Получить(Ном+1);
								КонецЦикла;   				
							КонецЕсли;  
							
							// Для выгрузки многострочного приложения 700_02 не нужна первая итоговая строка (строки 1-4 выгружены отдельно)
							Если СтрНайти(СтрокаТаблицы.КодФормы, "Форма700_02") > 0 И Н = 0 Тогда 
								НомерСтрокиВТаблице = 4;
								Продолжить;	
							КонецЕсли;
							
							Для Каждого МногСтрока Из ТаблицаМногострочныхТегов Цикл
								
								СтруктураПараметров = Новый Структура;
								СтруктураПараметров.Вставить("НомерЗаписи", Н);

								ТекущийВладелецВЭкземпляре = ЭкземплярJSON;
								
								МассивВладельцевСтрокиВЭкземпляре = СтрРазделить(МногСтрока.ВладелецJSON, ".", Истина);
								Если УровеньВЭкземпляре < МассивВладельцевСтрокиВЭкземпляре.Количество() Тогда
									ТекущийВладелецВЭкземпляре = ПолучитьТекущийВладелец(ЭкземплярJSON, МногСтрока, ТаблицаМногострочнойФормы, УровеньВЭкземпляре + 1)
								КонецЕсли; 
									
							   	ЗаписатьЗначениеЭлементаJSON(СтруктураПараметровОтчетность1С, Запись, МногСтрока, МногСтруктура, СтруктураПараметров,,ТекущийВладелецВЭкземпляре);
								
							КонецЦикла;
							
							ЭкземплярJSON.Вставить("index", НомерСтрокиВТаблице); 
							НомерСтрокиВТаблице = НомерСтрокиВТаблице + 1;
								
							Если ТипЗнч(ТекущийВладелец) = Тип("Структура") Тогда
								// 200.06 - структура, table - массив строк
								МассивТекущихВладельцев = СтрРазделить(СтрокаТаблицы.ВладелецJSON, ".");
								ТекущийВладелец = ВладелецПриложение[МассивТекущихВладельцев[МассивТекущихВладельцев.Количество()-1]];
							КонецЕсли;
							
							СтрокаВладельца = СтрЗаменить(СтрокаТаблицы.ВладелецJSON, ПутьПриложения, "");
							Если ЗначениеЗаполнено(СтрокаВладельца) Тогда
								// 200.06, 700.02
								СтрокаДанных = Новый Структура("ВладелецJSON", Сред(СтрокаВладельца, 2, СтрДлина(СтрокаВладельца)));
								
								// владельцем является само приложение, но приложение может быть как структурой 701.01 , так и массивом 200.05
								Если ТипЗнч(ВладелецПриложение) = Тип("Структура") Тогда        
									// 200.06 - приложение-структура => обращаемся напрямую к элементу
									ТекущийВладелец = ВладелецПриложение[СтрокаДанных.ВладелецJSON];	
								Иначе
									// 700.02 - приложение-массив => ищем элемент внутри массива
									ТекущийВладелец = ПолучитьТекущийВладелец(ВладелецПриложение[ВладелецПриложение.Количество() - 1], СтрокаДанных, ТаблицаМногострочнойФормы);	
								КонецЕсли;
								
							Иначе
								Если ТипЗнч(ВладелецПриложение) = Тип("Структура") Тогда                                
									ТекущийВладелец = ВладелецПриложение;	
								Иначе
									// 200.02, 200.05 - приложения-массивы
									ТекущийВладелец = ВладелецПриложение;	
								КонецЕсли;
							КонецЕсли;
							
							ТекущийВладелец.Добавить(ЭкземплярJSON);
																				
						КонецЦикла;
					КонецЕсли;

				Иначе			
					СтрокаВладельца = СтрЗаменить(СтрокаТаблицы.ВладелецJSON, ПутьПриложения, "");
					Если ЗначениеЗаполнено(СтрокаВладельца) Тогда
						// элементы параметры-владельцев
						СтрокаДанных = Новый Структура("ВладелецJSON", Сред(СтрокаВладельца, 2, СтрДлина(СтрокаВладельца)));
						
						Если ТипЗнч(ВладелецПриложение) = Тип("Структура") Тогда
							// 200.06 - приложение-структура => обращаемся напрямую к элементу
							ТекущийВладелецВЭкземпляре = ВладелецПриложение[СтрокаДанных.ВладелецJSON];	
						Иначе
							// 700.02 - приложение-массив => ищем элемент внутри массива
							ТекущийВладелецВЭкземпляре = ПолучитьТекущийВладелец(ВладелецПриложение[ВладелецПриложение.Количество() - 1], СтрокаДанных, ТаблицаМногострочнойФормы);	
						КонецЕсли;
						
					Иначе
						// параметры-владельцы (commonInfo, rows, table)
						Если ТипЗнч(ВладелецПриложение) = Тип("Структура") Тогда                                
							// 200.06 - приложение-структура
							ТекущийВладелецВЭкземпляре = ВладелецПриложение;
							УровеньВЭкземпляре = УровеньВладельца + 1;
						Иначе
							
							ТекущийВладелецВЭкземпляре = ВладелецПриложение;
							Если ВладелецПриложение.Количество() > 0 Тогда
							    ЭкземплярВладельцаJSON = ВладелецПриложение[ВладелецПриложение.Количество()-1];
							    Если НЕ ЭкземплярВладельцаJSON.Свойство(СтрокаТаблицы.ИмяАтрибута) Тогда
							        ТекущийВладелецВЭкземпляре = ЭкземплярВладельцаJSON;    
							    КонецЕсли;
							КонецЕсли;
							
							// 700.02 - приложение-массив => ищем элемент внутри массива
							Если ТипЗнч(ТекущийВладелецВЭкземпляре) = Тип("Структура") Тогда
								УровеньВЭкземпляре = УровеньВладельца + 1;
							// 701.00 001 - приложение-массив без отдельной структуры строк => нужно добавить внутрь структуру	
							Иначе
								ВладелецПриложение.Добавить(Новый Структура);
								ТекущийВладелецВЭкземпляре = ?(ВладелецПриложение.Количество() = 0, ВладелецПриложение, ВладелецПриложение[ВладелецПриложение.Количество()-1]);
																
								УровеньВЭкземпляре = УровеньВладельца + 1;
							КонецЕсли;	
						КонецЕсли;
					КонецЕсли;
					
					СтруктураПараметров = Новый Структура;
					ЗаписатьЗначениеЭлементаJSON(СтруктураПараметровОтчетность1С, Запись, СтрокаТаблицы, МногСтруктура, СтруктураПараметров,,ТекущийВладелецВЭкземпляре); 
					
				КонецЕсли;				 
				СтрокаТаблицы = ТаблицаМногострочнойФормы[Ном];				
			КонецЦикла; 
		КонецЕсли;
		УровеньВладельца = УровеньВладельца + 1;
	КонецЦикла;	

КонецПроцедуры  

// Возвращает объект-владелец для текущего элемента JSON, исходя из структуры вложенности.  
// Определяет и при необходимости создаёт вложенные уровни (структуры или массивы) в соответствии с путём владельца.  
// Используется при формировании иерархических JSON-структур отчёта.
//
// Параметры:  
//  Запись – Структура – текущая JSON-запись, в которой ищется или создаётся владелец.  
//  СтрокаВыгрузки – Структура – описание строки формы с указанием пути владельца (ВладелецJSON).  
//  ТаблицаВыгрузки – ТаблицаЗначений – содержит все строки описания выгрузки для поиска типа вложенного элемента.  
//  УровеньВладельца – Число (Необязательный) – уровень вложенности, с которого начать поиск владельца.  
//
// Возвращает:  
//  Структура или Массив – объект-владелец для текущего элемента JSON.
Функция ПолучитьТекущийВладелец(Запись, СтрокаВыгрузки, ТаблицаВыгрузки, Знач УровеньВладельца = Неопределено) Экспорт
	
	МассивВладельцев = СтрРазделить(СтрокаВыгрузки.ВладелецJSON, ".", Истина);
	ТекущийВладелец = Запись;
	Если УровеньВладельца = Неопределено Тогда
		УровеньВладельца = 1;
	КонецЕсли;
	
	Пока УровеньВладельца <= МассивВладельцев.Количество() Цикл
		ИмяВладельца = СокрЛП(МассивВладельцев.Получить(УровеньВладельца - 1));
		
		Если ТипЗнч(ТекущийВладелец) = Тип("Структура") Тогда
			Если ИмяВладельца = "" Тогда
				// у первого уровня нет владельцев
				УровеньВладельца = УровеньВладельца + 1;
				Продолжить;
			ИначеЕсли ТекущийВладелец.Свойство(ИмяВладельца) Тогда
				ТекущийВладелец = ТекущийВладелец[ИмяВладельца];
			Иначе
				ТекущийВладелец.Вставить(ИмяВладельца);
				МассивСтрок = ТаблицаВыгрузки.НайтиСтроки(Новый Структура("ИмяАтрибута, ВладелецJSON", ИмяВладельца, СтрЗаменить(СтрокаВыгрузки.ВладелецJSON, "." + ИмяВладельца, "")));
				Если МассивСтрок.Количество() = 0 Тогда
					ТекущийВладелец[ИмяВладельца] = Новый Структура;
				Иначе
					ТекущийВладелец[ИмяВладельца] = Вычислить("Новый " + МассивСтрок[0].ТипСвойстваJSON);
				КонецЕсли;
				ТекущийВладелец = ТекущийВладелец[ИмяВладельца];
			КонецЕсли;	
		ИначеЕсли ТипЗнч(ТекущийВладелец) = Тип("Массив") И ТекущийВладелец.Количество() > 0 Тогда
			// Форма 220.00.045 A - СтруктураЗначение_Структура внутри Массива
			Если ТекущийВладелец[0].Свойство(ИмяВладельца) Тогда 
				ТекущийВладелец = ТекущийВладелец[0][ИмяВладельца];
			КонецЕсли;	
		КонецЕсли;
		УровеньВладельца = УровеньВладельца + 1;
	КонецЦикла; 
	
	Возврат ТекущийВладелец;
	
КонецФункции

// Добавляет значение атрибута в структуру внутри массива JSON-экземпляров.  
// Если у последнего элемента массива отсутствует нужный атрибут — вставляет его.  
// Если атрибут уже существует — создаёт новый экземпляр структуры и добавляет в массив.
//
// Параметры:  
//  ТекущийВладелецЭкземплярJSON – Массив – коллекция структур JSON для заполнения.  
//  СтрокаВыгрузки – СтрокаТаблицыЗначений – описание текущего атрибута (ИмяАтрибута, тип и т.п.).  
//  Значение – Произвольный – значение, которое требуется записать в JSON.
Процедура ЗаполнитьСтруктуруЗначений(ТекущийВладелецЭкземплярJSON, СтрокаВыгрузки, Значение) Экспорт
	
	КоличествоЭкземпляровВладельца = ТекущийВладелецЭкземплярJSON.Количество(); 

	Если КоличествоЭкземпляровВладельца > 0 Тогда								
		Если НЕ ТекущийВладелецЭкземплярJSON[КоличествоЭкземпляровВладельца-1].Свойство(СтрокаВыгрузки.ИмяАтрибута) Тогда 				
			ТекущийВладелецЭкземплярJSON[КоличествоЭкземпляровВладельца-1].Вставить(СтрокаВыгрузки.ИмяАтрибута, Значение);
		Иначе
			Если ЗначениеЗаполнено(Значение) И НЕ СтрокаВыгрузки.ИмяАтрибута = "index" Тогда
				СтруктураДанных = Новый Структура(СтрокаВыгрузки.ИмяАтрибута, Значение);
				ТекущийВладелецЭкземплярJSON.Добавить(СтруктураДанных);
			КонецЕсли;	
		КонецЕсли;
	Иначе
		Если ЗначениеЗаполнено(Значение) И НЕ СтрокаВыгрузки.ИмяАтрибута = "index" Тогда
			СтруктураДанных = Новый Структура(СтрокаВыгрузки.ИмяАтрибута, Значение);
			ТекущийВладелецЭкземплярJSON.Добавить(СтруктураДанных);
		КонецЕсли;	
	КонецЕсли;	
	
КонецПроцедуры

// Формирует и выгружает экземпляр приложения (application_X) в JSON-структуру.
// Используется для записи данных одной формы приложения, включая вложенные уровни.
//
// Логика работы:
// 1. Создаёт пустую структуру "ЭкземплярJSON" для одного экземпляра приложения.
// 2. Определяет уровень владельца (application_X) по пути "ВладелецJSON".
// 3. При необходимости корректирует имена и значения ячеек для связанных приложений ("ДопПриложение").
// 4. Последовательно проходит все строки, относящиеся к текущей форме, 
//    и записывает значения через "ЗаписатьЗначениеЭлементаJSON".
// 5. После заполнения добавляет готовый экземпляр структуры в массив владельца ("ТекущийВладелец").
//
// Параметры:
//  СтруктураПараметровОтчетность1С – Структура – параметры отчета, полученные из функции СформироватьСтруктуруПараметров().
//  Запись – Структура – структура, в которую добавляются данные для формирования итогового JSON. 
//  ТаблицаВыгрузки – ТаблицаЗначений - таблица с описанием всех полей для выгрузки.
//  СтрокаВыгрузки – СтрокаТаблицыЗначений - текущая строка таблицы, соответствующая началу формы приложения.
//  НомерСтроки – Число - позиция текущей строки в таблице выгрузки.
//  КоличествоСтрокВТаблице – Число - общее количество строк в таблице выгрузки.
//  ТекущийВладелец – Массив или Структура - реквизит, в который добавляется готовый экземпляр JSON.
//  ДопПриложение – (Необязательный) Структура - структура с данными другого приложения, 
//                  если выгрузка происходит по связанным формам.
//
Процедура ВыгрузитьЭкземплярПриложенияВJSON(СтруктураПараметровОтчетность1С, Запись, ТаблицаВыгрузки, СтрокаВыгрузки, НомерСтроки, КоличествоСтрокВТаблице, ТекущийВладелец, ДопПриложение=Неопределено)
		
	ЭкземплярJSON = Новый Структура; 		
	
	ТекущаяФорма = СтрокаВыгрузки.Форма;
	
	МассивВладельцев = СтрРазделить(СтрокаВыгрузки.ВладелецJSON, ".", Истина);
	УровеньВладельца = 1;
	Пока УровеньВладельца <= МассивВладельцев.Количество() Цикл
		ИмяВладельца = СокрЛП(МассивВладельцев.Получить(УровеньВладельца - 1));
		
		Если НЕ Найти(ИмяВладельца, "application_") > 0 Тогда		
			УровеньВладельца = УровеньВладельца + 1;
		Иначе
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	СледСтрокаВыгрузки = ТаблицаВыгрузки.Получить(НомерСтроки+1);  
	
	Если ДопПриложение <> Неопределено Тогда
		СписокФормБезИерархии = СтруктураПараметровОтчетность1С.мСписокФормБезИерархии;
		СтрокаФормы = СписокФормБезИерархии.Строки.Найти(ДопПриложение.КодФормы,"КодФормы");
		
		Если Найти(СледСтрокаВыгрузки.ИмяЯчейки, СтрЗаменить(СледСтрокаВыгрузки.КодФормы,"Форма", "")) > 0 Тогда 
			ИмяЯчейки = СтрЗаменить(СледСтрокаВыгрузки.ИмяЯчейки, СтрЗаменить(СледСтрокаВыгрузки.КодФормы,"Форма", ""), СтрЗаменить(ДопПриложение.КодФормы,"Форма", ""));
			СледСтрокаВыгрузки.ИмяЯчейки = ИмяЯчейки; 
		КонецЕсли;
		
		СледСтрокаВыгрузки.Значение = СтрокаФормы.Значение;		
	КонецЕсли; 
		
	НоваяФорма = СледСтрокаВыгрузки.Форма;
	
	Пока НоваяФорма = ТекущаяФорма Цикл
		НомерСтроки = НомерСтроки+1;	 
		
		ТекущийВладелецВЭкземпляре = ЭкземплярJSON; 
		
		МассивВладельцевСтрокиВЭкземпляре = СтрРазделить(СледСтрокаВыгрузки.ВладелецJSON, ".", Истина);
		Если УровеньВладельца < МассивВладельцевСтрокиВЭкземпляре.Количество() Тогда
			ТекущийВладелецВЭкземпляре = ПолучитьТекущийВладелец(ЭкземплярJSON, СледСтрокаВыгрузки, ТаблицаВыгрузки, УровеньВладельца + 1)
		КонецЕсли; 
		
		ЗаписатьЗначениеЭлементаJSON(СтруктураПараметровОтчетность1С, Запись, СледСтрокаВыгрузки,,,,ТекущийВладелецВЭкземпляре);
		ТекущаяФорма = СледСтрокаВыгрузки.Форма;   
		
		Если НомерСтроки+1 < КоличествоСтрокВТаблице Тогда
			СледСтрокаВыгрузки = ТаблицаВыгрузки.Получить(НомерСтроки+1);  
			
			Если ДопПриложение <> Неопределено Тогда
				Если Найти(СледСтрокаВыгрузки.ИмяЯчейки, СтрЗаменить(СледСтрокаВыгрузки.КодФормы,"Форма", "")) > 0 Тогда 
					ИмяЯчейки = СтрЗаменить(СледСтрокаВыгрузки.ИмяЯчейки, СтрЗаменить(СледСтрокаВыгрузки.КодФормы,"Форма", ""), СтрЗаменить(ДопПриложение.КодФормы,"Форма", ""));
					СледСтрокаВыгрузки.ИмяЯчейки = ИмяЯчейки; 
				КонецЕсли;
				
				СледСтрокаВыгрузки.Значение = СтрокаФормы.Значение;  
			КонецЕсли;
			
			НоваяФорма = СледСтрокаВыгрузки.Форма;  					
		Иначе
			НоваяФорма = Неопределено;
		КонецЕсли;
		
	КонецЦикла;
	
	ТекущийВладелец.Добавить(ЭкземплярJSON); 	
	
КонецПроцедуры

// Формирует таблицу стандартных служебных реквизитов JSON, общих для всех форм отчётности.
//
// Параметры:
//  СлужебныеРеквизитыДополнительныеПараметры – структура, содержащая информацию о налогоплательщике и пользователе:
//      * Налогоплательщик – объект с реквизитами (НаименованиеПолное, ЮрФизЛицо);
//      * ИдентификаторПользователя – уникальный код отправителя.
//  СлужебныеРеквизитыФормы – (необязательный) структура дополнительных реквизитов формы, 
//      которые также добавляются в JSON. Служебные данные формы (см. функцию  
//         ЗаполнитьСлужебныеРеквизитыФормыОтчетность1С() в форме отчета)
//
// Возвращаемое значение:
//  ТаблицаЗначений, где каждая строка содержит:
//      * ИмяАтрибута — название JSON-поля;
//      * Значение — его значение.
//
Функция ЗаполнитьСлужебныеРеквизитыФормыСтандартные(СлужебныеРеквизитыДополнительныеПараметры, СлужебныеРеквизитыФормы) Экспорт
	
	СлужебныеРеквизитыФормыСтандартные = Новый ТаблицаЗначений;
	СлужебныеРеквизитыФормыСтандартные.Колонки.Добавить("ИмяАтрибута");
	СлужебныеРеквизитыФормыСтандартные.Колонки.Добавить("Значение");
	
	Налогоплательщик = СлужебныеРеквизитыДополнительныеПараметры.Налогоплательщик;
	ОтправительКод = СлужебныеРеквизитыДополнительныеПараметры.ИдентификаторПользователя;
	ОтправительНаименование = ?(ЗначениеЗаполнено(Налогоплательщик.НаименованиеПолное),
								Налогоплательщик.НаименованиеПолное,
								Налогоплательщик.Наименование);
	ТипНалогоплательщика = Отчетность1ССерверПереопределяемый.ТипНалогоплательщика(Налогоплательщик);
		
	НоваяСтрока = СлужебныеРеквизитыФормыСтандартные.Добавить();
	НоваяСтрока.ИмяАтрибута = "taxpayerType";
	НоваяСтрока.Значение = ТипНалогоплательщика;
	
	НоваяСтрока = СлужебныеРеквизитыФормыСтандартные.Добавить();
	НоваяСтрока.ИмяАтрибута = "creatorType";
	НоваяСтрока.Значение = ТипНалогоплательщика;
	
	НоваяСтрока = СлужебныеРеквизитыФормыСтандартные.Добавить();
	НоваяСтрока.ИмяАтрибута = "creatorNameRu";
	НоваяСтрока.Значение = ОтправительНаименование;
	
	НоваяСтрока = СлужебныеРеквизитыФормыСтандартные.Добавить();
	НоваяСтрока.ИмяАтрибута = "creatorNameEn";
	НоваяСтрока.Значение = ОтправительНаименование;
	
	НоваяСтрока = СлужебныеРеквизитыФормыСтандартные.Добавить();
	НоваяСтрока.ИмяАтрибута = "creatorNameKk";
	НоваяСтрока.Значение = ОтправительНаименование;
	
	НоваяСтрока = СлужебныеРеквизитыФормыСтандартные.Добавить();
	НоваяСтрока.ИмяАтрибута = "creatorNameQq";
	НоваяСтрока.Значение = ОтправительНаименование;
	
	НоваяСтрока = СлужебныеРеквизитыФормыСтандартные.Добавить();
	НоваяСтрока.ИмяАтрибута = "creatorCode";
	НоваяСтрока.Значение = ОтправительКод;
	
	Если ЗначениеЗаполнено(СлужебныеРеквизитыФормы) Тогда
		Для Каждого СлужебныйРеквизитыФормы Из СлужебныеРеквизитыФормы Цикл
			НоваяСтрока = СлужебныеРеквизитыФормыСтандартные.Добавить();
			НоваяСтрока.ИмяАтрибута = СлужебныйРеквизитыФормы.Ключ;
			НоваяСтрока.Значение = СлужебныйРеквизитыФормы.Значение;
		КонецЦикла;	
	КонецЕсли;	
	
	Возврат СлужебныеРеквизитыФормыСтандартные;
КонецФункции

// Формирует таблицу выгрузки на основании макета выгрузки и параметров отчётности 1С.
//
// Параметры:
//  МакетВыгрузки – объект типа Макет (ТабличныйДокумент), содержащий структуру выгрузки форм;
//  СтруктураПараметровОтчетность1С – СтруктураПараметровОтчетность1С – Структура – параметры отчета, полученные из функции СформироватьСтруктуруПараметров().
//
// Возвращаемое значение:
//  ТаблицаЗначений:
//   * Форма – Строка, имя формы из макета выгрузки
//   * ИмяАтрибута – Строка, имя JSON-поля
//   * ИмяЯчейки – Строка, идентификатор ячейки формы
//   * КоличествоROW – Число, количество строк формы
//   * ИмяФормы – Строка, отображаемое имя формы
//   * ИмяЛиста – Строка, имя листа формы
//   * ВыгружатьНулевыеЗначения – Булево, указывает, выгружать ли нулевые значения
//   * КодФормы – Строка, уникальный код формы
//   * Выгружать – Булево, признак включения формы в выгрузку
//   * Многострочность – Булево, признак многострочной формы
//   * КоличествоНаЛисте – Число, количество страниц или строк в форме
//   * Значение – Произвольный, значение, связанное с формой
//   * ЗначениеJSON – Строка, значение JSON-представления атрибута
//   * ВладелецJSON – Строка, путь к владельцу в JSON-структуре
//   * ТипСвойстваJSON – Строка, тип JSON-свойства (Структура, Массив и т.п.)
Функция ЗаполнитьТаблицуВыгрузки(МакетВыгрузки, СтруктураПараметровОтчетность1С)

	// создадим таблицу для выгрузки
	ТаблицаВыгрузки = Новый ТаблицаЗначений;
	ТаблицаВыгрузки.Колонки.Добавить("Форма");
	ТаблицаВыгрузки.Колонки.Добавить("Страница");
	ТаблицаВыгрузки.Колонки.Добавить("ИмяАтрибута");
	ТаблицаВыгрузки.Колонки.Добавить("ИмяЯчейки");
	ТаблицаВыгрузки.Колонки.Добавить("КоличествоROW");
	ТаблицаВыгрузки.Колонки.Добавить("ИмяФормы");
	ТаблицаВыгрузки.Колонки.Добавить("ИмяЛиста");
	ТаблицаВыгрузки.Колонки.Добавить("ВыгружатьНулевыеЗначения");
	
	ТаблицаВыгрузки.Колонки.Добавить("КодФормы");
	ТаблицаВыгрузки.Колонки.Добавить("Выгружать");
	ТаблицаВыгрузки.Колонки.Добавить("Многострочность");
	ТаблицаВыгрузки.Колонки.Добавить("КоличествоНаЛисте");
	ТаблицаВыгрузки.Колонки.Добавить("Значение");

	ТаблицаВыгрузки.Колонки.Добавить("ЗначениеJSON");
	ТаблицаВыгрузки.Колонки.Добавить("ВладелецJSON");   
	ТаблицаВыгрузки.Колонки.Добавить("ТипСвойстваJSON");
	
	ОбластьВыгрузки = МакетВыгрузки.Область("Выгрузка" + СтруктураПараметровОтчетность1С.ПрефиксФормы);
	СписокФормБезИерархии = СтруктураПараметровОтчетность1С.мСписокФормБезИерархии;
	ТекущееИмяФормы = Неопределено;
	
	СписокПриложений = СтруктураПараметровОтчетность1С.СписокПриложений;
	ИмяЯчейкиНомерКолонки = Отчетность1ССерверПереопределяемый.ПолучитьНомерКолонки_ИмяЯчейки();
	
	Для Ном = ОбластьВыгрузки.Верх По ОбластьВыгрузки.Низ Цикл
		Строка = ТаблицаВыгрузки.Добавить();
		Строка.Форма 	       			= СокрП(МакетВыгрузки.Область(Ном, 1).Текст);
		Строка.Страница      	 	= СокрП(МакетВыгрузки.Область(Ном, 2).Текст);
		Строка.ВладелецJSON      	 	= СокрП(МакетВыгрузки.Область(Ном, 3).Текст);
		Строка.ИмяАтрибута     			= СокрП(МакетВыгрузки.Область(Ном, 4).Текст);
		
		Строка.ИмяЯчейки  				= СокрП(МакетВыгрузки.Область(Ном, ИмяЯчейкиНомерКолонки).Текст);
		
		Строка.Многострочность   		= ?(СокрП(МакетВыгрузки.Область(Ном, 7).Текст) = "1", Истина, Ложь);
		Строка.КоличествоROW   			= СокрП(МакетВыгрузки.Область(Ном, 7).Текст);
		Строка.ИмяФормы        			= СокрП(МакетВыгрузки.Область(Ном, 8).Текст);
		Строка.ИмяЛиста        			= СокрП(МакетВыгрузки.Область(Ном, 9).Текст);
		Строка.ВыгружатьНулевыеЗначения = ?(СокрП(МакетВыгрузки.Область(Ном, 10).Текст) = "1", Истина, Ложь);
		Строка.ТипСвойстваJSON 			= СокрП(МакетВыгрузки.Область(Ном, 11).Текст);
		Строка.ЗначениеJSON 			= СокрП(МакетВыгрузки.Область(Ном, 12).Текст); 

		НовоеИмяФормы = Строка.ИмяФормы;
		Если НовоеИмяФормы <> ТекущееИмяФормы Тогда
			Форма = СписокФормБезИерархии.Строки.Найти(Строка.ИмяФормы, "КодФормы");
		КонецЕсли;
		
		Если Форма <> Неопределено Тогда
			Строка.КодФормы  		 = Форма.КодФормы;
			
			ФормаВыгружать = СписокПриложений.Получить(Строка.КодФормы);
			Если ФормаВыгружать <> Неопределено Тогда
				Строка.Выгружать  		 = ФормаВыгружать;
			Иначе
				Строка.Выгружать  		 = Форма.Выгружать;
			КонецЕсли;
			Строка.Многострочность   = Форма.Многострочность;
			// Форма.Многострочность - многострочные формы (200.02, 200.05 и тд)
			// Форма.КоличествоНаЛисте - "1" одностраничные формы, формируемые по многострочному типу если приложений может быть неск(200.03)
			// остальные формы выгружаем без учета количества строк на листе
			Строка.КоличествоНаЛисте = ?(Форма.Многострочность И Форма.КоличествоНаЛисте = 1, 1, 100000000);
			
			Строка.Значение  		 = Форма.Значение;
		КонецЕсли;
		
		ТекущееИмяФормы = Строка.ИмяФормы;
	КонецЦикла;	
	
	Возврат ТаблицаВыгрузки;
КонецФункции

#КонецОбласти

#Область ПроверкаФЛК

// ПолучитьСтруктуруФормыКВыгрузке
//
// Формирует структуру данных конкретной формы отчета для последующей выгрузки в JSON.
// Функция обрабатывает как обычные, так и многострочные формы, учитывает синонимы
// реквизитов и проверяет допустимость типов данных.
//
// Параметры:
//   СтруктураПараметровОтчетность1С - структура с параметрами формы, содержащая:
//       * мСписокФормБезИерархии          – список всех форм без иерархии
//       * СписокМногострочныхСтруктур    – набор многострочных структур формы
//       * СоответствиеАльтернативныхЭлементовФормы – синонимы реквизитов и областей
//
//   СтруктураОбъектов - структура, в которую записываются:
//       * ТаблицаДанных<КодФормы>         – таблица данных формы
//       * РазмещениеРеквизитовНаСтраницах<КодФормы>ПолеТабличногоДокумента – структура размещения реквизитов
//       * СтруктураДобавляемыхПриПроверкеДанных – информация о многострочности и количестве строк
//
//   КодФормыОтправляемый - строка, код формы для выгрузки.
Процедура ПолучитьСтруктуруФормыКВыгрузке(СтруктураПараметровОтчетность1С, СтруктураОбъектов, КодФормыОтправляемый)
	КодПроверяемойФормы = "Форма" + КодФормыОтправляемый;
	
	СтрокаФормыВСписке =  СтруктураПараметровОтчетность1С.мСписокФормБезИерархии.Строки.Найти(КодПроверяемойФормы, "КодФормы");
	ЭтоМногострочнаяФорма = СтрокаФормыВСписке.Многострочность;
	
	Если ЭтоМногострочнаяФорма Тогда
		СтруктураДанных = СтруктураПараметровОтчетность1С.СписокМногострочныхСтруктур.Получить(КодПроверяемойФормы);
		Если ТипЗнч(СтруктураДанных) = Тип("Массив") Тогда
			СтруктураДанных = СтруктураДанных[0];
		КонецЕсли;
		
		РазмещениеРеквизитовНаСтраницах = СформироватьСтруктуруСтраницПоказателейМногострочнойФормы(СтруктураДанных, СтруктураПараметровОтчетность1С, КодФормыОтправляемый);
		
		// проверим что в таблице нет ссылочных типов в графах, иначе при их выгрузке в Json возникнет ошибка
		ИсключитьНедопустимыеТипыДанныхВТаблицеВыгрузки_МногострочнаяФорма(СтруктураДанных);
		
		ПреобразоватьСинонимыВФорме(СтруктураДанных, СтруктураПараметровОтчетность1С.СоответствиеАльтернативныхЭлементовФормы, Истина);
		
		Если СтруктураПараметровОтчетность1С.СписокПриложений.Получить(КодПроверяемойФормы) <> Неопределено И 
			НЕ СтруктураПараметровОтчетность1С.СписокПриложений.Получить(КодПроверяемойФормы) Тогда
			
			Для Каждого СтраницаСтруктурыДанных Из СтруктураДанных Цикл
				Страница = СтраницаСтруктурыДанных.Значение;
				Страница.Строки.Очистить();
				Страница.ШапкаИПодвал.Очистить();
			КонецЦикла;	
		КонецЕсли;	
		
		СтруктураОбъектов.Вставить("РазмещениеРеквизитовНаСтраницах"+ КодПроверяемойФормы +"ПолеТабличногоДокумента", РазмещениеРеквизитовНаСтраницах);
		СтруктураОбъектов.Вставить("СтруктураДанных" + КодФормыОтправляемый, СтруктураДанных);
		
		// Дополнительные данные многострочной формы
		СтруктураОбъектов.СтруктураДобавляемыхПриПроверкеДанных.Вставить("ЭтоМногострочнаяФорма" + КодПроверяемойФормы, ЭтоМногострочнаяФорма);
		КоличествоСтрокНаЛистеМногострочнойФормы = СтрокаФормыВСписке.КоличествоНаЛисте;
		СтруктураОбъектов.СтруктураДобавляемыхПриПроверкеДанных.Вставить("КоличествоСтрокНаЛистеМногострочнойФормы" + КодПроверяемойФормы, КоличествоСтрокНаЛистеМногострочнойФормы);
	Иначе
		ТаблицаДанных = СтрокаФормыВСписке.Значение;
		РазмещениеРеквизитовНаСтраницах = СформироватьСтруктуруСтраницПоказателейФормы(ТаблицаДанных, СтруктураПараметровОтчетность1С, КодПроверяемойФормы);
		
		// проверим что в таблице нет ссылочных типов в графах, иначе при их выгрузке в Json возникнет ошибка
		ИсключитьНедопустимыеТипыДанныхВТаблицеВыгрузки_ОбычнаяФорма(ТаблицаДанных);
		
		СтруктураОбъектов.Вставить("РазмещениеРеквизитовНаСтраницах"+ КодПроверяемойФормы +"ПолеТабличногоДокумента", РазмещениеРеквизитовНаСтраницах);
		//Если это основная форма, то ее код выглядит как xxx, а не xxx_xx
		//Исключение - форма 701.01
		КодФормыОтправляемый = ?(СтрДлина(КодФормыОтправляемый) = 3 ИЛИ КодФормыОтправляемый = "70101", КодФормыОтправляемый + "_00", КодФормыОтправляемый);	
		
		// поменять имя областей на их синонимы из макета
		ПреобразоватьСинонимыВФорме(ТаблицаДанных, СтруктураПараметровОтчетность1С.СоответствиеАльтернативныхЭлементовФормы, Истина);	
			
		СтруктураОбъектов.Вставить("ТаблицаДанных" + КодФормыОтправляемый, ТаблицаДанных);
	КонецЕсли;
	
КонецПроцедуры // ПолучитьСтруктуруФормыКВыгрузке() 

// Выполняет проверку всех значений таблицы данных обычной формы на недопустимые типы,
// которые могут вызвать ошибки при выгрузке в JSON. Если значение является ссылочным
// или другим недопустимым типом, оно преобразуется в строковое представление.
//
// Параметры:
//   ТаблицаДанных – ТаблицаЗначений, содержащая строки с реквизитами формы.
Процедура ИсключитьНедопустимыеТипыДанныхВТаблицеВыгрузки_ОбычнаяФорма(ТаблицаДанных)
	Для Каждого Строка Из ТаблицаДанных Цикл
		
		ЗначениеСтроки = Строка.Значение;
		Если ЭтоЗначениеНедопустимогоТипа(ЗначениеСтроки) Тогда
			// преобразуем ссылочный тип в строковое представление
			Строка.Значение = СокрЛП(ЗначениеСтроки);
		КонецЕсли;
		
	КонецЦикла;
КонецПроцедуры

// Выполняет проверку всех значений многострочной формы на недопустимые типы,
// которые могут вызвать ошибки при выгрузке в JSON. Если значение является ссылочным
// или другим недопустимым типом, оно преобразуется в строковое представление.
//
// Параметры:
//   СтруктураДанныхФормыДляОбработки – Структура, содержащая данные многострочной формы,
//       сформированные функцией РегламентированнаяОтчетность.ПолучитьМногострочнуюСтруктуру.
Процедура ИсключитьНедопустимыеТипыДанныхВТаблицеВыгрузки_МногострочнаяФорма(СтруктураДанныхФормыДляОбработки)
	// СтруктураДанныхФормыДляОБработки - Структура, сформированная в РегламентированнаяОтчетность.ПолучитьМногострочнуюСтруктуру
	Для Каждого ЭлементСтруктуры ИЗ СтруктураДанныхФормыДляОбработки Цикл
		
		ДанныеДляОбработки = ЭлементСтруктуры.Значение.Строки;
		
		Если НЕ ТипЗнч(ДанныеДляОбработки) = Тип("ТаблицаЗначений") Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого Строка из ДанныеДляОбработки Цикл
			Для ИндексКолонки = 0 По ДанныеДляОбработки.Колонки.Количество()-1 Цикл
				ЗначениеСтрокиВКолонке = Строка.Получить(ИндексКолонки);
				Если ЭтоЗначениеНедопустимогоТипа(ЗначениеСтрокиВКолонке) Тогда
					// преобразуем ссылочный тип в строковое представление
					Строка[ИндексКолонки] = СокрЛП(ЗначениеСтрокиВКолонке);
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		
	КонецЦикла;
КонецПроцедуры

// Формирует соответствие между показателями (областями) формы и страницами
// макета для последующей выгрузки данных в JSON. Используется для обычных (не многострочных) форм.
//
// Параметры:
//   ТаблицаДанных – ТаблицаЗначений, содержащая строки формы с реквизитами и областями.
//   СтруктураПараметровОтчетность1С – Структура параметров формы, сформированная функцией
//       СформироватьСтруктуруПараметров_Отправка, включает сведения о синонимах, таблице выгрузки и прочее.
//   КодПроверяемойФормы – Строка, код формы, для которой формируется соответствие.
//
// Возвращаемое значение:
//   Соответствие – объект Соответствие, где ключи – имена областей формы,
//       а значения – имена страниц макета, с которыми эти области связаны.
Функция СформироватьСтруктуруСтраницПоказателейФормы(ТаблицаДанных, СтруктураПараметровОтчетность1С, КодПроверяемойФормы)
	СоответствиеПоказателей = Новый Соответствие;
	ТаблицаВыгрузки = СтруктураПараметровОтчетность1С.ТаблицаВыгрузки;
	Для Каждого Элемент из ТаблицаДанных Цикл
		ИмяОбласти = Элемент.ИмяОбласти;
		
		ПараметрыОтбора = Новый Структура("КодФормы, ИмяЯчейки", КодПроверяемойФормы, ИмяОбласти);
		
		НайденнаяСтрока = ТаблицаВыгрузки.НайтиСтроки(ПараметрыОтбора);
		
		// Соответствия синонимов для реквизита
		ИмяОбласти = ?(СтруктураПараметровОтчетность1С.СоответствиеАльтернативныхЭлементовФормы.Получить(ИмяОбласти)<>Неопределено,
					   СтруктураПараметровОтчетность1С.СоответствиеАльтернативныхЭлементовФормы.Получить(ИмяОбласти),
					   ИмяОбласти);		 
		
		Если НайденнаяСтрока.Количество() > 0 Тогда
			Значение = СтруктураПараметровОтчетность1С.СинонимыЭлементовJSON.Получить(НайденнаяСтрока[0].Страница);
			СоответствиеПоказателей.Вставить(ИмяОбласти, Значение);
		Иначе
			СоответствиеПоказателей.Вставить(ИмяОбласти, "");
		КонецЕсли;
	КонецЦикла;	
	
	Возврат СоответствиеПоказателей;
КонецФункции

// Формирует структуру соответствия между колонками многострочной формы и страницами макета,
// необходимую для последующей выгрузки данных в JSON. Используется для многострочных форм.
//
// Параметры:
//   СтруктураДанных – Структура, содержащая данные многострочной формы, полученные
//       из функции РегламентированнаяОтчетность.ПолучитьМногострочнуюСтруктуру.
//   СтруктураПараметровОтчетность1С – Структура параметров формы, сформированная функцией
//       СформироватьСтруктуруПараметров_Отправка, содержит синонимы элементов и таблицу выгрузки.
//   КодФормы – Строка, код формы, для которой формируется соответствие.
//
// Возвращаемое значение:
//   РазмещениеРеквизитовНаСтраницах – структура (объект Соответствие), где ключи – имена колонок
//       многострочной формы (с учетом синонимов), а значения – код страницы формы, к которой привязана колонка.
Функция СформироватьСтруктуруСтраницПоказателейМногострочнойФормы(СтруктураДанных, СтруктураПараметровОтчетность1С, КодФормы)
	РазмещениеРеквизитовНаСтраницах = Новый Структура;
	Для Каждого Элемент Из СтруктураДанных Цикл
		Значение = Элемент.Ключ;
		Для Каждого Колонка Из Элемент.Значение.Строки.Колонки Цикл
			Ключ = Колонка.Имя;
			
			// Соответствия синонимов для реквизита
			Ключ = ?(СтруктураПараметровОтчетность1С.СоответствиеАльтернативныхЭлементовФормы.Получить(Ключ)<>Неопределено,
					 СтруктураПараметровОтчетность1С.СоответствиеАльтернативныхЭлементовФормы.Получить(Ключ),
					 Ключ);
			
			Если ((Лев(Ключ, 1) = "Ф") или (СтрНайти(Элемент.Значение.ИмяРеквизитаТаблицыСтрокГруппы,"200_03") > 0)) и НЕ Прав( Ключ, 11) = "Расшифровка" И ЗначениеЗаполнено(Ключ) Тогда
				РазмещениеРеквизитовНаСтраницах.Вставить(Ключ, Значение);	
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	Возврат РазмещениеРеквизитовНаСтраницах;
КонецФункции

// Преобразует таблицу, полученную из JSON, в массив структур для удобной обработки в 1С.
//
// Параметры:
//   ТаблицаJSON – ТаблицаЗначений, загруженная из JSON, где строки содержат значения по колонкам.
//
// Возвращаемое значение:
//   Массив структур, где каждая структура соответствует строке исходной таблицы, 
//   а поля структуры – значения колонок таблицы (исключая колонки с названием, содержащим "Расшифровка").
Функция ПреобразоватьТаблицу(ТаблицаJSON)

	//преобразование таблицы в массив структур
	Строки = Новый Массив;
	Для Каждого Стр Из ТаблицаJSON Цикл
		Колонки = Новый Структура;
		Для Каждого Кол Из ТаблицаJSON.Колонки Цикл 
			Если ЗначениеЗаполнено(Кол.Имя) Тогда	
				//Удаление расшифровок
				Если ТипЗнч(Стр[Кол.Имя]) = Тип("СписокЗначений") Тогда
					Стр[Кол.Имя] = Стр[Кол.Имя].ВыгрузитьЗначения();
				КонецЕсли;

				Если Не СтрНайти(Кол.Имя, "Расшифровка") Тогда
					Колонки.Вставить(Кол.Имя, Стр[Кол.Имя]);
				КонецЕсли;
			КонецЕсли;	
		КонецЦикла;	
		Строки.Добавить(Колонки);
	КонецЦикла;
	
	Возврат Строки;

КонецФункции

// Рекурсивно преобразует все таблицы значений в структуре в массивы структур, 
// сохраняя вложенные структуры.
//
// Параметры:
//   Структура – Структура, содержащая ключи и значения. Значениями могут быть:
//               - ТаблицаЗначений
//               - Вложенные структуры
//               - Простейшие значения (числа, строки, даты и т.д.)
//
// Возвращаемое значение:
//   Новая структура, где:
//     - Таблицы значений заменены на массивы структур (с помощью функции ПреобразоватьТаблицу)
//     - Вложенные структуры рекурсивно преобразованы аналогично
//     - Простейшие значения остаются без изменений
Функция ПреобразоватьТаблицыСтруктурыВМассивы(Структура)
	
	СтруктураБезТаблиц = Новый Структура;
	
	Для каждого ТекСтрока Из Структура Цикл
		Если ТипЗнч(ТекСтрока.Значение) = Тип("ТаблицаЗначений") Тогда
			Массив = ПреобразоватьТаблицу(ТекСтрока.Значение);
			СтруктураБезТаблиц.Вставить(ТекСтрока.Ключ, Массив);
		ИначеЕсли ТипЗнч(ТекСтрока) = Тип("КлючИЗначение") И ТипЗнч(ТекСтрока.Значение) = Тип("Структура") Тогда
			СтруктураБезТаблиц.Вставить(ТекСтрока.Ключ, ПреобразоватьТаблицыСтруктурыВМассивы(ТекСтрока.Значение));
		Иначе
			СтруктураБезТаблиц.Вставить(ТекСтрока.Ключ, ТекСтрока.Значение);
		КонецЕсли;
	КонецЦикла;
	
	Возврат СтруктураБезТаблиц;
	
КонецФункции

// Преобразует массив структур в ТаблицаЗначений 1С.
//
// Параметры:
//   мсДанные – Массив, где каждый элемент является структура с ключами и значениями.
//
// Возвращаемое значение:
//   ТаблицаЗначений, где:
//     - Колонки создаются автоматически по ключам первой структуры массива
//     - Типы колонок соответствуют типам значений из первой структуры
//     - Каждая структура массива преобразуется в строку таблицы
Функция ПреобразоватьМассивВТаблицуЗначений(мсДанные)
	
	тзДанные = Новый ТаблицаЗначений;
	Для Каждого ЭлементМассива Из мсДанные Цикл
		Если тзДанные.Колонки.Количество() = 0 Тогда
			Для Каждого ЗначениеСтруктуры Из ЭлементМассива Цикл
				МассивДопустимыеТипы = Новый Массив;
				ТипКолонки = ТипЗнч(ЗначениеСтруктуры.Значение); 
				МассивДопустимыеТипы.Добавить(ТипКолонки);
				Описание_Типов = Новый ОписаниеТипов(МассивДопустимыеТипы);
				тзДанные.Колонки.Добавить(ЗначениеСтруктуры.Ключ,Описание_Типов);
			КонецЦикла;
		КонецЕсли;
		НоваяСтрока = тзДанные.Добавить();
		Для Каждого ЗначениеСтруктуры Из ЭлементМассива Цикл
			НоваяСтрока[ЗначениеСтруктуры.Ключ] = ЗначениеСтруктуры.Значение;
		КонецЦикла;
	КонецЦикла;
	Возврат тзДанные;
	
КонецФункции

// Функция выполняет замену имен областей или реквизитов формы на их синонимы
// согласно справочнику соответствий СинонимыЭлементовФормы.
//
// Параметры:
//   Данные - структура данных формы. Может быть:
//     * ТаблицаЗначений
//     * Структура (страницы формы с таблицами и шапкой/подвалом)
//     * Массив строк
//   СинонимыЭлементовФормы - структура соответствий (оригинальное имя → синоним)
//   ПоискПоСинониму (логическое, по умолчанию Ложь) - если Истина, поиск выполняется по синониму, иначе по оригинальному имени
Функция ПреобразоватьСинонимыВФорме(Данные, СинонимыЭлементовФормы, ПоискПоСинониму=Ложь)
	Если ПоискПоСинониму Тогда
		ИмяКолонки = "ИмяОбласти";
	Иначе
		ИмяКолонки = "Реквизит";
	КонецЕсли;	
	
	Если ТипЗнч(Данные) = Тип("ТаблицаЗначений") Тогда
		Если ПоискПоСинониму Тогда
			Для Каждого Строка Из Данные Цикл
				Строка[ИмяКолонки] = ?(СинонимыЭлементовФормы.Получить(Строка[ИмяКолонки])<>Неопределено,
									   СинонимыЭлементовФормы.Получить(Строка[ИмяКолонки]),
									   Строка[ИмяКолонки]);					
			КонецЦикла;
		Иначе
			Для Каждого Строка Из Данные Цикл		
				ПозицияДвойногоПодчерка = СтрНайти(Строка[ИмяКолонки], "__", НаправлениеПоиска.СКонца);
				Если ПозицияДвойногоПодчерка > 0 Тогда
					ИмяКолонкиИзм = Лев(Строка[ИмяКолонки], ПозицияДвойногоПодчерка - 1);
				    ИмяКолонкиПост = СтрЗаменить(Строка[ИмяКолонки], ИмяКолонкиИзм, "");
				Иначе
					ИмяКолонкиИзм = Строка[ИмяКолонки];
					ИмяКолонкиПост = "";
				КонецЕсли;	
				
				Строка[ИмяКолонки] = ?(СинонимыЭлементовФормы.Свойство(ИмяКолонкиИзм),
									   СинонимыЭлементовФормы[ИмяКолонкиИзм] + ИмяКолонкиПост,
									   Строка[ИмяКолонки]);				   
			КонецЦикла;
		КонецЕсли;	
	ИначеЕсли ТипЗнч(Данные) = Тип("Структура") Тогда
		Для Каждого Страница Из Данные Цикл 
			СтрокиПриложения = Страница.Значение.Строки;
			Для Каждого Строка Из СтрокиПриложения.Колонки Цикл
				Строка.Имя = ?(СинонимыЭлементовФормы.Получить(Строка.Имя)<>Неопределено,
							   СинонимыЭлементовФормы.Получить(Строка.Имя),
							   Строка.Имя);	
			КонецЦикла;
			
			ШапкаПриложения = Страница.Значение.ШапкаИПодвал;
			Для Каждого Строка Из ШапкаПриложения Цикл
				Строка.ИмяОбласти = ?(СинонимыЭлементовФормы.Получить(Строка.ИмяОбласти)<>Неопределено,
									  СинонимыЭлементовФормы.Получить(Строка.ИмяОбласти),
									  Строка.ИмяОбласти);		
			КонецЦикла;			
		КонецЦикла;		
	ИначеЕсли ТипЗнч(Данные) = Тип("Массив") Тогда
		Индекс = 0;
		Для Каждого Строка Из Данные Цикл
			ПозицияДвойногоПодчерка = СтрНайти(Строка, "__", НаправлениеПоиска.СКонца);
			Если ПозицияДвойногоПодчерка > 0 Тогда
					ИмяКолонкиИзм = Лев(Строка, ПозицияДвойногоПодчерка - 1);
				    ИмяКолонкиПост = СтрЗаменить(Строка, ИмяКолонкиИзм, "");
			Иначе
				ИмяКолонкиИзм = Строка;
				ИмяКолонкиПост = "";
			КонецЕсли;
			
			ИмяОбластиИтог  = ?(СинонимыЭлементовФормы.Свойство(ИмяКолонкиИзм),
								СинонимыЭлементовФормы[ИмяКолонкиИзм] + ИмяКолонкиПост,
							    Строка);						   
			Данные.Установить(Индекс, ИмяОбластиИтог);		                                                       
			
			Индекс = Индекс + 1;		
		КонецЦикла;	
	КонецЕсли;	
	
КонецФункции

// Определяет, является ли переданное значение недопустимого типа для ссылочных объектов и NULL.
//
// Параметры:
//   Значение – Любое значение, которое необходимо проверить.
//
// Возвращаемое значение:
//   Булево:
//     Истина  – если Значение является ссылкой на объект, который не входит в перечень допустимых типов, или равно NULL.
//     Ложь   – если Значение имеет допустимый тип.
Функция ЭтоЗначениеНедопустимогоТипа(Значение)
	
	Тип = ТипЗнч(Значение);
	
	Возврат Тип <> Тип("Неопределено") 
		И (Справочники.ТипВсеСсылки().СодержитТип(Тип)
		ИЛИ Документы.ТипВсеСсылки().СодержитТип(Тип)
		ИЛИ Перечисления.ТипВсеСсылки().СодержитТип(Тип)
		ИЛИ ПланыВидовХарактеристик.ТипВсеСсылки().СодержитТип(Тип)
		ИЛИ ПланыСчетов.ТипВсеСсылки().СодержитТип(Тип)
		ИЛИ ПланыВидовРасчета.ТипВсеСсылки().СодержитТип(Тип)
		ИЛИ БизнесПроцессы.ТипВсеСсылки().СодержитТип(Тип)
		ИЛИ БизнесПроцессы.ТипВсеСсылкиТочекМаршрутаБизнесПроцессов().СодержитТип(Тип)
		ИЛИ Задачи.ТипВсеСсылки().СодержитТип(Тип)
		ИЛИ ПланыОбмена.ТипВсеСсылки().СодержитТип(Тип))
		ИЛИ Значение = NULL;
	
КонецФункции

// Загружает данные после валидации на форму, преобразуя их с учетом соответствия элементов формы.
//
// Параметры:
//   Форма – Объект формы, на которую загружаются данные.
//   ДанныеПослеВалидации – Структура, содержащая результаты валидации и данные для загрузки. Должна содержать:
//       - СтруктураДобавляемыхПриПроверкеДанных.ТаблицаОшибокОтчетность1С – массив ошибок для отображения на форме.
//       - СтруктураДобавляемыхПриПроверкеДанных.СписокОбязательныхПолейОтчетность1С – список обязательных полей.
//       - СоответствиеЭлементовФормы – соответствие между именами реквизитов/элементов формы и исходными данными.
//
Процедура ЗагрузитьДанныеПослеВалидацииНаФорму(Форма, ДанныеПослеВалидации)
	ТаблицаОшибок = ПреобразоватьМассивВТаблицуЗначений(ДанныеПослеВалидации.СтруктураДобавляемыхПриПроверкеДанных.ТаблицаОшибокОтчетность1С);

	СинонимыЭлементовФормы = ДанныеПослеВалидации.СоответствиеЭлементовФормы;
	
	ПреобразоватьСинонимыВФорме(ТаблицаОшибок, СинонимыЭлементовФормы);
	ПреобразоватьСинонимыВФорме(ДанныеПослеВалидации.СтруктураДобавляемыхПриПроверкеДанных.СписокОбязательныхПолейОтчетность1С, СинонимыЭлементовФормы);
		
	Если ТаблицаОшибок.Количество() > 0 Тогда
		ЗначениеВДанныеФормы(ТаблицаОшибок, Форма.ТаблицаОшибокОтчетность1С);
	КонецЕсли;
	
	Форма.СписокОбязательныхПолейОтчетность1С.ЗагрузитьЗначения(ДанныеПослеВалидации.СтруктураДобавляемыхПриПроверкеДанных.СписокОбязательныхПолейОтчетность1С);

КонецПроцедуры

// Настраивает условное оформление элементов дерева ошибок на форме.
// Процедура отвечает за визуальное выделение строк, группировку ошибок и отображение критичности.
//
// Параметры:
//   Форма – Объект формы, содержащий дерево ошибок и элементы условного оформления.
//
Процедура ОформлениеДереваОшибок(Форма)
	// Выделение строк группы
	ЭлементОформления = Форма.УсловноеОформление.Элементы.Добавить();
	ЭлементОформления.Использование = Истина;

	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ЦветФонаГруппировкиОтчета1);
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("Шрифт", Новый Шрифт(,,Истина));
	ДобавитьОтборДляОформленияСтрокПервогоУровняДереваОшибок(ЭлементОформления);
	ДобавитьСписокОформляемыхПолейДереваОшибок(ЭлементОформления);

	ЭлементОформления = Форма.УсловноеОформление.Элементы.Добавить();
	ЭлементОформления.Использование = Истина;	
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ЦветФона", ЦветаСтиля.ЦветФонаГруппировкиОтчета2);
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("Шрифт", Новый Шрифт(,,Истина, Истина));
	ДобавитьОтборДляОформленияСтрокВторогоУровняДереваОшибок(ЭлементОформления);
	ДобавитьСписокОформляемыхПолейДереваОшибок(ЭлементОформления);

	// Вывод представления форм
	мСписокФормБезИерархии = Форма.мСписокФормБезИерархии.ПолучитьЭлементы();
		
	Если мСписокФормБезИерархии <> Неопределено Тогда
		Для Каждого СтрокаДереваФорм из мСписокФормБезИерархии Цикл
			// Имя формы
			ЭлементОформления = Форма.УсловноеОформление.Элементы.Добавить();
			ЭлементОформления.Использование = Истина;
			ЭлементОформления.Оформление.УстановитьЗначениеПараметра("Текст", Форма.СоответствиеСинонимовОтчетность1С.СинонимыПолей.Получить(СтрокаДереваФорм.КодФормы));
			ЭлементОтбора = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			ЭлементОтбора.Использование = Истина;                                   
			ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ДеревоОшибокОтчетность1С.Форма");
			ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
			ЭлементОтбора.ПравоеЗначение = СтрокаДереваФорм.КодФормы;

			ПолеЭлементаОформления = ЭлементОформления.Поля.Элементы.Добавить();
			ПолеЭлементаОформления.Поле = Новый ПолеКомпоновкиДанных("КолонкаФорма");
		КонецЦикла;
	КонецЕсли;	

	// форматирование номеров строк
	ЭлементОформления = Форма.УсловноеОформление.Элементы.Добавить();
	ЭлементОформления.Использование = Истина;
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("Формат", Отчетность1СКлиентСервер.ФорматНомераСтрокиМногострочнойФормы());

	ЭлементОтбора = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.Использование = Истина;                                   
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ДеревоОшибокОтчетность1С.НомерСтроки");
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Заполнено;

	ПолеЭлементаОформления = ЭлементОформления.Поля.Элементы.Добавить();
	ПолеЭлементаОформления.Поле = Новый ПолеКомпоновкиДанных("КолонкаНомерСтроки");

	ЭлементОформления = Форма.УсловноеОформление.Элементы.Добавить();
	ЭлементОформления.Использование = Истина;	
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветОсобогоТекста);
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("Шрифт", Новый Шрифт(,,Истина, Истина));

	ЭлементОтбора = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ДеревоОшибокОтчетность1С.Критичность");
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.ПравоеЗначение = Истина;
	ЭлементОтбора.Использование = Истина;

	ПолеЭлементаОформления = ЭлементОформления.Поля.Элементы.Добавить();
	ПолеЭлементаОформления.Поле = Новый ПолеКомпоновкиДанных("КолонкаКритичностьСимвол");

	ЭлементОформления = Форма.УсловноеОформление.Элементы.Добавить();
	ЭлементОформления.Использование = Истина;	
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", WebЦвета.Синий);
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("Шрифт", Новый Шрифт(,,Истина, Истина));

	ЭлементОтбора = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ДеревоОшибокОтчетность1С.Критичность");
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.ПравоеЗначение = Ложь;
	ЭлементОтбора.Использование = Истина;

	ПолеЭлементаОформления = ЭлементОформления.Поля.Элементы.Добавить();
	ПолеЭлементаОформления.Поле = Новый ПолеКомпоновкиДанных("КолонкаКритичностьСимвол");

	Форма.Элементы.ГруппаОшибокОтчетность1С.Заголовок = Отчетность1СКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Ошибок: %1; Обратить внимание: %2;'"), 
																		Строка(Форма.КоличествоОшибокКритичныхОтчетность1С),
																		Строка(Форма.КоличествоОшибокВсегоОтчетность1С));
КонецПроцедуры

// Формирует таблицу значений с общими реквизитами из макета выгрузки.
//
// Параметры:
//   МакетВыгрузки – Объект макета, содержащий области с общими реквизитами.
//   ПрефиксФормы – Строка, используемая для формирования имени области макета ("ОбщиеРеквизиты" + ПрефиксФормы).
//
// Возвращаемое значение:
//   ТаблицаЗначений с колонками:
//       ИмяАтрибута – имя реквизита из макета
//       ЗначениеАтрибута – соответствующее значение реквизита
Функция ЗаполнитьТаблицуОбщихРеквизитов(МакетВыгрузки, ПрефиксФормы) Экспорт

	ТаблОбщиеРеквизиты = Новый ТаблицаЗначений;
	ТаблОбщиеРеквизиты.Колонки.Добавить("ИмяАтрибута");
	ТаблОбщиеРеквизиты.Колонки.Добавить("ЗначениеАтрибута");

	ОбластьОбщихРеквизитов = МакетВыгрузки.Область("ОбщиеРеквизиты" + ПрефиксФормы);
	Для Ном = ОбластьОбщихРеквизитов.Верх По ОбластьОбщихРеквизитов.Низ Цикл
		Строка = ТаблОбщиеРеквизиты.Добавить();
		Строка.ИмяАтрибута 		  = СокрП(МакетВыгрузки.Область(Ном, 1).Текст);
		Строка.ЗначениеАтрибута   = СокрП(МакетВыгрузки.Область(Ном, 2).Текст);
	КонецЦикла;
	
	Возврат ТаблОбщиеРеквизиты;
КонецФункции

#КонецОбласти

#Область Отправка

// Разобрать строку ошибки поля из структуры json и найти соответствующее его поле отчета.
// 
// Параметры: 
//  fieldName - Строка - полный путь строки ошибки
//  ТаблицаВыгрузки - ТаблицаЗначений - таблица элементов формы
// 
// Возвращаемое значение:
//  Результат - Структура:
//  	* ИмяЯчейки - Строка - имя поля ошибки
//  	* НомерСтроки (опц.) - Число - номер строки ошибки, если есть
//  	* ИмяФормы - Строка - имя формы или приложения, к которому принадлежит поле ошибки
//  	* Страница - Строка - имя страницы формы, к которому принадлежит поле ошибки
Функция РазобратьОтветСервера(fieldName, ТаблицаВыгрузки, ИдентификаторВидаФНО=Неопределено)
	РеквизитПриложение = "application_";	
	
	// Получим поле fieldName и уберем "root."
	СтрокаПоиска = СтрЗаменить(fieldName, "root.", "");
	
	Результат = Новый Структура;

	// 1. Получаем имя ячейки (после последней точки)
	ВсеЭлементы = СтрРазделить(СтрокаПоиска, ".");
	ИмяЯчейки = ВсеЭлементы[ВсеЭлементы.Количество()-1];
	Результат.Вставить("ИмяЯчейки", ИмяЯчейки);  
	
	ВсеЭлементы.Удалить(ВсеЭлементы.Количество()-1);
	
	// 2. Получаем номер строки (опционально)
	НомерСтроки = "";
	Для Каждого Элемент Из ВсеЭлементы Цикл
		Если СтрНайти(Элемент, РеквизитПриложение) > 0 Тогда
			НайденныйМассив = СтрНайтиВсеПоРегулярномуВыражению(Элемент, "\[\d+\]");
			Если НайденныйМассив.Количество() > 0 Тогда
				НомерСтроки = НайденныйМассив[0].Значение;
				НомерСтроки = СтрЗаменить(НомерСтроки, "[", "");
				НомерСтроки = СтрЗаменить(НомерСтроки, "]", "");
				Результат.Вставить("НомерСтроки", Число(НомерСтроки)+1);
			КонецЕсли;	
		КонецЕсли;	
	КонецЦикла;
	
	// 3. Получаем путь к ячейке
	ПутьКЯчейке = СтрСоединить(ВсеЭлементы, ".");
	ПутьКЯчейке = СтрЗаменитьПоРегулярномуВыражению(ПутьКЯчейке, "\[\d+\]", "");
	Результат.Вставить("ПутьКЯчейке", ПутьКЯчейке);
	
	ПараметрыОтбора = Новый Структура;
	ПараметрыОтбора.Вставить("ИмяЯчейки", Результат.ИмяЯчейки);
	ПараметрыОтбора.Вставить("ПутьКЯчейке", Результат.ПутьКЯчейке);
	
	НайденныеСтроки = ТаблицаВыгрузки.НайтиСтроки(ПараметрыОтбора);
	
	Если НайденныеСтроки.Количество() > 0 Тогда
		Результат.Вставить("ИмяФормы", НайденныеСтроки[0].ИмяФормы);
		Результат.Вставить("Страница", НайденныеСтроки[0].Страница);
	Иначе
		Результат.Вставить("ИмяФормы", "");
		Результат.Вставить("Страница", "");
	КонецЕсли;	
	
	Результат.Вставить("Реквизит", ПутьКЯчейке + "." + ИмяЯчейки);
	
	Возврат Результат;
	 
КонецФункции

#КонецОбласти

#Область УправлениеИнтерфейсомФормы

// Добавляет на форму стандартные реквизиты, используемые для работы с Отчетность1С,
// включая идентификаторы, уведомления, таблицы ошибок, дерево ошибок и служебные поля.
//
// Параметры:
//   Форма – Объект формы, на которую необходимо добавить реквизиты.
Процедура ДобавитьРеквизитФормы(Форма)
	Реквизиты = Новый Массив;
	КС_12 = Новый КвалификаторыСтроки(12);
	КС_20 = Новый КвалификаторыСтроки(20);
	КС_36 = Новый КвалификаторыСтроки(36);
	КС_50 = Новый КвалификаторыСтроки(50);

	Реквизиты.Добавить(Новый РеквизитФормы("ИдентификаторПользователяОтчетность1С", 		Новый ОписаниеТипов("Строка",,,,КС_12),, "БИН/ИИН"));
	Реквизиты.Добавить(Новый РеквизитФормы("ИдентификаторФормыВСистемеПриемаОтчетность1С", 	Новый ОписаниеТипов("Строка",,КС_12),, "Идентификатор в системе приема"));
	Реквизиты.Добавить(Новый РеквизитФормы("ИдентификаторФормыОтчетность1С", 				Новый ОписаниеТипов("Строка",,,,КС_36),, "Идентификатор формы"));
	Реквизиты.Добавить(Новый РеквизитФормы("СтатусПриемаОтчетность1С", 					Новый ОписаниеТипов("ПеречислениеСсылка.СтатусыПриемаОтчетность1С"),, "Статус приема"));
	Реквизиты.Добавить(Новый РеквизитФормы("СтатусРазноскиОтчетность1С", 					Новый ОписаниеТипов("ПеречислениеСсылка.СтатусыПриемаОтчетность1С"),, "Статус разноски"));
		
	Реквизиты.Добавить(Новый РеквизитФормы("УведомлениеОтчетность1С", 					Новый ОписаниеТипов())); // Структура
	Реквизиты.Добавить(Новый РеквизитФормы("ДатаУведомленияОтчетность1С", 					Новый ОписаниеТипов("Строка",,,,КС_20),, "Дата уведомления"));
	Реквизиты.Добавить(Новый РеквизитФормы("НомерУведомленияОтчетность1С", 		Новый ОписаниеТипов("Строка",,,,КС_36),,"Уведомление")); // Строка неограниченной длины
	
	Реквизиты.Добавить(Новый РеквизитФормы("ТаблицаОшибокОтчетность1С", 	Новый ОписаниеТипов("ТаблицаЗначений")));
	Реквизиты.Добавить(Новый РеквизитФормы("КодФормы", 				Новый ОписаниеТипов("Строка"), "ТаблицаОшибокОтчетность1С", "Форма"));
	Реквизиты.Добавить(Новый РеквизитФормы("Страница", 				Новый ОписаниеТипов("Строка"), "ТаблицаОшибокОтчетность1С", "Страница"));
	Реквизиты.Добавить(Новый РеквизитФормы("НомерЛиста",			Новый ОписаниеТипов("Строка"), "ТаблицаОшибокОтчетность1С", "Лист"));
	Реквизиты.Добавить(Новый РеквизитФормы("НомерСтроки", 			Новый ОписаниеТипов("Число"),  "ТаблицаОшибокОтчетность1С", "Номер"));
	Реквизиты.Добавить(Новый РеквизитФормы("Реквизит", 				Новый ОписаниеТипов("Строка"), "ТаблицаОшибокОтчетность1С", "Графа"));
	Реквизиты.Добавить(Новый РеквизитФормы("РеквизитНазвание", 		Новый ОписаниеТипов("Строка"), "ТаблицаОшибокОтчетность1С", "Поле"));
	Реквизиты.Добавить(Новый РеквизитФормы("Ошибка", 				Новый ОписаниеТипов("Строка"), "ТаблицаОшибокОтчетность1С", "Результат проверки"));
	Реквизиты.Добавить(Новый РеквизитФормы("Критичность", 			Новый ОписаниеТипов("Булево"), "ТаблицаОшибокОтчетность1С", "Критичность"));

	Реквизиты.Добавить(Новый РеквизитФормы("ДеревоОшибокОтчетность1С",     Новый ОписаниеТипов("ДеревоЗначений")));
	Реквизиты.Добавить(Новый РеквизитФормы("ИндексВТаблицеОшибок",	Новый ОписаниеТипов("Число"),  "ДеревоОшибокОтчетность1С", "Ключ")); // КлючСвязи с таблицей ошибок
	Реквизиты.Добавить(Новый РеквизитФормы("Реквизит", 				Новый ОписаниеТипов("Строка"), "ДеревоОшибокОтчетность1С", "Графа"));
	Реквизиты.Добавить(Новый РеквизитФормы("Форма", 				Новый ОписаниеТипов("Строка"), "ДеревоОшибокОтчетность1С", "Форма"));
	Реквизиты.Добавить(Новый РеквизитФормы("Страница", 				Новый ОписаниеТипов("Строка"), "ДеревоОшибокОтчетность1С", "Страница"));
	Реквизиты.Добавить(Новый РеквизитФормы("НомерЛиста", 		    Новый ОписаниеТипов("Строка"), "ДеревоОшибокОтчетность1С", "Лист"));
	Реквизиты.Добавить(Новый РеквизитФормы("Поле", 				    Новый ОписаниеТипов("Строка"), "ДеревоОшибокОтчетность1С", "Поле"));
	Реквизиты.Добавить(Новый РеквизитФормы("НомерСтроки",		    Новый ОписаниеТипов("Число"),  "ДеревоОшибокОтчетность1С", "№ строки")); // Для многострочных форм	
	Реквизиты.Добавить(Новый РеквизитФормы("Ошибка", 				Новый ОписаниеТипов("Строка"), "ДеревоОшибокОтчетность1С", "Результат проверки"));
	Реквизиты.Добавить(Новый РеквизитФормы("Критичность", 			Новый ОписаниеТипов("Булево"), "ДеревоОшибокОтчетность1С", "Критичность"));
	Реквизиты.Добавить(Новый РеквизитФормы("КритичностьСимвол", 	Новый ОписаниеТипов("Строка"), "ДеревоОшибокОтчетность1С", "КритичностьСимвол"));

	Реквизиты.Добавить(Новый РеквизитФормы("РезультатПроверкиТекущийОтчетность1С", 	Новый ОписаниеТипов("Строка")));

	Реквизиты.Добавить(Новый РеквизитФормы("КоличествоОшибокВсегоОтчетность1С", 	    Новый ОписаниеТипов("Число")));
	Реквизиты.Добавить(Новый РеквизитФормы("КоличествоОшибокКритичныхОтчетность1С", 	Новый ОписаниеТипов("Число")));

	Реквизиты.Добавить(Новый РеквизитФормы("ПоказыватьВсеОшибкиОтчетность1С", 		Новый ОписаниеТипов("Булево")));
	Реквизиты.Добавить(Новый РеквизитФормы("СоответствиеСинонимовОтчетность1С",    Новый ОписаниеТипов()));
	Реквизиты.Добавить(Новый РеквизитФормы("СписокОбязательныхПолейОтчетность1С",    Новый ОписаниеТипов("СписокЗначений")));
	
	Реквизиты.Добавить(Новый РеквизитФормы("АдресПараметровПолученияДанныхВалидацииОтчетность1С", Новый ОписаниеТипов("Строка")));
	
	// добавим реквизиты на форму
	Форма.ИзменитьРеквизиты(Реквизиты);
	Форма.СоответствиеСинонимовОтчетность1С = Новый Структура("СинонимыПолей, НаименованиеКаз", Новый Соответствие, Новый Соответствие);
КонецПроцедуры

// Добавляет на форму элементы управления в виде кнопок и групп, используемые для работы с отчетностью 1С.
//
// Параметры:
//   Форма – Объект формы, на которую добавляются элементы управления.
//   ГруппаКоманд – Родительская группа для размещения элементов кнопок.
Процедура ДобавитьЭлементыУправления_Кнопки(Форма, ГруппаКоманд)
		
	// 1. Добавление кнопки с командами Отчетность1С
	ГруппаКнопокОтчетность1С = Форма.Элементы.Вставить("ФормаГруппаОтчетность1С", Тип("ГруппаФормы"), ГруппаКоманд);
	ГруппаКнопокОтчетность1С.Вид = ВидГруппыФормы.Подменю;
	ГруппаКнопокОтчетность1С.Заголовок = НСтр("ru='1С:Отчетность'");
	ГруппаКнопокОтчетность1С.Отображение = ОтображениеКнопки.КартинкаИТекст;
	ГруппаКнопокОтчетность1С.Картинка = БиблиотекаКартинок.ЗаписатьИзменения;

	// Кнопка "Проверить заполнение"
	Если Форма.ИспользоватьКоманду_ПроверкаФЛК() Тогда
		НоваяКоманда = Форма.Команды.Добавить("ПроверитьЗаполнениеОтчетность1С");
		НоваяКоманда.Действие = "Подключаемый_ПроверитьЗаполнениеОтчетность1С";

		КнопкаПроверитьОтчетность1С = Форма.Элементы.Вставить("ФормаПроверитьЗаполнениеОтчетность1С", Тип("КнопкаФормы"), ГруппаКнопокОтчетность1С);
		КнопкаПроверитьОтчетность1С.Заголовок = НСтр("ru='Проверить заполнение'");
		КнопкаПроверитьОтчетность1С.ИмяКоманды = "ПроверитьЗаполнениеОтчетность1С";
		КнопкаПроверитьОтчетность1С.Отображение = ОтображениеКнопки.КартинкаИТекст;
		КнопкаПроверитьОтчетность1С.Картинка = БиблиотекаКартинок.ВыполнитьЗадачу;
	КонецЕсли;

	// Кнопка "Отправить в ИСНА"
	Если Форма.ИспользоватьКоманду_Отправить() Тогда
		НоваяКоманда = Форма.Команды.Добавить("ОтправитьОтчетность1С");
		НоваяКоманда.Действие = "Подключаемый_ОтправитьОтчетность1С";
		
		КнопкаОтправитьОтчетность1С = Форма.Элементы.Вставить("ФормаОтправитьОтчетность1С", Тип("КнопкаФормы"), ГруппаКнопокОтчетность1С);
		КнопкаОтправитьОтчетность1С.Заголовок = НСтр("ru='Отправить в ИСНА'");
		КнопкаОтправитьОтчетность1С.ИмяКоманды = "ОтправитьОтчетность1С";
		КнопкаОтправитьОтчетность1С.Отображение = ОтображениеКнопки.КартинкаИТекст;
		КнопкаОтправитьОтчетность1С.Картинка = БиблиотекаКартинок.ПрочитатьИзменения;
	КонецЕсли;
	
	// Кнопка "Обновить статус"
	Если Форма.ИспользоватьКоманду_ОбновитьСтатус() Тогда
		НоваяКоманда = Форма.Команды.Добавить("ОбновитьСтатусОтчетность1С");
		НоваяКоманда.Действие = "Подключаемый_ОбновитьСтатусОтчетность1С";
		
		КнопкаОбновитьСтатусОтчетность1С = Форма.Элементы.Вставить("ФормаОбновитьСтатусОтчетность1С", Тип("КнопкаФормы"), ГруппаКнопокОтчетность1С);
		КнопкаОбновитьСтатусОтчетность1С.Заголовок = НСтр("ru='Обновить статус отправки'");
		КнопкаОбновитьСтатусОтчетность1С.ИмяКоманды = "ОбновитьСтатусОтчетность1С";
		КнопкаОбновитьСтатусОтчетность1С.Отображение = ОтображениеКнопки.КартинкаИТекст;
		КнопкаОбновитьСтатусОтчетность1С.Картинка = БиблиотекаКартинок.ВосстановитьЗначения;
	КонецЕсли;
	
	// Группа выгрузки

	ГруппаВыгрузитьОтчетность1С = Форма.Элементы.Вставить("ГруппаВыгрузитьОтчетность1С", Тип("ГруппаФормы"), ГруппаКнопокОтчетность1С);
	ГруппаВыгрузитьОтчетность1С.Вид = ВидГруппыФормы.ГруппаКнопок;
	
	// Кнопка "Выгрузить в JSON"
	Если Форма.ИспользоватьКоманду_Выгрузить() Тогда
		НоваяКоманда = Форма.Команды.Добавить("ВыгрузитьВJSONОтчетность1С");
		НоваяКоманда.Действие = "Подключаемый_ВыгрузитьВJSONОтчетность1С";	
		
		КнопкаВыгрузитьВJSONОтчетность1С = Форма.Элементы.Вставить("ФормаВыгрузитьВJSONОтчетность1С", Тип("КнопкаФормы"), ГруппаВыгрузитьОтчетность1С);
		КнопкаВыгрузитьВJSONОтчетность1С.Заголовок = НСтр("ru='Выгрузить в ИСНА (JSON)'");
		КнопкаВыгрузитьВJSONОтчетность1С.ИмяКоманды = "ВыгрузитьВJSONОтчетность1С";
		КнопкаВыгрузитьВJSONОтчетность1С.Отображение = ОтображениеКнопки.Текст;
	КонецЕсли;                    
	
	// 2. Группа для подвала Отчетность1С
	ПолеКомментарий = Форма.Элементы.Найти("Комментарий");
	
	Если ТипЗнч(ПолеКомментарий.Родитель) = Тип("ГруппаФормы") Тогда
		ГруппаОшибок = Форма.Элементы.Вставить("ГруппаОшибокОтчетность1С", Тип("ГруппаФормы"));	
	Иначе
		ГруппаОшибок = Форма.Элементы.Вставить("ГруппаОшибокОтчетность1С", Тип("ГруппаФормы"),, ПолеКомментарий);	
	КонецЕсли;
	
	ГруппаОшибок.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаОшибок.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	ГруппаОшибок.РастягиватьПоГоризонтали = Истина;
	ГруппаОшибок.Заголовок = НСтр("ru='Обнаруженные ошибки'");
	ГруппаОшибок.ОтображатьЗаголовок = Истина;
	ГруппаОшибок.Поведение = ПоведениеОбычнойГруппы.Свертываемая;
    ГруппаОшибок.Отображение = ОтображениеОбычнойГруппы.Нет;
	
	//Группа для отображения Дерева ошибок
	ГруппаДеревоОшибок = Форма.Элементы.Вставить("ГруппаДеревоОшибокОтчетность1С", Тип("ГруппаФормы"), ГруппаОшибок);
	ГруппаДеревоОшибок.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаДеревоОшибок.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	ГруппаДеревоОшибок.ОтображатьЗаголовок = Ложь;

	КоманднаяПанельДеревоОшибок = Форма.Элементы.Вставить("КоманднаяПанельДеревоОшибокОтчетность1С", Тип("ГруппаФормы"), ГруппаДеревоОшибок);
	КоманднаяПанельДеревоОшибок.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	КоманднаяПанельДеревоОшибок.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяЕслиВозможно;
	КоманднаяПанельДеревоОшибок.ОтображатьЗаголовок = Ложь;

	КнопкаПоказыватьВсеОшибкиОтчетность1С = Форма.Элементы.Добавить("ДеревоОшибокПоказыватьВсеОшибкиОтчетность1С", Тип("ПолеФормы"), КоманднаяПанельДеревоОшибок);
	КнопкаПоказыватьВсеОшибкиОтчетность1С.ПутьКДанным = "ПоказыватьВсеОшибкиОтчетность1С";
	КнопкаПоказыватьВсеОшибкиОтчетность1С.Заголовок = НСтр("ru='Показывать'");
	КнопкаПоказыватьВсеОшибкиОтчетность1С.Вид = ВидПоляФормы.ПолеФлажка;
	КнопкаПоказыватьВсеОшибкиОтчетность1С.ВидФлажка = ВидФлажка.Тумблер;
	КнопкаПоказыватьВсеОшибкиОтчетность1С.ФорматРедактирования = "БИ=Все; БЛ='Ошибки'";
	КнопкаПоказыватьВсеОшибкиОтчетность1С.УстановитьДействие("ПриИзменении", "Подключаемый_ДеревоОшибокПоказыватьВсеОшибкиПриИзмененииОтчетность1С");
	
	НоваяКоманда = Форма.Команды.Добавить("ДеревоОшибокСвернутьВсеСтрокиОтчетность1С");
	НоваяКоманда.Действие = "Подключаемый_ОбработчикЭлементовФормыОтчетность1С";

	КнопкаСвернутьВсеСтрокиОтчетность1С = Форма.Элементы.Вставить("ДеревоОшибокСвернутьВсеСтрокиОтчетность1С", Тип("КнопкаФормы"), КоманднаяПанельДеревоОшибок);
	КнопкаСвернутьВсеСтрокиОтчетность1С.Заголовок = НСтр("ru='Свернуть строки'");
	КнопкаСвернутьВсеСтрокиОтчетность1С.ИмяКоманды = "ДеревоОшибокСвернутьВсеСтрокиОтчетность1С";
	КнопкаСвернутьВсеСтрокиОтчетность1С.Картинка = БиблиотекаКартинок.СвернутьВсе;
	КнопкаСвернутьВсеСтрокиОтчетность1С.Отображение = ОтображениеКнопки.КартинкаИТекст;

	//Кнопка Развернуть все строки
	НоваяКоманда = Форма.Команды.Добавить("ДеревоОшибокРазвернутьВсеСтрокиОтчетность1С");
	НоваяКоманда.Действие = "Подключаемый_ОбработчикЭлементовФормыОтчетность1С";
	
	КнопкаРазвернутьВсеСтрокиОтчетность1С = Форма.Элементы.Вставить("ДеревоОшибокРазвернутьВсеСтрокиОтчетность1С", Тип("КнопкаФормы"), КоманднаяПанельДеревоОшибок);
	КнопкаРазвернутьВсеСтрокиОтчетность1С.Заголовок = НСтр("ru='Развернуть строки'");
	КнопкаРазвернутьВсеСтрокиОтчетность1С.ИмяКоманды = "ДеревоОшибокРазвернутьВсеСтрокиОтчетность1С";
	КнопкаРазвернутьВсеСтрокиОтчетность1С.Картинка = БиблиотекаКартинок.РазвернутьВсе;
	КнопкаРазвернутьВсеСтрокиОтчетность1С.Отображение = ОтображениеКнопки.КартинкаИТекст;
	
	//Группа для отображения подсказки. Содержит: ГруппаПодсказкиКоманднаяПанельОтчетность1С
	ГруппаПодсказка = Форма.Элементы.Вставить("ГруппаПодсказкаОтчетность1С", Тип("ГруппаФормы"), ГруппаОшибок);
	ГруппаПодсказка.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаПодсказка.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	ГруппаПодсказка.ОтображатьЗаголовок = Ложь;
	
	//Группа подробной информации в подсказке
	ГруппаПодсказкаПодробно = Форма.Элементы.Вставить("ГруппаПодсказкаПодробноОтчетность1С", Тип("ГруппаФормы"), ГруппаПодсказка);
	ГруппаПодсказкаПодробно.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаПодсказкаПодробно.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	ГруппаПодсказкаПодробно.РастягиватьПоГоризонтали = Истина;
	ГруппаПодсказкаПодробно.РастягиватьПоВертикали = Истина;
	ГруппаПодсказкаПодробно.ОтображатьЗаголовок = Ложь;
КонецПроцедуры

// Добавляет элементы управления (реквизиты, дерево ошибок и подсказки) на форму для работы с отчетностью ИСНА.
//
// Назначение:
//   Настраивает визуальные элементы формы: реквизиты отправки отчетности, дерево ошибок и элементы подсказок.
//   Обеспечивает отображение информации о статусе отправки, идентификаторах сообщений и уведомлений, 
//   а также визуализирует критичные и некритичные ошибки.
//
// Параметры:
//   Форма – Объект формы, на которую добавляются элементы.
Процедура ДобавитьЭлементыУправления_Реквизиты(Форма)
	// Блок реквизитов Отчетность1С
	ГруппаОтчет = Форма.Элементы.Найти("Отчет");
	
	ГруппаОтчетность1С = Форма.Элементы.Вставить("ГруппаОтчетность1С", Тип("ГруппаФормы"),,ГруппаОтчет);
	ГруппаОтчетность1С.Вид = ВидГруппыФормы.Страницы;
	ГруппаОтчетность1С.ОтображениеСтраниц = ОтображениеСтраницФормы.ЗакладкиСверху;
	
	ГруппаРеквизитовОтправки = Форма.Элементы.Добавить("ГруппаРеквизитовОтправкиОтчетность1С", Тип("ГруппаФормы"), ГруппаОтчетность1С);
	ГруппаРеквизитовОтправки.Вид = ВидГруппыФормы.Страница;
	ГруппаРеквизитовОтправки.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	ГруппаРеквизитовОтправки.Заголовок = НСтр("ru='Сервис 1С:Отчетность для Казахстана'");
	
	//Общая информация
	НадписьОбщаяИнформация = Форма.Элементы.Вставить("ОбщаяИнформацияОтчетность1С", Тип("ДекорацияФормы"), ГруппаРеквизитовОтправки);
	НадписьОбщаяИнформация.Вид = ВидДекорацииФормы.Надпись;
	НадписьОбщаяИнформация.Заголовок = Отчетность1СКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Текущая версия: %1'"), Отчетность1СКлиентСервер.ВерсияБиблиотеки());
	НадписьОбщаяИнформация.АвтоМаксимальнаяШирина  = Ложь;	
	НадписьОбщаяИнформация.ЦветТекста = Отчетность1СКлиентСервер.ЦветСиний();
	
	ГруппаРеквизитовИдентификаторы = Форма.Элементы.Вставить("ГруппаРеквизитовИдентификаторыОтчетность1С", Тип("ГруппаФормы"),ГруппаРеквизитовОтправки);
