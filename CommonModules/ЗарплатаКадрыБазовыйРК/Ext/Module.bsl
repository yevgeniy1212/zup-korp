
#Область СлужебныйПрограммныйИнтерфейс

Функция ДатаИзмененияПорядкаПеречисленияОСМС2024() Экспорт
	
	Возврат НачалоМесяца('20240421');
	
КонецФункции

Процедура ИзменитьПериодыОплатыДляМедицинскогоСтрахованияПриЗаписи(Источник, Отказ, Замещение) Экспорт
	
	Если ЗарплатаКадры.ОтключитьБизнесЛогикуПриЗаписи(Источник) Тогда
		Возврат;
	КонецЕсли;
		
	ДокументОснование = Источник.Отбор.Регистратор.Значение;

    // регистрируем данные только для документов регистрации события отпуска
	Если НЕ ТипЗнч(ДокументОснование) = Тип("ДокументСсылка.Отпуск") Тогда
		
		Возврат;
		
	КонецЕсли;	

	ДанныеДокумента = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДокументОснование, "ПериодРегистрации, Организация, Сотрудник, ФизическоеЛицо, ИсправленныйДокумент");

	Если ЗначениеЗаполнено(ДанныеДокумента.ИсправленныйДокумент) Тогда
		
		ПериодРегистрацииИсправления = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеДокумента.ИсправленныйДокумент, "ПериодРегистрации");
		
		Если ЗначениеЗаполнено(ПериодРегистрацииИсправления) Тогда
			ПериодРегистрации = ПериодРегистрацииИсправления;
		Иначе
			ПериодРегистрации = ПериодРегистрацииИсправления;
		КонецЕсли;
		
	Иначе
		
		ПериодРегистрации = ДанныеДокумента.ПериодРегистрации;
		
	КонецЕсли;
	
	Организация = ДанныеДокумента.Организация;
	ФизическоеЛицо = ДанныеДокумента.ФизическоеЛицо;

	// настройки периода действия получаем на период регистрации документа
	// при расчете по периоду действия расчет ОСМС будет разноситься по месяцу действия события,
	// делить сумму ОСМС по периодам необходимости нет
	ИспользуетсяПериодДействия = Ложь;
	
	Если ИспользуетсяПериодДействия
		ИЛИ ПериодРегистрации < ДатаИзмененияПорядкаПеречисленияОСМС2024() Тогда
		Возврат;
	КонецЕсли;
	
	ПериодыОплатыДляМедицинскогоСтрахования = РегистрыСведений.ПериодыОплатыДляМедицинскогоСтрахования.СоздатьНаборЗаписей();
	ПериодыОплатыДляМедицинскогоСтрахования.Отбор.Регистратор.Установить(ДокументОснование);
	
	Если Источник.Количество() = 0 Тогда
		
		ПериодыОплатыДляМедицинскогоСтрахования.Записать();
		Возврат;	
		
	КонецЕсли;
	
    // в рамках документа регистрации события по сотруднику может быть несколько событий, 
	// переходящий период необходимо контролировать по всем видам событий
	// например, отпуск основной + отпуск экологический
	ДатаНачалаПоДокументу	 = Дата(3999, 12, 31, 23, 59, 59);
	ДатаОкончанияПоДокументу = Дата(1, 1, 1);
    ОбщиеКалендарныеДниРегистратора = 0;
	
	ЕстьСобытиеБудущегоПериода = Ложь;
	МесяцПослеПериодаРегистрации = НачалоМесяца(ДобавитьМесяц(ПериодРегистрации, 1));
	
    // Добавляем в регистр записи при переходящем отпуске или отпуске будущего периода
	Для Каждого СтрокаОтпуска Из Источник Цикл
		
		Если НЕ СтрокаОтпуска.Компенсация
				И (СтрокаОтпуска.Состояние = Перечисления.СостоянияСотрудника.ОтпускОсновной
					ИЛИ СтрокаОтпуска.Состояние = Перечисления.СостоянияСотрудника.ДополнительныйОтпуск) Тогда
			
			Если ДатаНачалаПоДокументу > СтрокаОтпуска.ДатаНачала Тогда
				ДатаНачалаПоДокументу = СтрокаОтпуска.ДатаНачала;	
			КонецЕсли;
			
			Если ДатаОкончанияПоДокументу < СтрокаОтпуска.ДатаОкончания Тогда
				ДатаОкончанияПоДокументу = СтрокаОтпуска.ДатаОкончания;	
			КонецЕсли;
			
			Если СтрокаОтпуска.ДатаНачала >= МесяцПослеПериодаРегистрации
				ИЛИ СтрокаОтпуска.ДатаОкончания >= МесяцПослеПериодаРегистрации Тогда
				
				ЕстьСобытиеБудущегоПериода = Истина;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
    // документ отпуска может регистрировать только отпуск без оплаты или только компенсацию
	Если ДатаНачалаПоДокументу = ДатаОкончанияПоДокументу = Дата(1, 1, 1)
		ИЛИ ДатаНачалаПоДокументу = Дата(3999, 12, 31, 23, 59, 59) Тогда
		
		Возврат;
				
	КонецЕсли;
	
	ОбщиеКалендарныеДниРегистратора = ОбщегоНазначенияБЗККлиентСервер.КоличествоДнейВПериоде(ДатаНачалаПоДокументу, ДатаОкончанияПоДокументу);
	
	// календарный месяц более 28 дней (28-31, в высокосном 29-31)
	МинимальноеКоличествоКалендарныхДнейВГоду = ?(Цел(Год(ПериодРегистрации)/4 = Год(ПериодРегистрации)/4), 29, 28); 
	
    // в регистре формируем записи, только если отпуск удовлетворяет условию
	// начислении (исчислении) дохода, включающего период оплачиваемого трудового отпуска длительностью один или более одного календарного месяца
	Если ОбщиеКалендарныеДниРегистратора >= МинимальноеКоличествоКалендарныхДнейВГоду И (ЕстьСобытиеБудущегоПериода
		ИЛИ (НЕ ДатаНачалаПоДокументу = ДатаОкончанияПоДокументу И ЗначениеЗаполнено(ДатаНачалаПоДокументу)))  Тогда

		// Сформируем суммы отпуска по месяцам
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
		               |	СУММА(ВЫБОР
		               |			КОГДА НалогообложениеНачислений.СпособОбложенияВОСМС В (ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.ОблагаетсяЦеликом), ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.НеОблагаетсяЧастично))
		               |				ТОГДА ОтпускНачисления.Результат
		               |			ИНАЧЕ 0
		               |		КОНЕЦ) КАК СуммаПоДокументу
		               |ИЗ
		               |	Документ.Отпуск.Начисления КАК ОтпускНачисления
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланВидовРасчета.Начисления КАК Начисления
		               |		ПО ОтпускНачисления.Начисление = Начисления.Ссылка
		               |			И (Начисления.КатегорияНачисленияИлиНеоплаченногоВремени = ЗНАЧЕНИЕ(Перечисление.КатегорииНачисленийИНеоплаченногоВремени.ОплатаОтпуска))
		               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НалогообложениеНачислений.СрезПоследних(&ПериодРегистрации, ) КАК НалогообложениеНачислений
		               |		ПО ОтпускНачисления.Начисление = НалогообложениеНачислений.Начисление
		               |ГДЕ
		               |	ОтпускНачисления.Ссылка = &Регистратор";
		
		Запрос.УстановитьПараметр("Регистратор", ДокументОснование);
		Запрос.УстановитьПараметр("ПериодРегистрации", ПериодРегистрации);
		
		ДанныеОблагаемойСуммыДокумента = Запрос.Выполнить().Выбрать();
		
		Если ДанныеОблагаемойСуммыДокумента.Следующий() Тогда
			
			ОблагаемаяСуммаДокумента = ДанныеОблагаемойСуммыДокумента.СуммаПоДокументу;
			
		Иначе
			
			ОблагаемаяСуммаДокумента = 0;
			
		КонецЕсли;

		Если ОблагаемаяСуммаДокумента = 0 Тогда
			
			ПериодыОплатыДляМедицинскогоСтрахования.Записать();
			Возврат;	
			
		КонецЕсли;

		ТаблицаПериодовОплаты = ПериодыОплатыДляМедицинскогоСтрахования.ВыгрузитьКолонки();
		
		Для Каждого СтрокаОтпуска Из Источник Цикл
			
			Если НЕ СтрокаОтпуска.Компенсация
					И (СтрокаОтпуска.Состояние = Перечисления.СостоянияСотрудника.ОтпускОсновной
						ИЛИ СтрокаОтпуска.Состояние = Перечисления.СостоянияСотрудника.ДополнительныйОтпуск) Тогда
				
				ДатаНачала    = СтрокаОтпуска.ДатаНачала;
				ДатаОкончания = КонецМесяца(СтрокаОтпуска.ДатаНачала);
				
				Пока КонецМесяца(СтрокаОтпуска.ДатаОкончания) > КонецМесяца(ДатаОкончания) Цикл
					
					ЗаписьПериода = ТаблицаПериодовОплаты.Добавить();
					ЗаполнитьЗначенияСвойств(ЗаписьПериода, СтрокаОтпуска);
					ЗаписьПериода.МесяцСобытия = НачалоМесяца(ДатаНачала);
					ЗаписьПериода.Организация = Организация;
					ЗаписьПериода.ФизическоеЛицо = ФизическоеЛицо;
					ЗаписьПериода.ПериодРегистрации = ПериодРегистрации;
	                ЗаписьПериода.УчитываемыеДниПериода = ОбщегоНазначенияБЗККлиентСервер.КоличествоДнейВПериоде(ДатаНачала, ДатаОкончания);
	                ЗаписьПериода.УчитываемыеДниСобытия = ОбщиеКалендарныеДниРегистратора;
					ЗаписьПериода.СуммаСобытия = ОблагаемаяСуммаДокумента;	
					
					ДатаНачала = КонецМесяца(ДатаОкончания) + 1;
					ДатаОкончания = Мин(КонецМесяца(ДатаНачала), СтрокаОтпуска.ДатаОкончания);
					
				КонецЦикла;
				
				// закрывающая запись
				ЗаписьПериода = ТаблицаПериодовОплаты.Добавить();
				ЗаполнитьЗначенияСвойств(ЗаписьПериода, СтрокаОтпуска);
				ЗаписьПериода.МесяцСобытия = НачалоМесяца(ДатаНачала);
				ЗаписьПериода.Организация = Организация;
				ЗаписьПериода.ФизическоеЛицо = ФизическоеЛицо;
				ЗаписьПериода.ПериодРегистрации = ПериодРегистрации;
                ЗаписьПериода.УчитываемыеДниПериода = ОбщегоНазначенияБЗККлиентСервер.КоличествоДнейВПериоде(ДатаНачала, СтрокаОтпуска.ДатаОкончания);
                ЗаписьПериода.УчитываемыеДниСобытия = ОбщиеКалендарныеДниРегистратора;
				ЗаписьПериода.СуммаСобытия = ОблагаемаяСуммаДокумента;	

			КонецЕсли;
			
		КонецЦикла;
		
		// если в рамках месяца были разные виды отпусков, то свернем их, получим итогы количества дней события и общую сумму
		ТаблицаПериодовОплаты.Свернуть("ПериодРегистрации, Сотрудник, ФизическоеЛицо, Организация, МесяцСобытия, Подразделение, УчитываемыеДниСобытия, СуммаСобытия", "УчитываемыеДниПериода");
		
		ПериодыОплатыДляМедицинскогоСтрахования.Загрузить(ТаблицаПериодовОплаты);

	КонецЕсли;
	
	// набор записываем в любом случае (отмена проведения, срабатывания механизмов сторнирования и исправления)
	ПериодыОплатыДляМедицинскогоСтрахования.Записать(Истина);

КонецПроцедуры

#Область ДатыЗапретаИзмененияДанных

// См. ДатыЗапретаИзмененияПереопределяемый.ЗаполнитьИсточникиДанныхДляПроверкиЗапретаИзменения.
Процедура ЗаполнитьИсточникиДанныхДляПроверкиЗапретаИзменения(ИсточникиДанных) Экспорт
	
	// Раздел Зарплата
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.МесячныйРасчетныйПоказатель",							"Период",				"Зарплата", "");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.РасчетСреднегоЗаработкаОрганизаций", 					"Период", 				"Зарплата", "Организация");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.РасчетСреднегоЗаработкаПодразделений", 				"Период", 				"Зарплата", "");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.РасчетСреднегоЗаработкаСотрудников", 					"Период", 				"Зарплата", "");
	
	// Раздел НалогиВзносыОтчисления
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "Документ.ЗаявлениеНаПредоставлениеВычетовИПН", 						"Месяц", 				"НДФЛ", "Организация");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "Документ.ПрекращениеПредоставленияВычетовИПН", 						"Месяц", 				"НДФЛ", "Организация");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "Документ.ВедомостьНаПеречислениеВзносовОтчислений", 					"ПериодРегистрации", 	"НДФЛ", "Организация");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "Документ.СведенияОНезачисленныхВзносахОтчислениях", 					"Дата", 				"НДФЛ", "Организация");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "Документ.ПеняПоВзносамИОтчислениям", 									"ПериодРегистрации",	"НДФЛ", "Организация");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "Документ.УдержаниеНалоговВзносовПоНУ", 								"ПериодРегистрации",	"НДФЛ", "Организация");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "Документ.РегистрацияПрочихВыплат",									"Дата",					"Зарплата", "Организация");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "Документ.ВедомостьНаПеречислениеПрочихВыплат",						"ПериодВзаиморасчетов",	"Зарплата", "Организация");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "Документ.ВедомостьНаВозвратПрочихВыплат",								"Дата",					"Зарплата", "Организация");
	
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.СтатусФизическихЛицКакНалогоплательщиков",			"Период", 				"НДФЛ", "");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.ВычетыФизическихЛицИПН", 								"Период", 				"НДФЛ", "");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.ПрименениеВычетовИПН",			 					"Период", 				"НДФЛ", "");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.ЛьготыФизическихЛицИПН",			 					"Период", 				"НДФЛ", "");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.ПрочиеВычетыФизическихЛицИПН", 						"Период", 				"НДФЛ", "");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.НалогообложениеНачислений", 							"Период", 				"НДФЛ", "");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.ПорядокОкругленияРезультатовРасчетаЗарплаты", 		"Период", 				"НДФЛ", "Организация");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.СведенияОПенсионномОбеспеченииФизическихЛиц", 		"ДатаРегистрацииИзменений", "НДФЛ", "");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.СведенияОСтавкахИПН", 								"Период", 				"НДФЛ", "Организация");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.СведенияОСтавкахНалоговСборовОтчислений", 			"Период", 				"НДФЛ", "Организация");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.СведенияОСтавкахОСМС", 								"Период", 				"НДФЛ", "Организация");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.СведенияОДоляхЕП", 									"Период", 				"НДФЛ", "");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "РегистрСведений.СведенияОФизическихЛицахУчастникахВОВ", 				"ДатаРегистрацииИзменений", "НДФЛ", "");
