	ПолеОформления = ЭлементОформления.Поля.Элементы.Добавить();
	ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("НачисленияСН");
	
	ЭлементОформления = Форма.УсловноеОформление.Элементы.Добавить();
	// Вид оформления
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
	// Условие для оформления
	ЭлементОтбора = ЭлементОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.Равно;
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("УчитыватьСО");
	ЭлементОтбора.ПравоеЗначение = Ложь;
	// Оформляемое поле
	ПолеОформления = ЭлементОформления.Поля.Элементы.Добавить();
	ПолеОформления.Поле = Новый ПолеКомпоновкиДанных("НачисленияСО");
		
КонецПроцедуры

Функция РеквизитВходитВСписокНеиспользуемых(Реквизит) Экспорт
	
	ПодстрокиНеиспользуемыхРеквизитов = Новый Массив;
	ПодстрокиНеиспользуемыхРеквизитов.Добавить("НДФЛ");
	ПодстрокиНеиспользуемыхРеквизитов.Добавить("ЕНВД");
	ПодстрокиНеиспользуемыхРеквизитов.Добавить("ОГРН");
	ПодстрокиНеиспользуемыхРеквизитов.Добавить("ДНР, ЛНР");
	ПодстрокиНеиспользуемыхРеквизитов.Добавить("БИК РКЦ");
	ПодстрокиНеиспользуемыхРеквизитов.Добавить(ВРег("(не используется)"));
	ПодстрокиНеиспользуемыхРеквизитов.Добавить(ВРег("районный коэффициент"));
	ПодстрокиНеиспользуемыхРеквизитов.Добавить(ВРег("районному коэффициенту"));
	ПодстрокиНеиспользуемыхРеквизитов.Добавить(ВРег("северная надбавка"));
	ПодстрокиНеиспользуемыхРеквизитов.Добавить(ВРег("северной надбавки"));
	
	НаименованиеРеквизита = ВРег(Реквизит);
	Для Каждого Подстрока Из ПодстрокиНеиспользуемыхРеквизитов Цикл
		Если СтрНайти(НаименованиеРеквизита, Подстрока) > 0 Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

// Заполнение сведений о показателях, используемых при расчете результата предопределенным способом.
//
// Параметры:
//	- ТаблицаПоказателей - таблица значений с колонками
//		СпособРасчета.
//		Показатель
//
Процедура ОбработатьПоказателиПредопределенногоСпособа(СпособРасчета, ВидОперацииПоЗарплате, ТаблицаПоказателей) Экспорт
	
	// Исполнительные листы
	Если СпособРасчета = Перечисления.СпособыРасчетаУдержаний.ИсполнительныйЛист
		И ВидОперацииПоЗарплате = Перечисления.ВидыОперацийПоЗарплате.АлиментыПрочиеИсполнительныеЛистыКонтрагенты Тогда
		
		НоваяСтрока = ТаблицаПоказателей.Добавить();
		НоваяСтрока.Показатель = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ИсчисленныйПоИсполнительномуЛистуСО");
		НоваяСтрока.ИспользоватьПриРасчете = Истина;
		
	ИначеЕсли СпособРасчета = Перечисления.СпособыРасчетаУдержаний.ИсполнительныйЛист
		И ВидОперацииПоЗарплате = Перечисления.ВидыОперацийПоЗарплате.АлиментыПрочиеИсполнительныеЛисты Тогда
		
		НоваяСтрока = ТаблицаПоказателей.Добавить();
		НоваяСтрока.Показатель = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ИсчисленныйПоИсполнительномуЛистуЕП");
		НоваяСтрока.ИспользоватьПриРасчете = Истина;

	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти