//@strict-types

#Область СлужебныйПрограммныйИнтерфейс

// Параметры:
//  Форма - ФормаКлиентскогоПриложения: См. Обработка.ПоискРезюмеВИнтернете.Форма.Форма
Процедура ФормаПоискаКандидатовПриСозданииНаСервере(Форма) Экспорт
	
	МенеджерСайтов = РекрутинговыеСайты.МенеджерРекрутинговыхСайтов();
	
	Сайты = МенеджерСайтов.Сайты();
	ДанныеСайтов = МенеджерСайтов.ДанныеСайтов();
	
	СайтыСДоступнымПоиском = Новый Массив(); // Массив из СправочникСсылка.ИсточникиИнформацииОКандидатах
	
	Форма.Сайты = Новый ФиксированныйМассив(СайтыСДоступнымПоиском); //@skip-check property-return-type
	Форма.ДанныеСайтов = ДанныеСайтов; //@skip-check property-return-type
	
	Для Каждого Сайт Из Сайты Цикл
		ДанныеСайта = ДанныеСайтов[Сайт]; // См. РекрутинговыеСайтыСлужебный.НовыеДанныеСайта
		Если ДанныеСайта.ДоступенПоискРезюме Тогда
			СайтыСДоступнымПоиском.Добавить(Сайт);
		КонецЕсли;
	КонецЦикла;
	
	Если ЗначениеЗаполнено(СайтыСДоступнымПоиском) Тогда
		ПодключенныеСайты = Новый Массив(); // Массив из СправочникСсылка.ИсточникиИнформацииОКандидатах
		
		РезультатПроверкиПодключения = РекрутинговыеСайты.ПроверитьПодключение(СайтыСДоступнымПоиском);
		
		Для каждого КлючИЗначение Из РезультатПроверкиПодключения Цикл
			РеквизитыСайта = КлючИЗначение.Значение;
			Если РеквизитыСайта.Подключен Тогда
				ПодключенныеСайты.Добавить(КлючИЗначение.Ключ);
			КонецЕсли;
		КонецЦикла;
		
		Если ПодключенныеСайты.Количество() <> 0 Тогда
			МенеджерСайтов = РекрутинговыеСайты.МенеджерРекрутинговыхСайтов(ПодключенныеСайты);
			ДанныеСайтов = МенеджерСайтов.ДанныеСайтов();
			
			ФормаПоискаКандидатовДобавитьРеквизиты(Форма, ПодключенныеСайты, ДанныеСайтов);
			
			ФормаПоискаКандидатовДобавитьЭлементы(Форма, ПодключенныеСайты, ДанныеСайтов);
			
			ФормаПоискаКандидатовУстановитьТекстПодсказки(Форма, МенеджерСайтов);
			
			Форма.Сайты = МенеджерСайтов.Сайты(); //@skip-check property-return-type
			Форма.ДанныеСайтов = ДанныеСайтов; //@skip-check property-return-type
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  Форма - ФормаКлиентскогоПриложения: См. Справочник.Вакансии.Форма.ФормаСписка
Процедура ФормаСпискаВакансийПриСозданииНаСервере(Форма) Экспорт
	
	ФормаСпискаВакансийСоздатьКомандыЗагрузкиССайта(Форма);
	
КонецПроцедуры

// Параметры:
//  Форма - ФормаКлиентскогоПриложения: См. Справочник.Вакансии.Форма.ФормаСписка -
Процедура ФормаСпискаВакансийПриИзмененииНастроекДоступаКСайтам(Форма) Экспорт
	
	ПодчиненныеЭлементы = Форма.Элементы.КоманднаяПанельФормы.ПодчиненныеЭлементы.ФормаЗагрузить.ПодчиненныеЭлементы;
	
	КоличествоЭлементов = ПодчиненныеЭлементы.Количество();
	ЭлементыДляУдаления = Новый Массив; // Массив Из КнопкаФормы
	Для Индекс = 0 По КоличествоЭлементов - 1 Цикл
		ЭлементыДляУдаления.Добавить(ПодчиненныеЭлементы.Получить(Индекс));
	КонецЦикла;
	
	Для Каждого ЭлементДляУдаления Из ЭлементыДляУдаления Цикл
		Форма.Элементы.Удалить(ЭлементДляУдаления);
	КонецЦикла;
	
	Форма.СоответствиеКомандИСайтов = НовоеСоответствиеКомандИСайтов(); // @skip-check property-return-type
	
	ФормаСпискаВакансийСоздатьКомандыЗагрузкиССайта(Форма);
	
КонецПроцедуры

#Область ФормаЭлементаВакансии

// Параметры:
//  Строки - СтрокиДинамическогоСписка Из КлючИЗначение:
//  * Ключ - РегистрСведенийКлючЗаписи.ПубликацияВакансий
//  *Значение - СтрокаДинамическогоСписка:
// * Данные - ДанныеФормыСтруктура
Процедура ФормаЭлементаВакансииПубликацииПриПолученииДанныхНаСервере(Строки) Экспорт
	
	Для Каждого Строка Из Строки Цикл
		ФормаЭлементаВакансииЗаполнитьДатуСобытияВСтроке(Строка.Значение.Данные);
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  Форма - См. Справочник.Вакансии.Форма.ФормаЭлемента
Процедура ФормаЭлементаВакансииПриПолученииДанныхНаСервере(Форма) Экспорт
	
	Если Не ПравоДоступа("Чтение", Метаданные.РегистрыСведений.НастройкиИнтеграцииРекрутинговыхСайтов) Тогда
		Возврат;
	КонецЕсли;
	
	ФормаЭлементаВакансииУстановитьУсловноеОформление(Форма.Публикации);
	ФормаЭлементаВакансииНастроитьКомандыПубликацииВакансии(Форма);
	
КонецПроцедуры

// Параметры:
//  Форма - См. Справочник.Вакансии.Форма.ФормаЭлемента
Процедура ФормаЭлементаВакансииОбработатьОповещенияПубликацииВакансий(Форма) Экспорт
	
	ПодчиненныеЭлементы =
		Форма.Элементы.Публикации.КоманднаяПанель.ПодчиненныеЭлементы.ГруппаОпубликовать.ПодчиненныеЭлементы;
	
	КоличествоЭлементов = ПодчиненныеЭлементы.Количество();
	ЭлементыДляУдаления = Новый Массив; // Массив Из КнопкаФормы
	
	Для Индекс = 0 По КоличествоЭлементов - 1 Цикл
		ЭлементыДляУдаления.Добавить(ПодчиненныеЭлементы.Получить(Индекс));
	КонецЦикла;
	
	Для Каждого ЭлементДляУдаления Из ЭлементыДляУдаления Цикл
		Форма.Элементы.Удалить(ЭлементДляУдаления);
	КонецЦикла;
	
	Форма.СоответствиеКомандИСайтов = Новый ФиксированноеСоответствие(Новый Соответствие); // @skip-check property-return-type
	
	ФормаЭлементаВакансииНастроитьКомандыПубликацииВакансии(Форма);
	
КонецПроцедуры

#КонецОбласти

Функция НовыйРеквизит(Имя, Тип, Заголовок = "", Путь = "", СохраняемыеДанные = Ложь) Экспорт
	
	Возврат Новый РеквизитФормы(Имя, Тип, Путь, СтрШаблон(НСтр("ru = '%1'"), Заголовок), СохраняемыеДанные);
	
КонецФункции

// Параметры:
//  Элемент - ПолеФормы
Процедура УстановитьВидимостьЭлементаФормы(Элемент) Экспорт
	
	Элемент.Видимость = РекрутинговыеСайты.ДоступнаИнтеграцияРекрутинговыхСайтов();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ФормаПоискаКандидатов

// Параметры:
//  Форма - См. Обработка.НастройкаДоступаКРекрутинговымСайтам.Форма.ФормаНастройкиДоступа
//  Сайты - Массив Из СправочникСсылка.ИсточникиИнформацииОКандидатах
//  ДанныеСайтов - См. РекрутинговыеСайтыСлужебный.ДанныеСайтов
Процедура ФормаПоискаКандидатовДобавитьРеквизиты(Форма, Сайты, ДанныеСайтов)
	
	ДобавляемыеРеквизиты = Новый Массив(); // Массив из РеквизитФормы
	
	Для Каждого Сайт Из Сайты Цикл
		
		ДанныеСайта = ДанныеСайтов[Сайт]; // См. РекрутинговыеСайтыСлужебный.НовыеДанныеСайта
		
		Если Не ДанныеСайта.ДоступенПоискРезюме Или Не ЗначениеЗаполнено(ДанныеСайта.Имя) Тогда
			Продолжить;
		КонецЕсли;
		
		Имя = "ВсегоКандидатов" + ДанныеСайта.Имя;
		Тип = ОбщегоНазначения.ОписаниеТипаЧисло(10);
		Реквизит = НовыйРеквизит(Имя, Тип);
		ДобавляемыеРеквизиты.Добавить(Реквизит);
		
		Имя = "ЗагруженоКандидатов" + ДанныеСайта.Имя;
		Тип = ОбщегоНазначения.ОписаниеТипаЧисло(10);
		Реквизит = НовыйРеквизит(Имя, Тип);
		ДобавляемыеРеквизиты.Добавить(Реквизит);
		
		Имя = "НомерПорции" + ДанныеСайта.Имя;
		Тип = ОбщегоНазначения.ОписаниеТипаЧисло(10);
		Реквизит = НовыйРеквизит(Имя, Тип);
		ДобавляемыеРеквизиты.Добавить(Реквизит);
		
		Имя = "ОбластьПоиска" + ДанныеСайта.Имя;
		Тип = Новый ОписаниеТипов("Булево");
		Реквизит = НовыйРеквизит(Имя, Тип);
		ДобавляемыеРеквизиты.Добавить(Реквизит);
		
	КонецЦикла;
	
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
КонецПроцедуры

// Параметры:
//  Форма - См. Обработка.НастройкаДоступаКРекрутинговымСайтам.Форма.ФормаНастройкиДоступа
//  Сайты - Массив Из СправочникСсылка.ИсточникиИнформацииОКандидатах
//  ДанныеСайтов - См. РекрутинговыеСайтыСлужебный.ДанныеСайтов
Процедура ФормаПоискаКандидатовДобавитьЭлементы(Форма, Сайты, ДанныеСайтов)
	
	Родитель = Форма.Элементы.ГруппаРекрутинговыеСайты;
	
	Для Каждого Сайт Из Сайты Цикл
		ДанныеСайта = ДанныеСайтов[Сайт]; // См. РекрутинговыеСайтыСлужебный.НовыеДанныеСайта
		
		Если Не ДанныеСайта.ДоступенПоискРезюме Или Не ЗначениеЗаполнено(ДанныеСайта.Имя) Тогда
			Продолжить;
		КонецЕсли;
		
		Элемент = Форма.Элементы.Добавить("ОбластьПоиска" + ДанныеСайта.Имя, Тип("ПолеФормы"), Родитель);
		Элемент.Вид = ВидПоляФормы.ПолеФлажка;
		Элемент.Видимость = Ложь;
		Элемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
		Элемент.Заголовок = ДанныеСайта.Представление;
		Элемент.ПутьКДанным = Элемент.Имя;
		Элемент.УстановитьДействие("ПриИзменении", "Подключаемый_ИскатьНаСайтеПриИзменении");
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  Форма - См. Обработка.НастройкаДоступаКРекрутинговымСайтам.Форма.ФормаНастройкиДоступа
//  МенеджерСайтов - ОбработкаОбъект.МенеджерИнтеграцииСРекрутинговымиСайтами
Процедура ФормаПоискаКандидатовУстановитьТекстПодсказки(Форма, МенеджерСайтов)
	
	Сайты = МенеджерСайтов.Сайты();
	ДанныеСайтов = МенеджерСайтов.ДанныеСайтов();
	
	Для Каждого Сайт Из Сайты Цикл
		
		ДанныеСайта = ДанныеСайтов[Сайт]; // См. РекрутинговыеСайтыСлужебный.НовыеДанныеСайта
		
		Если Не ДанныеСайта.ДоступенПоискРезюме Или Не ЗначениеЗаполнено(ДанныеСайта.Имя) Тогда
			Продолжить;
		КонецЕсли;
		
		Элемент = Форма.Элементы["ОбластьПоиска" + ДанныеСайта.Имя];
		
		Если ДанныеСайта.ПоискОграничиваетсяТарифом Тогда
			
			ПоискДоступен = МенеджерСайтов.ПоискДоступен(Сайт);
			
			Если ПоискДоступен = Истина Тогда
				Элемент.ОтображениеПодсказки = ОтображениеПодсказки.Нет;
			ИначеЕсли ПоискДоступен = Ложь Тогда
				Форма["ОбластьПоиска" + ДанныеСайта.Имя] = Ложь;
				Элемент.Доступность = Ложь;
				Элемент.ОтображениеПодсказки = ОтображениеПодсказки.Кнопка;
				
				ПерсональныйМенеджер = МенеджерСайтов.ДанныеПерсональногоМенеджера(Сайт);
				
				ФИО = ПерсональныйМенеджер.Имя + " " + ПерсональныйМенеджер.Фамилия;
				ФизическиеЛицаЗарплатаКадры.Просклонять(ФИО, 2, ФИО);
				
				Подсказка = СтрШаблон(НСтр("ru = 'Поиск %1 с вашим тарифом недоступен.'"), ДанныеСайта.Представление);
				
				Если Не ПустаяСтрока(ДанныеСайта.ПодробностиОграниченияПоискаСсылка) Тогда
					Подсказка = Подсказка
						+ СтрШаблон(НСтр("ru = '|Подробности по ссылке <a href=""%1""></a>'"),
							ДанныеСайта.ПодробностиОграниченияПоискаСсылка);
				КонецЕсли;
				
				Если Не ПустаяСтрока(ФИО) Тогда
					Подсказка = СтрШаблон(НСтр("ru = '%1 или у вашего персонального менеджера %2'"), Подсказка, ФИО);
				КонецЕсли;
				
				Если Не ПустаяСтрока(ПерсональныйМенеджер.ЭлектроннаяПочта) Тогда
					Подсказка = СтрШаблон(НСтр("ru = '%1 <a href=""mailto:%1"">%2</a>'"),
						Подсказка, ПерсональныйМенеджер.ЭлектроннаяПочта);
				КонецЕсли;
				
				Элемент.РасширеннаяПодсказка.Заголовок = СтроковыеФункции.ФорматированнаяСтрока(Подсказка);
			КонецЕсли;
			
		Иначе
			Элемент.ОтображениеПодсказки = ОтображениеПодсказки.Нет;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ФормаСпискаВакансий

// Параметры:
//  Форма - ФормаКлиентскогоПриложения: См. Справочник.Вакансии.Форма.ФормаСписка
Процедура ФормаСпискаВакансийСоздатьКомандыЗагрузкиССайта(Форма)
	
	Если Не ПравоДоступа("Чтение", Метаданные.РегистрыСведений.НастройкиИнтеграцииРекрутинговыхСайтов) Тогда
		Возврат;
	КонецЕсли;
	
	Если Не РекрутинговыеСайты.ИспользуетсяИнтеграцияРекрутинговыхСайтов() Тогда
		Возврат;
	КонецЕсли;
	
	НастроенныеСайты = РекрутинговыеСайты.НастроенныеСайты();
	ДанныеСайтов = РекрутинговыеСайты.ДанныеСайтов(НастроенныеСайты);
	
	Если НастроенныеСайты.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	// @skip-check property-return-type
	СоответствиеКомандИСайтов = Форма.СоответствиеКомандИСайтов; // ФиксированноеСоответствие
	
	Если ЗначениеЗаполнено(СоответствиеКомандИСайтов) Тогда
		СоответствиеКомандИСайтовПромежуточное = 
			РекрутинговыеСайтыСлужебный.СоответствиеПоФиксированномуСоответствию(СоответствиеКомандИСайтов);
	Иначе
		СоответствиеКомандИСайтовПромежуточное = Новый Соответствие;
	КонецЕсли;
	
	Для Каждого Сайт Из НастроенныеСайты Цикл
		
		ДанныеСайта = ДанныеСайтов[Сайт]; // См. РекрутинговыеСайтыСлужебный.НовыеДанныеСайта
		
		Если Не ДанныеСайта.ДоступнаЗагрузкаВакансий Тогда
			Продолжить;
		КонецЕсли;
		
		ЕстьМенюДляСайта = Ложь;
		Если ЗначениеЗаполнено(СоответствиеКомандИСайтов) Тогда
			Для Каждого ЭлементСоответствия Из СоответствиеКомандИСайтов Цикл
				Если ЭлементСоответствия.Значение = Сайт Тогда // @skip-check property-return-type
					ЕстьМенюДляСайта = Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		Если Не ЕстьМенюДляСайта Тогда
			ФормаСпискаВакансийСоздатьКомандуЗагрузкиССайта(
				Форма, ДанныеСайта.Представление, Сайт, СоответствиеКомандИСайтовПромежуточное);
		КонецЕсли;
		
	КонецЦикла;
	
	// @skip-check property-return-type
	Форма.СоответствиеКомандИСайтов = Новый ФиксированноеСоответствие(СоответствиеКомандИСайтовПромежуточное);
	
КонецПроцедуры

#КонецОбласти

#Область ФормаЭлементаВакансии

// Возвращаемое значение:
//  ФиксированноеСоответствие Из КлючИЗначение:
// * Ключ - Строка
// * Значение - СправочникСсылка.ИсточникиИнформацииОКандидатах
Функция НовоеСоответствиеКомандИСайтов()
	
	Возврат Новый ФиксированноеСоответствие(Новый Соответствие());
	
КонецФункции

Процедура ФормаСпискаВакансийСоздатьКомандуЗагрузкиССайта(Форма, Заголовок, Сайт, СоответствиеКомандИСайтов)
	
	ИдентификаторКоманды = РекрутинговыеСайтыКлиентСервер.УникальноеИмяРеквизита();
	
	// Добавляем команду
	НоваяКоманда = Форма.Команды.Добавить("ЗагрузкаССайта_" + ИдентификаторКоманды);
	НоваяКоманда.Заголовок	= Заголовок;
	НоваяКоманда.Действие	= "Подключаемый_КомандаЗагрузитьССайта";
	
	// Определяем в какое подменю, добавить кнопку
	ГруппаКнопок = Форма.Элементы.КоманднаяПанельФормы.ПодчиненныеЭлементы.ФормаЗагрузить;
	
	// Добавляем кнопку
	Кнопка = Форма.Элементы.Добавить("ЗагрузкаССайта_" + ИдентификаторКоманды, Тип("КнопкаФормы"), ГруппаКнопок); 
	Кнопка.ИмяКоманды	= НоваяКоманда.Имя;
	Кнопка.Заголовок	= Заголовок;
	
	СоответствиеКомандИСайтов.Вставить(НоваяКоманда.Имя, Сайт);
	
КонецПроцедуры

// Параметры:
//  ДанныеСтроки - ДанныеФормыСтруктура:
//  * ДатаПубликации - Дата
//  * ДатаСнятияСПубликации - Дата
//  * ДатаОбновления - Дата
//  * ДатаСобытияСтрокой - Строка
Процедура ФормаЭлементаВакансииЗаполнитьДатуСобытияВСтроке(ДанныеСтроки)
	
	ДатаСобытия = ДанныеСтроки.ДатаПубликации;
	
	СобытиеСтрокой = НСтр("ru = 'Опубликована'");
	ДатаСобытияСтрокой = "";
	
	Если ЗначениеЗаполнено(ДанныеСтроки.ДатаСнятияСПубликации) Тогда
		ДатаСобытия = ДанныеСтроки.ДатаСнятияСПубликации;
		СобытиеСтрокой = НСтр("ru = 'Снята с публикации'");
	Иначе
		Если ДанныеСтроки.ДатаОбновления > ДанныеСтроки.ДатаПубликации Тогда
			ДатаСобытия = ДанныеСтроки.ДатаОбновления;
			СобытиеСтрокой = НСтр("ru = 'Обновлена'");
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ДатаСобытия) Тогда
		Возврат;
	КонецЕсли;
	
	Сегодня = НачалоДня(ТекущаяДатаСеанса());
	
	Если ДатаСобытия > Сегодня Тогда
		ДатаСобытияСтрокой = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'сегодня в %1'"), 
			Формат(ДатаСобытия, "ДФ=ЧЧ:мм"));
	Иначе
		Если ДатаСобытия > НачалоДня(Сегодня - 1) Тогда // @skip-check invocation-parameter-type-intersect
			ДатаСобытияСтрокой = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'вчера в %1'"), 
				Формат(ДатаСобытия, "ДФ=ЧЧ:мм"));
		Иначе
			ДатаСобытияСтрокой = Формат(ДатаСобытия, "ДФ=ддд") + " " + Формат(ДатаСобытия, "ДЛФ=DT");
		КонецЕсли;
	КонецЕсли;
	
	ДанныеСтроки.ДатаСобытияСтрокой = СобытиеСтрокой + " " + ДатаСобытияСтрокой;
	
КонецПроцедуры

// Параметры:
//  Список - ДинамическийСписок
Процедура ФормаЭлементаВакансииУстановитьУсловноеОформление(Список)
	
	Элемент = Список.УсловноеОформление.Элементы.Добавить();
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ТекстЗапрещеннойЯчейкиЦвет);
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Элемент.Отбор, "ДатаСнятияСПубликации", '00010101', ВидСравненияКомпоновкиДанных.НеРавно); // @skip-check invocation-parameter-type-intersect
	
КонецПроцедуры

// Параметры:
//  Форма - ФормаКлиентскогоПриложения:
// * СоответствиеКомандИСайтов - См. НовоеСоответствиеКомандИСайтов
// * ВакансияСсылка - СправочникСсылка.Вакансии
// * ИспользуемыеСайты - Массив Из СправочникСсылка.ИсточникиИнформацииОКандидатах
Процедура ФормаЭлементаВакансииНастроитьКомандыПубликацииВакансии(Форма)
	
	Если Не ПравоДоступа("Чтение", Метаданные.РегистрыСведений.НастройкиИнтеграцииРекрутинговыхСайтов) Тогда
		Возврат;
	КонецЕсли;
	
	АктуальныеСайты = РекрутинговыеСайты.НастроенныеСайты();
	Если Не ЗначениеЗаполнено(АктуальныеСайты) Тогда
		Возврат;
	КонецЕсли;
	
	СайтыСПубликациейВакансии = РекрутинговыеСайты.СайтыСПубликациейВакансии(Форма.ВакансияСсылка, АктуальныеСайты);
	СайтыБезПубликации = ОбщегоНазначенияКлиентСервер.РазностьМассивов(АктуальныеСайты, СайтыСПубликациейВакансии);
	
	Если ЗначениеЗаполнено(Форма.СоответствиеКомандИСайтов) Тогда
		СоответствиеКомандИСайтовПромежуточное =
			РекрутинговыеСайтыСлужебный.СоответствиеПоФиксированномуСоответствию(Форма.СоответствиеКомандИСайтов);
	Иначе
		СоответствиеКомандИСайтовПромежуточное = Новый Соответствие;
	КонецЕсли;
	
	ДанныеСайтов = РекрутинговыеСайтыСлужебный.ДанныеСайтов(СайтыБезПубликации);
	
	Для Каждого Сайт Из СайтыБезПубликации Цикл
		ЕстьКомандаМенюДляСайта = Ложь;
		Если ЗначениеЗаполнено(Форма.СоответствиеКомандИСайтов) Тогда
			Для Каждого ЭлементСоответствия Из Форма.СоответствиеКомандИСайтов Цикл
				Если ЭлементСоответствия.Значение = Сайт Тогда
					ЕстьКомандаМенюДляСайта = Истина;
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		ДанныеСайта = ДанныеСайтов[Сайт]; // См. РекрутинговыеСайтыСлужебный.НовыеДанныеСайта
		
		Если Не ЕстьКомандаМенюДляСайта Тогда
			ФормаЭлементаВакансииСоздатьКомандуПубликацииНаСайте(
				Форма, Сайт, ДанныеСайта.Представление, СоответствиеКомандИСайтовПромежуточное);
		КонецЕсли;
	КонецЦикла;
	
	Форма.ИспользуемыеСайты = АктуальныеСайты;
	Форма.СоответствиеКомандИСайтов = Новый ФиксированноеСоответствие(СоответствиеКомандИСайтовПромежуточное);
	
КонецПроцедуры

// Параметры:
//  Форма - ФормаКлиентскогоПриложения: См. Справочник.Вакансии.Форма.ФормаЭлемента
//  Заголовок - Строка
//  СоответствиеКомандИСайтов - Соответствие Из КлючИЗначение:
// * Ключ - Строка
// * Значение - СправочникСсылка.ИсточникиИнформацииОКандидатах
Процедура ФормаЭлементаВакансииСоздатьКомандуПубликацииНаСайте(Форма, Сайт, Заголовок, СоответствиеКомандИСайтов)
	
	ИдентификаторКоманды = РекрутинговыеСайтыКлиентСервер.УникальноеИмяРеквизита();
	
	// Добавляем команду
	НоваяКоманда = Форма.Команды.Добавить("ПубликацияНаСайт_" + ИдентификаторКоманды);
	НоваяКоманда.Заголовок	= Заголовок;
	НоваяКоманда.Действие	= "Подключаемый_ОпубликоватьНаСайте";
	
	// Определяем в какое подменю, добавить кнопку
	ГруппаКнопок = Форма.Элементы.Публикации.КоманднаяПанель.ПодчиненныеЭлементы.ГруппаОпубликовать;
	
	// Добавляем кнопку
	Кнопка = Форма.Элементы.Добавить("ПубликацияНаСайт_" + ИдентификаторКоманды, Тип("КнопкаФормы"), ГруппаКнопок); 
	Кнопка.ИмяКоманды	= НоваяКоманда.Имя;
	Кнопка.Заголовок	= Заголовок;
	
	СоответствиеКомандИСайтов.Вставить(НоваяКоманда.Имя, Сайт);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти
