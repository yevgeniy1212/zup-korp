// @strict-types

#Область СлужебныеПроцедурыИФункции

// Таблица этапов работы обработка выбора.
// 
// Параметры:
//  Форма - Форма
//  ЭтапыРаботыСКандидатами - см. Справочник.Вакансии.ЭтапыРаботыСКандидатами
//  ВыбранныеЭтапы - Массив Из СправочникСсылка.ЭтапыРаботыСКандидатами
Процедура ТаблицаЭтаповРаботыОбработкаВыбора(Форма, ЭтапыРаботыСКандидатами, ВыбранныеЭтапы) Экспорт
	
	Форма.Модифицированность = Истина;
	МестоВставки = МестоПервогоПредопределенногоЭтапа(ЭтапыРаботыСКандидатами);
	Для Каждого ВыбранныйЭтап Из ВыбранныеЭтапы Цикл
		ЭтапыРаботыСКандидатами.Вставить(МестоВставки).ЭтапРаботы = ВыбранныйЭтап;
		МестоВставки = МестоВставки + 1;
	КонецЦикла;
	
КонецПроцедуры

// Место первого предопределенного этапа.
// 
// Параметры:
//  ЭтапыРаботыСКандидатами - см. Справочник.Вакансии.ЭтапыРаботыСКандидатами
// 
// Возвращаемое значение:
//  Число - Место первого предопределенного этапа
Функция МестоПервогоПредопределенногоЭтапа(ЭтапыРаботыСКандидатами)
	
	НайденныеСтроки = ЭтапыРаботыСКандидатами.НайтиСтроки(
		Новый Структура("ЭтапРаботы", ПредопределенноеЗначение("Перечисление.ЭтапыРаботыСКандидатами.Утверждение")));
	
	Если НайденныеСтроки.Количество() = 0 Тогда
		Возврат ЭтапыРаботыСКандидатами.Количество();
	КонецЕсли;
	
	Возврат ЭтапыРаботыСКандидатами.Индекс(НайденныеСтроки[0]);
	
КонецФункции

// Изменить порядок этапа.
// Поддерживается перемещение этапов со следующими ограничениями:
// - последовательность предопределенных этапов не может быть изменена
// - этап решения о приеме на работу следует непосредственно за утверждением.
// 
// Параметры:
//  ЭтапыРаботыСКандидатами - см. Справочник.Вакансии.ЭтапыРаботыСКандидатами
//  ДанныеЭтапа - СтрокаТабличнойЧасти - см. Справочник.Вакансии.ЭтапыРаботыСКандидатами
//  Направление - Число -  если 1, то - вниз, если -1 - вверх
//  Сведения - Неопределено 
//			 - см. ПодборПерсоналаВызовСервера.СведенияОбЭтапах
Процедура ИзменитьПорядокЭтапа(ЭтапыРаботыСКандидатами, ДанныеЭтапа, Направление, Сведения = Неопределено) Экспорт
	
	ОбщегоНазначенияКлиентСервер.Проверить(Направление = 1 Или Направление = -1, 
		СтрШаблон(НСтр("ru = 'Значение параметра Направление задано неверно.
					   |Ожидается Число 1 или -1, фактически передано %1.'"), Направление), 
		"ПодборПерсоналаФормыКлиент.ИзменитьПорядокЭтапа");
	
	ТекущийИндекс = ЭтапыРаботыСКандидатами.Индекс(ДанныеЭтапа);
	ЦелевойИндекс = ТекущийИндекс + Направление;
	
	Если Не ИндексВГраницах(ЭтапыРаботыСКандидатами, ЦелевойИндекс) Тогда
		Возврат;
	КонецЕсли;
	
	ТекущийЭтап = ЭтапыРаботыСКандидатами[ТекущийИндекс].ЭтапРаботы; // СтрокаТабличнойЧасти
	ЦелевойЭтап = ЭтапыРаботыСКандидатами[ЦелевойИндекс].ЭтапРаботы; // СтрокаТабличнойЧасти
	
	Если Сведения = Неопределено Тогда
		Сведения = ПодборПерсоналаВызовСервера.СведенияОбЭтапах(
			ОбщегоНазначенияБЗККлиентСервер.ЗначенияВМассиве(ТекущийЭтап, ЦелевойЭтап));
	КонецЕсли;
	
	Если Сведения[ТекущийЭтап].Предопределенный И Сведения[ЦелевойЭтап].Предопределенный Тогда
		// Предопределенным этапам не разрешается изменять положение относительно друг друга.
		Возврат;
	КонецЕсли;
	
	Если Сведения[ТекущийЭтап].СтрогоПоследовательный Тогда
		// Переносим всю последовательность вверх или вниз,
		// а для этого, чтобы не переносить последовательность по одному, переносим через нее.
		ИзменитьПорядокЭтапа(ЭтапыРаботыСКандидатами, ЭтапыРаботыСКандидатами[ЦелевойИндекс], - Направление, Сведения);
		Возврат;
	КонецЕсли;

	Если Сведения[ЦелевойЭтап].СтрогоПоследовательный Тогда
		// Увеличиваем направление на размер последовательности.
		Пока ИндексВГраницах(ЭтапыРаботыСКандидатами, ЦелевойИндекс + Направление) 
			И ПринадлежитПоследовательности(ЭтапыРаботыСКандидатами[ЦелевойИндекс + Направление].ЭтапРаботы, 
				Сведения[ЦелевойЭтап].Последовательность) Цикл
			ЦелевойИндекс = ЦелевойИндекс + Направление;
		КонецЦикла;
	КонецЕсли;
	
	ЭтапыРаботыСКандидатами.Сдвинуть(ТекущийИндекс, ЦелевойИндекс - ТекущийИндекс);
	
КонецПроцедуры

// Индекс в границах.
// 
// Параметры:
//  Коллекция - ТабличнаяЧасть
//  Индекс - Число
// 
// Возвращаемое значение:
//  Булево - Индекс в границах
Функция ИндексВГраницах(Коллекция, Индекс)
	Возврат Индекс >= 0 И Индекс < Коллекция.Количество();
КонецФункции

// Принадлежит последовательности.
// 
// Параметры:
//  Элемент - Произвольный
//  Последовательность - Массив из Произвольный
// 
// Возвращаемое значение:
//  Булево - Принадлежит последовательности
Функция ПринадлежитПоследовательности(Элемент, Последовательность)
	Возврат Последовательность.Найти(Элемент) <> Неопределено;
КонецФункции

// Обработка навигационной ссылки этапа кандидатов.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения
//  Вакансия - СправочникСсылка.Вакансии
//  НавигационнаяСсылка - Строка -
//  СтандартнаяОбработка - Булево -
Процедура ОбработкаНавигационнойСсылкиЭтапаКандидатов(Форма, Вакансия, НавигационнаяСсылка, СтандартнаяОбработка) Экспорт
	
	Если СтрНайти(НавигационнаяСсылка, "ЭтапКандидата_") = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	
	ПараметрыФормы = Новый Структура("Отбор", Новый Структура());
	ПараметрыФормы.Отбор.Вставить("Вакансия", Вакансия);
	ПараметрыФормы.Отбор.Вставить("ЭтапРаботы", 
		ПодборПерсоналаВызовСервера.ЭтапКандидатаПоНавигационнойСсылке(НавигационнаяСсылка));
	
	ОткрытьФорму("Справочник.Кандидаты.ФормаСписка", ПараметрыФормы, Форма);
	
КонецПроцедуры

// Обработка события ПередУдалением таблицы этапов работы в формах вакансии и профилей.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения
//  ЭтапыТаблицаФормы - ТаблицаФормы
//  ЭтапыДанныеФормы - ДанныеФормыКоллекция
//  Отказ - Булево
Процедура ЭтапыРаботыПередУдалением(Форма, ЭтапыТаблицаФормы, ЭтапыДанныеФормы, Отказ) Экспорт

	Для Каждого ВыделеннаяСтрока Из ЭтапыТаблицаФормы.ВыделенныеСтроки Цикл // Число
		СтрокаКоллекции = ЭтапыДанныеФормы.НайтиПоИдентификатору(ВыделеннаяСтрока); // СтрокаТабличнойЧасти: см. Справочник.Вакансии.ЭтапыРаботыСКандидатами
		Если Не ПодборПерсоналаВызовСервера.ЭтапРаботыМожноУдалить(СтрокаКоллекции.ЭтапРаботы) Тогда
			Отказ = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// После установки этапов по умолчанию.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения
//  Результат - см. ПодборПерсоналаФормы.УстановитьЭтапыПоУмолчанию
Процедура ПослеУстановкиЭтаповПоУмолчанию(Форма, Результат) Экспорт
	
	Если Результат.Добавленные.Количество() = 0 И Результат.Удаленные.Количество() = 0 Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Все обязательные этапы уже есть в таблице'"), , 
			НСтр("ru = 'Изменения не требуются'"));
		Возврат;
	КонецЕсли;

	ТекстИзменения = "";

	Если Результат.Добавленные.Количество() > 0 Тогда
		ТекстИзменения = ТекстИзменения + СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(
			НСтр("ru = ';%1 этап добавлен;;%1 этапа добавлены;%1 этапов добавлены;%1 этапа добавлены'"), 
			Результат.Добавленные.Количество())
	КонецЕсли;

	Если Результат.Удаленные.Количество() > 0 Тогда
		Если Не ПустаяСтрока(ТекстИзменения) Тогда
			ТекстИзменения = ТекстИзменения + ", ";
		КонецЕсли;
		ТекстИзменения = ТекстИзменения + СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(
			НСтр("ru = ';%1 этап удален;;%1 этапа удалены;%1 этапов удалены;%1 этапа удалены'"), 
			Результат.Удаленные.Количество())
	КонецЕсли;

	ПоказатьОповещениеПользователя(НСтр("ru = 'Обновлено'"), , ТекстИзменения);
	
КонецПроцедуры

#КонецОбласти