#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ШаблонОбработчикаПриОбработкеПередИзменением
Процедура ПриОбработкеПравилаРегистрацииПередИзменениемОбъекта(Объект, Отказ, Параметры) Экспорт
	ПриОбработкеПравилаРегистрации(Объект, Отказ, Ложь, Параметры);
КонецПроцедуры

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ШаблонОбработчикаПриОбработкеПослеИзменения
Процедура ПриОбработкеПравилаРегистрацииПослеИзмененияОбъекта(Объект, Отказ, Параметры) Экспорт
	Выгрузка = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Параметры, "Выгрузка", Ложь);
	ПриОбработкеПравилаРегистрации(Объект, Отказ, Выгрузка, Параметры);
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПриОбработкеПравилаРегистрации(Объект, Отказ, Выгрузка, Параметры)

	ИмяПроцедуры = "СинхронизацияДанныхБЗКОбработчикиОграничениеПоРеквизиту.ПриОбработкеПравилаРегистрации";
	
	ТекстОшибки = НСтр("ru = 'В параметре Параметры.ДополнительныеПараметры отсутствует свойство ""Реквизит""'");
	ОбщегоНазначенияКлиентСервер.Проверить(Параметры.ДополнительныеПараметры.Свойство("Реквизит"), ТекстОшибки,
		СтрШаблон(НСтр("ru = '%1'"), ИмяПроцедуры));
	
	Реквизит = Параметры.ДополнительныеПараметры.Реквизит;

	ОжидаемыеТипы = ОбщегоНазначенияБЗККлиентСервер.ЗначенияВМассиве(Тип("Строка"), Тип("ОбъектМетаданных"));	
	ОбщегоНазначенияКлиентСервер.ПроверитьПараметр(ИмяПроцедуры, "Реквизит", Реквизит, ОжидаемыеТипы);
		
	Если ТипЗнч(Реквизит) = Тип("Строка") Тогда
		ИмяРеквизита = Реквизит;
	ИначеЕсли ТипЗнч(Реквизит) = Тип("ОбъектМетаданных") Тогда
		ИмяРеквизита = Реквизит.Имя;
	КонецЕсли;
	
	СинхронизацияДанныхЗарплатаКадрыСервер.ОграничитьРегистрациюПодчиненногоОбъектаПоРегистрацииОбъектаВладельца(
		Объект, Отказ, Объект[ИмяРеквизита], Выгрузка, Параметры);
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли
