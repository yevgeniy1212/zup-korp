#Область СлужебныйПрограммныйИнтерфейс

// См. ШаблоныСообщенийПереопределяемый.ПриПодготовкеШаблонаСообщения
Процедура ПриПодготовкеШаблонаСообщения(Реквизиты, Вложения, НазначениеШаблона, ДополнительныеПараметры) Экспорт
	
	Если Не Метаданные.ОпределяемыеТипы.РассылаемыйДокумент.Тип.СодержитТип(
		ТипЗнч(ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(ДополнительныеПараметры["ПолноеИмяТипаНазначения"]).ПолучитьСсылку())) Тогда
		Возврат;
	КонецЕсли;

	ШаблоныСообщенийБЗК.ДополнитьШаблонРеквизитамиПолучателя(Реквизиты, Вложения, ДополнительныеПараметры);

КонецПроцедуры

// См. ШаблоныСообщенийПереопределяемый.ПриФормированииСообщения
Процедура ПриФормированииСообщения(Сообщение, НазначениеШаблона, ПредметСообщения, ПараметрыШаблона) Экспорт
	
	Если Не Метаданные.ОпределяемыеТипы.РассылаемыйДокумент.Тип.СодержитТип(ТипЗнч(ПредметСообщения)) Тогда
		Возврат;
	КонецЕсли;
	
	ШаблоныСообщенийБЗК.ЗаполнитьЗначенияПолучателяВДополнительныхРеквизитахШаблона(
		Сообщение, ПредметСообщения, ПараметрыШаблона);

КонецПроцедуры

// Добавляет колонки для описания команды с поддержкой рассылки документов по шаблону.
//   РассылатьПоШаблону - Булево - установите Истина, если рассылка будет выполняться по шаблонам писем.
//   ПредметШаблона - Строка - полное имя типа метаданных, являющегося предметом шаблона, например, Справочник.Кандидаты.
//   ВладелецШаблона - ОпределяемыйТип.ВладелецШаблонаСообщения - значение используемое для отбора контекстных шаблонов.
// 
// Параметры:
//  Команды - ТаблицаЗначений - см. РассылкаДокументов.НоваяТаблицаКомандРассылкиДокументов.
//
Процедура ПриСозданииТаблицыКомандРассылкиДокументов(Команды) Экспорт
	Команды.Колонки.Добавить("РассылатьПоШаблону", Новый ОписаниеТипов("Булево"));
	Команды.Колонки.Добавить("ПредметШаблона", Новый ОписаниеТипов("Строка"));
	Команды.Колонки.Добавить("ВладелецШаблона", Метаданные.ОпределяемыеТипы.ВладелецШаблонаСообщения.Тип);
КонецПроцедуры

Процедура ПриЗаполненииПараметровФормыПоКомандеРассылки(ПараметрыФормы, КомандаРассылки) Экспорт
	ПараметрыФормы.Вставить("РассылатьПоШаблону", КомандаРассылки.РассылатьПоШаблону);
	ПараметрыФормы.Вставить("ПредметШаблона", КомандаРассылки.ПредметШаблона);
	ПараметрыФормы.Вставить("ВладелецШаблона", КомандаРассылки.ВладелецШаблона);
КонецПроцедуры

Функция ОтправитьДокументыПолучателямПоШаблону(Получатели, ДляОтправки) Экспорт
	
	Если Не ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДляОтправки, "РассылатьПоШаблону", Ложь) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДлительныеОперации.СообщитьПрогресс(5);
	
	Результаты = Обработки.РассылкаПечатныхФорм.НовыйСводныйРезультатОтправки();
	ТаблицаРезультатов = РассылкаДокументов.ТаблицаРезультатовОтправки();
	
	Для Каждого СтрокаПолучателя Из Получатели Цикл
		Если Не ЗначениеЗаполнено(СтрокаПолучателя.Адрес) Тогда
			НакопитьЗначение(Результаты.Обработано, 1);
			НакопитьЗначение(Результаты.БезАдресов, 1);
			Продолжить;
		КонецЕсли;
				
		РезультатОтправки = РезультатыРассылкиДокументов.НовыйРезультатОтправки();

		ПараметрыОтправки = ОписаниеПараметровРассылки();
		ПараметрыОтправки.УчетнаяЗапись = ДляОтправки.УчетнаяЗапись;
		ПараметрыОтправки.ПерезаполнятьПолучателей = Истина;
		ПараметрыОтправки.Получатели = ШаблоныСообщенийБЗК.НоваяТаблицаПолучателей();
		НовыйПолучатель = ПараметрыОтправки.Получатели.Добавить();
		ЗаполнитьЗначенияСвойств(НовыйПолучатель, СтрокаПолучателя);
		НовыйПолучатель.Контакт = СтрокаПолучателя.ФизическоеЛицо;
	
		РезультатОтправкиПоШаблону = ШаблоныСообщений.СформироватьСообщениеИОтправить(
			ДляОтправки.ВыбранныйШаблон, СтрокаПолучателя.РассылаемыйДокумент, Новый УникальныйИдентификатор, ПараметрыОтправки);
		
		Если Не ЗначениеЗаполнено(РезультатОтправкиПоШаблону.ОписаниеОшибки) Тогда
			РезультатыРассылкиДокументов.ЗаполнитьУспешнымРезультатом(РезультатОтправки);
			НакопитьЗначение(Результаты.Отправлено, 1);
		Иначе
			РезультатыРассылкиДокументов.ЗаполнитьНеуспешнымРезультатом(РезультатОтправки, РезультатОтправкиПоШаблону.ОписаниеОшибки);
			НакопитьЗначение(Результаты.Ошибок, 1);
			ЗаписьЖурналаРегистрации(
				НСтр("ru = 'Рассылка документов.Сообщение по шаблону не отправлено'", ОбщегоНазначения.КодОсновногоЯзыка()), 
				УровеньЖурналаРегистрации.Предупреждение, , , РезультатОтправкиПоШаблону.ОписаниеОшибки);
		КонецЕсли;
		РезультатОтправки.Письмо = РезультатОтправкиПоШаблону.СсылкаНаПисьмо;
	
		РезультатыРассылкиДокументов.ЗаписатьРезультатОтправки(СтрокаПолучателя.ФизическоеЛицо, СтрокаПолучателя.ФизическоеЛицо, 
			СтрокаПолучателя.РассылаемыйДокумент, РезультатОтправки);
		НоваяСтрокаРезультата = ТаблицаРезультатов.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрокаРезультата, СтрокаПолучателя);
		НоваяСтрокаРезультата.Результат = РезультатОтправки;
			
		ДлительныеОперации.СообщитьПрогресс(ПрогрессОтправки(Результаты.Обработано, Получатели.Количество()));
		НакопитьЗначение(Результаты.Обработано, 1);
	КонецЦикла;
	
	Результаты.Детально = ОбщегоНазначения.ТаблицаЗначенийВМассив(ТаблицаРезультатов);
	
	Возврат Результаты;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура НакопитьЗначение(Накопленное, Значение)
	Накопленное = Накопленное + Значение;
КонецПроцедуры

Функция ПрогрессОтправки(Обработано, Всего)
	Возврат Макс(5, Окр(Обработано / Всего * 100));
КонецФункции

Функция ОписаниеПараметровРассылки()

	ПараметрыОтправки = Новый Структура(
		"Получатели,
		|ПерезаполнятьПолучателей,
		|УчетнаяЗапись");
	ПараметрыОтправки.Получатели = Новый Массив;
	ПараметрыОтправки.ПерезаполнятьПолучателей = Ложь;
	
	Возврат ПараметрыОтправки;
	
КонецФункции

#КонецОбласти
