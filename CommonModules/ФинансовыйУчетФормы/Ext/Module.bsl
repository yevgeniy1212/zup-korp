#Область СлужебныйПрограммныйИнтерфейс

Процедура ДополнитьФормуОрганизации(Форма) Экспорт
	
	Если ПолучитьФункциональнуюОпцию("СтруктураПредприятияНеСоответствуетСтруктуреЮридическихЛиц") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ФинансовыйУчет.ИспользоватьФинансовыйУчет() Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПравоДоступа("Чтение", Метаданные.РегистрыСведений.ФинансовыйУчетПодразделений) Тогда
		Возврат;
	КонецЕсли;
	
	ИмяКоманды = "НастройкиФинансовогоУчета";
	Если Форма.Команды.Найти(ИмяКоманды) = Неопределено Тогда
		КомандаФормы = Форма.Команды.Добавить(ИмяКоманды);
		КомандаФормы.Заголовок = НСтр("ru = 'Финансовый учет'");
		КомандаФормы.Действие = "Подключаемый_" + ИмяКоманды;
	КонецЕсли;
	
	ГруппаФормы = Форма.Элементы.Найти("ГруппаНастройкиФинансовогоУчета");
	Если Форма.Элементы.Найти(ИмяКоманды) = Неопределено Тогда
		Элемент = Форма.Элементы.Добавить(ИмяКоманды, Тип("КнопкаФормы"), ГруппаФормы);
		Элемент.Вид = ВидКнопкиФормы.Гиперссылка;
		Элемент.ИмяКоманды = ИмяКоманды;
	КонецЕсли;
	
КонецПроцедуры

Процедура СоздатьКомандуФинансовыйУчетВФормеСотрудника(Форма) Экспорт
	
	Если Не ФинансовыйУчет.ИспользоватьФинансовыйУчет() Тогда
		Возврат;
	КонецЕсли;
	
	ГруппаКнопки = Форма.Элементы.Найти("ГруппаФинансовыйУчет");
	Если ГруппаКнопки = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПравоДоступа("Чтение", Метаданные.РегистрыСведений.ФинансовыйУчетСотрудников) Тогда
		Возврат;
	КонецЕсли;
	
	Если Форма.Команды.Найти("ФинансовыйУчет") = Неопределено Тогда
		КомандаФинансовыйУчет = Форма.Команды.Добавить("ФинансовыйУчет");
		КомандаФинансовыйУчет.Действие = "Подключаемый_ФинансовыйУчет";
		КомандаФинансовыйУчет.Заголовок = НСтр("ru = 'Финансовый учет'");
	КонецЕсли;
	
	// Добавляем кнопку
	Если Форма.Элементы.Найти("ФинансовыйУчет") = Неопределено Тогда
		ЭлементФинансовыйУчет = Форма.Элементы.Вставить("ФинансовыйУчет", Тип("КнопкаФормы"), ГруппаКнопки);
		ЭлементФинансовыйУчет.Вид = ВидКнопкиФормы.Гиперссылка;
		ЭлементФинансовыйУчет.ИмяКоманды = "ФинансовыйУчет"; 
	КонецЕсли;
	
КонецПроцедуры

#Область Подразделения

Процедура ДополнитьФормуПодразделения(Форма) Экспорт
	ДополнитьФормуОбъектаУчета(Форма, "ФинансовыйУчетПодразделений");
КонецПроцедуры

Процедура ФормаПодразделенияПриЧтенииНаСервере(Форма) Экспорт
	
	ДополнитьФормуПодразделения(Форма);
	ПрочитатьДанныеФинансовогоУчетаДляРедактированияВФорме(Форма);
	
КонецПроцедуры

Процедура ПроверитьЗаполнениеПодразделения(Форма, Отказ) Экспорт
	ПроверитьЗаполнениеОбъектаУчета(Форма, Отказ);
КонецПроцедуры

Процедура ФормаПодразделенияПриЗаписиНаСервере(Форма, СсылкаНаОбъект, Отказ) Экспорт
	
	Если Не ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, "ФинансовыйУчетПодразделенийНаборЗаписей") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не Форма["ДоступноРедактированиеФинансовыйУчетПодразделений"] Тогда
		Возврат;
	КонецЕсли;
	
	Если Форма.Параметры.Ключ = Справочники.ПодразделенияОрганизаций.ПустаяСсылка() Тогда
		Форма.ОбъектФинансовогоУчета = ОрганизационнаяСтруктура.ПодразделениеВСтруктуреПредприятия(Форма.СсылкаНаОбъект);
		
		ФинансовыйУчетПодразделенийПрежняя = Новый Структура(Форма["ФинансовыйУчетПодразделенийПрежняя"]);
		ФинансовыйУчетПодразделенийПрежняя.Подразделение = Форма.ОбъектФинансовогоУчета;
		Форма["ФинансовыйУчетПодразделенийПрежняя"] = Новый ФиксированнаяСтруктура(ФинансовыйУчетПодразделенийПрежняя);
		
		Для Каждого Запись Из Форма.ФинансовыйУчетПодразделенийНаборЗаписей Цикл
			Запись.Подразделение = Форма.ОбъектФинансовогоУчета;
		КонецЦикла;
		
		Форма["ФинансовыйУчетПодразделений"].Подразделение = Форма.ОбъектФинансовогоУчета;
	КонецЕсли;
	
	ЗаписатьДанныеСпособовОтражения(Форма);
	
КонецПроцедуры

Функция МассивЗаписейИсторииФинансовогоУчетаПодразделения(Форма) Экспорт
	Возврат МассивЗаписейИсторииФинансовогоУчета(Форма);
КонецФункции

#КонецОбласти

