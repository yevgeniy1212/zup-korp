#Область СлужебныеПроцедурыИФункции

Функция МассивСвязанныхДанных(ИмяПланаОбмена, ПолноеИмяОбъектаМетаданных) Экспорт
	
	МассивСвязанныхДанных = Новый Структура;
	
	ОбъектМетаданных = Метаданные.НайтиПоПолномуИмени(ПолноеИмяОбъектаМетаданных);
	Если ОбъектМетаданных = Неопределено Тогда
		Возврат МассивСвязанныхДанных;
	КонецЕсли;
	
	МассивЗависимыхМетаданных = СинхронизацияДанныхЗарплатаКадрыСервер.ЗависимыеОбъекты();
	
	МассивСлужебныхРегистров = Новый Массив;
	МассивСлужебныхРегистров.Добавить("СоответствияОбъектовИнформационныхБаз");
	
	Для Каждого Состав Из Метаданные.ПланыОбмена[ИмяПланаОбмена].Состав Цикл
		МДСостава = Состав.Метаданные;
		Если Не ОбщегоНазначения.ЭтоРегистрСведений(МДСостава) Тогда
			Продолжить;
		КонецЕсли;
		Если МассивСлужебныхРегистров.Найти(МДСостава.Имя) <> Неопределено
			Или ВРег(Прав(МДСостава.Имя, 4)) = "ИСПР" Тогда
			Продолжить;
		КонецЕсли;
		Если МассивЗависимыхМетаданных.Найти(МДСостава) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		Если МДСостава.РежимЗаписи = Метаданные.СвойстваОбъектов.РежимЗаписиРегистра.ПодчинениеРегистратору Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого Измерение Из Состав.Метаданные.Измерения Цикл
			Если Не Измерение.ОсновнойОтбор Тогда
				Продолжить;
			КонецЕсли;
			
			Для Каждого ТипИзмерения Из Измерение.Тип.Типы() Цикл
				Если Метаданные.НайтиПоТипу(ТипИзмерения) = ОбъектМетаданных Тогда
					МассивСвязанныхДанных.Вставить(Состав.Метаданные.Имя, Измерение.Имя);
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	Возврат МассивСвязанныхДанных;
	
КонецФункции

Функция ЭтотУзелПланаОбмена(ИмяПланаОбмена) Экспорт
	Возврат ПланыОбмена[ИмяПланаОбмена].ЭтотУзел();
КонецФункции

Функция ОбъектыРегламентированногоУчета() Экспорт
	
	РазделыДанныхОбъектов = СинхронизацияДанныхЗарплатаКадрыСеансПовтИсп.РазделыДанныхОбъектов();
	
	Возврат РазделыДанныхОбъектов.Скопировать(
		Новый Структура("РазделДанных", "РегламентированныеДанные"), "ИмяОбъекта").ВыгрузитьКолонку("ИмяОбъекта");
		
КонецФункции

Функция ОбъектыУправленческогоУчета() Экспорт
	
	РазделыДанныхОбъектов = СинхронизацияДанныхЗарплатаКадрыСеансПовтИсп.РазделыДанныхОбъектов();
	
	Возврат РазделыДанныхОбъектов.Скопировать(
		Новый Структура("РазделДанных", "УправленческиеДанные"), "ИмяОбъекта").ВыгрузитьКолонку("ИмяОбъекта");
		
КонецФункции

Функция ОбщиеОбъекты() Экспорт
	
	РазделыДанныхОбъектов = СинхронизацияДанныхЗарплатаКадрыСеансПовтИсп.РазделыДанныхОбъектов();
	
	Возврат РазделыДанныхОбъектов.Скопировать(
		Новый Структура("РазделДанных", "ОбщиеДанные"), "ИмяОбъекта").ВыгрузитьКолонку("ИмяОбъекта");
			
КонецФункции

Функция ИменаОбъектовСОбработчикамиПравилРегистрации() Экспорт
	
	ИменаОбъектов = Новый Массив;
	Для Каждого Тип Из Метаданные.ОпределяемыеТипы.ОбъектСОбработчикамиПравилРегистрации.Тип.Типы() Цикл
		ИменаОбъектов.Добавить(Метаданные.НайтиПоТипу(Тип).ПолноеИмя());
	КонецЦикла;
	
	Возврат ИменаОбъектов;
	
КонецФункции

// См. СинхронизацияДанныхЗарплатаКадрыСервер.НастройкиОбработчиковПравилРегистрации
Функция НастройкиОбработчиковПравилРегистрации(ИмяОбъекта) Экспорт
	
	Настройки = СинхронизацияДанныхЗарплатаКадрыСервер.НоваяТаблицаНастроекОбработчиковПравилРегистрации();
	
	ИменаОбъектов = СинхронизацияДанныхЗарплатаКадрыСеансПовтИсп.ИменаОбъектовСОбработчикамиПравилРегистрации();
	Если ИменаОбъектов.Найти(ИмяОбъекта) <> Неопределено Тогда
		МодульМенеджера = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(ИмяОбъекта);
		МодульМенеджера.ПриЗаполненииНастроекОбработчиковПравилРегистрации(Настройки);
	Иначе
		СинхронизацияДанныхЗарплатаКадрыИнтеграцияПодсистем.ПриЗаполненииНастроекОбработчиковПравилРегистрации(
			Настройки, ИмяОбъекта);
	КонецЕсли;
	
	Если Настройки.Количество() = 0 Тогда
		Настройки = Неопределено;
	КонецЕсли;
	
	Возврат Настройки;
	
КонецФункции

#Область РазделыДанных

// См. СинхронизацияДанныхЗарплатаКадрыСервер.РазделыДанныхОбъектов
Функция РазделыДанныхОбъектов(ИмяПланаОбмена = "ОбменВРаспределеннойИнформационнойБазе") Экспорт
	
	РазделыДанныхОбъектов = Новый ТаблицаЗначений();
	РазделыДанныхОбъектов.Колонки.Добавить("ИмяОбъекта", Новый ОписаниеТипов("Строка"));
	РазделыДанныхОбъектов.Колонки.Добавить("РазделДанных", Новый ОписаниеТипов("Строка"));
	ОбщегоНазначенияБЗК.ДобавитьИндексКоллекции(РазделыДанныхОбъектов, "ИмяОбъекта");
	ОбщегоНазначенияБЗК.ДобавитьИндексКоллекции(РазделыДанныхОбъектов, "РазделДанных");
	
	Для Каждого ЭлементСостава Из Метаданные.ПланыОбмена[ИмяПланаОбмена].Состав Цикл
		ИмяОбъекта = ЭлементСостава.Метаданные.ПолноеИмя();
		РазделыДанных = СинхронизацияДанныхЗарплатаКадрыСервер.РазделыДанныхОбъекта(ИмяОбъекта);
		Для Каждого РазделДанных Из РазделыДанных Цикл
			НоваяСтрока = РазделыДанныхОбъектов.Добавить();
			НоваяСтрока.ИмяОбъекта = ИмяОбъекта;
			НоваяСтрока.РазделДанных = РазделДанных;
		КонецЦикла;
	КонецЦикла;

	Возврат РазделыДанныхОбъектов;
	
КонецФункции

// См. СинхронизацияДанныхЗарплатаКадрыСервер.РазделыДанныхОбъекта
Функция РазделыДанныхОбъекта(ИмяОбъекта) Экспорт

	РазделыДанныхОбъекта =
		СинхронизацияДанныхЗарплатаКадрыСервер.РазделыДанныхОбъектаИзНастроекОбработчиков(ИмяОбъекта);
	
	Если РазделыДанныхОбъекта.Количество() = 0 Тогда
		РазделыДанныхОбъекта = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(
			СинхронизацияДанныхЗарплатаКадрыСервер.ИдентификаторыРазделовДанных().ОбщиеДанные);
	Иначе
		Для Каждого РазделДанных Из РазделыДанныхОбъекта Цикл
			ТекстОшибки = СтрШаблон(НСтр("ru = 'Для объекта метаданных %1 указан несуществующий раздел данных %2'"),
				ИмяОбъекта, РазделДанных); 
			ОбщегоНазначенияКлиентСервер.Проверить(
				СинхронизацияДанныхЗарплатаКадрыСеансПовтИсп.РазделДанныхСуществует(РазделДанных), ТекстОшибки);
		КонецЦикла;
	КонецЕсли;
	
	Возврат РазделыДанныхОбъекта;
	
КонецФункции

// См. СинхронизацияДанныхЗарплатаКадрыСервер.РазделыДанныхОбъектаИзНастроекОбработчиков
Функция РазделыДанныхОбъектаИзНастроекОбработчиков(ИмяОбъекта) Экспорт
	
	РазделыДанныхОбъекта = Новый Массив;
	
	ТаблицаНастроекОбработчиков =
		СинхронизацияДанныхЗарплатаКадрыСервер.НастройкиОбработчиковПравилРегистрации(ИмяОбъекта);
	
	Если ТаблицаНастроекОбработчиков = Неопределено Тогда
		Возврат РазделыДанныхОбъекта;
	КонецЕсли;
		
	Для Каждого Настройки Из ТаблицаНастроекОбработчиков Цикл
		РазделыДанных = Неопределено;
		Если Не Настройки.ДополнительныеПараметры.Свойство("РазделыДанных", РазделыДанных) Тогда
			Продолжить;
		КонецЕсли;
		Если ТипЗнч(РазделыДанных) = Тип("Массив") Тогда
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(РазделыДанныхОбъекта, РазделыДанных, Истина);
		ИначеЕсли ТипЗнч(РазделыДанных) = Тип("Строка") Тогда
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(РазделыДанныхОбъекта,
				СтрРазделить(РазделыДанных, ",", Ложь), Истина);
		Иначе
			ТекстОшибки = СтрШаблон(
				НСтр("ru = 'Не корректный тип %1 настройки ""Разделы данных"". Ожидалась строка или массив строк'"),
				ТипЗнч(РазделыДанных));
			ОбщегоНазначенияКлиентСервер.Проверить(Ложь, ТекстОшибки,
				"СинхронизацияДанныхЗарплатаКадрыСеансПовтИсп.РазделыДанныхОбъекта");
		КонецЕсли;
	КонецЦикла;
	
	СинхронизацияДанныхЗарплатаКадрыСервер.ПереопределитьРазделыДанных(РазделыДанныхОбъекта);
	
	Возврат РазделыДанныхОбъекта;
	
КонецФункции

// Определяет соответствует ли узел разделу данных.
// 
// Параметры:
//  Узел - ПланОбменаСсылка.ОбменВРаспределеннойИнформационнойБазе,ПланОбменаСсылка.АвтономнаяРабота
//  РазделДанных - Строка - идентификатор раздела данных
// 
// Возвращаемое значение:
//  Булево
Функция УзелСоответствуетРазделуДанных(Узел, РазделДанных) Экспорт
	
	Если Не ЗначениеЗаполнено(РазделДанных) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если РазделДанных = СинхронизацияДанныхЗарплатаКадрыСервер.ИдентификаторыРазделовДанных().ОбщиеДанные Тогда
		Возврат Истина;
	КонецЕсли;
	
	ИмяПланаОбмена = Узел.Метаданные().Имя;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ПланОбмена.Ссылка
		|ИЗ
		|	#ПланОбменаОсновнаяТаблица КАК ПланОбмена
		|		ЛЕВОЕ СОЕДИНЕНИЕ #ПланОбменаРазделыДанных КАК ПланОбменаРазделыДанных
		|		ПО ПланОбмена.Ссылка = ПланОбменаРазделыДанных.Ссылка
		|ГДЕ
		|	ПланОбмена.Ссылка = &Ссылка
		|	И ПланОбменаРазделыДанных.Идентификатор = &РазделДанных";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "#ПланОбменаОсновнаяТаблица", СтрШаблон("ПланОбмена.%1", ИмяПланаОбмена));
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "#ПланОбменаРазделыДанных", СтрШаблон("ПланОбмена.%1.РазделыДанных",
		ИмяПланаОбмена));
	Запрос.УстановитьПараметр("Ссылка", Узел);
	Запрос.УстановитьПараметр("РазделДанных", РазделДанных);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Возврат Не РезультатЗапроса.Пустой();
	
КонецФункции

// Возвращает таблицу всех разделов данных.
// 
// Возвращаемое значение:
//  ТаблицаЗначений:
// * Идентификатор - Строка
// * Представление - Строка
// * Родитель - Строка - идентификатор родителя
// * Картинка - Картинка - картинка из библиотеки картинок
Функция ТаблицаВсехРазделовДанных() Экспорт
	
	РазделыДанных = Новый ТаблицаЗначений();
	РазделыДанных.Колонки.Добавить("Идентификатор", Новый ОписаниеТипов("Строка"));
	РазделыДанных.Колонки.Добавить("Представление", Новый ОписаниеТипов("Строка"));
	РазделыДанных.Колонки.Добавить("Родитель", Новый ОписаниеТипов("Строка"));
	РазделыДанных.Колонки.Добавить("Картинка", Новый ОписаниеТипов("Картинка"));
	
	СинхронизацияДанныхЗарплатаКадрыСервер.ДобавитьРазделДанныхВТаблицу(РазделыДанных, "ОбщиеДанные",
		НСтр("ru = 'Общие данные'"));
	СинхронизацияДанныхЗарплатаКадрыСервер.ДобавитьРазделДанныхВТаблицу(РазделыДанных, "РегламентированныеДанные",
		НСтр("ru = 'Регламентированные данные'"));
	СинхронизацияДанныхЗарплатаКадрыСервер.ДобавитьРазделДанныхВТаблицу(РазделыДанных, "УправленческиеДанные",
		НСтр("ru = 'Управленческие данные'"));
	
	Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыКорпоративнаяПодсистемы.ПодборПерсонала") Тогда
		МодульПодборПерсонала = ОбщегоНазначения.ОбщийМодуль("ПодборПерсонала");
		МодульПодборПерсонала.ПриДобавленииРазделовДанных(РазделыДанных);
	КонецЕсли;
	
	Возврат РазделыДанных;
	
КонецФункции

// Определяет существует ли раздел данных с заданным идентификатором
// 
// Параметры:
//  Идентификатор - Строка
// 
// Возвращаемое значение:
//  Булево
Функция РазделДанныхСуществует(Идентификатор) Экспорт
	
	Если ЗначениеЗаполнено(Идентификатор) Тогда
		ИдентификаторыРазделовДанных = СинхронизацияДанныхЗарплатаКадрыСеансПовтИсп.ИдентификаторыРазделовДанных();
		Результат = ИдентификаторыРазделовДанных.Свойство(Идентификатор);
	Иначе
		Результат = Ложь;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// См. СинхронизацияДанныхЗарплатаКадрыСервер.ИдентификаторыРазделовДанных
Функция ИдентификаторыРазделовДанных() Экспорт
	
	ИдентификаторыРазделовДанных = Новый Структура;
	
	ВсеРазделыДанных = СинхронизацияДанныхЗарплатаКадрыСеансПовтИсп.ТаблицаВсехРазделовДанных();
	
	Для Каждого СтрокаТаблицы Из ВсеРазделыДанных Цикл
		ИдентификаторыРазделовДанных.Вставить(СтрокаТаблицы.Идентификатор, СтрокаТаблицы.Идентификатор);
	КонецЦикла;
	
	ИдентификаторыРазделовДанных.Вставить("ОхранаТруда", "УправленческиеДанные");
	ИдентификаторыРазделовДанных.Вставить("Инструктажи", "УправленческиеДанные");
	ИдентификаторыРазделовДанных.Вставить("НесчастныеСлучаи", "УправленческиеДанные");
	ИдентификаторыРазделовДанных.Вставить("СпециальнаяОценкаУсловийТруда", "УправленческиеДанные");
	ИдентификаторыРазделовДанных.Вставить("МедицинскиеОсмотры", "УправленческиеДанные");
	
	Возврат ИдентификаторыРазделовДанных;
	
КонецФункции

// Получатели соответствующие разделам данных.
// 
// Параметры:
//  ИмяПланаОбмена - Строка
//  РазделыДанных - Строка - идентификаторы разделов данных, разделенные запятыми
// 
// Возвращаемое значение:
//  Массив - Получатели соответствующие разделам данных
Функция ПолучателиСоответствующиеРазделамДанных(ИмяПланаОбмена, РазделыДанных) Экспорт

	СинхронизацияДанныхЗарплатаКадрыСервер.ПроверитьПривестиПараметрРазделыДанных(РазделыДанных,
		"СинхронизацияДанныхЗарплатаКадрыСеансПовтИсп.ПолучателиСоответствующиеРазделамДанных");
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПланОбменаРазделыДанных.Ссылка
		|ИЗ
		|	ПланОбмена.ОбменВРаспределеннойИнформационнойБазе.РазделыДанных КАК ПланОбменаРазделыДанных
		|ГДЕ
		|	ПланОбменаРазделыДанных.Идентификатор В (&РазделыДанных)
		|	И НЕ ПланОбменаРазделыДанных.Ссылка.ПометкаУдаления
		|	И НЕ ПланОбменаРазделыДанных.Ссылка.ЭтотУзел";
	
	Запрос.УстановитьПараметр("РазделыДанных", РазделыДанных);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ОбменВРаспределеннойИнформационнойБазе", ИмяПланаОбмена);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

#КонецОбласти

#КонецОбласти