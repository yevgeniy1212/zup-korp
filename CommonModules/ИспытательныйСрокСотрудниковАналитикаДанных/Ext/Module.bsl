// @strict-types

#Область СлужебныйПрограммныйИнтерфейс

#Область ОбменДанными

// См. СинхронизацияДанныхЗарплатаКадрыИнтеграцияПодсистем.ЗаполнитьТаблицуЗависимыхДанных.
Процедура ПриЗаполненииТаблицыЗависимыхДанныхДляОбмена(ЗависимыеДанные) Экспорт
	
	// Метаданные.РегистрыСведений.ДанныеИспытательногоСрокаСотрудников
	НоваяСтрока = ЗависимыеДанные.Добавить();
	НоваяСтрока.ВедущиеМетаданные = Метаданные.РегистрыСведений.ДанныеИспытательногоСрокаСотрудников;
	НоваяСтрока.ЗависимыеМетаданные = Метаданные.РегистрыСведений.ОбновлениеАналитикиСтажейКандидатов;
	
КонецПроцедуры

#КонецОбласти

// Заполняет таблицу обновления данных испытательного срока сотрудников.
// 
// Параметры:
//  Источник - РегистрСведенийНаборЗаписей.ДанныеИспытательногоСрокаСотрудников
Процедура ЗаполнитьТаблицуОбновленияДанныхИспытательногоСрокаСотрудников(Источник) Экспорт
	
	Источник.ДополнительныеСвойства.Вставить("ТаблицаОбновленияДанныхИспытательногоСрокаДляСтажейКандидатов",
		ТаблицаОбновленияДанныхИспытательногоСрокаДляСтажейКандидатов(Источник));
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ПодключениеСобытийОбновленияАналитикиДанных

// Зарегистрировать изменение данных испытательного срока сотрудников.
// 
// Параметры:
//  Источник - РегистрСведенийНаборЗаписей.ДанныеИспытательногоСрокаСотрудников - Источник
//  Отказ - Булево - Отказ
//  Замещение - Булево - Замещение
Процедура ЗарегистрироватьИзменениеДанныхИспытательногоСрокаДляАналитикиДанныхПриЗаписи(Источник, Отказ, Замещение) Экспорт
	
	Если ЗарплатаКадры.ОтключитьБизнесЛогикуПриЗаписи(Источник) Тогда
		Возврат;
	КонецЕсли;
	
	Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыКорпоративнаяПодсистемы.КадровыйУчет.АналитикаДанных") Тогда
		МодульКадровыйУчетАналитикаДанных = ОбщегоНазначения.ОбщийМодуль("КадровыйУчетАналитикаДанных");
		МодульКадровыйУчетАналитикаДанных.ЗарегистрироватьОбновлениеАналитикиСтажейКандидатов(
			ТаблицаОбновленияДанныхИспытательногоСрокаДляСтажейКандидатов(Источник));
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

Функция ТаблицаОбновленияДанныхИспытательногоСрокаДляСтажейКандидатов(Источник)
	
	ТаблицаОбновления = ОбщегоНазначенияБЗК.ТаблицаЗначенийПоИмениРегистраСведений("ОбновлениеАналитикиСтажейКандидатов");
	ИзменившиесяДанные = Источник.ТаблицаИзменившихсяДанныхНабора(); // ТаблицаЗначений
	
	Если ИзменившиесяДанные <> Неопределено Тогда
		КандидатыФизическихЛиц = ПодборПерсонала.КандидатыФизическихЛиц(ИзменившиесяДанные.ВыгрузитьКолонку("ФизическоеЛицо"));
		КандидатыФизическихЛиц.Индексы.Добавить("ФизическоеЛицо");
		Для Каждого СтрокаТаблицы Из ИзменившиесяДанные Цикл
			КандидатыФизическогоЛица = КандидатыФизическихЛиц.НайтиСтроки(
				Новый Структура("ФизическоеЛицо", СтрокаТаблицы.ФизическоеЛицо));
			Если КандидатыФизическогоЛица.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			Если СтрокаТаблицы["Добавление"] = Истина
			 Или СтрокаТаблицы["Удаление"] = Истина
			 Или СтрокаТаблицы["ИзменилсяРесурсДействует"] = Истина
			 Или СтрокаТаблицы["ИзменилсяРесурсДатаЗавершения"] = Истина Тогда
				Для Каждого СтрокаКандидат Из КандидатыФизическогоЛица Цикл
					НоваяСтрока = ТаблицаОбновления.Добавить();
					НоваяСтрока.Кандидат = СтрокаКандидат.Кандидат; // СправочникСсылка.Кандидаты
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат ТаблицаОбновления;
	
КонецФункции

#КонецОбласти