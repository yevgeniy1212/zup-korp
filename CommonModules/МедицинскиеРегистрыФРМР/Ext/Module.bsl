	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "docDate", PersonCommonData.docDate, "ДатаUTC"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "profCourseSet", "[" + СтрСоединить(ПрофКурсыРаботника, ",") + "]", "JSON"); 
	ЗаписьJSON = "{" + СтрСоединить(ЭлементыJSON, ",") + "}";
	
	ПараметрыВызоваМетода = МедицинскиеРегистры.ПараметрыВызоваМетода();
	Если PersonCommonData.commonId=Неопределено Тогда 
		ПараметрыВызоваМетода.Метод = "POST";
		PersonKey.entityId = Неопределено;
	Иначе 
		ПараметрыВызоваМетода.Метод = "PUT";
		PersonKey.entityId = PersonCommonData.commonId;
	КонецЕсли;
	ПараметрыВызоваМетода.РазделМедрегистра = "person/common";
	ПараметрыВызоваМетода.Команда = ПараметрыВызоваМетода.РазделМедрегистра + "?" + PersonKeyUrl(PersonKey);
	ПараметрыВызоваМетода.Тело = ЗаписьJSON;
	
	Возврат ПараметрыВызоваМетода;	      	
	
КонецФункции

