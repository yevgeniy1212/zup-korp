//
// Параметры:
//  PersonKey - Структура - см. описание функции PersonKey.
// 
// Возвращаемое значение:
//  Строка - часть url, содержащая пары &параметр=значение.
//
Функция PersonKeyUrl(PersonKey, ПропуститьКлючMr = Ложь) Экспорт 
	
	Шаблон = "mo=%1%2%3%4%5%6%7%8%9";
	PersonKeyUrl = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		Шаблон, 
		?(PersonKey.mo=Неопределено, "", PersonKey.mo),
		?(ПропуститьКлючMr Или PersonKey.mr=Неопределено, "", "&mr=" + ?(PersonKey.mr, "true", "false")),
		?(PersonKey.oid=Неопределено, "", "&oid=" + PersonKey.oid),
		?(PersonKey.snils=Неопределено, "", "&snils=" + PersonKey.snils),
		ТегСоЗначениемИзЧислаИлиСтроки("documentId", PersonKey.documentId),
		?(PersonKey.serial=Неопределено, "", "&serial=" + PersonKey.serial),
		?(PersonKey.number=Неопределено, "", "&number=" + PersonKey.number),
		?(PersonKey.passDate=Неопределено, "", "&passDate=" + Формат(PersonKey.passDate, "ДФ=гггг-ММ-дд")),
		ТегСоЗначениемИзЧислаИлиСтроки("entityId", PersonKey.entityId)
		);	
	
	Возврат PersonKeyUrl;	      	
    
КонецФункции

Функция ТегСоЗначениемИзЧислаИлиСтроки(Тег, ЗначениеИдентификатора)
	Результат = "";
	Если ЗначениеИдентификатора<>Неопределено Тогда 
		Если ТипЗнч(ЗначениеИдентификатора)=Тип("Число") Тогда 
			Результат = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("&%1=%2", Тег, Формат(ЗначениеИдентификатора, "ЧГ=0; ЧН="));
		ИначеЕсли ТипЗнч(ЗначениеИдентификатора)=Тип("Строка") Тогда 
			Результат = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("&%1=%2", Тег, СокрЛП(ЗначениеИдентификатора));
		Иначе 
			Результат = "";
		КонецЕсли;
	КонецЕсли;
	Возврат Результат;
КонецФункции


