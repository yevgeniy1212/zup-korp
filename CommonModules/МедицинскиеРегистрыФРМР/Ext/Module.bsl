//
Функция PostPutPersonCommon(PersonKey, PersonCommonData) Экспорт 
	
	ПрофКурсыРаботника = Новый Массив;
	Если PersonCommonData.profCourseSet<>Неопределено Тогда 
		Для Каждого ДанныеПрофКурса Из PersonCommonData.profCourseSet Цикл
			ДополнительныеЭлементыJSON = Новый Массив;
			МедицинскиеРегистры.ДобавитьЭлементJSON(ДополнительныеЭлементыJSON, "profCourseId", ДанныеПрофКурса.profCourseId, "Число"); 
			МедицинскиеРегистры.ДобавитьЭлементJSON(ДополнительныеЭлементыJSON, "profCourseName", ДанныеПрофКурса.profCourseName, "Строка"); 
			МедицинскиеРегистры.ДобавитьЭлементJSON(ДополнительныеЭлементыJSON, "docDate", ДанныеПрофКурса.docDate, "ДатаUTC"); 
			ПрофКурсыРаботника.Добавить("{" + СтрСоединить(ДополнительныеЭлементыJSON, ",") + "}");
		КонецЦикла;	
	КонецЕсли;
    
	ЭлементыJSON = Новый Массив;
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "institution", PersonCommonData.institution, "Строка"); 
