			МедицинскиеРегистры.ДобавитьЭлементJSON(ДополнительныеЭлементыJSON, "beginDate", ДанныеВременногоНеисполнения.beginDate, "ДатаUTC"); 
			МедицинскиеРегистры.ДобавитьЭлементJSON(ДополнительныеЭлементыJSON, "endDate", ДанныеВременногоНеисполнения.endDate, "ДатаUTC"); 
			ВременныеНеисполненияОбязанностейРаботника.Добавить("{" + СтрСоединить(ДополнительныеЭлементыJSON, ",") + "}");
		КонецЦикла;	
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "temporaryDerelictions", "[" + СтрСоединить(ВременныеНеисполненияОбязанностейРаботника, ",") + "]", "JSON");
	КонецЕсли;

	ЗаписьJSON = "{" + СтрСоединить(ЭлементыJSON, ",") + "}";
	
	ПараметрыВызоваМетода = МедицинскиеРегистры.ПараметрыВызоваМетода();
	Если PersonCardData.id=Неопределено Тогда 
		ПараметрыВызоваМетода.Метод = "POST";
		PersonKey.entityId = Неопределено;
	Иначе 
		ПараметрыВызоваМетода.Метод = "PUT";
		PersonKey.entityId = PersonCardData.id;
	КонецЕсли;
	ПараметрыВызоваМетода.РазделМедрегистра = "person/card";
	ПараметрыВызоваМетода.Команда = ПараметрыВызоваМетода.РазделМедрегистра + "?" + PersonKeyUrl(PersonKey, Истина) + "&lastName=" + PersonCardData.lastName;
	ПараметрыВызоваМетода.Тело = ЗаписьJSON;
	
	Возврат ПараметрыВызоваМетода;	      	
	
КонецФункции

