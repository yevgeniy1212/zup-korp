#Область СлужебныеПроцедурыИФункции

// Возвращает параметры вызова rest-метода для чтения сведений медицинского работника.
//
// Параметры:
//  PersonKey - Структура - см. описание функции PersonKey.
// 
// Возвращаемое значение:
//  Структура - см. описание функции МедицинскиеРегистры.ПараметрыВызоваМетода.
//
Функция GetPerson(PersonKey) Экспорт 
	
	ПараметрыВызоваМетода = МедицинскиеРегистры.ПараметрыВызоваМетода();
	ПараметрыВызоваМетода.Метод = "GET";
	ПараметрыВызоваМетода.РазделМедрегистра = "person";
	ПараметрыВызоваМетода.Команда = ПараметрыВызоваМетода.РазделМедрегистра + "?" + PersonKeyUrl(PersonKey);
	Возврат ПараметрыВызоваМетода;	      	
    
КонецФункции

// Возвращает параметры вызова rest-метода для чтения всех сведений медицинского работника.
//
// Параметры:
//  PersonKey - Структура - см. описание функции PersonKey.
// 
// Возвращаемое значение:
//  Структура - см. описание функции МедицинскиеРегистры.ПараметрыВызоваМетода.
//
Функция GetPersonFull(PersonKey) Экспорт 
	
	ПараметрыВызоваМетода = МедицинскиеРегистры.ПараметрыВызоваМетода();
	ПараметрыВызоваМетода.Метод = "GET";
	ПараметрыВызоваМетода.РазделМедрегистра = "person/full";
	ПараметрыВызоваМетода.Команда = ПараметрыВызоваМетода.РазделМедрегистра + "?" + PersonKeyUrl(PersonKey);
	Возврат ПараметрыВызоваМетода;	      	
    
КонецФункции

// Возвращает параметры вызова rest-метода POST для создания (create) 
// или PUT для изменения (update) сведений о медицинском работнике.
//
// Параметры:
//  PersonKey - Структура - Данные идентификации медработника для метода PUT (см. описание функции PersonKey).
//                          Для метода POST (create) PersonKey.oid оставлять в значении Неопределено.
//  PersonData - Структура - Данные медработника (см. описание функции PersonData).
// 
// Возвращаемое значение:
//  Структура - см. описание функции МедицинскиеРегистры.ПараметрыВызоваМетода.
//
Функция PostPutPerson(PersonKey, PersonData) Экспорт 
	
	ДокументыРаботника = "";
	Для ИндексДокумента = 0 По PersonData.documents.Количество()-1 Цикл
		ДанныеДокумента = PersonData.documents[ИндексДокумента];
		ЭлементыJSON = Новый Массив;
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "serial", ДанныеДокумента.serial, "Строка"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "number", ДанныеДокумента.number, "Строка"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "passDate", ДанныеДокумента.passDate, "ДатаUTC"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "passOrg", ДанныеДокумента.passOrg, "Строка"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "codeOrg", ДанныеДокумента.codeOrg, "Строка"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "documentId", ДанныеДокумента.documentId, "JSON"); 
		ЗаписьJSON = "{" + СтрСоединить(ЭлементыJSON, ",") + "}";
		Если ИндексДокумента = 0 Тогда 
			ДокументыРаботника = ЗаписьJSON;
		Иначе 
			ДокументыРаботника = ДокументыРаботника + "," + Символы.ПС + ЗаписьJSON;
		КонецЕсли;
	КонецЦикла;	
	
	АдресаРаботника = "";
	Для ИндексАдреса = 0 По PersonData.addresses.Количество()-1 Цикл
		ДанныеАдреса = PersonData.addresses[ИндексАдреса];
		
		ЭлементыJSON = Новый Массив;
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "GARguid", ДанныеАдреса.address.GARguid, "Строка"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "aoidArea", ДанныеАдреса.address.aoidArea, "Строка"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "aoidStreet", ДанныеАдреса.address.aoidStreet, "Строка"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "houseid", ДанныеАдреса.address.houseid, "Строка"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "region", ДанныеАдреса.address.region, "Число"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "areaName", ДанныеАдреса.address.areaName, "Строка"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "prefixArea", ДанныеАдреса.address.prefixArea, "Строка"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "streetName", ДанныеАдреса.address.streetName, "Строка"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "prefixStreet", ДанныеАдреса.address.prefixStreet, "Строка"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "house", ДанныеАдреса.address.house, "Строка"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "building", ДанныеАдреса.address.building, "Строка"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "struct", ДанныеАдреса.address.struct, "Строка"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "flat", ДанныеАдреса.address.flat, "Строка"); 
		ОбъектJSON = "{" + СтрСоединить(ЭлементыJSON, ",") + "}";
		
		ЭлементыJSON = Новый Массив;
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "addressId", ДанныеАдреса.addressId, "Строка"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "regDate", ДанныеАдреса.regDate, "ДатаUTC"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "addressTypeId", ДанныеАдреса.addressTypeId, "Число"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "address", ОбъектJSON, "JSON"); 
		ЗаписьJSON = "{" + СтрСоединить(ЭлементыJSON, ",") + "}";
		
		Если ИндексАдреса = 0 Тогда 
			АдресаРаботника = ЗаписьJSON;
		Иначе 
			АдресаРаботника = АдресаРаботника + "," + Символы.ПС + ЗаписьJSON;
		КонецЕсли;
	КонецЦикла;	
			
	ЭлементыJSON = Новый Массив;
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "mr", PersonData.mr, "Булево"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "student", PersonData.student, "Булево"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "lastName", PersonData.lastName, "Строка"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "firstName", PersonData.firstName, "Строка"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "patronymic", PersonData.patronymic, "Строка"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "gender", ?(PersonData.gender=Перечисления.ПолФизическогоЛица.Женский, 2, 1), "Число"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "birthDate", PersonData.birthDate, "ДатаUTC"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "snils", PersonData.snils, "Строка"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "inn", PersonData.inn, "Строка");
	
	ЭлементыКатегорииГражданства = Новый Массив;
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыКатегорииГражданства, "code", PersonData.citizenShipId.code, "JSON"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыКатегорииГражданства, "name", PersonData.citizenShipId.name, "Строка"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "citizenShipId", "{" + СтрСоединить(ЭлементыКатегорииГражданства, ",") + "}", "JSON"); 
	
	Если PersonData.citizenShipId.code<>"1" Тогда 
		ЭлементыСтраныГражданства = Новый Массив;
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыСтраныГражданства, "code", PersonData.oksmId.code, "JSON"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыСтраныГражданства, "name", PersonData.oksmId.name, "Строка"); 
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "oksmId", "{" + СтрСоединить(ЭлементыСтраныГражданства, ",") + "}", "JSON"); 
	КонецЕсли;
	
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "militaryRelationId", PersonData.militaryRelationId, "JSON"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "phone", PersonData.phone, "Строка"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "email", PersonData.email, "Строка"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "isDisabled", PersonData.isDisabled, "Булево"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "disabledGroupId", PersonData.disabledGroupId, "Число"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "disabledGroupName", PersonData.disabledGroupName, "Строка"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "disabledDate", PersonData.disabledDate, "ДатаUTC"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "covid19", PersonData.covid19, "Булево"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "documents", "[" + ДокументыРаботника + "]", "JSON"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "addresses", "[" + АдресаРаботника + "]", "JSON"); 
	ЗаписьJSON = "{" + СтрСоединить(ЭлементыJSON, ",") + "}";
	
	ПараметрыВызоваМетода = МедицинскиеРегистры.ПараметрыВызоваМетода();
	Если PersonKey.oid=Неопределено Тогда 
		ПараметрыВызоваМетода.Метод = "POST";
	Иначе 
		ПараметрыВызоваМетода.Метод = "PUT";
	КонецЕсли;
	ПараметрыВызоваМетода.РазделМедрегистра = "person";
	ПараметрыВызоваМетода.Команда = ПараметрыВызоваМетода.РазделМедрегистра + "?" + PersonKeyUrl(PersonKey);
	ПараметрыВызоваМетода.Тело = ЗаписьJSON;
	
	Возврат ПараметрыВызоваМетода;	      	
    
КонецФункции

// Конструктор структуры основных данных медицинского работника.
// 
// Возвращаемое значение:
//  Структура - параметры, необходимые для вызова метода сервиса REST.
//
//      ...
//
//  	documents - Массив – Документы, удостоверяющие личность (см. Функция PersonDocumentData).
//  	addresses - Массив – Адреса (см. Функция PersonAddressData).
//
Функция PersonData() Экспорт

	Результат = Новый Структура;
	Результат.Вставить("mr", Неопределено);
	Результат.Вставить("student", Неопределено);
	Результат.Вставить("lastName", Неопределено);
	Результат.Вставить("firstName", Неопределено);
	Результат.Вставить("patronymic", Неопределено);
	Результат.Вставить("gender", Неопределено);
	Результат.Вставить("birthDate", Неопределено);
	Результат.Вставить("snils", Неопределено);
	Результат.Вставить("inn", Неопределено);
	Результат.Вставить("citizenShipId", Новый Структура("code,name", Неопределено, Неопределено));
	Результат.Вставить("oksmId", Новый Структура("code,name", Неопределено, Неопределено));
	Результат.Вставить("militaryRelationId", Неопределено);
	Результат.Вставить("phone", Неопределено);
	Результат.Вставить("email", Неопределено);
	Результат.Вставить("isDisabled", Неопределено);
	Результат.Вставить("disabledGroupId", Неопределено);
	Результат.Вставить("disabledGroupName", Неопределено);
	Результат.Вставить("disabledDate", Неопределено);
	Результат.Вставить("covid19", Неопределено);
	Результат.Вставить("documents", Неопределено);
	Результат.Вставить("addresses", Неопределено);
	Возврат Результат;
	
КонецФункции

// *** Документ, удостоверяющий личность.
//serial	Строка	Нет	Серия документа, удостоверяющего личность		Числовое поле до 10 символов
//number	Строка	Да	Номер документа, удостоверяющего личность		Числовое поле до 20 символов
//passDate	Дата	Да	Дата выдачи документа, удостоверяющего личность		Дата в формате ГГГГ-ММ-ДД
//passOrg	Строка	Да	Организация выдачи документа, удостоверяющего личность		Текст до 200 символов
//codeOrg	Число	Нет	Код подразделения		
//documentId	Положительное число (unsigned int)	Да	Код документа, удостоверяющего личность	Справочник ФНСИ «Документы, удостоверяющие личность», OID 1.2.643.5.1.13.13.99.2.48	
Функция PersonDocumentData() Экспорт

	Результат = Новый Структура;
	Результат.Вставить("serial", Неопределено);
	Результат.Вставить("number", Неопределено);
	Результат.Вставить("passDate", Неопределено);
	Результат.Вставить("passOrg", Неопределено);
	Результат.Вставить("codeOrg", Неопределено);
	Результат.Вставить("documentId", Неопределено);
	Возврат Результат;
	
КонецФункции

Функция PersonAddressData() Экспорт

	АдреснаяИнформация = Новый Структура;
	АдреснаяИнформация.Вставить("GARguid", Неопределено);
	АдреснаяИнформация.Вставить("aoidArea", Неопределено);
	АдреснаяИнформация.Вставить("aoidStreet", Неопределено);
	АдреснаяИнформация.Вставить("houseid", Неопределено);
	АдреснаяИнформация.Вставить("region", Неопределено);
	АдреснаяИнформация.Вставить("areaName", Неопределено);
	АдреснаяИнформация.Вставить("prefixArea", Неопределено);
	АдреснаяИнформация.Вставить("streetName", Неопределено);
	АдреснаяИнформация.Вставить("prefixStreet", Неопределено);
	АдреснаяИнформация.Вставить("house", Неопределено);
	АдреснаяИнформация.Вставить("building", Неопределено);
	АдреснаяИнформация.Вставить("struct", Неопределено);
	АдреснаяИнформация.Вставить("flat", Неопределено);
	
	Результат = Новый Структура;
	Результат.Вставить("addressId", Неопределено);
	Результат.Вставить("regDate", Неопределено);
	Результат.Вставить("addressTypeId", Неопределено);
	Результат.Вставить("address", АдреснаяИнформация);
	
	Возврат Результат;
	
КонецФункции

#Область ЛичноеДелоМедицинскогоРаботника

// Возвращает параметры вызова rest-метода для чтения личного дела медицинского работника.
//
// Параметры:
//  PersonKey - Структура - см. описание функции PersonKey.
// 
// Возвращаемое значение:
//  Структура - см. описание функции МедицинскиеРегистры.ПараметрыВызоваМетода.
//
Функция GetPersonCard(PersonKey) Экспорт 
	
	ПараметрыВызоваМетода = МедицинскиеРегистры.ПараметрыВызоваМетода();
	ПараметрыВызоваМетода.Метод = "GET";
	ПараметрыВызоваМетода.РазделМедрегистра = "person/card";
	ПараметрыВызоваМетода.Команда = ПараметрыВызоваМетода.РазделМедрегистра + "?" + PersonKeyUrl(PersonKey);
	Возврат ПараметрыВызоваМетода;	      	
    
КонецФункции

// Возвращает параметры вызова rest-метода для создания (create) или изменения данных личного дела медицинского работника.
//
// Параметры:
//  PersonKey - Структура - см. описание функции PersonKey.
//  PersonCardData - Структура - см. описание функции PersonCardData.
// 
// Возвращаемое значение:
//  Структура - см. описание функции МедицинскиеРегистры.ПараметрыВызоваМетода.
//
Функция PostPutPersonCard(PersonKey, PersonCardData) Экспорт 
	
    
	ЭлементыJSON = Новый Массив;
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "oid", PersonCardData.oid, "Строка"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "organization", PersonCardData.organization, "Строка"); 
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "nrPmuDepartId", PersonCardData.nrPmuDepartId, "Строка");
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "nrPmuDepartHospitalSubdivisionId", PersonCardData.nrPmuDepartHospitalSubdivisionId, "Строка");
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "roomOid", PersonCardData.roomOid, "Строка");
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "contractNumber", PersonCardData.contractNumber, "Строка");
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "contractDate", PersonCardData.contractDate, "ДатаUTC");
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "serviceNumber", PersonCardData.serviceNumber, "Строка");
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "fedPositionId", PersonCardData.fedPositionId, "Число");
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "seniority", PersonCardData.seniority, "Число");
	
	Если ТипЗнч(PersonCardData.services)=Тип("Массив") Тогда 
		МедицинскиеУслугиРаботника = Новый Массив;
		Для Каждого ДанныеМедицинскойУслуги Из PersonCardData.services Цикл
			ДополнительныеЭлементыJSON = Новый Массив;
			МедицинскиеРегистры.ДобавитьЭлементJSON(ДополнительныеЭлементыJSON, "code", ДанныеМедицинскойУслуги.code, "Число"); 
			МедицинскиеРегистры.ДобавитьЭлементJSON(ДополнительныеЭлементыJSON, "name", ДанныеМедицинскойУслуги.name, "Строка"); 
			МедицинскиеУслугиРаботника.Добавить("{" + СтрСоединить(ДополнительныеЭлементыJSON, ",") + "}");
		КонецЦикла;	
		МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "services", "[" + СтрСоединить(МедицинскиеУслугиРаботника, ",") + "]", "JSON");
	КонецЕсли;
	
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "positionTypeId", PersonCardData.positionTypeId, "Число");
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "postId", PersonCardData.postId, "Число");
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "rate", PersonCardData.rate, "Число", 4);
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "beginDate", PersonCardData.beginDate, "ДатаUTC");
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "endDate", PersonCardData.endDate, "ДатаUTC");
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "endTypeId", PersonCardData.endTypeId, "Число");
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "fireReasonId", PersonCardData.fireReasonId, "Число");
	МедицинскиеРегистры.ДобавитьЭлементJSON(ЭлементыJSON, "targeted", PersonCardData.targeted, "Булево");
	
