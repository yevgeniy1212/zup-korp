#Область СтатистикиКонфигурации

// См. ЦентрМониторингаПереопределяемый.ПриСбореПоказателейСтатистикиКонфигурации.
Процедура ПриСбореПоказателейСтатистикиКонфигурации() Экспорт
	
	ИмяКонфигурации = КонфигурацииЗарплатаКадры.КраткоеНазваниеПрограммыСлужебный();
	// АПК:1297-выкл Имя подсистемы для статистики, не локализуется
	ИмяПодсистемы = "Льготы сотрудников";
	// АПК:1297-вкл
	
	ВидСтатистики = СборСтатистики.ВидыСтатистики().Накопительная;
	
	Статистика = Новый Соответствие;
	// АПК:1297-выкл Статистика, не локализуется
	Статистика.Вставить("Льготы", СтатистикаЛьгот());
	// АПК:1297-вкл
	СборСтатистики.ЗаписатьСтатистикуПоОбъектам(ИмяКонфигурации, ИмяПодсистемы, Статистика, ВидСтатистики);
	
	НачалоПериода = СборСтатистики.НачалоПериодаСбораСтатистики();
	ВидСтатистики = СборСтатистики.ВидыСтатистики().Периодическая;
	
	Статистика = Новый Соответствие;
	Статистика.Вставить("Изменение льгот сотрудников", СтатистикаИзмененияЛьготСотрудников(НачалоПериода));
	Статистика.Вставить("Индивидуальные льготы физических лиц", СтатистикаИзмененияЛьготФизическихЛиц(НачалоПериода));
	СборСтатистики.ЗаписатьСтатистикуПоОбъектам(ИмяКонфигурации, ИмяПодсистемы, Статистика, ВидСтатистики);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область СтатистикиКонфигурации

// АПК:1297-выкл Статистика, не локализуется

Функция СтатистикаЛьгот()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Льготы.Сотрудник) КАК Сотрудников,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Льготы.Льгота) КАК Льгот,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЛьготыКатегория.Льгота) КАК ЛьготКатегория,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВыбираемыеСотрудникомЛьготыКатегория.Льгота) КАК ВыбираемыхСотрудникомЛьготКатегория,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЛьготыУчитывающиесяПриРасчетеЗарплаты.Льгота) КАК ЛьготУчитывающихсяПриРасчетеЗарплаты,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЛьготыСБаллами.Льгота) КАК ЛьготСБаллами
		|ИЗ
		|	Документ.ИзменениеЛьготСотрудников.Льготы КАК Льготы
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ИзменениеЛьготСотрудников.Льготы КАК ЛьготыКатегория
		|		ПО Льготы.Льгота = ЛьготыКатегория.Льгота
		|		И
		|			(Льготы.Льгота.КатегорияНачисленияИлиНеоплаченногоВремени = ЗНАЧЕНИЕ(Перечисление.КатегорииНачисленийИНеоплаченногоВремени.Льгота))
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ИзменениеЛьготСотрудников.Льготы КАК ВыбираемыеСотрудникомЛьготыКатегория
		|		ПО Льготы.Льгота = ВыбираемыеСотрудникомЛьготыКатегория.Льгота
		|		И
		|			(Льготы.Льгота.КатегорияНачисленияИлиНеоплаченногоВремени = ЗНАЧЕНИЕ(Перечисление.КатегорииНачисленийИНеоплаченногоВремени.ВыбираемаяСотрудникомЛьгота))
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ИзменениеЛьготСотрудников.Льготы КАК ЛьготыУчитывающиесяПриРасчетеЗарплаты
		|		ПО Льготы.Льгота = ЛьготыУчитывающиесяПриРасчетеЗарплаты.Льгота
		|		И (Льготы.Льгота.ЛьготаУчитываетсяПриРасчетеЗарплаты = ИСТИНА)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ИзменениеЛьготСотрудников.Льготы КАК ЛьготыСБаллами
		|		ПО Льготы.Льгота = ЛьготыСБаллами.Льгота
		|		И (Льготы.Льгота.КоличествоБаллов > 0)
		|ГДЕ
		|	Льготы.Ссылка.ПометкаУдаления = ЛОЖЬ
		|	И Льготы.Ссылка.Проведен = ИСТИНА";
	
	ТаблицаЛьгот = Запрос.Выполнить().Выгрузить();
	
	ПоказателиСтатистики = Новый Соответствие;
	ПоказателиСтатистики.Вставить("Сотрудников",ТаблицаЛьгот.ВыгрузитьКолонку("Сотрудников")[0]);
	ПоказателиСтатистики.Вставить("Льгот", ТаблицаЛьгот.ВыгрузитьКолонку("Льгот")[0]);
	ПоказателиСтатистики.Вставить("Льгот как категория",ТаблицаЛьгот.ВыгрузитьКолонку("ЛьготКатегория")[0]);
	ПоказателиСтатистики.Вставить("Льгот как категория выбираемая сотрудником",
		ТаблицаЛьгот.ВыгрузитьКолонку("ВыбираемыхСотрудникомЛьготКатегория")[0]);
	ПоказателиСтатистики.Вставить("Льгот учитывающихся при расчете зарплаты",
		ТаблицаЛьгот.ВыгрузитьКолонку("ЛьготУчитывающихсяПриРасчетеЗарплаты")[0]);
	ПоказателиСтатистики.Вставить("Льгот с баллами", ТаблицаЛьгот.ВыгрузитьКолонку("ЛьготСБаллами")[0]);
	
	Возврат ПоказателиСтатистики;
	
КонецФункции

Функция СтатистикаИзмененияЛьготСотрудников(НачалоПериода)
	
	Таблица = Метаданные.Документы.ИзменениеЛьготСотрудников;
	ДанныеСтатистики = СборСтатистики.ДанныеСбораСтатистики();
	
	ДанныеСтатистики.ДанныеОбъекта.Объект = Таблица.СтандартныеРеквизиты.Ссылка;
	ДанныеСтатистики.ДанныеОбъекта.ПредставлениеОбъектов = "Изменений";
	
	ДанныеСтатистики.ДанныеПериода.Период = Таблица.СтандартныеРеквизиты.Дата;
	ДанныеСтатистики.ДанныеПериода.НачалоПериода = НачалоПериода;
	
	ДанныеГруппировок = Новый Массив;
	
	ДанныеГруппировки = СборСтатистики.ДанныеГруппировки();
	ДанныеГруппировки.Группировка = Таблица.Реквизиты.Ответственный;
	ДанныеГруппировки.ПредставлениеГруппировки = "Ответственных";
	ДанныеГруппировок.Добавить(ДанныеГруппировки);
	
	ДанныеСтатистики.ДанныеГруппировок = ДанныеГруппировок;
	ДанныеСтатистики.ПроверкиОбъекта.ПометкаУдаления = Истина;
	ДанныеСтатистики.ПроверкиОбъекта.Проведение = Истина;
	
	ПоказателиСтатистики = СборСтатистики.СтандартныеПоказателиПоТаблице(Таблица, ДанныеСтатистики);
	
	Возврат ПоказателиСтатистики;
	
КонецФункции

Функция СтатистикаИзмененияЛьготФизическихЛиц(НачалоПериода)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", ТекущаяДатаСеанса());
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ИндивидуальныеЛьготыФизическихЛиц.Льгота) КАК Льгот
		|ИЗ
		|	РегистрСведений.ИндивидуальныеЛьготыФизическихЛиц КАК ИндивидуальныеЛьготыФизическихЛиц
		|ГДЕ
		|	ИндивидуальныеЛьготыФизическихЛиц.Дата > &НачалоПериода
		|	И ИндивидуальныеЛьготыФизическихЛиц.Дата <= &КонецПериода";
	
	ПоказателиСтатистики = Новый Соответствие;
	ПоказателиСтатистики.Вставить("Льгот", Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Льгот")[0]);
	
	Возврат ПоказателиСтатистики;
	
КонецФункции

