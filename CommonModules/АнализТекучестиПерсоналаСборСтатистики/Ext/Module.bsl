#Область ПрограммныйИнтерфейс

#Область СтатистикиКонфигурации

// См. ЦентрМониторингаПереопределяемый.ПриСбореПоказателейСтатистикиКонфигурации.
Процедура ПриСбореПоказателейСтатистикиКонфигурации() Экспорт
	
	ИмяКонфигурации = КонфигурацииЗарплатаКадры.КраткоеНазваниеПрограммыСлужебный();
	// АПК:1297-выкл Имя подсистемы для статистики, не локализуется
	ИмяПодсистемы = "Анализ текучести персонала";
	// АПК:1297-вкл
	
	НачалоПериода = СборСтатистики.НачалоПериодаСбораСтатистики();
	ВидСтатистики = СборСтатистики.ВидыСтатистики().Периодическая;
	
	Статистика = Новый Соответствие;
	Статистика.Вставить("Причины увольнения сотрудников", СтатистикаПричинУвольнений(НачалоПериода));
	СборСтатистики.ЗаписатьСтатистикуПоОбъектам(ИмяКонфигурации, ИмяПодсистемы, Статистика, ВидСтатистики);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область СтатистикиКонфигурации

// АПК:1297-выкл Статистика, не локализуется

Функция СтатистикаПричинУвольнений(НачалоПериода)
	
	МенеджерВТ = Новый МенеджерВременныхТаблиц;
	
	ПараметрыСотрудников = КадровыйУчет.ПараметрыПолученияСотрудниковОрганизацийПоСпискуФизическихЛиц();
	ЗарплатаКадрыОбщиеНаборыДанных.ДобавитьВКоллекциюОтбор(ПараметрыСотрудников.Отборы,
		"ДатаУвольнения", ">=", НачалоПериода);
	КадровыйУчет.СоздатьВТСотрудникиОрганизации(МенеджерВТ, Ложь, ПараметрыСотрудников, "ВТУволенныеСотрудники");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(УволенныеСотрудники.Сотрудник) КАК Уволенных,
		|	КОЛИЧЕСТВО(ПричиныУвольненияСотрудников.Сотрудник) КАК УволенныхСПричиной,
		|	КОЛИЧЕСТВО(РазныеПричиныУвольненияСотрудников.Сотрудник) КАК УволенныхСРазнымиПричинами,
		|	ПричиныУвольненияСотрудников.Ответственный КАК Ответственный
		|ИЗ
		|	ВТУволенныеСотрудники КАК УволенныеСотрудники
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПричиныУвольненияСотрудников КАК ПричиныУвольненияСотрудников
		|		ПО УволенныеСотрудники.Сотрудник = ПричиныУвольненияСотрудников.Сотрудник
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПричиныУвольненияСотрудников КАК РазныеПричиныУвольненияСотрудников
		|		ПО (ПричиныУвольненияСотрудников.Сотрудник = РазныеПричиныУвольненияСотрудников.Сотрудник)
		|			И (ПричиныУвольненияСотрудников.ПричинаHR <> ПричиныУвольненияСотрудников.ПричинаРуководитель)
		|			И (ПричиныУвольненияСотрудников.ПричинаHR <> ЗНАЧЕНИЕ(Справочник.ПричиныУвольнений.ПустаяСсылка))
		|			И (ПричиныУвольненияСотрудников.ПричинаРуководитель <> ЗНАЧЕНИЕ(Справочник.ПричиныУвольнений.ПустаяСсылка))
		|
		|СГРУППИРОВАТЬ ПО
		|	ПричиныУвольненияСотрудников.Ответственный
		|ИТОГИ
		|	СУММА(Уволенных),
		|	СУММА(УволенныхСПричиной),
		|	СУММА(УволенныхСРазнымиПричинами),
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Ответственный)
		|ПО
		|	ОБЩИЕ";
	
	ПоказателиСтатистики = Новый Соответствие;
	ВыборкаВсего = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаВсего.Следующий() Цикл
		
		ПоказателиСтатистики.Вставить("Уволенных", ВыборкаВсего.Уволенных);
		ПоказателиСтатистики.Вставить("Уволенных(С причиной)", ВыборкаВсего.УволенныхСПричиной);
		ПоказателиСтатистики.Вставить("Уволенных(С разными причинами)", ВыборкаВсего.УволенныхСРазнымиПричинами);
		ПоказателиСтатистики.Вставить("Ответственных", ВыборкаВсего.Ответственный);
		
		ВСреднемНаОтветственного = СборСтатистики.ОбъектовВСреднем(ВыборкаВсего.УволенныхСПричиной, ВыборкаВсего.Ответственный);
		Если ВСреднемНаОтветственного <> Неопределено Тогда
			ПоказателиСтатистики.Вставить("Уволенных в среднем(Ответственный)", ВСреднемНаОтветственного);
		КонецЕсли;
		
		ПричинОтветственного = Новый Массив;
		ВыборкаОтветственного = ВыборкаВсего.Выбрать();
		Пока ВыборкаОтветственного.Следующий() Цикл
			ПричинОтветственного.Добавить(ВыборкаОтветственного.УволенныхСПричиной);
		КонецЦикла;
		
		Дисперсия = СборСтатистики.Дисперсия(ВыборкаВсего.Ответственный, ПричинОтветственного, ВСреднемНаОтветственного);
		Если Дисперсия <> Неопределено Тогда
			ПоказателиСтатистики.Вставить("Дисперсия Уволенных(Ответственный)", Дисперсия);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ПоказателиСтатистики;
	
КонецФункции

