Функция СформироватьСписокНалоговыхКомитетов(Налогоплательщик, Знач ДатаАктуальности = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(ДатаАктуальности) Тогда
		ДатаАктуальности = ТекущаяДатаСеанса()
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Налогоплательщик",	Налогоплательщик);
	Запрос.УстановитьПараметр("ДатаАктуальности",	ДатаАктуальности);
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Организации.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_СписокСтруктурныхЕдениц
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	Организации.Ссылка = &Налогоплательщик
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	Организации.Ссылка
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	Организации.ГоловнаяОрганизация = &Налогоплательщик
	|	И Организации.ОбособленноеПодразделение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПодразделенияОрганизаций.Ссылка КАК Ссылка
	|ПОМЕСТИТЬ ВТ_ПолныйСписокПлательщиков
	|ИЗ
	|	ВТ_СписокСтруктурныхЕдениц КАК ВТ_СписокСтруктурныхЕдениц
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ПодразделенияОрганизаций КАК ПодразделенияОрганизаций
	|		ПО ВТ_СписокСтруктурныхЕдениц.Ссылка = ПодразделенияОрганизаций.Владелец
	|ГДЕ
	|	ПодразделенияОрганизаций.ОбособленноеПодразделение
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ВТ_СписокСтруктурныхЕдениц.Ссылка
	|ИЗ
	|	ВТ_СписокСтруктурныхЕдениц КАК ВТ_СписокСтруктурныхЕдениц
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ИсторияРегистрацийВНалоговомОрганеСрезПоследних.РегистрацияВНалоговомОргане КАК РегистрацияВНалоговомОргане,
	|	ИсторияРегистрацийВНалоговомОрганеСрезПоследних.РегистрацияВНалоговомОргане.Наименование КАК Наименование
	|ИЗ
	|	РегистрСведений.ИсторияРегистрацийВНалоговомОргане.СрезПоследних(
	|			&ДатаАктуальности,
	|			СтруктурнаяЕдиница В
	|				(ВЫБРАТЬ
	|					ВТ_ПолныйСписокПлательщиков.Ссылка
	|				ИЗ
	|					ВТ_ПолныйСписокПлательщиков КАК ВТ_ПолныйСписокПлательщиков)) КАК ИсторияРегистрацийВНалоговомОрганеСрезПоследних";
	
	Выборка = Запрос.Выполнить().Выбрать();
	СписокНК = Новый СписокЗначений;
	
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.РегистрацияВНалоговомОргане) Тогда
			ЭлементСписка 				= СписокНК.Добавить();
			ЭлементСписка.Значение 		= Выборка.РегистрацияВНалоговомОргане;
			ЭлементСписка.Представление = Выборка.Наименование;
		КонецЕсли;
	КонецЦикла;
	
	Возврат СписокНК;
	
КонецФункции

