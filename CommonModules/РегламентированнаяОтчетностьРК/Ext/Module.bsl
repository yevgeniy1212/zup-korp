Функция  ЗаполнитьКАТО(Запись)Экспорт
	
	Если ПустаяСтрока(Запись.ЗначенияПолей) Тогда
		ЗначенияПолейКИ = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению(Запись.Представление, Запись.Вид);
	Иначе
		ЗначенияПолейКИ = Запись.ЗначенияПолей;
	КонецЕсли;
	КодТерритории = "";
	
	СтруктураАдреса = РаботаСАдресами.ПредыдущаяСтруктураКонтактнойИнформацииXML(ЗначенияПолейКИ);
	
	Город = ?(СтруктураАдреса.Свойство("Город"), СтруктураАдреса.Город, "");
	НаселенныйПункт = ?(СтруктураАдреса.Свойство("НаселенныйПункт"), СтруктураАдреса.НаселенныйПункт, "");
	Регион = ?(СтруктураАдреса.Свойство("Регион"), СтруктураАдреса.Регион, "");
	Район = ?(СтруктураАдреса.Свойство("Район"), СтруктураАдреса.Район, "");

	СписокУровней = АдресныйКлассификаторПовтИсп.НомераУровнейАдресаПоНаименованию();
	
	Если НаселенныйПункт <> "" Тогда
		НаименованиеТерритории = СокрЛП(НаселенныйПункт);
		Уровень = СписокУровней.locality;
		Сокращение = СтруктураАдреса.НаселенныйПунктСокращение;
	ИначеЕсли Город <> "" Тогда
		НаименованиеТерритории = СокрЛП(Город);
		Уровень = СписокУровней.city;
		Сокращение = СтруктураАдреса.ГородСокращение;
	ИначеЕсли Район <> "" Тогда
		// "Ауэзовский район", уберем "район"
		НаименованиеТерритории = СокрЛП(Район);
		Уровень = СписокУровней.district;
		Сокращение = СтруктураАдреса.РайонСокращение;
	ИначеЕсли Регион <> "" Тогда
		// в том числе города республиканского значения
		НаименованиеТерритории = СокрЛП(Регион);
		Уровень = СписокУровней.area;
		Сокращение = СтруктураАдреса.РегионСокращение;
	Иначе
		НаименованиеТерритории = "";
		Уровень = 0;
		Сокращение = "";
	КонецЕсли;
	
	// Если территория выбиралась из адресного классификатора, то сокращения предопределены
	НаименованиеТерритории = СокрЛП(СтрЗаменить(НаименованиеТерритории, Сокращение, ""));
	
	// заменим спецсимволы
	НаименованиеТерритории = СтрЗаменить(НаименованиеТерритории, "~", "~~");
	НаименованиеТерритории = СтрЗаменить(НаименованиеТерритории, "%", "~%");
	НаименованиеТерритории = СтрЗаменить(НаименованиеТерритории, "_", "~_");
	НаименованиеТерритории = СтрЗаменить(НаименованиеТерритории, "[", "~[");
	НаименованиеТерритории = СтрЗаменить(НаименованиеТерритории, "-", "~-");
	НаименованиеТерритории = НаименованиеТерритории + "%";
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Наименование", НаименованиеТерритории);
	Запрос.УстановитьПараметр("Уровень", Уровень);
	
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	АдресныеОбъекты.КодКЛАДР КАК Код,
	|	АдресныеОбъекты.Наименование
	|ИЗ
	|	РегистрСведений.АдресныеОбъекты КАК АдресныеОбъекты
	|ГДЕ
	|	АдресныеОбъекты.Уровень = &Уровень
	|	И АдресныеОбъекты.Наименование ПОДОБНО &Наименование СПЕЦСИМВОЛ ""~""
	|
	|УПОРЯДОЧИТЬ ПО
	|	Код";
	
	ВыборкаКод = Запрос.Выполнить().Выбрать();
	Если ВыборкаКод.Следующий() Тогда
		КодТерритории = ВыборкаКод.Код;
	КонецЕсли;
	
	Возврат Формат(КодТерритории, "ЧГ=");	

КонецФункции 

