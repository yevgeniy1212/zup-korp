// АПК:1297-выкл Статистика, не локализуется

Функция СтатистикаЧатботов()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Чатботы.Ссылка) КАК Чатботов
		|ИЗ
		|	Справочник.Чатботы КАК Чатботы
		|ГДЕ
		|	Чатботы.ПометкаУдаления = ЛОЖЬ
		|	И Чатботы.Используется = ИСТИНА";
	
	ПоказателиСтатистики = Новый Соответствие;
	ПоказателиСтатистики.Вставить("Чатботов", Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Чатботов")[0]);
	
	Возврат ПоказателиСтатистики;
	
КонецФункции

