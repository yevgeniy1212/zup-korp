Функция ПериодичностьМедицинскихОсмотров(РабочееМесто, ВидОсмотра = Неопределено) Экспорт
	
	ОписаниеПериодичности = ОписаниеПериодичностиОсмотров();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидОсмотра", ВидОсмотра);
