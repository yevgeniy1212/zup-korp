	ОбновляемыеДанные = ОбновлениеИБ.ВыполнитьЗапросПолученияОбновляемыхДанных(Запрос, ПараметрыОбновления, "ВТНаправленияЗаключенияКОбновлению");
	
	Если ОбновляемыеДанные.Пустой() Тогда
		ОбновлениеИБ.ЗавершитьОбработчик(ПараметрыОбновления);
		Возврат;
	КонецЕсли;
	
	ОбновлениеИБ.ПродолжитьОбработчик(ПараметрыОбновления);
	
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВредныеФакторыНаправление.Ссылка КАК Документ,
		|	ВредныеФакторыНаправление.ВредныйФактор КАК ВредныйФактор
		|ПОМЕСТИТЬ ВТВредныеФакторыДокументов
		|ИЗ
		|	Документ.НаправлениеНаМедицинскийОсмотр.ВредныеФакторы КАК ВредныеФакторыНаправление
		|ГДЕ
		|	ВредныеФакторыНаправление.Ссылка В
		|		(ВЫБРАТЬ
		|			НаправленияЗаключенияКОбновлению.Документ
		|		ИЗ
		|			ВТНаправленияЗаключенияКОбновлению КАК НаправленияЗаключенияКОбновлению)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВидыРаботНаправление.Ссылка,
		|	ВидыРаботНаправление.ВидРабот
		|ИЗ
		|	Документ.НаправлениеНаМедицинскийОсмотр.ВидыРабот КАК ВидыРаботНаправление
		|ГДЕ
		|	ВидыРаботНаправление.Ссылка В
		|		(ВЫБРАТЬ
		|			НаправленияЗаключенияКОбновлению.Документ
		|		ИЗ
		|			ВТНаправленияЗаключенияКОбновлению КАК НаправленияЗаключенияКОбновлению)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВредныеФакторыЗаключение.Ссылка,
		|	ВредныеФакторыЗаключение.ВредныйФактор
		|ИЗ
		|	Документ.ЗаключениеМедицинскогоОсмотра.ВредныеФакторы КАК ВредныеФакторыЗаключение
		|ГДЕ
		|	ВредныеФакторыЗаключение.Ссылка В
		|		(ВЫБРАТЬ
		|			НаправленияЗаключенияКОбновлению.Документ
		|		ИЗ
		|			ВТНаправленияЗаключенияКОбновлению КАК НаправленияЗаключенияКОбновлению)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВидыРаботЗаключение.Ссылка,
		|	ВидыРаботЗаключение.ВидРабот
		|ИЗ
		|	Документ.ЗаключениеМедицинскогоОсмотра.ВидыРабот КАК ВидыРаботЗаключение
		|ГДЕ
		|	ВидыРаботЗаключение.Ссылка В
		|		(ВЫБРАТЬ
		|			НаправленияЗаключенияКОбновлению.Документ
		|		ИЗ
		|			ВТНаправленияЗаключенияКОбновлению КАК НаправленияЗаключенияКОбновлению)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НаправленияЗаключенияКОбновлению.Документ КАК Документ,
		|	ВредныеФакторыДокументов.ВредныйФактор
		|ПОМЕСТИТЬ ВТДокументыСВреднымиФакторами
		|ИЗ
		|	ВТНаправленияЗаключенияКОбновлению КАК НаправленияЗаключенияКОбновлению
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТВредныеФакторыДокументов КАК ВредныеФакторыДокументов
		|		ПО НаправленияЗаключенияКОбновлению.Документ = ВредныеФакторыДокументов.Документ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СоответствиеВредныхФакторов.Ссылка КАК ВредныйФактор302Н,
		|	СоответствиеВредныхФакторов.ВредныйФактор КАК ВредныйФактор29Н
		|ПОМЕСТИТЬ ВТСоответствиеВредныхФакторов
		|ИЗ
		|	Справочник.ВредныеОпасныеПроизводственныеФакторы.СоответствующиеВредныеФакторы КАК СоответствиеВредныхФакторов
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СоответствиеВредныхФакторов.Ссылка,
		|	СоответствиеВредныхФакторов.ВредныйФактор
		|ИЗ
		|	Справочник.ВидыРаботМедицинскихОсмотров.СоответствующиеВредныеФакторы КАК СоответствиеВредныхФакторов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДокументыСВреднымиФакторами.Документ КАК Документ,
		|	ДокументыСВреднымиФакторами.ВредныйФактор КАК ВредныйФактор302Н,
		|	СоответствиеВредныхФакторов.ВредныйФактор29Н КАК ВредныйФактор29Н,
		|	НЕ СоответствиеВредныхФакторов.ВредныйФактор29Н ЕСТЬ NULL КАК ЕстьСоответствие
		|ИЗ
		|	ВТДокументыСВреднымиФакторами КАК ДокументыСВреднымиФакторами
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСоответствиеВредныхФакторов КАК СоответствиеВредныхФакторов
		|		ПО ДокументыСВреднымиФакторами.ВредныйФактор = СоответствиеВредныхФакторов.ВредныйФактор302Н
		|УПОРЯДОЧИТЬ ПО
		|	Документ
		|ИТОГИ
		|ПО
		|	Документ,
		|	ВредныйФактор302Н";
		
	БлокировкаДанных = Новый БлокировкаДанных;
	БлокировкаДанных.Добавить("Документ.НаправлениеНаМедицинскийОсмотр");
	БлокировкаДанных.Добавить("Документ.ЗаключениеМедицинскогоОсмотра");
	
	НачатьТранзакцию();
	Попытка
		БлокировкаДанных.Заблокировать();
		
		ВыборкаДокументов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаДокументов.Следующий() Цикл
			Обработанные.Добавить(ВыборкаДокументов.Документ);
			ДокументОбъект = ВыборкаДокументов.Документ.ПолучитьОбъект();
			ВыборкаВредныхФакторов = ВыборкаДокументов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			КоличествоФакторов = ВыборкаВредныхФакторов.Количество();
			ВредныеФакторыСопоставлены = Истина;
			Пока ВыборкаВредныхФакторов.Следующий() Цикл
				Если КоличествоФакторов = 1 И Не ЗначениеЗаполнено(ВыборкаВредныхФакторов.ВредныйФактор302Н) Тогда
					Прервать;
				КонецЕсли;
				Выборка = ВыборкаВредныхФакторов.Выбрать();
				Если Выборка.Количество() > 1 Тогда;
					ВредныеФакторыСопоставлены = Ложь;
				КонецЕсли;
				Пока Выборка.Следующий() Цикл
					Если Выборка.ЕстьСоответствие Тогда
						ДокументОбъект.ВредныеФакторыИВидыРабот.Добавить().ВредныйФактор = Выборка.ВредныйФактор29Н;
					Иначе
						ВредныеФакторыСопоставлены = Ложь;
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
			Если ВредныеФакторыСопоставлены Или ДокументОбъект.ВредныеФакторыИВидыРабот.Количество() > 0 Тогда
				ДокументОбъект.ВредныеФакторыИВидыРабот.Свернуть("ВредныйФактор");
				ДокументОбъект.ВредныеФакторыИВидыРабот.Сортировать("ВредныйФактор");
				Если ТипЗнч(ВыборкаДокументов.Документ) = Тип("ДокументСсылка.ЗаключениеМедицинскогоОсмотра") И ДокументОбъект.Проведен Тогда
					ДокументОбъект.ЗаполнитьМедицинскиеОсмотрыПоВреднымФакторам();
				КонецЕсли;
				ЗаблокироватьДанныеДляРедактирования(ВыборкаДокументов.Документ);
				ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ДокументОбъект);
			КонецЕсли;
		КонецЦикла;
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ПредставлениеОбработки = НСтр("ru = 'Заполнение медицинских документов вредными факторами из классификатора по приказу №29н'"); 
		ЗарегистрироватьОшибкуОбработкиМедицинскихОсмотров(ИнформацияОбОшибке(), ПредставлениеОбработки);
		ВызватьИсключение;
	КонецПопытки;
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "Обработанные", Обработанные);
	
КонецПроцедуры

Процедура ЗаполнитьОрганизацииРабочихМест(ПараметрыОбновления = Неопределено) Экспорт
	
	Если ПараметрыОбновления = Неопределено Тогда
		ПараметрыОбновления = Новый Структура("ОбработкаЗавершена");
	КонецЕсли;
	
	ИменаРегистров = Новый Массив;
	ИменаРегистров.Добавить("ВидыРаботМедицинскихОсмотровРабочегоМеста");
	ИменаРегистров.Добавить("ВредныеФакторыИВидыРаботРабочегоМеста");
	ИменаРегистров.Добавить("ВредныеФакторыРабочегоМеста");
	ИменаРегистров.Добавить("ПериодичностьМедицинскихОсмотровРабочихМест");
	
	БлокировкаДанных = Новый БлокировкаДанных;
	Для Каждого ИмяРегистра Из ИменаРегистров Цикл
		БлокировкаДанных.Добавить("РегистрСведений." + ИмяРегистра);
	КонецЦикла;
	
	НачатьТранзакцию();
	Попытка
		БлокировкаДанных.Заблокировать();
		
		Для Каждого ИмяРегистра Из ИменаРегистров Цикл
			НаборЗаписей = РегистрыСведений[ИмяРегистра].СоздатьНаборЗаписей();
			НаборЗаписей.Прочитать();
			ЗаполнитьОрганизацию(НаборЗаписей);
			ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
		КонецЦикла;
		
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
	Исключение
		ОтменитьТранзакцию();
		ПредставлениеОбработки = НСтр("ru = 'Заполнение организаций для рабочих мест в регистрах сведений медосмотров'");
		ЗарегистрироватьОшибкуОбработкиМедицинскихОсмотров(ИнформацияОбОшибке(), ПредставлениеОбработки);
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

Процедура ОбновитьПериодичностьОсмотровРабочихМестПоВредномуФактору(ВредныйФактор)
	
	РабочиеМеста = РабочиеМестаПоВредномуФактору(ВредныйФактор);
	
	ОбновитьПериодичностьОсмотровРабочихМест(РабочиеМеста, ВредныйФактор.ВидОсмотра);
	
КонецПроцедуры

Функция РабочиеМестаПоВредномуФактору(ВредныйФактор)
	
	Если ТипЗнч(ВредныйФактор) = Тип("СправочникСсылка.ВредныеОпасныеПроизводственныеФакторы") Тогда
		РегистрСведений = РегистрыСведений.ВредныеФакторыРабочегоМеста;
	Иначе
		РегистрСведений = РегистрыСведений.ВредныеФакторыИВидыРаботРабочегоМеста;
	КонецЕсли;
	
	НаборЗаписей = РегистрСведений.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ВредныйФактор.Установить(ВредныйФактор);
	НаборЗаписей.Отбор.ВидОсмотра.Установить(ВредныйФактор.ВидОсмотра);
	НаборЗаписей.Прочитать();
	
	Возврат ОбщегоНазначенияКлиентСервер.СвернутьМассив(НаборЗаписей.ВыгрузитьКолонку("РабочееМесто"));
	
КонецФункции

Процедура ОбновитьПериодичностьОсмотровРабочихМестПоВидуРабот(ВидРабот)
	
	РабочиеМеста = РабочиеМестаПоВидуРабот(ВидРабот);
	
	ОбновитьПериодичностьОсмотровРабочихМест(РабочиеМеста, ВидРабот.ВидОсмотра);
	
КонецПроцедуры

Функция РабочиеМестаПоВидуРабот(ВидРабот)
	
	НаборЗаписей = РегистрыСведений.ВидыРаботМедицинскихОсмотровРабочегоМеста.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.ВидРабот.Установить(ВидРабот);
	НаборЗаписей.Отбор.ВидОсмотра.Установить(ВидРабот.ВидОсмотра);
	НаборЗаписей.Прочитать();
	
	Возврат ОбщегоНазначенияКлиентСервер.СвернутьМассив(НаборЗаписей.ВыгрузитьКолонку("РабочееМесто"));
	
КонецФункции

Процедура ОбновитьЗависимыеДанныеПоНаборуВредныхФакторовВидовРабот(НаборЗаписей) Экспорт
	
	ОбновитьПериодичностьОсмотровРабочихМестПоНаборуВредныхФакторовВидовРабот(НаборЗаписей);
	ОбновитьВредныеФакторыНаправленийЗаключений(НаборЗаписей);
	ОбновитьВредныеФакторыРезультатовСпецоценки(НаборЗаписей);
	
КонецПроцедуры

Процедура ОбновитьПериодичностьОсмотровРабочихМестПоНаборуВредныхФакторовВидовРабот(НаборЗаписей) Экспорт
	
	Если Не НаборЗаписей.ДополнительныеСвойства.Свойство("ПрежнийНабор") Тогда
		Возврат;
	КонецЕсли;
	
	ПрежнийНабор = НаборЗаписей.ДополнительныеСвойства["ПрежнийНабор"];
	
	Если ОбщегоНазначения.КоллекцииИдентичны(ПрежнийНабор, НаборЗаписей) Тогда
		Возврат;
	КонецЕсли;
	
	РабочиеМеста = НаборЗаписей.ВыгрузитьКолонку("РабочееМесто");
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(РабочиеМеста, ПрежнийНабор.ВыгрузитьКолонку("РабочееМесто"), Истина);

	ВидыОсмотра = НаборЗаписей.ВыгрузитьКолонку("ВидОсмотра");
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ВидыОсмотра, ПрежнийНабор.ВыгрузитьКолонку("ВидОсмотра"), Истина);
	ВидыОсмотра = ОбщегоНазначенияКлиентСервер.СвернутьМассив(ВидыОсмотра);
	
	УстановитьПривилегированныйРежим(Истина);
	Для каждого ВидОсмотра Из ВидыОсмотра Цикл
		ОбновитьПериодичностьОсмотровРабочихМест(РабочиеМеста, ВидОсмотра);
	КонецЦикла;
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

Процедура ОбновитьРабочиеМестаПоСопоставленнымВреднымФакторам(ФакторОбъект)
	
	Если Не ФакторОбъект.ДополнительныеСвойства.Свойство("ПрежниеСоответствующиеВредныеФакторы") Тогда
		Возврат;
	КонецЕсли;
	
	ВредныйФактор = ФакторОбъект.Ссылка;
	ТаблицаПрежнихВредныхФакторов = ФакторОбъект.ДополнительныеСвойства.ПрежниеСоответствующиеВредныеФакторы;
	
	ВредныеФакторыПрежние = ТаблицаПрежнихВредныхФакторов.ВыгрузитьКолонку("ВредныйФактор");
	ВредныеФакторыНовые = ВредныйФактор.СоответствующиеВредныеФакторы.Выгрузить().ВыгрузитьКолонку("ВредныйФактор");
	
	Если ОбщегоНазначения.КоллекцииИдентичны(ВредныеФакторыПрежние, ВредныеФакторыНовые) Тогда
		Возврат;
	КонецЕсли;
	
	ВредныеФакторыКДобавлению = ОбщегоНазначенияКлиентСервер.РазностьМассивов(ВредныеФакторыНовые, ВредныеФакторыПрежние);
	ВредныеФакторыКУдалению = ОбщегоНазначенияКлиентСервер.РазностьМассивов(ВредныеФакторыПрежние, ВредныеФакторыНовые);
	
	Если ВредныеФакторыКДобавлению.Количество() = 0 И ВредныеФакторыКУдалению.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ВредныйФактор) = Тип("СправочникСсылка.ВидыРаботМедицинскихОсмотров") Тогда
		РабочиеМеста = РабочиеМестаПоВидуРабот(ВредныйФактор);
	Иначе
		РабочиеМеста = РабочиеМестаПоВредномуФактору(ВредныйФактор);
		Если ТипЗнч(ВредныйФактор) = Тип("СправочникСсылка.ВредныеОпасныеПроизводственныеФакторыИВыполняемыеРаботы") Тогда
			ВредныеФакторыКУдалению.Добавить(ВредныйФактор);
		КонецЕсли;
	КонецЕсли;
	
	ВидОсмотра = ВредныйФактор.ВидОсмотра;
	
	Для Каждого РабочееМесто Из РабочиеМеста Цикл
		БлокировкаДанных = Новый БлокировкаДанных;
		ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("РегистрСведений.ВредныеФакторыИВидыРаботРабочегоМеста");
		ЭлементБлокировкиДанных.УстановитьЗначение("РабочееМесто", РабочееМесто);
		ЭлементБлокировкиДанных.УстановитьЗначение("ВидОсмотра", ВидОсмотра);
		
		НаборФакторов = РегистрыСведений.ВредныеФакторыИВидыРаботРабочегоМеста.СоздатьНаборЗаписей();
		НаборФакторов.Отбор.РабочееМесто.Установить(РабочееМесто);
		НаборФакторов.Отбор.ВидОсмотра.Установить(ВидОсмотра);
		
		НачатьТранзакцию();
		Попытка
			БлокировкаДанных.Заблокировать();
			НаборФакторов.Прочитать();
			ВредныеФакторыРабочегоМеста = НаборФакторов.ВыгрузитьКолонку("ВредныйФактор");
			НовыеВредныеФакторыРабочегоМеста = ОбщегоНазначения.СкопироватьРекурсивно(ВредныеФакторыРабочегоМеста);
			Для Каждого ФакторКУдалению Из ВредныеФакторыКУдалению Цикл
				ОбщегоНазначенияКлиентСервер.УдалитьЗначениеИзМассива(НовыеВредныеФакторыРабочегоМеста, ФакторКУдалению);
			КонецЦикла;
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(НовыеВредныеФакторыРабочегоМеста, ВредныеФакторыКДобавлению);
			НовыеВредныеФакторыРабочегоМеста = ОбщегоНазначенияКлиентСервер.СвернутьМассив(НовыеВредныеФакторыРабочегоМеста);
			Если ОбщегоНазначения.КоллекцииИдентичны(ВредныеФакторыРабочегоМеста, НовыеВредныеФакторыРабочегоМеста) Тогда
				Продолжить;
			КонецЕсли;
			НаборФакторов.Очистить();
			Для Каждого НовыйФактор Из НовыеВредныеФакторыРабочегоМеста Цикл
				НоваяЗапись = НаборФакторов.Добавить();
				НоваяЗапись.РабочееМесто = РабочееМесто;
				НоваяЗапись.ВидОсмотра = ВидОсмотра;
				НоваяЗапись.ВредныйФактор = НовыйФактор;
			КонецЦикла;
			НаборФакторов.ДополнительныеСвойства.Вставить("ОбновитьНаправленияЗаключения", Истина);
			НаборФакторов.ДополнительныеСвойства.Вставить("ОбновитьРезультатыСпецоценки", Истина);
			НаборФакторов.Записать();
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ПредставлениеОбработки = НСтр("ru = 'Обновление вредных факторов рабочего места'"); 
			ЗарегистрироватьОшибкуОбработкиМедицинскихОсмотров(ИнформацияОбОшибке(), ПредставлениеОбработки);
			ВызватьИсключение;
		КонецПопытки;
	КонецЦикла;
		
	ПроверитьРезультатСопоставлениеВредныхФакторовРабочегоМеста(РабочиеМеста);
		
КонецПроцедуры

Процедура ОбновитьВредныеФакторыНаправленийЗаключений(НаборЗаписей)
	
	Если Не НаборЗаписей.ДополнительныеСвойства.Свойство("ОбновитьНаправленияЗаключения") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не НаборЗаписей.ДополнительныеСвойства["ОбновитьНаправленияЗаключения"] Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	НаправлениеНаМедицинскийОсмотр.Ссылка КАК Документ,
		|	ЛОЖЬ КАК ПерезаполнятьМедосмотр
		|ИЗ
		|	Документ.НаправлениеНаМедицинскийОсмотр КАК НаправлениеНаМедицинскийОсмотр
		|ГДЕ
		|	НЕ НаправлениеНаМедицинскийОсмотр.ПометкаУдаления
		|	И НаправлениеНаМедицинскийОсмотр.РабочееМесто = &РабочееМесто
		|	И НаправлениеНаМедицинскийОсмотр.ВидОсмотра = &ВидОсмотра
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЗаключениеМедицинскогоОсмотра.Ссылка,
		|	ИСТИНА
		|ИЗ
		|	Документ.ЗаключениеМедицинскогоОсмотра КАК ЗаключениеМедицинскогоОсмотра
		|ГДЕ
		|	НЕ ЗаключениеМедицинскогоОсмотра.ПометкаУдаления
		|	И ЗаключениеМедицинскогоОсмотра.РабочееМесто = &РабочееМесто
		|	И ЗаключениеМедицинскогоОсмотра.ВидОсмотра = &ВидОсмотра";
	
	Запрос.УстановитьПараметр("РабочееМесто", НаборЗаписей.Отбор.РабочееМесто.Значение);
	Запрос.УстановитьПараметр("ВидОсмотра", НаборЗаписей.Отбор.ВидОсмотра.Значение);
	
	ВыборкаДокументов = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаДокументов.Следующий() Цикл
		ДокументОбъект = ВыборкаДокументов.Документ.ПолучитьОбъект();
		ДокументОбъект.ВредныеФакторыИВидыРабот.Очистить();
		Для Каждого Запись Из НаборЗаписей Цикл
			ДокументОбъект.ВредныеФакторыИВидыРабот.Добавить().ВредныйФактор = Запись.ВредныйФактор;
		КонецЦикла;
		Если ВыборкаДокументов.ПерезаполнятьМедосмотр Тогда
			ДокументОбъект.ЗаполнитьМедицинскиеОсмотрыПоВреднымФакторам();
		КонецЕсли;
		ЗаблокироватьДанныеДляРедактирования(ВыборкаДокументов.Документ);
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ДокументОбъект);
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбновитьВредныеФакторыРезультатовСпецоценки(НаборЗаписей)
	
	Если Не НаборЗаписей.ДополнительныеСвойства.Свойство("ОбновитьРезультатыСпецоценки") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не НаборЗаписей.ДополнительныеСвойства["ОбновитьРезультатыСпецоценки"] Тогда
		Возврат;
	КонецЕсли;
	
	// АПК:96 -выкл результат должен содержать уникальные значения
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	РезультатыСпецоценкиУсловийТрудаРабочиеМеста.Ссылка КАК Документ,
		|	РезультатыСпецоценкиУсловийТрудаРабочиеМеста.ИдентификаторСтрокиРабочегоМеста КАК ИдентификаторСтрокиРабочегоМеста,
		|	РезультатыСпецоценкиУсловийТрудаРабочиеМеста.Ссылка.Дата КАК Дата
		|ИЗ
		|	Документ.РезультатыСпецоценкиУсловийТруда.РабочиеМеста КАК РезультатыСпецоценкиУсловийТрудаРабочиеМеста
		|ГДЕ
		|	РезультатыСпецоценкиУсловийТрудаРабочиеМеста.РабочееМесто = &РабочееМесто
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	РезультатыСпецоценкиУсловийТрудаАналогичныеМеста.Ссылка,
		|	РезультатыСпецоценкиУсловийТрудаАналогичныеМеста.ИдентификаторСтрокиРабочегоМеста,
		|	РезультатыСпецоценкиУсловийТрудаАналогичныеМеста.Ссылка.Дата
		|ИЗ
		|	Документ.РезультатыСпецоценкиУсловийТруда.АналогичныеМеста КАК РезультатыСпецоценкиУсловийТрудаАналогичныеМеста
		|ГДЕ
		|	РезультатыСпецоценкиУсловийТрудаАналогичныеМеста.АналогичноеМесто = &РабочееМесто
		|УПОРЯДОЧИТЬ ПО
		|	Дата
		|ИТОГИ
		|ПО
		|	Документ";
	
	// АПК:96 -вкл
	
	РабочееМесто = НаборЗаписей.Отбор.РабочееМесто.Значение;
	
	Запрос.УстановитьПараметр("РабочееМесто", РабочееМесто);
	
	ВидОсмотра = НаборЗаписей.Отбор.ВидОсмотра.Значение;
	
	ВыборкаДокументов = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаДокументов.Следующий() Цикл
		ДокументОбъект = ВыборкаДокументов.Документ.ПолучитьОбъект();
		ВыборкаИдентификаторов = ВыборкаДокументов.Выбрать();
		Пока ВыборкаИдентификаторов.Следующий() Цикл
			ДанныеПоиска = Новый Структура("ИдентификаторСтрокиРабочегоМеста", ВыборкаИдентификаторов.ИдентификаторСтрокиРабочегоМеста);
			НайденныеСтроки = ДокументОбъект.ВредныеФакторы.НайтиСтроки(ДанныеПоиска);
			Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл 
				Если ЗначениеЗаполнено(НайденнаяСтрока.ВредныйФактор)
				 И ВидОсмотра = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(НайденнаяСтрока.ВредныйФактор, "ВидОсмотра") Тогда 
					ДокументОбъект.ВредныеФакторы.Удалить(НайденнаяСтрока); 
				КонецЕсли;
			КонецЦикла;
			Для Каждого Запись Из НаборЗаписей Цикл
				НоваяСтрока = ДокументОбъект.ВредныеФакторы.Добавить();
				НоваяСтрока.ВредныйФактор = Запись.ВредныйФактор;
				НоваяСтрока.ИдентификаторСтрокиРабочегоМеста = ВыборкаИдентификаторов.ИдентификаторСтрокиРабочегоМеста;
			КонецЦикла;
		КонецЦикла;
		ЗаблокироватьДанныеДляРедактирования(ВыборкаДокументов.Документ);
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ДокументОбъект);
	КонецЦикла;
	
	ОбновитьВредныеФакторыРабочихМест(, ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(РабочееМесто));
	
КонецПроцедуры

Процедура ПроверитьРезультатСопоставлениеВредныхФакторовРабочегоМеста(РабочиеМеста)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("РабочиеМеста", РабочиеМеста);
	Запрос.Текст =
		"ВЫБРАТЬ
		|	РабочиеМестаОхраныТруда.Ссылка КАК РабочееМесто
		|ИЗ
		|	Справочник.РабочиеМестаОхраныТруда КАК РабочиеМестаОхраныТруда
		|ГДЕ
		|	НЕ РабочиеМестаОхраныТруда.ВредныеФакторыСопоставлены
		|	И РабочиеМестаОхраныТруда.Ссылка В (&РабочиеМеста)
		|	И (ВЫБОР
		|		КОГДА (РабочиеМестаОхраныТруда.Ссылка, ЛОЖЬ) В
		|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
		|				ВредныеФакторыРабочегоМеста.РабочееМесто КАК РабочееМесто,
		|				ВредныеФакторыРабочегоМеста.ВредныйФактор.СоответствиеПодтверждено КАК СоответствиеПодтверждено
		|			ИЗ
		|				РегистрСведений.ВредныеФакторыРабочегоМеста КАК ВредныеФакторыРабочегоМеста
		|			ГДЕ
		|				ВредныеФакторыРабочегоМеста.РабочееМесто В (&РабочиеМеста)
		|
		|			ОБЪЕДИНИТЬ ВСЕ
		|
		|			ВЫБРАТЬ РАЗЛИЧНЫЕ
		|				ВидыРаботМедицинскихОсмотров.РабочееМесто,
		|				ВидыРаботМедицинскихОсмотров.ВидРабот.СоответствиеПодтверждено
		|			ИЗ
		|				РегистрСведений.ВидыРаботМедицинскихОсмотровРабочегоМеста КАК ВидыРаботМедицинскихОсмотров
		|			ГДЕ
		|				ВидыРаботМедицинскихОсмотров.РабочееМесто В (&РабочиеМеста)
		|
		|			ОБЪЕДИНИТЬ ВСЕ
		|
		|			ВЫБРАТЬ РАЗЛИЧНЫЕ
		|				ВредныеФакторыИВидыРаботРабочегоМеста.РабочееМесто,
		|				ВредныеФакторыИВидыРаботРабочегоМеста.ВредныйФактор.СоответствиеПодтверждено
		|			ИЗ
		|				РегистрСведений.ВредныеФакторыИВидыРаботРабочегоМеста КАК ВредныеФакторыИВидыРаботРабочегоМеста
		|			ГДЕ
		|				ВредныеФакторыИВидыРаботРабочегоМеста.РабочееМесто В (&РабочиеМеста)
		|				И ВредныеФакторыИВидыРаботРабочегоМеста.ВредныйФактор.ВАрхиве)
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ)";
	
	Выборка =  Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		РабочееМестоОбъект = Выборка.РабочееМесто.ПолучитьОбъект();
		ЗаблокироватьДанныеДляРедактирования(Выборка.РабочееМесто);
		РабочееМестоОбъект.ВредныеФакторыСопоставлены = Истина;
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(РабочееМестоОбъект);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти
