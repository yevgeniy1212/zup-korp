		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ДокументОбъект);
	КонецЦикла; 
	
КонецПроцедуры

Процедура ОбновитьПериодическиеОсмотрыНазначенныхРабочихМест(ПараметрыОбновления = Неопределено) Экспорт
	
	ОбновлениеИБ = ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	РабочиеМестаСотрудников.ФизическоеЛицо КАК ФизическоеЛицо,
		|	РабочиеМестаСотрудников.ГоловнаяОрганизация КАК ГоловнаяОрганизация
		|ИЗ
		|	РегистрСведений.РабочиеМестаСотрудников КАК РабочиеМестаСотрудников";
	
	ОбновляемыеДанные = ОбновлениеИБ.ВыполнитьЗапросПолученияОбновляемыхДанных(Запрос, ПараметрыОбновления, , Неопределено);
	
	Если ОбновляемыеДанные.Пустой() Тогда
		ОбновлениеИБ.ЗавершитьОбработчик(ПараметрыОбновления);
		Возврат;
	КонецЕсли;
	
	ОбновлениеИБ.ПродолжитьОбработчик(ПараметрыОбновления);
	
	Выборка = ОбновляемыеДанные.Выбрать();
	
	ТаблицаОбновления = НоваяТаблицаОбновлениеПериодическихОсмотров();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ТаблицаОбновления.Добавить(), Выборка);
	КонецЦикла;
	
	Если ТаблицаОбновления.Количество() = 0 Тогда
		ОбновлениеИБ.ЗавершитьОбработчик(ПараметрыОбновления);
		Возврат;
	КонецЕсли;
	
	ЗарегистрироватьОбновлениеПериодическихОсмотров(ТаблицаОбновления);
	ОбновлениеИБ.ЗавершитьОбработчик(ПараметрыОбновления);
	
	ФизическиеЛица = ТаблицаОбновления.ВыгрузитьКолонку("ФизическоеЛицо");
	ЗапуститьОбновлениеПериодическихОсмотров(, ФизическиеЛица);
	
КонецПроцедуры

Процедура ЗаполнитьРабочиеМестаНовымиВреднымиФакторами(ПараметрыОбновления = Неопределено) Экспорт

	ОбновлениеИБ = ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый;
	
	Если ПараметрыОбновления = Неопределено Тогда
		ПараметрыОбновления = Новый Структура("ОбработкаЗавершена");
	КонецЕсли;
	
	Если Не Справочники.ВредныеОпасныеПроизводственныеФакторыИВыполняемыеРаботы.ЕстьСоответствия() Тогда
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Обновление информационной базы.Отсутствуют соответствия вредных факторов по приказу 302н вредным факторам по приказу 29н'", 
				ОбщегоНазначения.КодОсновногоЯзыка()), УровеньЖурналаРегистрации.Ошибка);
		ОбновлениеИБ.ЗавершитьОбработчик(ПараметрыОбновления);
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВредныеФакторыИВидыРаботРабочегоМеста.РабочееМесто КАК РабочееМесто
		|ПОМЕСТИТЬ ВТРабочиеМестаОбновленные
		|ИЗ
		|	РегистрСведений.ВредныеФакторыИВидыРаботРабочегоМеста КАК ВредныеФакторыИВидыРаботРабочегоМеста
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	РабочиеМеста.Ссылка КАК РабочееМесто
		|ПОМЕСТИТЬ ВТРабочиеМестаКОбновлению
		|ИЗ
		|	Справочник.РабочиеМестаОхраныТруда КАК РабочиеМеста
		|ГДЕ
		|	НЕ РабочиеМеста.Ссылка В (&Обработанные)
		|	И НЕ РабочиеМеста.ЭтоГруппа
		|	И НЕ РабочиеМеста.ВАрхиве
		|	И НЕ РабочиеМеста.ВредныеФакторыСопоставлены
		|	И НЕ РабочиеМеста.Ссылка В
		|		(ВЫБРАТЬ
		|			РабочиеМестаОбновленные.РабочееМесто
		|		ИЗ
		|			ВТРабочиеМестаОбновленные КАК РабочиеМестаОбновленные)";
	
	Если Не ПараметрыОбновления.Свойство("Обработанные") Тогда
		Обработанные = Новый Массив;
		ПараметрыОбновления.Вставить("Обработанные");
	ИначеЕсли ПараметрыОбновления.Обработанные = Неопределено Тогда
		Обработанные = Новый Массив;
	Иначе
		Обработанные = ПараметрыОбновления.Обработанные;
	КонецЕсли;
	Запрос.УстановитьПараметр("Обработанные", Обработанные);
	
	ОбновляемыеДанные = ОбновлениеИБ.ВыполнитьЗапросПолученияОбновляемыхДанных(Запрос, ПараметрыОбновления, "ВТРабочиеМестаКОбновлению");
	
	Если ОбновляемыеДанные.Пустой() Тогда
		ОбновлениеИБ.ЗавершитьОбработчик(ПараметрыОбновления);
		Возврат;
	КонецЕсли;
	
	ОбновлениеИБ.ПродолжитьОбработчик(ПараметрыОбновления);
	
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВредныеФакторыРабочегоМеста.РабочееМесто КАК РабочееМесто,
		|	ВредныеФакторыРабочегоМеста.ВредныйФактор КАК ВредныйФактор
		|ПОМЕСТИТЬ ВТВредныеФакторыРабочегоМеста
		|ИЗ
		|	РегистрСведений.ВредныеФакторыРабочегоМеста КАК ВредныеФакторыРабочегоМеста
		|ГДЕ
		|	ВредныеФакторыРабочегоМеста.РабочееМесто В
		|		(ВЫБРАТЬ
		|			РабочиеМестаКОбновлению.РабочееМесто
		|		ИЗ
		|			ВТРабочиеМестаКОбновлению КАК РабочиеМестаКОбновлению)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВидыРаботРабочегоМеста.РабочееМесто,
		|	ВидыРаботРабочегоМеста.ВидРабот
		|ИЗ
		|	РегистрСведений.ВидыРаботМедицинскихОсмотровРабочегоМеста КАК ВидыРаботРабочегоМеста
		|ГДЕ
		|	ВидыРаботРабочегоМеста.РабочееМесто В
		|		(ВЫБРАТЬ
		|			РабочиеМестаКОбновлению.РабочееМесто
		|		ИЗ
		|			ВТРабочиеМестаКОбновлению КАК РабочиеМестаКОбновлению)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РабочиеМестаКОбновлению.РабочееМесто КАК РабочееМесто,
		|	ВредныеФакторыРабочегоМеста.ВредныйФактор
		|ПОМЕСТИТЬ ВТРабочиеМестаСВреднымиФакторами
		|ИЗ
		|	ВТРабочиеМестаКОбновлению КАК РабочиеМестаКОбновлению
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТВредныеФакторыРабочегоМеста КАК ВредныеФакторыРабочегоМеста
		|		ПО РабочиеМестаКОбновлению.РабочееМесто = ВредныеФакторыРабочегоМеста.РабочееМесто
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СоответствиеВредныхФакторов.Ссылка КАК ВредныйФактор302Н,
		|	СоответствиеВредныхФакторов.ВредныйФактор КАК ВредныйФактор29Н
		|ПОМЕСТИТЬ ВТСоответствиеВредныхФакторов
		|ИЗ
		|	Справочник.ВредныеОпасныеПроизводственныеФакторы.СоответствующиеВредныеФакторы КАК СоответствиеВредныхФакторов
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СоответствиеВредныхФакторов.Ссылка,
		|	СоответствиеВредныхФакторов.ВредныйФактор
		|ИЗ
		|	Справочник.ВидыРаботМедицинскихОсмотров.СоответствующиеВредныеФакторы КАК СоответствиеВредныхФакторов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РабочиеМестаСВреднымиФакторами.РабочееМесто КАК РабочееМесто,
		|	РабочиеМестаСВреднымиФакторами.ВредныйФактор КАК ВредныйФактор302Н,
		|	СоответствиеВредныхФакторов.ВредныйФактор29Н КАК ВредныйФактор29Н,
		|	НЕ СоответствиеВредныхФакторов.ВредныйФактор29Н ЕСТЬ NULL КАК ЕстьСоответствие
		|ИЗ
		|	ВТРабочиеМестаСВреднымиФакторами КАК РабочиеМестаСВреднымиФакторами
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСоответствиеВредныхФакторов КАК СоответствиеВредныхФакторов
		|		ПО РабочиеМестаСВреднымиФакторами.ВредныйФактор = СоответствиеВредныхФакторов.ВредныйФактор302Н
		|ИТОГИ
		|ПО
		|	РабочееМесто,
		|	ВредныйФактор302Н";
		
	БлокировкаДанных = Новый БлокировкаДанных;
	БлокировкаДанных.Добавить("РегистрСведений.ВредныеФакторыРабочегоМеста");
	БлокировкаДанных.Добавить("РегистрСведений.ВидыРаботМедицинскихОсмотровРабочегоМеста");
	
	НачатьТранзакцию();
	Попытка
		БлокировкаДанных.Заблокировать();
		
		ВыборкаРабочихМест = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		РабочиеМестаСНовымиФакторами = Новый Массив;
		
		Пока ВыборкаРабочихМест.Следующий() Цикл
			Обработанные.Добавить(ВыборкаРабочихМест.РабочееМесто);
			НовыеФакторы = Новый Массив;
			НаборЗаписей = РегистрыСведений.ВредныеФакторыИВидыРаботРабочегоМеста.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.РабочееМесто.Установить(ВыборкаРабочихМест.РабочееМесто);
			НаборЗаписей.Отбор.ВидОсмотра.Использование = Ложь;
			
			ВыборкаВредныхФакторов = ВыборкаРабочихМест.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			КоличествоФакторов = ВыборкаВредныхФакторов.Количество();
			ВредныеФакторыСопоставлены = Истина;
			Пока ВыборкаВредныхФакторов.Следующий() Цикл
				Если КоличествоФакторов = 1 И Не ЗначениеЗаполнено(ВыборкаВредныхФакторов.ВредныйФактор302Н) Тогда
					Прервать;
				КонецЕсли;
				Выборка = ВыборкаВредныхФакторов.Выбрать();
				Если Выборка.Количество() > 1 Тогда;
					ВредныеФакторыСопоставлены = Ложь;
				КонецЕсли;
				Пока Выборка.Следующий() Цикл
					Если Выборка.ЕстьСоответствие И НовыеФакторы.Найти(Выборка.ВредныйФактор29Н) = Неопределено Тогда
						НовыеФакторы.Добавить(Выборка.ВредныйФактор29Н);
						НоваяЗапись = НаборЗаписей.Добавить();
						НоваяЗапись.РабочееМесто = ВыборкаРабочихМест.РабочееМесто;
						НоваяЗапись.ВредныйФактор = Выборка.ВредныйФактор29Н;
						НоваяЗапись.ВидОсмотра = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Выборка.ВредныйФактор29Н, "ВидОсмотра");
					Иначе
						ВредныеФакторыСопоставлены = Ложь;
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
			НовыеФакторыДобавлены = НаборЗаписей.Количество() > 0;
			Если НовыеФакторыДобавлены Тогда
				РабочиеМестаСНовымиФакторами.Добавить(ВыборкаРабочихМест.РабочееМесто);
			КонецЕсли;
			Если ВредныеФакторыСопоставлены Или НовыеФакторыДобавлены Тогда
				ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
				
				РабочееМестоОбъект = ВыборкаРабочихМест.РабочееМесто.ПолучитьОбъект();
				ЗаблокироватьДанныеДляРедактирования(ВыборкаРабочихМест.РабочееМесто);
				РабочееМестоОбъект.ВредныеФакторыСопоставлены = ВредныеФакторыСопоставлены;
				ОбновлениеИнформационнойБазы.ЗаписатьОбъект(РабочееМестоОбъект);
			КонецЕсли;
		КонецЦикла;
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ПредставлениеОбработки = НСтр("ru = 'Заполнение рабочих мест вредными факторами из классификатора по приказу №29н'"); 
		ЗарегистрироватьОшибкуОбработкиМедицинскихОсмотров(ИнформацияОбОшибке(), ПредставлениеОбработки);
		ВызватьИсключение;
	КонецПопытки;
	
	ОбновитьПериодичностьОсмотровРабочихМест(РабочиеМестаСНовымиФакторами, Перечисления.ВидыОбследований.МедицинскийОсмотр);
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "Обработанные", Обработанные);
	
КонецПроцедуры

