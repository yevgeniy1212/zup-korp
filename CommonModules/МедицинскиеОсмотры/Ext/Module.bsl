	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПериодичностьОсмотров.КратностьОсмотра КАК Кратность,
		|	ПериодичностьОсмотров.ПериодичностьОсмотра КАК Периодичность,
		|	ПериодичностьОсмотров.ЕдиницаПериодичностиОсмотра КАК ЕдиницаПериодичности,
		|	ПериодичностьОсмотров.ПредставлениеПериодичностиОсмотра КАК Представление,
		|	ПериодичностьОсмотров.Однократно КАК Однократно
		|ИЗ
		|	РегистрСведений.ПериодичностьМедицинскихОсмотровРабочихМест КАК ПериодичностьОсмотров
		|ГДЕ
		|	ПериодичностьОсмотров.РабочееМесто = &РабочееМесто
		|	И ПериодичностьОсмотров.ВидОсмотра = &ВидОсмотра";
	
	Если ВидОсмотра = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПериодичностьОсмотров.ВидОсмотра = &ВидОсмотра", "ИСТИНА");
