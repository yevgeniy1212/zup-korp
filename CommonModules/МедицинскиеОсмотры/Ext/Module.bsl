Функция ВредныеФакторыИВидыРаботТребующиеОсмотра(ФизическоеЛицо, ВидОсмотра, РабочееМесто, ДатаАктуальности) Экспорт
	
	ВредныеФакторыИВидыРабот = Новый ТаблицаЗначений;
	ВредныеФакторыИВидыРабот.Колонки.Добавить("ВредныйФактор", Новый ОписаниеТипов("СправочникСсылка.ВредныеОпасныеПроизводственныеФакторыИВыполняемыеРаботы"));
	ВредныеФакторыИВидыРабот.Колонки.Добавить("ДатаОсмотра", Новый ОписаниеТипов("Дата"));
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	СоздатьВТВредныеФакторыИВидыРаботРабочегоМеста(МенеджерВременныхТаблиц, РабочееМесто, ВидОсмотра);
	
	Если Не ЗарплатаКадры.ВТСодержитСтроки(МенеджерВременныхТаблиц, "ВТВредныеФакторыИВидыРаботРабочегоМеста") Тогда
		Возврат ВредныеФакторыИВидыРабот;
	КонецЕсли;
	
	СоздатьВТПериодичностьВредныхФакторов(МенеджерВременныхТаблиц, "ВТВредныеФакторыИВидыРаботРабочегоМеста");
	СоздатьВТОсмотрыПоВреднымФакторамФизическогоЛица(МенеджерВременныхТаблиц, ФизическоеЛицо, ДатаАктуальности, Истина);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВредныеФакторыРабочегоМеста.ВредныйФактор КАК ВредныйФактор,
		|	ОсмотрыПоВреднымФакторам.ДатаОсмотра КАК ДатаОсмотра,
		|	ОсмотрыПоВреднымФакторам.РезультатОсмотра КАК РезультатОсмотра,
		|	ПериодичностьВредныхФакторов.Кратность КАК Кратность,
		|	ПериодичностьВредныхФакторов.Периодичность КАК Периодичность,
		|	ПериодичностьВредныхФакторов.ЕдиницаПериодичности КАК ЕдиницаПериодичности,
		|	ПериодичностьВредныхФакторов.Однократно КАК Однократно
		|ИЗ
		|	ВТВредныеФакторыИВидыРаботРабочегоМеста КАК ВредныеФакторыРабочегоМеста
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТОсмотрыПоВреднымФакторам КАК ОсмотрыПоВреднымФакторам
		|		ПО (ОсмотрыПоВреднымФакторам.ВредныйФактор = ВредныеФакторыРабочегоМеста.ВредныйФактор)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТПериодичностьВредныхФакторов КАК ПериодичностьВредныхФакторов
		|		ПО (ПериодичностьВредныхФакторов.ВредныйФактор = ВредныеФакторыРабочегоМеста.ВредныйФактор)";
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Если Не ЗначениеЗаполнено(Выборка.ДатаОсмотра) Тогда
			// Осмотр не проводился.
			НоваяСтрока = ВредныеФакторыИВидыРабот.Добавить();
			НоваяСтрока.ВредныйФактор = Выборка.ВредныйФактор;
			НоваяСтрока.ДатаОсмотра = ДатаАктуальности;
			Продолжить;
		КонецЕсли;
		// Осмотр проводился, проверяем его актуальность.
		ОписаниеПериодичности = ОписаниеПериодичностиОсмотров();
		ЗаполнитьЗначенияСвойств(ОписаниеПериодичности, Выборка);
		ДатаСледующегоОсмотра = ДатаСледующегоОсмотра(Выборка.ДатаОсмотра, ОписаниеПериодичности);
		Если ДатаСледующегоОсмотра > ДатаАктуальности Тогда
			Продолжить;
		КонецЕсли;
		НоваяСтрока = ВредныеФакторыИВидыРабот.Добавить();
		НоваяСтрока.ВредныйФактор = Выборка.ВредныйФактор;
		НоваяСтрока.ДатаОсмотра = ДатаСледующегоОсмотра;
	КонецЦикла;
	
	Возврат ВредныеФакторыИВидыРабот;
	
КонецФункции

