	ОсмотрыПоВидамРабот.Колонки.Добавить("СостояниеПроцент", Новый ОписаниеТипов("Число"));
	ОсмотрыПоВидамРабот.Колонки.Добавить("Требуется", Новый ОписаниеТипов("Булево"));
	ОсмотрыПоВидамРабот.Колонки.Добавить("Регистратор");
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	СоздатьВТВидыРаботРабочегоМеста(МенеджерВременныхТаблиц, РабочееМесто, ВидОсмотра);
	СоздатьВТОсмотрыПоВидамРаботФизическогоЛица(МенеджерВременныхТаблиц, ФизическоеЛицо, ДатаАктуальности);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ВидОсмотра", ВидОсмотра);
	Запрос.УстановитьПараметр("ЕстьВидОсмотра", Не ВидОсмотра = Неопределено);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОсмотрыПоВидамРабот.ВидРабот КАК ВидРабот,
		|	ОсмотрыПоВидамРабот.ДатаОсмотра КАК ПоследнийОсмотр,
		|	ОсмотрыПоВидамРабот.Регистратор КАК Регистратор,
		|	ОсмотрыПоВидамРабот.РезультатОсмотра КАК РезультатОсмотра,
		|	ВЫБОР
		|		КОГДА ВидыРаботПозиции.ВидРабот ЕСТЬ НЕ NULL
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ТребуетсяРабочимМестом
		|ПОМЕСТИТЬ ВТСостояниеОсмотров
		|ИЗ
		|	ВТОсмотрыПоВидамРабот КАК ОсмотрыПоВидамРабот
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТВидыРаботПозиции КАК ВидыРаботПозиции
		|		ПО ВидыРаботПозиции.ВидРабот = ОсмотрыПоВидамРабот.ВидРабот
		|		И ВЫБОР
		|			КОГДА &ЕстьВидОсмотра
		|				ТОГДА ВидыРаботПозиции.ВидОсмотра = &ВидОсмотра
		|			ИНАЧЕ ИСТИНА
		|		КОНЕЦ
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВидыРаботПозиции.ВидРабот,
		|	NULL,
		|	NULL,
		|	NULL,
		|	ИСТИНА
		|ИЗ
		|	ВТВидыРаботПозиции КАК ВидыРаботПозиции
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТОсмотрыПоВидамРабот КАК ОсмотрыПоВидамРабот
		|		ПО ВидыРаботПозиции.ВидРабот = ОсмотрыПоВидамРабот.ВидРабот
		|ГДЕ
		|	ОсмотрыПоВидамРабот.ВидРабот ЕСТЬ NULL";
	Запрос.Выполнить();
	
	СоздатьВТПериодичностьВидовРабот(МенеджерВременныхТаблиц, "ВТСостояниеОсмотров");
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СостояниеОсмотров.ВидРабот КАК ВидРабот,
		|	СостояниеОсмотров.ПоследнийОсмотр КАК ПоследнийОсмотр,
		|	СостояниеОсмотров.Регистратор КАК Регистратор,
		|	СостояниеОсмотров.РезультатОсмотра КАК Результат,
		|	СостояниеОсмотров.ТребуетсяРабочимМестом КАК Требуется,
		|	ПериодичностьВидовРабот.Кратность КАК Кратность,
		|	ПериодичностьВидовРабот.Периодичность КАК Периодичность,
		|	ПериодичностьВидовРабот.ЕдиницаПериодичности КАК ЕдиницаПериодичности
		|ИЗ
		|	ВТСостояниеОсмотров КАК СостояниеОсмотров
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТПериодичностьВидовРабот КАК ПериодичностьВидовРабот
		|		ПО (ПериодичностьВидовРабот.ВидРабот = СостояниеОсмотров.ВидРабот)";
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ДобавитьСтрокуТаблицыОсмотровПоФакторам(ОсмотрыПоВидамРабот, Выборка);
	КонецЦикла;
	
	Возврат ОсмотрыПоВидамРабот;
	
КонецФункции

Процедура ЗаполнитьРабочееМесто(РабочееМесто, КадровыеДанные) Экспорт
	
	Если Не ОхранаТруда.ОхранаТрудаИспользуется() Тогда
		Возврат;
	КонецЕсли; 
	
	Если ЗначениеЗаполнено(РабочееМесто) Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КадровыеДанные[0].РабочееМестоОхраныТруда) Тогда
		РабочееМесто = КадровыеДанные[0].РабочееМестоОхраныТруда;
	КонецЕсли;
	
КонецПроцедуры

// Выполняется при изменении состава вредных факторов или видов работ для рабочего места или при изменении периодичности
// одного из них.
//
Процедура ОбновитьПериодичностьОсмотровРабочихМест(РабочиеМеста, ВидОсмотра) Экспорт
	
	ЭтоПсихиатрическийОсмотр = ВидОсмотра = Перечисления.ВидыОбследований.ПсихиатрическоеОсвидетельствование;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТекущаяДата", НачалоДня(ТекущаяДатаСеанса()));
	Запрос.УстановитьПараметр("РабочиеМеста", РабочиеМеста);
	Запрос.УстановитьПараметр("ВидОсмотра", ВидОсмотра);
	Запрос.УстановитьПараметр("ЭтоПсихиатрическийОсмотр", ЭтоПсихиатрическийОсмотр);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СправочникРабочиеМеста.Ссылка КАК РабочееМесто,
		|	ВЫБОР
		|		КОГДА ИСТИНА В
		|				(ВЫБРАТЬ ПЕРВЫЕ 1
		|					ИСТИНА
		|				ИЗ
		|					РегистрСведений.ВредныеФакторыИВидыРаботРабочегоМеста КАК ВредныеФакторыИВидыРаботРабочегоМеста
		|				ГДЕ
		|					ВредныеФакторыИВидыРаботРабочегоМеста.РабочееМесто = СправочникРабочиеМеста.Ссылка
		|					И ВредныеФакторыИВидыРаботРабочегоМеста.ВидОсмотра = &ВидОсмотра)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЕстьВредныеФакторыИВидыРабот,
		|	ВЫБОР
		|		КОГДА ИСТИНА В
		|				(ВЫБРАТЬ ПЕРВЫЕ 1
		|					ИСТИНА
		|				ИЗ
		|					РегистрСведений.ВредныеФакторыРабочегоМеста КАК ВредныеФакторыРабочегоМеста
		|				ГДЕ
		|					ВредныеФакторыРабочегоМеста.РабочееМесто = СправочникРабочиеМеста.Ссылка
		|					И ВредныеФакторыРабочегоМеста.ВидОсмотра = &ВидОсмотра
		|					И НЕ ВредныеФакторыРабочегоМеста.ВредныйФактор.СоответствиеПодтверждено)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЕстьВредныеФакторы,
		|	ВЫБОР
		|		КОГДА ИСТИНА В
		|				(ВЫБРАТЬ ПЕРВЫЕ 1
		|					ИСТИНА
		|				ИЗ
		|					РегистрСведений.ВидыРаботМедицинскихОсмотровРабочегоМеста КАК ВидыРаботРабочегоМеста
		|				ГДЕ
		|					ВидыРаботРабочегоМеста.РабочееМесто = СправочникРабочиеМеста.Ссылка
		|					И ВидыРаботРабочегоМеста.ВидОсмотра = &ВидОсмотра
		|					И НЕ ВидыРаботРабочегоМеста.ВидРабот.СоответствиеПодтверждено)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ЕстьВидыРабот
		|ИЗ
		|	Справочник.РабочиеМестаОхраныТруда КАК СправочникРабочиеМеста
		|ГДЕ
		|	СправочникРабочиеМеста.Ссылка В(&РабочиеМеста)
		|
		|УПОРЯДОЧИТЬ ПО
		|	РабочееМесто
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВредныеФакторыРабочегоМеста.РабочееМесто КАК РабочееМесто,
		|	ВредныеФакторы.КратностьОсмотра КАК Кратность,
		|	ВредныеФакторы.ПериодичностьОсмотра КАК Периодичность,
		|	ВредныеФакторы.ЕдиницаПериодичностиОсмотра КАК ЕдиницаПериодичности,
		|	ВредныеФакторы.Однократно КАК Однократно,
		|	ВЫБОР
		|		КОГДА &ЭтоПсихиатрическийОсмотр
		|			ТОГДА """"
		|		ИНАЧЕ ВредныеФакторы.Код
		|	КОНЕЦ КАК ВредныйФакторКод,
		|	ВредныеФакторы.Наименование КАК ВредныйФакторНаименование,
		|	NULL КАК ВидРаботКод,
		|	NULL КАК ВидРаботНаименование
		|ИЗ
		|	РегистрСведений.ВредныеФакторыРабочегоМеста КАК ВредныеФакторыРабочегоМеста
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВредныеОпасныеПроизводственныеФакторы КАК ВредныеФакторы
		|		ПО ВредныеФакторыРабочегоМеста.ВредныйФактор = ВредныеФакторы.Ссылка
		|			И (ВредныеФакторыРабочегоМеста.РабочееМесто В (&РабочиеМеста))
		|			И (ВредныеФакторыРабочегоМеста.ВидОсмотра = &ВидОсмотра)
		|			И (НЕ ВредныеФакторы.СоответствиеПодтверждено)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВидыРаботРабочегоМеста.РабочееМесто,
		|	ВидыРабот.КратностьОсмотра,
		|	ВидыРабот.ПериодичностьОсмотра,
		|	ВидыРабот.ЕдиницаПериодичностиОсмотра,
		|	ВидыРабот.Однократно,
		|	NULL,
		|	NULL,
		|	ВЫБОР
		|		КОГДА &ЭтоПсихиатрическийОсмотр
		|			ТОГДА """"
		|		ИНАЧЕ ВидыРабот.Код
		|	КОНЕЦ,
		|	ВидыРабот.Наименование
		|ИЗ
		|	РегистрСведений.ВидыРаботМедицинскихОсмотровРабочегоМеста КАК ВидыРаботРабочегоМеста
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыРаботМедицинскихОсмотров КАК ВидыРабот
		|		ПО ВидыРаботРабочегоМеста.ВидРабот = ВидыРабот.Ссылка
		|			И (ВидыРаботРабочегоМеста.РабочееМесто В (&РабочиеМеста))
		|			И (ВидыРаботРабочегоМеста.ВидОсмотра = &ВидОсмотра)
		|			И (НЕ ВидыРабот.СоответствиеПодтверждено)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВредныеФакторыИВидыРаботРабочегоМеста.РабочееМесто,
		|	ВредныеФакторы.КратностьОсмотра,
		|	ВредныеФакторы.ПериодичностьОсмотра,
		|	ВредныеФакторы.ЕдиницаПериодичностиОсмотра,
		|	ВредныеФакторы.Однократно,
		|	ВредныеФакторы.Код,
		|	ВредныеФакторы.Наименование,
		|	NULL,
		|	NULL
		|ИЗ
		|	РегистрСведений.ВредныеФакторыИВидыРаботРабочегоМеста КАК ВредныеФакторыИВидыРаботРабочегоМеста
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВредныеОпасныеПроизводственныеФакторыИВыполняемыеРаботы КАК ВредныеФакторы
		|		ПО ВредныеФакторыИВидыРаботРабочегоМеста.ВредныйФактор = ВредныеФакторы.Ссылка
		|			И (ВредныеФакторыИВидыРаботРабочегоМеста.РабочееМесто В (&РабочиеМеста))
		|			И (ВредныеФакторыИВидыРаботРабочегоМеста.ВидОсмотра = &ВидОсмотра)
		|
		|УПОРЯДОЧИТЬ ПО
		|	РабочееМесто";
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаРабочихМест = РезультатыЗапроса[0].Выбрать();
	ВыборкаФакторов = РезультатыЗапроса[1].Выбрать();
	Пока ВыборкаРабочихМест.Следующий() Цикл
		НаборЗаписей = РегистрыСведений.ПериодичностьМедицинскихОсмотровРабочихМест.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.РабочееМесто.Установить(ВыборкаРабочихМест.РабочееМесто);
		НаборЗаписей.Отбор.ВидОсмотра.Установить(ВидОсмотра);
		Если Не ВыборкаРабочихМест.ЕстьВредныеФакторы И Не ВыборкаРабочихМест.ЕстьВидыРабот И Не ВыборкаРабочихМест.ЕстьВредныеФакторыИВидыРабот Тогда
			НаборЗаписей.Записать();
			Продолжить;
		КонецЕсли;
		ПредставленияФакторов = ПредставленияФакторов();
		ОписанияПериодичности = Новый Массив;
		ВыборкаФакторов.СледующийПоЗначениюПоля("РабочееМесто");
		Пока ВыборкаФакторов.Следующий() Цикл
			Описание = ОписаниеПериодичностиОсмотров();
			ЗаполнитьЗначенияСвойств(Описание, ВыборкаФакторов);
			ОписанияПериодичности.Добавить(Описание);
			ДополнитьПредставленияФакторов(ПредставленияФакторов, ВыборкаФакторов, ЭтоПсихиатрическийОсмотр);
		КонецЦикла;
		МинимальнаяПериодичность = МинимальнаяПериодичность(ОписанияПериодичности);
		СтрокаНабора = НаборЗаписей.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаНабора, ПредставленияФакторов);
		СтрокаНабора.РабочееМесто = ВыборкаРабочихМест.РабочееМесто;
		СтрокаНабора.ВидОсмотра = ВидОсмотра;
		СтрокаНабора.Однократно = МинимальнаяПериодичность.Однократно;
		СтрокаНабора.КратностьОсмотра = МинимальнаяПериодичность.Кратность;
		СтрокаНабора.ПериодичностьОсмотра = МинимальнаяПериодичность.Периодичность;
		СтрокаНабора.ЕдиницаПериодичностиОсмотра = МинимальнаяПериодичность.ЕдиницаПериодичности;
		СтрокаНабора.ПредставлениеПериодичностиОсмотра = МинимальнаяПериодичность.Представление;
		НаборЗаписей.Записать();
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗапуститьОбновлениеПериодическихОсмотров(Организация = Неопределено, ФизическиеЛица = Неопределено) Экспорт
	
	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьМедицинскиеОсмотры") Тогда 
		Возврат;
	КонецЕсли;
	
	Параметры = Новый Массив;
	Параметры.Добавить(Организация);
	Параметры.Добавить(ФизическиеЛица);
	
	ФоновыеЗадания.Выполнить("МедицинскиеОсмотры.ОбновитьПериодическиеОсмотры", Параметры);
	
КонецПроцедуры

Функция МинимальнаяПериодичностьОсмотров(ВредныеФакторыВидыРабот) Экспорт
	
	ОписаниеПериодичности = ОписаниеПериодичностиОсмотров();
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ВредныеФакторыВидыРабот);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВредныеФакторы.КратностьОсмотра КАК Кратность,
		|	ВредныеФакторы.ПериодичностьОсмотра КАК Периодичность,
		|	ВредныеФакторы.ЕдиницаПериодичностиОсмотра КАК ЕдиницаПериодичности,
		|	ВредныеФакторы.Однократно КАК Однократно
		|ИЗ
		|	Справочник.ВредныеОпасныеПроизводственныеФакторы КАК ВредныеФакторы
		|ГДЕ
		|	ВредныеФакторы.Ссылка В (&Ссылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВидыРабот.КратностьОсмотра,
		|	ВидыРабот.ПериодичностьОсмотра,
		|	ВидыРабот.ЕдиницаПериодичностиОсмотра,
		|	ВидыРабот.Однократно
		|ИЗ
		|	Справочник.ВидыРаботМедицинскихОсмотров КАК ВидыРабот
		|ГДЕ
		|	ВидыРабот.Ссылка В (&Ссылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВредныеОпасныеПроизводственныеФакторыИВыполняемыеРаботы.КратностьОсмотра,
		|	ВредныеОпасныеПроизводственныеФакторыИВыполняемыеРаботы.ПериодичностьОсмотра,
		|	ВредныеОпасныеПроизводственныеФакторыИВыполняемыеРаботы.ЕдиницаПериодичностиОсмотра,
		|	ВредныеОпасныеПроизводственныеФакторыИВыполняемыеРаботы.Однократно
		|ИЗ
		|	Справочник.ВредныеОпасныеПроизводственныеФакторыИВыполняемыеРаботы КАК ВредныеОпасныеПроизводственныеФакторыИВыполняемыеРаботы
		|ГДЕ
		|	ВредныеОпасныеПроизводственныеФакторыИВыполняемыеРаботы.Ссылка В (&Ссылка)";
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат ОписаниеПериодичности;
	КонецЕсли;
	
	МаксимальныйКоэффициент = 0;
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.Однократно Тогда
			ОписаниеПериодичности.Однократно = Истина;
			Продолжить;
		КонецЕсли;
		Коэффициент = Выборка.Кратность * ЧастейВГоду(Выборка.ЕдиницаПериодичности) / Выборка.Периодичность;
		Если Коэффициент > МаксимальныйКоэффициент Тогда
			ЗаполнитьЗначенияСвойств(ОписаниеПериодичности, Выборка);
			МаксимальныйКоэффициент = Коэффициент;
		КонецЕсли;
	КонецЦикла;
	
	ЗаполнитьПредставлениеПериодичности(ОписаниеПериодичности);
	
	Возврат ОписаниеПериодичности;
	
КонецФункции

Функция ПериодичностьОсмотровПоВреднымФакторам(ВредныеФакторы) Экспорт
	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъектов(ВредныеФакторы, "ПредставлениеПериодичностиОсмотра");
КонецФункции

Процедура ОбновитьВредныеФакторыРабочихМест(ИсточникСсылка = Неопределено, РабочиеМеста = Неопределено) Экспорт
	
	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьМедицинскиеОсмотры") Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Ссылка", ИсточникСсылка);
	Запрос.УстановитьПараметр("ЕстьОтборРабочихМест", РабочиеМеста <> Неопределено);
	Запрос.УстановитьПараметр("РабочиеМеста", РабочиеМеста);
	
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	РабочиеМестаОхраныТруда.Ссылка КАК РабочееМесто,
	|	ЕСТЬNULL(РабочиеМестаПоРезультату.Ссылка, НЕОПРЕДЕЛЕНО) КАК Документ,
	|	ВредныеФакторыПоРезультату.ВредныйФактор КАК ВредныйФактор,
	|	ВредныеФакторыПоРезультату.ВредныйФактор.ВидОсмотра КАК ВидОсмотра,
	|	НЕ ВредныеФакторыПоРезультату.ВредныйФактор ЕСТЬ NULL КАК ЕстьФакторы
	|ПОМЕСТИТЬ ВТВсеРабочиеМеста
	|ИЗ
	|	Справочник.РабочиеМестаОхраныТруда КАК РабочиеМестаОхраныТруда
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РезультатыСпецоценкиУсловийТруда.РабочиеМеста КАК РабочиеМестаПоРезультату
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РезультатыСпецоценкиУсловийТруда КАК РезультатыСпецоценкиУсловийТруда
	|			ПО РабочиеМестаПоРезультату.Ссылка = РезультатыСпецоценкиУсловийТруда.Ссылка
	|				И (РезультатыСпецоценкиУсловийТруда.Проведен)
	|				И (РезультатыСпецоценкиУсловийТруда.Ссылка <> &Ссылка)
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.РезультатыСпецоценкиУсловийТруда.ВредныеФакторы КАК ВредныеФакторыПоРезультату
	|			ПО РабочиеМестаПоРезультату.Ссылка = ВредныеФакторыПоРезультату.Ссылка
	|				И РабочиеМестаПоРезультату.ИдентификаторСтрокиРабочегоМеста = ВредныеФакторыПоРезультату.ИдентификаторСтрокиРабочегоМеста
	|		ПО РабочиеМестаОхраныТруда.Ссылка = РабочиеМестаПоРезультату.РабочееМесто
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &ЕстьОтборРабочихМест
	|				ТОГДА РабочиеМестаОхраныТруда.Ссылка В (&РабочиеМеста)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И НЕ РабочиеМестаОхраныТруда.ЭтоГруппа
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РабочиеМестаОхраныТруда.Ссылка,
	|	ЕСТЬNULL(АналогичныеМестаПоРезультату.Ссылка, НЕОПРЕДЕЛЕНО),
	|	ВредныеФакторыПоРезультату.ВредныйФактор,
	|	ВредныеФакторыПоРезультату.ВредныйФактор.ВидОсмотра,
	|	НЕ ВредныеФакторыПоРезультату.ВредныйФактор ЕСТЬ NULL
	|ИЗ
	|	Справочник.РабочиеМестаОхраныТруда КАК РабочиеМестаОхраныТруда
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РезультатыСпецоценкиУсловийТруда.АналогичныеМеста КАК АналогичныеМестаПоРезультату
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РезультатыСпецоценкиУсловийТруда КАК РезультатыСпецоценкиУсловийТруда
	|			ПО АналогичныеМестаПоРезультату.Ссылка = РезультатыСпецоценкиУсловийТруда.Ссылка
	|				И (РезультатыСпецоценкиУсловийТруда.Проведен)
	|				И (РезультатыСпецоценкиУсловийТруда.Ссылка <> &Ссылка)
	|			ЛЕВОЕ СОЕДИНЕНИЕ Документ.РезультатыСпецоценкиУсловийТруда.ВредныеФакторы КАК ВредныеФакторыПоРезультату
	|			ПО АналогичныеМестаПоРезультату.Ссылка = ВредныеФакторыПоРезультату.Ссылка
	|				И АналогичныеМестаПоРезультату.ИдентификаторСтрокиРабочегоМеста = ВредныеФакторыПоРезультату.ИдентификаторСтрокиРабочегоМеста
	|		ПО РабочиеМестаОхраныТруда.Ссылка = АналогичныеМестаПоРезультату.АналогичноеМесто
	|ГДЕ
	|	ВЫБОР
	|			КОГДА &ЕстьОтборРабочихМест
	|				ТОГДА РабочиеМестаОхраныТруда.Ссылка В (&РабочиеМеста)
	|			ИНАЧЕ ИСТИНА
	|		КОНЕЦ
	|	И НЕ РабочиеМестаОхраныТруда.ЭтоГруппа
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВсеРабочиеМеста.РабочееМесто КАК РабочееМесто,
	|	МАКСИМУМ(ВсеРабочиеМеста.Документ) КАК Документ
	|ПОМЕСТИТЬ ВТМаксимальныеРабочиеМеста
	|ИЗ
	|	ВТВсеРабочиеМеста КАК ВсеРабочиеМеста
	|
	|СГРУППИРОВАТЬ ПО
	|	ВсеРабочиеМеста.РабочееМесто
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВсеРабочиеМеста.РабочееМесто КАК РабочееМесто,
	|	МАКСИМУМ(ВсеРабочиеМеста.ЕстьФакторы) КАК ЕстьФакторы
	|ИЗ
	|	ВТМаксимальныеРабочиеМеста КАК МаксимальныеРабочиеМеста
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТВсеРабочиеМеста КАК ВсеРабочиеМеста
	|		ПО МаксимальныеРабочиеМеста.РабочееМесто = ВсеРабочиеМеста.РабочееМесто
	|			И МаксимальныеРабочиеМеста.Документ = ВсеРабочиеМеста.Документ
	|
	|СГРУППИРОВАТЬ ПО
	|	ВсеРабочиеМеста.РабочееМесто
	|
	|УПОРЯДОЧИТЬ ПО
	|	РабочееМесто
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВсеРабочиеМеста.РабочееМесто КАК РабочееМесто,
	|	ВсеРабочиеМеста.ВредныйФактор КАК ВредныйФактор,
	|	ВсеРабочиеМеста.ВидОсмотра КАК ВидОсмотра,
	|	ВсеРабочиеМеста.Документ КАК Документ,
	|	ВсеРабочиеМеста.ЕстьФакторы КАК ЕстьФакторы
	|ИЗ
	|	ВТМаксимальныеРабочиеМеста КАК МаксимальныеРабочиеМеста
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТВсеРабочиеМеста КАК ВсеРабочиеМеста
	|		ПО МаксимальныеРабочиеМеста.РабочееМесто = ВсеРабочиеМеста.РабочееМесто
	|			И МаксимальныеРабочиеМеста.Документ = ВсеРабочиеМеста.Документ
	|
	|УПОРЯДОЧИТЬ ПО
	|	РабочееМесто";
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаРабочихМест = РезультатыЗапроса[2].Выбрать();
	ВыборкаФакторов = РезультатыЗапроса[3].Выбрать();
	Пока ВыборкаРабочихМест.Следующий() Цикл
		ВыборкаФакторов.СледующийПоЗначениюПоля("РабочееМесто");
		ПоРезультатуСпецоценки = Истина;
		
		БлокировкаДанных = Новый БлокировкаДанных;
		ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("РегистрСведений.ВредныеФакторыИВидыРаботРабочегоМеста");
		ЭлементБлокировкиДанных.УстановитьЗначение("РабочееМесто", ВыборкаРабочихМест.РабочееМесто);
		
		НаборЗаписей = РегистрыСведений.ВредныеФакторыИВидыРаботРабочегоМеста.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.РабочееМесто.Установить(ВыборкаРабочихМест.РабочееМесто);
		
		НачатьТранзакцию();
		Попытка
			БлокировкаДанных.Заблокировать();
			НаборЗаписей.Прочитать();
			Для Каждого НайденнаяСтрока Из НаборЗаписей Цикл
				Если Не ЗначениеЗаполнено(НайденнаяСтрока.Основание) Тогда
					ПоРезультатуСпецоценки = Ложь;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			Если Не ВыборкаРабочихМест.ЕстьФакторы Тогда
				Если ПоРезультатуСпецоценки Тогда
					НаборЗаписей.Очистить();
					НаборЗаписей.Записать();
				КонецЕсли;
			Иначе
				НаборЗаписей.Очистить();
				Пока ВыборкаФакторов.Следующий() Цикл
					НоваяСтрока = НаборЗаписей.Добавить();
					НоваяСтрока.РабочееМесто = ВыборкаРабочихМест.РабочееМесто;
					НоваяСтрока.ВредныйФактор = ВыборкаФакторов.ВредныйФактор;
					НоваяСтрока.ВидОсмотра = ВыборкаФакторов.ВидОсмотра;
					НоваяСтрока.Основание = ВыборкаФакторов.Документ;
				КонецЦикла;
				НаборЗаписей.Записать();
			КонецЕсли;
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ПредставлениеОбработки = НСтр("ru = 'Обновление вредных факторов рабочих мест по результатам спецоценки'"); 
			ЗарегистрироватьОшибкуОбработкиМедицинскихОсмотров(ИнформацияОбОшибке(), ПредставлениеОбработки);
			ВызватьИсключение;
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

Функция МедицинскиеОсмотрыФизическихЛиц(ФизическиеЛица) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ФизическиеЛица", ФизическиеЛица);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПериодическиеМедицинскиеОсмотры.ВидОсмотра КАК ВидОсмотра,
	|	ПериодическиеМедицинскиеОсмотры.ДатаПройденногоОсмотра КАК ДатаПройденногоОсмотра,
	|	ПериодическиеМедицинскиеОсмотры.РезультатОсмотра КАК РезультатОсмотра,
	|	ПериодическиеМедицинскиеОсмотры.ФизическоеЛицо КАК ФизическоеЛицо
	|ИЗ
	|	РегистрСведений.ПериодическиеМедицинскиеОсмотры КАК ПериодическиеМедицинскиеОсмотры
	|ГДЕ
	|	ПериодическиеМедицинскиеОсмотры.ФизическоеЛицо В (&ФизическиеЛица)";
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

#Область ПодключениеСобытийОбновленияПериодическихОсмотров

Процедура ЗарегистрироватьИзменениеРабочихМестДляМедосмотровПриЗаписи(Источник, Отказ, Замещение) Экспорт
	
	Если ЗарплатаКадры.ОтключитьБизнесЛогикуПриЗаписи(Источник) Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьТаблицуОбновленияРабочихМестДляМедосмотров(Источник);
	
	ЗарегистрироватьОбновлениеПериодическихОсмотров(Источник.ДополнительныеСвойства.ТаблицаОбновлениеПериодическихОсмотров);
	
КонецПроцедуры

Процедура ЗарегистрироватьИзменениеКадровойИсторииДляМедосмотровПриЗаписи(Источник, Отказ, Замещение) Экспорт
	
	Если ЗарплатаКадры.ОтключитьБизнесЛогикуПриЗаписи(Источник) Тогда
		Возврат;
	КонецЕсли;
	
	ТипРегистратора = ТипЗнч(Источник.Отбор.Регистратор.Значение);
	Если Не (ТипРегистратора = Тип("ДокументСсылка.Увольнение") Или ТипРегистратора = Тип("ДокументСсылка.УвольнениеСписком")
		Или ТипРегистратора = Тип("ДокументСсылка.ПрекращениеПодработки")) Тогда
		
		Возврат;
	КонецЕсли;
	
	ЗаполнитьТаблицуОбновленияКадровойИсторииДляМедосмотров(Источник);
	
	ЗарегистрироватьОбновлениеПериодическихОсмотров(Источник.ДополнительныеСвойства.ТаблицаОбновлениеПериодическихОсмотров);
	
КонецПроцедуры

Процедура ЗарегистрироватьИзменениеФизическогоЛицаДляМедосмотровПриЗаписи(Источник, Отказ) Экспорт
	
	Если ЗарплатаКадры.ОтключитьБизнесЛогикуПриЗаписи(Источник) Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаОбновленияПериодическихОсмотров = НоваяТаблицаОбновлениеПериодическихОсмотров();
	
	ЗаполнитьТаблицуОбновленияПериодическихОсмотровПоФизическомуЛицу(ТаблицаОбновленияПериодическихОсмотров, Источник);
	
	ЗарегистрироватьОбновлениеПериодическихОсмотров(ТаблицаОбновленияПериодическихОсмотров);
	
КонецПроцедуры

Процедура ЗаполнитьТаблицуОбновленияПериодическихОсмотровПоФизическимЛицам(ТаблицаОбновлениеПериодическихОсмотров, ФизическиеЛица) Экспорт

	Если ФизическиеЛица.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	МенеджерВТ = Новый МенеджерВременныхТаблиц;
	
	ОтборыМассив = Новый Массив;
	ЗарплатаКадрыОбщиеНаборыДанных.ДобавитьВКоллекциюОтбор(ОтборыМассив, "ФизическоеЛицо", "В", ФизическиеЛица);
	ЗарплатаКадрыОбщиеНаборыДанных.ДобавитьВКоллекциюОтбор(ОтборыМассив, "ОформленПоТрудовомуДоговору", "=", Истина);
	ЗарплатаКадрыОбщиеНаборыДанных.ДобавитьВКоллекциюОтбор(ОтборыМассив, "ДатаУвольнения", "<", ТекущаяДатаСеанса());
	КадровыйУчет.СоздатьВТТекущиеКадровыеДанныеСотрудников(МенеджерВТ, Ложь, ОтборыМассив, "ГоловнаяОрганизация");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВТ;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КадровыеДанные.ФизическоеЛицо КАК ФизическоеЛицо,
		|	КадровыеДанные.ГоловнаяОрганизация КАК ГоловнаяОрганизация
		|ИЗ
		|	ВТТекущиеКадровыеДанныеСотрудников КАК КадровыеДанные";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ТаблицаОбновлениеПериодическихОсмотров.Добавить(), Выборка);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ПодключениеВводаНаОсновании

Процедура ЗаполнитьКадровыйПереводПоЗаключениюМедицинскогоОсмотра(ДокументОбъект, Основание) Экспорт
	ЗаполнитьДокументОтстраненияПоЗаключениюМедицинскогоОсмотра(ДокументОбъект, Основание);	
КонецПроцедуры

Процедура ЗаполнитьУвольнениеПоЗаключениюМедицинскогоОсмотра(ДокументОбъект, Основание) Экспорт
	ЗаполнитьДокументОтстраненияПоЗаключениюМедицинскогоОсмотра(ДокументОбъект, Основание);
КонецПроцедуры

Процедура ПриЗаписиДокументаОтстранения(ДокументОбъект) Экспорт
	
	Если Не ДокументОбъект.ДополнительныеСвойства.Свойство("Основание") Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	НаборЗаписей = РегистрыСведений.ОтстранениеОтРаботыПоРезультатамМедицинскогоОсмотра.СоздатьНаборЗаписей();
	
	СтрокаНабора = НаборЗаписей.Добавить();
	СтрокаНабора.ДокументОтстранения = ДокументОбъект.Ссылка;
	СтрокаНабора.ЗаключениеМедицинскогоОсмотра = ДокументОбъект.ДополнительныеСвойства["Основание"];
	СтрокаНабора.Организация = ДокументОбъект.Организация;
	СтрокаНабора.ФизическоеЛицо = ДокументОбъект.ФизическоеЛицо;
	
	НаборЗаписей.Отбор.ДокументОтстранения.Установить(ДокументОбъект.Ссылка);
	НаборЗаписей.Записать();
	
КонецПроцедуры

Процедура ЗаполнитьОплатуПоСреднемуПоНаправлениюНаМедицинскийОсмотр(ДокументОбъект, Основание) Экспорт
	
	Если ТипЗнч(Основание) <> Тип("ДокументСсылка.НаправлениеНаМедицинскийОсмотр") Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеНаправления = Документы.НаправлениеНаМедицинскийОсмотр.ДанныеНаправления(Основание);
	Если ДанныеНаправления = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ДанныеНаправления.Проведен Тогда
		ТекстСообщения = НСтр("ru = 'Документ направления на медицинский осмотр не проведен'");
		ВызватьИсключение ТекстСообщения;
	КонецЕсли;
	
	Сотрудник = СотрудникПоФизическомуЛицу(
		ДанныеНаправления.ФизическоеЛицо, 
		ДанныеНаправления.РабочееМесто,
		ДанныеНаправления.Организация);
		
	ДокументОбъект["ДатаНачала"] = ДанныеНаправления.ДатаОсмотра;
	ДокументОбъект["ДатаОкончания"] = ДанныеНаправления.ДатаОсмотра;
	ДокументОбъект.Заполнить(Сотрудник);
	
КонецПроцедуры

