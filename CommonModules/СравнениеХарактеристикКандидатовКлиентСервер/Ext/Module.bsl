#Область СлужебныеПроцедурыИФункции

Функция ЛичныеДанныеКандидатаПоНомеруКолонки(НомераКолонок, НомерКолонки) Экспорт

	НайденныеСтроки = НомераКолонок.НайтиСтроки(Новый Структура("Номер", НомерКолонки));
	Если НайденныеСтроки.Количество() > 0 Тогда
		Возврат НайденныеСтроки[0].ЛичныеДанныеКандидата;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция КандидатПоНомеруКолонки(НомераКолонок, НомерКолонки) Экспорт

	НайденныеСтроки = НомераКолонок.НайтиСтроки(Новый Структура("Номер", НомерКолонки));
	Если НайденныеСтроки.Количество() > 0 Тогда
		Возврат НайденныеСтроки[0].Кандидат;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция НомерКолонкиЛичныеДанныеКандидата(НомераКолонок, ЛичныеДанныеКандидата) Экспорт
	
	НайденныеСтроки = НомераКолонок.НайтиСтроки(Новый Структура("ЛичныеДанныеКандидата", ЛичныеДанныеКандидата));
	Если НайденныеСтроки.Количество() > 0 Тогда
		Возврат НайденныеСтроки[0].Номер;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция ИмяКолонки(Префикс, Номер) Экспорт
	Возврат СтрСоединить(ОбщегоНазначенияБЗККлиентСервер.ЗначенияВМассиве(Префикс, Формат(Номер, "ЧГ=;")), "_");
КонецФункции

Функция ВидыОтбораПериода() Экспорт
	ВидыОтбора = Новый Структура;
	ВидыОтбора.Вставить("Все", НСтр("ru = 'за все время'"));
	ВидыОтбора.Вставить("Неделя", НСтр("ru = 'за неделю'"));
	ВидыОтбора.Вставить("Месяц", НСтр("ru = 'за месяц'"));
	ВидыОтбора.Вставить("ТриМесяца", НСтр("ru = 'за 3 месяца'"));
	ВидыОтбора.Вставить("Полгода", НСтр("ru = 'за полгода'"));
	ВидыОтбора.Вставить("Год", НСтр("ru = 'за год'"));
	Возврат ВидыОтбора;
КонецФункции

#КонецОбласти