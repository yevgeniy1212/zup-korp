#Область СлужебныйПрограммныйИнтерфейс

Процедура ОткрытьФормуНастройкиДоступа(ФормаВладелец) Экспорт
	ОткрытьФорму("РегистрСведений.ДоступДляЗагрузкиКандидатовИзИнтернета.Форма.НастройкаДоступа", , ФормаВладелец);
КонецПроцедуры

Процедура ФормаСОповещениямиПриОткрытии(Форма, Отказ) Экспорт
	ПодключитьПроверкуЗагруженныхИзИнтернетаКандидатов(Форма);
КонецПроцедуры

Процедура ФормаСОповещениямиПриЗакрытии(Форма) Экспорт
	ОтключитьОбработчикОжиданияПроверкиЗагруженныхКандидатов(Форма);
	ОповеститьДругиеФормыОбОтключении(Форма);
КонецПроцедуры

Процедура ФормаСОповещениямиОбработкаОповещения(Форма, ИмяСобытия, Параметр, Источник) Экспорт
	
	Если ИмяСобытия = "ПроверкаЗагруженныхКандидатовВключена" И Источник <> Форма Тогда
		ОтключитьОбработчикОжиданияПроверкиЗагруженныхКандидатов(Форма);
	КонецЕсли;

	Если ИмяСобытия = "ПроверкаЗагруженныхКандидатовОтключена" И Источник <> Форма Тогда
		ПодключитьПроверкуЗагруженныхИзИнтернетаКандидатов(Форма);
	КонецЕсли;

	Если ИмяСобытия = "СообщатьОНеЗагруженныхКандидатах" И Источник <> Форма Тогда
		УстановитьУведомленияОНеЗагруженныхКандидатах(Форма, Параметр);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьЗагруженныхИзИнтернетаКандидатов(Форма) Экспорт

	НовыеЗагрузки = ЗагрузкаКандидатовИзИнтернетаВызовСервера.НовыеЗагрузкиКандидатовИзИнтернета();
	
	Для Каждого Загрузка Из НовыеЗагрузки.Загружены Цикл
		ШаблонСообщения = ?(Загрузка.Пол = ПредопределенноеЗначение("Перечисление.ПолФизическогоЛица.Женский"), 
			НСтр("ru = '%1 загружена с сайта %2'"), 
			НСтр("ru = '%1 загружен с сайта %2'"));
		ПоказатьОповещениеПользователя(НСтр("ru = 'Новый кандидат'"), 
			Новый ОписаниеОповещения("ПоказатьЗагруженногоКандидата", ЭтотОбъект, 
				Новый Структура("Кандидат", Загрузка.Кандидат)), 
			СтрШаблон(ШаблонСообщения, Загрузка.Кандидат, Загрузка.Сайт), 
			Форма.ЛоготипыСайтов[Загрузка.Сайт], 
			СтатусОповещенияПользователя.Важное, 
			Загрузка.Кандидат);
		ОбщегоНазначенияКлиент.ОповеститьОбИзмененииОбъекта(Загрузка.Кандидат);
	КонецЦикла;
	
	Если УведомлятьОНеЗагруженныхКандидатах(Форма) И НовыеЗагрузки.НеЗагружены.Количество() > 0 Тогда
		ПоказатьОповещениеПользователя(
			СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(
				НСтр("ru = ';%1 кандидат не загружен;;%1 кандидата не загружены;%1 кандидатов не загружены;'"),
				НовыеЗагрузки.НеЗагружены.Количество()),
			Новый ОписаниеОповещения("НачатьПоказНеЗагруженныхКандидатов", ЭтотОбъект, Новый Структура("Форма", Форма)), 
			СтрШаблон(НСтр("ru = 'Резюме кандидатов из браузера не удалось загрузить'")), 
			БиблиотекаКартинок.Предупреждение32, 
			СтатусОповещенияПользователя.Важное, 
			"НеЗагруженныеКандидаты");
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПодключитьПроверкуЗагруженныхИзИнтернетаКандидатов(Форма)
	
	Если Не Форма.ПроверятьЗагрузкуКандидатовИзИнтернета Тогда
		Возврат;
	КонецЕсли;
	
	// Любая форма, подключенная к оповещениям, подключает свой обработчик.
	// При этом в каждый момент времени обработчик работает только в одной из открытых форм - в самой последней открытой.
	//
	// Кроме обработчика ожидания в каждой форме есть еще реквизит СообщатьОНеЗагруженныхКандидатах (Булево), 
	// который определяет необходимость оповещать об ошибках загрузки. 
	// Особенность этого уведомления в том, что оно 
	// - отключается, когда форма не загруженных кандидатов открывается,
	// - включается, когда форма не загруженных кандидатов закрывается.
	//
	// Как это работает.
	// При открытии каждой формы с оповещением в ней подключается обработчик, и выдается оповещение всем другим формам.
	// При получении этого оповещения любая другая форма с оповещениями:
	// - отключает свой обработчик ожидания оповещения,
	// - сообщает широковещательно о включенности оповещения о не загруженных кандидатах.
	// Если в этот момент в форме было отключено сообщение о не загруженных кандидатах, например, по причине того, 
	// что форма не загруженных была открыта, то об этом будет сообщено новой форме, и в ней тоже отключится сообщение.
	// При закрытии формы сообщение о не загруженных кандидатах включается и об этом также сообщается широковещательно,
	// благодаря чему, сообщение о не загруженных кандидатах включается в другой форме, в которой сейчас обработчик активен.
	
	ПодключитьОбработчикОжиданияПроверкиЗагруженныхКандидатов(Форма);
	ВключитьУведомленияОНеЗагруженныхКандидатах(Форма);
	ОповеститьДругиеФормыОПодключении(Форма);
	
КонецПроцедуры

Процедура ПодключитьОбработчикОжиданияПроверкиЗагруженныхКандидатов(Форма)
	Форма.ПодключитьОбработчикОжиданияПроверкиЗагруженныхКандидатов(ИнтервалПроверкиЗагруженныхКандидатов());
КонецПроцедуры

Процедура ОтключитьОбработчикОжиданияПроверкиЗагруженныхКандидатов(Форма)
	Форма.ОтключитьОбработчикОжиданияПроверкиЗагруженныхКандидатов();
	ОповеститьОбИзмененииУведомленияОНеЗагруженныхКандидатах(Форма);
КонецПроцедуры

Процедура ОповеститьДругиеФормыОПодключении(Форма)
	Оповестить("ПроверкаЗагруженныхКандидатовВключена", Неопределено, Форма);
КонецПроцедуры

Процедура ОповеститьДругиеФормыОбОтключении(Форма)
	Оповестить("ПроверкаЗагруженныхКандидатовОтключена", Неопределено, Форма);
КонецПроцедуры

Процедура УстановитьУведомленияОНеЗагруженныхКандидатах(Форма, Состояние)
	
	Если Состояние = УведомлятьОНеЗагруженныхКандидатах(Форма) Тогда
		Возврат;
	КонецЕсли;
	
	Если Состояние Тогда
		ВключитьУведомленияОНеЗагруженныхКандидатах(Форма);
	Иначе
		ОтключитьУведомленияОНеЗагруженныхКандидатах(Форма);
	КонецЕсли;
	
КонецПроцедуры

Процедура ВключитьУведомленияОНеЗагруженныхКандидатах(Форма)
	Форма.СообщатьОНеЗагруженныхКандидатах = Истина;
КонецПроцедуры

Процедура ОтключитьУведомленияОНеЗагруженныхКандидатах(Форма)
	Форма.СообщатьОНеЗагруженныхКандидатах = Ложь;
КонецПроцедуры

Процедура ОповеститьОбИзмененииУведомленияОНеЗагруженныхКандидатах(Форма)
	Оповестить("СообщатьОНеЗагруженныхКандидатах", УведомлятьОНеЗагруженныхКандидатах(Форма), Форма);
КонецПроцедуры

Функция УведомлятьОНеЗагруженныхКандидатах(Форма)
	Возврат Форма.СообщатьОНеЗагруженныхКандидатах;
КонецФункции

Функция ИнтервалПроверкиЗагруженныхКандидатов()
	Возврат 10;
КонецФункции

Процедура ПоказатьЗагруженногоКандидата(ДополнительныеПараметры) Экспорт
	ОткрытьФорму("Справочник.Кандидаты.ФормаОбъекта", Новый Структура("Ключ", ДополнительныеПараметры.Кандидат));
КонецПроцедуры

Процедура НачатьПоказНеЗагруженныхКандидатов(ДополнительныеПараметры) Экспорт
	ОтключитьУведомленияОНеЗагруженныхКандидатах(ДополнительныеПараметры.Форма);
	ОткрытьФорму("РегистрСведений.ЗагрузкаКандидатовИзИнтернета.Форма.НеЗагруженныеКандидаты", , 
		ЭтотОбъект, Истина, , , 
		Новый ОписаниеОповещения("ЗавершитьПоказНеЗагруженныхКандидатов", ЭтотОбъект, ДополнительныеПараметры));
КонецПроцедуры

Процедура ЗавершитьПоказНеЗагруженныхКандидатов(Результат, ДополнительныеПараметры) Экспорт
	ВключитьУведомленияОНеЗагруженныхКандидатах(ДополнительныеПараметры.Форма);
	ОповеститьОбИзмененииУведомленияОНеЗагруженныхКандидатах(ДополнительныеПараметры.Форма);
КонецПроцедуры

#КонецОбласти