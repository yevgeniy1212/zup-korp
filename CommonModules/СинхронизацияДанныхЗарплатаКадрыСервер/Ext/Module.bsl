// Определяет соответствует ли узел плана обмена РИБ хотя бы одному из разделов данных.
// 
// Параметры:
//  Узел - ПланОбменаСсылка.ОбменВРаспределеннойИнформационнойБазе,ПланОбменаСсылка.АвтономнаяРабота 
//  РазделыДанных - Массив из Строка
// 
// Возвращаемое значение:
//  Булево
Функция УзелСоответствуетРазделамДанных(Узел, РазделыДанных)
	
	Результат = Ложь;
	Для Каждого РазделДанных Из РазделыДанных Цикл
		Результат = СинхронизацияДанныхЗарплатаКадрыСеансПовтИсп.УзелСоответствуетРазделуДанных(Узел, РазделДанных);
		Если Результат Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#Область ОбработчикиПравилРегистрации


Функция ИменаОбработчиковПравилРегистрации()
	
	Обработчики = Новый Структура;
	Обработчики.Вставить("ПриОбработкеПередИзменением", "ПриОбработкеПередИзменением");
	Обработчики.Вставить("ПриОбработкеПослеИзменения", "ПриОбработкеПослеИзменения");
	Обработчики.Вставить("ПослеОбработки", "ПослеОбработки");
	
	Возврат Обработчики;
	
КонецФункции

Процедура ВыполнитьОбработчикПравилаРегистрации(Объект, ИмяОбработчика, Отказ, Параметры)
	
	ТаблицаНастроекОбработчиков = НастройкиОбработчиковПравилРегистрации(Параметры.ПРО.ОбъектМетаданныхИмя);
	
	Если ТаблицаНастроекОбработчиков = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Настройки Из ТаблицаНастроекОбработчиков Цикл
		Параметры.ДополнительныеПараметры = Настройки.ДополнительныеПараметры;
		Если Настройки.ПриОбработкеПередИзменением
			И ИмяОбработчика = ИменаОбработчиковПравилРегистрации().ПриОбработкеПередИзменением Тогда
			ВыполнитьОбработчикПриОбработкеПередИзменением(Объект, Настройки, Отказ, Параметры);
		ИначеЕсли Настройки.ПриОбработкеПослеИзменения 
			И ИмяОбработчика = ИменаОбработчиковПравилРегистрации().ПриОбработкеПослеИзменения Тогда
			ВыполнитьОбработчикПриОбработкеПослеИзменения(Объект, Настройки, Отказ, Параметры);
		ИначеЕсли Настройки.ПослеОбработки 
			И ИмяОбработчика = ИменаОбработчиковПравилРегистрации().ПослеОбработки Тогда
			ВыполнитьОбработчикПослеОбработки(Объект, Настройки, Отказ, Параметры);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ВыполнитьОбработчикПриОбработкеПередИзменением(Объект, Настройки, Отказ, Параметры)
	
	Если Настройки.Модуль <> Неопределено Тогда
		Настройки.Модуль.ПриОбработкеПравилаРегистрацииПередИзменениемОбъекта(Объект, Отказ, Параметры);
	Иначе
		МодульОбработчиков = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(Параметры.ПРО.ОбъектМетаданныхИмя);
		МодульОбработчиков.ПриОбработкеПравилаРегистрацииПередИзменениемОбъекта(Объект, Отказ, Параметры);
	КонецЕсли;
	
КонецПроцедуры

Процедура ВыполнитьОбработчикПриОбработкеПослеИзменения(Объект, Настройки, Отказ, Параметры)
	
	Если Настройки.Модуль <> Неопределено Тогда
		Настройки.Модуль.ПриОбработкеПравилаРегистрацииПослеИзмененияОбъекта(Объект, Отказ, Параметры);
	Иначе
		МодульОбработчиков = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(Параметры.ПРО.ОбъектМетаданныхИмя);
		МодульОбработчиков.ПриОбработкеПравилаРегистрацииПослеИзмененияОбъекта(Объект, Отказ, Параметры);
	КонецЕсли;
	
КонецПроцедуры

Процедура ВыполнитьОбработчикПослеОбработки(Объект, Настройки, Отказ, Параметры)
	
	ИмяОбъекта = Параметры.ПРО.ОбъектМетаданныхИмя;
	Если Настройки.Модуль <> Неопределено Тогда
		Настройки.Модуль.ПослеОбработкиПравилаРегистрации(Объект, Отказ, Параметры);
	Иначе
		МодульОбработчиков = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(ИмяОбъекта);
		МодульОбработчиков.ПослеОбработкиПравилаРегистрации(Объект, Отказ, Параметры);
	КонецЕсли;
	
КонецПроцедуры

Процедура ИзменитьТекстЗапросаПоЗначениямМассива(МассивЗначений, ТекстЗапроса, ПараметрыЗапроса, СтрокаЗамены,
	ЗначениеЗамены, ИмяПараметра)
	
	НомерПоказателя = 0;
	ТекстЗамены = "";
	Для Каждого ЗначениеМассива Из МассивЗначений Цикл
		
		НомерПоказателя = НомерПоказателя + 1;
		Если Не ПустаяСтрока(ТекстЗамены) Тогда
			ТекстЗамены = ТекстЗамены + " ИЛИ ";
		КонецЕсли;
		ТекстЗамены = ТекстЗамены + ЗначениеЗамены + " = &СвойствоОбъекта_" + ИмяПараметра + Строка(НомерПоказателя);
		
		ПараметрыЗапроса.Вставить(ИмяПараметра + Строка(НомерПоказателя), ЗначениеМассива);
		
	КонецЦикла;
	
	Если ПустаяСтрока(ТекстЗамены) Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, СтрокаЗамены, "ИСТИНА");
	Иначе
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, СтрокаЗамены, "(" + ТекстЗамены + ")");
	КонецЕсли;
	
КонецПроцедуры

Процедура ДобавитьПараметрОтправитель(Объект, ПараметрыЗапроса, ЭтоРегистр = Ложь)
	
	Отправитель = Неопределено;
	
	Если Не ЭтоРегистр Тогда
		Если Объект.ОбменДанными.Загрузка Тогда
			// Если это загрузка объекта, то исключим Отправителя из Получателей, чтобы не было зацикливания
			Отправитель = Объект.ОбменДанными.Отправитель;
		КонецЕсли;
		Если Объект.ДополнительныеСвойства.Свойство("Загрузка") И Объект.ДополнительныеСвойства.Загрузка Тогда
			// Если это загрузка объекта, то исключим Отправителя из Получателей, чтобы не было зацикливания
			Отправитель = Объект.ДополнительныеСвойства.Отправитель;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ПараметрыЗапроса.Свойство("Отправитель") Тогда
		ПараметрыЗапроса.Вставить("Отправитель", Отправитель);
	КонецЕсли;
	
КонецПроцедуры

Функция ПодчиненныеОрганизации(ГоловнаяОрганизация)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ГоловнаяОрганизация", ГоловнаяОрганизация);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Организации.Ссылка КАК Организация,
	|	Организации.ЕстьОбособленныеПодразделения КАК ЕстьОбособленныеПодразделения
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	Организации.ГоловнаяОрганизация = &ГоловнаяОрганизация";
	
	МассивОрганизаций = Новый Массив;
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.ЕстьОбособленныеПодразделения И Выборка.Организация <> ГоловнаяОрганизация Тогда
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(МассивОрганизаций, ПодчиненныеОрганизации(Выборка.Организация));
		Иначе
			МассивОрганизаций.Добавить(Выборка.Организация);
		КонецЕсли;
	КонецЦикла;
	
	Возврат МассивОрганизаций;
	
КонецФункции

#КонецОбласти

