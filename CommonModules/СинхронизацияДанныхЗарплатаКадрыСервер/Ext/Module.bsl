	ЭлементБлокировки.УстановитьЗначение("Подразделение", Справочники.СтруктураПредприятия.ПустаяСсылка());
	
	НачатьТранзакцию();
	Попытка
		Блокировка.Заблокировать();
		РезультатЗапроса = Запрос.Выполнить();
		Если Не РезультатЗапроса.Пустой() Тогда
