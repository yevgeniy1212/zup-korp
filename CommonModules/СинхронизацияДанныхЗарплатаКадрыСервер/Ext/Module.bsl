Функция ОписаниеКолонки(Имя, Заполнение, Тип)
	ОписаниеКолонки = Новый Структура;
	ОписаниеКолонки.Вставить("Имя", Имя);
	ОписаниеКолонки.Вставить("Заполнение", Заполнение);
	ОписаниеКолонки.Вставить("Тип", Тип);
