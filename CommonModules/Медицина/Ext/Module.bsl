#Область ПрограммныйИнтерфейс

// См. УправлениеШтатнымРасписанием.ОписаниеИсточниковСведенийОШтатномРасписании.
Процедура ДополнитьОписаниеИсточниковСведенийОШтатномРасписании(ОписаниеИсточников) Экспорт
	
	ДобавитьОписаниеСведенийДолжностиМедработника(ОписаниеИсточников);
	
КонецПроцедуры

// Добавляет в переданный отбор условие, ограничивающее выборку только медицинскими должности.
//
// Параметры:
//  Отбор - массив отборов.
//  ИмяКомандыЗаполнения	 - строка с именем команды заполнения (см. функцию ИмяКомандыЗаполненияПоВидуДолжности),
//  которое определяет необходимость установки отбора.
//
Процедура ДополнитьФильтрПоВидуДолжностейЗаполненияПозиций(ИмяКомандыЗаполнения, Отбор) Экспорт
	Если ИмяКомандыЗаполнения=ИмяКомандыЗаполненияПоВидуДолжности() Тогда 
		ЗарплатаКадрыОбщиеНаборыДанных.ДобавитьВКоллекциюОтбор(
				Отбор, "ЯвляетсяМедицинскойДолжностью", "=", Истина);
	КонецЕсли;
КонецПроцедуры

// Добавляет в переданный отбор условия, исключающие из выборки медицинские должности.
//
// Параметры:
//  Отбор - массив отборов.
//
Процедура ДополнитьФильтрПоПоОстальнымДолжностямЗаполненияПозиций(Отбор) Экспорт
	ЗарплатаКадрыОбщиеНаборыДанных.ДобавитьВКоллекциюОтбор(
			Отбор, "ЯвляетсяМедицинскойДолжностью", "=", Ложь);
КонецПроцедуры

// Добавляет в массив команд заполнения данные команды для заполнения должностями медработников.
//
// Параметры:
//  КомандыЗаполнения - массив команд заполнения.
// 
// Возвращаемое значение:
//  Булево - Истина, если команда была добавлена.
//
Функция ДобавитьКомандуЗаполненияПоВидуДолжности(КомандыЗаполнения) Экспорт 
	
	Если РаботаВМедицинскомУчреждении() Тогда 
		КомандаЗаполнения = Новый Структура("Имя,Заголовок,Представление", 
											ИмяКомандыЗаполненияПоВидуДолжности(), 
											НСтр("ru = 'Заполнить позиции медработников'"),
											НСтр("ru = 'Заполнено позициями медработников'"));
		КомандыЗаполнения.Добавить(КомандаЗаполнения);
		Возврат Истина;
	КонецЕсли;

	Возврат Ложь;
	
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

#Область ЗащитаПерсональныхДанных

// Процедура обеспечивает сбор сведений о хранении данных,
// относящихся к персональным.
//
// Параметры:
//		ТаблицаСведений - таблица значений с полями:
//			Объект 			- строка, содержащая полное имя объекта метаданных,
//			ПоляРегистрации - строка, в которой перечислены имена полей регистрации,
//								отдельные поля регистрации отделяются запятой,
//								альтернативные - символом "|",
//			ПоляДоступа		- строка, в которой перечислены через запятую имена полей доступа.
//			ОбластьДанных	- строка с идентификатором области данных, необязательно для заполнения.
//
Процедура ЗаполнитьСведенияОПерсональныхДанных(ТаблицаСведений) Экспорт
	 ЗаполнитьСведенияОПерсональныхДанныхДокументаСведенияДляФРМР(ТаблицаСведений);
	 ЗаполнитьСведенияОПерсональныхДанныхДокументаСведенияОРаботникахДляМедРегистра(ТаблицаСведений);
	 ЗаполнитьСведенияОПерсональныхДанныхРегистраСведенийСертификатыПоСпециальностиФизическихЛиц(ТаблицаСведений);
КонецПроцедуры

Процедура ЗаполнитьСведенияОПерсональныхДанныхДокументаСведенияДляФРМР(ТаблицаСведений)
	
	НовыеСведения = ТаблицаСведений.Добавить();
	НовыеСведения.Объект			= "Документ.СведенияДляФРМР";
	НовыеСведения.ПоляРегистрации	= "Работники.ФизическоеЛицо,ДокументыУдостоверяющиеЛичность.ФизическоеЛицо,ОбщееОбразование.ФизическоеЛицо,ПрофессиональноеОбразование.ФизическоеЛицо,Сертификаты.ФизическоеЛицо";
	НовыеСведения.ПоляДоступа		= "";
	НовыеСведения.ОбластьДанных		= "ЛичныеДанные";
	
	ПоляДоступа = "";
	ПоляИсключаемыеИзПерсональныхДанных = "ФизическоеЛицо,";
	ТабличныеЧасти = Метаданные.Документы.СведенияДляФРМР.ТабличныеЧасти;
	Для Каждого ТабличнаяЧасть Из ТабличныеЧасти Цикл
		
		ИмяТабличнойЧасти = ТабличнаяЧасть.Имя+".";
		Для Каждого Реквизит Из ТабличнаяЧасть.Реквизиты Цикл
			
			ИмяРеквизита = Реквизит.Имя;
			Если СтрНайти(ПоляИсключаемыеИзПерсональныхДанных,ИмяРеквизита) Тогда
				Продолжить;
			КонецЕсли;
			ПоляДоступа = ПоляДоступа + "," + ИмяТабличнойЧасти+ИмяРеквизита;
			
		КонецЦикла;
	КонецЦикла;
	
	ПоляДоступа = Сред(ПоляДоступа,2);
	НовыеСведения.ПоляДоступа = ПоляДоступа;
	
КонецПроцедуры

Процедура ЗаполнитьСведенияОПерсональныхДанныхДокументаСведенияОРаботникахДляМедРегистра(ТаблицаСведений)
	
	НовыеСведения = ТаблицаСведений.Добавить();
	НовыеСведения.Объект			= "Документ.СведенияОРаботникахДляМедРегистра";
	НовыеСведения.ПоляРегистрации	= "Сотрудники.Сотрудник,Сотрудники.ФизическоеЛицо,Образование.ФизическоеЛицо,Сертификаты.ФизическоеЛицо,Переподготовка.ФизическоеЛицо,ПовышениеКвалификации.ФизическоеЛицо,"
		+ "ПослевузовскоеОбразование.ФизическоеЛицо,КвалификационныеКатегории.ФизическоеЛицо,Награды.ФизическоеЛицо,ЛичноеДело.Сотрудник,Неявки.Сотрудник,Невыходы.Сотрудник,ФактическиОтработанноеВремя.Сотрудник";
	НовыеСведения.ПоляДоступа		= "";
	НовыеСведения.ОбластьДанных		= "ЛичныеДанные";
	
	ПоляДоступа = "";
	ПоляИсключаемыеИзПерсональныхДанных = "Сотрудник,ФизическоеЛицо,";
	ТабличныеЧасти = Метаданные.Документы.СведенияОРаботникахДляМедРегистра.ТабличныеЧасти;
	Для Каждого ТабличнаяЧасть Из ТабличныеЧасти Цикл
		
		ИмяТабличнойЧасти = ТабличнаяЧасть.Имя+".";
		Для Каждого Реквизит Из ТабличнаяЧасть.Реквизиты Цикл
			
			ИмяРеквизита = Реквизит.Имя;
			Если СтрНайти(ПоляИсключаемыеИзПерсональныхДанных,ИмяРеквизита) Тогда
				Продолжить;
			КонецЕсли;
			ПоляДоступа = ПоляДоступа + "," + ИмяТабличнойЧасти+ИмяРеквизита;
			
		КонецЦикла;
	КонецЦикла;
	
	ПоляДоступа = Сред(ПоляДоступа,2);
	НовыеСведения.ПоляДоступа = ПоляДоступа;
	
КонецПроцедуры

Процедура ЗаполнитьСведенияОПерсональныхДанныхРегистраСведенийСертификатыПоСпециальностиФизическихЛиц(ТаблицаСведений)
	НовыеСведения = ТаблицаСведений.Добавить();
	НовыеСведения.Объект			= "РегистрСведений.СертификатыПоСпециальностиФизическихЛиц";
	НовыеСведения.ПоляРегистрации	= "ФизическоеЛицо";
	НовыеСведения.ПоляДоступа		= "Специальность,ДатаПолучения,ДействуетПо,Серия,Номер,КемВыдан";
	НовыеСведения.ОбластьДанных		= "ЛичныеДанные";
КонецПроцедуры

#КонецОбласти

#Область ПервоначальноеЗаполнениеИОбновлениеИБ

// Добавляет в список Обработчики процедуры-обработчики обновления,
// необходимые данной подсистеме.
//
// Параметры:
//   Обработчики - ТаблицаЗначений - см. описание функции НоваяТаблицаОбработчиковОбновления
//                                   общего модуля ОбновлениеИнформационнойБазы.
//
Процедура ЗарегистрироватьОбработчикиОбновления(Обработчики) Экспорт
	
КонецПроцедуры

#КонецОбласти

#Область Свойства

// См. УправлениеСвойствамиПереопределяемый.ПриПолученииПредопределенныхНаборовСвойств.
Процедура ПриПолученииПредопределенныхНаборовСвойств(Наборы) Экспорт
	
	Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.Медицина.ДоступКНаркотическимСредствам") Тогда
		МодульДоступКНаркотическимСредствам = ОбщегоНазначения.ОбщийМодуль("ДоступКНаркотическимСредствам");
		МодульДоступКНаркотическимСредствам.ПриПолученииПредопределенныхНаборовСвойств(Наборы);
	КонецЕсли;
	
	УправлениеСвойствамиБЗК.ЗарегистрироватьНаборСвойств(Наборы, "d42dbf92-9802-11e9-80cd-4cedfb43b11a", Метаданные.Документы.СведенияОРаботникахДляМедРегистра);
	УправлениеСвойствамиБЗК.ЗарегистрироватьНаборСвойств(Наборы, "d42dbfbd-9802-11e9-80cd-4cedfb43b11a", Метаданные.Документы.СведенияОШтатномРасписанииДляМедРегистра);
	УправлениеСвойствамиБЗК.ЗарегистрироватьНаборСвойств(Наборы, "4a6b9112-c35b-4f68-9744-4d4ce8d0fda9", Метаданные.Документы.СведенияДляФРМО);
	УправлениеСвойствамиБЗК.ЗарегистрироватьНаборСвойств(Наборы, "cff59589-07ed-4e01-8628-0a7d8b05a027", Метаданные.Документы.СведенияДляФРМР);
	УправлениеСвойствамиБЗК.ЗарегистрироватьНаборСвойств(Наборы, "c091b4cc-9802-11e9-80cd-4cedfb43b11a", Метаданные.Справочники.КлассификаторыМедРегистра);
	УправлениеСвойствамиБЗК.ЗарегистрироватьНаборСвойств(Наборы, "3dfefadd-24c2-4de2-b83c-2a8ebc7fbbaf", Метаданные.Справочники.КлассификаторыФедеральныхМедрегистров);
	
КонецПроцедуры

#КонецОбласти

#Область УправлениеДоступом

// См. УправлениеДоступомПереопределяемый.ПриЗаполненииСписковСОграничениемДоступа.
Процедура ПриЗаполненииСписковСОграничениемДоступа(Списки) Экспорт
	
	Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.Медицина.ДоступКНаркотическимСредствам") Тогда
		МодульДоступКНаркотическимСредствам = ОбщегоНазначения.ОбщийМодуль("ДоступКНаркотическимСредствам");
		МодульДоступКНаркотическимСредствам.ПриЗаполненииСписковСОграничениемДоступа(Списки);
	КонецЕсли;
	
	// ЗарплатаКадрыПриложения.Медицина.ФедеральныйРегистрМедицинскихРаботников
	Списки.Вставить(Метаданные.Документы.СведенияОРаботникахДляМедРегистра, Истина);
	Списки.Вставить(Метаданные.Документы.СведенияОШтатномРасписанииДляМедРегистра, Истина);
	Списки.Вставить(Метаданные.Документы.СведенияДляФРМО, Истина);
	Списки.Вставить(Метаданные.Документы.СведенияДляФРМР, Истина);
	Списки.Вставить(Метаданные.ЖурналыДокументов.СведенияДляФедеральногоРегистраМедицинскихРаботников, Истина);
	Списки.Вставить(Метаданные.РегистрыСведений.СведенияОбОрганизацииДляМедРегистра, Истина);
	Списки.Вставить(Метаданные.Справочники.СведенияОРаботникахДляМедРегистраПрисоединенныеФайлы, Истина);
	Списки.Вставить(Метаданные.Справочники.СведенияОШтатномРасписанииДляМедРегистраПрисоединенныеФайлы, Истина);
	Списки.Вставить(Метаданные.Справочники.СведенияДляФРМОПрисоединенныеФайлы, Истина);
	Списки.Вставить(Метаданные.Справочники.СведенияДляФРМРПрисоединенныеФайлы, Истина);
	// Конец ЗарплатаКадрыПриложения.Медицина.ФедеральныйРегистрМедицинскихРаботников
	
КонецПроцедуры

#КонецОбласти

Процедура ЗаполнитьИсточникиДанныхДляПроверкиЗапретаИзменения(ИсточникиДанных) Экспорт
	
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "Документ.СведенияОРаботникахДляМедРегистра",			"Дата", "КадровыйУчет", "Организация");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "Документ.СведенияОШтатномРасписанииДляМедРегистра",	"Дата", "КадровыйУчет", "Организация");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "Документ.СведенияДляФРМО",	"Дата", "КадровыйУчет", "Организация");
	ДатыЗапретаИзменения.ДобавитьСтроку(ИсточникиДанных, "Документ.СведенияДляФРМР",	"Дата", "КадровыйУчет", "Организация");
	
КонецПроцедуры

#Область СправочникДолжности 

Процедура ДополнитьФормуЭлементаСправочникаДолжности(Форма, ИмяГруппыДляВставки = "ГруппаМедицинскаяДолжность") Экспорт
	
	Если Не РаботаВМедицинскомУчреждении() Тогда
		Возврат;
	КонецЕсли;
	
	ДобавляемыеРеквизиты = Новый Массив;
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("СвойстваДолжностейМедицинскихРаботников", Новый ОписаниеТипов("РегистрСведенийМенеджерЗаписи.СвойстваДолжностейМедицинскихРаботников"),,,Истина));
	
	МассивИменРеквизитовФормы = Новый Массив;
	ЗарплатаКадры.ЗаполнитьМассивИменРеквизитовФормы(Форма, МассивИменРеквизитовФормы);
	ЗарплатаКадры.ИзменитьРеквизитыФормы(Форма, ДобавляемыеРеквизиты, МассивИменРеквизитовФормы);
	
	ГруппаФормы = Форма.Элементы.Найти(ИмяГруппыДляВставки); 
	ОписанияРесурсов = Метаданные.РегистрыСведений.СвойстваДолжностейМедицинскихРаботников.Ресурсы;
	ПрефиксПутиКДанным = "СвойстваДолжностейМедицинскихРаботников";
	
	ДобавитьПолеВвода(Форма, ГруппаФормы, ОписанияРесурсов.Найти("ЯвляетсяМедицинскойДолжностью"), ПрефиксПутиКДанным);
	
	ДобавитьСпециальныеУсловияЗанятости(Форма, ИмяГруппыДляВставки);
	
КонецПроцедуры

Процедура ПрочитатьДополнительныеДанныеДолжности(Форма) Экспорт
	
	Если Не РаботаВМедицинскомУчреждении() Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПравоДоступа("Чтение", Метаданные.РегистрыСведений.СвойстваДолжностейМедицинскихРаботников) Тогда
		Возврат;
	КонецЕсли;

	МенеджерЗаписи = РегистрыСведений.СвойстваДолжностейМедицинскихРаботников.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Должность = Форма.Объект.Ссылка;
	МенеджерЗаписи.Прочитать();
	
	ЗначениеВДанныеФормы(МенеджерЗаписи, Форма.СвойстваДолжностейМедицинскихРаботников);
	
	ПрочитатьСпециальныеУсловияЗанятости(Форма, Форма.Объект.Ссылка);
	
КонецПроцедуры

Процедура ЗаписатьДополнительныеДанныеДолжности(Форма, Ссылка) Экспорт
	
	Если Не РаботаВМедицинскомУчреждении() Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПравоДоступа("Изменение", Метаданные.РегистрыСведений.СвойстваДолжностейМедицинскихРаботников) Тогда
		Возврат;
	КонецЕсли;
	
	НаборЗаписей = РегистрыСведений.СвойстваДолжностейМедицинскихРаботников.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Должность.Установить(Ссылка);
	
	Запись = НаборЗаписей.Добавить();
	ЗаполнитьЗначенияСвойств(Запись, Форма.СвойстваДолжностейМедицинскихРаботников);
	Запись.Должность = Ссылка;
	
	Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыКорпоративнаяПодсистемы.АвтоматическийРасчетСтажейФизическихЛиц") Тогда
		
		МодульАвтоматическийРасчетСтажейФизическихЛиц = ОбщегоНазначения.ОбщийМодуль("АвтоматическийРасчетСтажейФизическихЛиц");
		МодульАвтоматическийРасчетСтажейФизическихЛиц.УстановитьДополнительноеСвойствоПропуститьОбновлениеЗависимыхСтажей(НаборЗаписей.ДополнительныеСвойства);
		
	КонецЕсли;
	
	НаборЗаписей.Записать();
	
	ЗаписатьСпециальныеУсловияЗанятости(Форма, Ссылка);
	
КонецПроцедуры

#КонецОбласти

#Область СправочникШтатноеРасписание

Процедура ДополнитьФормуПозицииШтатногоРасписания(Форма, ИмяГруппыДляВставки = "ГруппаМедицина") Экспорт
	
	Если Не РаботаВМедицинскомУчреждении() Тогда
		Возврат;
	КонецЕсли;
	
    ДобавитьСпециальныеУсловияЗанятости(Форма, ИмяГруппыДляВставки);
	
КонецПроцедуры

Процедура ПрочитатьДополнительныеДанныеПозицииШтатногоРасписания(Форма) Экспорт
	
	ПрочитатьСпециальныеУсловияЗанятости(Форма, Форма.Объект.Ссылка);
	
КонецПроцедуры

Процедура ПрочитатьДополнительныеДанныеДолжностиДляПозицииШтатногоРасписания(Форма) Экспорт
	
	Если Не РаботаВМедицинскомУчреждении() Тогда
		Возврат;
	КонецЕсли;
	
	ПрочитатьСпециальныеУсловияЗанятости(Форма, Форма.Объект.Должность);
	
	Для Каждого Строка Из Форма.СпециальныеУсловияЗанятости Цикл
		Строка.Должность = Форма.СсылкаНаОбъект;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьДополнительныеДанныеПозицииШтатногоРасписания(Форма, Позиция) Экспорт
	
	ЗаписатьСпециальныеУсловияЗанятости(Форма, Позиция);
	
КонецПроцедуры

#КонецОбласти

#Область СправочникПодразделенияОрганизаций 

Функция ОписаниеКлассификатораПодразделений() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Код", "1.2.643.5.1.13.13.99.2.114");
	Результат.Вставить("Наименование", "ФРМО. Справочник структурных подразделений");
	Результат.Вставить("ТипОбъектаМетаданных", "СправочникСсылка.ПодразделенияОрганизаций");
	Результат.Вставить("ПолеИдентификатор", "depart_oid");
	Возврат Результат;
	
КонецФункции

Функция ПолучитьКлассификаторПодразделений(Создавать = Ложь) Экспорт
	
	ПараметрыКлассификатора = ОписаниеКлассификатораПодразделений();
	КлассификаторПодразделений = Справочники.КлассификаторыФедеральныхМедрегистров.НайтиПоКоду(ПараметрыКлассификатора.Код);
	
	Если Создавать И Не ЗначениеЗаполнено(КлассификаторПодразделений) Тогда
		
		УстановитьПривилегированныйРежим(Истина);
		
		ОбъектСправочника = Справочники.КлассификаторыФедеральныхМедрегистров.СоздатьЭлемент();
		ОбъектСправочника.Код = ПараметрыКлассификатора.Код;
		ОбъектСправочника.ПолеИдентификатор = ПараметрыКлассификатора.ПолеИдентификатор;
		ОбъектСправочника.Наименование = ПараметрыКлассификатора.Наименование;
		ОбъектСправочника.Записать();
		КлассификаторПодразделений = ОбъектСправочника.Ссылка;
		
	КонецЕсли;
	
	Возврат КлассификаторПодразделений;
	
КонецФункции

Процедура ДополнитьФормуПодразделения(Форма, ИмяГруппыДляВставки = "ГруппаМедицина") Экспорт
	
	Если Не РаботаВМедицинскомУчреждении() Тогда
		Возврат;
	КонецЕсли;
	
	ДобавляемыеРеквизиты = Новый Массив;
	ДобавляемыеРеквизиты.Добавить(
		Новый РеквизитФормы("ХарактеристикаПодразделениеФРМО",
		Новый ОписаниеТипов("РегистрСведенийМенеджерЗаписи.ХарактеристикиОбъектовДляФедеральныхМедрегистров"),,,Истина));
	
	ИменаРеквизитовФормы = Новый Массив;
	ЗарплатаКадры.ЗаполнитьМассивИменРеквизитовФормы(Форма, ИменаРеквизитовФормы);
	ЗарплатаКадры.ИзменитьРеквизитыФормы(Форма, ДобавляемыеРеквизиты, ИменаРеквизитовФормы);
	
	ГруппаФормы = Форма.Элементы.Найти(ИмяГруппыДляВставки); 
	
	ОписанияРесурсов = Метаданные.РегистрыСведений.ХарактеристикиОбъектовДляФедеральныхМедрегистров.Ресурсы;
	ОписаниеРесурса = ОписанияРесурсов.Найти("Характеристика");
	
	Описание = Новый Структура();
	Описание.Вставить("Имя", ОписаниеРесурса.Имя);
	Описание.Вставить("Тип", ОписаниеРесурса.Тип);
	Описание.Вставить("Синоним", НСтр("ru='Подразделение ФРМО'"));
	Описание.Вставить("Подсказка", Неопределено);
	
	ПолеВвода = ДобавитьПолеВвода(Форма, ГруппаФормы, Описание, "ХарактеристикаПодразделениеФРМО");
	ПолеВвода.Ширина = 26;
	
	Описание = ОписаниеКлассификатораПодразделений();
	
	ПараметрыВыбора = Новый Массив;
	ПараметрыВыбора.Добавить(Новый ПараметрВыбора("Отбор.КодКлассификатора", Описание.Код));
	ПолеВвода.ПараметрыВыбора = Новый ФиксированныйМассив(ПараметрыВыбора);
	
	СвязиПараметровВыбора = Новый Массив;
	СвязиПараметровВыбора.Добавить(Новый СвязьПараметраВыбора("Отбор.Организация", "Объект.Владелец"));
	ПолеВвода.СвязиПараметровВыбора = Новый ФиксированныйМассив(СвязиПараметровВыбора);
	
	Имя = "OIDПодразделения";
	ПолеНадписи = Форма.Элементы.Найти(Имя);
	Если ПолеНадписи = Неопределено Тогда
		ПолеНадписи = Форма.Элементы.Вставить(Имя, Тип("ПолеФормы"), ГруппаФормы);
	КонецЕсли;
	ПолеНадписи.ПутьКДанным = "ХарактеристикаПодразделениеФРМО.Характеристика.Код";
	ПолеНадписи.Вид = ВидПоляФормы.ПолеНадписи;
	ПолеНадписи.РастягиватьПоГоризонтали = Ложь;
	ПолеНадписи.Заголовок = "OID подразделения";
	
КонецПроцедуры

Процедура ПрочитатьДополнительныеДанныеПодразделения(Форма) Экспорт
	
	Если Не РаботаВМедицинскомУчреждении() Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПравоДоступа("Чтение", Метаданные.РегистрыСведений.ХарактеристикиОбъектовДляФедеральныхМедрегистров) Тогда
		Возврат;
	КонецЕсли;
	
	КлассификаторПодразделений = ПолучитьКлассификаторПодразделений();
	
	Если Не ЗначениеЗаполнено(КлассификаторПодразделений) Тогда
		Возврат;
	КонецЕсли;
	
	МенеджерЗаписи = РегистрыСведений.ХарактеристикиОбъектовДляФедеральныхМедрегистров.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Объект = Форма.Объект.Ссылка;
	МенеджерЗаписи.Классификатор = КлассификаторПодразделений;
	МенеджерЗаписи.Прочитать();
	ЗначениеВДанныеФормы(МенеджерЗаписи, Форма.ХарактеристикаПодразделениеФРМО);
	
КонецПроцедуры

Процедура ЗаписатьДополнительныеДанныеПодразделения(Форма, Ссылка) Экспорт
	
	Если Не РаботаВМедицинскомУчреждении() Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПравоДоступа("Изменение", Метаданные.РегистрыСведений.ХарактеристикиОбъектовДляФедеральныхМедрегистров) Тогда
		Возврат;
	КонецЕсли;
	
	КлассификаторПодразделений = ПолучитьКлассификаторПодразделений();	
	
	Если Не ЗначениеЗаполнено(КлассификаторПодразделений) Тогда
		Возврат;
	КонецЕсли;
	
	НаборЗаписей = РегистрыСведений.ХарактеристикиОбъектовДляФедеральныхМедрегистров.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Объект.Установить(Ссылка);
	НаборЗаписей.Отбор.Классификатор.Установить(КлассификаторПодразделений);
	
	Если ЗначениеЗаполнено(Форма.ХарактеристикаПодразделениеФРМО.Характеристика) Тогда
		Запись = НаборЗаписей.Добавить();
		ЗаполнитьЗначенияСвойств(Запись, Форма.ХарактеристикаПодразделениеФРМО);
		Запись.Объект = Ссылка;
		Запись.Классификатор = КлассификаторПодразделений;
	КонецЕсли;
	
	НаборЗаписей.Записать();
	
КонецПроцедуры

#КонецОбласти

#Область ЗаполнениеРеглотчетности

Процедура ПереопределитьЗапросПоОтраслевымУсловиям_ЕФС1(Запрос) Экспорт
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьШтатноеРасписание") Тогда
		Текст =
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	КадровыеДанные.Сотрудник КАК Сотрудник,
			|	ЕСТЬNULL(СпециальныеУсловияЗанятостиПозиций.Код, ЕСТЬNULL(СпециальныеУсловияЗанятостиДолжностей.Код, ""0"")) КАК Код,
			|	ЕСТЬNULL(СпециальныеУсловияЗанятостиПозиций.Значение, ЕСТЬNULL(СпециальныеУсловияЗанятостиДолжностей.Значение, ""0"")) КАК Значение
			|ИЗ
			|	ВТКадровыеДанныеСотрудников КАК КадровыеДанные
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СпециальныеУсловияЗанятостиДолжностей КАК СпециальныеУсловияЗанятостиДолжностей
			|		ПО КадровыеДанные.Должность = СпециальныеУсловияЗанятостиДолжностей.Должность
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СпециальныеУсловияЗанятостиДолжностей КАК СпециальныеУсловияЗанятостиПозиций
			|		ПО (КадровыеДанные.ДолжностьПоШтатномуРасписанию = СпециальныеУсловияЗанятостиПозиций.Должность)
			|ГДЕ
			|	КадровыеДанные.Сотрудник = КадровыеДанные.ГоловнойСотрудник";
	Иначе
		Текст =
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	КадровыеДанные.Сотрудник КАК Сотрудник,
			|	ЕСТЬNULL(СпециальныеУсловияЗанятостиДолжностей.Код, ""0"") КАК Код,
			|	ЕСТЬNULL(СпециальныеУсловияЗанятостиДолжностей.Значение, ""0"") КАК Значение
			|ИЗ
			|	ВТКадровыеДанныеСотрудников КАК КадровыеДанные
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СпециальныеУсловияЗанятостиДолжностей КАК СпециальныеУсловияЗанятостиДолжностей
			|		ПО КадровыеДанные.Должность = СпециальныеУсловияЗанятостиДолжностей.Должность
			|ГДЕ
			|	КадровыеДанные.Сотрудник = КадровыеДанные.ГоловнойСотрудник";
	КонецЕсли;
	
	Запрос.Текст = Текст;

КонецПроцедуры

Процедура ПереопределитьЗапросПоOID_ЕФС1(Запрос) Экспорт
	
	КлассификаторПодразделений = ПолучитьКлассификаторПодразделений();
	Если Не ЗначениеЗаполнено(КлассификаторПодразделений) Тогда
		Возврат;
	КонецЕсли;
	
	Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	КадровыеДанные.Подразделение КАК Подразделение,
		|	КадровыеДанные.Организация КАК Организация,
		|	ЕСТЬNULL(СведенияПоМедрегистру.Характеристика.Код, """") КАК OIDПодразделения,
		|	ЕСТЬNULL(ОписаниеЭлемента.Значение, """") КАК OIDОрганизации
		|ИЗ
		|	ВТКадровыеДанныеСотрудников КАК КадровыеДанные
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ХарактеристикиОбъектовДляФедеральныхМедрегистров КАК СведенияПоМедрегистру
		|		ПО (СведенияПоМедрегистру.Объект = КадровыеДанные.Подразделение)
		|			И (СведенияПоМедрегистру.Классификатор = (&КлассификаторПодразделений))
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЭлементыКлассификаторовФедеральныхМедрегистров.ОписаниеЭлемента КАК ОписаниеЭлемента
		|		ПО (ОписаниеЭлемента.Ссылка = СведенияПоМедрегистру.Характеристика)
		|			И (ОписаниеЭлемента.Поле = ""mo_oid"")";
	
	Запрос.УстановитьПараметр("КлассификаторПодразделений", КлассификаторПодразделений);
	
КонецПроцедуры

#КонецОбласти

#Область НачальнаяНастройкаПрограммы

Процедура ЗаписатьНастройкиНачальнаяНастройкаПрограммы(Параметры) Экспорт

	Если Параметры.ПараметрыПрограммы.ИспользоватьМедицинскоеУчреждение <> Константы.РаботаВМедицинскомУчреждении.Получить() Тогда
		Константы.РаботаВМедицинскомУчреждении.Установить(Параметры.ПараметрыПрограммы.ИспользоватьМедицинскоеУчреждение);
		Если Не Параметры.ПараметрыПрограммы.ИспользоватьМедицинскоеУчреждение Тогда 
			СброситьЗависимыеНастройкиЗарплатыМедицинскогоУчреждения();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура СброситьЗависимыеНастройкиЗарплатыМедицинскогоУчреждения()

	Константы.ИспользоватьВыгрузкуВФедеральныйРегистрМедицинскихРаботников.Установить(Ложь);
	Константы.ИспользоватьВыгрузкуВФедеральныеМедрегистры.Установить(Ложь);
		
	Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.Медицина.ТарификационнаяОтчетностьУчрежденийФМБА") Тогда
		МодульТарификационнаяОтчетностьУчрежденийФМБА = ОбщегоНазначения.ОбщийМодуль("ТарификационнаяОтчетностьУчрежденийФМБА");
		МодульТарификационнаяОтчетностьУчрежденийФМБА.СброситьЗависимыеНастройкиЗарплатыМедицинскогоУчреждения();
	КонецЕсли;
	
	Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.Медицина.ДоступКНаркотическимСредствам") Тогда
		МодульДоступКНаркотическимСредствам = ОбщегоНазначения.ОбщийМодуль("ДоступКНаркотическимСредствам");
		МодульДоступКНаркотическимСредствам.СброситьЗависимыеНастройкиЗарплатыМедицинскогоУчреждения();
	КонецЕсли;
	
	Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.АккредитацияСпециалистов") Тогда
		Константы.ИспользоватьАккредитациюСпециалистов.Установить(Ложь);
	КонецЕсли;
		
КонецПроцедуры

#КонецОбласти

#Область НастройкаРасчетаЗарплаты

Процедура ДополнитьФормуНастройкаРасчетаЗарплаты(Форма) Экспорт
	
	ДобавляемыеРеквизиты = Новый Массив;
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("РаботаВМедицинскомУчреждении", Новый ОписаниеТипов("Булево"), , НСтр("ru='Работа в медицинском учреждении'")));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("РаботаВМедицинскомУчрежденииПрежняя", Новый ОписаниеТипов("Булево"), , НСтр("ru=''")));	
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ИспользоватьВыгрузкуВФедеральныеМедрегистры", Новый ОписаниеТипов("Булево"), , НСтр("ru='Использовать выгрузку в федеральный регистр медицинских работников (формат 2022 г.)'")));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ИспользоватьВыгрузкуВФедеральныеМедрегистрыПрежняя", Новый ОписаниеТипов("Булево"), , НСтр("ru=''")));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ИспользоватьВыгрузкуВФедеральныйРегистрМедицинскихРаботников", Новый ОписаниеТипов("Булево"), , НСтр("ru='Использовать выгрузку в федеральный регистр медицинских работников (формат до 2017 г.)'")));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ИспользоватьВыгрузкуВФедеральныйРегистрМедицинскихРаботниковПрежняя", Новый ОписаниеТипов("Булево"), , НСтр("ru=''")));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ИспользоватьАккредитациюСпециалистов", Новый ОписаниеТипов("Булево"), , НСтр("ru='Использовать аккредитацию специалистов'")));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ИспользоватьАккредитациюСпециалистовПрежняя", Новый ОписаниеТипов("Булево"), , НСтр("ru=''")));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ИспользоватьДоступКНаркотическимСредствам", Новый ОписаниеТипов("Булево"), , НСтр("ru='Использовать доступ к наркотическим средствам'")));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ИспользоватьДоступКНаркотическимСредствамПрежняя", Новый ОписаниеТипов("Булево"), , НСтр("ru=''")));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ИспользоватьТарификационнуюОтчетностьУчрежденийФМБА", Новый ОписаниеТипов("Булево"), , НСтр("ru='Использовать тарификационную отчетность учреждений ФМБА'")));
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ИспользоватьТарификационнуюОтчетностьУчрежденийФМБАПрежняя", Новый ОписаниеТипов("Булево"), , НСтр("ru=''")));
	
	МассивИменРеквизитовФормы = Новый Массив;
	ЗарплатаКадры.ЗаполнитьМассивИменРеквизитовФормы(Форма, МассивИменРеквизитовФормы);
	ЗарплатаКадры.ИзменитьРеквизитыФормы(Форма, ДобавляемыеРеквизиты, МассивИменРеквизитовФормы);
	
	Если Форма.Элементы.Найти("РаботаВМедицинскомУчреждении") = Неопределено Тогда
		
		ГруппаРабота = Форма.Элементы.ГруппаРаботаВМедицинскомУчреждении;
		ГруппаНастройки = Форма.Элементы.ГруппаНастройкиМедицинскогоУчреждения;
		
		ПолеФлажка = Форма.Элементы.Вставить("РаботаВМедицинскомУчреждении", Тип("ПолеФормы"), ГруппаРабота, ГруппаНастройки);
		ПолеФлажка.ПутьКДанным = "РаботаВМедицинскомУчреждении";
		ПолеФлажка.Вид = ВидПоляФормы.ПолеФлажка;
		ПолеФлажка.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
		ПолеФлажка.УстановитьДействие("ПриИзменении", "Подключаемый_РаботаВМедицинскомУчрежденииПриИзменении");
		
		ПолеФлажка = Форма.Элементы.Вставить("ИспользоватьВыгрузкуВФедеральныйРегистрМедицинскихРаботников", Тип("ПолеФормы"), ГруппаНастройки);
		ПолеФлажка.ПутьКДанным = "ИспользоватьВыгрузкуВФедеральныйРегистрМедицинскихРаботников";
		ПолеФлажка.Вид = ВидПоляФормы.ПолеФлажка;
		ПолеФлажка.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
		ПолеФлажка.УстановитьДействие("ПриИзменении", "Подключаемый_ДополнительныеНастройкиМедицинскойОрганизацииПриИзменении");
		
		ПолеФлажка = Форма.Элементы.Вставить("ИспользоватьВыгрузкуВФедеральныеМедрегистры", Тип("ПолеФормы"), ГруппаНастройки);
		ПолеФлажка.ПутьКДанным = "ИспользоватьВыгрузкуВФедеральныеМедрегистры";
		ПолеФлажка.Вид = ВидПоляФормы.ПолеФлажка;
		ПолеФлажка.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
		ПолеФлажка.УстановитьДействие("ПриИзменении", "Подключаемый_ДополнительныеНастройкиМедицинскойОрганизацииПриИзменении");
		
		Если Форма.РаботаВБюджетномУчреждении И Форма.Элементы.Найти("ИспользоватьТарификационнуюОтчетностьУчрежденийФМБА") = Неопределено Тогда 
			
			ПолеФлажка = Форма.Элементы.Вставить("ИспользоватьТарификационнуюОтчетностьУчрежденийФМБА", Тип("ПолеФормы"), ГруппаНастройки);
			ПолеФлажка.ПутьКДанным = "ИспользоватьТарификационнуюОтчетностьУчрежденийФМБА";
			ПолеФлажка.Вид = ВидПоляФормы.ПолеФлажка;
			ПолеФлажка.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
			ПолеФлажка.УстановитьДействие("ПриИзменении", "Подключаемый_ДополнительныеНастройкиМедицинскойОрганизацииПриИзменении");
			
			ПолеФлажка = Форма.Элементы.Вставить("ИспользоватьДоступКНаркотическимСредствам", Тип("ПолеФормы"), ГруппаНастройки);
			ПолеФлажка.ПутьКДанным = "ИспользоватьДоступКНаркотическимСредствам";
			ПолеФлажка.Вид = ВидПоляФормы.ПолеФлажка;
			ПолеФлажка.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
			ПолеФлажка.УстановитьДействие("ПриИзменении", "Подключаемый_ДополнительныеНастройкиМедицинскойОрганизацииПриИзменении");
			
			ПолеФлажка = Форма.Элементы.Вставить("ИспользоватьАккредитациюСпециалистов", Тип("ПолеФормы"), ГруппаНастройки);
			ПолеФлажка.ПутьКДанным = "ИспользоватьАккредитациюСпециалистов";
			ПолеФлажка.Вид = ВидПоляФормы.ПолеФлажка;
			ПолеФлажка.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
			ПолеФлажка.УстановитьДействие("ПриИзменении", "Подключаемый_ДополнительныеНастройкиМедицинскойОрганизацииПриИзменении");
			
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура НастройкиПрограммыВРеквизитыФормы(Форма) Экспорт
	
	Форма.РаботаВМедицинскомУчреждении = РаботаВМедицинскомУчреждении();
	Форма.РаботаВМедицинскомУчрежденииПрежняя = Форма.РаботаВМедицинскомУчреждении;
		
	Форма.ИспользоватьВыгрузкуВФедеральныйРегистрМедицинскихРаботников = ПолучитьФункциональнуюОпцию("ИспользоватьВыгрузкуВФедеральныйРегистрМедицинскихРаботников");
	Форма.ИспользоватьВыгрузкуВФедеральныйРегистрМедицинскихРаботниковПрежняя = Форма.ИспользоватьВыгрузкуВФедеральныйРегистрМедицинскихРаботников;
		
	Форма.ИспользоватьВыгрузкуВФедеральныеМедрегистры = ПолучитьФункциональнуюОпцию("ИспользоватьВыгрузкуВФедеральныеМедрегистры");
	Форма.ИспользоватьВыгрузкуВФедеральныеМедрегистрыПрежняя = Форма.ИспользоватьВыгрузкуВФедеральныеМедрегистры;
		
	Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.Медицина.ТарификационнаяОтчетностьУчрежденийФМБА") Тогда
		МодульТарификационнаяОтчетностьУчрежденийФМБА = ОбщегоНазначения.ОбщийМодуль("ТарификационнаяОтчетностьУчрежденийФМБА");
		МодульТарификационнаяОтчетностьУчрежденийФМБА.НастройкиПрограммыВРеквизитыФормы(Форма);
	КонецЕсли;
		
	Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.Медицина.ДоступКНаркотическимСредствам") Тогда
		МодульДоступКНаркотическимСредствам = ОбщегоНазначения.ОбщийМодуль("ДоступКНаркотическимСредствам");
		МодульДоступКНаркотическимСредствам.НастройкиПрограммыВРеквизитыФормы(Форма);
	КонецЕсли;
	
	Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.АккредитацияСпециалистов") Тогда
		Форма.ИспользоватьАккредитациюСпециалистов = ПолучитьФункциональнуюОпцию("ИспользоватьАккредитациюСпециалистов");
		Форма.ИспользоватьАккредитациюСпециалистовПрежняя = Форма.ИспользоватьАккредитациюСпециалистов;
	КонецЕсли;
		
КонецПроцедуры

Процедура ДополнитьСтруктуруПараметровНастроек(СтруктураПараметров) Экспорт
	
	СтруктураПараметров.ПараметрыНастроек.Вставить("РаботаВМедицинскомУчреждении", Ложь);
	СтруктураПараметров.Вставить("РаботаВМедицинскомУчреждении");
	СтруктураПараметров.ПараметрыНастроек.Вставить("ИспользоватьВыгрузкуВФедеральныйРегистрМедицинскихРаботников", Ложь);
	СтруктураПараметров.Вставить("ИспользоватьВыгрузкуВФедеральныйРегистрМедицинскихРаботников");
	СтруктураПараметров.ПараметрыНастроек.Вставить("ИспользоватьВыгрузкуВФедеральныеМедрегистры", Ложь);
	СтруктураПараметров.Вставить("ИспользоватьВыгрузкуВФедеральныеМедрегистры");
	СтруктураПараметров.ПараметрыНастроек.Вставить("ИспользоватьТарификационнуюОтчетностьУчрежденийФМБА", Ложь);
	СтруктураПараметров.Вставить("ИспользоватьТарификационнуюОтчетностьУчрежденийФМБА");
	СтруктураПараметров.ПараметрыНастроек.Вставить("ИспользоватьДоступКНаркотическимСредствам", Ложь);
	СтруктураПараметров.Вставить("ИспользоватьДоступКНаркотическимСредствам");
	СтруктураПараметров.ПараметрыНастроек.Вставить("ИспользоватьАккредитациюСпециалистов", Ложь);
	СтруктураПараметров.Вставить("ИспользоватьАккредитациюСпециалистов");
	
КонецПроцедуры

Процедура ЗначенияСохраняемыхРеквизитовФормыНастройкаПрограммы(Форма, Параметры) Экспорт
	
	Параметры.РаботаВМедицинскомУчреждении = Форма.РаботаВМедицинскомУчреждении;  
	Параметры.ИспользоватьВыгрузкуВФедеральныйРегистрМедицинскихРаботников = Форма.ИспользоватьВыгрузкуВФедеральныйРегистрМедицинскихРаботников;  
	Параметры.ИспользоватьВыгрузкуВФедеральныеМедрегистры = Форма.ИспользоватьВыгрузкуВФедеральныеМедрегистры;  
	Параметры.ИспользоватьТарификационнуюОтчетностьУчрежденийФМБА = Форма.ИспользоватьТарификационнуюОтчетностьУчрежденийФМБА;  
	Параметры.ИспользоватьДоступКНаркотическимСредствам = Форма.ИспользоватьДоступКНаркотическимСредствам;  
	Параметры.ИспользоватьАккредитациюСпециалистов = Форма.ИспользоватьАккредитациюСпециалистов;  
	
КонецПроцедуры

Процедура ЗаписатьНастройкиЗарплатыМедицинскогоУчреждения(НастройкиПрограммы) Экспорт

	ПараметрыНастроек = НастройкиПрограммы.ПараметрыНастроек;
	
	Если ПараметрыНастроек.РаботаВМедицинскомУчреждении Тогда
		Константы.РаботаВМедицинскомУчреждении.Установить(НастройкиПрограммы.РаботаВМедицинскомУчреждении);
	КонецЕсли;
		
	Если ПараметрыНастроек.ИспользоватьВыгрузкуВФедеральныйРегистрМедицинскихРаботников Тогда
		Константы.ИспользоватьВыгрузкуВФедеральныйРегистрМедицинскихРаботников.Установить(НастройкиПрограммы.ИспользоватьВыгрузкуВФедеральныйРегистрМедицинскихРаботников);
	КонецЕсли;
		
	Если ПараметрыНастроек.ИспользоватьВыгрузкуВФедеральныеМедрегистры Тогда
		Константы.ИспользоватьВыгрузкуВФедеральныеМедрегистры.Установить(НастройкиПрограммы.ИспользоватьВыгрузкуВФедеральныеМедрегистры);
	КонецЕсли;
		
	Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.Медицина.ТарификационнаяОтчетностьУчрежденийФМБА") Тогда
		МодульТарификационнаяОтчетностьУчрежденийФМБА = ОбщегоНазначения.ОбщийМодуль("ТарификационнаяОтчетностьУчрежденийФМБА");
		МодульТарификационнаяОтчетностьУчрежденийФМБА.ЗаписатьНастройкиЗарплатыМедицинскогоУчреждения(НастройкиПрограммы);
	КонецЕсли;
		
	Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.Медицина.ДоступКНаркотическимСредствам") Тогда
		МодульДоступКНаркотическимСредствам = ОбщегоНазначения.ОбщийМодуль("ДоступКНаркотическимСредствам");
		МодульДоступКНаркотическимСредствам.ЗаписатьНастройкиЗарплатыМедицинскогоУчреждения(НастройкиПрограммы);
	КонецЕсли;
	
	Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.АккредитацияСпециалистов") Тогда
		Если ПараметрыНастроек.ИспользоватьАккредитациюСпециалистов Тогда
			Константы.ИспользоватьАккредитациюСпециалистов.Установить(НастройкиПрограммы.ИспользоватьАккредитациюСпециалистов);
		КонецЕсли;
	КонецЕсли;
		
КонецПроцедуры

Процедура ДобавитьПоказательОтчетаПоНастройкам(ТаблицаПоказателей) Экспорт
	
	Отчеты.НастройкиПрограммыЗарплатаКадры.ДобавитьПоказатель(ТаблицаПоказателей, "Константы", "РаботаВМедицинскомУчреждении", 
		"Рассчитывается зарплата в медицинском учреждении", "Расчет зарплаты", "Работа в медицинском учреждении", "Ложь", 4, 8, 1);	
		
	Если ПолучитьФункциональнуюОпцию("РаботаВМедицинскомУчреждении") Тогда			
		Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.Медицина.ТарификационнаяОтчетностьУчрежденийФМБА") Тогда
			Отчеты.НастройкиПрограммыЗарплатаКадры.ДобавитьПоказатель(ТаблицаПоказателей, "Константы", "ИспользоватьТарификационнуюОтчетностьУчрежденийФМБА", 
				"Использовать тарификационную отчетность учреждений ФМБА", "Расчет зарплаты", "Работа в медицинском учреждении", "Ложь", 4, 8, 2);	
		КонецЕсли;
		Отчеты.НастройкиПрограммыЗарплатаКадры.ДобавитьПоказатель(ТаблицаПоказателей, "Константы", "ИспользоватьВыгрузкуВФедеральныйРегистрМедицинскихРаботников", 
			"Использовать выгрузку в федеральный регистр медицинских работников", "Расчет зарплаты", "Работа в медицинском учреждении", "Ложь", 4, 8, 3);	
		Отчеты.НастройкиПрограммыЗарплатаКадры.ДобавитьПоказатель(ТаблицаПоказателей, "Константы", "ИспользоватьВыгрузкуВФедеральныеМедрегистры", 
			"Использовать выгрузку в федеральные медрегистры (версия 2)", "Расчет зарплаты", "Работа в медицинском учреждении", "Ложь", 4, 8, 4);	
		Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.Медицина.ДоступКНаркотическимСредствам") Тогда
			Отчеты.НастройкиПрограммыЗарплатаКадры.ДобавитьПоказатель(ТаблицаПоказателей, "Константы", "ИспользоватьДоступКНаркотическимСредствам", 
				"Использовать доступ к наркотическим средствам", "Расчет зарплаты", "Работа в медицинском учреждении", "Ложь", 4, 8, 5);	
		КонецЕсли;
		Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.АккредитацияСпециалистов") Тогда
			Отчеты.НастройкиПрограммыЗарплатаКадры.ДобавитьПоказатель(ТаблицаПоказателей, "Константы", "ИспользоватьАккредитациюСпециалистов", 
				"Использовать аккредитацию специалистов", "Расчет зарплаты", "Работа в медицинском учреждении", "Ложь", 4, 8, 6);	
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

