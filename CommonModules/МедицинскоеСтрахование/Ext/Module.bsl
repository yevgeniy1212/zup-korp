		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПрикреплениеКПрограммамМедицинскогоСтрахования.ДанныеЗастрахованных КАК ПрикреплениеКПрограммамМедицинскогоСтрахованияДанныеЗастрахованных
		|		ПО ПрикреплениеКПрограммамМедицинскогоСтрахования.Ссылка = ПрикреплениеКПрограммамМедицинскогоСтрахованияДанныеЗастрахованных.Ссылка
		|ГДЕ
		|	ПрикреплениеКПрограммамМедицинскогоСтрахованияДанныеЗастрахованных.Застрахованный ЕСТЬ NULL
		|	И ПрикреплениеКПрограммамМедицинскогоСтрахования.КраткийСоставДокумента <> """"
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПрикреплениеКПрограммамМедицинскогоСтрахования.Дата УБЫВ";
	Если ПараметрыОбновления = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПЕРВЫЕ 1000", "");
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
	Иначе
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Ложь);
		
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			
			Если Не ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ПодготовитьОбновлениеДанных(ПараметрыОбновления, "Документ.ПрикреплениеКПрограммамМедицинскогоСтрахования", "Ссылка", Выборка.Ссылка) Тогда
				Продолжить;
			КонецЕсли;
			
			ДокументПрикрепление = Выборка.Ссылка.ПолучитьОбъект();
			Для Каждого СведениеСотрудника Из ДокументПрикрепление.СведенияСотрудников Цикл
				ОтборСтрок = Новый Структура("Сотрудник", СведениеСотрудника.Сотрудник);
				НайденнаяСтрока = ДокументПрикрепление.Сотрудники.НайтиСтроки(ОтборСтрок);
				Если НайденнаяСтрока.Количество() = 0 Тогда
					Продолжить;
				КонецЕсли;
				Застрахованный = НайденнаяСтрока[0].ФизическоеЛицо;
				Если ДанныеЗастрахованных()[СведениеСотрудника.СведениеИмя] Тогда
					ЗаполнитьДанныеЗастрахованного(Застрахованный, ДокументПрикрепление, СведениеСотрудника);
				Иначе
					ЗаполнитьКонтактнуюИнформациюЗастрахованного(Застрахованный, ДокументПрикрепление, СведениеСотрудника);
				КонецЕсли;
			КонецЦикла;
			Для Каждого СведениеРодственника Из ДокументПрикрепление.СведенияРодственников Цикл
				Если ДанныеЗастрахованных()[СведениеРодственника.СведениеИмя] Тогда
					ЗаполнитьДанныеЗастрахованного(СведениеРодственника.РодственникСсылка, ДокументПрикрепление, СведениеРодственника);
				Иначе
					ЗаполнитьКонтактнуюИнформациюЗастрахованного(СведениеРодственника.РодственникСсылка, ДокументПрикрепление, СведениеРодственника);
				КонецЕсли;
			КонецЦикла;
			
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ДокументПрикрепление);
			ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
			
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьУсловияМедицинскогоСтрахованияИзПрикреплений(ПараметрыОбновления) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1000
		|	ПрикреплениеКПрограммамМедицинскогоСтрахования.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.ПрикреплениеКПрограммамМедицинскогоСтрахования КАК ПрикреплениеКПрограммамМедицинскогоСтрахования
		|ГДЕ
		|	ПрикреплениеКПрограммамМедицинскогоСтрахования.Проведен = ИСТИНА
		|	И НЕ ПрикреплениеКПрограммамМедицинскогоСтрахования.Ссылка В (&Обработанные)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПрикреплениеКПрограммамМедицинскогоСтрахования.Дата УБЫВ";
	Если Не ПараметрыОбновления.Свойство("Обработанные") Тогда
		Обработанные = Новый Массив;
		ПараметрыОбновления.Вставить("Обработанные");
	ИначеЕсли ПараметрыОбновления.Обработанные = Неопределено Тогда
		Обработанные = Новый Массив;
	Иначе
		Обработанные = ПараметрыОбновления.Обработанные;
	КонецЕсли;
	Запрос.УстановитьПараметр("Обработанные", Обработанные);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
	Иначе
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Ложь);
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			Обработанные.Добавить(Выборка.Ссылка);
			ЗаполнитьПрограммыМедицинскогоСтрахованияИзПрикрепления(ПараметрыОбновления, Выборка.Ссылка);
			ЗаполнитьРасширенияПрограммМедицинскогоСтрахованияИзПрикрепления(ПараметрыОбновления, Выборка.Ссылка);
		КонецЦикла;
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "Обработанные", Обработанные);
	КонецЕсли;
	
КонецПроцедуры

