Процедура ВыполнитьЗаполнениеДатСтрахования(ПараметрыОбновления, ОбновляемыеДокументы)
	
	Выборка = ОбновляемыеДокументы.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если Не ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ПодготовитьОбновлениеДанных(
				ПараметрыОбновления, "Документ.ПрикреплениеКПрограммамМедицинскогоСтрахования", "Ссылка", Выборка.Ссылка) Тогда
			Продолжить;
		КонецЕсли;
		
		ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
		Для каждого СтрокаДокумента Из ДокументОбъект.Сотрудники Цикл
			ОтборСтрок = Новый Структура("Сотрудник", СтрокаДокумента.Сотрудник);
			НайденныеСтроки = ДокументОбъект.ПрограммыСтрахованияСотрудников.НайтиСтроки(ОтборСтрок);
			Для Каждого ИзменяемаяСтрока Из НайденныеСтроки Цикл
				ИзменяемаяСтрока.ДатаНачала = СтрокаДокумента.ДатаПрикрепления;
				ИзменяемаяСтрока.ДатаОкончания = ДокументОбъект.ДатаОкончанияСтрахования;
			КонецЦикла;
			НайденныеСтроки = ДокументОбъект.РасширенияПрограммСтрахованияСотрудников.НайтиСтроки(ОтборСтрок);
			Для Каждого ИзменяемаяСтрока Из НайденныеСтроки Цикл
				ИзменяемаяСтрока.ДатаНачала = СтрокаДокумента.ДатаПрикрепления;
				ИзменяемаяСтрока.ДатаОкончания = ДокументОбъект.ДатаОкончанияСтрахования;
			КонецЦикла;
		КонецЦикла;
		Для каждого СтрокаДокумента Из ДокументОбъект.Родственники Цикл
			ОтборСтрок = Новый Структура("ФизическоеЛицо, Родственник", СтрокаДокумента.ФизическоеЛицо, СтрокаДокумента.Родственник);
			НайденныеСтроки = ДокументОбъект.ПрограммыСтрахованияРодственников.НайтиСтроки(ОтборСтрок);
			Для Каждого ИзменяемаяСтрока Из НайденныеСтроки Цикл
				ИзменяемаяСтрока.ДатаНачала = СтрокаДокумента.ДатаПрикрепления;
				ИзменяемаяСтрока.ДатаОкончания = СтрокаДокумента.ДатаОткрепления;
			КонецЦикла;
			НайденныеСтроки = ДокументОбъект.РасширенияПрограммСтрахованияРодственников.НайтиСтроки(ОтборСтрок);
			Для Каждого ИзменяемаяСтрока Из НайденныеСтроки Цикл
				ИзменяемаяСтрока.ДатаНачала = СтрокаДокумента.ДатаПрикрепления;
				ИзменяемаяСтрока.ДатаОкончания = СтрокаДокумента.ДатаОткрепления;
			КонецЦикла;
		КонецЦикла;
		ОбновлениеИнформационнойБазы.ЗаписатьДанные(ДокументОбъект);
		
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
		
	КонецЦикла;

КонецПроцедуры

Функция РодственникМедицинскогоСтрахования(ФИОРодственника)
	
	РодственникСсылка = Справочники.РодственникиФизическихЛиц.НайтиПоНаименованию(ФИОРодственника);
	Если ЗначениеЗаполнено(РодственникСсылка) Тогда
		Возврат РодственникСсылка;
	КонецЕсли;
	
	РодственникОбъект = Справочники.РодственникиФизическихЛиц.СоздатьЭлемент();
	РодственникОбъект.Наименование = ФИОРодственника;
	ФИО = СокрЛП(ФИОРодственника);
	Пока СтрНайти(ФИО, "  ") > 0 Цикл
		ФИО = СтрЗаменить(ФИО, "  ", " ");
	КонецЦикла;
	СтруктураФИО = ФизическиеЛицаКлиентСервер.ЧастиИмени(ФИО);
	РодственникОбъект.Фамилия  = СтруктураФИО.Фамилия;
	РодственникОбъект.Имя = СтруктураФИО.Имя;
	РодственникОбъект.Отчество = СтруктураФИО.Отчество;
	ОбновлениеИнформационнойБазы.ЗаписатьОбъект(РодственникОбъект);
	
	Возврат РодственникОбъект.Ссылка;
	
КонецФункции

Процедура ЗаполнитьДанныеЗастрахованного(Застрахованный, ДокументПрикрепление, СтрокаСведение)
	
	НайденныеДанные = ДокументПрикрепление.ДанныеЗастрахованных.НайтиСтроки(Новый Структура("Застрахованный", Застрахованный));
	Если НайденныеДанные.Количество() = 0 Тогда
		СтрокаДанные = ДокументПрикрепление.ДанныеЗастрахованных.Добавить();
		СтрокаДанные.Застрахованный = Застрахованный;
	Иначе
		СтрокаДанные = НайденныеДанные[0];
	КонецЕсли;
	Если СтрокаСведение.СведениеИмя = "ДатаРождения" Тогда
		СтрокаДанные.ДатаРождения = СтрокаСведение.СведениеЗначение;
		СтрокаДанные.ДатаРожденияДоИзменения = СтрокаСведение.СведениеЗначение;
	ИначеЕсли СтрокаСведение.СведениеИмя = "СтраховойНомерПФР" Тогда
		СтрокаДанные.СтраховойНомерПФР = СтрокаСведение.СведениеЗначение;
		СтрокаДанные.СтраховойНомерПФРДоИзменения = СтрокаСведение.СведениеЗначение;
	ИначеЕсли СтрокаСведение.СведениеИмя = "Пол" Тогда
		СтрокаДанные.Пол = СтрокаСведение.СведениеЗначение;
		СтрокаДанные.ПолДоИзменения = СтрокаСведение.СведениеЗначение;
	ИначеЕсли СтрокаСведение.СведениеИмя = "Страна" Тогда
		СтрокаДанные.Страна = СтрокаСведение.СведениеЗначение;
		СтрокаДанные.СтранаДоИзменения = СтрокаСведение.СведениеЗначение;
	ИначеЕсли СтрокаСведение.СведениеИмя = "ДокументПредставление" Тогда
		СтрокаДанные.ДокументПредставление = СтрокаСведение.СведениеЗначение;
		СтрокаДанные.ДокументПредставлениеДоИзменения = СтрокаСведение.СведениеЗначение;
	ИначеЕсли СтрокаСведение.СведениеИмя = "ДокументВид" Тогда
		СтрокаДанные.ДокументВид = СтрокаСведение.СведениеЗначение;
		СтрокаДанные.ДокументВидДоИзменения = СтрокаСведение.СведениеЗначение;
	ИначеЕсли СтрокаСведение.СведениеИмя = "ДокументСерия" Тогда
		СтрокаДанные.ДокументСерия = СтрокаСведение.СведениеЗначение;
		СтрокаДанные.ДокументСерияДоИзменения = СтрокаСведение.СведениеЗначение;
	ИначеЕсли СтрокаСведение.СведениеИмя = "ДокументНомер" Тогда
		СтрокаДанные.ДокументНомер = СтрокаСведение.СведениеЗначение;
		СтрокаДанные.ДокументНомерДоИзменения = СтрокаСведение.СведениеЗначение;
	ИначеЕсли СтрокаСведение.СведениеИмя = "ДокументДатаВыдачи" Тогда
		СтрокаДанные.ДокументДатаВыдачи = СтрокаСведение.СведениеЗначение;
		СтрокаДанные.ДокументДатаВыдачиДоИзменения = СтрокаСведение.СведениеЗначение;
	ИначеЕсли СтрокаСведение.СведениеИмя = "ДокументСрокДействия" Тогда
		СтрокаДанные.ДокументСрокДействия = СтрокаСведение.СведениеЗначение;
		СтрокаДанные.ДокументСрокДействияДоИзменения = СтрокаСведение.СведениеЗначение;
	ИначеЕсли СтрокаСведение.СведениеИмя = "ДокументКемВыдан" Тогда
		СтрокаДанные.ДокументКемВыдан = СтрокаСведение.СведениеЗначение;
		СтрокаДанные.ДокументКемВыданДоИзменения = СтрокаСведение.СведениеЗначение;
	ИначеЕсли СтрокаСведение.СведениеИмя = "ДокументКодПодразделения" Тогда
		СтрокаДанные.ДокументКодПодразделения = СтрокаСведение.СведениеЗначение;
		СтрокаДанные.ДокументКодПодразделенияДоИзменения = СтрокаСведение.СведениеЗначение;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьКонтактнуюИнформациюЗастрахованного(Застрахованный, ДокументПрикрепление, СтрокаСведение)
	
	ВидКИ = ВидКонтактнойИнформацииПоСведению()[СтрокаСведение.СведениеИмя];
	ОтборСтрок = Новый Структура("Застрахованный, Вид", Застрахованный, ВидКИ);
	НайденнаяКИ = ДокументПрикрепление.КонтактнаяИнформацияЗастрахованных.НайтиСтроки(ОтборСтрок);
	Если НайденнаяКИ.Количество() = 0 Тогда
		СтрокаКИ = ДокументПрикрепление.КонтактнаяИнформацияЗастрахованных.Добавить();
		СтрокаКИ.Застрахованный = Застрахованный;
		СтрокаКИ.Вид = ВидКИ;
	Иначе
		СтрокаКИ = НайденнаяКИ[0];
	КонецЕсли;
	Если СтрокаСведение.СведениеИмя = "КонтактнаяИнформация1"
		Или СтрокаСведение.СведениеИмя = "КонтактнаяИнформация2"
		Или СтрокаСведение.СведениеИмя = "КонтактнаяИнформация3"
		Или СтрокаСведение.СведениеИмя = "КонтактнаяИнформация4" Тогда
		СтрокаКИ.Значение = СтрокаСведение.СведениеЗначение;
	Иначе
		СтрокаКИ.Представление = СтрокаСведение.СведениеЗначение;
	КонецЕсли;
	
КонецПроцедуры

Функция ДанныеЗастрахованных()
	
	ДанныеЗастрахованных = Новый Структура;
	ДанныеЗастрахованных.Вставить("ДатаРождения", Истина);
	ДанныеЗастрахованных.Вставить("СтраховойНомерПФР", Истина);
	ДанныеЗастрахованных.Вставить("Пол", Истина);
	ДанныеЗастрахованных.Вставить("Страна", Истина);
	ДанныеЗастрахованных.Вставить("ДокументПредставление", Истина);
	ДанныеЗастрахованных.Вставить("ДокументВид", Истина);
	ДанныеЗастрахованных.Вставить("ДокументСерия",Истина);
	ДанныеЗастрахованных.Вставить("ДокументНомер", Истина);
	ДанныеЗастрахованных.Вставить("ДокументДатаВыдачи", Истина);
	ДанныеЗастрахованных.Вставить("ДокументСрокДействия", Истина);
	ДанныеЗастрахованных.Вставить("ДокументКемВыдан", Истина);
	ДанныеЗастрахованных.Вставить("ДокументКодПодразделения", Истина);
	ДанныеЗастрахованных.Вставить("КонтактнаяИнформация1", Ложь);
	ДанныеЗастрахованных.Вставить("КонтактнаяИнформация2", Ложь);
	ДанныеЗастрахованных.Вставить("КонтактнаяИнформация3", Ложь);
	ДанныеЗастрахованных.Вставить("КонтактнаяИнформация4", Ложь);
	ДанныеЗастрахованных.Вставить("КонтактнаяИнформация1Представление", Ложь);
	ДанныеЗастрахованных.Вставить("КонтактнаяИнформация2Представление", Ложь);
	ДанныеЗастрахованных.Вставить("КонтактнаяИнформация3Представление", Ложь);
	ДанныеЗастрахованных.Вставить("КонтактнаяИнформация4Представление", Ложь);
	
	Возврат ДанныеЗастрахованных;
	
КонецФункции

Функция ВидКонтактнойИнформацииПоСведению()
	
	СтруктураВидимостьНаФорме = Новый Структура;
	СтруктураВидимостьНаФорме.Вставить("КонтактнаяИнформация1", Справочники.ВидыКонтактнойИнформации.АдресДляИнформированияФизическиеЛица);
	СтруктураВидимостьНаФорме.Вставить("КонтактнаяИнформация2", Справочники.ВидыКонтактнойИнформации.ТелефонДомашнийФизическиеЛица);
	СтруктураВидимостьНаФорме.Вставить("КонтактнаяИнформация3", Справочники.ВидыКонтактнойИнформации.ТелефонМобильныйФизическиеЛица);
	СтруктураВидимостьНаФорме.Вставить("КонтактнаяИнформация4", Справочники.ВидыКонтактнойИнформации.EMailФизическиеЛица);
	СтруктураВидимостьНаФорме.Вставить("КонтактнаяИнформация1Представление", Справочники.ВидыКонтактнойИнформации.АдресДляИнформированияФизическиеЛица);
	СтруктураВидимостьНаФорме.Вставить("КонтактнаяИнформация2Представление", Справочники.ВидыКонтактнойИнформации.ТелефонДомашнийФизическиеЛица);
	СтруктураВидимостьНаФорме.Вставить("КонтактнаяИнформация3Представление", Справочники.ВидыКонтактнойИнформации.ТелефонМобильныйФизическиеЛица);
	СтруктураВидимостьНаФорме.Вставить("КонтактнаяИнформация4Представление", Справочники.ВидыКонтактнойИнформации.EMailФизическиеЛица);
	
	Возврат СтруктураВидимостьНаФорме;
	
КонецФункции

#Область ПоказателиРасчетаЗарплаты

Процедура ЗаполнитьИсточникДанныхПоказателейИсключений(ПоказательРасчетаЗарплаты) Экспорт
	
	Если ПоказательРасчетаЗарплаты.ИмяПредопределенныхДанных = "СтраховаяПремия"
		Или ПоказательРасчетаЗарплаты.ИмяПредопределенныхДанных = "КоличествоДнейПериодаСтрахования" Тогда
		ПоказательРасчетаЗарплаты.ПериодическийПоказательСотрудника = Истина;
	КонецЕсли;
	
КонецПроцедуры

Процедура ДополнитьТаблицуУдержанийИзвестнымиПоказателями(ДатаУвольнения, МенеджерРасчета) Экспорт
	
	ЗначениеКалендарныеДни = ЗарплатаКадрыКлиентСервер.ДнейВПериоде(НачалоМесяца(ДатаУвольнения), ДатаУвольнения);
	ПоказательКалендарныеДни = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.КалендарныеДни");
	Для Каждого СтрокаУдержаний Из МенеджерРасчета.Зарплата.Удержания Цикл
		МенеджерРасчета.ДобавитьИзвестноеЗначениеПоказателя(СтрокаУдержаний, ПоказательКалендарныеДни, ЗначениеКалендарныеДни);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

Функция ФизическиеЛицаСУдержаниемПоГрафику(Организация, ФизическиеЛица)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	УдержанияМедицинскогоСтрахования.ФизическоеЛицо
		|ИЗ
		|	РегистрСведений.УдержанияМедицинскогоСтрахования КАК УдержанияМедицинскогоСтрахования
		|ГДЕ
		|	УдержанияМедицинскогоСтрахования.Организация = &Организация
		|	И УдержанияМедицинскогоСтрахования.ФизическоеЛицо В (&ФизическиеЛица)
		|	И
		|		УдержанияМедицинскогоСтрахования.СпособУдержания = ЗНАЧЕНИЕ(Перечисление.СпособыУдержанияМедицинскогоСтрахованияСотрудников.ПоГрафику)";
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ФизическиеЛица", ФизическиеЛица);
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ФизическоеЛицо");
	
КонецФункции

Функция ГрафикУдержаний(Организация, ФизическиеЛица, МесяцНачисления)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	УдержанияМедицинскогоСтрахованияСрезПоследних.ФизическоеЛицо КАК ФизическоеЛицо,
		|	МАКСИМУМ(УдержанияМедицинскогоСтрахованияСрезПоследних.ДокументОснование) КАК ДокументОснование
		|ПОМЕСТИТЬ ВТУдержанияПоГрафику
		|ИЗ
		|	РегистрСведений.УдержанияМедицинскогоСтрахования.СрезПоследних(
		|			,
		|			Организация = &Организация
		|				И ФизическоеЛицо В (&ФизическиеЛица)) КАК УдержанияМедицинскогоСтрахованияСрезПоследних
		|ГДЕ
		|	УдержанияМедицинскогоСтрахованияСрезПоследних.СпособУдержания = ЗНАЧЕНИЕ(Перечисление.СпособыУдержанияМедицинскогоСтрахованияСотрудников.ПоГрафику)
		|
		|СГРУППИРОВАТЬ ПО
		|	УдержанияМедицинскогоСтрахованияСрезПоследних.ФизическоеЛицо
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТУдержанияПоГрафику.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТУдержанияПоГрафику.ДокументОснование КАК ДокументОснование,
		|	ГрафикУдержанийМедицинскогоСтрахования.Удержание КАК Удержание,
		|	ГрафикУдержанийМедицинскогоСтрахования.Сумма КАК Сумма
		|ИЗ
		|	ВТУдержанияПоГрафику КАК ВТУдержанияПоГрафику
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГрафикУдержанийМедицинскогоСтрахования КАК ГрафикУдержанийМедицинскогоСтрахования
		|		ПО ВТУдержанияПоГрафику.ФизическоеЛицо = ГрафикУдержанийМедицинскогоСтрахования.ФизическоеЛицо
		|			И ВТУдержанияПоГрафику.ДокументОснование = ГрафикУдержанийМедицинскогоСтрахования.ДокументОснование
		|ГДЕ
		|	ГрафикУдержанийМедицинскогоСтрахования.Дата = &МесяцНачисления";
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ФизическиеЛица", ФизическиеЛица);
	Запрос.УстановитьПараметр("МесяцНачисления", МесяцНачисления);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Процедура ЗарегистрироватьИзменениеФизическогоЛицаПриЗаписи(Объект) Экспорт
	
	ТекущиеСтрахования = ТекущиеСтрахованияФизическогоЛица(Объект.Ссылка);
	Если ТекущиеСтрахования.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ТекущееСтрахование Из ТекущиеСтрахования Цикл
		ОтборСтруктура = Новый Структура("Организация, СтраховаяКомпания, Застрахованный",
			ТекущееСтрахование.Организация, ТекущееСтрахование.СтраховаяКомпания, Объект.Ссылка);
			
		ОтправляемыеДанныеТаблица = ОтправляемыеДанныеВСтраховуюКомпанию(
			ТекущееСтрахование.Организация, ТекущееСтрахование.СтраховаяКомпания);
		Если ОтправляемыеДанныеТаблица.Количество() > 0 Тогда
			ТаблицаОтправленныеДанные = РегистрыСведений.ОтправленныеДанныеЗастрахованных.СрезПоследних(, ОтборСтруктура);
			Если ТаблицаОтправленныеДанные.Количество() > 0 Тогда
				ОбработатьИзменениеОтправленныхДанныхФизическогоЛица(
					Объект,
					ОтправляемыеДанныеТаблица.ВыгрузитьКолонку("Сведение"),
					ТаблицаОтправленныеДанные[0],
					ТекущееСтрахование);
			КонецЕсли;
		КонецЕсли;
		
		ОтправленнаяКонтактнаяИнформация = РегистрыСведений.ОтправленнаяКонтактнаяИнформацияЗастрахованных.СрезПоследних(, ОтборСтруктура);
		Если ОтправленнаяКонтактнаяИнформация.Количество() > 0 Тогда
			ОбработатьИзменениеКонтактнойИнформацииФизическогоЛица(
				Объект,
				ОтправленнаяКонтактнаяИнформация,
				ТекущееСтрахование);
		КонецЕсли; 
		
		Если ПолучитьФункциональнуюОпцию("ИспользоватьДополнительныеРеквизитыИСведения") И УправлениеСвойствами.СвойстваДоступны() Тогда
			ОтправленныеДополнительныеРеквизитыИСведения = РегистрыСведений.ОтправленныеДополнительныеРеквизитыИСведенияЗастрахованных.СрезПоследних(, ОтборСтруктура);
			Если ОтправленныеДополнительныеРеквизитыИСведения.Количество() > 0 Тогда
				ОбработатьИзменениеДополнительныхРеквизитовИСведенийФизическогоЛица(
					Объект,
					ОтправленныеДополнительныеРеквизитыИСведения,
					ТекущееСтрахование);
			КонецЕсли;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗарегистрироватьИзменениеРодственникаПриЗаписи(Объект) Экспорт

	ТекущиеСтрахования = ТекущиеСтрахованияРодственника(Объект.Ссылка);
	Если ТекущиеСтрахования.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	Для Каждого ТекущееСтрахование Из ТекущиеСтрахования Цикл
		ОтборСтруктура = Новый Структура("Организация, СтраховаяКомпания, Застрахованный",
			ТекущееСтрахование.Организация, ТекущееСтрахование.СтраховаяКомпания, Объект.Ссылка);
			
		ОтправляемыеДанныеТаблица = ОтправляемыеДанныеВСтраховуюКомпанию(
			ТекущееСтрахование.Организация, ТекущееСтрахование.СтраховаяКомпания);
		Если ОтправляемыеДанныеТаблица.Количество() > 0 Тогда
			ТаблицаОтправленныеДанные = РегистрыСведений.ОтправленныеДанныеЗастрахованных.СрезПоследних(, ОтборСтруктура);
			Если ТаблицаОтправленныеДанные.Количество() > 0 Тогда
				ОбработатьИзменениеОтправленныхДанныхРодственника(
					Объект,
					ОтправляемыеДанныеТаблица.ВыгрузитьКолонку("Сведение"),
					ТаблицаОтправленныеДанные[0],
					ТекущееСтрахование);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗапомнитьПрежнееЗначениеГражданстваФизическогоЛицаПередЗаписью(Источник, ФизическоеЛицо) Экспорт
	
	ТекущиеСтрахования = ТекущиеСтрахованияФизическогоЛица(ФизическоеЛицо);
	Если ТекущиеСтрахования.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеСтрахованияМассив = Новый Массив;
	ЗапоминатьГражданство = Ложь;
	
	Для Каждого ТекущееСтрахование Из ТекущиеСтрахования Цикл
		ОтправляемыеДанныеТаблица = ОтправляемыеДанныеВСтраховуюКомпанию(
			ТекущееСтрахование.Организация, ТекущееСтрахование.СтраховаяКомпания);
		ОтправляемыеДанные = ОтправляемыеДанныеТаблица.ВыгрузитьКолонку("Сведение");
		Если ОтправляемыеДанные.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		Если ОтправляемыеДанные.Найти("Страна") = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ЗапоминатьГражданство = Истина;
		ТекущиеСтрахованияМассив.Добавить(Новый Структура("Организация, СтраховаяКомпания", ТекущееСтрахование.Организация, ТекущееСтрахование.СтраховаяКомпания));
	КонецЦикла;
	
	Если ЗапоминатьГражданство Тогда
		Таблица = КадровыйУчет.КадровыеДанныеФизическихЛиц(Истина, ФизическоеЛицо, "Страна");
		СоответствиеПрежнееЗначениеГражданства = Новый Соответствие;
		СоответствиеПрежнееЗначениеГражданства.Вставить(ФизическоеЛицо, Таблица);
		Источник.ДополнительныеСвойства.Вставить("СоответствиеПрежнееЗначениеГражданстваМедицинскогоСтрахования", СоответствиеПрежнееЗначениеГражданства);
		Источник.ДополнительныеСвойства.Вставить("ТекущиеСтрахованияМассив", ТекущиеСтрахованияМассив);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьИзменениеГражданстваМедицинскогоСтрахованияПриЗаписи(Источник) Экспорт
	
	СоответствиеПрежнееЗначениеГражданства = Источник.ДополнительныеСвойства["СоответствиеПрежнееЗначениеГражданстваМедицинскогоСтрахования"];
	ТаблицаПрежнееЗначения = СоответствиеПрежнееЗначениеГражданства.Получить(Источник[0].ФизическоеЛицо);
	ТекущиеСтрахованияМассив = Источник.ДополнительныеСвойства["ТекущиеСтрахованияМассив"];
	
	Для Каждого ТекущееСтрахование Из ТекущиеСтрахованияМассив Цикл
		ОтборСтруктура = Новый Структура("Организация, СтраховаяКомпания, Застрахованный",ТекущееСтрахование.Организация, ТекущееСтрахование.СтраховаяКомпания, Источник[0].ФизическоеЛицо);
		ТаблицаОтправленныеДанные = РегистрыСведений.ОтправленныеДанныеЗастрахованных.СрезПоследних(, ОтборСтруктура);
		Если ТаблицаОтправленныеДанные.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ОтправленныеДанные = ТаблицаОтправленныеДанные[0];
		
		ИзменилосьГражданство = Ложь;
		Если ТаблицаПрежнееЗначения.Количество() > 0 Тогда
			Если ТаблицаПрежнееЗначения[0].Страна <> Источник[0].Страна И Источник[0].Страна <> ОтправленныеДанные.Страна Тогда
				ИзменилосьГражданство = Истина;
			КонецЕсли;
		КонецЕсли;
		
		Если ИзменилосьГражданство = Ложь Тогда
			Продолжить;
		КонецЕсли;
		
		НаборЗаписей = РегистрыСведений.ИзменениеОтправленныхДанныхЗастрахованных.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Организация.Установить(ТекущееСтрахование.Организация);
		НаборЗаписей.Отбор.СтраховаяКомпания.Установить(ТекущееСтрахование.СтраховаяКомпания);
		НаборЗаписей.Отбор.Застрахованный.Установить(Источник[0].ФизическоеЛицо);
		НаборЗаписей.Прочитать();
		Если НаборЗаписей.Количество() = 0 Тогда
			Запись = НаборЗаписей.Добавить();
			Запись.Организация = ТекущееСтрахование.Организация;
			Запись.СтраховаяКомпания = ТекущееСтрахование.СтраховаяКомпания;
			Запись.Застрахованный = Источник[0].ФизическоеЛицо;
		Иначе
			Запись = НаборЗаписей[0];
		КонецЕсли;
		Запись.Страна = Источник[0].Страна;
		НаборЗаписей.Записать();
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбработатьИзменениеОтправленныхДанныхФизическогоЛица(Объект, ОтправляемыеДанные, ОтправленныеДанные, ТекущееСтрахование)
	
	ПрежниеЗначения = Объект.ДополнительныеСвойства["ПрежниеЗначения"];
	ИзменилисьОтправленныеДанные = Ложь;
	
	ИзмениласьФамилия = Ложь;
	Если Объект.Фамилия <> ПрежниеЗначения.Фамилия Тогда
		ИзмениласьФамилия = Истина;
		Если Объект.Фамилия <> ОтправленныеДанные.Фамилия Тогда
			ИзменилисьОтправленныеДанные = Истина;
		КонецЕсли;
	КонецЕсли;
	
	ИзменилосьИмя = Ложь;
	Если Объект.Имя <> ПрежниеЗначения.Имя Тогда
		ИзменилосьИмя = Истина;
		Если Объект.Имя <> ОтправленныеДанные.Имя Тогда
			ИзменилисьОтправленныеДанные = Истина;
		КонецЕсли;
	КонецЕсли;
	
	ИзменилосьОтчество = Ложь;
	Если Объект.Отчество <> ПрежниеЗначения.Отчество Тогда
		ИзменилосьОтчество = Истина;
		Если Объект.Отчество <> ОтправленныеДанные.Отчество Тогда
			ИзменилисьОтправленныеДанные = Истина;
		КонецЕсли;
	КонецЕсли;
	
	ИзмениласьДатаРождения = Ложь;
	Если ОтправляемыеДанные.Найти("ДатаРождения") <> Неопределено Тогда
		Если Объект.ДатаРождения <> ПрежниеЗначения.ДатаРождения Тогда
			ИзменилисьОтправленныеДанные = Истина;
			Если Объект.ДатаРождения <> ОтправленныеДанные.ДатаРождения Тогда
				ИзмениласьДатаРождения = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ИзменилсяСНИЛС = Ложь;
	Если ОтправляемыеДанные.Найти("СтраховойНомерПФР") <> Неопределено Тогда
		Если Объект.СтраховойНомерПФР <> ПрежниеЗначения.СтраховойНомерПФР Тогда
			ИзменилисьОтправленныеДанные = Истина;
		 	Если Объект.СтраховойНомерПФР <> ОтправленныеДанные.СтраховойНомерПФР Тогда
				ИзменилсяСНИЛС = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ИзменилсяПол = Ложь;
	Если ОтправляемыеДанные.Найти("Пол") <> Неопределено Тогда
		Если Объект.Пол <> ПрежниеЗначения.Пол Тогда
			ИзменилисьОтправленныеДанные = Истина;
			Если Объект.Пол <> ОтправленныеДанные.Пол Тогда
				ИзменилсяПол = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ИзменилисьОтправленныеДанные Тогда
		НаборЗаписей = РегистрыСведений.ИзменениеОтправленныхДанныхЗастрахованных.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Организация.Установить(ТекущееСтрахование.Организация);
		НаборЗаписей.Отбор.СтраховаяКомпания.Установить(ТекущееСтрахование.СтраховаяКомпания);
		НаборЗаписей.Отбор.Застрахованный.Установить(Объект.Ссылка);
		НаборЗаписей.Прочитать();
		Если НаборЗаписей.Количество() = 0 Тогда
			Запись = НаборЗаписей.Добавить();
			Запись.Организация = ТекущееСтрахование.Организация;
			Запись.СтраховаяКомпания = ТекущееСтрахование.СтраховаяКомпания;
			Запись.Застрахованный = Объект.Ссылка;
		Иначе
			Запись = НаборЗаписей[0];
		КонецЕсли;
		
		Запись.ИзмениласьФамилия = ИзмениласьФамилия;
		Запись.Фамилия = ?(ИзмениласьФамилия = Истина, Объект.Фамилия, Неопределено);
		
		Запись.ИзменилосьИмя = ИзменилосьИмя;
		Запись.Имя = ?(ИзменилосьИмя = Истина, Объект.Имя, Неопределено);
		
		Запись.ИзменилосьОтчество = ИзменилосьОтчество;
		Запись.Отчество = ?(ИзменилосьОтчество = Истина, Объект.Отчество, Неопределено);
		
		Запись.ИзмениласьДатаРождения = ИзмениласьДатаРождения;
		Запись.ДатаРождения = ?(ИзмениласьДатаРождения = Истина, Объект.ДатаРождения, Неопределено);
		
		Запись.ИзменилсяСтраховойНомерПФР = ИзменилсяСНИЛС;
		Запись.СтраховойНомерПФР = ?(ИзменилсяСНИЛС = Истина, Объект.СтраховойНомерПФР, Неопределено);
		
		Запись.ИзменилсяПол = ИзменилсяПол;
		Запись.Пол = ?(ИзменилсяПол = Истина, Объект.Пол, Неопределено);

		УстановитьПривилегированныйРежим(Истина);
		НаборЗаписей.Записать();
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработатьИзменениеКонтактнойИнформацииФизическогоЛица(Объект, ТаблицаОтправленнаяКонтактнаяИнформация, ТекущееСтрахование)
	
	ПрежниеЗначения = Объект.ДополнительныеСвойства["ПрежниеЗначения"];
	ИзмененнаяКИ = Новый Массив;
	ВосстановленнаяКИ = Новый Массив;
	
	Для Каждого ОтправленнаяКонтактнаяИнформация Из ТаблицаОтправленнаяКонтактнаяИнформация Цикл
		Если ПрежниеЗначения.Свойство("ТаблицаКИ") Тогда
			ПрежниеЗначенияКонтактнойИнформации = ПрежниеЗначения.ТаблицаКИ;
			БылоПрежнееЗначениеКИ = Ложь;
			Для Каждого ПрежнееЗначениеСтруктура Из ПрежниеЗначенияКонтактнойИнформации Цикл
				Если ПрежнееЗначениеСтруктура.Вид = ОтправленнаяКонтактнаяИнформация.Вид Тогда
					БылоПрежнееЗначениеКИ = Истина;
					НовоеПредставление = УправлениеКонтактнойИнформацией.ПредставлениеКонтактнойИнформацииОбъекта(
						Объект, ОтправленнаяКонтактнаяИнформация.Вид);
					Если Не ЗначениеЗаполнено(НовоеПредставление) Тогда
						НовоеПредставление = "";
					КонецЕсли;
					Если ПрежнееЗначениеСтруктура.Представление <> НовоеПредставление Тогда
						Если НовоеПредставление = ОтправленнаяКонтактнаяИнформация.Представление Тогда
							ВосстановленнаяКИ.Добавить(Новый Структура("Вид, Представление", ОтправленнаяКонтактнаяИнформация.Вид, НовоеПредставление));
						Иначе
							ИзмененнаяКИ.Добавить(Новый Структура("Вид, Представление", ОтправленнаяКонтактнаяИнформация.Вид, НовоеПредставление));
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
			Если Не БылоПрежнееЗначениеКИ Тогда
				ДобавитьИзменениеКонтактнойИнформацииВМассив(Объект, ОтправленнаяКонтактнаяИнформация, ИзмененнаяКИ, ВосстановленнаяКИ);
			КонецЕсли;
		Иначе
			ДобавитьИзменениеКонтактнойИнформацииВМассив(Объект, ОтправленнаяКонтактнаяИнформация, ИзмененнаяКИ, ВосстановленнаяКИ);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого КИ Из ИзмененнаяКИ Цикл
		НаборЗаписей = РегистрыСведений.ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Организация.Установить(ТекущееСтрахование.Организация);
		НаборЗаписей.Отбор.СтраховаяКомпания.Установить(ТекущееСтрахование.СтраховаяКомпания);
		НаборЗаписей.Отбор.Застрахованный.Установить(Объект.Ссылка);
		НаборЗаписей.Отбор.Вид.Установить(КИ.Вид);
		
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Организация = ТекущееСтрахование.Организация;
		НоваяЗапись.СтраховаяКомпания = ТекущееСтрахование.СтраховаяКомпания;
		НоваяЗапись.Застрахованный = Объект.Ссылка;
		НоваяЗапись.Вид = КИ.Вид;
		НоваяЗапись.Представление = КИ.Представление;
		
		УстановитьПривилегированныйРежим(Истина);
		НаборЗаписей.Записать();
		УстановитьПривилегированныйРежим(Ложь);
	КонецЦикла;
	
	Для Каждого КИ Из ВосстановленнаяКИ Цикл
		НаборЗаписей = РегистрыСведений.ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Организация.Установить(ТекущееСтрахование.Организация);
		НаборЗаписей.Отбор.СтраховаяКомпания.Установить(ТекущееСтрахование.СтраховаяКомпания);
		НаборЗаписей.Отбор.Застрахованный.Установить(Объект.Ссылка);
		НаборЗаписей.Отбор.Вид.Установить(КИ.Вид);
		
		УстановитьПривилегированныйРежим(Истина);
		НаборЗаписей.Записать();
		УстановитьПривилегированныйРежим(Ложь);
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбработатьИзменениеДополнительныхРеквизитовИСведенийФизическогоЛица(Объект, ТаблицаОтправленныеДополнительныеРеквизитыИСведения, ТекущееСтрахование)

	ПрежниеЗначения = Объект.ДополнительныеСвойства["ПрежниеЗначения"];
	ИзмененныеСвойства = Новый Массив;
	ВосстановленныеСвойства = Новый Массив;
	
	Если ТаблицаОтправленныеДополнительныеРеквизитыИСведения.Количество() > 0 Тогда
		Для Каждого ОтправленноеСвойство Из ТаблицаОтправленныеДополнительныеРеквизитыИСведения Цикл
			Если ПрежниеЗначения.Свойство("ДополнительныеРеквизитыИСведения") Тогда
				ПрежниеЗначенияСвойств = ПрежниеЗначения.ДополнительныеРеквизитыИСведения;
				Для Каждого ПрежнееЗначениеСтруктура Из ПрежниеЗначенияСвойств Цикл
					Если ПрежнееЗначениеСтруктура.Свойство = ОтправленноеСвойство.Свойство Тогда
						НовоеЗначение = Объект.ДополнительныеРеквизиты.НайтиСтроки(Новый Структура("Свойство", ОтправленноеСвойство.Свойство));
						Если НовоеЗначение.Количество() > 0 Тогда
							НовоеЗначениеСвойства = НовоеЗначение[0].Значение;
						Иначе
							НовоеЗначениеСвойства = Неопределено;
						КонецЕсли;
						Если ПрежнееЗначениеСтруктура.Значение <> НовоеЗначениеСвойства Тогда
							Если НовоеЗначениеСвойства = ОтправленноеСвойство.Значение Тогда
								ВосстановленныеСвойства.Добавить(Новый Структура("Свойство, Значение", ОтправленноеСвойство.Свойство, НовоеЗначениеСвойства));
							Иначе
								ИзмененныеСвойства.Добавить(Новый Структура("Свойство, Значение", ОтправленноеСвойство.Свойство, НовоеЗначениеСвойства));
							КонецЕсли;
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
			Иначе
				НовоеЗначение = Объект.ДополнительныеРеквизиты.НайтиСтроки(Новый Структура("Свойство", ОтправленноеСвойство.Свойство));
				Если НовоеЗначение.Количество() > 0 Тогда
					НовоеЗначениеСвойства = НовоеЗначение[0].Значение;
				Иначе
					НовоеЗначениеСвойства = Неопределено;
				КонецЕсли;
				Если НовоеЗначениеСвойства <> Неопределено И НовоеЗначениеСвойства <> ОтправленноеСвойство.Значение Тогда
					ИзмененныеСвойства.Добавить(Новый Структура("Свойство, Значение", ОтправленноеСвойство.Свойство, НовоеЗначениеСвойства));
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Для Каждого ИзмененноеСвойство Из ИзмененныеСвойства Цикл
		НаборЗаписей = РегистрыСведений.ИзменениеОтправленныхДополнительныхРеквизитовИСведенийЗастрахованных.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Организация.Установить(ТекущееСтрахование.Организация);
		НаборЗаписей.Отбор.СтраховаяКомпания.Установить(ТекущееСтрахование.СтраховаяКомпания);
		НаборЗаписей.Отбор.Застрахованный.Установить(Объект.Ссылка);
		НаборЗаписей.Отбор.Свойство.Установить(ИзмененноеСвойство.Свойство);
		
		НоваяЗапись = НаборЗаписей.Добавить();
		НоваяЗапись.Организация = ТекущееСтрахование.Организация;
		НоваяЗапись.СтраховаяКомпания = ТекущееСтрахование.СтраховаяКомпания;
		НоваяЗапись.Застрахованный = Объект.Ссылка;
		НоваяЗапись.Свойство = ИзмененноеСвойство.Свойство;
		НоваяЗапись.Значение = ИзмененноеСвойство.Значение;
		
		УстановитьПривилегированныйРежим(Истина);
		НаборЗаписей.Записать();
		УстановитьПривилегированныйРежим(Ложь);
	КонецЦикла;

	Для Каждого ИзмененноеСвойство Из ВосстановленныеСвойства Цикл
		НаборЗаписей = РегистрыСведений.ИзменениеОтправленныхДополнительныхРеквизитовИСведенийЗастрахованных.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Организация.Установить(ТекущееСтрахование.Организация);
		НаборЗаписей.Отбор.СтраховаяКомпания.Установить(ТекущееСтрахование.СтраховаяКомпания);
		НаборЗаписей.Отбор.Застрахованный.Установить(Объект.Ссылка);
		НаборЗаписей.Отбор.Свойство.Установить(ИзмененноеСвойство.Свойство);
		
		УстановитьПривилегированныйРежим(Истина);
		НаборЗаписей.Записать();
		УстановитьПривилегированныйРежим(Ложь);
	КонецЦикла;

КонецПроцедуры

Процедура ОбработатьИзменениеОтправленныхДанныхРодственника(Объект, ОтправляемыеДанные, ОтправленныеДанные, ТекущееСтрахование)
	
	ПрежниеЗначения = Объект.ДополнительныеСвойства["ПрежниеЗначения"];
	ИзменилисьОтправленныеДанные = Ложь;
	
	ИзмениласьФамилия = Ложь;
	Если Объект.Фамилия <> ПрежниеЗначения.Фамилия Тогда
		ИзмениласьФамилия = Истина;
		Если Объект.Фамилия <> ОтправленныеДанные.Фамилия Тогда
			ИзменилисьОтправленныеДанные = Истина;
		КонецЕсли;
	КонецЕсли;
	
	ИзменилосьИмя = Ложь;
	Если Объект.Имя <> ПрежниеЗначения.Имя Тогда
		ИзменилосьИмя = Истина;
		Если Объект.Имя <> ОтправленныеДанные.Имя Тогда
			ИзменилисьОтправленныеДанные = Истина;
		КонецЕсли;
	КонецЕсли;
	
	ИзменилосьОтчество = Ложь;
	Если Объект.Отчество <> ПрежниеЗначения.Отчество Тогда
		ИзменилосьОтчество = Истина;
		Если Объект.Отчество <> ОтправленныеДанные.Отчество Тогда
			ИзменилисьОтправленныеДанные = Истина;
		КонецЕсли;
	КонецЕсли;
	
	ИзмениласьДатаРождения = Ложь;
	Если ОтправляемыеДанные.Найти("ДатаРождения") <> Неопределено Тогда
		Если Объект.ДатаРождения <> ПрежниеЗначения.ДатаРождения Тогда
			ИзменилисьОтправленныеДанные = Истина;
			Если Объект.ДатаРождения <> ОтправленныеДанные.ДатаРождения Тогда
				ИзмениласьДатаРождения = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ИзменилсяСНИЛС = Ложь;
	Если ОтправляемыеДанные.Найти("СтраховойНомерПФР") <> Неопределено Тогда
		Если Объект.СНИЛС <> ПрежниеЗначения.СНИЛС Тогда
			ИзменилисьОтправленныеДанные = Истина;
		 	Если Объект.СНИЛС <> ОтправленныеДанные.СтраховойНомерПФР Тогда
				ИзменилсяСНИЛС = Истина;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ИзменилисьОтправленныеДанные Тогда
		НаборЗаписей = РегистрыСведений.ИзменениеОтправленныхДанныхЗастрахованных.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Организация.Установить(ТекущееСтрахование.Организация);
		НаборЗаписей.Отбор.СтраховаяКомпания.Установить(ТекущееСтрахование.СтраховаяКомпания);
		НаборЗаписей.Отбор.Застрахованный.Установить(Объект.Ссылка);
		НаборЗаписей.Прочитать();
		Если НаборЗаписей.Количество() = 0 Тогда
			Запись = НаборЗаписей.Добавить();
			Запись.Организация = ТекущееСтрахование.Организация;
			Запись.СтраховаяКомпания = ТекущееСтрахование.СтраховаяКомпания;
			Запись.Застрахованный = Объект.Ссылка;
		Иначе
			Запись = НаборЗаписей[0];
		КонецЕсли;
		
		Запись.ИзмениласьФамилия = ИзмениласьФамилия;
		Запись.Фамилия = ?(ИзмениласьФамилия = Истина, Объект.Фамилия, Неопределено);
		
		Запись.ИзменилосьИмя = ИзменилосьИмя;
		Запись.Имя = ?(ИзменилосьИмя = Истина, Объект.Имя, Неопределено);
		
		Запись.ИзменилосьОтчество = ИзменилосьОтчество;
		Запись.Отчество = ?(ИзменилосьОтчество = Истина, Объект.Отчество, Неопределено);
		
		Запись.ИзмениласьДатаРождения = ИзмениласьДатаРождения;
		Запись.ДатаРождения = ?(ИзмениласьДатаРождения = Истина, Объект.ДатаРождения, Неопределено);
		
		Запись.ИзменилсяСтраховойНомерПФР = ИзменилсяСНИЛС;
		Запись.СтраховойНомерПФР = ?(ИзменилсяСНИЛС = Истина, Объект.СНИЛС, Неопределено);

		УстановитьПривилегированныйРежим(Истина);
		НаборЗаписей.Записать();
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
КонецПроцедуры

Функция ТекущиеСтрахованияРодственника(Родственник)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПрограммыМедицинскогоСтрахованияСотрудниковСрезПоследних.Организация КАК Организация,
		|	ПрограммыМедицинскогоСтрахованияСотрудниковСрезПоследних.ПрограммаСтрахования.СтраховаяКомпания КАК СтраховаяКомпания
		|ИЗ
		|	РегистрСведений.ПрограммыМедицинскогоСтрахованияСотрудников.СрезПоследних(, Родственник = &Родственник
		|	И Действует = ИСТИНА) КАК ПрограммыМедицинскогоСтрахованияСотрудниковСрезПоследних";
	Запрос.УстановитьПараметр("Родственник", Родственник);
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Функция СоставСведенийДокументаУдостоверяющегоЛичность()
	
	Сведения = Новый Массив;
	
	Сведения.Добавить("ДокументПредставление");
	Сведения.Добавить("ДокументВид");
	Сведения.Добавить("ДокументСерия");
	Сведения.Добавить("ДокументНомер");
	Сведения.Добавить("ДокументДатаВыдачи");
	Сведения.Добавить("ДокументКемВыдан");
	Сведения.Добавить("ДокументСрокДействия");
	Сведения.Добавить("ДокументКодПодразделения");
	
	Возврат Сведения;
	
КонецФункции

Функция ОтправляемаяКонтактнаяИнформацияВСтраховуюКомпанию(Организация, СтраховаяКомпания) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОтправляемаяКонтактнаяИнформацияЗастрахованных.Вид КАК Вид,
		|	ОтправляемаяКонтактнаяИнформацияЗастрахованных.СпособПроверкиЗаполнения КАК СпособПроверкиЗаполнения
		|ИЗ
		|	РегистрСведений.ОтправляемаяКонтактнаяИнформацияЗастрахованных КАК ОтправляемаяКонтактнаяИнформацияЗастрахованных
		|ГДЕ
		|	ОтправляемаяКонтактнаяИнформацияЗастрахованных.Организация = &Организация
		|	И ОтправляемаяКонтактнаяИнформацияЗастрахованных.СтраховаяКомпания = &СтраховаяКомпания
		|	И ОтправляемаяКонтактнаяИнформацияЗастрахованных.Отправлять = ИСТИНА";
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("СтраховаяКомпания", СтраховаяКомпания);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

