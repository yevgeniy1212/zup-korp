Процедура ПроверитьИзменениеДокументаУдостоверяющегоЛичность(Форма) Экспорт
	
	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьМедицинскоеСтрахованиеСотрудников") Тогда
		Возврат;
	КонецЕсли;
	
	Если Форма.СозданиеНового Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПрограммыМедицинскогоСтрахованияСотрудниковСрезПоследних.Организация КАК Организация,
		|	ПрограммыМедицинскогоСтрахованияСотрудниковСрезПоследних.ПрограммаСтрахования.СтраховаяКомпания КАК СтраховаяКомпания
		|ИЗ
		|	РегистрСведений.ПрограммыМедицинскогоСтрахованияСотрудников.СрезПоследних КАК ПрограммыМедицинскогоСтрахованияСотрудниковСрезПоследних
		|ГДЕ
		|	ПрограммыМедицинскогоСтрахованияСотрудниковСрезПоследних.Действует = ИСТИНА
		|	И ПрограммыМедицинскогоСтрахованияСотрудниковСрезПоследних.ДействуетДо >= &ТекущаяДата
		|	И ПрограммыМедицинскогоСтрахованияСотрудниковСрезПоследних.ФизическоеЛицо = &ФизическоеЛицо";
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	Запрос.УстановитьПараметр("ФизическоеЛицо", Форма.ФизическоеЛицоСсылка);
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеСтрахования = РезультатЗапроса.Выгрузить();
	Для Каждого ТекущееСтрахование Из ТекущиеСтрахования Цикл
		ОтправляемыеДанныеТаблица = ОтправляемыеДанныеВСтраховуюКомпанию(
			ТекущееСтрахование.Организация, ТекущееСтрахование.СтраховаяКомпания);
		ОтправляемыеДанные = ОтправляемыеДанныеТаблица.ВыгрузитьКолонку("Сведение");
		Если ОтправляемыеДанные.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		Если ОтправляемыеДанные.Найти("ДокументВид") = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ОтборСтруктура = Новый Структура("Организация, СтраховаяКомпания, Застрахованный",ТекущееСтрахование.Организация, ТекущееСтрахование.СтраховаяКомпания, Форма.ФизическоеЛицоСсылка);
		ТаблицаОтправленныеДанные = РегистрыСведений.ОтправленныеДанныеЗастрахованных.СрезПоследних(, ОтборСтруктура);
		Если ТаблицаОтправленныеДанные.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ОтправленныеДанные = ТаблицаОтправленныеДанные[0];
		
		Если Форма.ДокументыФизическихЛиц.ВидДокумента <> ОтправленныеДанные.ДокументВид Тогда
			Продолжить;
		КонецЕсли;
		
		ИзменилисьОтправленныеДанные = Ложь;
		ИзмениласьСерия = Ложь;
		Если Форма.ДокументыФизическихЛиц.Серия <> Форма.ДокументыФизическихЛицПрежняя.Серия И Форма.ДокументыФизическихЛиц.Серия <> ОтправленныеДанные.ДокументСерия Тогда
			ИзмениласьСерия = Истина;
			ИзменилисьОтправленныеДанные = Истина;
		КонецЕсли;
		
		ИзменилсяНомер = Ложь;
		Если Форма.ДокументыФизическихЛиц.Номер <> Форма.ДокументыФизическихЛицПрежняя.Номер И Форма.ДокументыФизическихЛиц.Номер <> ОтправленныеДанные.ДокументНомер Тогда
			ИзменилсяНомер = Истина;
			ИзменилисьОтправленныеДанные = Истина;
		КонецЕсли;
		
		ИзмениласьДатаВыдачи = Ложь;
		Если Форма.ДокументыФизическихЛиц.ДатаВыдачи <> Форма.ДокументыФизическихЛицПрежняя.ДатаВыдачи И Форма.ДокументыФизическихЛиц.ДатаВыдачи <> ОтправленныеДанные.ДокументДатаВыдачи Тогда
			ИзмениласьДатаВыдачи = Истина;
			ИзменилисьОтправленныеДанные = Истина;
		КонецЕсли;
		
		ИзменилсяСрокДействия = Ложь;
		Если Форма.ДокументыФизическихЛиц.СрокДействия <> Форма.ДокументыФизическихЛицПрежняя.СрокДействия И Форма.ДокументыФизическихЛиц.СрокДействия <> ОтправленныеДанные.ДокументСрокДействия Тогда
			ИзменилсяСрокДействия = Ложь;
			ИзменилисьОтправленныеДанные = Истина;
		КонецЕсли;
		
		ИзменилсяКемВыдан = Ложь;
		Если Форма.ДокументыФизическихЛиц.КемВыдан <> Форма.ДокументыФизическихЛицПрежняя.КемВыдан И Форма.ДокументыФизическихЛиц.КемВыдан <> ОтправленныеДанные.ДокументКемВыдан Тогда
			ИзменилсяКемВыдан = Истина;
			ИзменилисьОтправленныеДанные = Истина;
		КонецЕсли;
		
		ИзменилсяКодПодразделения = Ложь;
		Если Форма.ДокументыФизическихЛиц.КодПодразделения <> Форма.ДокументыФизическихЛицПрежняя.КодПодразделения И Форма.ДокументыФизическихЛиц.КодПодразделения <> ОтправленныеДанные.ДокументКодПодразделения Тогда
			ИзменилсяКодПодразделения = Истина;
			ИзменилисьОтправленныеДанные = Истина;
		КонецЕсли;
		
		Если Не ИзменилисьОтправленныеДанные Тогда
			Продолжить;
		КонецЕсли;
		
		НаборЗаписей = РегистрыСведений.ИзменениеОтправленныхДанныхЗастрахованных.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Организация.Установить(ТекущееСтрахование.Организация);
		НаборЗаписей.Отбор.СтраховаяКомпания.Установить(ТекущееСтрахование.СтраховаяКомпания);
		НаборЗаписей.Отбор.Застрахованный.Установить(Форма.ФизическоеЛицоСсылка);
		НаборЗаписей.Прочитать();
		Если НаборЗаписей.Количество() = 0 Тогда
			Запись = НаборЗаписей.Добавить();
			Запись.Организация = ТекущееСтрахование.Организация;
			Запись.СтраховаяКомпания = ТекущееСтрахование.СтраховаяКомпания;
			Запись.Застрахованный = Форма.ФизическоеЛицоСсылка;
		Иначе
			Запись = НаборЗаписей[0];
		КонецЕсли;
		
		Если ИзмениласьСерия  Тогда
			Запись.ДокументСерия = Форма.ДокументыФизическихЛиц.Серия;
		КонецЕсли;
		Если ИзменилсяНомер  Тогда
			Запись.ДокументНомер = Форма.ДокументыФизическихЛиц.Номер;
		КонецЕсли;
		Если ИзмениласьДатаВыдачи  Тогда
			Запись.ДокументДатаВыдачи = Форма.ДокументыФизическихЛиц.ДатаВыдачи;
		КонецЕсли;
		Если ИзменилсяСрокДействия  Тогда
			Запись.ДокументСрокДействия = Форма.Форма.ДокументыФизическихЛиц.СрокДействия;
		КонецЕсли;
		Если ИзменилсяКемВыдан  Тогда
			Запись.ДокументКемВыдан = Форма.ДокументыФизическихЛиц.КемВыдан;
		КонецЕсли;
		Если ИзменилсяКодПодразделения  Тогда
			Запись.ДокументКодПодразделения = Форма.ДокументыФизическихЛиц.КодПодразделения;
		КонецЕсли;
		
		УстановитьПривилегированныйРежим(Истина);
		НаборЗаписей.Записать();
		УстановитьПривилегированныйРежим(Ложь);
	КонецЦикла;
	
КонецПроцедуры

Функция ОтправляемыеДанныеВСтраховуюКомпанию(Организация, СтраховаяКомпания) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОтправляемыеДанныеЗастрахованных.Сведение КАК Сведение,
		|	ОтправляемыеДанныеЗастрахованных.СпособПроверкиЗаполнения КАК СпособПроверкиЗаполнения
		|ИЗ
		|	РегистрСведений.ОтправляемыеДанныеЗастрахованных КАК ОтправляемыеДанныеЗастрахованных
		|ГДЕ
		|	ОтправляемыеДанныеЗастрахованных.Организация = &Организация
		|	И ОтправляемыеДанныеЗастрахованных.СтраховаяКомпания = &СтраховаяКомпания
		|	И ОтправляемыеДанныеЗастрахованных.Отправлять = ИСТИНА";
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("СтраховаяКомпания", СтраховаяКомпания);
	ОтправляемыеДанные = Новый ТаблицаЗначений;
	ОтправляемыеДанные.Колонки.Добавить("Сведение", Новый ОписаниеТипов("Строка"));
	ОтправляемыеДанные.Колонки.Добавить("СпособПроверкиЗаполнения", Новый ОписаниеТипов("ПеречислениеСсылка.СпособыПроверкиЗаполненияПерсональныхДанныхМедицинскогоСтрахования"));
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка.Сведение = Перечисления.ДанныеЗастрахованных.ДокументУдостоверяющийЛичность Тогда
			СведенияДокументаУдостоверяющегоЛичность = СоставСведенийДокументаУдостоверяющегоЛичность();
			Для Каждого  Сведение Из СведенияДокументаУдостоверяющегоЛичность Цикл
				НоваяСтрока = ОтправляемыеДанные.Добавить();
				НоваяСтрока.Сведение = Сведение;
				НоваяСтрока.СпособПроверкиЗаполнения = Выборка.СпособПроверкиЗаполнения;
			КонецЦикла;
		Иначе
			ИндексЗначения = Перечисления.ДанныеЗастрахованных.Индекс(Выборка.Сведение);
			НоваяСтрока = ОтправляемыеДанные.Добавить();
			НоваяСтрока.Сведение = Метаданные.Перечисления.ДанныеЗастрахованных.ЗначенияПеречисления[ИндексЗначения].Имя;
			НоваяСтрока.СпособПроверкиЗаполнения = Выборка.СпособПроверкиЗаполнения;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ОтправляемыеДанные;
	
КонецФункции

Функция ТекущиеСтрахованияФизическогоЛица(ФизическоеЛицо) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПрограммыМедицинскогоСтрахованияСотрудниковСрезПоследних.Организация КАК Организация,
		|	ПрограммыМедицинскогоСтрахованияСотрудниковСрезПоследних.ПрограммаСтрахования.СтраховаяКомпания КАК СтраховаяКомпания
		|ИЗ
		|	РегистрСведений.ПрограммыМедицинскогоСтрахованияСотрудников.СрезПоследних(, ФизическоеЛицо = &ФизическоеЛицо
		|	И Действует = ИСТИНА) КАК ПрограммыМедицинскогоСтрахованияСотрудниковСрезПоследних";
	Запрос.УстановитьПараметр("ФизическоеЛицо", ФизическоеЛицо);
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// СтандартныеПодсистемы.УчетОригиналовПервичныхДокументов

// См. УчетОригиналовПервичныхДокументовПереопределяемый.ПриОпределенииОбъектовСКомандамиУчетаОригиналов.
Процедура ПриОпределенииОбъектовСКомандамиУчетаОригиналов(СписокОбъектов) Экспорт
	
	// Формы списков журналов документов
	СписокОбъектов.Добавить("ЖурналДокументов.МедицинскоеСтрахование.Форма.ФормаСписка");
	
	// Формы списков документов
	СписокОбъектов.Добавить("Документ.ПрикреплениеКПрограммамМедицинскогоСтрахования.Форма.ФормаСписка");
	
КонецПроцедуры

// См. УчетОригиналовПервичныхДокументовПереопределяемый.ПриОпределенииМногосотрудниковыхДокументов.
Процедура ПриОпределенииМногосотрудниковыхДокументов(СписокОбъектов) Экспорт
	
	СписокОбъектов.Вставить(Метаданные.Документы.ПрикреплениеКПрограммамМедицинскогоСтрахования.ПолноеИмя(), "Сотрудники");
	
КонецПроцедуры

// См. УчетОригиналовПервичныхДокументовПереопределяемый.ЗаполнитьТаблицуУчетаОригиналов.
Процедура ЗаполнитьТаблицуУчетаОригиналов(ТаблицаУчетаОригиналов) Экспорт
	
	// Прикрепление к программам страхования
	НоваяСтрока = ТаблицаУчетаОригиналов.Добавить();
	НоваяСтрока.ОбъектМетаданных = Метаданные.Документы.ПрикреплениеКПрограммамМедицинскогоСтрахования;
	НоваяСтрока.Идентификатор = "ЗаявлениеНаУдержание";
	
КонецПроцедуры

// Конец СтандартныеПодсистемы.УчетОригиналовПервичныхДокументов

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ПараметрыОтправкиПисьма

Функция ТабличныйДокументПоНастройкеПечатнойФормы(НастройкаПечатнойФормы)
	
	МассивОбъектов = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(НастройкаПечатнойФормы.СсылкаДокумента);
	
	ПараметрыПечати = НастройкаПечатнойФормы.ДополнительныеПараметры;
	ДанныеПечати = УправлениеПечатью.СформироватьПечатныеФормы(
		НастройкаПечатнойФормы.СсылкаДокумента.Метаданные().ПолноеИмя(),
		НастройкаПечатнойФормы.ИмяМакета, МассивОбъектов, ПараметрыПечати);
	КоллекцияПечатныхФорм = ДанныеПечати.КоллекцияПечатныхФорм;
	ОбъектыПечати = ДанныеПечати.ОбъектыПечати;
	ПараметрыВывода = ДанныеПечати.ПараметрыВывода;
	
	ПечатнаяФорма = Новый ТабличныйДокумент;
	Если НастройкаПечатнойФормы.ПолноеИмяОбъекта = "СтандартныеПодсистемы.ДополнительныеОтчетыИОбработки" Тогда
		ПараметрыИсточника = Новый Структура;
		ПараметрыИсточника.Вставить("ИдентификаторКоманды", НастройкаПечатнойФормы.ИмяМакета);
		ПараметрыИсточника.Вставить("ОбъектыНазначения", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(НастройкаПечатнойФормы.СсылкаДокумента));
		УправлениеПечатью.ПечатьПоВнешнемуИсточнику(
			НастройкаПечатнойФормы.ДополнительныеПараметры.Ссылка, ПараметрыИсточника, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода);
	Иначе
		МенеджерОбъекта = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(НастройкаПечатнойФормы.ПолноеИмяОбъекта);
		МенеджерОбъекта.Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода);
	КонецЕсли;
	Для Каждого ЭлементКоллекции Из КоллекцияПечатныхФорм Цикл
		НастройкаПечатнойФормы.ТабличныйДокумент = ЭлементКоллекции.ТабличныйДокумент;
		ПечатнаяФорма = ЭлементКоллекции.ТабличныйДокумент;
	КонецЦикла;
	
	Возврат ПечатнаяФорма;
	
КонецФункции

Функция ПоместитьТабличныеДокументыВоВременноеХранилище(Форма, ПереданныеНастройки, НастройкиПечатныхФорм)
	Перем ЗаписьZipФайла, ИмяАрхива;
	
	НастройкиСохранения = НастройкиСохранения();
	ЗаполнитьЗначенияСвойств(НастройкиСохранения, ПереданныеНастройки);
	
	Результат = Новый Массив;
	
	// подготовка архива
	Если НастройкиСохранения.УпаковатьВАрхив Тогда
		ИмяАрхива = ПолучитьИмяВременногоФайла("zip");
		ЗаписьZipФайла = Новый ЗаписьZipФайла(ИмяАрхива);
	КонецЕсли;
	
	// подготовка временной папки
	ИмяВременнойПапки = ПолучитьИмяВременногоФайла();
	СоздатьКаталог(ИмяВременнойПапки);
	ИспользованныеИменаФайлов = Новый Соответствие;
	
	ВыбранныеФорматыСохранения = НастройкиСохранения.ФорматыСохранения;
	ПереводитьИменаФайловВТранслит = НастройкиСохранения.ПереводитьИменаФайловВТранслит;
	ТаблицаФорматов = УправлениеПечатью.НастройкиФорматовСохраненияТабличногоДокумента();
	
	// сохранение печатных форм
	ОбработанныеПечатныеФормы = Новый Массив;
	Для Каждого НастройкаПечатнойФормы Из НастройкиПечатныхФорм Цикл
		
		Если Не НастройкаПечатнойФормы.Печатать Тогда
			Продолжить;
		КонецЕсли;
		
		Если НастройкаПечатнойФормы.ТабличныйДокумент = Неопределено Тогда
			ПечатнаяФорма = ТабличныйДокументПоНастройкеПечатнойФормы(НастройкаПечатнойФормы);
		Иначе
			ПечатнаяФорма = НастройкаПечатнойФормы.ТабличныйДокумент;
		КонецЕсли;
		Если ОбработанныеПечатныеФормы.Найти(ПечатнаяФорма) = Неопределено Тогда
			ОбработанныеПечатныеФормы.Добавить(ПечатнаяФорма);
		Иначе
			Продолжить;
		КонецЕсли;
		
		Если ВычислитьИспользованиеВывода(ПечатнаяФорма) = ИспользованиеВывода.Запретить Тогда
			Продолжить;
		КонецЕсли;
		
		Если ПечатнаяФорма.Защита Тогда
			Продолжить;
		КонецЕсли;
		
		Если ПечатнаяФорма.ВысотаТаблицы = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ПечатныеФормыПоОбъектам = Новый Соответствие;
		ПечатныеФормыПоОбъектам.Вставить(Форма.Объект.Ссылка, ПечатнаяФорма);
		Для Каждого СоответствиеОбъектаПечатнойФорме Из ПечатныеФормыПоОбъектам Цикл
			ОбъектПечати = СоответствиеОбъектаПечатнойФорме.Ключ;
			ПечатнаяФорма = СоответствиеОбъектаПечатнойФорме.Значение;
			
			Для Каждого ВыбранныйФормат Из ВыбранныеФорматыСохранения Цикл
				ТипФайла = ТипФайлаТабличногоДокумента[ВыбранныйФормат];
				НастройкиФормата = ТаблицаФорматов.НайтиСтроки(Новый Структура("ТипФайлаТабличногоДокумента", ТипФайла))[0];
				ЗаданныеИменаПечатныхФорм = ОбщегоНазначения.ЗначениеИзСтрокиXML(НастройкаПечатнойФормы.ИмяФайлаПечатнойФормы);
				
				ИмяФайла = УправлениеПечатью.ИмяФайлаПечатнойФормыОбъекта(ОбъектПечати, ЗаданныеИменаПечатныхФорм, НастройкаПечатнойФормы.Название);
				ИмяФайла = ОбщегоНазначенияКлиентСервер.ЗаменитьНедопустимыеСимволыВИмениФайла(ИмяФайла);
				
				Если ПереводитьИменаФайловВТранслит Тогда
					ИмяФайла = СтроковыеФункции.СтрокаЛатиницей(ИмяФайла);
				КонецЕсли;
				
				ИмяФайла = ИмяФайла + "." + НастройкиФормата.Расширение;
				
				ПолноеИмяФайла = УникальноеИмяФайла(ОбщегоНазначенияКлиентСервер.ДобавитьКонечныйРазделительПути(ИмяВременнойПапки) + ИмяФайла);
				ПечатнаяФорма.Записать(ПолноеИмяФайла, ТипФайла);
				
				Если ТипФайла = ТипФайлаТабличногоДокумента.HTML Тогда
					УправлениеПечатью.ВставитьКартинкиВHTML(ПолноеИмяФайла);
				КонецЕсли;
				
				Если ЗаписьZipФайла <> Неопределено Тогда 
					ЗаписьZipФайла.Добавить(ПолноеИмяФайла);
				Иначе
					ДвоичныеДанные = Новый ДвоичныеДанные(ПолноеИмяФайла);
					ПутьВоВременномХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанные, Форма.УникальныйИдентификатор);
					ОписаниеФайла = Новый Структура;
					ОписаниеФайла.Вставить("Представление", ИмяФайла);
					ОписаниеФайла.Вставить("АдресВоВременномХранилище", ПутьВоВременномХранилище);
					Если ТипФайла = ТипФайлаТабличногоДокумента.ANSITXT Тогда
						ОписаниеФайла.Вставить("Кодировка", "windows-1251");
					КонецЕсли;
					Результат.Добавить(ОписаниеФайла);
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	// Если архив подготовлен, записываем и помещаем его во временное хранилище.
	Если ЗаписьZipФайла <> Неопределено Тогда 
		ЗаписьZipФайла.Записать();
		ФайлАрхива = Новый Файл(ИмяАрхива);
		ДвоичныеДанные = Новый ДвоичныеДанные(ИмяАрхива);
		ПутьВоВременномХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанные, Форма.УникальныйИдентификатор);
		ОписаниеФайла = Новый Структура;
		ОписаниеФайла.Вставить("Представление", ПолучитьИмяФайлаДляАрхива(Форма, НастройкиПечатныхФорм, ПереводитьИменаФайловВТранслит));
		ОписаниеФайла.Вставить("АдресВоВременномХранилище", ПутьВоВременномХранилище);
		Результат.Добавить(ОписаниеФайла);
	КонецЕсли;
	
	УдалитьФайлы(ИмяВременнойПапки);
	Если ЗначениеЗаполнено(ИмяАрхива) Тогда
		УдалитьФайлы(ИмяАрхива);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция НастройкиСохранения()
	
	НастройкиСохранения = Новый Структура;
	НастройкиСохранения.Вставить("ФорматыСохранения", Новый Массив);
	НастройкиСохранения.Вставить("УпаковатьВАрхив", Ложь);
	НастройкиСохранения.Вставить("ПереводитьИменаФайловВТранслит", Ложь);
	
	Возврат НастройкиСохранения;
	
КонецФункции

Функция ВычислитьИспользованиеВывода(ТабличныйДокумент)
	Если ТабличныйДокумент.Вывод = ИспользованиеВывода.Авто Тогда
		Возврат ?(ПравоДоступа("Вывод", Метаданные), ИспользованиеВывода.Разрешить, ИспользованиеВывода.Запретить);
	Иначе
		Возврат ТабличныйДокумент.Вывод;
	КонецЕсли;
КонецФункции

Функция УникальноеИмяФайла(ИмяФайла)
	
	Файл = Новый Файл(ИмяФайла);
	ИмяБезРасширения = Файл.ИмяБезРасширения;
	Расширение = Файл.Расширение;
	Папка = Файл.Путь;
	
	Счетчик = 1;
	Пока Файл.Существует() Цикл
		Счетчик = Счетчик + 1;
		Файл = Новый Файл(Папка + ИмяБезРасширения + " (" + Счетчик + ")" + Расширение);
	КонецЦикла;
	
	Возврат Файл.ПолноеИмя;

КонецФункции

Функция ПолучитьИмяФайлаДляАрхива(Форма, НастройкиПечатныхФорм, ПереводитьИменаФайловВТранслит)
	
	Результат = "";
	
	Для Каждого НастройкаПечатнойФормы Из НастройкиПечатныхФорм Цикл
		
		Если Не НастройкаПечатнойФормы.Печатать Тогда
			Продолжить;
		КонецЕсли;
		
		Если НастройкаПечатнойФормы.ТабличныйДокумент = Неопределено Тогда
			ПечатнаяФорма = ТабличныйДокументПоНастройкеПечатнойФормы(НастройкаПечатнойФормы);
		Иначе
			ПечатнаяФорма = НастройкаПечатнойФормы.ТабличныйДокумент;
		КонецЕсли;
		
		Если ВычислитьИспользованиеВывода(ПечатнаяФорма) = ИспользованиеВывода.Запретить Тогда
			Продолжить;
		КонецЕсли;
		
		Если ПустаяСтрока(Результат) Тогда
			Результат = НастройкаПечатнойФормы.Название;
		Иначе
			Результат = НСтр("ru = 'Документы'");
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если ПереводитьИменаФайловВТранслит Тогда
		Результат = СтроковыеФункции.СтрокаЛатиницей(Результат);
	КонецЕсли;
	
	Возврат Результат + ".zip";
	
КонецФункции

#КонецОбласти

