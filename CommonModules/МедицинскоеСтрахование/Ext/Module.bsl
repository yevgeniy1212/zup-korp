Процедура ЗаполнитьОтправляемыеДанныеЗастрахованных(ПараметрыОбновления) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	УсловияМедицинскогоСтрахования.Организация КАК Организация,
		|	УсловияМедицинскогоСтрахования.СтраховаяКомпания КАК СтраховаяКомпания
		|ИЗ
		|	РегистрСведений.УсловияМедицинскогоСтрахования КАК УсловияМедицинскогоСтрахования
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОтправляемыеДанныеЗастрахованных КАК ОтправляемыеДанныеЗастрахованных
		|		ПО (УсловияМедицинскогоСтрахования.Организация = ОтправляемыеДанныеЗастрахованных.Организация)
		|		И (УсловияМедицинскогоСтрахования.СтраховаяКомпания = ОтправляемыеДанныеЗастрахованных.СтраховаяКомпания)
		|ГДЕ
		|	ОтправляемыеДанныеЗастрахованных.Организация ЕСТЬ NULL";
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
		Возврат;
	КонецЕсли;
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Ложь);
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		НаборЗаписей = РегистрыСведений.ОтправляемыеДанныеЗастрахованных.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Организация.Установить(Выборка.Организация);
		НаборЗаписей.Отбор.СтраховаяКомпания.Установить(Выборка.СтраховаяКомпания);
		Для Каждого Сведение Из Перечисления.ДанныеЗастрахованных Цикл
			ЗаписьНабора = НаборЗаписей.Добавить();
			ЗаполнитьЗначенияСвойств(ЗаписьНабора, Выборка);
			ЗаписьНабора.Сведение = Сведение;
			ЗаписьНабора.Отправлять = Истина;
			ЗаписьНабора.СпособПроверкиЗаполнения = Перечисления.СпособыПроверкиЗаполненияПерсональныхДанныхМедицинскогоСтрахования.НеПроверять;
		КонецЦикла;
		ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьОтправляемуюКонтактнуюИнформациюЗастрахованных(ПараметрыОбновления) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	УсловияМедицинскогоСтрахования.Организация КАК Организация,
		|	УсловияМедицинскогоСтрахования.СтраховаяКомпания КАК СтраховаяКомпания
		|ИЗ
		|	РегистрСведений.УсловияМедицинскогоСтрахования КАК УсловияМедицинскогоСтрахования
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОтправляемаяКонтактнаяИнформацияЗастрахованных КАК ОтправляемаяКонтактнаяИнформацияЗастрахованных
		|		ПО УсловияМедицинскогоСтрахования.Организация = ОтправляемаяКонтактнаяИнформацияЗастрахованных.Организация
		|			И УсловияМедицинскогоСтрахования.СтраховаяКомпания = ОтправляемаяКонтактнаяИнформацияЗастрахованных.СтраховаяКомпания
		|ГДЕ
		|	ОтправляемаяКонтактнаяИнформацияЗастрахованных.Организация ЕСТЬ NULL";
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
		Возврат;
	КонецЕсли;
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Ложь);
	МассивОтправляемойКИ = Новый Массив;
	МассивОтправляемойКИ.Добавить(Справочники.ВидыКонтактнойИнформации.АдресДляИнформированияФизическиеЛица);
	МассивОтправляемойКИ.Добавить(Справочники.ВидыКонтактнойИнформации.ТелефонДомашнийФизическиеЛица);
	МассивОтправляемойКИ.Добавить(Справочники.ВидыКонтактнойИнформации.ТелефонМобильныйФизическиеЛица);
	МассивОтправляемойКИ.Добавить(Справочники.ВидыКонтактнойИнформации.EMailФизическиеЛица);
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		НаборЗаписей = РегистрыСведений.ОтправляемаяКонтактнаяИнформацияЗастрахованных.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Организация.Установить(Выборка.Организация);
		НаборЗаписей.Отбор.СтраховаяКомпания.Установить(Выборка.СтраховаяКомпания);
		Для Каждого КИ Из МассивОтправляемойКИ Цикл
			ЗаписьНабора = НаборЗаписей.Добавить();
			ЗаполнитьЗначенияСвойств(ЗаписьНабора, Выборка);
			ЗаписьНабора.Вид = КИ;
			ЗаписьНабора.Отправлять = Истина;
			ЗаписьНабора.СпособПроверкиЗаполнения = Перечисления.СпособыПроверкиЗаполненияПерсональныхДанныхМедицинскогоСтрахования.НеПроверять;
		КонецЦикла;
		ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
	КонецЦикла;
	
КонецПроцедуры

