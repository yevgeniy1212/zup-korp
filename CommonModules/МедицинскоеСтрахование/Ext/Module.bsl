Процедура ДобавитьИзменениеКонтактнойИнформацииВМассив(Объект, ОтправленнаяКонтактнаяИнформация, ИзмененнаяКИ, ВосстановленнаяКИ)
	
	НовоеПредставление = УправлениеКонтактнойИнформацией.ПредставлениеКонтактнойИнформацииОбъекта(
		Объект, ОтправленнаяКонтактнаяИнформация.Вид);
	Если Не ЗначениеЗаполнено(НовоеПредставление) Тогда
		НовоеПредставление = "";
	КонецЕсли;
	Если НовоеПредставление = ОтправленнаяКонтактнаяИнформация.Представление Тогда
		ВосстановленнаяКИ.Добавить(Новый Структура("Вид, Представление", ОтправленнаяКонтактнаяИнформация.Вид, НовоеПредставление));
	Иначе
		ИзмененнаяКИ.Добавить(Новый Структура("Вид, Представление", ОтправленнаяКонтактнаяИнформация.Вид, НовоеПредставление));
	КонецЕсли;
	
КонецПроцедуры

