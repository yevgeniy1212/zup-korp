// Возвращает индексированную таблицу физических лиц с общими сроками работы в компании.
// 
// Параметры:
//  ФизическиеЛица - Массив - Список физических лиц.
// 
// Возвращаемое значение:
//  Неопределено, ТаблицаЗначений - Отработано лет в компании с индексом по колонке ФизическоеЛицо:
// * ФизическоеЛицо - СправочникСсылка.ФизическиеЛица - Физическое лицо.
// * ОтработаноЛет - Число - Общий срок работы в компании.
// * ДатаНачалаРаботы - Дата - Дата отсчета по отаботке лет.
Функция ОтработаноЛетВКомпании(ФизическиеЛица)
	
	Если Не ЗначениеЗаполнено(ФизическиеЛица) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ФизическиеЛица", ФизическиеЛица);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	Запрос.Текст =
		"ВЫБРАТЬ
		|	СотрудникиОрганизации.ФизическоеЛицо КАК ФизическоеЛицо,
		|	СотрудникиОрганизации.ДатаПриема КАК ДатаНачалаРаботы,
		|	ВЫБОР
		|		КОГДА СотрудникиОрганизации.ДатаУвольнения = ДАТАВРЕМЯ(1, 1, 1)
		|			ТОГДА &ТекущаяДата
		|		ИНАЧЕ СотрудникиОрганизации.ДатаУвольнения
		|	КОНЕЦ КАК ДатаОкончанияРаботы
		|ИЗ
		|	ВТСотрудникиОрганизации КАК СотрудникиОрганизации
		|ГДЕ
		|	СотрудникиОрганизации.ФизическоеЛицо В (&ФизическиеЛица)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ФизическоеЛицо,
		|	ДатаНачалаРаботы УБЫВ";
	
	ПараметрыПолучения = КадровыйУчет.ПараметрыПолученияСотрудниковОрганизацийПоСпискуФизическихЛиц();
	ПараметрыПолучения.КадровыеДанные = "ДатаПриема, ДатаУвольнения";
	КадровыйУчет.СоздатьВТСотрудникиОрганизации(Запрос.МенеджерВременныхТаблиц, Ложь, ПараметрыПолучения);
	
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ОтработаноЛетВКомпании = Новый ТаблицаЗначений;
	ОтработаноЛетВКомпании.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	ОтработаноЛетВКомпании.Колонки.Добавить("ОтработаноЛет", Новый ОписаниеТипов("Число"));
	ОтработаноЛетВКомпании.Колонки.Добавить("ДатаНачалаРаботы", Новый ОписаниеТипов("Дата"));
	
	Обход = Обработки.ОбходКоллекции.НовыйОбход(Результат.Выгрузить());
	Пока Обход.СледующийПоЗначениюПоля("ФизическоеЛицо") Цикл
		ДатаНачалаРаботы = Дата(1, 1, 1);
		СтрокаОтработаноЛет = ОтработаноЛетВКомпании.Добавить();
		СтрокаОтработаноЛет.ФизическоеЛицо = Обход.ТекущиеДанные().ФизическоеЛицо;
		Пока Обход.Следующий() Цикл
			ТекущиеДанные = Обход.ТекущиеДанные();
			Если Не ЗначениеЗаполнено(ДатаНачалаРаботы) Тогда
				ДатаНачалаРаботы = ТекущиеДанные.ДатаНачалаРаботы;
				ДатаОкончанияРаботы = ТекущиеДанные.ДатаОкончанияРаботы;
				Продолжить;
			КонецЕсли;
			Если ДатаНачалаРаботы <= ТекущиеДанные.ДатаОкончанияРаботы
				Или НастройкиУправленияПерсоналом.ДопустимыйПерерывРаботы(ДатаНачалаРаботы, ТекущиеДанные.ДатаОкончанияРаботы) Тогда
				ДатаНачалаРаботы = ТекущиеДанные.ДатаНачалаРаботы;
			Иначе
				Прервать;
			КонецЕсли;
			Если ДатаОкончанияРаботы < ТекущиеДанные.ДатаОкончанияРаботы Тогда
				ДатаОкончанияРаботы = ТекущиеДанные.ДатаОкончанияРаботы;
			КонецЕсли;
		КонецЦикла;
		СтрокаОтработаноЛет.ДатаНачалаРаботы = ДатаНачалаРаботы;
		СтрокаОтработаноЛет.ОтработаноЛет = Год(ДатаОкончанияРаботы) - Год(ДатаНачалаРаботы)
			+ ?(Дата(Год(ДатаОкончанияРаботы), Месяц(ДатаНачалаРаботы), День(ДатаНачалаРаботы))
			> НачалоДня(ДатаОкончанияРаботы), -1, 0);
	КонецЦикла;
	ОбщегоНазначенияБЗК.ДобавитьИндексКоллекции(ОтработаноЛетВКомпании, "ФизическоеЛицо");
	
	Возврат ОтработаноЛетВКомпании;
	
КонецФункции

Функция ДатаСобытияВПериоде(НачалоПериода, ОкончаниеПериода, ДеньМесяца, НомерМесяца)
	
	ГодНачало = Год(НачалоПериода);
	ГодОкончание = Год(ОкончаниеПериода);
	
	Если ГодНачало = ГодОкончание Тогда
		ДатаСобытия = Дата(ГодНачало, НомерМесяца, ДеньМесяца);
		Если ДатаСобытия >= НачалоПериода И ДатаСобытия <= ОкончаниеПериода Тогда
			Возврат ДатаСобытия;
		КонецЕсли;
	Иначе
		ДатаСобытия = Дата(ГодНачало, НомерМесяца, ДеньМесяца);
		Если ДатаСобытия >= НачалоПериода И ДатаСобытия <= КонецГода(НачалоПериода) Тогда
			Возврат ДатаСобытия;
		КонецЕсли;
		ДатаСобытия = Дата(ГодНачало + 1, НомерМесяца, ДеньМесяца);
		Если ДатаСобытия >= КонецГода(НачалоПериода) + 1 И ДатаСобытия <= ОкончаниеПериода Тогда
			Возврат ДатаСобытия;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция ЗначениеОтбораВСтроку(ЗначениеОтбора)
	
	Результат = ЗначениеОтбора;
	
	Если ТипЗнч(Результат) = Тип("СписокЗначений") Тогда
		Результат = Результат.ВыгрузитьЗначения();
		Результат = СтрСоединить(Результат, ",");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОбращениеКФизическомуЛицу(Пол)
	
	Если Пол = Перечисления.ПолФизическогоЛица.Мужской Тогда
		Обращение = НСтр("ru = 'Уважаемый'");
	ИначеЕсли Пол = Перечисления.ПолФизическогоЛица.Женский Тогда
		Обращение = НСтр("ru = 'Уважаемая'");
	Иначе
		// АПК:1036-выкл: сокращения
		Обращение = НСтр("ru = 'Уважаемый(ая)'");
		// АПК:1036-вкл
	КонецЕсли;
	
	Возврат Обращение;
	
КонецФункции

