Процедура ПриказОбАттестацииСотрудниковПослеЗагрузки(Объект, Отказ) Экспорт
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	СотрудникиДокумента = Объект.Сотрудники.Выгрузить(,"Сотрудник").ВыгрузитьКолонку("Сотрудник");
	КадровыеДанныеСотрудников = КадровыйУчет.КадровыеДанныеСотрудников(Истина, СотрудникиДокумента,
		"Должность,Подразделение", Объект.Дата);
	ОбщегоНазначенияБЗК.ДобавитьИндексКоллекции(КадровыеДанныеСотрудников, "Сотрудник");
	
	Для Каждого СтрокаДокумента Из Объект.Сотрудники Цикл
		СтруктураОтбора = Новый Структура("Сотрудник", СтрокаДокумента.Сотрудник);
		НайденныеСтроки = КадровыеДанныеСотрудников.НайтиСтроки(СтруктураОтбора);
		Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
			СтрокаДокумента.Подразделение = НайденнаяСтрока.Подразделение;
			СтрокаДокумента.Должность = НайденнаяСтрока.Должность;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Процедура РезультатыАттестацииСотрудниковПослеЗагрузки(Объект, Отказ) Экспорт
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	СотрудникиДокумента = Объект.РезультатыАттестации.Выгрузить(,"Сотрудник").ВыгрузитьКолонку("Сотрудник");
	КадровыеДанныеСотрудников = КадровыйУчет.КадровыеДанныеСотрудников(Истина, СотрудникиДокумента, "Должность",
		Объект.Дата);
	ОбщегоНазначенияБЗК.ДобавитьИндексКоллекции(КадровыеДанныеСотрудников, "Сотрудник");
	
	Для Каждого СтрокаДокумента Из Объект.РезультатыАттестации Цикл
		СтруктураОтбора = Новый Структура("Сотрудник", СтрокаДокумента.Сотрудник);
		НайденныеСтроки = КадровыеДанныеСотрудников.НайтиСтроки(СтруктураОтбора);
		Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
			СтрокаДокумента.Должность = НайденнаяСтрока.Должность;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

