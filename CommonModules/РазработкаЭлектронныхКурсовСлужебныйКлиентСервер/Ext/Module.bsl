Процедура УдалитьСлайдВПрезентацииImpress(ПутьКПрезентации, МассивИдентификаторовСлайдов) Экспорт	
	
	#Если ВебКлиент ИЛИ МобильныйКлиент Тогда
		
	ВызватьИсключение НСтр("ru = 'Для работы с документами OpenOffice используйте тонкий клиент'");
		
	#Иначе
		
	Если МассивИдентификаторовСлайдов = Неопределено
		ИЛИ МассивИдентификаторовСлайдов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;		
		
	ФайлыДляУдаления = Новый Массив;
	
	// Создаем временный каталог
	
	ПутьККаталогуРаспаковки = ПолучитьИмяВременногоФайла("");	
	ЭлектронноеОбучениеСлужебныйКлиентСервер.НовыйКаталог(ПутьККаталогуРаспаковки);	
	ФайлыДляУдаления.Добавить(ПутьККаталогуРаспаковки);
	
	ПутьККаталогуРаспаковки = ЭлектронноеОбучениеСлужебныйКлиентСервер.ДобавитьКонечныйРазделительПути(ПутьККаталогуРаспаковки);	
	
	// Распаковываем ZIP
	
	ФайлАрхива = Новый ЧтениеZIPФайла(ПутьКПрезентации);
	ФайлАрхива.ИзвлечьВсе(ПутьККаталогуРаспаковки, РежимВосстановленияПутейФайловZIP.Восстанавливать); 
	ФайлАрхива.Закрыть(); 				
	
	// Читаем content.xml
	
	СодержимоеДокументаСтрока = ФайлContentВСтроку(ПутьККаталогуРаспаковки);
	
	// Удаляем слайды	
	
	КоличествоУдаленных = УдалитьСлайдыВФайлеContentПрезентации(СодержимоеДокументаСтрока, МассивИдентификаторовСлайдов);
		
	// Записываем новый файл content.xml
	
	Если КоличествоУдаленных > 0 Тогда		
		ПутьКФайлуContent = ПутьККаталогуРаспаковки + "content.xml"; 
		ЭлектронноеОбучениеСлужебныйКлиентСервер.ЗаписатьТекстовыйФайлUTF8БезBOM(ПутьКФайлуContent, СодержимоеДокументаСтрока);		
	КонецЕсли;
		
	// Упаковываем новый архив
	
	ФайлZIP = Новый ЗаписьZipФайла(ПутьКПрезентации);
	ФайлZIP.Добавить(ПутьККаталогуРаспаковки + "*", РежимСохраненияПутейZIP.СохранятьОтносительныеПути,  РежимОбработкиПодкаталоговZIP.ОбрабатыватьРекурсивно);
	ФайлZIP.Записать();
		
	// Удаляем временные файлы
	
	УдалитьВременныеФайлы(ФайлыДляУдаления)
		
	#КонецЕсли	
	
КонецПроцедуры

Функция УдалитьСлайдыВФайлеContentПрезентации(СодержимоеДокументаСтрока, МассивИдентификаторовСлайдов) Экспорт
	
	КоличествоУдаленных = 0;
	
	Для каждого ИдентификаторСлайда Из МассивИдентификаторовСлайдов Цикл
	
		МаркерНачала = "<draw:page draw:name=""" + СокрЛП(ИдентификаторСлайда) + """";
		МаркерКонца  = "</draw:page>";
	
		НомерМаркераНачала = СтрНайти(СодержимоеДокументаСтрока, МаркерНачала);
		
		Если НомерМаркераНачала = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		НомерМаркераКонца = СтрНайти(СодержимоеДокументаСтрока, МаркерКонца,, НомерМаркераНачала);
		НомерКонцаСлайда = НомерМаркераКонца + СтрДлина(МаркерКонца) - 1;
		
		СодержимоеДокументаСтрока = Лев(СодержимоеДокументаСтрока, НомерМаркераНачала - 1) + Сред(СодержимоеДокументаСтрока, НомерКонцаСлайда + 1);
			
		КоличествоУдаленных = КоличествоУдаленных + 1;
	
	КонецЦикла;		
	
	Возврат КоличествоУдаленных;
	
КонецФункции

Функция ФайлContentВСтроку(ПутьККаталогуРаспаковки) Экспорт
	
	ПутьКФайлуContent = ПутьККаталогуРаспаковки + "content.xml"; 
	ЧтениеТекста = Новый ЧтениеТекста(ПутьКФайлуContent, КодировкаТекста.UTF8);
	СодержимоеДокументаСтрока = ЧтениеТекста.Прочитать();
	ЧтениеТекста.Закрыть();		
	
	Возврат СодержимоеДокументаСтрока;
	
КонецФункции

Функция ИдентификаторыВсехСлайдовПрезентацииImpress(СодержимоеДокументаСтрока) Экспорт
	
	// Примечание: похожий алгоритм присутствует в процедуре
	// ЭлектронноеОбучениеСлужебныйКлиент.УстановитьИменаСлайдовВПрезентацииImpress
	
	ИдентификаторыСлайдов = Новый Массив;
	
	Маркер = "<draw:page draw:name=""";
	НачалоПоиска = 1;
	
	Пока Истина Цикл		
		
		НомерМаркера = СтрНайти(СодержимоеДокументаСтрока, Маркер, , НачалоПоиска);
		
		Если НомерМаркера = 0 Тогда
			Прервать;
		КонецЕсли;
		
		НомерНачалаПараметра = НомерМаркера + СтрДлина(Маркер);
		НомерКонцаПараметра = СтрНайти(СодержимоеДокументаСтрока, """",, НомерНачалаПараметра);
		ИмяСлайда = Сред(СодержимоеДокументаСтрока, НомерНачалаПараметра, НомерКонцаПараметра - НомерНачалаПараметра);
		ИдентификаторыСлайдов.Добавить(ИмяСлайда);
		НачалоПоиска = НомерКонцаПараметра + 1;
		
	КонецЦикла;
	
	Возврат ИдентификаторыСлайдов;
	
КонецФункции

Процедура ПреобразоватьПервыйСлайдImpressВКартинку(ПриложениеImpress, ПутьКФайлуПрезентацииКурса, ПутьКаталогуСКартинками, ИдентификаторПервогоСлайда) Экспорт
		
	#Если Клиент Тогда	
		
	Если ОбщегоНазначенияКлиент.ЭтоWindowsКлиент() Тогда
		ВызватьИсключение НСтр("ru = 'Процедура не может быть запущена в ОС Windows'");
	КонецЕсли;
	
	#КонецЕсли

	#Если ВебКлиент ИЛИ МобильныйКлиент Тогда
		
	ВызватьИсключение НСтр("ru = 'Для работы с документами OpenOffice используйте тонкий клиент'");
		
	#Иначе		
		
	// Определяем переменные
		
	ФайлыДляУдаления = Новый Массив;
	ПутьКВременномуКаталогу = ПолучитьИмяВременногоФайла("");
	СоздатьКаталог(ПутьКВременномуКаталогу);
	ФайлыДляУдаления.Добавить(ПутьКВременномуКаталогу);
	ПутьКВременномуКаталогу = ЭлектронноеОбучениеСлужебныйКлиентСервер.ДобавитьКонечныйРазделительПути(ПутьКВременномуКаталогу);
	
	// Конвертируем первый слайд в картинку 
	
	#Если Клиент Тогда
	ПараметрыЗапускаПрограммы = ФайловаяСистемаКлиент.ПараметрыЗапускаПрограммы();
	#Иначе
	ПараметрыЗапускаПрограммы = ФайловаяСистема.ПараметрыЗапускаПрограммы();
	#КонецЕсли
	
	ПараметрыЗапускаПрограммы.ДождатьсяЗавершения = Истина;
	ПараметрыКонвертации = " --convert-to png """+ ПутьКФайлуПрезентацииКурса +""" --outdir """+ ПутьКВременномуКаталогу +""" --headless";	
	
	#Если Клиент Тогда
	Результат = ФайловаяСистемаКлиент.ЗапуститьПрограмму(ПриложениеImpress.Пользовательское + ПараметрыКонвертации, ПараметрыЗапускаПрограммы);
	#Иначе
	Результат = ФайловаяСистема.ЗапуститьПрограмму(ПриложениеImpress.Пользовательское + ПараметрыКонвертации, ПараметрыЗапускаПрограммы);
	#КонецЕсли
	
	Если Результат.КодВозврата <> 0 Тогда
		ВызватьИсключение СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Ошибка конвертации презентации Impress: %1'"), Результат.ПотокВывода);
	КонецЕсли;	
	
	СтруктураФайлаПрезентации = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(ПутьКФайлуПрезентацииКурса);
	ПутьКФайлуPNG = ПутьКВременномуКаталогу + СтруктураФайлаПрезентации.ИмяБезРасширения + ".png";
	ДатаОкончанияОжидания = ТекущаяДата() + 5;
	ФайлPNG = Новый Файл(ПутьКФайлуPNG);
	Пока ДатаОкончанияОжидания > ТекущаяДата() Цикл			
		Если ФайлPNG.Существует() Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	Если НЕ ФайлPNG.Существует() Тогда
		ВызватьИсключение НСтр("ru = 'Ошибка конвертации презентации Impress: файл png не найден'");
	КонецЕсли;		
	
	// Копируем файл в итоговый каталог и переименовываем
	
	ИтоговыйПутьКФайлуКартинки = ЭлектронноеОбучениеСлужебныйКлиентСервер.ДобавитьКонечныйРазделительПути(ПутьКаталогуСКартинками);
	ИтоговыйПутьКФайлуКартинки = ИтоговыйПутьКФайлуКартинки + ИдентификаторПервогоСлайда + ".png";
	ЭлектронноеОбучениеСлужебныйКлиентСервер.СкопироватьФайл(ПутьКФайлуPNG, ИтоговыйПутьКФайлуКартинки);
	
	// Удаляем временные файлы
	
	УдалитьВременныеФайлы(ФайлыДляУдаления);
	
	#КонецЕсли	
	
КонецПроцедуры

Процедура УдалитьВременныеФайлы(ФайлыДляУдаления)
	
	Для каждого ПутьКФайлу Из ФайлыДляУдаления Цикл
			
		Попытка
			УдалитьФайлы(ПутьКФайлу);
		Исключение
			
			#Если Клиент Тогда
			ЭлектронноеОбучениеСлужебныйКлиент.ЗаписатьОшибкуВЖурналРегистрации(
				СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Не удалось удалить временный файл
				|%1 по причине: %2'"), ПутьКФайлу, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()))
			);
			#Иначе
			ЭлектронноеОбучениеСлужебный.ЗаписатьОшибкуВЖурналРегистрации(
				СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Не удалось удалить временный файл
				|%1 по причине: %2'"), ПутьКФайлу, КраткоеПредставлениеОшибки(ИнформацияОбОшибке()))
			);			
		    #КонецЕсли
			
		КонецПопытки;			
					
	КонецЦикла;		
	
	
КонецПроцедуры

#КонецОбласти

