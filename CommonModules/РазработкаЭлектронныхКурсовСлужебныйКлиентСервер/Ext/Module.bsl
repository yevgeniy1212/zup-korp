Функция ПутьКФайлуЗапускаДокумента(Знач ПутьККаталогу) Экспорт
	Возврат ЭлектронноеОбучениеСлужебныйКлиентСервер.ДобавитьКонечныйРазделительПути(ПутьККаталогу) + "index.html";
КонецФункции

Функция ПустаяСтруктураСвойствВладельцаЗагружаемыхФайлов() Экспорт
	
	Возврат Новый Структура("
		|ИмяВладельцаФайлов,
		|ЭлектронныйКурс,
		|Теория,
		|НаборФайлов,
		|ЭлементСодержания,
		|СтраницаТеории,
		|ОбновлятьДатуРесурса");	
	
КонецФункции

Функция ПустаяСтруктураСвойствЗагружаемогоФайла() Экспорт
	
	Возврат Новый Структура("
		|Имя,
		|Расширение,
		|ЭтоКаталог,
		|Преобразовать,
		|СтруктураФайлов,
		|СписокФайлов,
		|НастройкиКартинок,
		|ДанныеВидео,
		|КонтекстФайла,
		|ТекстовыеДанныеДляИндексирования,
		|ВнутренниеГиперссылки");
	
КонецФункции

Функция ЭтоФайлыДляСлайдовогоКурса(ПутьККаталогуСФайлами) Экспорт
	
	#Если ВебКлиент ИЛИ МобильныйКлиент Тогда
		
	ВызватьИсключение НСтр("ru = 'Функциональность загрузки файлов в веб-клиенте не поддерживается'");
		
	#Иначе
		
	ФайлыВКаталоге = ЭлектронноеОбучениеСлужебныйКлиентСервер.ИскатьФайлы(ПутьККаталогуСФайлами, "*", Ложь);

	ЕстьКаталоги = Ложь;
	
	Для каждого ФайлИзКаталога Из ФайлыВКаталоге Цикл
		Если ФайлИзКаталога.ЭтоКаталог() Тогда			
			ФайлыHTML = ЭлектронноеОбучениеСлужебныйКлиентСервер.ИскатьФайлы(ФайлИзКаталога.ПолноеИмя, "index.htm*", Ложь);
			Если ФайлыHTML.Количество() = 0 Тогда
				ЕстьКаталоги = Истина;
				Прервать;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;

	Возврат НЕ ЕстьКаталоги;
	
	#КонецЕсли
	
КонецФункции

Функция ИдентификаторВидеоYouTubeИзURI(ГиперссылкаНаВидео) Экспорт
	
	ИдентификаторВидео = "";
	
	Если НЕ ЗначениеЗаполнено(ГиперссылкаНаВидео) Тогда
		Возврат ИдентификаторВидео;
	КонецЕсли;
	
	// Находим идентификатор
	
	СтруктураURI = ОбщегоНазначенияКлиентСервер.СтруктураURI(ГиперссылкаНаВидео);	
	ЧастьПутиEmbed = "embed/";
	
	Если СтруктураURI.Хост = "youtu.be" 
		ИЛИ СтруктураURI.Хост = "www.youtu.be" 
		ИЛИ СтрНачинаетсяС(СтруктураURI.ПутьНаСервере, ЧастьПутиEmbed) Тогда
		
		Если СтрНачинаетсяС(СтруктураURI.ПутьНаСервере, ЧастьПутиEmbed) Тогда
			СтруктураURI.ПутьНаСервере = Сред(СтруктураURI.ПутьНаСервере, СтрДлина(ЧастьПутиEmbed) + 1);	
		КонецЕсли;
		
		НачалоПараметров = СтрНайти(СтруктураURI.ПутьНаСервере, "?");
		НачалоХеша = СтрНайти(СтруктураURI.ПутьНаСервере, "#");
		
		Если НачалоПараметров > 0 Тогда
			ИдентификаторВидео = Лев(СтруктураURI.ПутьНаСервере, НачалоПараметров-1);
		ИначеЕсли НачалоХеша > 0 Тогда
			ИдентификаторВидео = Лев(СтруктураURI.ПутьНаСервере, НачалоХеша-1);
		Иначе
			ИдентификаторВидео = СтруктураURI.ПутьНаСервере;
		КонецЕсли;		
				
	Иначе
		
		НачалоПараметров = СтрНайти(СтруктураURI.ПутьНаСервере, "?");
		
		Если НачалоПараметров > 0 Тогда
			
			СтруктураПараметров = ИзучениеЭлектронныхКурсовСлужебныйКлиентСервер.СтруктураСтрокиПараметров(ГиперссылкаНаВидео);
			
			Если СтруктураПараметров.Свойство("v") Тогда
				ИдентификаторВидео = СтруктураПараметров["v"];
			КонецЕсли;
			
		КонецЕсли;
			
	КонецЕсли;
	
	Возврат ИдентификаторВидео;
	
КонецФункции

