	СвойстваВидаКИ.МожноИзменятьСпособРедактирования = Истина;
	СвойстваВидаКИ.ОбязательноеЗаполнение = Ложь;
	СвойстваВидаКИ.РазрешитьВводНесколькихЗначений = Ложь;
	СвойстваВидаКИ.Порядок = 1;
	СвойстваВидаКИ.ЗапретитьРедактированиеПользователем = Истина;
	УправлениеКонтактнойИнформацией.УстановитьСвойстваВидаКонтактнойИнформации(СвойстваВидаКИ);
	
	// EMailЛичныеДанныеКандидатов
	СвойстваВидаКИ = УправлениеКонтактнойИнформацией.ПараметрыВидаКонтактнойИнформации(
		Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты);
	СвойстваВидаКИ.Вид = Справочники.ВидыКонтактнойИнформации.EMailЛичныеДанныеКандидатов;
	СвойстваВидаКИ.Наименование = НСтр("ru = 'Email'");
	СвойстваВидаКИ.НастройкиПроверки.ПроверятьКорректность = Истина;
	СвойстваВидаКИ.ОбязательноеЗаполнение = Ложь;
	СвойстваВидаКИ.Порядок = 2;
	СвойстваВидаКИ.ЗапретитьРедактированиеПользователем = Истина;
	УправлениеКонтактнойИнформацией.УстановитьСвойстваВидаКонтактнойИнформации(СвойстваВидаКИ);
	
	// АдресЛичныеДанныеКандидатов
	СвойстваВидаКИ = УправлениеКонтактнойИнформацией.ПараметрыВидаКонтактнойИнформации(
		Перечисления.ТипыКонтактнойИнформации.Адрес);
	СвойстваВидаКИ.Вид = Справочники.ВидыКонтактнойИнформации.АдресЛичныеДанныеКандидатов;
	СвойстваВидаКИ.Наименование = НСтр("ru = 'Адрес места проживания'");
	СвойстваВидаКИ.МожноИзменятьСпособРедактирования = Ложь;
	СвойстваВидаКИ.ВидРедактирования = "ПолеВводаИДиалог";
	СвойстваВидаКИ.ОбязательноеЗаполнение = Ложь;
	СвойстваВидаКИ.НастройкиПроверки.ТолькоНациональныйАдрес = Истина;
	СвойстваВидаКИ.НастройкиПроверки.ПроверятьКорректность = Ложь;
	СвойстваВидаКИ.НастройкиПроверки.СкрыватьНеактуальныеАдреса = Ложь;
	СвойстваВидаКИ.НастройкиПроверки.ВключатьСтрануВПредставление = Истина;
	СвойстваВидаКИ.Порядок = 3;
	СвойстваВидаКИ.ЗапретитьРедактированиеПользователем = Истина;
	УправлениеКонтактнойИнформацией.УстановитьСвойстваВидаКонтактнойИнформации(СвойстваВидаКИ);
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления,
		"ОбработкаЗавершена", Истина);
	
КонецПроцедуры

Процедура ЗаменитьПараметрыШаблоновСообщенийКандидатов(ПараметрыОбновления = Неопределено) Экспорт

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НазначенияШаблонов", "Справочник.Кандидаты"); 
	Запрос.УстановитьПараметр("НазначениеКандидаты", "Справочник.Кандидаты"); 
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ШаблоныСообщений.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ШаблоныСообщений КАК ШаблоныСообщений
		|ГДЕ
		|	ШаблоныСообщений.ПолноеИмяТипаПараметраВводаНаОсновании = &НазначенияШаблонов
		|	И (ШаблоныСообщений.ТекстШаблонаПисьма ПОДОБНО ""%\[Кандидаты.ФизическоеЛицо.%"" СПЕЦСИМВОЛ ""\""
		|	ИЛИ ШаблоныСообщений.ТекстШаблонаПисьмаHTML ПОДОБНО ""%\[Кандидаты.ФизическоеЛицо.%"" СПЕЦСИМВОЛ ""\""
		|	ИЛИ ШаблоныСообщений.ТекстШаблонаSMS ПОДОБНО ""%\[Кандидаты.ФизическоеЛицо.%"" СПЕЦСИМВОЛ ""\""
		|	ИЛИ ШаблоныСообщений.ТемаПисьма ПОДОБНО ""%\[Кандидаты.ФизическоеЛицо.%"" СПЕЦСИМВОЛ ""\"")
		|	И НЕ ШаблоныСообщений.ПометкаУдаления";

	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить(Метаданные.Справочники.ШаблоныСообщений.ПолноеИмя());
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;

	НачатьТранзакцию();
	Попытка
		Блокировка.Заблокировать();
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() Тогда
			ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(
				ПараметрыОбновления, "ОбработкаЗавершена", Истина);
			ЗафиксироватьТранзакцию();
			Возврат;
		КонецЕсли;
		
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(
			ПараметрыОбновления, "ОбработкаЗавершена", Ложь);
	
		СтрокаПоиска = "[Кандидаты.ФизическоеЛицо.";
		СтрокаЗамены = "[Кандидаты.ЛичныеДанные.";
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			ШаблонОбъект = Выборка.Ссылка.ПолучитьОбъект();
			ШаблонОбъект.ТекстШаблонаПисьма = СтрЗаменить(ШаблонОбъект.ТекстШаблонаПисьма, СтрокаПоиска, СтрокаЗамены);
			ШаблонОбъект.ТекстШаблонаПисьмаHTML = СтрЗаменить(ШаблонОбъект.ТекстШаблонаПисьмаHTML, СтрокаПоиска, СтрокаЗамены);
			ШаблонОбъект.ТекстШаблонаSMS = СтрЗаменить(ШаблонОбъект.ТекстШаблонаSMS, СтрокаПоиска, СтрокаЗамены);
			ШаблонОбъект.ТемаПисьма = СтрЗаменить(ШаблонОбъект.ТемаПисьма, СтрокаПоиска, СтрокаЗамены);
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ШаблонОбъект);
		КонецЦикла;
	
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(
			ПараметрыОбновления, "ОбработкаЗавершена", Истина);
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(
			ПараметрыОбновления, "ОбработкаЗавершена", Ложь);
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

Процедура УточнитьТекущийЭтапРаботыСКандидатами(ПараметрыОбновления) Экспорт

	// Текущий этап рассчитывается как
	// - первый не пройденный (или не пропущенный) этап для кандидатов на рассмотрении
	// - последний пройденный (или пропущенный) этап для отклоненных кандидатов
	// В этом случае, если у кандидата есть пропуски в этапах, не отмеченные статусом "Пропущен", 
	// то ожидается, что текущим будет следующий за последним пройденным или пропущенным
	
	// Обработчик 
	// - находит минимальный не пройденный этап для кандидатов
	// - отбирает тех кандидатов, у которых есть пройденные этапы с номером выше, чем первый не пройденный
	// Для таких кандидатов текущий этап будет пересчитан

	ОбработанныеКандидаты = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(
		ПараметрыОбновления, "ОбработанныеКандидаты", Новый Массив);
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("ЗавершенныеЭтапы", 
		ОбщегоНазначенияБЗККлиентСервер.ЗначенияВМассиве(
			Перечисления.СостоянияЭтаповРаботыСКандидатами.Пройден, 
			Перечисления.СостоянияЭтаповРаботыСКандидатами.Пропущен));
	Запрос.УстановитьПараметр("Обработанные", ОбработанныеКандидаты);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Кандидаты.Ссылка КАК Кандидат,
		|	МИНИМУМ(ЭтапыВакансии.НомерСтроки) КАК НомерЭтапа
		|ПОМЕСТИТЬ ВТПервыйНеПройденныйЭтапПоНомеру
		|ИЗ
		|	Справочник.Вакансии.ЭтапыРаботыСКандидатами КАК ЭтапыВакансии
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Кандидаты КАК Кандидаты
		|		ПО (Кандидаты.Вакансия = ЭтапыВакансии.Ссылка)
		|			И (НЕ Кандидаты.Ссылка В (&Обработанные))
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РаботаСКандидатами КАК РаботаСКандидатами
		|		ПО (ЭтапыВакансии.Ссылка = Кандидаты.Вакансия)
		|			И (РаботаСКандидатами.Кандидат = Кандидаты.Ссылка)
		|			И (ЭтапыВакансии.ЭтапРаботы = РаботаСКандидатами.ЭтапРаботы)
		|ГДЕ
		|	НЕ ЕСТЬNULL(РаботаСКандидатами.СостояниеЭтапа, ЗНАЧЕНИЕ(Перечисление.СостоянияЭтаповРаботыСКандидатами.ПустаяСсылка)) В (&ЗавершенныеЭтапы)
		|
		|СГРУППИРОВАТЬ ПО
		|	Кандидаты.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 1000
		|	Кандидаты.Ссылка КАК Кандидат
		|ИЗ
		|	Справочник.Вакансии.ЭтапыРаботыСКандидатами КАК ЭтапыВакансии
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Кандидаты КАК Кандидаты
		|		ПО (Кандидаты.Вакансия = ЭтапыВакансии.Ссылка)
		|			И (НЕ Кандидаты.Ссылка В (&Обработанные))
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РаботаСКандидатами КАК РаботаСКандидатами
		|		ПО (ЭтапыВакансии.Ссылка = Кандидаты.Вакансия)
		|			И (РаботаСКандидатами.Кандидат = Кандидаты.Ссылка)
		|			И ЭтапыВакансии.ЭтапРаботы = РаботаСКандидатами.ЭтапРаботы
		|			И (РаботаСКандидатами.СостояниеЭтапа В (&ЗавершенныеЭтапы))
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПервыйНеПройденныйЭтапПоНомеру КАК ПервыйНеПройденныйЭтапПоНомеру
		|		ПО (ПервыйНеПройденныйЭтапПоНомеру.Кандидат = Кандидаты.Ссылка)
		|			И (ПервыйНеПройденныйЭтапПоНомеру.НомерЭтапа < ЭтапыВакансии.НомерСтроки)";
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		ПараметрыОбновления.ОбработкаЗавершена = Истина;
		Возврат;
	КонецЕсли;
	
	ПараметрыОбновления.ОбработкаЗавершена = Ложь;

	Кандидаты = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Кандидат");

	Если ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ПодготовитьОбновлениеДанных(ПараметрыОбновления, 
			"РегистрСведений.ТекущиеЭтапыРаботыСКандидатами", Неопределено, Неопределено) Тогда
		ОбновитьТекущийЭтапРаботыКандидатов(Кандидаты);
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ОбработанныеКандидаты, Кандидаты);
	ПараметрыОбновления.Вставить("ОбработанныеКандидаты", ОбработанныеКандидаты);

КонецПроцедуры

Процедура ДобавитьПредопределенныеЭтапыРаботыСКандидатами(ПараметрыОбновления) Экспорт

	ОбновлениеИБ = ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый;
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("ПредопределенныеЭтапы", Перечисления.ЭтапыРаботыСКандидатами.Действующие());
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 300
		|	Кандидаты.Ссылка КАК Ссылка,
		|	Кандидаты.Вакансия КАК Вакансия
		|ПОМЕСТИТЬ ВТКандидаты
		|ИЗ
		|	Справочник.Кандидаты КАК Кандидаты
		|ГДЕ
		|	Кандидаты.Вакансия В
		|			(ВЫБРАТЬ
		|				Вакансии.Ссылка КАК Ссылка
		|			ИЗ
		|				Справочник.Вакансии КАК Вакансии
		|			ГДЕ
		|				НЕ Вакансии.Ссылка В
		|						(ВЫБРАТЬ
		|							Этапы.Ссылка
		|						ИЗ
		|							Справочник.Вакансии.ЭтапыРаботыСКандидатами КАК Этапы
		|						ГДЕ
		|							Этапы.ЭтапРаботы В (&ПредопределенныеЭтапы)))
		|
		|УПОРЯДОЧИТЬ ПО
		|	Кандидаты.ДатаРегистрации УБЫВ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Кандидаты.Ссылка КАК Кандидат,
		|	Кандидаты.Вакансия КАК Вакансия,
		|	РаботаСКандидатами.Период КАК Период,
		|	РаботаСКандидатами.ЭтапРаботы КАК ЭтапРаботы,
		|	РаботаСКандидатами.Комментарий КАК Комментарий,
		|	РаботаСКандидатами.СостояниеЭтапа КАК СостояниеЭтапа,
		|	РаботаСКандидатами.ШаблонАнкеты КАК ШаблонАнкеты,
		|	РаботаСКандидатами.ПричинаОтклонения КАК ПричинаОтклонения,
		|	РаботаСКандидатами.ПериодОкончание КАК ПериодОкончание,
		|	РаботаСКандидатами.Бронь КАК Бронь,
		|	РаботаСКандидатами.Организатор КАК Организатор,
		|	РаботаСКандидатами.ДокументОснование КАК ДокументОснование
		|ИЗ
		|	Справочник.Кандидаты КАК Кандидаты
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РаботаСКандидатами КАК РаботаСКандидатами
		|		ПО (РаботаСКандидатами.Кандидат = Кандидаты.Ссылка)
		|			И (НЕ РаботаСКандидатами.ЭтапРаботы В (&ПредопределенныеЭтапы))
		|ГДЕ
		|	Кандидаты.Вакансия В
		|			(ВЫБРАТЬ
		|				ВТКандидаты.Вакансия
		|			ИЗ
		|				ВТКандидаты)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Кандидаты.Вакансия,
		|	Кандидаты.Ссылка";
	
	ОписаниеДанных = Новый Массив;
	ОписаниеДанных.Добавить(ОписаниеБлокируемыхДанных(Метаданные.Справочники.Вакансии));
	ОписаниеДанных.Добавить(ОписаниеБлокируемыхДанных(Метаданные.Справочники.ПрофилиДолжностей));
	ОписаниеДанных.Добавить(ОписаниеБлокируемыхДанных(Метаданные.РегистрыСведений.РаботаСКандидатами));
	ОписаниеДанных.Добавить(ОписаниеБлокируемыхДанных(Метаданные.РегистрыСведений.ТекущиеЭтапыРаботыСКандидатами));
	ОписаниеДанных.Добавить(ОписаниеБлокируемыхДанных(Метаданные.Документы.РешениеОПриемеНаРаботу));
	ОписаниеДанных.Добавить(ОписаниеБлокируемыхДанных(Метаданные.Документы.ПриемНаРаботу));
	ОписаниеДанных.Добавить(ОписаниеБлокируемыхДанных(Метаданные.Документы.ПриемНаРаботуСписком));

	Если Не ОбновлениеИБ.НачатьОбновлениеДанных(ОписаниеДанных, ПараметрыОбновления) Тогда
		Возврат;
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		ОбновлениеИБ.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
		ПараметрыОбновления.ОбработкаЗавершена = Истина;
		Возврат;
	КонецЕсли;
	
	ПараметрыОбновления.ОбработкаЗавершена = Ложь;

	ВсеКандидаты = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Кандидат");
	
	ДанныеКандидатов = Справочники.Кандидаты.ДанныеКандидатов(ВсеКандидаты);
	ОбщегоНазначенияБЗК.ДобавитьИндексКоллекции(ДанныеКандидатов, "Кандидат");

	РешенияПоКандидатам = Документы.РешениеОПриемеНаРаботу.РешенияПоКандидатам(ВсеКандидаты);
	РеквизитыРешений = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(
		ОбщегоНазначения.ВыгрузитьКолонку(РешенияПоКандидатам, "Значение"), "Проведен, Дата, Комментарий");
	
	СотрудникиПоКандидатам = СотрудникиПоКандидатам(ВсеКандидаты);
	КадровыеДанные = КадровыйУчет.КадровыеДанныеСотрудников(Ложь, 
		ОбщегоНазначения.ВыгрузитьКолонку(СотрудникиПоКандидатам, "Значение"), "ДатаПриема, ПриказОПриеме");
	ОбщегоНазначенияБЗК.ДобавитьИндексКоллекции(КадровыеДанные, "Сотрудник");
	
	Профили = Новый Соответствие();
	ОбновленныеКандидаты = Новый Массив;

	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.СледующийПоЗначениюПоля("Вакансия") Цикл
		ВакансияОбъект = Выборка.Вакансия.ПолучитьОбъект(); // СправочникОбъект.Вакансии
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицуИзМассива(ВакансияОбъект.ЭтапыРаботыСКандидатами, 
			Перечисления.ЭтапыРаботыСКандидатами.Действующие(), "ЭтапРаботы");
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ВакансияОбъект);
		Если ВакансияОбъект.СоответствуетПрофилюДолжности 
			И ЗначениеЗаполнено(ВакансияОбъект.ПрофильДолжности) 
			И Профили.Получить(ВакансияОбъект.ПрофильДолжности) = Неопределено Тогда
			ПрофильОбъект = ВакансияОбъект.ПрофильДолжности.ПолучитьОбъект();
			Если ПрофильОбъект.ЭтапыРаботыСКандидатами.НайтиСтроки(
				Новый Структура("ЭтапРаботы", Перечисления.ЭтапыРаботыСКандидатами.Утверждение)).Количество() = 0 Тогда
				ОбщегоНазначенияКлиентСервер.ДополнитьТаблицуИзМассива(ПрофильОбъект.ЭтапыРаботыСКандидатами, 
					Перечисления.ЭтапыРаботыСКандидатами.Действующие(), "ЭтапРаботы");
				ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ПрофильОбъект);
			КонецЕсли;
			Профили.Вставить(ПрофильОбъект.Ссылка, Истина);
		КонецЕсли;
		Пока Выборка.СледующийПоЗначениюПоля("Кандидат") Цикл
			НаборЗаписей = РегистрыСведений.РаботаСКандидатами.СоздатьНаборЗаписей();
			ДанныеКандидата = ДанныеКандидатов.НайтиСтроки(Новый Структура("Кандидат", Выборка.Кандидат))[0];
			Если ДанныеКандидата.Состояние = Перечисления.СостоянияСогласования.Согласовано Тогда
				СтрокаНабора = НаборЗаписей.Добавить();
				СтрокаНабора.Кандидат = Выборка.Кандидат;
				СтрокаНабора.Период = ДанныеКандидата.ДатаРешения;
				СтрокаНабора.ЭтапРаботы = Перечисления.ЭтапыРаботыСКандидатами.Утверждение;
				СтрокаНабора.СостояниеЭтапа = Перечисления.СостоянияЭтаповРаботыСКандидатами.Пройден;
				СтрокаНабора.Комментарий = ДанныеКандидата.КомментарийРешения;
			КонецЕсли;
			Если РешенияПоКандидатам[Выборка.Кандидат] <> Неопределено Тогда
				Решение = РешенияПоКандидатам[Выборка.Кандидат];
				СтрокаНабора = НаборЗаписей.Добавить();
				СтрокаНабора.Кандидат = Выборка.Кандидат;
				СтрокаНабора.ЭтапРаботы = Перечисления.ЭтапыРаботыСКандидатами.РешениеОПриемеНаРаботу;
				СтрокаНабора.Период = Перечисления.ЭтапыРаботыСКандидатами.УточнитьВремяЭтапа(СтрокаНабора.ЭтапРаботы, 
					РеквизитыРешений[Решение].Дата);
				СтрокаНабора.СостояниеЭтапа = ?(РеквизитыРешений[Решение].Проведен, 
					Перечисления.СостоянияЭтаповРаботыСКандидатами.Пройден, 
					Перечисления.СостоянияЭтаповРаботыСКандидатами.Запланирован);
				СтрокаНабора.Комментарий = РеквизитыРешений[Решение].Комментарий;
				СтрокаНабора.ДокументОснование = Решение;
			КонецЕсли;
			Если СотрудникиПоКандидатам[Выборка.Кандидат] <> Неопределено Тогда
				НайденныеСтроки = КадровыеДанные.НайтиСтроки(
					Новый Структура("Сотрудник", СотрудникиПоКандидатам[Выборка.Кандидат]));
				Если НайденныеСтроки.Количество() > 0 И ЗначениеЗаполнено(НайденныеСтроки[0].ДатаПриема) Тогда
					СтрокаНабора = НаборЗаписей.Добавить();
					СтрокаНабора.Кандидат = Выборка.Кандидат;
					СтрокаНабора.ЭтапРаботы = Перечисления.ЭтапыРаботыСКандидатами.ПриемНаРаботу;
					СтрокаНабора.Период = Перечисления.ЭтапыРаботыСКандидатами.УточнитьВремяЭтапа(СтрокаНабора.ЭтапРаботы, 
						НайденныеСтроки[0].ДатаПриема);
					СтрокаНабора.СостояниеЭтапа = Перечисления.СостоянияЭтаповРаботыСКандидатами.Пройден;
					СтрокаНабора.ДокументОснование = НайденныеСтроки[0].ПриказОПриеме;
				КонецЕсли;
			КонецЕсли;
			Если НаборЗаписей.Количество() > 0 Тогда
				Пока Выборка.Следующий() Цикл
					Если ЗначениеЗаполнено(Выборка.ЭтапРаботы) Тогда
						ЗаполнитьЗначенияСвойств(НаборЗаписей.Добавить(), Выборка);
					КонецЕсли;
				КонецЦикла;
				НаборЗаписей.Отбор.Кандидат.Установить(Выборка.Кандидат);
				ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
			КонецЕсли;
			ОбновленныеКандидаты.Добавить(Выборка.Кандидат); // Текуший этап все равно нужно пересчитать.
		КонецЦикла;
	КонецЦикла;

	ОбновитьТекущийЭтапРаботыКандидатов(ОбновленныеКандидаты, Истина);
	
	ОбновлениеИБ.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
	
КонецПроцедуры

Процедура ДобавитьПредопределенныеЭтапыВакансийПрофилейДолжности(ПараметрыОбновления) Экспорт
	
	ОбновлениеИБ = ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый;

	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("ПредопределенныеЭтапы", Перечисления.ЭтапыРаботыСКандидатами.Действующие());
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1000
		|	Вакансии.Ссылка КАК Ссылка,
		|	Вакансии.СоответствуетПрофилюДолжности КАК СоответствуетПрофилюДолжности,
		|	Вакансии.ПрофильДолжности КАК ПрофильДолжности
		|ИЗ
		|	Справочник.Вакансии КАК Вакансии
		|ГДЕ
		|	НЕ Вакансии.Ссылка В
		|				(ВЫБРАТЬ
		|					Этапы.Ссылка
		|				ИЗ
		|					Справочник.Вакансии.ЭтапыРаботыСКандидатами КАК Этапы
		|				ГДЕ
		|					Этапы.ЭтапРаботы В (&ПредопределенныеЭтапы))
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПрофилиДолжностей.Ссылка,
		|	ЛОЖЬ,
		|	NULL
		|ИЗ
		|	Справочник.ПрофилиДолжностей КАК ПрофилиДолжностей
		|ГДЕ
		|	НЕ ПрофилиДолжностей.Ссылка В
		|				(ВЫБРАТЬ
		|					Этапы.Ссылка
		|				ИЗ
		|					Справочник.ПрофилиДолжностей.ЭтапыРаботыСКандидатами КАК Этапы
		|				ГДЕ
		|					Этапы.ЭтапРаботы В (&ПредопределенныеЭтапы))";
	
	ОписаниеДанных = Новый Массив;
	ОписаниеДанных.Добавить(ОписаниеБлокируемыхДанных(Метаданные.Справочники.Вакансии));
	ОписаниеДанных.Добавить(ОписаниеБлокируемыхДанных(Метаданные.Справочники.ПрофилиДолжностей));

	Если Не ОбновлениеИБ.НачатьОбновлениеДанных(ОписаниеДанных, ПараметрыОбновления) Тогда
		Возврат;
	КонецЕсли;
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		ОбновлениеИБ.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
		ПараметрыОбновления.ОбработкаЗавершена = Истина;
		Возврат;
	КонецЕсли;
	
	ПараметрыОбновления.ОбработкаЗавершена = Ложь;
	
	Профили = Новый Соответствие();

	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Профили.Получить(Выборка.Ссылка) <> Неопределено Тогда
			Продолжить;
		КонецЕсли;
		СправочникОбъект = Выборка.Ссылка.ПолучитьОбъект(); // СправочникОбъект.Вакансии
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицуИзМассива(СправочникОбъект.ЭтапыРаботыСКандидатами, 
			Перечисления.ЭтапыРаботыСКандидатами.Действующие(), "ЭтапРаботы");
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(СправочникОбъект);
		Если Выборка.СоответствуетПрофилюДолжности 
			И ЗначениеЗаполнено(Выборка.ПрофильДолжности) 
			И Профили.Получить(Выборка.ПрофильДолжности) = Неопределено Тогда
			ПрофильОбъект = Выборка.ПрофильДолжности.ПолучитьОбъект();
			Если ПрофильОбъект.ЭтапыРаботыСКандидатами.НайтиСтроки(
				Новый Структура("ЭтапРаботы", Перечисления.ЭтапыРаботыСКандидатами.Утверждение)).Количество() = 0 Тогда
				ОбщегоНазначенияКлиентСервер.ДополнитьТаблицуИзМассива(ПрофильОбъект.ЭтапыРаботыСКандидатами, 
					Перечисления.ЭтапыРаботыСКандидатами.Действующие(), "ЭтапРаботы");
				ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ПрофильОбъект);
			КонецЕсли;
			Профили.Вставить(ПрофильОбъект.Ссылка, Истина);
		КонецЕсли;
	КонецЦикла;

	ОбновлениеИБ.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
	
КонецПроцедуры

Функция ОписаниеБлокируемыхДанных(МетаданныеОбъекта)
	Описание = ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ОписаниеБлокируемыхДанных(МетаданныеОбъекта);
	Описание.ПоляБлокировки.Очистить();
	Возврат Описание;
КонецФункции

