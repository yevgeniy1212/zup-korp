КонецПроцедуры

// АПК:299-вкл

Функция ЗапросКонтактнаяИнформацияКандидатов(ОписательВременныхТаблиц, ТолькоРазрешенные) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = ОписательВременныхТаблиц.МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ РАЗРЕШЕННЫЕ
	|	КонтактнаяИнформация.Ссылка КАК ЛичныеДанныеКандидата,
	|	КонтактнаяИнформация.НомерСтроки КАК НомерСтроки,
	|	КонтактнаяИнформация.Тип КАК Тип,
	|	КонтактнаяИнформация.Вид КАК Вид,
	|	КонтактнаяИнформация.Страна КАК Страна,
	|	КонтактнаяИнформация.Регион КАК Регион,
	|	КонтактнаяИнформация.Город КАК Город,
	|	КонтактнаяИнформация.Представление КАК Представление,
	|	ВЫБОР
	|		КОГДА (ВЫРАЗИТЬ(КонтактнаяИнформация.Значение КАК СТРОКА(1))) = """"
	|			ТОГДА ВЫРАЗИТЬ(КонтактнаяИнформация.ЗначенияПолей  КАК СТРОКА(1000))
	|		ИНАЧЕ ВЫРАЗИТЬ(КонтактнаяИнформация.Значение КАК СТРОКА(1000))
	|	КОНЕЦ КАК ЗначенияПолей
	|ПОМЕСТИТЬ ВТВсяКонтактнаяИнформация
	|ИЗ
	|	Справочник.ЛичныеДанныеКандидатов.КонтактнаяИнформация КАК КонтактнаяИнформация
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТОтборы КАК ТаблицаОтборов
	|		ПО КонтактнаяИнформация.Ссылка = ТаблицаОтборов.ЛичныеДанныеКандидата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВсяКонтактнаяИнформация.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата,
	|	ВсяКонтактнаяИнформация.Вид КАК Вид,
	|	МИНИМУМ(ВсяКонтактнаяИнформация.НомерСтроки) КАК НомерСтроки
	|ПОМЕСТИТЬ ВТПервыеЗначенияПоВидуКонтактнойИнформации
	|ИЗ
	|	ВТВсяКонтактнаяИнформация КАК ВсяКонтактнаяИнформация
	|СГРУППИРОВАТЬ ПО
	|	ВсяКонтактнаяИнформация.ЛичныеДанныеКандидата,
	|	ВсяКонтактнаяИнформация.Вид
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВсяКонтактнаяИнформация.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата,
	|	ВсяКонтактнаяИнформация.Тип КАК Тип,
	|	ВсяКонтактнаяИнформация.Вид КАК Вид,
	|	ВсяКонтактнаяИнформация.Страна КАК Страна,
	|	ВсяКонтактнаяИнформация.Регион КАК Регион,
	|	ВсяКонтактнаяИнформация.Город КАК Город,
	|	ВсяКонтактнаяИнформация.Представление КАК Представление,
	|	ВсяКонтактнаяИнформация.ЗначенияПолей КАК ЗначенияПолей
	|ПОМЕСТИТЬ ВТКонтактнаяИнформация
	|ИЗ
	|	ВТВсяКонтактнаяИнформация КАК ВсяКонтактнаяИнформация
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПервыеЗначенияПоВидуКонтактнойИнформации КАК ПервыеЗначенияПоВидуКонтактнойИнформации
	|		ПО ВсяКонтактнаяИнформация.ЛичныеДанныеКандидата = ПервыеЗначенияПоВидуКонтактнойИнформации.ЛичныеДанныеКандидата
	|		И ВсяКонтактнаяИнформация.Вид = ПервыеЗначенияПоВидуКонтактнойИнформации.Вид
	|		И ВсяКонтактнаяИнформация.НомерСтроки = ПервыеЗначенияПоВидуКонтактнойИнформации.НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТВсяКонтактнаяИнформация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТПервыеЗначенияПоВидуКонтактнойИнформации";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВТОтборы", ОписательВременныхТаблиц.ИмяВременнойТаблицыОтборов);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаОтборов.ЛичныеДанныеКандидата",
		"ТаблицаОтборов." + ОписательВременныхТаблиц.ИмяПоляОтбора);
		
	ЗарплатаКадрыОбщиеНаборыДанных.ЗаменитьИмяСоздаваемойВременнойТаблицы(Запрос.Текст, "ВТКонтактнаяИнформация",
		ОписательВременныхТаблиц.ИмяСоздаваемойВТ);
	ЗарплатаКадрыОбщиеНаборыДанных.УстановитьВыборкуТолькоРазрешенныхДанных(Запрос.Текст, ТолькоРазрешенные);
	
	Возврат Запрос;
	
КонецФункции

// Создает временную таблицу сведений о кандидатах.
// 
// Параметры:
//  ОписательВременныхТаблиц - см. ОписательВременныхТаблиц
//  ТолькоРазрешенные - Булево
Процедура СоздатьВТОсновныеСведенияОКандидатах(ОписательВременныхТаблиц, ТолькоРазрешенные) Экспорт

	Запрос = ЗапросОсновныеСведенияОКандидатах(ОписательВременныхТаблиц, ТолькоРазрешенные);
	
	Запрос.Выполнить();
	
	УдалитьВТ = Новый Массив;
