// Возвращает структуру с параметрами для методов создания временных таблиц
//
// Параметры:
//	МенеджерВременныхТаблиц - МенеджерВременныхТаблиц
//	ИмяВременнойТаблицыОтборов - Строка - имя временной таблицы-"фильтра"
//	ИмяСоздаваемойВТ - Строка - имя создаваемой временной таблицы
//	ИмяПоляОтбора - Строка - имя поля таблицы отбора кандидатов
//
// Возвращаемое значение:
//	 Структура:
//	   * МенеджерВременныхТаблиц - МенеджерВременныхТаблиц
//	   * ИмяВременнойТаблицыОтборов - Строка - имя временной таблицы отборов кандидатов
//	   * ИмяСоздаваемойВТ - Строка - имя создаваемой временной таблицы
//	   * ИмяПоляОтбора - Строка - имя поля таблицы отбора кандидатов
Функция ОписательВременныхТаблиц(МенеджерВременныхТаблиц, ИмяВременнойТаблицыОтборов, ИмяСоздаваемойВТ, ИмяПоляОтбора) Экспорт
	
	ОписательВременныхТаблиц = Новый Структура;
	
	ОписательВременныхТаблиц.Вставить("МенеджерВременныхТаблиц", МенеджерВременныхТаблиц);
	ОписательВременныхТаблиц.Вставить("ИмяВременнойТаблицыОтборов", ИмяВременнойТаблицыОтборов);
	ОписательВременныхТаблиц.Вставить("ИмяСоздаваемойВТ", ИмяСоздаваемойВТ);
	ОписательВременныхТаблиц.Вставить("ИмяПоляОтбора", ИмяПоляОтбора);
	
	Возврат ОписательВременныхТаблиц
	
КонецФункции

// Создает в менеджере временных таблиц временную таблицу для отбора кандидатов.
// 
// Параметры:
//  Кандидаты - Массив из СправочникСсылка.Кандидаты
//  МенеджерВременныхТаблиц - МенеджерВременныхТаблиц
//  ИмяВТ - Строка - имя создаваемой таблицы
Процедура СоздатьВТОтборовКандидатов(Кандидаты, МенеджерВременныхТаблиц, ИмяВТ = "ВТОтборы") Экспорт
	
	Если МенеджерВременныхТаблиц.Таблицы.Найти(ИмяВТ) <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ РАЗРЕШЕННЫЕ
	|	Кандидаты.Ссылка КАК Кандидат
	|ПОМЕСТИТЬ ВТОтборы
	|ИЗ
	|	Справочник.Кандидаты КАК Кандидаты
	|ГДЕ
	|	Кандидаты.Ссылка В (&Кандидаты)";
	
	Запрос.УстановитьПараметр("Кандидаты", Кандидаты);
	ЗарплатаКадрыОбщиеНаборыДанных.ЗаменитьИмяСоздаваемойВременнойТаблицы(Запрос.Текст, "ВТОтборы", ИмяВТ);
	Запрос.Выполнить();
	
КонецПроцедуры

// Создает в менеджере временных таблиц временную таблицу для отбора личных данных кандидатов.
// 
// Параметры:
//  ЛичныеДанныеКандидатов - Массив из СправочникСсылка.ЛичныеДанныеКандидатов
//  МенеджерВременныхТаблиц - МенеджерВременныхТаблиц
//  ИмяВТ - Строка - имя создаваемой таблицы
Процедура СоздатьВТОтборовЛичныхДанныхКандидатов(ЛичныеДанныеКандидатов, МенеджерВременныхТаблиц, ИмяВТ = "ВТОтборы") Экспорт
	
	Если МенеджерВременныхТаблиц.Таблицы.Найти(ИмяВТ) <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ РАЗРЕШЕННЫЕ
	|	ЛичныеДанныеКандидатов.Ссылка КАК ЛичныеДанныеКандидата
	|ПОМЕСТИТЬ ВТОтборы
	|ИЗ
	|	Справочник.ЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатов
	|ГДЕ
	|	ЛичныеДанныеКандидатов.Ссылка В (&ЛичныеДанныеКандидатов)";
	
	Запрос.УстановитьПараметр("ЛичныеДанныеКандидатов", ЛичныеДанныеКандидатов);
	ЗарплатаКадрыОбщиеНаборыДанных.ЗаменитьИмяСоздаваемойВременнойТаблицы(Запрос.Текст, "ВТОтборы", ИмяВТ);
	Запрос.Выполнить();
	
КонецПроцедуры

// Формирует временную таблицу с личными данными кандидатов
//
// Параметры:
//   ОписательВременныхТаблиц - см. ОписательВременныхТаблиц
//   ТолькоРазрешенные - Булево
Процедура СоздатьВТЛичныеДанныеКандидатов(ОписательВременныхТаблиц, ТолькоРазрешенные) Экспорт
	
	Запрос = ЗапросЛичныеДанныеКандидатов(ОписательВременныхТаблиц, ТолькоРазрешенные);
	Запрос.Выполнить();
	
КонецПроцедуры

Функция ЗапросЛичныеДанныеКандидатов(ОписательВременныхТаблиц, ТолькоРазрешенные) Экспорт
	
	ОписательТаблицКонтактнойИнформации = ОписательВременныхТаблиц(ОписательВременныхТаблиц.МенеджерВременныхТаблиц,
		ОписательВременныхТаблиц.ИмяВременнойТаблицыОтборов, "ВТКонтактнаяИнформация",
		ОписательВременныхТаблиц.ИмяПоляОтбора);
	ИтоговыйЗапрос = ЗапросКонтактнаяИнформацияКандидатов(ОписательТаблицКонтактнойИнформации,
		ТолькоРазрешенные);
	
	ОписательТаблицЗнаниеЯзыков = ОписательВременныхТаблиц(ОписательВременныхТаблиц.МенеджерВременныхТаблиц,
		ОписательВременныхТаблиц.ИмяВременнойТаблицыОтборов, "ВТЗнаниеЯзыковКандидатов",
		ОписательВременныхТаблиц.ИмяПоляОтбора);
	ЗапросЗнаниеЯзыков = ЗапросВТЗнаниеЯзыковКандидатов(ОписательТаблицЗнаниеЯзыков, ТолькоРазрешенные);
	
	ОписательТаблицОбразование = ОписательВременныхТаблиц(ОписательВременныхТаблиц.МенеджерВременныхТаблиц,
		ОписательВременныхТаблиц.ИмяВременнойТаблицыОтборов, "ВТОбразованияКандидатов",
		ОписательВременныхТаблиц.ИмяПоляОтбора);
	ЗапросОбразование = ЗапросВТОбразованиеКандидатов(ОписательТаблицОбразование, ТолькоРазрешенные);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = ОписательВременныхТаблиц.МенеджерВременныхТаблиц;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ РАЗРЕШЕННЫЕ
	|	ЛичныеДанныеКандидатов.Ссылка КАК ЛичныеДанныеКандидата,
	|	ЛичныеДанныеКандидатов.ФИО КАК ФИО,
	|	ЛичныеДанныеКандидатов.Фамилия КАК Фамилия,
	|	ЛичныеДанныеКандидатов.Имя КАК Имя,
	|	ЛичныеДанныеКандидатов.Отчество КАК Отчество,
	|	ЛичныеДанныеКандидатов.УточнениеНаименования КАК УточнениеНаименования,
	|	ЛичныеДанныеКандидатов.Пол КАК Пол,
	|	ЛичныеДанныеКандидатов.ДатаРождения КАК ДатаРождения,
	|	ЛичныеДанныеКандидатов.МестоРождения КАК МестоРождения,
	|	ЛичныеДанныеКандидатов.СостояниеВБраке КАК СостояниеВБраке,
	|	ЛичныеДанныеКандидатов.Гражданство КАК Гражданство,
	|	ВЫБОР
	|		КОГДА ЛичныеДанныеКандидатов.ДатаРождения = ДАТАВРЕМЯ(1, 1, 1)
	|			ТОГДА 0
	|		КОГДА ЛичныеДанныеКандидатов.ДатаРождения >= &ТекущаяДата
	|			ТОГДА 0
	|		ИНАЧЕ РАЗНОСТЬДАТ(ЛичныеДанныеКандидатов.ДатаРождения, &ТекущаяДата, ГОД) + ВЫБОР
	|			КОГДА МЕСЯЦ(ЛичныеДанныеКандидатов.ДатаРождения) > МЕСЯЦ(&ТекущаяДата)
	|				ТОГДА -1
	|			КОГДА МЕСЯЦ(ЛичныеДанныеКандидатов.ДатаРождения) = МЕСЯЦ(&ТекущаяДата)
	|			И ДЕНЬ(ЛичныеДанныеКандидатов.ДатаРождения) > ДЕНЬ(&ТекущаяДата)
	|				ТОГДА -1
	|			ИНАЧЕ 0
	|		КОНЕЦ
	|	КОНЕЦ КАК Возраст,
	|	ЕСТЬNULL(EMailКандидата.Представление, """") КАК EMailПредставление,
	|	ЕСТЬNULL(АДРЕСКандидата.Представление, """") КАК АдресПредставление,
	|	ЕСТЬNULL(ТЕЛЕФОНКандидата.Представление, """") КАК ТелефонПредставление,
	|	ЕСТЬNULL(ФизическиеЛицаКандидатов.ФизическоеЛицо, ЗНАЧЕНИЕ(Справочник.ФизическиеЛица.ПустаяСсылка)) КАК
	|		ФизическоеЛицо,
	|	ЕСТЬNULL(ЗнаниеЯзыкаКандидатов.Язык, ЗНАЧЕНИЕ(Справочник.ЯзыкиНародовМира.ПустаяСсылка)) КАК Язык,
	|	ЕСТЬNULL(ОбразованиеКандидатов.ВидОбразования, ЗНАЧЕНИЕ(Справочник.ВидыОбразованияФизическихЛиц.ПустаяСсылка)) КАК
	|		ВидОбразования,
	|	ЕСТЬNULL(ОбразованиеКандидатов.УчебноеЗаведение, ЗНАЧЕНИЕ(Справочник.УчебныеЗаведения.ПустаяСсылка)) КАК
	|		УчебноеЗаведение,
	|	ЕСТЬNULL(ОбразованиеКандидатов.Факультет, """") КАК Факультет,
	|	ЕСТЬNULL(ОбразованиеКандидатов.Специальность,
	|		ЗНАЧЕНИЕ(Справочник.КлассификаторСпециальностейПоОбразованию.ПустаяСсылка)) КАК Специальность,
	|	ЕСТЬNULL(ОбразованиеКандидатов.ГодОкончания, 0) КАК ГодОкончания,
	|	ЕСТЬNULL(ОбразованиеПервое.Образование1ВидОбразования,
	|		ЗНАЧЕНИЕ(Справочник.ВидыОбразованияФизическихЛиц.ПустаяСсылка)) КАК Образование1ВидОбразования,
	|	ЕСТЬNULL(ОбразованиеПервое.Образование1УчебноеЗаведение, ЗНАЧЕНИЕ(Справочник.УчебныеЗаведения.ПустаяСсылка)) КАК
	|		Образование1УчебноеЗаведение,
	|	ЕСТЬNULL(ОбразованиеПервое.Образование1Факультет, """") КАК Образование1Факультет,
	|	ЕСТЬNULL(ОбразованиеПервое.Образование1Специальность,
	|		ЗНАЧЕНИЕ(Справочник.КлассификаторСпециальностейПоОбразованию.ПустаяСсылка)) КАК Образование1Специальность,
	|	ЕСТЬNULL(ОбразованиеПервое.Образование1ГодОкончания, 0) КАК Образование1ГодОкончания,
	|	ЕСТЬNULL(ОбразованиеВторое.Образование2ВидОбразования,
	|		ЗНАЧЕНИЕ(Справочник.ВидыОбразованияФизическихЛиц.ПустаяСсылка)) КАК Образование2ВидОбразования,
	|	ЕСТЬNULL(ОбразованиеВторое.Образование2УчебноеЗаведение, ЗНАЧЕНИЕ(Справочник.УчебныеЗаведения.ПустаяСсылка)) КАК
	|		Образование2УчебноеЗаведение,
	|	ЕСТЬNULL(ОбразованиеВторое.Образование2Факультет, """") КАК Образование2Факультет,
	|	ЕСТЬNULL(ОбразованиеВторое.Образование2Специальность,
	|		ЗНАЧЕНИЕ(Справочник.КлассификаторСпециальностейПоОбразованию.ПустаяСсылка)) КАК Образование2Специальность,
	|	ЕСТЬNULL(ОбразованиеВторое.Образование2ГодОкончания, 0) КАК Образование2ГодОкончания
	|ПОМЕСТИТЬ ВТЛичныеДанныеКандидатов
	|ИЗ
	|	Справочник.ЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТОтборы КАК ТаблицаОтборов
	|		ПО ЛичныеДанныеКандидатов.Ссылка = ТаблицаОтборов.ЛичныеДанныеКандидата
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТКонтактнаяИнформация КАК EMailКандидата
	|		ПО ЛичныеДанныеКандидатов.Ссылка = EMailКандидата.ЛичныеДанныеКандидата
	|		И EMailКандидата.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.EMailЛичныеДанныеКандидатов)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТКонтактнаяИнформация КАК АДРЕСКандидата
	|		ПО ЛичныеДанныеКандидатов.Ссылка = АДРЕСКандидата.ЛичныеДанныеКандидата
	|		И АДРЕСКандидата.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресЛичныеДанныеКандидатов)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТКонтактнаяИнформация КАК ТЕЛЕФОНКандидата
	|		ПО ЛичныеДанныеКандидатов.Ссылка = ТЕЛЕФОНКандидата.ЛичныеДанныеКандидата
	|		И ТЕЛЕФОНКандидата.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ТелефонЛичныеДанныеКандидатов)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФизическиеЛицаКандидатов КАК ФизическиеЛицаКандидатов
	|		ПО ФизическиеЛицаКандидатов.ЛичныеДанныеКандидата = ЛичныеДанныеКандидатов.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТЗнаниеЯзыкаКандидатов КАК ЗнаниеЯзыкаКандидатов
	|		ПО ЗнаниеЯзыкаКандидатов.ЛичныеДанныеКандидата = ЛичныеДанныеКандидатов.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТОбразованиеКандидатовМаксимум КАК ОбразованиеКандидатов
	|		ПО ОбразованиеКандидатов.ЛичныеДанныеКандидата = ЛичныеДанныеКандидатов.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТОбразованиеПервое КАК ОбразованиеПервое
	|		ПО ОбразованиеПервое.ЛичныеДанныеКандидата = ЛичныеДанныеКандидатов.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТОбразованиеВторое КАК ОбразованиеВторое
	|		ПО ОбразованиеВторое.ЛичныеДанныеКандидата = ЛичныеДанныеКандидатов.Ссылка";
	
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВТОтборы", ОписательВременныхТаблиц.ИмяВременнойТаблицыОтборов);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаОтборов.ЛичныеДанныеКандидата",
		"ТаблицаОтборов." + ОписательВременныхТаблиц.ИмяПоляОтбора);
		
	ЗарплатаКадрыОбщиеНаборыДанных.ЗаменитьИмяСоздаваемойВременнойТаблицы(Запрос.Текст, "ВТЛичныеДанныеКандидатов",
		ОписательВременныхТаблиц.ИмяСоздаваемойВТ);
	ЗарплатаКадрыОбщиеНаборыДанных.УстановитьВыборкуТолькоРазрешенныхДанных(Запрос.Текст, ТолькоРазрешенные);
	
	ЗарплатаКадрыОбщиеНаборыДанных.ОбъединитьЗапросы(ИтоговыйЗапрос, ЗапросЗнаниеЯзыков);
	ЗарплатаКадрыОбщиеНаборыДанных.ОбъединитьЗапросы(ИтоговыйЗапрос, ЗапросОбразование);
	ЗарплатаКадрыОбщиеНаборыДанных.ОбъединитьЗапросы(ИтоговыйЗапрос, Запрос);

	ТаблицыКУничтожению = Новый Массив;
	ТаблицыКУничтожению.Добавить("ВТКонтактнаяИнформация");
	ТаблицыКУничтожению.Добавить("ВТЗнаниеЯзыковКандидатов");
	ТаблицыКУничтожению.Добавить("ВТЗнаниеЯзыкаКандидатов");
	ТаблицыКУничтожению.Добавить("ВТСтепеньЗнанияЯзыкаКандидатов");
	ТаблицыКУничтожению.Добавить("ВТСтепеньЗнанияЯзыкаКандидатов1");
	ТаблицыКУничтожению.Добавить("ВТСтепеньЗнанияЯзыкаКандидатов2");
	ТаблицыКУничтожению.Добавить("ВТОбразованиеКандидатовМаксимум");
	ТаблицыКУничтожению.Добавить("ВТОбразование1ПриоритетКодаВидаОбразования");
	ТаблицыКУничтожению.Добавить("ВТОбразованиеПервое");
	ТаблицыКУничтожению.Добавить("ВТОбразование2ПриоритетКодаВидаОбразования");
	ТаблицыКУничтожению.Добавить("ВТОбразованиеВторое");
	
	ЗарплатаКадрыОбщиеНаборыДанных.ДобавитьЗапросыУничтоженияВременныхТаблиц(ИтоговыйЗапрос.Текст, ТаблицыКУничтожению);
	
	Возврат ИтоговыйЗапрос;
	
КонецФункции

