Функция АдресФотографииЛичныхДанныхКандидата(ЛичныеДанныеКандидата) Экспорт
	
	Фотографии = АдресаФотографийЛичныхДанныхКандидатов(ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(
		ЛичныеДанныеКандидата));
	
	Возврат ?(Фотографии[ЛичныеДанныеКандидата] = Неопределено, "", Фотографии[ЛичныеДанныеКандидата]);
	
КонецФункции

Функция АдресаФотографийЛичныхДанныхКандидатов(ЛичныеДанныеКандидатов) Экспорт
	
	Фотографии = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ЛичныеДанныеКандидатов", ЛичныеДанныеКандидатов);
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЛичныеДанныеКандидатов.Ссылка КАК ЛичныеДанныеКандидата,
		|	ЛичныеДанныеКандидатов.Фотография КАК Фотография
		|ИЗ
		|	Справочник.ЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатов
		|ГДЕ
		|	ЛичныеДанныеКандидатов.Ссылка В (&ЛичныеДанныеКандидатов)
		|	И ЛичныеДанныеКандидатов.Фотография <> ЗНАЧЕНИЕ(Справочник.ЛичныеДанныеКандидатовПрисоединенныеФайлы.ПустаяСсылка)";
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Фотографии;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		ДанныеФайла = РаботаСФайлами.ДанныеФайла(Выборка.Фотография,
			Новый Структура("ИдентификаторФормы", Выборка.ЛичныеДанныеКандидата.УникальныйИдентификатор()));
		АдресФотографии = ДанныеФайла.СсылкаНаДвоичныеДанныеФайла;
		Фотографии.Вставить(Выборка.ЛичныеДанныеКандидата, АдресФотографии);
	КонецЦикла;
	
	Возврат Фотографии;
	
КонецФункции

// АПК:299-выкл
Функция АдресФотографииКандидата(Кандидат) Экспорт
	
	Фотографии = АдресаФотографийКандидатов(ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Кандидат));
	
	Возврат ?(Фотографии[Кандидат] = Неопределено, "", Фотографии[Кандидат]);
	
КонецФункции
// АПК:299-вкл

Функция АдресаФотографийКандидатов(Кандидаты) Экспорт
	
	Фотографии = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Кандидаты", Кандидаты);
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Кандидаты.Ссылка КАК Кандидат,
		|	Кандидаты.ЛичныеДанные.Фотография КАК Фотография
		|ИЗ
		|	Справочник.Кандидаты КАК Кандидаты
		|ГДЕ
		|	Кандидаты.Ссылка В (&Кандидаты)
		|	И
		|		Кандидаты.ЛичныеДанные.Фотография <> ЗНАЧЕНИЕ(Справочник.ЛичныеДанныеКандидатовПрисоединенныеФайлы.ПустаяСсылка)";
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Фотографии;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		ДанныеФайла = РаботаСФайлами.ДанныеФайла(Выборка.Фотография,
			Новый Структура("ИдентификаторФормы", Выборка.Кандидат.УникальныйИдентификатор()));
		АдресФотографии = ДанныеФайла.СсылкаНаДвоичныеДанныеФайла;
		Фотографии.Вставить(Выборка.Кандидат, АдресФотографии);
	КонецЦикла;
	
	Возврат Фотографии;
	
КонецФункции

// Дополняет массив объектов метаданных физических лиц.
// 
// Параметры:
//  ОбъектыМетаданныхФизическихЛиц - Массив из ОбъектМетаданных
Процедура ДополнитьОбъектыМетаданныхФизическихЛиц(ОбъектыМетаданныхФизическихЛиц) Экспорт
	ОбъектыМетаданныхФизическихЛиц.Добавить(Метаданные.Справочники.ЛичныеДанныеКандидатов);
КонецПроцедуры

Процедура ДополнитьТекстЗапросаГлобальногоПоискаФизическихЛиц(ТекстЗапроса) Экспорт

	СхемаЗапроса = Новый СхемаЗапроса();
	СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
	
	ПакетЗапроса = СхемаЗапроса.ПакетЗапросов[0];
	ОператорыЗапроса = ПакетЗапроса.Операторы;
	НовыйОператор = ОператорыЗапроса.Добавить(ОператорыЗапроса[0]);
	
	ТаблицаЛичныеДанныеКандидатов = ПакетЗапроса.ДоступныеТаблицы.Найти("Справочник.ЛичныеДанныеКандидатов");
	НовыйОператор.Источники.Заменить(0, ТаблицаЛичныеДанныеКандидатов);
	
	Источник = НовыйОператор.Источники[0].Источник;
	Источник.Псевдоним = "ЛичныеДанныеКандидатов";
	
	ИсточникФизическиеЛицаКандидатов = НовыйОператор.Источники.Добавить("РегистрСведений.ФизическиеЛицаКандидатов",
		"ФизическиеЛицаКандидатов");
	ИсточникФизическиеЛицаКандидатов.Соединения.Очистить();
	ИсточникФизическиеЛицаКандидатов.Соединения.Добавить("ЛичныеДанныеКандидатов");
	ИсточникФизическиеЛицаКандидатов.Соединения[0].ТипСоединения = ТипСоединенияСхемыЗапроса.ПравоеВнешнее;
	
	НовыйОператор.Отбор.Добавить("&УсловияПоиска");
	НовыйОператор.Отбор.Добавить("ФизическиеЛицаКандидатов.ФизическоеЛицо Есть NULL");
	
	ТекстЗапроса = СхемаЗапроса.ПолучитьТекстЗапроса();
	
	УсловияПоиска = "(ЛичныеДанныеКандидатов.ФИО ПОДОБНО &СтрокаПоиска
	|	ИЛИ ДанныеПоискаФизическихЛиц.АдресаЭлектроннойПочты ПОДОБНО &СтрокаПоиска
	|	ИЛИ ДанныеПоискаФизическихЛиц.Телефоны ПОДОБНО &СтрокаПоиска)";
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловияПоиска", УсловияПоиска);
	
КонецПроцедуры

