// Возвращаемое значение:
//	ТаблицаЗначений - Таблица значений, содержащая поля:
//	* ФизическоеЛицо - СправочникСсылка.ФизическиеЛица - физическое лицо сотрудника.
//	* Сотрудник		 - СправочникСсылка.Сотрудники - сотрудник.
//	* Кандидат		 - СправочникСсылка.Кандидаты - приоритетный кандидат по сотруднику.
//	* Вакансия		 - СправочникСсылка.Вакансии - вакансия кандидата.
Функция ТаблицаКандидатыПоСотрудникам()
	
	КандидатыПоСотрудникам = Новый ТаблицаЗначений;
	КандидатыПоСотрудникам.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	КандидатыПоСотрудникам.Колонки.Добавить("Сотрудник", Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
	КандидатыПоСотрудникам.Колонки.Добавить("Кандидат", Новый ОписаниеТипов("СправочникСсылка.Кандидаты"));
	КандидатыПоСотрудникам.Колонки.Добавить("Вакансия", Новый ОписаниеТипов("СправочникСсылка.Вакансии"));
	
	Возврат КандидатыПоСотрудникам;
	
КонецФункции

Процедура ЗаполнитьПолеЕслиНеЗаполнено(Коллекция, ИмяПоля, ЗначениеЗаполнения)
	
	Для Каждого ЭлементКоллекции Из Коллекция Цикл
		Если Не ЗначениеЗаполнено(ЭлементКоллекции[ИмяПоля]) Тогда
			ЭлементКоллекции[ИмяПоля] = ЗначениеЗаполнения;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция ПриоритетКандидата(ДанныеСотрудника, ДанныеКандидата)
	
	ПриоритетКандидата = Неопределено;
	Если ДанныеКандидата.Состояние = Перечисления.СостоянияСогласования.Согласовано
		И ДанныеСотрудника.ДолжностьПоШтатномуРасписанию = ДанныеКандидата.Позиция Тогда
		ПриоритетКандидата = 1;
	ИначеЕсли ДанныеКандидата.Состояние = Перечисления.СостоянияСогласования.Согласовано
		И ДанныеСотрудника.МестоВСтруктуреПредприятия = ДанныеКандидата.Подразделение Тогда
		ПриоритетКандидата = 2;
	ИначеЕсли ДанныеКандидата.Состояние = Перечисления.СостоянияСогласования.Согласовано Тогда
		ПриоритетКандидата = 3;
	Иначе
		ПриоритетКандидата = 4;
	КонецЕсли;
	
	Возврат ПриоритетКандидата;
	
КонецФункции

#КонецОбласти