Функция ЗапросОсновныеСведенияОКандидатах(ОписательВременныхТаблиц, ТолькоРазрешенные) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = ОписательВременныхТаблиц.МенеджерВременныхТаблиц;

	ТекстЗапросаВТКандидаты =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Кандидаты.Ссылка КАК Кандидат,
	|	Кандидаты.Код КАК Код,
	|	Кандидаты.Наименование КАК Наименование,
	|	Кандидаты.ПометкаУдаления КАК ПометкаУдаления,
	|	Кандидаты.Вакансия КАК Вакансия,
	|	Кандидаты.Позиция КАК Позиция,
	|	Кандидаты.Подразделение КАК Подразделение,
	|	Кандидаты.ЛичныеДанные КАК ЛичныеДанныеКандидата,
	|	Кандидаты.ОжидаемыйДоход КАК ОжидаемыйДоход,
	|	Кандидаты.ВалютаДохода КАК ВалютаДохода,
	|	Кандидаты.ПериодичностьДохода КАК ПериодичностьДохода,
	|	Кандидаты.ИсточникИнформации КАК ИсточникИнформации,
	|	Кандидаты.АдресРезюме КАК АдресРезюме,
	|	Кандидаты.ОСебе КАК ОСебе,
	|	Кандидаты.Ответственный КАК Ответственный,
	|	Кандидаты.Ответственный.ФизическоеЛицо КАК ОтветственныйФизическоеЛицо,
	|	Кандидаты.ПричинаОтклонения КАК ПричинаОтклонения,
	|	Кандидаты.СреднийРейтинг КАК СреднийРейтинг,
	|	Кандидаты.Вакансия.ПрофильДолжности КАК ПрофильДолжности,
	|	Кандидаты.Состояние КАК Состояние,
	|	Кандидаты.ДатаРегистрации КАК ДатаРегистрации,
	|	Кандидаты.Рейтинг КАК Рейтинг,
	|	Кандидаты.ДатаРешения КАК ДатаРешения,
	|	Кандидаты.КомментарийРешения КАК КомментарийРешения
	|ПОМЕСТИТЬ ВТКандидаты
	|ИЗ
	|	Справочник.Кандидаты КАК Кандидаты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТОтборы КАК ТаблицаОтборов
	|		По Кандидаты.Ссылка = ТаблицаОтборов.Кандидат";
	
	ТекстЗапросаВТКандидаты = СтрЗаменить(ТекстЗапросаВТКандидаты, "ВТОтборы",
		ОписательВременныхТаблиц.ИмяВременнойТаблицыОтборов);
	ТекстЗапросаВТКандидаты = СтрЗаменить(ТекстЗапросаВТКандидаты, "ТаблицаОтборов.Кандидат",
		"ТаблицаОтборов." + ОписательВременныхТаблиц.ИмяПоляОтбора);
	
	ОписательВТЛичныеДанныеКандидатов = ОписательВременныхТаблицДляСоздатьВТЛичныеДанныеКандидатов(
		ОписательВременныхТаблиц.МенеджерВременныхТаблиц, "ВТКандидаты");
	ЗапросЛичныеДанные = ЗапросЛичныеДанныеКандидатов(ОписательВТЛичныеДанныеКандидатов, ТолькоРазрешенные);
	
	ТекстЗапросаВТСведенияОКандидатах = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	Кандидаты.Кандидат КАК Кандидат,
	|	МАКСИМУМ(ВЫБОР
	|		КОГДА НЕ ОткликиКандидатовНаВакансию.Вакансия ЕСТЬ NULL
	|			ТОГДА ВЫРАЗИТЬ(ОткликиКандидатовНаВакансию.Сообщение КАК СТРОКА(1000))
	|		КОГДА НЕ ОткликиКандидатов.Вакансия ЕСТЬ NULL
	|			ТОГДА ВЫРАЗИТЬ(ОткликиКандидатов.Сообщение КАК СТРОКА(1000))
	|		ИНАЧЕ """"
	|	КОНЕЦ) КАК Письмо
	|ПОМЕСТИТЬ ВТОткликиКандидатов
	|ИЗ
	|	ВТКандидаты КАК Кандидаты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОткликиКандидатов КАК ОткликиКандидатов
	|		ПО Кандидаты.ИсточникИнформации = ОткликиКандидатов.Источник
	|		И (Кандидаты.АдресРезюме = (ВЫРАЗИТЬ(ОткликиКандидатов.АдресРезюме КАК СТРОКА(500))))
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОткликиКандидатов КАК ОткликиКандидатовНаВакансию
	|		ПО Кандидаты.ИсточникИнформации = ОткликиКандидатовНаВакансию.Источник
	|		И Кандидаты.Вакансия = ОткликиКандидатовНаВакансию.Вакансия
	|		И (Кандидаты.АдресРезюме = (ВЫРАЗИТЬ(ОткликиКандидатовНаВакансию.АдресРезюме КАК СТРОКА(500))))
	|СГРУППИРОВАТЬ ПО
	|	Кандидаты.Кандидат
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Кандидаты.Кандидат КАК Кандидат,
	|	Кандидаты.Код КАК Код,
	|	Кандидаты.Наименование КАК Наименование,
	|	Кандидаты.ПометкаУдаления КАК ПометкаУдаления,
	|	Кандидаты.Вакансия КАК Вакансия,
	|	Кандидаты.Позиция КАК Позиция,
	|	Кандидаты.Подразделение КАК Подразделение,
	|	Кандидаты.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата,
	|	Кандидаты.ОжидаемыйДоход КАК ОжидаемыйДоход,
	|	Кандидаты.ВалютаДохода КАК ВалютаДохода,
	|	Кандидаты.ПериодичностьДохода КАК ПериодичностьДохода,
	|	Кандидаты.ИсточникИнформации КАК ИсточникИнформации,
	|	Кандидаты.АдресРезюме КАК АдресРезюме,
	|	Кандидаты.ОСебе КАК ОСебе,
	|	Кандидаты.Ответственный КАК Ответственный,
	|	Кандидаты.ОтветственныйФизическоеЛицо КАК ОтветственныйФизическоеЛицо,
	|	Кандидаты.ПричинаОтклонения КАК ПричинаОтклонения,
	|	Кандидаты.СреднийРейтинг КАК СреднийРейтинг,
	|	Кандидаты.ПрофильДолжности КАК ПрофильДолжности,
	|	Кандидаты.Состояние КАК Состояние,
	|	Кандидаты.ДатаРегистрации КАК ДатаРегистрации,
	|	Кандидаты.Рейтинг КАК Рейтинг,
	|	Кандидаты.ДатаРешения КАК ДатаРешения,
	|	Кандидаты.КомментарийРешения КАК КомментарийРешения,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.ФизическоеЛицо, ЗНАЧЕНИЕ(Справочник.ФизическиеЛица.ПустаяСсылка)) КАК ФизическоеЛицо,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.ФИО, """") КАК ФИО,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.Фамилия, """") КАК Фамилия,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.Имя, """") КАК Имя,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.Отчество, """") КАК Отчество,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.УточнениеНаименования, """") КАК УточнениеНаименования,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.Пол, ЗНАЧЕНИЕ(Перечисление.ПолФизическогоЛица.ПустаяСсылка)) КАК Пол,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.ДатаРождения, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаРождения,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.МестоРождения, """") КАК МестоРождения,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.СостояниеВБраке, ЗНАЧЕНИЕ(Справочник.СостояниеВБраке.ПустаяСсылка)) КАК
	|		СостояниеВБраке,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.Гражданство, ЗНАЧЕНИЕ(Справочник.СтраныМира.ПустаяСсылка)) КАК Гражданство,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.EMailПредставление, """") КАК EMail,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.АдресПредставление, """") КАК Адрес,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.ТелефонПредставление, """") КАК Телефон,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.Возраст, 0) КАК Возраст,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.Язык, ЗНАЧЕНИЕ(Справочник.ЯзыкиНародовМира.ПустаяСсылка)) КАК Язык,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.ВидОбразования, ЗНАЧЕНИЕ(Справочник.ВидыОбразованияФизическихЛиц.ПустаяСсылка)) КАК
	|		ВидОбразования,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.УчебноеЗаведение, ЗНАЧЕНИЕ(Справочник.УчебныеЗаведения.ПустаяСсылка)) КАК
	|		УчебноеЗаведение,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.Факультет, """") КАК Факультет,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.Специальность,
	|		ЗНАЧЕНИЕ(Справочник.КлассификаторСпециальностейПоОбразованию.ПустаяСсылка)) КАК Специальность,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.ГодОкончания, 0) КАК ГодОкончания,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.Образование1ВидОбразования,
	|		ЗНАЧЕНИЕ(Справочник.ВидыОбразованияФизическихЛиц.ПустаяСсылка)) КАК Образование1ВидОбразования,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.Образование1УчебноеЗаведение, ЗНАЧЕНИЕ(Справочник.УчебныеЗаведения.ПустаяСсылка)) КАК
	|		Образование1УчебноеЗаведение,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.Образование1Факультет, """") КАК Образование1Факультет,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.Образование1Специальность,
	|		ЗНАЧЕНИЕ(Справочник.КлассификаторСпециальностейПоОбразованию.ПустаяСсылка)) КАК Образование1Специальность,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.Образование1ГодОкончания, 0) КАК Образование1ГодОкончания,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.Образование2ВидОбразования,
	|		ЗНАЧЕНИЕ(Справочник.ВидыОбразованияФизическихЛиц.ПустаяСсылка)) КАК Образование2ВидОбразования,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.Образование2УчебноеЗаведение, ЗНАЧЕНИЕ(Справочник.УчебныеЗаведения.ПустаяСсылка)) КАК
	|		Образование2УчебноеЗаведение,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.Образование2Факультет, """") КАК Образование2Факультет,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.Образование2Специальность,
	|		ЗНАЧЕНИЕ(Справочник.КлассификаторСпециальностейПоОбразованию.ПустаяСсылка)) КАК Образование2Специальность,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатов.Образование2ГодОкончания, 0) КАК Образование2ГодОкончания,
	|	ЕСТЬNULL(ОткликиКандидатов.Письмо, """") КАК Письмо,
	|	ЕСТЬNULL(ТекущиеЭтапы.ЭтапРаботы, ЗНАЧЕНИЕ(Справочник.ЭтапыРаботыСКандидатами.ПустаяСсылка)) КАК ТекущийЭтап,
	|	ЕСТЬNULL(ТекущиеЭтапы.Состояние, ЗНАЧЕНИЕ(Перечисление.СостоянияЭтаповРаботыСКандидатами.ПустаяСсылка)) КАК
	|		СостояниеЭтапа,
	|	ЕСТЬNULL(ТекущиеЭтапы.ДатаВремя, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаВремяЭтапа,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатовФото.Фотография, НЕОПРЕДЕЛЕНО) КАК ФотографияСсылка,
	|	ЕСТЬNULL(ЛичныеДанныеКандидатовФото.Фотография.ФайлХранилище, НЕОПРЕДЕЛЕНО) КАК ХранилищеФотографии
	|ПОМЕСТИТЬ ВТСведенияОКандидатах
	|ИЗ
	|	ВТКандидаты КАК Кандидаты
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатов
	|		ПО Кандидаты.ЛичныеДанныеКандидата = ЛичныеДанныеКандидатов.ЛичныеДанныеКандидата
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТОткликиКандидатов КАК ОткликиКандидатов
	|		ПО Кандидаты.Кандидат = ОткликиКандидатов.Кандидат
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ТекущиеЭтапыРаботыСКандидатами КАК ТекущиеЭтапы
	|		ПО (ТекущиеЭтапы.Кандидат = Кандидаты.Кандидат)
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатовФото
	|		ПО Кандидаты.ЛичныеДанныеКандидата = ЛичныеДанныеКандидатовФото.Ссылка";
	
	ЗарплатаКадрыОбщиеНаборыДанных.ЗаменитьИмяСоздаваемойВременнойТаблицы(ТекстЗапросаВТСведенияОКандидатах,
		"ВТСведенияОКандидатах", ОписательВременныхТаблиц.ИмяСоздаваемойВТ);
	ЗарплатаКадрыОбщиеНаборыДанных.УстановитьВыборкуТолькоРазрешенныхДанных(ТекстЗапросаВТСведенияОКандидатах,
		ТолькоРазрешенные);
	
	Запрос.Текст = ЗарплатаКадрыОбщиеНаборыДанных.ТекстОбъединенногоЗапроса(ТекстЗапросаВТКандидаты,
		ЗапросЛичныеДанные.Текст, ТекстЗапросаВТСведенияОКандидатах);
	
	ЗарплатаКадрыОбщиеНаборыДанных.СкопироватьПараметрыЗапроса(Запрос, ЗапросЛичныеДанные);
	
	Возврат Запрос;
	
КонецФункции

// Создает временную таблицу с данными об опыте работы кандидатов в ОписательВременныхТаблиц.МенеджерВременныхТаблиц
// 
// Параметры:
//  ОписательВременныхТаблиц - см. ОписательВременныхТаблиц
//  ТолькоРазрешенные - Булево
Процедура СоздатьВТОпытРаботыКандидатов(ОписательВременныхТаблиц, ТолькоРазрешенные) Экспорт
	
	Запрос = ЗапросВТОпытРаботыКандидатов(ОписательВременныхТаблиц, ТолькоРазрешенные);
	Запрос.Выполнить();
	
КонецПроцедуры

// Параметры:
//  ОписательВременныхТаблиц - см. ОписательВременныхТаблиц
//  ТолькоРазрешенные - Булево
// 
// Возвращаемое значение:
//  Запрос
Функция ЗапросВТОпытРаботыКандидатов(ОписательВременныхТаблиц, ТолькоРазрешенные) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = ОписательВременныхТаблиц.МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТаблицаОтборов.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата,
		|	ОпытРаботы.Компания КАК Компания,
		|	ОпытРаботы.ДатаНачала КАК ДатаНачала,
		|	ОпытРаботы.ДатаОкончания КАК ДатаОкончания,
		|	ОпытРаботы.Должность КАК Должность,
		|	ОпытРаботы.Обязанности КАК Обязанности,
		|	ОпытРаботы.СфераДеятельностиКомпании КАК СфераДеятельностиКомпании
		|ПОМЕСТИТЬ ВТОпытРаботыКандидатов
		|ИЗ
		|	ВТОтборы КАК ТаблицаОтборов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЛичныеДанныеКандидатов.ОпытРаботы КАК ОпытРаботы
		|		ПО ТаблицаОтборов.ЛичныеДанныеКандидата = ОпытРаботы.Ссылка";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВТОтборы", ОписательВременныхТаблиц.ИмяВременнойТаблицыОтборов);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаОтборов.ЛичныеДанныеКандидата",
		"ТаблицаОтборов." + ОписательВременныхТаблиц.ИмяПоляОтбора);
	
	ЗарплатаКадрыОбщиеНаборыДанных.ЗаменитьИмяСоздаваемойВременнойТаблицы(Запрос.Текст, "ВТОпытРаботыКандидатов",
		ОписательВременныхТаблиц.ИмяСоздаваемойВТ);
	ЗарплатаКадрыОбщиеНаборыДанных.УстановитьВыборкуТолькоРазрешенныхДанных(Запрос.Текст, ТолькоРазрешенные);
	
	Возврат Запрос;
	
КонецФункции

// Создает временную таблицу с данными об образовании кандидатов в ОписательВременныхТаблиц.МенеджерВременныхТаблиц
// 
// Параметры:
//  ОписательВременныхТаблиц - см. ОписательВременныхТаблиц
//  ТолькоРазрешенные - Булево
Процедура СоздатьВТОбразованиеКандидатов(ОписательВременныхТаблиц, ТолькоРазрешенные) Экспорт
	
	Запрос = ЗапросВТОбразованиеКандидатов(ОписательВременныхТаблиц, ТолькоРазрешенные);
	Запрос.Выполнить();
	
КонецПроцедуры

// Параметры:
//  ОписательВременныхТаблиц - см. ОписательВременныхТаблиц
//  ТолькоРазрешенные - Булево
// 
// Возвращаемое значение:
//  Запрос
Функция ЗапросВТОбразованиеКандидатов(ОписательВременныхТаблиц, ТолькоРазрешенные) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = ОписательВременныхТаблиц.МенеджерВременныхТаблиц;
	
	ВТКУничтожению = Новый Массив;
	ВТКУничтожению.Добавить("ВТОбразованияКандидатовПервые");
	ВТКУничтожению.Добавить("ВТОбразование1ПриоритетВидаОбразования");
	ВТКУничтожению.Добавить("ВТОбразование1ПриоритетГОдаОкончания");
	ВТКУничтожению.Добавить("ВТОбразование1ПриоритетНомераСтроки");
	
	ВТКУничтожению.Добавить("ВТОбразованияКандидатовВторые");
	ВТКУничтожению.Добавить("ВТОбразование2ПриоритетВидаОбразования");
	ВТКУничтожению.Добавить("ВТОбразование2ПриоритетГОдаОкончания");
	ВТКУничтожению.Добавить("ВТОбразование2ПриоритетНомераСтроки");
	
	ЗапросВажностиОбразований = Новый Массив;
	
	ПервыйЗапрос = Истина;
	ВидыОбразованийПоВажности = КадровыйУчетРасширенный.ВидыОбразованийПоВажности();
	Для Индекс = 0 По ВидыОбразованийПоВажности.Количество() - 1 Цикл
		
		Если Не ПервыйЗапрос Тогда
			ЗапросВажностиОбразований.Добавить("ОБЪЕДИНИТЬ");
		КонецЕсли;
		
		ЗапросВажностиОбразований.Добавить("ВЫБРАТЬ
			|	" + Индекс + " КАК Важность,
			|	&ПараметрВТОбразованияФизическихЛиц" + Индекс + " КАК ВидОбразования");
		
		Запрос.УстановитьПараметр("ПараметрВТОбразованияФизическихЛиц" + Индекс, ВидыОбразованийПоВажности[Индекс]);
		
		Если ПервыйЗапрос Тогда
			ЗапросВажностиОбразований.Добавить("ПОМЕСТИТЬ ВТВидыОбразованийПоВажности");
		КонецЕсли;
		
		ПервыйЗапрос = Ложь;
		
	КонецЦикла;
	
	ВТКУничтожению.Добавить("ВТВидыОбразованийПоВажности");
	
	Запрос.Текст =  СтрСоединить(ЗапросВажностиОбразований, Символы.ПС)
		+ ЗарплатаКадрыОбщиеНаборыДанных.РазделительЗапросов() +
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТаблицаОтборов.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата,
		|	Образование.ВидОбразования КАК ВидОбразования,
		|	Образование.УчебноеЗаведение КАК УчебноеЗаведение,
		|	Образование.Факультет КАК Факультет,
		|	Образование.Специальность КАК Специальность,
		|	Образование.ГодОкончания КАК ГодОкончания,
		|	Образование.НомерСтроки
		|ПОМЕСТИТЬ ВТОбразованияКандидатов
		|ИЗ
		|	ВТОтборы КАК ТаблицаОтборов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЛичныеДанныеКандидатов.Образование КАК Образование
		|		ПО ТаблицаОтборов.ЛичныеДанныеКандидата = Образование.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОбразованияКандидатов.ЛичныеДанныеКандидата,
		|	МАКСИМУМ(ОбразованияКандидатов.ВидОбразования) КАК ВидОбразования,
		|	МАКСИМУМ(ОбразованияКандидатов.УчебноеЗаведение) КАК УчебноеЗаведение,
		|	МАКСИМУМ(ОбразованияКандидатов.Факультет) КАК Факультет,
		|	МАКСИМУМ(ОбразованияКандидатов.Специальность) КАК Специальность,
		|	МАКСИМУМ(ОбразованияКандидатов.ГодОкончания) КАК ГодОкончания
		|ПОМЕСТИТЬ ВТОбразованиеКандидатовМаксимум
		|ИЗ
		|	ВТОбразованияКандидатов КАК ОбразованияКандидатов
		|СГРУППИРОВАТЬ ПО
		|	ОбразованияКандидатов.ЛичныеДанныеКандидата
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОбразованияФЛ.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата,
		|	ВЫРАЗИТЬ(ОбразованияФЛ.ВидОбразования КАК Справочник.ВидыОбразованияФизическихЛиц) КАК ВидОбразования,
		|	ОбразованияФЛ.УчебноеЗаведение КАК УчебноеЗаведение,
		|	ОбразованияФЛ.Факультет КАК Факультет,
		|	ОбразованияФЛ.Специальность КАК Специальность,
		|	ОбразованияФЛ.ГодОкончания КАК ГодОкончания,
		|	ОбразованияФЛ.НомерСтроки КАК НомерСтроки,
		|	ЕСТЬNULL(ВидыОбразованийПоВажности.Важность, 0) КАК Важность
		|ПОМЕСТИТЬ ВТОбразованияКандидатовПервые
		|ИЗ
		|	ВТОбразованияКандидатов КАК ОбразованияФЛ
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТВидыОбразованийПоВажности КАК ВидыОбразованийПоВажности
		|		ПО ОбразованияФЛ.ВидОбразования = ВидыОбразованийПоВажности.ВидОбразования
		|ГДЕ
		|	ОбразованияФЛ.ВидОбразования В (ЗНАЧЕНИЕ(Справочник.ВидыОбразованияФизическихЛиц.СреднееПолноеОбщееОбразование),
		|		ЗНАЧЕНИЕ(Справочник.ВидыОбразованияФизическихЛиц.НачальноеПрофессиональноеОбразование),
		|		ЗНАЧЕНИЕ(Справочник.ВидыОбразованияФизическихЛиц.СреднееПрофессиональноеОбразование),
		|		ЗНАЧЕНИЕ(Справочник.ВидыОбразованияФизическихЛиц.ВысшееОбразование),
		|		ЗНАЧЕНИЕ(Справочник.ВидыОбразованияФизическихЛиц.НеполноеВысшееОбразование),
		|		ЗНАЧЕНИЕ(Справочник.ВидыОбразованияФизическихЛиц.ОсновноеОбщееОбразование),
		|		ЗНАЧЕНИЕ(Справочник.ВидыОбразованияФизическихЛиц.ВысшееОбразованиеБакалавриат),
		|		ЗНАЧЕНИЕ(Справочник.ВидыОбразованияФизическихЛиц.ВысшееОбразованиеСпециалитетМагистратура),
		|		ЗНАЧЕНИЕ(Справочник.ВидыОбразованияФизическихЛиц.СреднееОбщееОбразование))
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Образования.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата,
		|	МАКСИМУМ(Образования.Важность) КАК Важность
		|ПОМЕСТИТЬ ВТОбразование1ПриоритетКодаВидаОбразования
		|ИЗ
		|	ВТОбразованияКандидатовПервые КАК Образования
		|СГРУППИРОВАТЬ ПО
		|	Образования.ЛичныеДанныеКандидата
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Образования.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата,
		|	МАКСИМУМ(Образования.ВидОбразования) КАК ВидОбразования,
		|	Образования.Важность КАК Важность
		|ПОМЕСТИТЬ ВТОбразование1ПриоритетВидаОбразования
		|ИЗ
		|	ВТОбразованияКандидатовПервые КАК Образования
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТОбразование1ПриоритетКодаВидаОбразования КАК Образование1ПриоритетКодаВидаОбразования
		|		ПО Образования.ЛичныеДанныеКандидата = Образование1ПриоритетКодаВидаОбразования.ЛичныеДанныеКандидата
		|		И Образования.Важность = Образование1ПриоритетКодаВидаОбразования.Важность
		|СГРУППИРОВАТЬ ПО
		|	Образования.ЛичныеДанныеКандидата,
		|	Образования.Важность
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Образования.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата,
		|	Образования.ВидОбразования КАК ВидОбразования,
		|	МАКСИМУМ(Образования.ГодОкончания) КАК ГодОкончания
		|ПОМЕСТИТЬ ВТОбразование1ПриоритетГодаОкончания
		|ИЗ
		|	ВТОбразованияКандидатовПервые КАК Образования
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТОбразование1ПриоритетВидаОбразования КАК Образование1ПриоритетВидаОбразования
		|		ПО Образования.ЛичныеДанныеКандидата = Образование1ПриоритетВидаОбразования.ЛичныеДанныеКандидата
		|		И Образования.ВидОбразования = Образование1ПриоритетВидаОбразования.ВидОбразования
		|		И Образования.Важность = Образование1ПриоритетВидаОбразования.Важность
		|СГРУППИРОВАТЬ ПО
