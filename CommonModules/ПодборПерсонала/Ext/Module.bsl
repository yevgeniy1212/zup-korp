#Область КандидатыПоСотрудникам

// Возвращает таблицу с кандидатами по сотрудникам, связывая их через решения о приеме на работу.
// Если по такому принципу не удается найти кандидатов для сотрудников, выполняется сопоставление
// при помощи метода ПриоритетныеКандидатыПоСотрудникам(Сотрудники).
//
// Параметры:
//	Сотрудники - Массив Из СправочникСсылка.Сотрудники - сотрудники, по которым необходимо найти кандидатов.
// 
// Возвращаемое значение:
//	ТаблицаЗначений - Таблица значений, содержащая поля:
//	* ФизическоеЛицо - СправочникСсылка.ФизическиеЛица - физическое лицо сотрудника.
//	* Сотрудник		 - СправочникСсылка.Сотрудники - сотрудник.
//	* Кандидат		 - СправочникСсылка.Кандидаты - приоритетный кандидат по сотруднику.
//	* Вакансия		 - СправочникСсылка.Вакансии - вакансия кандидата.
//
Функция КандидатыПоСотрудникам(Сотрудники) Экспорт
	
	КандидатыПоСотрудникам = ТаблицаКандидатыПоСотрудникам();
	
	УстановитьПривилегированныйРежим(Истина);
	РешенияПоСотрудникам =
		РегистрыСведений.СотрудникиПоРешениямОПриемеНаРаботу.РешенияОПриемеНаРаботуПоСотрудникам(Сотрудники);
	УстановитьПривилегированныйРежим(Ложь);
	КандидатыПоРешениям = Документы.РешениеОПриемеНаРаботу.КандидатыПоРешениям(
		ОбщегоНазначения.ВыгрузитьКолонку(РешенияПоСотрудникам, "Значение", Истина));
	ОсновныеСведенияОКандидатах = ОсновныеСведенияОКандидатах(
		ОбщегоНазначения.ВыгрузитьКолонку(КандидатыПоРешениям, "Значение", Истина));
	ОбщегоНазначенияБЗК.ДобавитьИндексКоллекции(ОсновныеСведенияОКандидатах, "Кандидат");
	
	СотрудникиСКандидатами = Новый Массив;
	КандидатыССотрудниками = Новый Массив;
	Для Каждого РешениеПоСотруднику Из РешенияПоСотрудникам Цикл
		Кандидат = КандидатыПоРешениям.Получить(РешениеПоСотруднику.Значение);
		ОсновныеСведенияОКандидате = ОсновныеСведенияОКандидатах.НайтиСтроки(Новый Структура("Кандидат", Кандидат));
		Если ОсновныеСведенияОКандидате.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		КандидатПоСотруднику = КандидатыПоСотрудникам.Добавить();
		КандидатПоСотруднику.Сотрудник = РешениеПоСотруднику.Ключ;
		КандидатПоСотруднику.Кандидат = Кандидат;
		КандидатПоСотруднику.ФизическоеЛицо = ОсновныеСведенияОКандидате[0].ФизическоеЛицо;
		КандидатПоСотруднику.Вакансия = ОсновныеСведенияОКандидате[0].Вакансия;
		СотрудникиСКандидатами.Добавить(КандидатПоСотруднику.Сотрудник);
		КандидатыССотрудниками.Добавить(КандидатПоСотруднику.Кандидат);
	КонецЦикла;
	
	ОставшиесяСотрудники = ОбщегоНазначенияКлиентСервер.РазностьМассивов(Сотрудники, СотрудникиСКандидатами);
	Если ОставшиесяСотрудники.Количество() = 0 Тогда
		Возврат КандидатыПоСотрудникам;
	КонецЕсли;
	
	ПриоритетныеКандидатыПоСотрудникам = ПриоритетныеКандидатыПоСотрудникам(
		ОставшиесяСотрудники,
		СотрудникиСКандидатами,
		КандидатыССотрудниками);
	Для Каждого ПриоритетныйКандидатПоСотруднику Из ПриоритетныеКандидатыПоСотрудникам Цикл
		КандидатПоСотруднику = КандидатыПоСотрудникам.Добавить();
		ЗаполнитьЗначенияСвойств(КандидатПоСотруднику, ПриоритетныйКандидатПоСотруднику);
	КонецЦикла;
	
	Возврат КандидатыПоСотрудникам;
	
КонецФункции

// Возвращает таблицу с кандидатами по сотрудникам, связывая их через физические лица и выбирая лучший приоритет:
//      Приоритеты:
//              1 - Кандидат согласован и его позиция совпадает с должностью по ШР сотрудника;
//              2 - Кандидат согласован и имеет тоже подразделение, что и сотрудник;
//              3 - Кандидат согласован;
//              4 - Все остальные удовлетворяющие вышеперечисленным условиям.
//
// Параметры:
//	Сотрудники - Массив Из СправочникСсылка.Сотрудники - сотрудники, по которым необходимо найти кандидатов.
//	ИсключаемыеСотрудники - Массив Из СправочникСсылка.Сотрудники - сотрудники, которых нужно исключить из анализа.
//	ИсключаемыеКандидаты - Массив Из СправочникСсылка.Кандидаты - кандидаты, которых нужно исключить из анализа.
// 
// Возвращаемое значение:
//	ТаблицаЗначений - Таблица значений, содержащая поля:
//	* ФизическоеЛицо - СправочникСсылка.ФизическиеЛица - физическое лицо сотрудника.
//	* Сотрудник		 - СправочникСсылка.Сотрудники - сотрудник.
//	* Кандидат		 - СправочникСсылка.Кандидаты - приоритетный кандидат по сотруднику.
//	* Вакансия		 - СправочникСсылка.Вакансии - вакансия кандидата.
//
Функция ПриоритетныеКандидатыПоСотрудникам(Сотрудники, ИсключаемыеСотрудники = Неопределено, ИсключаемыеКандидаты = Неопределено) Экспорт
	
	ПриоритетныеКандидатыПоСотрудникам = ТаблицаКандидатыПоСотрудникам();
	
	Если ИсключаемыеКандидаты = Неопределено Тогда
		ИсключаемыеКандидаты = Новый Массив;
	КонецЕсли;
	
	// Получение физических лиц и всех сотрудников по ним с необходимыми кадровыми данными для установления приоритетности.
	// Исключаем уже связанных (по пункуту 1) сотрудников.
	// Упорядочиваем по физическим лицам и по возрастанию даты приема.
	УстановитьПривилегированныйРежим(Истина);
	ФизическиеЛицаСотрудников = КадровыйУчет.ФизическиеЛицаСотрудников(Сотрудники);
	СотрудникиФизическихЛиц = ОбщегоНазначения.ВыгрузитьКолонку(
		КадровыйУчет.СотрудникиФизическихЛиц(ФизическиеЛицаСотрудников), "Сотрудник", Истина);
	Если ИсключаемыеСотрудники <> Неопределено Тогда
		СотрудникиФизическихЛиц = ОбщегоНазначенияКлиентСервер.РазностьМассивов(
			СотрудникиФизическихЛиц,
			ИсключаемыеСотрудники);
	КонецЕсли;
	КадровыеДанныеСотрудников = КадровыйУчет.КадровыеДанныеСотрудников(Истина, СотрудникиФизическихЛиц,
		"ДолжностьПоШтатномуРасписанию, МестоВСтруктуреПредприятия, ДатаПриема, ФизическоеЛицо");
	УстановитьПривилегированныйРежим(Ложь);
	ЗаполнитьПолеЕслиНеЗаполнено(КадровыеДанныеСотрудников, "ДатаПриема", Дата(3999, 12, 31));
	КадровыеДанныеСотрудников.Сортировать("ФизическоеЛицо, ДатаПриема");
	
	// Получение кандидатов по физическим лицам.
	// Исключаем уже связанных (по пункуту 1) кандидатов.
	// Упорядочиваем по физическим лицам и по возрастанию даты утверждения.
	КандидатыФизическихЛиц = КандидатыФизическихЛиц(ФизическиеЛицаСотрудников);
	ОбщегоНазначенияБЗК.ДобавитьИндексКоллекции(КандидатыФизическихЛиц , "ФизическоеЛицо");
	КандидатыФизическихЛиц.Сортировать("ФизическоеЛицо, ДатаРешения");
	
	// Создание таблицы для сотрудников с неоднозначными кандидатами.
	СотрудникиСНесколькимиКандидатами = ТаблицаКандидатыПоСотрудникам();
	СотрудникиСНесколькимиКандидатами.Колонки.Добавить("ПриоритетКандидата", Новый ОписаниеТипов("Число"));
	СотрудникиСНесколькимиКандидатами.Колонки.Добавить("КандидатовПоСотруднику", Новый ОписаниеТипов("Число"));
	СотрудникиСНесколькимиКандидатами.Колонки.Добавить("ДатаУтверждения", Новый ОписаниеТипов("Дата"));
	ОбщегоНазначенияБЗК.ДобавитьИндексКоллекции(СотрудникиСНесколькимиКандидатами, "Кандидат");
	
	// Удаляем помеченных на удаление, отклоненных и связанных кандидатов
	Индекс = КандидатыФизическихЛиц.Количество() - 1;
	Пока Индекс >= 0 Цикл
		ИндексКандидата = ИсключаемыеКандидаты.Найти(КандидатыФизическихЛиц[Индекс].Кандидат);
		Если КандидатыФизическихЛиц[Индекс].ПометкаУдаления
			Или КандидатыФизическихЛиц[Индекс].Состояние = Перечисления.СостоянияСогласования.Отклонено
			Или ИндексКандидата <> Неопределено Тогда
			КандидатыФизическихЛиц.Удалить(КандидатыФизическихЛиц[Индекс]);
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;
	
	ОбходПоСотрудникам = Обработки.ОбходКоллекции.НовыйОбход(КадровыеДанныеСотрудников);
	ОбходПоКандидатам = Обработки.ОбходКоллекции.НовыйОбход(КандидатыФизическихЛиц);
	
	ЛучшийПриоритетКандидатов = Новый Соответствие;
	Пока ОбходПоСотрудникам.СледующийПоЗначениюПоля("ФизическоеЛицо") Цикл
		Пока ОбходПоСотрудникам.Следующий() Цикл
			ТекущиеДанныеСотрудника = ОбходПоСотрудникам.ТекущиеДанные();
			КандидатыСотрудника = Новый Массив;
			// Обход по кандидатам с подходящим физическим лицом
			Пока ОбходПоКандидатам.НайтиСледующий(Новый Структура("ФизическоеЛицо",
				ТекущиеДанныеСотрудника.ФизическоеЛицо)) Цикл
				ТекущиеДанныеКандидата = ОбходПоКандидатам.ТекущиеДанные();
				// Если это кандидат с датой решения большей чем дата приема, можно останавливать цикл
				Если ТекущиеДанныеСотрудника.ДатаПриема < ТекущиеДанныеКандидата.ДатаРешения Тогда
					Прервать;
				КонецЕсли;
				// Сохраняем кандидатов и индексы строк для них
				Кандидат = Новый Структура;
				Кандидат.Вставить("ИндексСтроки", ОбходПоКандидатам.ТекущаяСтрока());
				Кандидат.Вставить("ДанныеКандидата", ТекущиеДанныеКандидата);
				КандидатыСотрудника.Добавить(Кандидат);
			КонецЦикла;
			КандидатовПоСотруднику = КандидатыСотрудника.Количество();
			ИндексКандидата = КандидатовПоСотруднику - 1;
			// Обход кандидатов в обратном порядке по дате утверждения для установки связей
			Пока ИндексКандидата >= 0 Цикл
				ПриоритетКандидата = ПриоритетКандидата(ТекущиеДанныеСотрудника, КандидатыСотрудника[ИндексКандидата].ДанныеКандидата);
				// Если кандидат имеет 1 приоритет, его можно сразу связать с сотрудником и удалить из доступных
				Если ПриоритетКандидата = 1 Тогда
					Если Сотрудники.Найти(ТекущиеДанныеСотрудника.Сотрудник) <> Неопределено Тогда
						КандидатПоСотруднику = ПриоритетныеКандидатыПоСотрудникам.Добавить();
						КандидатПоСотруднику.Сотрудник = ТекущиеДанныеСотрудника.Сотрудник;
						КандидатПоСотруднику.ФизическоеЛицо = ТекущиеДанныеСотрудника.ФизическоеЛицо;
						КандидатПоСотруднику.Кандидат = КандидатыСотрудника[ИндексКандидата].ДанныеКандидата.Кандидат;
						КандидатПоСотруднику.Вакансия = КандидатыСотрудника[ИндексКандидата].ДанныеКандидата.Вакансия;
					КонецЕсли;
					КандидатыФизическихЛиц.Удалить(КандидатыСотрудника[ИндексКандидата].ИндексСтроки);
					//Удаляем все связи с кандидатом, которые установили до этого момента.
					СвязиСКандидатом = СотрудникиСНесколькимиКандидатами.НайтиСтроки(
						Новый Структура("Кандидат", КандидатыСотрудника[ИндексКандидата].ДанныеКандидата.Кандидат));
					Для Каждого СтрокаСвязь Из СвязиСКандидатом Цикл
						СотрудникиСНесколькимиКандидатами.Удалить(СтрокаСвязь);
					КонецЦикла;
					Прервать;
				КонецЕсли;
				// Записываем связь
				СотрудникСНесколькимиКандидатами = СотрудникиСНесколькимиКандидатами.Добавить();
				СотрудникСНесколькимиКандидатами.ФизическоеЛицо = ТекущиеДанныеСотрудника.ФизическоеЛицо;
				СотрудникСНесколькимиКандидатами.Сотрудник = ТекущиеДанныеСотрудника.Сотрудник;
				СотрудникСНесколькимиКандидатами.Кандидат = КандидатыСотрудника[ИндексКандидата].ДанныеКандидата.Кандидат;
				СотрудникСНесколькимиКандидатами.Вакансия = КандидатыСотрудника[ИндексКандидата].ДанныеКандидата.Вакансия;
				СотрудникСНесколькимиКандидатами.ДатаУтверждения =
					КандидатыСотрудника[ИндексКандидата].ДанныеКандидата.ДатаРешения;
				СотрудникСНесколькимиКандидатами.КандидатовПоСотруднику = КандидатовПоСотруднику;
				СотрудникСНесколькимиКандидатами.ПриоритетКандидата = ПриоритетКандидата;
				ИндексКандидата = ИндексКандидата - 1;
				// Запоминаем лучшие приоритеты кандидатов для сотрудников
				ЛучшийПриоритетКандидата = ЛучшийПриоритетКандидатов.Получить(СотрудникСНесколькимиКандидатами.Кандидат);
				Если ЛучшийПриоритетКандидата = Неопределено Или ЛучшийПриоритетКандидата > ПриоритетКандидата Тогда
					ЛучшийПриоритетКандидатов.Вставить(СотрудникСНесколькимиКандидатами.Кандидат, ПриоритетКандидата);
				КонецЕсли;
			КонецЦикла;
			ОбходПоКандидатам.Сбросить();
		КонецЦикла;
	КонецЦикла;
	
	// Если остались неоднозначные связи, сортируем и отбираем приоритетных кандидатов
	Если СотрудникиСНесколькимиКандидатами.Количество() <> 0 Тогда
		СотрудникиСНесколькимиКандидатами.Сортировать(
			"ФизическоеЛицо,
			|КандидатовПоСотруднику,
			|Сотрудник,
			|ПриоритетКандидата,
			|ДатаУтверждения Убыв");
		ОставшиесяКандидаты = КандидатыФизическихЛиц.ВыгрузитьКолонку("Кандидат");
		Обход = Обработки.ОбходКоллекции.НовыйОбход(СотрудникиСНесколькимиКандидатами);
		Пока Обход.СледующийПоЗначениюПоля("Сотрудник") Цикл
			Пока Обход.Следующий() Цикл
				ТекущиеДанные = Обход.ТекущиеДанные();
				ИндексКандидата = ОставшиесяКандидаты.Найти(ТекущиеДанные.Кандидат);
				// Если это не лучший приоритет кандидата для сотрудника, берем следующего
				ЛучшийПриоритетКандидата = ЛучшийПриоритетКандидатов.Получить(ТекущиеДанные.Кандидат);
				Если ИндексКандидата <> Неопределено И ЛучшийПриоритетКандидата = ТекущиеДанные.ПриоритетКандидата Тогда
					Если Сотрудники.Найти(ТекущиеДанные.Сотрудник) <> Неопределено Тогда
						КандидатПоСотруднику = ПриоритетныеКандидатыПоСотрудникам.Добавить();
						ЗаполнитьЗначенияСвойств(КандидатПоСотруднику, ТекущиеДанные);
					КонецЕсли;
					ОставшиесяКандидаты.Удалить(ИндексКандидата);
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
	КонецЕсли;
	
	Возврат ПриоритетныеКандидатыПоСотрудникам;
	
КонецФункции

// Создает временную таблицу с кандидатами по сотрудникам.
//
// Параметры:
//	МенеджерВременныхТаблиц - МенеджерВременныхТаблиц.
//	Сотрудники - Массив, СправочникСсылка.Сотрудники - сотрудники, по которым необходимо найти кандидатов.
//	ИмяВТ - Строка - имя временной таблицы с кандидатами по сотрудникам.
//
Процедура СоздатьВТКандидатыПоСотрудникам(МенеджерВременныхТаблиц, Сотрудники, ИмяВТ ="ВТКандидатыПоСотрудникам") Экспорт
	КандидатыПоСотрудникам = КандидатыПоСотрудникам(Сотрудники);
	ЗарплатаКадры.СоздатьВТПоТаблицеЗначений(МенеджерВременныхТаблиц, КандидатыПоСотрудникам, ИмяВТ);
КонецПроцедуры

// Создает временную таблицу с кандидатами, которые приняты в указанном периоде.
//
// Параметры:
//	МенеджерВременныхТаблиц - МенеджерВременныхТаблиц.
//	НачалоПериода - Дата.
//	ОкончаниеПериода - Дата.
//
Процедура СоздатьВТПринятыеКандидаты(МенеджерВременныхТаблиц, НачалоПериода, ОкончаниеПериода) Экспорт
	
	ПараметрыСотрудников = КадровыйУчет.ПараметрыПолученияСотрудниковОрганизацийПоСпискуФизическихЛиц();
	
	ЗарплатаКадрыОбщиеНаборыДанных.ДобавитьВКоллекциюОтбор(
		ПараметрыСотрудников.Отборы, "ДатаПриема", ">=", НачалоПериода);
	
	ЗарплатаКадрыОбщиеНаборыДанных.ДобавитьВКоллекциюОтбор(
		ПараметрыСотрудников.Отборы, "ДатаПриема", "<=", ОкончаниеПериода);
	
	УстановитьПривилегированныйРежим(Истина);
	Сотрудники = КадровыйУчет.СотрудникиОрганизации(Истина, ПараметрыСотрудников);
	УстановитьПривилегированныйРежим(Ложь);
	
	КандидатыПоСотрудникам = КандидатыПоСотрудникам(Сотрудники.ВыгрузитьКолонку("Сотрудник"));
	ЗарплатаКадры.СоздатьВТПоТаблицеЗначений(МенеджерВременныхТаблиц, КандидатыПоСотрудникам, "ВТПринятыеКандидаты");
	
КонецПроцедуры

// Создает временную таблицу с кандидатами, которые уволены в указанном периоде.
//
// Параметры:
//	МенеджерВременныхТаблиц - МенеджерВременныхТаблиц.
//	НачалоПериода - Дата.
//	ОкончаниеПериода - Дата.
//
Процедура СоздатьВТУволенныеКандидаты(МенеджерВременныхТаблиц, НачалоПериода, ОкончаниеПериода) Экспорт
	
	ПараметрыСотрудников = КадровыйУчет.ПараметрыПолученияСотрудниковОрганизацийПоСпискуФизическихЛиц();
	
	ЗарплатаКадрыОбщиеНаборыДанных.ДобавитьВКоллекциюОтбор(
		ПараметрыСотрудников.Отборы, "ДатаУвольнения", ">=", НачалоПериода);
	
	ЗарплатаКадрыОбщиеНаборыДанных.ДобавитьВКоллекциюОтбор(
		ПараметрыСотрудников.Отборы, "ДатаУвольнения", "<=", ОкончаниеПериода);
	
	УстановитьПривилегированныйРежим(Истина);
	Сотрудники = КадровыйУчет.СотрудникиОрганизации(Истина, ПараметрыСотрудников);
	УстановитьПривилегированныйРежим(Ложь);
	
	КандидатыПоСотрудникам = КандидатыПоСотрудникам(Сотрудники.ВыгрузитьКолонку("Сотрудник"));
	ЗарплатаКадры.СоздатьВТПоТаблицеЗначений(МенеджерВременныхТаблиц, КандидатыПоСотрудникам, "ВТУволенныеКандидаты");
	
КонецПроцедуры

// Получает сотрудников по кандидатам на основании алгоритма, реализованного в КандидатыПоСотрудникам.
// 
// Параметры:
//  Кандидаты - Массив Из СправочникСсылка.Кандидаты
// 
// Возвращаемое значение:
//  Соответствие Из СправочникСсылка.Сотрудники
Функция СотрудникиПоКандидатам(Кандидаты) Экспорт
	
	ФизическиеЛицаКандидатов = Справочники.Кандидаты.ФизическиеЛицаКандидатов(Кандидаты);
	СотрудникиТаблица = КадровыйУчет.СотрудникиФизическихЛиц(
		ОбщегоНазначенияБЗККлиентСервер.ЗначенияСоответствия(ФизическиеЛицаКандидатов));
	
	КандидатыПоСотрудникам = КандидатыПоСотрудникам(СотрудникиТаблица.ВыгрузитьКолонку("Сотрудник"));
	ОбщегоНазначенияБЗК.ДобавитьИндексКоллекции(КандидатыПоСотрудникам, "Кандидат");
	
	СотрудникиПоКандидатам = Новый Соответствие();
	Для Каждого Кандидат Из Кандидаты Цикл
		НайденныеСтроки = КандидатыПоСотрудникам.НайтиСтроки(Новый Структура("Кандидат", Кандидат));
		ОбщегоНазначенияКлиентСервер.Проверить(НайденныеСтроки.Количество() <= 1, 
			СтрШаблон(НСтр("ru = 'Получили более 1 записи с кандидатом %1 по сотрудникам'"), Кандидат), 
			"ПодборПерсонала.СотрудникиПоКандидатам");
		Если НайденныеСтроки.Количество() > 0 Тогда
			СотрудникиПоКандидатам.Вставить(Кандидат, НайденныеСтроки[0].Сотрудник);
		КонецЕсли;
	КонецЦикла;
	
	Возврат СотрудникиПоКандидатам;
	
КонецФункции

#КонецОбласти

#Область Видеоконференции

// Параметры:
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиВидеоконференций
//  Начало - Дата
//  Окончание - Дата
// 
// Возвращаемое значение:
//  Структура:
// * ЕстьПересечения - Булево -
// * Кандидат - Строка -
// * ЭтапРаботы - Строка -
// * Начало - Дата -
// * Окончание - Дата -
Функция ДанныеПересеченияВидеоконференций(УчетнаяЗапись, Начало, Окончание) Экспорт
	
	ДанныеПересечения = Новый Структура();
	ДанныеПересечения.Вставить("ЕстьПересечения", Ложь);
	ДанныеПересечения.Вставить("Кандидат", "");
	ДанныеПересечения.Вставить("ЭтапРаботы", "");
	ДанныеПересечения.Вставить("Начало", Дата(1, 1, 1));
	ДанныеПересечения.Вставить("Окончание", Дата(1, 1, 1));
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПРЕДСТАВЛЕНИЕ(РаботаСКандидатами.Кандидат) КАК Кандидат,
	|	ПРЕДСТАВЛЕНИЕ(РаботаСКандидатами.ЭтапРаботы) КАК ЭтапРаботы,
	|	РаботаСКандидатами.Период КАК Начало,
	|	РаботаСКандидатами.ПериодОкончание КАК Окончание
	|ИЗ
	|	РегистрСведений.РаботаСКандидатами КАК РаботаСКандидатами
	|ГДЕ
	|	РаботаСКандидатами.УчетнаяЗаписьВидеоконференции = &УчетнаяЗапись
	|	И (&НачалоПериода < РаботаСКандидатами.ПериодОкончание
	|	И &КонецПериода > РаботаСКандидатами.Период)";
	
	Запрос.УстановитьПараметр("УчетнаяЗапись", УчетнаяЗапись);
	Запрос.УстановитьПараметр("НачалоПериода", Начало);
	Запрос.УстановитьПараметр("КонецПериода", Окончание);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(ДанныеПересечения, Выборка);
		ДанныеПересечения.ЕстьПересечения = Истина;
	КонецЕсли;
	
	Возврат ДанныеПересечения;
	
КонецФункции

// Параметры:
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиВидеоконференций
//  Кандидат - СправочникСсылка.Кандидаты
// 
// Возвращаемое значение:
//  Массив Из Строка - Массив из идентификаторов видеоконференций
Функция ВидеоконференцииПоКандидату(УчетнаяЗапись, Кандидат) Экспорт
	
	ВидеоконференцииПоКандидату = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	РаботаСКандидатами.ИдентификаторВидеоконференции КАК Идентификатор
	|ИЗ
	|	РегистрСведений.РаботаСКандидатами КАК РаботаСКандидатами
	|ГДЕ
	|	РаботаСКандидатами.Кандидат = &Кандидат
	|	И РаботаСКандидатами.УчетнаяЗаписьВидеоконференции = &УчетнаяЗапись
	|
	|УПОРЯДОЧИТЬ ПО
	|	РаботаСКандидатами.Период УБЫВ";
	
	Запрос.УстановитьПараметр("Кандидат", Кандидат);
	Запрос.УстановитьПараметр("УчетнаяЗапись", УчетнаяЗапись);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.Идентификатор) Тогда
			ВидеоконференцииПоКандидату.Добавить(Выборка.Идентификатор);
		КонецЕсли;
	КонецЦикла;
	
	Возврат ВидеоконференцииПоКандидату;
	
КонецФункции

// Параметры:
//  Кандидат - СправочникСсылка.Кандидаты
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиВидеоконференций
//  Идентификатор - Строка
// 
// Возвращаемое значение:
//  Булево
Функция ОтменитьВидеоконференцииПоКандидату(Кандидат, УчетнаяЗапись, Идентификатор) Экспорт
	
	Результат = Истина;
	
	НачатьТранзакцию();
	Попытка
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.РаботаСКандидатами");
		ЭлементБлокировки.УстановитьЗначение("Кандидат", Кандидат);
		Блокировка.Заблокировать();
		
		Набор = РегистрыСведений.РаботаСКандидатами.СоздатьНаборЗаписей();
		Набор.Отбор.Кандидат.Установить(Кандидат);
		Набор.Прочитать();
		
		Для каждого Запись Из Набор Цикл
			Если Запись.УчетнаяЗаписьВидеоконференции = УчетнаяЗапись
				И Запись.ИдентификаторВидеоконференции = Идентификатор Тогда
				Запись.УчетнаяЗаписьВидеоконференции = Неопределено;
				Запись.ИдентификаторВидеоконференции = Неопределено;
			КонецЕсли;
		КонецЦикла;
		
		Набор.Записать();
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Отмена видеоконференций по кандидату'", ОбщегоНазначения.КодОсновногоЯзыка()), 
			УровеньЖурналаРегистрации.Ошибка,,, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Результат = Ложь;
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

// Возвращает таблицу значений с данными об образовании физического лица.
// 
// Параметры:
//  ФизическоеЛицоСсылка - СправочникСсылка.ФизическиеЛица
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Трудовая деятельность физ лица:
//   * УчебноеЗаведение - СправочникСсылка.УчебныеЗаведения
//   * ВидОбразования - СправочникСсылка.ВидыОбразованияФизическихЛиц
//   * ВидПослевузовскогоОбразования - СправочникСсылка.ВидыОбразованияФизическихЛиц
//   * ВидДополнительногоОбучения - ПеречислениеСсылка.ВидыПрофессиональнойПодготовки
//   * Начало - Дата
//   * Окончание - Дата
//   * Квалификация - Строка
//   * Специальность - СправочникСсылка.КлассификаторСпециальностейПоОбразованию
//   * НаименованиеКурса - Строка
Функция ОбразованиеФизическогоЛица(ФизическоеЛицоСсылка) Экспорт
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ДАТАВРЕМЯ(1, 1, 1) КАК Период,
		|	ФизическиеЛица.Ссылка КАК ФизическоеЛицо
		|ПОМЕСТИТЬ ВТФизическиеЛицаПериоды
		|ИЗ
		|	Справочник.ФизическиеЛица КАК ФизическиеЛица
		|ГДЕ
		|	ФизическиеЛица.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", ФизическоеЛицоСсылка);
	
	Запрос.Выполнить();
	
	ОписаниеВТ = КадровыйУчет.ОписаниеВременнойТаблицыОтборовФизическихЛиц("ВТФизическиеЛицаПериоды");
	
	Запрос = КадровыйУчетРасширенный.ЗапросВТОбразованияФизическихЛиц(Истина, ОписаниеВТ);
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Выполнить();
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Образование.УчебноеЗаведение КАК УчебноеЗаведение,
		|	Образование.ВидОбразования КАК ВидОбразования,
		|	Образование.ВидПослевузовскогоОбразования КАК ВидПослевузовскогоОбразования,
		|	Образование.ВидДополнительногоОбучения КАК ВидДополнительногоОбучения,
		|	Образование.Начало КАК Начало,
		|	Образование.Окончание КАК Окончание,
		|	Образование.Квалификация КАК Квалификация,
		|	Образование.Специальность КАК Специальность,
		|	Образование.НаименованиеКурса КАК НаименованиеКурса
		|ИЗ
		|	ВТОбразованияФизическихЛиц КАК Образование";

	Образование = Запрос.Выполнить().Выгрузить();
	
	Возврат Образование;
	
КонецФункции

// Возвращает таблицу значений с данными о трудовой деятельности физического лица.
// 
// Параметры:
//  ФизическоеЛицоСсылка - СправочникСсылка.ФизическиеЛица
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Трудовая деятельность физ лица:
//   * ДатаНачала - Дата
//   * ДатаОкончания - Дата
//   * Компания - Строка
//   * Должность - Строка
//   * Обязанности - Строка
//   * СфераДеятельностиКомпании - Строка
Функция ТрудоваяДеятельностьФизическогоЛица(ФизическоеЛицоСсылка) Экспорт
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ДАТАВРЕМЯ(1, 1, 1) КАК Период,
		|	ФизическиеЛица.Ссылка КАК ФизическоеЛицо
		|ПОМЕСТИТЬ ВТФизическиеЛицаПериоды
		|ИЗ
		|	Справочник.ФизическиеЛица КАК ФизическиеЛица
		|ГДЕ
		|	ФизическиеЛица.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", ФизическоеЛицоСсылка);
	
	Запрос.Выполнить();
	
	ОписаниеВТ = КадровыйУчет.ОписаниеВременнойТаблицыОтборовФизическихЛиц("ВТФизическиеЛицаПериоды");
	
	Запрос = КадровыйУчетРасширенный.ЗапросВТТрудоваяДеятельностьФизическихЛиц(Истина, ОписаниеВТ);
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Выполнить();
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТрудоваяДеятельность.ДатаНачала КАК ДатаНачала,
		|	ТрудоваяДеятельность.ДатаОкончания КАК ДатаОкончания,
		|	ТрудоваяДеятельность.Организация КАК Компания,
		|	ТрудоваяДеятельность.Должность КАК Должность,
		|	ТрудоваяДеятельность.Обязанности КАК Обязанности,
		|	ТрудоваяДеятельность.СфераДеятельностиКомпании КАК СфераДеятельностиКомпании
		|ИЗ
		|	ВТТрудоваяДеятельностьФизическихЛиц КАК ТрудоваяДеятельность
		|
		|УПОРЯДОЧИТЬ ПО
		|	ТрудоваяДеятельность.ДатаНачала";
	
	ТрудоваяДеятельность = Запрос.Выполнить().Выгрузить();
	
	Возврат ТрудоваяДеятельность;
	
КонецФункции

// Создает временную таблицу ВТЗадублированныеКандидаты в менеджере временных таблиц.
// 
// Параметры:
//  МенеджерВременныхТаблиц  - МенеджерВременныхТаблиц
Процедура СоздатьВТЗадублированныеКандидаты(МенеджерВременныхТаблиц) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ЛичныеДанныеКандидатов.Ссылка КАК ЛичныеДанныеКандидата
		|ПОМЕСТИТЬ ВТОтборы
		|ИЗ
		|	Справочник.ЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатов
		|ГДЕ
		|	НЕ ЛичныеДанныеКандидатов.ПометкаУдаления";
		
	Запрос.Выполнить();
	
	ОписательВТЛичныеДанныеКандидатов = ОписательВременныхТаблицДляСоздатьВТЛичныеДанныеКандидатов(
		МенеджерВременныхТаблиц);
	СоздатьВТЛичныеДанныеКандидатов(ОписательВТЛичныеДанныеКандидатов, Истина);
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ЛичныеДанныеКандидатов.ФИО КАК ФИО,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЛичныеДанныеКандидатов.ЛичныеДанныеКандидата) КАК Количество
		|ПОМЕСТИТЬ ВТЗадублированныеФИО
		|ИЗ
		|	ВТЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатов
		|ГДЕ
		|	ЛичныеДанныеКандидатов.ФИО <> """"
		|
		|СГРУППИРОВАТЬ ПО
		|	ЛичныеДанныеКандидатов.ФИО
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЛичныеДанныеКандидатов.ТелефонПредставление КАК Телефон,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЛичныеДанныеКандидатов.ЛичныеДанныеКандидата) КАК Количество
		|ПОМЕСТИТЬ ВТЗадублированныеТелефоны
		|ИЗ
		|	ВТЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатов
		|ГДЕ
		|	ЛичныеДанныеКандидатов.ТелефонПредставление <> """"
		|
		|СГРУППИРОВАТЬ ПО
		|	ЛичныеДанныеКандидатов.ТелефонПредставление
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЛичныеДанныеКандидатов.EMailПредставление КАК EMail,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЛичныеДанныеКандидатов.ЛичныеДанныеКандидата) КАК Количество
		|ПОМЕСТИТЬ ВТЗадублированныеEMail
		|ИЗ
		|	ВТЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатов
		|ГДЕ
		|	ЛичныеДанныеКандидатов.EMailПредставление <> """"
		|
		|СГРУППИРОВАТЬ ПО
		|	ЛичныеДанныеКандидатов.EMailПредставление
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	&ФИО КАК ОбластьПоиска,
		|	ЗадублированныеФИО.ФИО КАК Значение,
		|	ЛичныеДанныеКандидатов.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата,
		|	ЗадублированныеФИО.ФИО КАК ФИО,
		|	"""" КАК Телефон,
		|	"""" КАК EMail
		|ПОМЕСТИТЬ ВТЗадублированныеКандидаты
		|ИЗ
		|	ВТЗадублированныеФИО КАК ЗадублированныеФИО
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатов
		|		ПО ЗадублированныеФИО.ФИО = ЛичныеДанныеКандидатов.ФИО
		|			И (ЗадублированныеФИО.Количество > 1)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	&Телефон КАК ОбластьПоиска,
		|	ЗадублированныеТелефоны.Телефон КАК Значение,
		|	ЛичныеДанныеКандидатов.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата,
		|	"""" КАК ФИО,
		|	ЗадублированныеТелефоны.Телефон КАК Телефон,
		|	"""" КАК EMail
		|ИЗ
		|	ВТЗадублированныеТелефоны КАК ЗадублированныеТелефоны
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатов
		|		ПО ЗадублированныеТелефоны.Телефон = ЛичныеДанныеКандидатов.ТелефонПредставление
		|			И (ЗадублированныеТелефоны.Количество > 1)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	&EMail КАК ОбластьПоиска,
		|	ЗадублированныеEMail.EMail КАК Значение,
		|	ЛичныеДанныеКандидатов.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата,
		|	"""" КАК ФИО,
		|	"""" КАК Телефон,
		|	ЗадублированныеEMail.EMail КАК EMail
		|ИЗ
		|	ВТЗадублированныеEMail КАК ЗадублированныеEMail
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатов
		|		ПО ЗадублированныеEMail.EMail = ЛичныеДанныеКандидатов.EMailПредставление
		|			И (ЗадублированныеEMail.Количество > 1)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТЛичныеДанныеКандидатов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТЗадублированныеФИО
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТЗадублированныеТелефоны
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТЗадублированныеEMail";
		
	Запрос.УстановитьПараметр("ФИО", НСтр("ru='ФИО'"));
	Запрос.УстановитьПараметр("Телефон", НСтр("ru='Телефон'"));
	Запрос.УстановитьПараметр("EMail", НСтр("ru='E-mail'"));
	
	Запрос.Выполнить();
	
КонецПроцедуры

#Область ИнформацияОКандидате

// Возвращает ссылку на приоритетного кандидата.
// Используется для страницы "О кандидате" справочника "Сотрудники".
// 
// Параметры:
//  Сотрудник - СправочникСсылка.Сотрудники
// 
// Возвращаемое значение:
//  СправочникСсылка.Кандидаты, Неопределено - Кандидат сотрудника
Функция КандидатСотрудника(Сотрудник) Экспорт
	
	ТаблицаКандидатов = КандидатыПоСотрудникам(ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Сотрудник));
	Если ТаблицаКандидатов.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;

	Возврат ТаблицаКандидатов[0].Кандидат;
	
КонецФункции

// Определяет сотрудника по кандидату.
// 
// Параметры:
//  Кандидат - СправочникСсылка.Кандидаты
// 
// Возвращаемое значение:
//  СправочникСсылка.Сотрудники, Неопределено - Сотрудник кандидата
Функция СотрудникКандидата(Кандидат) Экспорт
	Возврат СотрудникиПоКандидатам(ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Кандидат))[Кандидат];
КонецФункции

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Определяет объекты, в которых есть процедура ДобавитьКомандыПечати().
// Подробнее см. УправлениеПечатьюПереопределяемый.
//
// Параметры:
//  СписокОбъектов - Массив - список менеджеров объектов.
//
Процедура ПриОпределенииОбъектовСКомандамиПечати(СписокОбъектов) Экспорт
	
	СписокОбъектов.Добавить(Справочники.Вакансии);
	СписокОбъектов.Добавить(Справочники.Кандидаты);
	СписокОбъектов.Добавить(Справочники.ПрофилиДолжностей);
	СписокОбъектов.Добавить(Документы.ЗаявкаНаПодборПерсонала);
	СписокОбъектов.Добавить(Документы.РасходыНаИсточникИнформацииОКандидатах);
	СписокОбъектов.Добавить(Обработки.ПечатьДолжностнойИнструкции);
	
КонецПроцедуры

Функция СклонениеКандидата(Кандидат, Падеж) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Кандидат", Кандидат);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЛичныеДанныеКандидатов.Ссылка КАК ФизическоеЛицо,
		|	ЛичныеДанныеКандидатов.ФИО КАК ФИО,
		|	ЛичныеДанныеКандидатов.Фамилия КАК Фамилия,
		|	ЛичныеДанныеКандидатов.Имя КАК Имя,
		|	ЛичныеДанныеКандидатов.Отчество КАК Отчество,
		|	ЛичныеДанныеКандидатов.Инициалы КАК Инициалы,
		|	ЛичныеДанныеКандидатов.Пол КАК Пол
		|ИЗ
		|	Справочник.ЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Кандидаты КАК Кандидаты
		|		ПО (Кандидаты.ЛичныеДанные = ЛичныеДанныеКандидатов.Ссылка)
		|		И (Кандидаты.Ссылка = &Кандидат)";
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	
	СклонениеКандидата = "";
	ФизическиеЛицаЗарплатаКадры.Просклонять(Выборка.ФИО, Падеж, СклонениеКандидата, Выборка.Пол, Выборка.ФизическоеЛицо);
	
	Возврат ФизическиеЛицаКлиентСервер.ФамилияИнициалы(СклонениеКандидата);
	
КонецФункции

Процедура УстановитьРешениеПоКандидатам(Кандидаты, РезультатВыбора) Экспорт
	
	// Все сопряженные действия выполняем целостно.
	НачатьТранзакцию();
	Попытка
		УстановитьСостояниеКандидатов(Кандидаты, РезультатВыбора);
		ЗакрытьВакансииКандидатов(Кандидаты, РезультатВыбора);
		ОтправитьСообщенияОПринятомРешении(РезультатВыбора);
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры

Процедура ОтменитьРешениеПоКандидатам(Кандидаты) Экспорт
	
	Для Каждого Кандидат Из Кандидаты Цикл
		Справочники.Кандидаты.УстановитьРешениеПоКандидату(Кандидат, Перечисления.СостоянияСогласования.ПустаяСсылка());
	КонецЦикла;
	
КонецПроцедуры

Процедура УстановитьСостояниеКандидатов(Кандидаты, РезультатВыбора)
	
	ДеталиРешения = РезультатВыбора.Решение;
	
	// Устанавливаем решение выбранным кандидатам.
	ПараметрыРешения = Справочники.Кандидаты.ДополнительныеПараметрыРешенияПоКандидату();
	ПараметрыРешения.КомментарийРешения = ДеталиРешения.Комментарий;
	ПараметрыРешения.ПричинаОтклонения = ДеталиРешения.Причина;
	ПараметрыРешения.ГруппаДоступаФизическогоЛица = РезультатВыбора.ГруппаДоступа;
	Для Каждого Кандидат Из Кандидаты Цикл
		Справочники.Кандидаты.УстановитьРешениеПоКандидату(Кандидат, ДеталиРешения.Решение, ДеталиРешения.ДатаРешения,
			ПараметрыРешения);
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗакрытьВакансииКандидатов(Кандидаты, РезультатВыбора)
	
	// Если указано - закрываем вакансию.
	Если РезультатВыбора.Вакансия.ЗакрыватьВакансию = Истина Тогда
		Вакансии = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(РезультатВыбора.Вакансия.Вакансия);
		Справочники.Вакансии.ЗакрытьВакансии(Вакансии, РезультатВыбора.Вакансия.Дата);
	КонецЕсли;
	
	// Если указано - отклоняем других кандидатов.
	Если РезультатВыбора.ДругиеКандидаты.Отклонять = Истина Тогда
		Для Каждого СтрокаКоллекции Из РезультатВыбора.ДругиеКандидаты.Кандидаты Цикл
			ПараметрыРешения = Справочники.Кандидаты.ДополнительныеПараметрыРешенияПоКандидату();
			ПараметрыРешения.ПричинаОтклонения = СтрокаКоллекции.ПричинаОтклонения;
			Справочники.Кандидаты.УстановитьРешениеПоКандидату(
				СтрокаКоллекции.Кандидат, Перечисления.СостоянияСогласования.Отклонено, РезультатВыбора.ДругиеКандидаты.Дата, ПараметрыРешения);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОтправитьСообщенияОПринятомРешении(РезультатВыбора)
	
	Отказ = Ложь;
	
	Если РезультатВыбора.ПисьмоОдобрение.Написать = Истина Тогда
		Для Каждого Получатель Из РезультатВыбора.ПисьмоОдобрение.Получатели Цикл
			СформироватьСообщениеИОтправить(РезультатВыбора.ПисьмоОдобрение.Шаблон, Получатель, Отказ);
		КонецЦикла;
	КонецЕсли;
	
	Если РезультатВыбора.СообщениеSMSОдобрение.Написать = Истина Тогда
		Для Каждого Получатель Из РезультатВыбора.СообщениеSMSОдобрение.Получатели Цикл
			СформироватьСообщениеИОтправить(РезультатВыбора.СообщениеSMSОдобрение.Шаблон, Получатель, Отказ);
		КонецЦикла;
	КонецЕсли;
	
	Если РезультатВыбора.ПисьмоОтказ.Написать = Истина Тогда
		Для Каждого Получатель Из РезультатВыбора.ПисьмоОтказ.Получатели Цикл
			СформироватьСообщениеИОтправить(РезультатВыбора.ПисьмоОтказ.Шаблон, Получатель, Отказ);
		КонецЦикла;
	КонецЕсли;
	
	Если РезультатВыбора.СообщениеSMSОтказ.Написать = Истина Тогда
		Для Каждого Получатель Из РезультатВыбора.СообщениеSMSОтказ.Получатели Цикл
			СформироватьСообщениеИОтправить(РезультатВыбора.СообщениеSMSОтказ.Шаблон, Получатель, Отказ);
		КонецЦикла;
	КонецЕсли;
	
	Если Отказ Тогда
		ТекстСообщения = НСтр("ru = 'Не удалось отправить одно или несколько сообщений кандидатам'");
		ВызватьИсключение ТекстСообщения;
	КонецЕсли;
	
КонецПроцедуры

Функция ОписаниеКандидатаДляСтрокиИсторииВзаимоотношений(СтрокаДанных)

	ПараметрыШаблона = Новый Структура(
		"Вакансия,
		|Подразделение,
		|Ответственный");
	ЗаполнитьЗначенияСвойств(ПараметрыШаблона, СтрокаДанных);
	Если ЗначениеЗаполнено(СтрокаДанных.ОтветственныйФизическоеЛицо) Тогда
		ПараметрыШаблона["Ответственный"] = ФизическиеЛицаЗарплатаКадрыКлиентСервер.ФамилияИнициалы(
			Строка(СтрокаДанных.ОтветственныйФизическоеЛицо));
	КонецЕсли;

	Если Перечисления.СостоянияСогласования.РешениеПринято(СтрокаДанных.Состояние) Тогда
		ПараметрыШаблона.Вставить("ДатаРешения", Формат(СтрокаДанных.ДатаРешения, "ДЛФ=D;"));
		Если СтрокаДанных.Состояние = Перечисления.СостоянияСогласования.Отклонено Тогда
			Шаблон = НСтр("ru = 'Кандидат отклонен [ДатаРешения] по вакансии «[Вакансия]», отв. [Ответственный]'");
			Если ЗначениеЗаполнено(СтрокаДанных.ПричинаОтклонения) Тогда
				Шаблон = Шаблон + " " + НСтр("ru = 'по причине «[Причина]»'");
				ПараметрыШаблона.Вставить("Причина", СтрокаДанных.ПричинаОтклонения);
			КонецЕсли;
			Если ЗначениеЗаполнено(СтрокаДанных.КомментарийРешения) Тогда
				Шаблон = Шаблон + ", " + НСтр("ru = 'с комментарием: «[КомментарийРешения]»'");
				ПараметрыШаблона.Вставить("КомментарийРешения", СтрокаДанных.КомментарийРешения);
			КонецЕсли;
		ИначеЕсли СтрокаДанных.Состояние = Перечисления.СостоянияСогласования.Согласовано Тогда
			Шаблон = НСтр("ru = 'Кандидат утвержден [ДатаРешения] на вакансию «[Вакансия]», отв. [Ответственный]'");
		КонецЕсли;
	Иначе
		ПараметрыШаблона.Вставить("ДатаРегистрации", Формат(СтрокаДанных.ДатаРегистрации, "ДЛФ=D;"));
		Шаблон = НСтр(
			"ru = 'Кандидат в работе на вакансию «[Вакансия]», поступил [ДатаРегистрации], отв. [Ответственный]'");
		Если Не ЗначениеЗаполнено(ПараметрыШаблона["Вакансия"]) Тогда
			Шаблон = НСтр(
				"ru = 'Кандидат в работе, подразделение «[Подразделение]», поступил [ДатаРегистрации], отв. [Ответственный]'");
		КонецЕсли;
	КонецЕсли;
	
	Возврат СтроковыеФункцииКлиентСервер.ВставитьПараметрыВСтроку(Шаблон, ПараметрыШаблона);

КонецФункции

Процедура ЗаполнитьНаборЗначенийДоступаВзаимодействияСПредметомКандидатом(Объект, Таблица)
	
	Предмет = ?(Объект.ДополнительныеСвойства.Свойство("Предмет"), 
		Объект.ДополнительныеСвойства.Предмет, Взаимодействия.ПредметВзаимодействия(Объект.Ссылка));
	Если ТипЗнч(Предмет) <> Тип("СправочникСсылка.Кандидаты") Или Не ЗначениеЗаполнено(Предмет) Тогда
		Возврат;
	КонецЕсли;
	
	Взаимодействия.ЗаполнитьНаборыЗначенийДоступаПоУмолчанию(Объект, Таблица);

	НоваяТаблица = УправлениеДоступом.ТаблицаНаборыЗначенийДоступа();
	НоваяТаблица.Добавить().ЗначениеДоступа = Справочники.Кандидаты.ФизическоеЛицоКандидата(Предмет);

	УправлениеДоступом.ДобавитьНаборыЗначенийДоступа(Таблица, НоваяТаблица);
	
КонецПроцедуры

Процедура ДобавитьСтрокуВИсториюВзаимоотношений(Взаимоотношения, СтрокаДанных)
	
	НоваяСтрока = Взаимоотношения.Добавить();
	НоваяСтрока.Ссылка = СтрокаДанных.Кандидат;
	НоваяСтрока.Кандидат = СтрокаДанных.Кандидат;
	НоваяСтрока.ЛичныеДанныеКандидата = СтрокаДанных.ЛичныеДанныеКандидата;
	НоваяСтрока.Роль = СотрудникиФормы.РолиФизическогоЛицаИсторииВзаимоотношений().Кандидат;
	НоваяСтрока.ГруппаРоли = СотрудникиФормы.РолиФизическогоЛицаИсторииВзаимоотношений().Кандидат;
	НоваяСтрока.ДатаАктуальности = СтрокаДанных.ДатаРегистрации;
	Если Перечисления.СостоянияСогласования.РешениеПринято(СтрокаДанных.Состояние) Тогда
		НоваяСтрока.ДатаАктуальности = СтрокаДанных.ДатаРешения;
	КонецЕсли;
	НоваяСтрока.Примечание = ОписаниеКандидатаДляСтрокиИсторииВзаимоотношений(СтрокаДанных);
	
КонецПроцедуры

Процедура УстановитьНаименованиеКандидата(Выборка, Фамилия, Имя, Отчество, УточнениеНаименования)
	
	Если ЗначениеЗаполнено(Выборка.Наименование) Тогда
		СтруктураФИО = ФизическиеЛицаКлиентСервер.ЧастиИмени(Выборка.Наименование);
		ОбъектНаименование = СтруктураФИО.Фамилия + " " + СтруктураФИО.Имя + " " + СтруктураФИО.Отчество;
	Иначе
		ОбъектНаименование = "";
	КонецЕсли;
	
	ПолноеНаименование = КадровыйУчетКлиентСервер.ПолноеНаименованиеСотрудника(Фамилия, Имя, Отчество,
		УточнениеНаименования, Выборка.УточнениеНаименования);
	
	Если СокрЛП(ОбъектНаименование) = ПолноеНаименование Тогда
		Возврат;
	КонецЕсли;
	
	Объект = Выборка.Кандидат.ПолучитьОбъект();
	Попытка 
		Объект.Заблокировать();
	Исключение
