Функция ЗапросВТКурсыКандидатов(ОписательВременныхТаблиц, ТолькоРазрешенные) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = ОписательВременныхТаблиц.МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТаблицаОтборов.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата,
		|	Курсы.НаименованиеКурса КАК НаименованиеКурса,
		|	Курсы.УчебноеЗаведение КАК УчебноеЗаведение,
		|	Курсы.ГодОкончания КАК ГодОкончания,
		|	Курсы.ДополнительнаяИнформация КАК ДополнительнаяИнформация
		|ПОМЕСТИТЬ ВТКурсыКандидатов
		|ИЗ
		|	ВТОтборы КАК ТаблицаОтборов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЛичныеДанныеКандидатов.Курсы КАК Курсы
		|		ПО ТаблицаОтборов.ЛичныеДанныеКандидата = Курсы.Ссылка";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВТОтборы", ОписательВременныхТаблиц.ИмяВременнойТаблицыОтборов);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаОтборов.ЛичныеДанныеКандидата",
		"ТаблицаОтборов." + ОписательВременныхТаблиц.ИмяПоляОтбора);
	
	ЗарплатаКадрыОбщиеНаборыДанных.ЗаменитьИмяСоздаваемойВременнойТаблицы(Запрос.Текст, "ВТКурсыКандидатов",
		ОписательВременныхТаблиц.ИмяСоздаваемойВТ);
	ЗарплатаКадрыОбщиеНаборыДанных.УстановитьВыборкуТолькоРазрешенныхДанных(Запрос.Текст, ТолькоРазрешенные);
	
	Возврат Запрос;
	
КонецФункции

