		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНаименованиеСтепениЗнанияЯзыкаКандидатов1 КАК НаименованиеСтепениЗнанияЯзыка1
		|		ПО ЗнаниеЯзыков.ЛичныеДанныеКандидата = НаименованиеСтепениЗнанияЯзыка1.ЛичныеДанныеКандидата
		|		И ЗнаниеЯзыков.СтепеньЗнанияЯзыка.Наименование = НаименованиеСтепениЗнанияЯзыка1.СтепеньЗнанияЯзыкаНаименование
		|СГРУППИРОВАТЬ ПО
		|	ЗнаниеЯзыков.ЛичныеДанныеКандидата,
		|	ЗнаниеЯзыков.СтепеньЗнанияЯзыка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗнаниеЯзыков.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата,
		|	МАКСИМУМ(ЗнаниеЯзыков.СтепеньЗнанияЯзыка.Наименование) КАК СтепеньЗнанияЯзыкаНаименование
		|ПОМЕСТИТЬ ВТНаименованиеСтепениЗнанияЯзыкаКандидатов2
		|ИЗ
		|	ВТЗнаниеЯзыковКандидатов КАК ЗнаниеЯзыков
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтепеньЗнанияЯзыкаКандидатов1 КАК СтепеньЗнанияЯзыка1
		|		ПО ЗнаниеЯзыков.ЛичныеДанныеКандидата = СтепеньЗнанияЯзыка1.ЛичныеДанныеКандидата
		|		И ЗнаниеЯзыков.Язык = СтепеньЗнанияЯзыка1.Язык
		|		И ЗнаниеЯзыков.СтепеньЗнанияЯзыка = СтепеньЗнанияЯзыка1.СтепеньЗнанияЯзыка
		|ГДЕ
		|	СтепеньЗнанияЯзыка1.Язык ЕСТЬ NULL
		|СГРУППИРОВАТЬ ПО
		|	ЗнаниеЯзыков.ЛичныеДанныеКандидата
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗнаниеЯзыков.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата,
		|	МАКСИМУМ(ЗнаниеЯзыков.Язык) КАК Язык,
		|	ЗнаниеЯзыков.СтепеньЗнанияЯзыка КАК СтепеньЗнанияЯзыка
		|ПОМЕСТИТЬ ВТСтепеньЗнанияЯзыкаКандидатов2
		|ИЗ
		|	ВТЗнаниеЯзыковКандидатов КАК ЗнаниеЯзыков
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНаименованиеСтепениЗнанияЯзыкаКандидатов2 КАК НаименованиеСтепениЗнанияЯзыка2
		|		ПО ЗнаниеЯзыков.ЛичныеДанныеКандидата = НаименованиеСтепениЗнанияЯзыка2.ЛичныеДанныеКандидата
		|		И ЗнаниеЯзыков.СтепеньЗнанияЯзыка.Наименование = НаименованиеСтепениЗнанияЯзыка2.СтепеньЗнанияЯзыкаНаименование
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтепеньЗнанияЯзыкаКандидатов1 КАК СтепеньЗнанияЯзыка1
		|		ПО ЗнаниеЯзыков.ЛичныеДанныеКандидата = СтепеньЗнанияЯзыка1.ЛичныеДанныеКандидата
		|		И ЗнаниеЯзыков.Язык = СтепеньЗнанияЯзыка1.Язык
		|ГДЕ
		|	СтепеньЗнанияЯзыка1.Язык ЕСТЬ NULL
		|СГРУППИРОВАТЬ ПО
		|	ЗнаниеЯзыков.ЛичныеДанныеКандидата,
		|	ЗнаниеЯзыков.СтепеньЗнанияЯзыка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТНаименованиеСтепениЗнанияЯзыкаКандидатов1
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТНаименованиеСтепениЗнанияЯзыкаКандидатов2";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВТОтборы", ОписательВременныхТаблиц.ИмяВременнойТаблицыОтборов);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаОтборов.ЛичныеДанныеКандидата",
		"ТаблицаОтборов." + ОписательВременныхТаблиц.ИмяПоляОтбора);
	
	ЗарплатаКадрыОбщиеНаборыДанных.ЗаменитьИмяСоздаваемойВременнойТаблицы(Запрос.Текст, "ВТЗнаниеЯзыковКандидатов",
		ОписательВременныхТаблиц.ИмяСоздаваемойВТ);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "	ВТЗнаниеЯзыковКандидатов КАК",
		СтрШаблон("	%1 КАК", ОписательВременныхТаблиц.ИмяСоздаваемойВТ));
	ЗарплатаКадрыОбщиеНаборыДанных.УстановитьВыборкуТолькоРазрешенныхДанных(Запрос.Текст, ТолькоРазрешенные);
	
	Возврат Запрос;
	
КонецФункции

// Создает временную таблицу с данными о дополнительной контактной информации кандидатов
// в ОписательВременныхТаблиц.МенеджерВременныхТаблиц
// 
// Параметры:
//  ОписательВременныхТаблиц - см. ОписательВременныхТаблиц
//  ТолькоРазрешенные - Булево
Процедура СоздатьВТДополнительныеКонтактыКандидатов(ОписательВременныхТаблиц, ТолькоРазрешенные) Экспорт
	
	Запрос = ЗапросВТДополнительныеКонтактыКандидатов(ОписательВременныхТаблиц, ТолькоРазрешенные);
	Запрос.Выполнить();
	
КонецПроцедуры

// Параметры:
//  ОписательВременныхТаблиц - см. ОписательВременныхТаблиц
//  ТолькоРазрешенные - Булево
// 
// Возвращаемое значение:
//  Запрос
Функция ЗапросВТДополнительныеКонтактыКандидатов(ОписательВременныхТаблиц, ТолькоРазрешенные) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = ОписательВременныхТаблиц.МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ТаблицаОтборов.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата,
		|	КонтактнаяИнформация.Тип КАК Тип,
		|	КонтактнаяИнформация.Вид КАК Вид,
		|	КонтактнаяИнформация.Представление КАК Представление
		|ПОМЕСТИТЬ ВТДополнительныеКонтактыКандидатов
		|ИЗ
		|	ВТОтборы КАК ТаблицаОтборов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЛичныеДанныеКандидатов.КонтактнаяИнформация КАК КонтактнаяИнформация
		|		ПО ТаблицаОтборов.ЛичныеДанныеКандидата = КонтактнаяИнформация.Ссылка
		|ГДЕ
		|	НЕ КонтактнаяИнформация.Вид.Предопределенный";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВТОтборы", ОписательВременныхТаблиц.ИмяВременнойТаблицыОтборов);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ТаблицаОтборов.ЛичныеДанныеКандидата",
		"ТаблицаОтборов." + ОписательВременныхТаблиц.ИмяПоляОтбора);
	
	ЗарплатаКадрыОбщиеНаборыДанных.ЗаменитьИмяСоздаваемойВременнойТаблицы(Запрос.Текст, "ВТДополнительныеКонтактыКандидатов",
		ОписательВременныхТаблиц.ИмяСоздаваемойВТ);
	ЗарплатаКадрыОбщиеНаборыДанных.УстановитьВыборкуТолькоРазрешенныхДанных(Запрос.Текст, ТолькоРазрешенные);
	
	Возврат Запрос;
	
КонецФункции

#КонецОбласти
// АПК:581-вкл.

#Область КонтрольВеденияУчета

// См. КонтрольВеденияУчетаПереопределяемый.ПриОпределенииПроверок.
Процедура ОпределитьПроверкиВеденияУчета(ГруппыПроверок, Проверки) Экспорт
	
	ГруппаПроверок = ГруппыПроверок.Добавить();
	ГруппаПроверок.Наименование					= НСтр("ru = 'Подбор персонала'");
	ГруппаПроверок.Идентификатор				= "КонтрольПодбораПерсонала";
	ГруппаПроверок.КонтекстПроверокВеденияУчета	= ГруппаПроверок.Идентификатор;
	
	Проверка = Проверки.Добавить();
	Проверка.ИдентификаторГруппы			= ГруппаПроверок.Идентификатор;
	Проверка.Наименование					= НСтр("ru = 'Наличие кандидатов, задержавшихся на одном этапе'");
	Проверка.Причины						= НСтр("ru = 'Кандидат долгое время находится на одном этапе'");
	Проверка.Рекомендация					= НСтр("ru = 'Продолжить работу с кандидатом или отклонить его (если работа завершена)'");
	Проверка.Идентификатор					= ГруппаПроверок.Идентификатор + ".ПроверкаНаличияЗадержавшихсяКандидатов";
	Проверка.ОбработчикПроверки				= "ПодборПерсоналаПроверки.ПроверкаНаличияЗадержавшихсяКандидатов";
	Проверка.КонтекстПроверокВеденияУчета	= ГруппаПроверок.КонтекстПроверокВеденияУчета;
	
КонецПроцедуры

#КонецОбласти

Функция ЗапросПоПредставлению(ИмяПредставления, ПараметрыЗапросаКомпоновки, ТолькоРазрешенные) Экспорт
	
	Запрос = Неопределено;
	
	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьПодборПерсонала") Тогда
		Возврат Запрос;
	КонецЕсли;
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц();
	Если ВРег(ИмяПредставления) = ВРег("СведенияОКандидатах") Тогда
		ОписательВременныхТаблиц = ОписательВременныхТаблицДляСоздатьВТОсновныеСведенияОКандидатах(
			МенеджерВременныхТаблиц, , "Представления_СведенияОКандидатах");
		Запрос = ЗапросОсновныеСведенияОКандидатах(ОписательВременныхТаблиц, ТолькоРазрешенные);
	ИначеЕсли ВРег(ИмяПредставления) = ВРег("ЛичныеДанныеКандидатов") Тогда
		ОписательВременныхТаблиц = ОписательВременныхТаблицДляСоздатьВТЛичныеДанныеКандидатов(
			МенеджерВременныхТаблиц, , "Представления_ЛичныеДанныеКандидатов");
		Запрос = ЗапросЛичныеДанныеКандидатов(ОписательВременныхТаблиц, ТолькоРазрешенные);
	ИначеЕсли ВРег(ИмяПредставления) = ВРег("СтажПринятыхКандидатов") Тогда
		Запрос = ЗапросСтажПринятыхКандидатов();
	КонецЕсли;
	
	Возврат Запрос;
	
КонецФункции

// Формирует временную таблицу с вакансиями, соответствующими отбору.
// 
// Параметры:
// 	МенеджерВременныхТаблиц - МенеджерВременныхТаблиц, Неопределено - Описание
// 	Отбор - Структура - значения отбора,
// 	ТолькоРазрешенные - Булево - Описание, если Истина, в таблицу будут включены вакансии, доступные текущему пользователю.
//
Процедура СоздатьВТВакансииПоОтбору(МенеджерВременныхТаблиц, Отбор, ТолькоРазрешенные = Истина) Экспорт
	Справочники.Вакансии.СоздатьВТВакансииПоОтбору(МенеджерВременныхТаблиц, Отбор, ТолькоРазрешенные);
КонецПроцедуры

// Добавляет в таблицу взаимоотношений сведения о кандидатах физических лиц.
// 
// Параметры:
// 	Взаимоотношения - ТаблицаЗначений:
//   * ФизическоеЛицо - СправочникСсылка.ФизическиеЛица -
//   * Ссылка - СправочникСсылка -
//   * Примечание - Строка -
//   * Роль - Число -
//   * ГруппаРоли - Число -
//   * ДатаАктуальности - Дата -
//	ОбъектыВзаимоотношений - Массив.
Процедура ДополнитьИсториюВзаимоотношенийКандидатамиПоФизическимЛицам(Взаимоотношения, ОбъектыВзаимоотношений) Экспорт
	
	ФизическиеЛица = ОбщегоНазначения.СкопироватьРекурсивно(ОбъектыВзаимоотношений);
	ОбщегоНазначенияБЗККлиентСервер.УдалитьВсеВхожденияКромеТипаИзМассива(ФизическиеЛица,
		Тип("СправочникСсылка.ФизическиеЛица"));
	
	Если ФизическиеЛица.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	Кандидаты = КандидатыФизическихЛиц(ФизическиеЛица).ВыгрузитьКолонку("Кандидат");
	ДополнитьИсториюВзаимоотношенийКандидатами(Взаимоотношения, Кандидаты);
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

// Добавляет в таблицу взаимоотношений сведения о кандидатах по личным данным кандидатов.
// 
// Параметры:
// 	Взаимоотношения - ТаблицаЗначений:
//   * ФизическоеЛицо - СправочникСсылка.ФизическиеЛица -
//   * Ссылка - СправочникСсылка -
//   * Примечание - Строка -
//   * Роль - Число -
//   * ГруппаРоли - Число -
//   * ДатаАктуальности - Дата -
//	ОбъектыВзаимоотношений - Массив.
Процедура ДополнитьИсториюВзаимоотношенийКандидатамиПоЛичнымДанным(Взаимоотношения, ОбъектыВзаимоотношений) Экспорт
	
	ЛичныеДанныеКандидатов = ОбщегоНазначения.СкопироватьРекурсивно(ОбъектыВзаимоотношений);
	ОбщегоНазначенияБЗККлиентСервер.УдалитьВсеВхожденияКромеТипаИзМассива(ЛичныеДанныеКандидатов,
		Тип("СправочникСсылка.ЛичныеДанныеКандидатов"));
	
	Если ЛичныеДанныеКандидатов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	Кандидаты = КандидатыПоЛичнымДаннымКандидатов(ЛичныеДанныеКандидатов).ВыгрузитьКолонку("Кандидат");
	ДополнитьИсториюВзаимоотношенийКандидатами(Взаимоотношения, Кандидаты);
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

// Добавляет в таблицу взаимоотношений сведения о кандидатах.
// 
// Параметры:
//  Взаимоотношения - ТаблицаЗначений - см. СотрудникиФормы.ТаблицаИсторииВзаимоотношений.
//  Кандидаты - Массив из СправочникСсылка.Кандидаты.
Процедура ДополнитьИсториюВзаимоотношенийКандидатами(Взаимоотношения, Кандидаты) Экспорт
	
	Если Кандидаты.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СведенияОКандидатах = ОсновныеСведенияОКандидатах(Кандидаты);
	
	Для Каждого СтрокаДанных Из СведенияОКандидатах Цикл
		НайденнаяСтрока = Взаимоотношения.Найти(СтрокаДанных.Кандидат, "Кандидат");
		Если НайденнаяСтрока = Неопределено Тогда
			ДобавитьСтрокуВИсториюВзаимоотношений(Взаимоотношения, СтрокаДанных);
		Иначе
			НайденнаяСтрока.Кандидат = СтрокаДанных.Кандидат;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// См. СотрудникиФормы.РолиФизическогоЛицаИсторииВзаимоотношений.
// 
Процедура ПриЗаполненииРолейФизическогоЛица(Роли) Экспорт
	
	Если Не ИспользоватьКандидатов() Тогда
		Возврат;
	КонецЕсли;

	Роли.Вставить("Кандидат", 3);

КонецПроцедуры

// Формирует таблицу откликов кандидатов на указанную вакансию.
//
//
Функция ОткликиКандидатов(ОтборВакансий, ТолькоНеРассмотренные = Истина) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	СоздатьВТВакансииПоОтбору(Запрос.МенеджерВременныхТаблиц, ОтборВакансий);
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОткликиКандидатов.Вакансия КАК Вакансия,
		|	ОткликиКандидатов.НомерОтклика КАК НомерОтклика,
		|	ОткликиКандидатов.Фамилия,
		|	ОткликиКандидатов.Имя,
		|	ОткликиКандидатов.Отчество,
		|	ОткликиКандидатов.ДатаРождения,
		|	ОткликиКандидатов.Адрес,
		|	ОткликиКандидатов.Телефон,
		|	ОткликиКандидатов.EMail,
		|	ОткликиКандидатов.Сообщение,
		|	ОткликиКандидатов.ФайлРезюме,
		|	ОткликиКандидатов.Источник,
		|	ОткликиКандидатов.ДатаОтклика,
		|	ОткликиКандидатов.Рассмотрено
		|ИЗ
		|	РегистрСведений.ОткликиКандидатов КАК ОткликиКандидатов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТВакансииПоОтбору КАК ВакансииПоОтбору
		|		ПО (ВакансииПоОтбору.Вакансия = ОткликиКандидатов.Вакансия)
		|			И (ОткликиКандидатов.Рассмотрено = ЛОЖЬ
		|				ИЛИ &ТолькоНеРассмотренные <> ИСТИНА)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Вакансия,
		|	НомерОтклика";
		
	Запрос.УстановитьПараметр("ТолькоНеРассмотренные", ТолькоНеРассмотренные);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

// Для указанных откликов кандидатов устанавливает отметку о том, что отклик рассмотрен.
//
// Параметры 
//	- ОткликиКандидатов - таблица значений, см. ПустаяТаблицаОткликиКандидатов.
//
Процедура УстановитьОткликамКандидатовОтметкуРассмотрено(ОткликиКандидатов) Экспорт
	
	Для Каждого Отклик Из ОткликиКандидатов Цикл
		МенеджерЗаписи = РегистрыСведений.ОткликиКандидатов.СоздатьМенеджерЗаписи();
		МенеджерЗаписи.Вакансия = Отклик.Вакансия;
		МенеджерЗаписи.НомерОтклика = Отклик.НомерОтклика;
		МенеджерЗаписи.Прочитать();
		Если Не МенеджерЗаписи.Рассмотрено Тогда
			МенеджерЗаписи.Рассмотрено = Истина;
			МенеджерЗаписи.Записать();
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция ПустаяТаблицаОткликиКандидатов() Экспорт
	
	ОткликиКандидатов = Новый ТаблицаЗначений;
