КонецПроцедуры

// См. ОчередьЗаданийПереопределяемый.ПриОпределенииПсевдонимовОбработчиков.
//
Процедура ПриОпределенииПсевдонимовОбработчиков(СоответствиеИменПсевдонимам) Экспорт
	СоответствиеИменПсевдонимам.Вставить(Метаданные.РегламентныеЗадания.ОтклонениеКандидатовЗадержавшихсяНаОдномЭтапе.ИмяМетода);
КонецПроцедуры

// Конец ТехнологияСервиса.ОчередьЗаданий

// См. ЗащитаПерсональныхДанныхПереопределяемый.ДополнитьДанныеСубъектовПерсональныхДанных.
Процедура ДополнитьДанныеСубъектовПерсональныхДанных(СубъектыПерсональныхДанных, ДатаАктуальности) Экспорт
	
	ЛичныеДанныеКандидатов = ОбщегоНазначения.ВыгрузитьКолонку(СубъектыПерсональныхДанных, "Субъект", Истина);
	ОбщегоНазначенияБЗККлиентСервер.УдалитьВсеВхожденияКромеТипаИзМассива(ЛичныеДанныеКандидатов,
		Тип("СправочникСсылка.ЛичныеДанныеКандидатов"));
		
	ДанныеЛичныхДанныхКандидатов = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(ЛичныеДанныеКандидатов, "ФИО");
	
	Для Каждого ТекСтрока Из СубъектыПерсональныхДанных Цикл 
		ДанныеЛичныхДанныхКандидата = ДанныеЛичныхДанныхКандидатов.Получить(ТекСтрока.Субъект);
		Если ДанныеЛичныхДанныхКандидата <> Неопределено Тогда
			ТекСтрока.ФИО = ДанныеЛичныхДанныхКандидата.ФИО;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

// Синхронизирует наименования личных данных кандидатов и кандидатов при смене ФИО физического лица.
// 
// Параметры:
//  МенеджерВременныхТаблиц - МенеджерВременныхТаблиц
Процедура ИзменитьНаименованиеКандидатов(МенеджерВременныхТаблиц) Экспорт
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ФИОФизЛицПоследнее.Фамилия,
		|	ФИОФизЛицПоследнее.Имя,
		|	ФИОФизЛицПоследнее.Отчество,
		|	ФизическиеЛица.УточнениеНаименования КАК УточнениеНаименованияФизЛица,
		|	ЛичныеДанныеКандидатов.Ссылка КАК Кандидат,
		|	ЛичныеДанныеКандидатов.Наименование КАК Наименование,
		|	ЛичныеДанныеКандидатов.УточнениеНаименования КАК УточнениеНаименования
		|ИЗ
		|	ВТФИОФизЛицПоследнее КАК ФИОФизЛицПоследнее
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ФизическиеЛицаКандидатов КАК ФизическиеЛицаКандидатов
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатов
		|			ПО ФизическиеЛицаКандидатов.ЛичныеДанныеКандидата = ЛичныеДанныеКандидатов.Ссылка
		|		ПО ФИОФизЛицПоследнее.ФизическоеЛицо = ФизическиеЛицаКандидатов.ФизическоеЛицо
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизическиеЛица
		|		ПО ФИОФизЛицПоследнее.ФизическоеЛицо = ФизическиеЛица.Ссылка";
		
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда 
		Возврат;
	КонецЕсли;
	
	// Синхронизируем наименования личных данных кандидатов
	ЛичныеДанныеКандидатов = Новый Массив();
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		УстановитьНаименованиеКандидата(Выборка, Выборка.Фамилия, Выборка.Имя, Выборка.Отчество,
			Выборка.УточнениеНаименованияФизЛица);
		ЛичныеДанныеКандидатов.Добавить(Выборка.Кандидат);
	КонецЦикла;
	
	// Синхронизируем наименования кандидатов
	Кандидаты = Справочники.Кандидаты.КандидатыПоЛичнымДаннымКандидатов(ЛичныеДанныеКандидатов);
	
	Для Каждого ТекущаяСтрока Из Кандидаты Цикл
		УстановитьНаименованиеКандидата(ТекущаяСтрока, Выборка.Фамилия, Выборка.Имя, Выборка.Отчество,
