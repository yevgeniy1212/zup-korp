		ОписательВременныхТаблиц = ОписательВременныхТаблиц(МенеджерВременныхТаблиц, ИмяТаблицыОтборов, ИмяВТ,
			ИмяПоляОтбора);
		СоздатьВТДополнительныеКонтактыКандидатов(ОписательВременныхТаблиц, Истина);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ДополнительныеКонтактыКандидатов.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата,
		|	ДополнительныеКонтактыКандидатов.Вид КАК Вид,
		|	ДополнительныеКонтактыКандидатов.Представление КАК Представление
		|ИЗ
		|	ВТДополнительныеКонтактыКандидатов КАК ДополнительныеКонтактыКандидатов
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДополнительныеКонтактыКандидатов.ЛичныеДанныеКандидата";
		
	ЗарплатаКадрыОбщиеНаборыДанных.ЗаменитьИмяСоздаваемойВременнойТаблицы(Запрос.Текст, "ВТДополнительныеКонтактыКандидатов", ИмяВТ);
		
	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции

