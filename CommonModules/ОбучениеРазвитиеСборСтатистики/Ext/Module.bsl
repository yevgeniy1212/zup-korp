	ДанныеСтатистики.ДанныеГруппировок = ДанныеГруппировок;
	ДанныеСтатистики.ПроверкиОбъекта.ПометкаУдаления = Истина;
	ДанныеСтатистики.ПроверкиОбъекта.Проведение = Истина;
	
	ПоказателиСтатистики = СборСтатистики.СтандартныеПоказателиПоТаблице(Таблица, ДанныеСтатистики);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", ТекущаяДатаСеанса());
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ОбучениеРазвитиеСотрудников.Ссылка) КАК Документов
		|ИЗ
		|	Документ.ОбучениеРазвитиеСотрудников КАК ОбучениеРазвитиеСотрудников
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОбучениеРазвитиеСотрудников.Расходы КАК ОбучениеРазвитиеСотрудниковРасходы
		|		ПО ОбучениеРазвитиеСотрудников.Ссылка = ОбучениеРазвитиеСотрудниковРасходы.Ссылка
		|ГДЕ
		|	ОбучениеРазвитиеСотрудниковРасходы.НомерСтроки > 1
		|	И ОбучениеРазвитиеСотрудников.Проведен = ИСТИНА
		|	И ОбучениеРазвитиеСотрудников.ПометкаУдаления = ЛОЖЬ
		|	И ОбучениеРазвитиеСотрудников.Дата > &НачалоПериода
		|	И ОбучениеРазвитиеСотрудников.Дата <= &КонецПериода";
	
	ПоказателиСтатистики.Вставить("Обучений c расходами", Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Документов")[0]);
	
	Возврат ПоказателиСтатистики;
	
КонецФункции

