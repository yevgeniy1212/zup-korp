Функция СтатистикаМероприятий()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ МероприятияОбученияРазвития.Ссылка) КАК Мероприятий,
		|	МероприятияОбученияРазвития.СпособПроведения КАК СпособПроведения
		|ИЗ
		|	Справочник.МероприятияОбученияРазвития КАК МероприятияОбученияРазвития
		|ГДЕ
		|	МероприятияОбученияРазвития.ВАрхиве = ЛОЖЬ
		|	И МероприятияОбученияРазвития.ПометкаУдаления = ЛОЖЬ
		|
		|СГРУППИРОВАТЬ ПО
		|	МероприятияОбученияРазвития.СпособПроведения";
	
	ВсегоМероприятий = 0;
	ПоказателиСтатистики = Новый Соответствие;
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		ПредставлениеПеречисления = Строка(Выборка.СпособПроведения);
		Если Не ЗначениеЗаполнено(ПредставлениеПеречисления) Тогда
			ПредставлениеПеречисления = "Пустых способов проведения";
		КонецЕсли;
		ПоказателиСтатистики.Вставить(ПредставлениеПеречисления, Выборка.Мероприятий);
		ВсегоМероприятий = ВсегоМероприятий + Выборка.Мероприятий;
	КонецЦикла;
	ПоказателиСтатистики.Вставить("Мероприятий", ВсегоМероприятий);
	
	Возврат ПоказателиСтатистики;
	
КонецФункции

Функция СтатистикаСотрудников()
	
	Родитель = Метаданные.Документы.ОбучениеРазвитиеСотрудников;
	Таблица = Родитель.ТабличныеЧасти.Сотрудники;
	ДанныеСтатистики = СборСтатистики.ДанныеСбораСтатистики();
	
	ДанныеСтатистики.ДанныеОбъекта.Объект = Таблица.Реквизиты.Сотрудник;
	ДанныеСтатистики.ДанныеОбъекта.ПредставлениеОбъектов = "Сотрудников";
	
	ДанныеГруппировок = Новый Массив;
	
	ДанныеГруппировки = СборСтатистики.ДанныеГруппировки();
	ДанныеГруппировки.Группировка = Родитель.СтандартныеРеквизиты.Ссылка;
	ДанныеГруппировки.ПредставлениеОднойГруппы = "Обучение";
	ДанныеГруппировки.ПредставлениеГруппировки = "Обучений";
	ДанныеГруппировок.Добавить(ДанныеГруппировки);
	
	ДанныеСтатистики.ДанныеГруппировок = ДанныеГруппировок;
	ДанныеСтатистики.ПроверкиОбъекта.ПометкаУдаления = Истина;
	ДанныеСтатистики.ПроверкиОбъекта.Проведение = Истина;
	
	ПоказателиСтатистики = СборСтатистики.СтандартныеПоказателиПоТаблице(Таблица, ДанныеСтатистики, Истина);
	
	Возврат ПоказателиСтатистики;
	
КонецФункции

