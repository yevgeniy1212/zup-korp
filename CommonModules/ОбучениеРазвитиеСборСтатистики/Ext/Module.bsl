// См. ЦентрМониторингаПереопределяемый.ПриСбореПоказателейСтатистикиКонфигурации.
Процедура ПриСбореПоказателейСтатистикиКонфигурации() Экспорт
	
	ИмяКонфигурации = КонфигурацииЗарплатаКадры.КраткоеНазваниеПрограммыСлужебный();
	// АПК:1297-выкл Имя подсистемы для статистики, не локализуется
	ИмяПодсистемы = "Обучение и развитие";
	// АПК:1297-вкл
	
	ВидСтатистики = СборСтатистики.ВидыСтатистики().Накопительная;
	
	Статистика = Новый Соответствие;
	Статистика.Вставить("Мероприятия обучение и развитие", СтатистикаМероприятий());
	Статистика.Вставить("Сотрудники(Обучение и развитие сотрудников)", СтатистикаСотрудников());
	СборСтатистики.ЗаписатьСтатистикуПоОбъектам(ИмяКонфигурации, ИмяПодсистемы, Статистика, ВидСтатистики);
	
	НачалоПериода = СборСтатистики.НачалоПериодаСбораСтатистики();
	ВидСтатистики = СборСтатистики.ВидыСтатистики().Периодическая;
	
	Статистика = Новый Соответствие;
	Статистика.Вставить("Индивидуальный план развития", СтатистикаИндивидуальныхПлановРазвития(НачалоПериода));
	Статистика.Вставить("Мероприятия(Индивидуальный план развития)", СтатистикаМероприятийИПР(НачалоПериода));
	Статистика.Вставить("Заявка на обучение и развитие", СтатистикаЗаявокНаОбучениеРазвитие(НачалоПериода));
	Статистика.Вставить("Заявка на включение в план обучения", СтатистикаЗаявокВключениеВПланОбучения(НачалоПериода));
	Статистика.Вставить("Обучение и развитие сотрудников", СтатистикаОбученийРазвитийСотрудников(НачалоПериода));
	Статистика.Вставить("План обучения и развития", СтатистикаПлановОбученияРазвития(НачалоПериода));
	Статистика.Вставить("Мероприятия(План обучения и развития)", СтатистикаМероприятийПОР(НачалоПериода));
	Статистика.Вставить("Ученический договор", СтатистикаУченическихДоговоров(НачалоПериода));
	Статистика.Вставить("Обязательства(Ученический договор)", СтатистикаОбязательств(НачалоПериода));
	СборСтатистики.ЗаписатьСтатистикуПоОбъектам(ИмяКонфигурации, ИмяПодсистемы, Статистика, ВидСтатистики);
	
КонецПроцедуры

#КонецОбласти

