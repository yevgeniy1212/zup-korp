Процедура НачатьОткрытиеФормыНовогоКандидата(Форма)

	Если Не Форма.Параметры.Ключ.Пустая() Тогда
		ОткрытьФормуНовогоКандидатаФизическогоЛица(Форма);
		Возврат;
	КонецЕсли;
	
	ПараметрыОповещения = Новый Структура();
	ПараметрыОповещения.Вставить("Форма", Форма);
	Форма.НачатьЗапись(, Новый ОписаниеОповещения("ЗавершитьОткрытиеФормыНовогоКандидата", ЭтотОбъект, ПараметрыОповещения));
	
