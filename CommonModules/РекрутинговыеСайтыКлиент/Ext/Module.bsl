//@strict-types

#Область СлужебныйПрограммныйИнтерфейс

// Параметры:
//  Форма - ФормаКлиентскогоПриложения
//  ОповещениеОЗавершении - ОписаниеОповещения
//  Сайты - Массив Из СправочникСсылка.ИсточникиИнформацииОКандидатах
Процедура НачатьЗагрузкуКлассификаторов(Форма, ОповещениеОЗавершении, Сайты) Экспорт
	
	ДлительнаяОперация = 
		РекрутинговыеСайтыВызовСервера.ДлительнаяОперацияЗагрузкиКлассификаторов(
			Сайты, Форма.УникальныйИдентификатор);
		
	Если ЗначениеЗаполнено(ДлительнаяОперация) Тогда
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(Форма);
		ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	КонецЕсли;
	
КонецПроцедуры

// Возвращаемое значение:
//  Структура - Новые параметры подключения:
// * Сайт - СправочникСсылка.ИсточникиИнформацииОКандидатах -
// * КодАвторизации - Строка -
// * ИмяПользователя - Строка -
// * Пароль - Строка -
Функция НовыеПараметрыПодключения() Экспорт

	ПараметрыПодключения = Новый Структура();
	ПараметрыПодключения.Вставить("Сайт",
		ПредопределенноеЗначение("Справочник.ИсточникиИнформацииОКандидатах.ПустаяСсылка"));
	ПараметрыПодключения.Вставить("КодАвторизации", "");
	ПараметрыПодключения.Вставить("ИмяПользователя", "");
	ПараметрыПодключения.Вставить("Пароль", "");
	
	Возврат ПараметрыПодключения;

КонецФункции

// См. РекрутинговыеСайтыСлужебный.СохранитьКлассификаторы
Процедура СохранитьКлассификаторы(Классификаторы, ДанныеСайтов) Экспорт
	
	РекрутинговыеСайтыВызовСервера.СохранитьКлассификаторы(Классификаторы, ДанныеСайтов);
	
КонецПроцедуры

// См. ОбработкаОбъект.МенеджерИнтеграцииСРекрутинговымиСайтами.ТекстВопросаПоКонтактногоДоступа
Функция ТекстВопросаПоКонтактногоДоступа(Сайт) Экспорт
	
	Возврат РекрутинговыеСайтыВызовСервера.ТекстВопросаПоКонтактногоДоступа(Сайт);
	
КонецФункции

// См. ОбработкаОбъект.МенеджерИнтеграцииСРекрутинговымиСайтами.БольшеНеЗадаватьВопросПоКонтактногоДоступа
Функция БольшеНеЗадаватьВопросПоКонтактногоДоступа(Сайт) Экспорт
	
	Возврат РекрутинговыеСайтыВызовСервера.БольшеНеЗадаватьВопросПоКонтактногоДоступа(Сайт);
	
КонецФункции

// См. ОбработкаОбъект.МенеджерИнтеграцииСРекрутинговымиСайтами.СохранитьБольшеНеЗадаватьВопросПоКонтактногоДоступа
Процедура СохранитьБольшеНеЗадаватьВопросПоКонтактногоДоступа(Сайт) Экспорт
	
	РекрутинговыеСайтыВызовСервера.СохранитьБольшеНеЗадаватьВопросПоКонтактногоДоступа(Сайт);
	
КонецПроцедуры

// Параметры:
//  СайтыСПубликациямиВакансий - Соответствие Из КлючИЗначение:
// * Ключ - СправочникСсылка.Вакансии
// * Значение - Массив Из СправочникСсылка.ИсточникиИнформацииОКандидатах
Процедура СнятьПубликациюВакансий(СайтыСПубликациямиВакансий) Экспорт
	
	Для Каждого ВакансияИСайты Из СайтыСПубликациямиВакансий Цикл 
		Вакансия = ВакансияИСайты.Ключ;
		СайтыСПубликациями = ВакансияИСайты.Значение;
		Для Каждого Сайт Из СайтыСПубликациями Цикл
			СнятьПубликациюВакансии(Вакансия, Сайт);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

// См. РекрутинговыеСайты.СнятьПубликациюВакансии
Функция СнятьПубликациюВакансии(Вакансия, Сайт, ИдентификаторВакансии = Неопределено) Экспорт
	
	Возврат РекрутинговыеСайтыВызовСервера.СнятьПубликациюВакансии(Вакансия, Сайт, ИдентификаторВакансии);
	
КонецФункции

// См. РекрутинговыеСайты.ОтметитьПубликациюВакансииСнятой
Процедура ОтметитьПубликациюВакансииСнятой(Вакансия, Сайт) Экспорт
	
	РекрутинговыеСайтыВызовСервера.ОтметитьПубликациюВакансииСнятой(Вакансия, Сайт);
	
КонецПроцедуры

// Параметры:
//  Вакансия - СправочникСсылка.Вакансии
Процедура ПолучитьОтклики(Вакансия) Экспорт
	
	ИспользуемыеСайты = РекрутинговыеСайтыВызовСервера.СайтыСПубликациями(Вакансия);
	
	Если ИспользуемыеСайты = Неопределено Тогда
		ПоказатьПредупреждение(,
			НСтр("ru = 'Вакансия не опубликована ни на одном из сайтов.
				 |Опубликуйте вакансию на рекрутинговом сайте, чтобы начать получать отклики.'"));
		Возврат;
	КонецЕсли;
	
	Для Каждого Сайт Из ИспользуемыеСайты Цикл
		РекрутинговыеСайтыВызовСервера.ПолучитьОтклики(Вакансия, Сайт);
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  ИмяФормы - Строка
//  ПараметрыФормы - Структура:
// * Вакансия - СправочникСсылка.Вакансии
// * Сайт - СправочникСсылка.ИсточникиИнформацииОКандидатах
// * ИдентификаторВакансии - Строка
// * АдресПубликации - Строка
// * ПовторнаяПубликация - Булево
//  Владелец - ФормаКлиентскогоПриложения
//  Оповещение - Неопределено, ОписаниеОповещения -
Процедура ОткрытьФормуОбработки(ИмяФормы, ПараметрыФормы, Владелец, Оповещение = Неопределено) Экспорт
	
	ОткрытьФорму(
		ИмяФормы, ПараметрыФормы, Владелец, Истина, , , Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

// Параметры:
//  Форма - ФормаКлиентскогоПриложения:
//  * ИспользуемыеСайты - Массив Из СправочникСсылка.ИсточникиИнформацииОКандидатах
//  Вакансия - СправочникСсылка.Вакансии
//  Сайт - СправочникСсылка.ИсточникиИнформацииОКандидатах
//  ПараметрыПубликации - Структура:
// * Вакансия - СправочникСсылка.Вакансии
// * Сайт - СправочникСсылка.ИсточникиИнформацииОКандидатах
// * ИдентификаторВакансии - Строка
// * АдресПубликации - Строка
// * ПовторнаяПубликация - Булево
Процедура ОткрытьФормуНастройкиПубликации(Форма, Вакансия, Сайт, ПараметрыПубликации) Экспорт
	
	Если Не ЗначениеЗаполнено(Сайт) 
		Или Не ЗначениеЗаполнено(Форма.ИспользуемыеСайты) Тогда
		Возврат;
	КонецЕсли;
	
	Если Форма.ИспользуемыеСайты.Найти(Сайт) = Неопределено Тогда 
		ПоказатьПредупреждение(, НСтр("ru = 'Настройте доступ к сайту'"));
		Возврат;
	КонецЕсли;
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Вакансия", Вакансия);
	ПараметрыФормы.Вставить("Сайт", Сайт);
	ПараметрыФормы.Вставить("ИдентификаторВакансии", ПараметрыПубликации.ИдентификаторВакансии);
	ПараметрыФормы.Вставить("АдресПубликации", ПараметрыПубликации.АдресПубликации);
	ПараметрыФормы.Вставить("ПовторнаяПубликация", ПараметрыПубликации.ПовторнаяПубликация);
	
	ОткрытьФормуОбработки(
		"Обработка.ПубликацияВакансийНаРекрутинговыхСайтах.Форма.НастройкаПубликации", ПараметрыФормы, Форма);
	
КонецПроцедуры

// Параметры:
//  Форма - ФормаКлиентскогоПриложения
Процедура ОткрытьФормуРедактированияПараметровДоступаКСайтам(Форма) Экспорт
	
	ПараметрыФормы = Новый Структура;
	ОткрытьФормуОбработки(
		"Обработка.НастройкаДоступаКРекрутинговымСайтам.Форма.ФормаНастройкиДоступа", ПараметрыФормы, Форма);
	
КонецПроцедуры

// Параметры:
//  ФормаВладелец - ФормаКлиентскогоПриложения
//  АдресРезюме - Строка
//  Вакансия - СправочникСсылка.Вакансии
//  ДляЗаписи - Неопределено, Структура -
Процедура НачатьСозданиеКандидатаПоАдресуРезюме(ФормаВладелец, АдресРезюме, Вакансия, ДляЗаписи = Неопределено) Экспорт
	
	ЗначенияЗаполнения = Новый Структура();
	ЗначенияЗаполнения.Вставить("Вакансия", Вакансия);
	ЗначенияЗаполнения.Вставить("ДляЗаписи", ДляЗаписи);
	
	СоздатьКандидатаПоАдресуРезюме(ФормаВладелец, АдресРезюме, ЗначенияЗаполнения);
	
КонецПроцедуры

// Параметры:
//  ФормаВладелец - ФормаКлиентскогоПриложения
//  АдресРезюме - Строка
//  ЗначенияЗаполнения - Структура:
// * Вакансия - СправочникСсылка.Вакансии -
// * ДляЗаписи - Неопределено, Структура -
Процедура СоздатьКандидатаПоАдресуРезюме(ФормаВладелец, АдресРезюме, ЗначенияЗаполнения) Экспорт
	
	ДополнительныеПараметры = Новый Структура();
	ДополнительныеПараметры.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
	ДополнительныеПараметры.Вставить("АдресРезюме", АдресРезюме);
	ДополнительныеПараметры.Вставить("ФормаВладелец", ФормаВладелец);
	
	ДлительнаяОперация = РекрутинговыеСайтыВызовСервера.ДлительнаяОперацияЗагрузкиРезюме(
		ФормаВладелец.УникальныйИдентификатор, АдресРезюме);
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ФормаВладелец);
	ПараметрыОжидания.ТекстСообщения = НСтр("ru = 'Загружаем резюме с рекрутингового сайта'");
	
	Оповещение = Новый ОписаниеОповещения("ЗавершитьЗагрузкуРезюме", ЭтотОбъект, ДополнительныеПараметры);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);
	
КонецПроцедуры

// Параметры:
//  Результат - Структура:
//  * Статус - Строка
//  * КраткоеПредставлениеОшибки - Строка
//  * АдресРезультата - Строка
//  ДополнительныеПараметры - Структура:
//  * ФормаВладелец - ФормаКлиентскогоПриложения
//  * ЗначенияЗаполнения - Структура
//  * АдресРезюме - Строка
Процедура ЗавершитьЗагрузкуРезюме(Результат, ДополнительныеПараметры) Экспорт
	
	Оповестить("ЗагрузкаРезюмеЗавершена", , ДополнительныеПараметры.ФормаВладелец);
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		ПоказатьПредупреждение(, СтрШаблон(НСтр("ru = '%1'"), Результат.КраткоеПредставлениеОшибки));
		Возврат;
	КонецЕсли;
	
	ДанныеКандидата = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	
	ПодборПерсоналаКлиент.ОткрытьФормуНовогоКандидата(ДополнительныеПараметры.ЗначенияЗаполнения,
		Новый Структура("ДанныеКандидата", ДанныеКандидата), ДополнительныеПараметры.АдресРезюме);
	
КонецПроцедуры

Функция НовыеПараметрыПубликации() Экспорт
	
	ПараметрыПубликации = Новый Структура;
	
	ПараметрыПубликации.Вставить("ПовторнаяПубликация", Ложь);
	ПараметрыПубликации.Вставить("АдресПубликации", "");
	ПараметрыПубликации.Вставить("ИдентификаторВакансии", "");
	
	Возврат ПараметрыПубликации;
	
КонецФункции

Процедура СоздатьКандидатаПоUrlРезюме(Вакансия = Неопределено) Экспорт
	
	ОткрытьФорму("ОбщаяФорма.ЗагрузкаКандидатаПоUrlРезюме", Новый Структура("Вакансия", Вакансия), , Вакансия);
	
КонецПроцедуры

// Параметры:
//  ПараметрыВыполненияКоманды - ПараметрыВыполненияКоманды
Процедура КомандаПоискРезюмеВИнтернете(ПараметрыВыполненияКоманды) Экспорт
	
	ОткрытьФорму("Обработка.ПоискРезюмеВИнтернете.Форма", ,
		ПараметрыВыполненияКоманды.Источник,
		ПараметрыВыполненияКоманды.Уникальность,
		ПараметрыВыполненияКоманды.Окно,
		ПараметрыВыполненияКоманды.НавигационнаяСсылка);
	
КонецПроцедуры

// Параметры:
//  ПараметрКоманды - СправочникСсылка.Вакансии
//  ПараметрыВыполненияКоманды - ПараметрыВыполненияКоманды
Процедура КомандаПоискРезюмеВИнтернетеПоВакансии(ПараметрКоманды, ПараметрыВыполненияКоманды) Экспорт
	
	ПараметрыФормы = Новый Структура;
	
	НаименованиеВакансии = Строка(ПараметрКоманды);
	ПозицияСимвола = 0;
	ПозицияСимвола = СтрНайти(НаименованиеВакансии, "/");
	НаименованиеВакансии =
		Лев(НаименованиеВакансии, ?(ПозицияСимвола = 0, СтрДлина(НаименованиеВакансии), ПозицияСимвола - 1)); 
	
	ПараметрыФормы.Вставить("КлючевоеСлово",  НаименованиеВакансии);
	ПараметрыФормы.Вставить("Вакансия", ПараметрКоманды);
		
	ОткрытьФорму("Обработка.ПоискРезюмеВИнтернете.Форма",
		ПараметрыФормы, ПараметрыВыполненияКоманды.Источник,
		ПараметрыВыполненияКоманды.Уникальность,
		ПараметрыВыполненияКоманды.Окно,
		ПараметрыВыполненияКоманды.НавигационнаяСсылка);
	
КонецПроцедуры

#КонецОбласти
