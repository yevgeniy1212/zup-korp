//@strict-types

#Область СлужебныйПрограммныйИнтерфейс

Функция МенеджерРекрутинговыхСайтов(Сайты = Неопределено, Пользователь = Неопределено, ТолькоНастроенные = Истина) Экспорт
	
	Возврат Обработки.МенеджерИнтеграцииСРекрутинговымиСайтами.НовыйМенеджер(Сайты, Пользователь, ТолькоНастроенные);
	
КонецФункции

// Параметры:
//  Сайты - Неопределено, Массив из СправочникСсылка.ИсточникиИнформацииОКандидатах -
// 
// Возвращаемое значение:
//  ФиксированноеСоответствие из КлючИЗначение:
// * Ключ - СправочникСсылка.ИсточникиИнформацииОКандидатах 
// * Значение - Структура: См. НовыеДанныеСайта
Функция ДанныеСайтов(Сайты = Неопределено) Экспорт

	Менеджер = МенеджерРекрутинговыхСайтов(Сайты, , Ложь);
	
	Возврат Менеджер.ДанныеСайтов();

КонецФункции

// См. РегистрыСведений.НастройкиИнтеграцииРекрутинговыхСайтов.РеквизитыСайтов
Функция РеквизитыСайтов(Сайты, Пользователь) Экспорт
	
	Возврат РегистрыСведений.НастройкиИнтеграцииРекрутинговыхСайтов.РеквизитыСайтов(Сайты, Пользователь);
	
КонецФункции

// Параметры:
//  Сайт - СправочникСсылка.ИсточникиИнформацииОКандидатах
//  Пользователь - СправочникСсылка.Пользователи
// 
// Возвращаемое значение:
// - Неопределено
// - Структура: См. НовыеРеквизитыСайта
Функция РеквизитыСайта(Сайт, Пользователь) Экспорт
	
	РеквизитыСайтов = РеквизитыСайтов(ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Сайт), Пользователь);
	
	//@skip-check constructor-function-return-section
	Возврат РеквизитыСайтов[Сайт];
	
КонецФункции

// См. РегистрыСведений.ПубликацияВакансий.ИдентификаторВакансии
Функция ИдентификаторВакансии(Вакансия, Сайт) Экспорт
	
	Возврат РегистрыСведений.ПубликацияВакансий.ИдентификаторВакансии(Вакансия, Сайт);
	
КонецФункции

// Параметры:
//  Вакансия - СправочникСсылка.Вакансии
// 
// Возвращаемое значение:
//  Число
Функция МаксимальныйНомерОтклика(Вакансия) Экспорт
	
	Возврат РегистрыСведений.ОткликиКандидатов.НомерПоследнегоОтклика(Вакансия);
	
КонецФункции

// См. РегистрыСведений.ОткликиКандидатов.ЗагруженныеОткликиВакансии
Функция ЗагруженныеОткликиВакансии(Вакансия) Экспорт
	
	Возврат РегистрыСведений.ОткликиКандидатов.ЗагруженныеОткликиВакансии(Вакансия);
	
КонецФункции

// См. РегистрыСведений.ДанныеПубликацииРезюме.ДанныеРезюме
Функция ДанныеРезюме(Кандидат) Экспорт
	
	Возврат РегистрыСведений.ДанныеПубликацииРезюме.ДанныеРезюме(Кандидат);
	
КонецФункции

// Параметры:
//  Кандидат - СправочникСсылка.Кандидаты
//  МестоПубликации - СправочникСсылка.ИсточникиИнформацииОКандидатах
//  Комментарии - ТаблицаЗначений: См. ТаблицаКомментарииКандидатов
// 
// Возвращаемое значение:
//  Булево
Функция ЕстьИзмененияКомментариев(Кандидат, МестоПубликации, Комментарии) Экспорт
	
	Если Комментарии.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Кандидат) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Кандидат", Кандидат);
	Запрос.УстановитьПараметр("МестоПубликации", МестоПубликации);
	Запрос.УстановитьПараметр("Идентификаторы", Комментарии.ВыгрузитьКолонку("Идентификатор"));
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КомментарииКандидатов.Период КАК Период,
	|	КомментарииКандидатов.Кандидат КАК Кандидат,
	|	КомментарииКандидатов.Пользователь КАК Пользователь,
	|	КомментарииКандидатов.Комментарий КАК Комментарий,
	|	ВЫБОР
	|		КОГДА КомментарииКандидатов.Доступность = ЗНАЧЕНИЕ(Перечисление.ДоступностьКомментарияКандидата.ТолькоДляАвтора)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ТолькоДляАвтора,
	|	КомментарииКандидатов.МестоПубликации КАК МестоПубликации,
	|	КомментарииКандидатов.Идентификатор КАК Идентификатор
	|ИЗ
	|	РегистрСведений.КомментарииКандидатов КАК КомментарииКандидатов
	|ГДЕ
	|	КомментарииКандидатов.Кандидат = &Кандидат
	|	И КомментарииКандидатов.МестоПубликации = &МестоПубликации
	|	И КомментарииКандидатов.Идентификатор В(&Идентификаторы)";
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		// Есть новые комментарии.
		Возврат Истина;
	КонецЕсли;
	
	// Проверяем содержимое.
	ОтборСтрок = Новый Структура("Идентификатор", "");
	ЗагруженныеКомментарии = РезультатЗапроса.Выгрузить();
	Для Каждого Строка Из Комментарии Цикл
		ОтборСтрок.Идентификатор = Строка.Идентификатор;
		НайденныеСтроки = ЗагруженныеКомментарии.НайтиСтроки(ОтборСтрок);
		Если НайденныеСтроки.Количество() = 0 Тогда
			// Есть отсутствующие комментарии.
			Возврат Истина;
		КонецЕсли;
		// Есть различающиеся комментарии.
		НайденнаяСтрока = НайденныеСтроки[0];
		Если Строка.Комментарий <> НайденнаяСтрока.Комментарий Тогда
			Возврат Истина;
		КонецЕсли;
		Если Строка.ТолькоДляАвтора <> НайденнаяСтрока.ТолькоДляАвтора Тогда
			Возврат Истина;
		КонецЕсли;
		Если Строка.Период <> НайденнаяСтрока.Период Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

// Параметры:
//  Комментарии - ТаблицаЗначений: См. ТаблицаКомментарииКандидатов
//  Кандидат - СправочникСсылка.Кандидаты
//  МестоПубликации - СправочникСсылка.ИсточникиИнформацииОКандидатах
Процедура ЗаписатьТаблицуКомментариевКандидата(Комментарии, Кандидат, МестоПубликации) Экспорт
	
	НаборЗаписей = РегистрыСведений.КомментарииКандидатов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Кандидат.Установить(Кандидат);
	
	Попытка
		УстановитьПривилегированныйРежим(Истина);
		НаборЗаписей.Прочитать();
		УстановитьПривилегированныйРежим(Ложь);
		
		// Удалим комментарии с идентификаторами, которых более нет на сайте.
		УдаляемыеСтроки = Новый Массив;
		ОтборСтрок = Новый Структура("Идентификатор", "");
		Для Каждого СтрокаНабора Из НаборЗаписей Цикл
			Если СтрокаНабора.МестоПубликации <> МестоПубликации Тогда
				Продолжить;
			КонецЕсли;
			ОтборСтрок.Идентификатор = СтрокаНабора.Идентификатор;
			НайденныеСтроки = Комментарии.НайтиСтроки(ОтборСтрок);
			Если НайденныеСтроки.Количество() = 0 Тогда
				УдаляемыеСтроки.Добавить(СтрокаНабора);
			КонецЕсли;
		КонецЦикла;
		
		Для Каждого УдаляемаяСтрока Из УдаляемыеСтроки Цикл // РегистрСведенийЗапись.КомментарииКандидатов
			НаборЗаписей.Удалить(УдаляемаяСтрока);
		КонецЦикла;
		
		// Добавляем новые комментарии, изменяем существующие.
		ОтборСтрок = Новый Структура("МестоПубликации", МестоПубликации);
		Для Каждого Строка Из Комментарии Цикл
			Если Не ЗначениеЗаполнено(Строка.Пользователь) Тогда
				Продолжить;
			КонецЕсли;
			СтрокаНабора = СтрокаКомментарияИзНабораПоИдентификатору(НаборЗаписей, Строка.Идентификатор, ОтборСтрок);
			Если СтрокаНабора = Неопределено Тогда
				СтрокаНабора = НаборЗаписей.Добавить();
				СтрокаНабора.Кандидат = Кандидат;
				СтрокаНабора.МестоПубликации = МестоПубликации;
			КонецЕсли;
			ЗаполнитьЗначенияСвойств(СтрокаНабора, Строка);
			СтрокаНабора.Доступность = Перечисления.ДоступностьКомментарияКандидата.Общедоступный;
			Если Строка.ТолькоДляАвтора Тогда
				СтрокаНабора.Доступность = Перечисления.ДоступностьКомментарияКандидата.ТолькоДляАвтора;
			КонецЕсли;
		КонецЦикла;
		
		УстановитьПривилегированныйРежим(Истина);
		НаборЗаписей.Записать();
		УстановитьПривилегированныйРежим(Ложь);
	Исключение
		Описание = СтрШаблон(НСтр(
			"ru = 'Ошибка при записи комментариев кандидата с сайта %1.
			|Не удалось заблокировать данные для изменения.'"), МестоПубликации);
		ЗаписьЖурналаРегистрации(НСтр("ru = 'Запись комментариев кандидата'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,,,
			Описание);
	КонецПопытки;
	
КонецПроцедуры

// Параметры:
//  Сайт - СправочникСсылка.ИсточникиИнформацииОКандидатах
//  Вакансия - СправочникСсылка.Вакансии
//  Отклики - ТаблицаЗначений: См. РегистрСведений.ОткликиКандидатов
Процедура ЗаписатьОтклики(Сайт, Вакансия, Отклики) Экспорт
	
	НачатьТранзакцию();
	Попытка
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ОткликиКандидатов");
		ЭлементБлокировки.УстановитьЗначение("Вакансия", Вакансия);
		Блокировка.Заблокировать();
		
		НаборЗаписей = РегистрыСведений.ОткликиКандидатов.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Вакансия.Установить(Вакансия);
		
		НаборЗаписей.Прочитать();
		
		Для Каждого Отклик Из Отклики Цикл
			ЗаполнитьЗначенияСвойств(НаборЗаписей.Добавить(), Отклик);
		КонецЦикла;
		
		Если НаборЗаписей.Модифицированность() Тогда
			НаборЗаписей.Записать();
		Иначе
			СообщитьОбОтсутствииОткликов(Сайт);
		КонецЕсли;
	Исключение
		ОтменитьТранзакцию();
		Описание = СтрШаблон(НСтр(
			"ru = 'Ошибка при получении откликов с сайта %1'"), Сайт);
		ЗаписьЖурналаРегистрации(НСтр("ru = 'Запись откликов кандидатов'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,,,
			Описание + Символы.ПС + ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ВызватьИсключение ТекстИсключения(Описание);
	КонецПопытки;
	
	ЗафиксироватьТранзакцию();
	
КонецПроцедуры

// Параметры:
//  АдресаАвторов - ТаблицаЗначений: См. НоваяТаблицаАдресаАвторов
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
// * Ключ - Строка
// * Значение - СправочникСсылка.Пользователи
Функция ПользователиПоАвторам(АдресаАвторов) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("АдресаАвторов", АдресаАвторов);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	АдресаАвторов.ИмяАвтора,
		|	АдресаАвторов.АдресПочты
		|ПОМЕСТИТЬ ВТАдресаАвторов
		|ИЗ
		|	&АдресаАвторов КАК АдресаАвторов
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	АдресаАвторов.ИмяАвтора,
		|	АдресаАвторов.АдресПочты,
		|	Пользователи.Ссылка КАК Пользователь
		|ПОМЕСТИТЬ ВТПользователиПоАвторам
		|ИЗ
		|	ВТАдресаАвторов КАК АдресаАвторов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица.КонтактнаяИнформация КАК КонтактыФизическихЛиц
		|		ПО (КонтактыФизическихЛиц.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты))
		|			И АдресаАвторов.АдресПочты = КонтактыФизическихЛиц.Представление
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Пользователи КАК Пользователи
		|		ПО (Пользователи.ФизическоеЛицо = КонтактыФизическихЛиц.Ссылка)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	АдресаАвторов.ИмяАвтора,
		|	АдресаАвторов.АдресПочты,
		|	КонтактыПользователей.Ссылка
		|ИЗ
		|	ВТАдресаАвторов КАК АдресаАвторов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Пользователи.КонтактнаяИнформация КАК КонтактыПользователей
		|		ПО (КонтактыПользователей.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.АдресЭлектроннойПочты))
		|			И АдресаАвторов.АдресПочты = КонтактыПользователей.Представление
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПользователиПоАвторам.ИмяАвтора,
		|	ПользователиПоАвторам.АдресПочты,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПользователиПоАвторам.Пользователь) КАК Количество
		|ПОМЕСТИТЬ ВТКоличествоПользователей
		|ИЗ
		|	ВТПользователиПоАвторам КАК ПользователиПоАвторам
		|
		|СГРУППИРОВАТЬ ПО
		|	ПользователиПоАвторам.ИмяАвтора,
		|	ПользователиПоАвторам.АдресПочты
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПользователиПоАвторам.ИмяАвтора,
		|	ПользователиПоАвторам.АдресПочты,
		|	ПользователиПоАвторам.Пользователь
		|ИЗ
		|	ВТПользователиПоАвторам КАК ПользователиПоАвторам
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТКоличествоПользователей КАК КоличествоПользователей
		|		ПО (КоличествоПользователей.ИмяАвтора = ПользователиПоАвторам.ИмяАвтора)
		|			И (КоличествоПользователей.АдресПочты = ПользователиПоАвторам.АдресПочты)
		|			И (КоличествоПользователей.Количество = 1)";
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	ПользователиПоАвторам = Новый Соответствие;
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		ПользователиПоАвторам.Вставить(Выборка.ИмяАвтора, Выборка.Пользователь);
	КонецЦикла;
	
	Возврат ПользователиПоАвторам;
	
КонецФункции

// Параметры:
//  Настройки - Структура: См. НовыеРеквизитыСайта
Процедура СохранитьНастройкиАвторизации(Настройки) Экспорт
	
	Набор = РегистрыСведений.НастройкиИнтеграцииРекрутинговыхСайтов.СоздатьНаборЗаписей();
	Набор.Отбор.Пользователь.Установить(Настройки.Пользователь);
	Набор.Отбор.РекрутинговыйСайт.Установить(Настройки.Сайт);
	
	Запись = Набор.Добавить();
	ЗаполнитьЗначенияСвойств(Запись, Настройки);
	
	Запись.Использовать = Настройки.Подключен;
	Запись.РекрутинговыйСайт = Настройки.Сайт;
	
	Если ЗначениеЗаполнено(Настройки.Пароль) Тогда
		ДанныеСайта = ДанныеСайта(Настройки.Сайт);
		
		УстановитьПривилегированныйРежим(Истина);
		ОбщегоНазначения.ЗаписатьДанныеВБезопасноеХранилище(
			Настройки.Пользователь, Настройки.Пароль, "Пароль" + ДанныеСайта.Имя);
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	Набор.Записать();
	
КонецПроцедуры

// Параметры:
//  Классификаторы - Соответствие Из КлючИЗначение:
// * Ключ - СправочникСсылка.ИсточникиИнформацииОКандидатах
// * Значение - Структура
//  ДанныеСайтов - ФиксированноеСоответствие Из КлючИЗначение
// * Ключ - СправочникСсылка.ИсточникиИнформацииОКандидатах
// * Значение - См. НовыеДанныеСайта
Процедура СохранитьКлассификаторы(Классификаторы, ДанныеСайтов) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	ТекущиеПараметры = СоответствиеПоФиксированномуСоответствию(ПараметрыСеанса.ПараметрыКлиентаНаСервере);
	Для Каждого КлючИЗначение Из Классификаторы Цикл
		ТекущиеПараметры.Вставить(
			РекрутинговыеСайтыКлиентСервер.ИмяРеквизита(ДанныеСайтов, "Классификаторы", КлючИЗначение.Ключ), КлючИЗначение.Значение);
	КонецЦикла;
	ПараметрыСеанса.ПараметрыКлиентаНаСервере = Новый ФиксированноеСоответствие(ТекущиеПараметры);
	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

// Параметры:
//  Вакансия - СправочникСсылка.Вакансии
//  Сайт - СправочникСсылка.ИсточникиИнформацииОКандидатах
//  ИдентификаторВакансии - Строка
//  Адрес - Строка
//  СвойстваПубликации - Неопределено, Структура: См. НовыеСвойстваПубликацииВакансии -
Процедура ЗаписьВРегистрИнформацииОПубликации(Вакансия, Сайт, ИдентификаторВакансии = "", Адрес = "", СвойстваПубликации = Неопределено) Экспорт
	
	ДатаСеанса = ТекущаяДатаСеанса();
	МенеджерЗаписи = РегистрыСведений.ПубликацияВакансий.СоздатьМенеджерЗаписи();
	
	МенеджерЗаписи.Вакансия = Вакансия;
	МенеджерЗаписи.МестоПубликации = Сайт;
	
	МенеджерЗаписи.Прочитать();
	
	Если Не МенеджерЗаписи.Выбран()
		Или ЗначениеЗаполнено(Адрес) Тогда
		МенеджерЗаписи.АдресПубликации = Адрес;
		МенеджерЗаписи.ДатаПубликации = ДатаСеанса;
		МенеджерЗаписи.Ответственный = Пользователи.ТекущийПользователь();
		
		Если ЗначениеЗаполнено(ИдентификаторВакансии) Тогда
			МенеджерЗаписи.ИдентификаторВакансии = ИдентификаторВакансии;
		КонецЕсли;
		
		Если Не МенеджерЗаписи.Выбран() Тогда
			МенеджерЗаписи.Вакансия = Вакансия;
			МенеджерЗаписи.МестоПубликации = Сайт;
		Иначе
			МенеджерЗаписи.ДатаСнятияСПубликации = Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СвойстваПубликации) Тогда
		Если ЗначениеЗаполнено(СвойстваПубликации.ДатаПубликации) Тогда
			МенеджерЗаписи.ДатаПубликации = СвойстваПубликации.ДатаПубликации;
		КонецЕсли;
		Если ЗначениеЗаполнено(СвойстваПубликации.ДатаОбновления) Тогда
			МенеджерЗаписи.ДатаОбновления = СвойстваПубликации.ДатаОбновления;
		КонецЕсли;
		
		МенеджерЗаписи.ДатаСнятияСПубликации = СвойстваПубликации.ДатаСнятияСПубликации;
	Иначе
		МенеджерЗаписи.ДатаОбновления = ДатаСеанса;
	КонецЕсли;
	
	МенеджерЗаписи.Записать();
	
КонецПроцедуры

// Параметры:
//  Путь - Строка
//  Вакансия - СправочникСсылка.Вакансии
//  ДанныеСайта - Структура: См. НовыеДанныеСайта
// 
// Возвращаемое значение:
//  Неопределено, Строка, Число -
Функция РеквизитВакансииСоответствующийПолюПубликации(Путь, Вакансия, ДанныеСайта) Экспорт
	
	РеквизитВакансии = Неопределено;
	
	ПоляВакансииВПрограммеИНаСайте = ДанныеСайта.ПоляВакансииВПрограммеИНаСайте;
	ИменаПолей = Новый Массив();
	
	ПутьСоответствуетРеквизиту = Ложь;
	
	Для Каждого КлючИЗначение Из ПоляВакансииВПрограммеИНаСайте Цикл
		ИменаПолей.Добавить(КлючИЗначение.Ключ);
		
		Если ПоляВакансииВПрограммеИНаСайте[КлючИЗначение.Ключ] = Путь Тогда
			ПутьСоответствуетРеквизиту = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Если Не ПутьСоответствуетРеквизиту Тогда
		Возврат РеквизитВакансии;
	КонецЕсли;
	
	РеквизитыВакансии = РеквизитыВакансии(Вакансия);
	
	Для Каждого ИмяПоля Из ИменаПолей Цикл
		Если ПоляВакансииВПрограммеИНаСайте[ИмяПоля] = Путь Тогда
			Если ИмяПоля = "Описание" Тогда
				Обязанности = РеквизитыВакансии.Обязанности;
				Условия = РеквизитыВакансии.Условия;
				Требования = РеквизитыВакансии.Требования;
				
				Описание = "";
				ДобавитьАбзац(Описание, НСтр("ru = 'Обязанности:'"), Обязанности);
				ДобавитьАбзац(Описание, НСтр("ru = 'Требования:'"), Требования);
				ДобавитьАбзац(Описание, НСтр("ru = 'Условия:'"), Условия);
				
				РеквизитВакансии = Описание;
			ИначеЕсли ИмяПоля = "Наименование" Тогда
				Наименование = РеквизитыВакансии.Наименование;
				ПозицияСимвола = 0;
				ПозицияСимвола = СтрНайти(Наименование, "/");
				Наименование = СокрЛП(
					Лев(Наименование, ?(ПозицияСимвола = 0, СтрДлина(Наименование), ПозицияСимвола - 1)));
				
				РеквизитВакансии = Наименование;
			Иначе
				РеквизитВакансии = РеквизитыВакансии[ИмяПоля]; // Строка
			КонецЕсли;
			
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат РеквизитВакансии;
	
КонецФункции

#Область СервисныеМетоды

// Параметры:
