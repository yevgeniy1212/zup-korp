// Параметры:
//  Сайт - СправочникСсылка.ИсточникиИнформацииОКандидатах
//  МенеджерСайта - Произвольный
//  Путь - Строка
// 
// Возвращаемое значение:
//  Строка
Функция ПредставлениеПоля(Сайт, МенеджерСайта, Путь) Экспорт
	
	Поля = Новый Массив;
	ПредставлениеПоля = "";
	
	Поля = РекрутинговыеСайтыВнутренний.ПоляВакансии(Сайт, МенеджерСайта);
	
	Для Каждого Поле Из Поля Цикл
		Если Поле.Путь = Путь Тогда
			ПредставлениеПоля = Поле.Описание;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Не ЗначениеЗаполнено(ПредставлениеПоля) Тогда
		ПредставлениеПоля = Путь;
	КонецЕсли;
	
	Возврат ПредставлениеПоля;
	
КонецФункции

// Параметры:
//  Поле - Строка
//  ОписаниеОшибки - Строка
// 
// Возвращаемое значение:
//  Строка
Функция ОписаниеНезаполненногоПоля(Поле, ОписаниеОшибки = "") Экспорт
	
	Если ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		ОписаниеОшибки = ": " + ОписаниеОшибки;
	КонецЕсли;
	
	Возврат СтрШаблон(НСтр("ru = 'неверно заполнено поле ""%1""%2'"), Поле, ОписаниеОшибки);
	
КонецФункции

// Параметры:
//  Сайт - СправочникСсылка.ИсточникиИнформацииОКандидатах
//  Пользователь - СправочникСсылка.Пользователи
Процедура ЗаписатьОшибкуПолученияОткликов(Сайт, Знач Пользователь) Экспорт
	
	Если Не ЗначениеЗаполнено(Пользователь) Тогда
		Пользователь = Пользователи.ТекущийПользователь();
	КонецЕсли;
	
	Описание = НСтр("ru = 'Ошибка при получении откликов с сайта %1
		|Не удалось автоматически обновить токен доступа. Необходимо авторизоваться вручную в персональных настройках пользователя %2.'");
	Описание = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Описание, Строка(Сайт), Строка(Пользователь));
	
	ЗаписьЖурналаРегистрации(НСтр("ru = 'Автоматическое получение откликов'", ОбщегоНазначения.КодОсновногоЯзыка()),
		УровеньЖурналаРегистрации.Ошибка,,,
		Описание);
	
КонецПроцедуры

