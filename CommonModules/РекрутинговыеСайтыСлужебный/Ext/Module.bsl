	ИменаСвойствЗнанияЯзыка.Вставить("НазваниеЯзыка", "");
	ИменаСвойствЗнанияЯзыка.Вставить("НазваниеУровня", "");
	ИменаСвойствЗнанияЯзыка.Вставить("ОбъектЯзык", "");
	ИменаСвойствЗнанияЯзыка.Вставить("ОбъектУровень", "");
	
	Возврат ИменаСвойствЗнанияЯзыка;
	
КонецФункции

Процедура ПрочитатьТелоОтвета(РезультатЗапроса, ПрочитатьВСоответствие = Ложь)
	
	ОтветОбъект = Неопределено;
	
	СтрокаJSON = РезультатЗапроса.ТелоОтвета;
	
	Если Не ЗначениеЗаполнено(СтрокаJSON) Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		ОтветОбъект = ПарсерJSON(СтрокаJSON, ПрочитатьВСоответствие);
	Исключение
		ОписаниеОшибки = СтрШаблон(
			НСтр("ru = 'Невозможно прочитать тело запроса JSON:
						|Читаемый объект(первые 500 символов): %1
						|Исходный запрос:
						|Метод: %2
						|Адрес ресурса: %3
						|Тело запроса: %4
						|Код состояния: %5
						|Информация об ошибке: %6'"),
			Лев(Строка(СтрокаJSON), 500),
			РезультатЗапроса.Метод,
			РезультатЗапроса.АдресРесурса,
			РезультатЗапроса.ТекстЗапроса,
			РезультатЗапроса.КодСостояния,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		
		ЗаписьЖурналаРегистрации(
			СтрШаблон(НСтр("ru = 'Чтение ответа от %1'", ОбщегоНазначения.КодОсновногоЯзыка()), РезультатЗапроса.Сервис),
			УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки);
		
		ВызватьИсключение ТекстИсключения(
			СтрШаблон(НСтр("ru = 'Не удалось прочитать ответ сервиса %1'"), РезультатЗапроса.Сервис));
	КонецПопытки;
	
	РезультатЗапроса.ОтветОбъект = ОтветОбъект;
	
КонецПроцедуры

// Параметры:
//  Сайт - СправочникСсылка.ИсточникиИнформацииОКандидатах
//  МенеджерСайта - Произвольный
//  КодСостояния - Число
//  ОписаниеОшибки - Строка
// 
// Возвращаемое значение:
//  Строка
Функция УточнитьОписаниеОшибки(Сайт, МенеджерСайта, КодСостояния, ОписаниеОшибки)
	
	УточненноеОписаниеОшибки = "";
	
	Если Не ЗначениеЗаполнено(ОписаниеОшибки) Тогда
		УточненноеОписаниеОшибки = СтрШаблон(НСтр("ru = 'Ошибка %1. Описание отсутствует.'"), КодСостояния);
	ИначеЕсли СтрНайти(ОписаниеОшибки, "token_not_found") <> 0 Тогда
		УточненноеОписаниеОшибки = НСтр("ru = 'Авторизационный токен не найден.'");
	ИначеЕсли СтрНайти(ОписаниеОшибки, "user_not_found") <> 0 Тогда
		УточненноеОписаниеОшибки = НСтр("ru = 'Пользователь не найден.'");
	ИначеЕсли КодСостояния = 404 Тогда
		УточненноеОписаниеОшибки = НСтр("ru = 'Ресурс не найден.'");
	ИначеЕсли КодСостояния = 429 Тогда
		УточненноеОписаниеОшибки = НСтр("ru = 'Превышен лимит запросов к серверу. Попробуйте повторить запрос позднее.'");
	Иначе
		УточненноеОписаниеОшибки = РекрутинговыеСайтыВнутренний.УточнитьОписаниеОшибки(Сайт, МенеджерСайта, КодСостояния, ОписаниеОшибки);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(УточненноеОписаниеОшибки)Тогда
		Если КодСостояния = 403 Тогда
			УточненноеОписаниеОшибки = НСтр("ru = 'Доступ к сайту запрещен.'");
		Иначе
			УточненноеОписаниеОшибки = СтрШаблон(НСтр(
				"ru = 'Неизвестная ошибка (%1):
				|%2'"),
				КодСостояния, ОписаниеОшибки);
		КонецЕсли;
	КонецЕсли;
	
	Возврат УточненноеОписаниеОшибки;
	
КонецФункции

// Параметры:
//  Сайт - СправочникСсылка.ИсточникиИнформацииОКандидатах
Процедура СообщитьОбОтсутствииОткликов(Сайт)
	
	СообщитьПользователю(СтрШаблон(НСтр("ru = 'Не найдено откликов для загрузки на сайте %1'"), Сайт));
	
КонецПроцедуры

Функция ТекстИсключения(Текст)
	
	Возврат СтрШаблон(
		НСтр("ru = '%1
		|Обратитесь к администратору.
		|Подробности в журнале регистрации.'"), Текст);
	
КонецФункции

// Возвращаемое значение:
//  ТаблицаЗначений - Новая таблица разделов описания вакансии:
// * ИндексНачала - Число
// * Имя - Строка
// * Заголовок - Строка
Функция НоваяТаблицаРазделовОписанияВакансии()
	
	ТаблицаРазделов = Новый ТаблицаЗначений;
	ТаблицаРазделов.Колонки.Добавить("ИндексНачала", ОбщегоНазначения.ОписаниеТипаЧисло(10));
	ТаблицаРазделов.Колонки.Добавить("Имя", ОбщегоНазначения.ОписаниеТипаСтрока(20));
	ТаблицаРазделов.Колонки.Добавить("Заголовок", ОбщегоНазначения.ОписаниеТипаСтрока(20));
	
	Возврат ТаблицаРазделов;
	
КонецФункции

Функция СтрокаКомментарияИзНабораПоИдентификатору(НаборЗаписей, Идентификатор, Отбор = Неопределено)
	
	Для Каждого СтрокаНабора Из НаборЗаписей Цикл
		Если СтрокаНабора.Идентификатор = Идентификатор Тогда
			Если Отбор = Неопределено Тогда
				Возврат СтрокаНабора;
			КонецЕсли;
			Для Каждого КлючИЗначение Из Отбор Цикл
				Если СтрокаНабора[КлючИЗначение.Ключ] <> КлючИЗначение.Значение Тогда
					Возврат Неопределено;
				КонецЕсли;
			КонецЦикла;
			Возврат СтрокаНабора;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Неопределено;
	
КонецФункции

Процедура ДобавитьАбзац(ИсходныйТекст, ЗаголовокАбзаца, ТекстАбзаца)
	
	Если ЗначениеЗаполнено(ТекстАбзаца) Тогда
		Если ЗначениеЗаполнено(ИсходныйТекст) Тогда
			ИсходныйТекст = ИсходныйТекст + Символы.ПС + Символы.ПС;
		КонецЕсли;
		
		ИсходныйТекст = ИсходныйТекст + ЗаголовокАбзаца + Символы.ПС + ТекстАбзаца;
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  Вакансия - СправочникСсылка.Вакансии
// 
// Возвращаемое значение:
//  Структура:
// * Наименование - Строка
// * ПредполагаемыйДоход - Число
// * Код - Строка
// * Обязанности - Строка
// * Условия - Строка
// * Требования - Строка
Функция РеквизитыВакансии(Вакансия)
	
	ИменаПолей = "Наименование,ПредполагаемыйДоход,Код,Обязанности,Условия,Требования";
	
	Возврат ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Вакансия, ИменаПолей);
	
КонецФункции

