#Область РаботаСОшибками

// Параметры:
//  ТекстОшибки - Строка
//  Сайт - СправочникСсылка.ИсточникиИнформацииОКандидатах
//  МенеджерСайта - Произвольный
//  РезультатЗапроса - См. ВыполнитьHTTPЗапрос
// 
// Возвращаемое значение:
//  Строка
Функция ТекстОшибки(ТекстОшибки, Сайт, МенеджерСайта, РезультатЗапроса) Экспорт
	
	ТекстОшибкиДляЖР = ТекстОшибки;
	
	Если РезультатЗапроса <> Неопределено Тогда
		УточненноеОписаниеОшибки = УточнитьОписаниеОшибки(Сайт, МенеджерСайта, РезультатЗапроса.КодСостояния, РезультатЗапроса.ТелоОтвета);
		
		ТекстОшибки = СтрШаблон(НСтр(
			"ru = '%1
			|%2'"), ТекстОшибки, УточненноеОписаниеОшибки);
		
		ТекстОшибкиДляЖР = СтрШаблон(
			НСтр("ru = '%1.
						|Исходный запрос:
						|Метод: %2
						|Адрес ресурса: %3
						|Тело запроса: %4
						|Код состояния: %5
						|Тело ответа: %6'"),
			ТекстОшибки,
			РезультатЗапроса.Метод,
