Функция ИспользуемыеСайты() Экспорт
	
	ИспользуемыеСайты = Новый Массив();
	
	ИспользуемыеСайты.Добавить(Обработки.ИнтеграцияHeadHunter.Сайт());
	ИспользуемыеСайты.Добавить(Обработки.ИнтеграцияSuperJob.Сайт());
	ИспользуемыеСайты.Добавить(Обработки.ИнтеграцияРаботаРу.Сайт());
	ИспользуемыеСайты.Добавить(Обработки.ИнтеграцияЗарплатаРу.Сайт());
	ИспользуемыеСайты.Добавить(Обработки.ИнтеграцияАвитоРабота.Сайт());
	ИспользуемыеСайты.Добавить(Обработки.ИнтеграцияХабрКарьера.Сайт());
	
	РекрутинговыеСайтыВнутреннийПереопределяемый.ПриОпределенииИспользуемыхСайтов(ИспользуемыеСайты);
	
	Возврат ИспользуемыеСайты;
	
КонецФункции

