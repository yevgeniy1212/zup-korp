		Результат = Обработки.ИнтеграцияЗарплатаРу.ВакансииССайта(МенеджерСайта, БылиОшибки);
	ИначеЕсли Сайт = Обработки.ИнтеграцияАвитоРабота.Сайт() Тогда
		Результат = Обработки.ИнтеграцияАвитоРабота.ВакансииССайта(МенеджерСайта, БылиОшибки);
	ИначеЕсли Сайт = Обработки.ИнтеграцияХабрКарьера.Сайт() Тогда
		Результат = Обработки.ИнтеграцияХабрКарьера.ВакансииССайта(МенеджерСайта, БылиОшибки);
	Иначе
