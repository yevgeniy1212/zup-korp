Функция НовыйМенеджерСайта(Сайт, Пользователь) Экспорт
	
	МенеджерСайта = Неопределено;
	
	Если Сайт = Обработки.ИнтеграцияHeadHunter.Сайт() Тогда
		МенеджерСайта = Обработки.ИнтеграцияHeadHunter.НовыйМенеджер(Пользователь);
	ИначеЕсли Сайт = Обработки.ИнтеграцияSuperJob.Сайт() Тогда
		МенеджерСайта = Обработки.ИнтеграцияSuperJob.НовыйМенеджер(Пользователь);
	ИначеЕсли Сайт = Обработки.ИнтеграцияРаботаРу.Сайт() Тогда
		МенеджерСайта = Обработки.ИнтеграцияРаботаРу.НовыйМенеджер(Пользователь);
	ИначеЕсли Сайт = Обработки.ИнтеграцияЗарплатаРу.Сайт() Тогда
		МенеджерСайта = Обработки.ИнтеграцияЗарплатаРу.НовыйМенеджер(Пользователь);
	ИначеЕсли Сайт = Обработки.ИнтеграцияАвитоРабота.Сайт() Тогда
		МенеджерСайта = Обработки.ИнтеграцияАвитоРабота.НовыйМенеджер(Пользователь);
	ИначеЕсли Сайт = Обработки.ИнтеграцияХабрКарьера.Сайт() Тогда
		МенеджерСайта = Обработки.ИнтеграцияХабрКарьера.НовыйМенеджер(Пользователь);
	Иначе
		РекрутинговыеСайтыВнутреннийПереопределяемый.ПриПолученииНовогоМенеджераСайта(МенеджерСайта, Сайт, Пользователь);
	КонецЕсли;
	
	Возврат МенеджерСайта;
	
КонецФункции

Процедура ПриЗаполненииАдресовРекрутинговыхСайтов(АдресаСайтов) Экспорт
	
	Обработки.ИнтеграцияHeadHunter.ПриЗаполненииАдресовРекрутинговыхСайтов(АдресаСайтов);
	Обработки.ИнтеграцияSuperJob.ПриЗаполненииАдресовРекрутинговыхСайтов(АдресаСайтов);
	Обработки.ИнтеграцияРаботаРу.ПриЗаполненииАдресовРекрутинговыхСайтов(АдресаСайтов);
	Обработки.ИнтеграцияЗарплатаРу.ПриЗаполненииАдресовРекрутинговыхСайтов(АдресаСайтов);
	Обработки.ИнтеграцияАвитоРабота.ПриЗаполненииАдресовРекрутинговыхСайтов(АдресаСайтов);
	Обработки.ИнтеграцияХабрКарьера.ПриЗаполненииАдресовРекрутинговыхСайтов(АдресаСайтов);
	
	РекрутинговыеСайтыВнутреннийПереопределяемый.ПриЗаполненииАдресовРекрутинговыхСайтов(АдресаСайтов);
	
КонецПроцедуры

Функция ДанныеСайта(Сайт) Экспорт
	
	ДанныеСайта = РекрутинговыеСайтыСлужебный.НовыеДанныеСайта();
	
	Если Сайт = Обработки.ИнтеграцияHeadHunter.Сайт() Тогда
		ДанныеСайта = Обработки.ИнтеграцияHeadHunter.ДанныеСайта();
	ИначеЕсли Сайт = Обработки.ИнтеграцияSuperJob.Сайт() Тогда
		ДанныеСайта = Обработки.ИнтеграцияSuperJob.ДанныеСайта();
	ИначеЕсли Сайт = Обработки.ИнтеграцияРаботаРу.Сайт() Тогда
		ДанныеСайта = Обработки.ИнтеграцияРаботаРу.ДанныеСайта(); 
	ИначеЕсли Сайт = Обработки.ИнтеграцияЗарплатаРу.Сайт() Тогда
		ДанныеСайта = Обработки.ИнтеграцияЗарплатаРу.ДанныеСайта(); 
	ИначеЕсли Сайт = Обработки.ИнтеграцияАвитоРабота.Сайт() Тогда
		ДанныеСайта = Обработки.ИнтеграцияАвитоРабота.ДанныеСайта(); 
	ИначеЕсли Сайт = Обработки.ИнтеграцияХабрКарьера.Сайт() Тогда
		ДанныеСайта = Обработки.ИнтеграцияХабрКарьера.ДанныеСайта(); 
	Иначе
		РекрутинговыеСайтыВнутреннийПереопределяемый.ПриПолученииДанныхСайта(ДанныеСайта, Сайт);
	КонецЕсли;
	
	Возврат ДанныеСайта;
	
КонецФункции

Функция ПроверитьПодключение(Сайт, МенеджерСайта) Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыеРеквизитыСайта();
	
	Если Сайт = Обработки.ИнтеграцияHeadHunter.Сайт() Тогда
		Результат = Обработки.ИнтеграцияHeadHunter.ПроверитьПодключение(МенеджерСайта);
	ИначеЕсли Сайт = Обработки.ИнтеграцияSuperJob.Сайт() Тогда
		Результат = Обработки.ИнтеграцияSuperJob.ПроверитьПодключение(МенеджерСайта);
	ИначеЕсли Сайт = Обработки.ИнтеграцияРаботаРу.Сайт() Тогда
		Результат = Обработки.ИнтеграцияРаботаРу.ПроверитьПодключение(МенеджерСайта);
	ИначеЕсли Сайт = Обработки.ИнтеграцияЗарплатаРу.Сайт() Тогда
		Результат = Обработки.ИнтеграцияЗарплатаРу.ПроверитьПодключение(МенеджерСайта);
	ИначеЕсли Сайт = Обработки.ИнтеграцияАвитоРабота.Сайт() Тогда
		Результат = Обработки.ИнтеграцияАвитоРабота.ПроверитьПодключение(МенеджерСайта);
	ИначеЕсли Сайт = Обработки.ИнтеграцияХабрКарьера.Сайт() Тогда
		Результат = Обработки.ИнтеграцияХабрКарьера.ПроверитьПодключение(МенеджерСайта);
	Иначе
		РекрутинговыеСайтыВнутреннийПереопределяемый.ПриПроверкеПодключения(Результат, Сайт, МенеджерСайта);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Подключить(Сайт, МенеджерСайта, ПараметрыПодключения) Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыеРеквизитыСайта();
	
	Если Сайт = Обработки.ИнтеграцияHeadHunter.Сайт() Тогда
		Результат = Обработки.ИнтеграцияHeadHunter.Подключить(МенеджерСайта, ПараметрыПодключения);
	ИначеЕсли Сайт = Обработки.ИнтеграцияSuperJob.Сайт() Тогда
		Результат = Обработки.ИнтеграцияSuperJob.Подключить(МенеджерСайта, ПараметрыПодключения);
	ИначеЕсли Сайт = Обработки.ИнтеграцияРаботаРу.Сайт() Тогда
		Результат = Обработки.ИнтеграцияРаботаРу.Подключить(МенеджерСайта, ПараметрыПодключения);
	ИначеЕсли Сайт = Обработки.ИнтеграцияЗарплатаРу.Сайт() Тогда
		Результат = Обработки.ИнтеграцияЗарплатаРу.Подключить(МенеджерСайта, ПараметрыПодключения);
	ИначеЕсли Сайт = Обработки.ИнтеграцияАвитоРабота.Сайт() Тогда
		Результат = Обработки.ИнтеграцияАвитоРабота.Подключить(МенеджерСайта, ПараметрыПодключения);
	ИначеЕсли Сайт = Обработки.ИнтеграцияХабрКарьера.Сайт() Тогда
		Результат = Обработки.ИнтеграцияХабрКарьера.Подключить(МенеджерСайта, ПараметрыПодключения);
	Иначе
		РекрутинговыеСайтыВнутреннийПереопределяемый.ПриПодключении(Результат, Сайт, МенеджерСайта, ПараметрыПодключения);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ВакансииССайта(Сайт, МенеджерСайта, БылиОшибки = Ложь) Экспорт
	
