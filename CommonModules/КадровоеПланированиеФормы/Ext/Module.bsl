#Область СлужебныйПрограммныйИнтерфейс

Процедура ФизическиеЛицаПриСозданииНаСервере(Форма) Экспорт
	
	Если Не КадровоеПланирование.ИспользоватьКадровоеПланирование() Тогда
		Возврат
	КонецЕсли;
	
	УстановитьВидимостьГруппыИстория(Форма);
	
КонецПроцедуры

#Область ШтатноеРасписание

Процедура ШтатноеРасписаниеПриСозданииНаСервере(Форма) Экспорт
	
	Если Не КадровоеПланирование.ИспользоватьКадровоеПланирование() Тогда 
		Возврат;
	КонецЕсли;
	
	Если Не ПравоДоступа("Чтение", Метаданные.РегистрыСведений.ПозицииШтатногоРасписанияПоКадровомуПлану) Тогда
		Форма.Элементы.ГруппаКадровоеПланирование.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Если Не ПравоДоступа("Изменение", Метаданные.РегистрыСведений.ПозицииШтатногоРасписанияПоКадровомуПлану) Тогда
		Форма.Элементы.ГруппаКадровоеПланирование.ТолькоПросмотр = Истина;
	КонецЕсли;
	
	Если Форма.ВнешниеДанные Тогда
		Форма.Элементы.ПозицииКадровогоПлана.ТолькоПросмотр = Истина;
	КонецЕсли;
	
КонецПроцедуры

Процедура ШтатноеРасписаниеПриДополненииФормы(Форма, ИмяГруппыКадровоеПланирование = "КадровоеПланированиеСтраница") Экспорт 
	
	Если НЕ КадровоеПланирование.ИспользоватьКадровоеПланирование() Тогда 
		Возврат;
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Форма.Элементы, ИмяГруппыКадровоеПланирование, "Видимость", НЕ Форма.ВнешниеДанные);
	
	СоздатьРеквизитыФормы(Форма);
	ДобавитьЭлементыФормы(Форма);
	
КонецПроцедуры

Процедура ШтатноеРасписаниеПриЧтенииНаСервере(Форма, ТекущийОбъект) Экспорт
	
	Если Не КадровоеПланирование.ИспользоватьКадровоеПланирование() Тогда
		Возврат;
	КонецЕсли;
	
	ПрочитатьПозиции(Форма, ТекущийОбъект, "ПозицииКадровогоПлана", "ПозицияШтатногоРасписания");
	
КонецПроцедуры

Процедура ШтатноеРасписаниеПередЗаписьюНаСервере(Форма) Экспорт
	
	Если Не ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, "ПозицииКадровогоПлана") Тогда
		Возврат;
	КонецЕсли;
	
	УдалитьДублиПозиций(Форма.ПозицииКадровогоПлана, "ПозицияКадровогоПлана");
	
КонецПроцедуры

Процедура ШтатноеРасписаниеПриЗаписиНаСервере(Форма, Отказ, ТекущийОбъект, ПараметрыЗаписи) Экспорт
	
	Если Не ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, "ПозицииКадровогоПлана") Тогда
		Возврат;
	КонецЕсли;
	
	ЗаписатьСвязанныеПозиции(Форма, Отказ, ТекущийОбъект, "ПозицииКадровогоПлана", "ПозицияШтатногоРасписания");
	
КонецПроцедуры

Процедура ШтатноеРасписаниеОбработкаПроверкиЗаполненияНаСервере(Форма, Отказ, ПроверяемыеРеквизиты) Экспорт
	
	Если Не КадровоеПланирование.ИспользоватьКадровоеПланирование() Тогда
		Возврат;
	КонецЕсли;
	
	ПроверитьЗаполнениеПозицийКадровогоПлана(Форма, Отказ);
	
КонецПроцедуры

Процедура ДополнитьФормуДокументовИзмененияШтатногоРасписания(Форма) Экспорт 
	
	Если Не КадровоеПланирование.ИспользоватьКадровоеПланирование() Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПравоДоступа("Чтение", Метаданные.Справочники.ПозицииКадровогоПлана) Тогда
		Возврат;
	КонецЕсли;
	
	ИмяКоманды = "ЗаполнитьПоКадровомуПлану";
	Элементы = Форма.Элементы;
	
	Если Форма.Команды.Найти(ИмяКоманды) = Неопределено Тогда
		КомандаФормы = Форма.Команды.Добавить(ИмяКоманды);
		КомандаФормы.Заголовок = НСтр("ru = 'Заполнить по кадровому плану'");
		КомандаФормы.Действие = "Подключаемый_" + ИмяКоманды;
		КомандаФормы.ИзменяетСохраняемыеДанные = Истина;
	КонецЕсли;
	
	Если Элементы.Найти(ИмяКоманды) = Неопределено Тогда
		Элемент = Элементы.Добавить(ИмяКоманды, Тип("КнопкаФормы"), Элементы.Позиции.КоманднаяПанель);
		Элемент.Вид = ВидКнопкиФормы.КнопкаКоманднойПанели;
		Элемент.ИмяКоманды = ИмяКоманды;
		Элемент.ПоложениеВКоманднойПанели = ПоложениеКнопкиВКоманднойПанели.ВДополнительномПодменю;
	КонецЕсли;
	
	Если Элементы.Найти("ПозицииПозицияКадровогоПлана") = Неопределено Тогда
		ПолеПозицияКадровогоПлана = Элементы.Добавить("ПозицииПозицияКадровогоПлана", Тип("ПолеФормы"), Элементы.ПодразделениеДолжностьГруппа);
		ПолеПозицияКадровогоПлана.Вид = ВидПоляФормы.ПолеВвода;
		ПолеПозицияКадровогоПлана.ПутьКДанным = "Объект.Позиции.ПозицияКадровогоПлана";
		ПолеПозицияКадровогоПлана.ТолькоПросмотр = Истина;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьДокументПоДаннымЗаполнения(Форма, Позиции) Экспорт 
	
	Если Не КадровоеПланирование.ИспользоватьКадровоеПланирование() Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПравоДоступа("Чтение", Метаданные.Справочники.ПозицииКадровогоПлана) Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураОтбора = Новый Структура("Действие", Перечисления.ДействияСПозициямиШтатногоРасписания.СоздатьНовуюПозицию);
	НовыеПозиции = Позиции.НайтиСтроки(СтруктураОтбора);
	
	Если НовыеПозиции.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
		
	СписокПозиций = Позиции.Выгрузить().ВыгрузитьКолонку("ПозицияКадровогоПлана");
	ПрофилиДолжностей = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(СписокПозиций, "ПрофильДолжности");
	
	Для Каждого СтрокаПозиции Из НовыеПозиции Цикл
		Если ЗначениеЗаполнено(СтрокаПозиции.ПозицияКадровогоПлана)
			И Не ЗначениеЗаполнено(СтрокаПозиции.ПрофильДолжности)
			И Не СтрокаПозиции.ПрофильИзменен Тогда
			
			СтрокаПозиции.ПрофильДолжности = ПрофилиДолжностей.Получить(СтрокаПозиции.ПозицияКадровогоПлана);
			СтрокаПозиции.ДействияХарактеристикиСоответствуютПрофилюДолжностиЧисло = 1;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ПрочитатьПозиции(Форма, ТекущийОбъект, ИмяТаблицыПозиций, ИмяПоляПозиции) Экспорт
	
	НаборЗаписей = РегистрыСведений.ПозицииШтатногоРасписанияПоКадровомуПлану.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор[ИмяПоляПозиции].Установить(ТекущийОбъект.Ссылка);
	НаборЗаписей.Прочитать();
	
	ЗначениеВДанныеФормы(НаборЗаписей, Форма[ИмяТаблицыПозиций]);
	
КонецПроцедуры

Процедура УдалитьДублиПозиций(ТаблицаПозиций, ИмяПоляПозиции) Экспорт
	
	Уникальные = Новый Соответствие;
	
	Индекс = 0;
	Пока Индекс < ТаблицаПозиций.Количество() Цикл
		СтрокаТаблицы = ТаблицаПозиций[Индекс];
		Если Уникальные[СтрокаТаблицы[ИмяПоляПозиции]] = Неопределено Тогда
			Уникальные.Вставить(СтрокаТаблицы[ИмяПоляПозиции], Истина);
			Индекс = Индекс + 1;
		Иначе
			ТаблицаПозиций.Удалить(СтрокаТаблицы);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьСвязанныеПозиции(Форма, Отказ, ТекущийОбъект, ИмяТаблицыПозиций, ИмяПоляПозиции) Экспорт
	
	НаборЗаписей = Форма.РеквизитФормыВЗначение(ИмяТаблицыПозиций);
	Для каждого СтрокаНабора Из НаборЗаписей Цикл
		СтрокаНабора[ИмяПоляПозиции] = ТекущийОбъект.Ссылка;
	КонецЦикла;
	
	НаборЗаписей.Отбор[ИмяПоляПозиции].Установить(ТекущийОбъект.Ссылка);
	НаборЗаписей.Записать();
	
КонецПроцедуры

Процедура УстановитьУсловноеОформлениеПодобранных(Форма) Экспорт
	
	ЭлементОформления = Форма.Список.УсловноеОформление.Элементы.Добавить();
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(
		ЭлементОформления.Отбор, "Ссылка", Форма.Подобранные.ВыгрузитьЗначения());
	ЭлементОформления.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ТекстПодобранногоЗначенияЦвет);
	ЭлементОформления.ИдентификаторПользовательскойНастройки = ИдентификаторПользовательскойНастройкиВыделениеПодобранных();
	ЭлементОформления.Представление = НСтр("ru = 'Выделение подобранных'");
	
КонецПроцедуры

Функция ИдентификаторПользовательскойНастройкиВыделениеПодобранных() Экспорт
	Возврат "ВыделениеПодобранных";
КонецФункции

#Область ШтатноеРасписание

#Область КонструированиеФормы

Процедура СоздатьРеквизитыФормы(Форма)
	
	ДобавляемыеРеквизиты = Новый Массив;
	
	ДобавляемыеРеквизиты.Добавить(
		Новый РеквизитФормы(
			"ПозицииКадровогоПлана", 
			Новый ОписаниеТипов("РегистрСведенийНаборЗаписей.ПозицииШтатногоРасписанияПоКадровомуПлану"),
			, 
			НСтр("ru = 'Позиции кадрового плана'"), 
			Истина));
			
	МассивИменРеквизитовФормы = Новый Массив;
	ЗарплатаКадры.ЗаполнитьМассивИменРеквизитовФормы(Форма, МассивИменРеквизитовФормы);
	ЗарплатаКадры.ИзменитьРеквизитыФормы(Форма, ДобавляемыеРеквизиты, МассивИменРеквизитовФормы);

КонецПроцедуры

Процедура ДобавитьЭлементыФормы(Форма)
	
	Элементы = Форма.Элементы;
	ГруппаРазмещения = Элементы.Найти("ГруппаКадровоеПланирование");
	ГруппаРазмещения.Заголовок = НСтр("ru = 'Позиции кадрового плана'");
	ГруппаРазмещения.ОтображатьЗаголовок = Истина;
	ГруппаРазмещения.Отображение = ОтображениеОбычнойГруппы.СлабоеВыделение;
	ГруппаРазмещения.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	ГруппаРазмещения.Подсказка =
		НСтр("ru = 'ФОТ и количество ставок этой позиции будут использованы при составлении кадрового плана для перечисленных позиций.'");
	ГруппаРазмещения.ОтображениеПодсказки = ОтображениеПодсказки.ОтображатьСнизу;
	ГруппаРазмещения.РасширеннаяПодсказка.АвтоМаксимальнаяШирина = Ложь;
	
	ДобавитьЭлементПозицииКадровогоПлана(Элементы, ГруппаРазмещения);
	
КонецПроцедуры

Процедура ДобавитьЭлементПозицииКадровогоПлана(Элементы, ГруппаРазмещения)
	
	Если Элементы.Найти("ПозицииКадровогоПлана") <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПозицииКадровогоПлана = Элементы.Добавить("ПозицииКадровогоПлана", Тип("ТаблицаФормы"), ГруппаРазмещения);
	ПозицииКадровогоПлана.ПутьКДанным = "ПозицииКадровогоПлана";
	ПозицииКадровогоПлана.Шапка = Ложь;
	
	ПозицияКадровогоПлана = Элементы.Добавить("ПозицииКадровогоПланаПозицияКадровогоПлана", Тип("ПолеФормы"), ПозицииКадровогоПлана);
	ПозицияКадровогоПлана.ПутьКДанным = "ПозицииКадровогоПлана.ПозицияКадровогоПлана";
	ПозицияКадровогоПлана.Вид = ВидПоляФормы.ПолеВвода;
	ПозицияКадровогоПлана.АвтоОтметкаНезаполненного = Истина;
	
КонецПроцедуры

#КонецОбласти

Процедура ПроверитьЗаполнениеПозицийКадровогоПлана(Форма, Отказ)
	
	Для Каждого СтрокаТаблицы Из Форма.ПозицииКадровогоПлана Цикл
		Если Не ЗначениеЗаполнено(СтрокаТаблицы.ПозицияКадровогоПлана) Тогда
			ТекстСообщения = НСтр("ru = 'Позиция кадрового плана не заполнена.'");
			НомерСтроки = Форма.ПозицииКадровогоПлана.Индекс(СтрокаТаблицы) + 1;
			Поле = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("ПозицииКадровогоПлана", НомерСтроки, "ПозицияКадровогоПлана");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , Поле, , Отказ);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

Процедура УстановитьВидимостьГруппыИстория(Форма)
	
	Если Не ПравоДоступа("Чтение", Метаданные.РегистрыСведений.КадроваяИсторияСотрудников) Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Форма.Элементы, "ГруппаИстория", "Видимость", Ложь);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти