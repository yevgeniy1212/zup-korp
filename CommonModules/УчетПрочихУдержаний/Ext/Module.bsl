			|	ВТСведенияОПрочихДоходах_ПрочиеУдержания КАК ВТСведенияОДоходах_ПрочиеУдержания
			|ГДЕ
			|	ВТСведенияОДоходах_ПрочиеУдержания.СпособОбложенияОПВ <> ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.НеОблагаетсяЦеликом)
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	ВТСведенияОДоходах_ПрочиеУдержания.Месяц,
			|	ВТСведенияОДоходах_ПрочиеУдержания.ПериодРегистрации,
			|	ВТСведенияОДоходах_ПрочиеУдержания.Начисление,
			|	ВТСведенияОДоходах_ПрочиеУдержания.ФизическоеЛицо,
			|	ВТСведенияОДоходах_ПрочиеУдержания.Результат,
			|	ВТСведенияОДоходах_ПрочиеУдержания.ВидДохода,
			|	ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ИПН)
			|ИЗ
			|	ВТСведенияОПрочихДоходах_ПрочиеУдержания КАК ВТСведенияОДоходах_ПрочиеУдержания
			|ГДЕ
			|	ВТСведенияОДоходах_ПрочиеУдержания.СпособОбложенияИПН <> ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.НеОблагаетсяЦеликом)
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	ВТСведенияОДоходах_ПрочиеУдержания.Месяц,
			|	ВТСведенияОДоходах_ПрочиеУдержания.ПериодРегистрации,
			|	ВТСведенияОДоходах_ПрочиеУдержания.Начисление,
			|	ВТСведенияОДоходах_ПрочиеУдержания.ФизическоеЛицо,
			|	ВТСведенияОДоходах_ПрочиеУдержания.Результат,
			|	ВТСведенияОДоходах_ПрочиеУдержания.ВидДохода,
			|	ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ВОСМС)
			|ИЗ
			|	ВТСведенияОПрочихДоходах_ПрочиеУдержания КАК ВТСведенияОДоходах_ПрочиеУдержания
			|ГДЕ
			|	ВТСведенияОДоходах_ПрочиеУдержания.СпособОбложенияВОСМС <> ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.НеОблагаетсяЦеликом)
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ
			|	ВТСведенияОДоходах_ПрочиеУдержания.Месяц,
			|	ВТСведенияОДоходах_ПрочиеУдержания.ПериодРегистрации,
			|	ВТСведенияОДоходах_ПрочиеУдержания.Начисление,
			|	ВТСведенияОДоходах_ПрочиеУдержания.ФизическоеЛицо,
			|	ВТСведенияОДоходах_ПрочиеУдержания.Результат,
			|	ВТСведенияОДоходах_ПрочиеУдержания.ВидДохода,
			|	ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ЕП)
			|ИЗ
			|	ВТСведенияОПрочихДоходах_ПрочиеУдержания КАК ВТСведенияОДоходах_ПрочиеУдержания
			|ГДЕ
			|	ВТСведенияОДоходах_ПрочиеУдержания.СпособОбложенияЕП <> ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.НеОблагаетсяЦеликом)
			|";
            
        //ЗУПК В случае, если исправительный документ вводится другим периодом регистрации, меняем условие на период
        Если ИсправленныйДокумент <> Неопределено
            И ЗначениеЗаполнено(ИсправленныйДокумент) Тогда
            ТекстУсловияИсправительныйДокумент = "СведенияОДоходахФизическихЛиц.ПериодРегистрации МЕЖДУ &НачалоПериода И &ОкончаниеПериода";
            Запрос.Текст = СтрЗаменить(Запрос.Текст, "СведенияОДоходахФизическихЛиц.Период МЕЖДУ &НачалоПериода И &ОкончаниеПериода", ТекстУсловияИсправительныйДокумент);
        КонецЕсли; 
        //ЗУПК В случае, если исправительный документ вводится другим периодом регистрации, меняем условие на период

		СведенияОДоходахФизическихЛиц = Запрос.Выполнить().Выгрузить();
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(СведенияОДоходахФизическихЛиц, ОблагаемыеДоходы);
		ИменаВТ.Добавить("ВТСведенияОПрочихДоходах_ПрочиеУдержания");

	КонецЕсли;	
	
	ОблагаемыеДоходы.Свернуть("Месяц,ПериодРегистрации,ФизическоеЛицо,Начисление,ВидДохода,ВидНалогаВзносаОтчисления,Статус", "ОблагаемыйДоход");
	ОблагаемыеДоходы.Индексы.Добавить("Месяц,ФизическоеЛицо");
	
	Для Каждого СтрокаНалога Из НалогиВзносыПоВидамДоходов Цикл 
		КоэффициентыРаспределения = Новый Массив;
		Отбор = Новый Структура("Месяц,ФизическоеЛицо,ВидДохода,ВидНалогаВзносаОтчисления", СтрокаНалога.Месяц, СтрокаНалога.ФизическоеЛицо, СтрокаНалога.ВидДохода, СтрокаНалога.ВидНалогаВзносаОтчисления);
	    ДоходыФизическогоЛица = ОблагаемыеДоходы.НайтиСтроки(Отбор);
		Для Каждого СтрокаДохода Из ДоходыФизическогоЛица Цикл 
			КоэффициентыРаспределения.Добавить(СтрокаДохода.ОблагаемыйДоход);
		КонецЦикла;
		РезультатРаспределения = ЗарплатаКадрыКлиентСервер.РаспределитьПропорциональноКоэффициентам(СтрокаНалога.НалогВзнос, КоэффициентыРаспределения);
		Если РезультатРаспределения <> Неопределено Тогда 
			Индекс = 0;
			Для Каждого СтрокаДохода Из ДоходыФизическогоЛица Цикл 
				НоваяСтрока = НалогиВзносы.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДохода);
                Если ИсправленныйДокумент <> Неопределено
                    И ЗначениеЗаполнено(ИсправленныйДокумент) Тогда
                    НоваяСтрока.Месяц = СтрокаДохода.ПериодРегистрации;
                КонецЕсли; 
				
				Если ПорядокОбложенияЕдинымПлатежом
					И СтрокаДохода.Статус = Перечисления.СтатусыФизическихЛицНалогоплательщиков.Резидент
					И СтрокаДохода.ВидДохода = Справочники.ВидыДоходов.ДоходыОтРаботодателя Тогда
					
					// в межрасчетных используем сумму ЕП (тк рассчитывается сумма ЕП только за счет работника)
					// в окончтальном расчете используем ОПВ, ВОСМС, ОПВ (вместо ЕП, тк появляется точное деление по компонентам ЕП)
					Если СтрокаНалога.ВидДохода = Справочники.ВидыДоходов.ДоходыОтРаботодателя Тогда
						
						Если НастройкиУдержаний.РассчитыватьТолькоПоТекущемуДокументу
							И СтрокаНалога.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ЕП Тогда
							НоваяСтрока.ЕП = РезультатРаспределения[Индекс];
						Иначе
							Если НЕ СтрокаНалога.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ЕП Тогда
								НоваяСтрока.ЕП = НоваяСтрока.ЕП + РезультатРаспределения[Индекс];
							КонецЕсли;
						КонецЕсли;
					
						Индекс = Индекс + 1;
						
						Продолжить;
					
					КонецЕсли;
					
				КонецЕсли;
				
				Если СтрокаНалога.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ОПВ Тогда
					НоваяСтрока.ОПВ = РезультатРаспределения[Индекс];
				ИначеЕсли СтрокаНалога.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС Тогда
					НоваяСтрока.ВОСМС = РезультатРаспределения[Индекс];
				ИначеЕсли СтрокаНалога.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ИПН Тогда
					НоваяСтрока.ИПН = РезультатРаспределения[Индекс];
				КонецЕсли;
				Индекс = Индекс + 1;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	НалогиВзносы.Свернуть("Месяц,ФизическоеЛицо,Начисление", "ОПВ,ВОСМС,ИПН,ЕП");
	НалогиВзносы.Индексы.Добавить("Месяц,ФизическоеЛицо,Начисление");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, ИменаВТ);
	
	Возврат НалогиВзносы;
	
КонецФункции

Функция ИсчисленныеНалогиВзносыДо2022(МенеджерВременныхТаблиц, ОписаниеВТ, МесяцНачисления, ЗарплатаЗаМесяц, ИсключаемыйРегистратор, НастройкиУдержаний, ОчередностьРасчета = Неопределено, ЭтоИсправлениеТекущимПериодом = Ложь, ИсправленныйДокумент = Неопределено) 
	
	НалогиВзносы = РегистрыНакопления.СведенияОДоходахФизическихЛиц.СоздатьНаборЗаписей().Выгрузить(, "Период,ФизическоеЛицо,Начисление");
	НалогиВзносы.Колонки.Период.Имя = "Месяц";
	НалогиВзносы.Колонки.Добавить("ОПВ", Новый ОписаниеТипов("Число"));
	НалогиВзносы.Колонки.Добавить("ВОСМС", Новый ОписаниеТипов("Число"));
	НалогиВзносы.Колонки.Добавить("ИПН", Новый ОписаниеТипов("Число"));
	
	Запрос = Новый Запрос;
	
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МИНИМУМ(Удержания.НачалоПериода) КАК НачалоПериода,
		|	МАКСИМУМ(Удержания.ОкончаниеПериода) КАК ОкончаниеПериода
		|ИЗ
		|	ВТУдержания КАК Удержания";
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВТУдержания", ОписаниеВТ.ИмяВТ);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "Удержания.НачалоПериода", "Удержания." + ОписаниеВТ.ИмяПоляНачалоПериода);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "Удержания.ОкончаниеПериода", "Удержания." + ОписаниеВТ.ИмяПоляОкончаниеПериода);
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	ИменаВТ = Новый Массив;
	
	Если НЕ ЗарплатаКадры.ВТСуществует(МенеджерВременныхТаблиц, "ВТДатыПоМесяцам") Тогда 
		
		// Таблица ВТДатыПоМесяцам: список налоговых периодов, в которых выполняется расчет.
		ЗарплатаКадрыОбщиеНаборыДанных.СоздатьВТПериоды(МенеджерВременныхТаблиц, НачалоГода(Выборка.НачалоПериода), НачалоМесяца(Выборка.ОкончаниеПериода),,,"ВТДатыПоМесяцам");
		ИменаВТ.Добавить("ВТДатыПоМесяцам");
		
	КонецЕсли;
	
	Если НЕ ЗарплатаКадры.ВТСуществует(МенеджерВременныхТаблиц, "ВТНалогообложениеНачислений") Тогда 
		
		УчетНалоговВзносовОтчислений.СоздатьВТНалогообложениеНачисленийПоПериодам(МенеджерВременныхТаблиц);
		ИменаВТ.Добавить("ВТНалогообложениеНачислений");
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоМесяца(Выборка.НачалоПериода));
	Запрос.УстановитьПараметр("ОкончаниеПериода", КонецМесяца(Выборка.ОкончаниеПериода));
	Запрос.УстановитьПараметр("ИсключаемыйРегистратор", ИсключаемыйРегистратор);
	Запрос.УстановитьПараметр("ВидыУдержанийНалоговВзносов", Обработки.МенеджерРасчетаЗарплаты.ВидыНалоговВзносовДополненияРасчетнойБазыУдержаний());
	ВидыНалоговВзносов = Новый Массив;
	ВидыНалоговВзносов.Добавить(Перечисления.ВидыНалоговВзносовОтчислений.ИПН);
	ВидыНалоговВзносов.Добавить(Перечисления.ВидыНалоговВзносовОтчислений.ОПВ);
	ВидыНалоговВзносов.Добавить(Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС);
	Запрос.УстановитьПараметр("ВидыНалоговВзносов", ВидыНалоговВзносов);
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ДанныеУдержаний.НомерСтроки КАК НомерСтроки,
	               |	ДанныеУдержаний.Организация КАК Организация,
	               |	ДанныеУдержаний.Организация.ГоловнаяОрганизация КАК ГоловнаяОрганизация,
	               |	ДанныеУдержаний.ФизическоеЛицо КАК ФизическоеЛицо,
	               |	ДанныеУдержаний.ВидРасчета КАК ВидРасчета,
	               |	ДанныеУдержаний.ДокументОснование КАК ИсполнительныйДокумент
	               |ПОМЕСТИТЬ ВТУдержанияПоПрочимУдержаниям
	               |ИЗ
	               |	ВТРегистрРасчета_Удержания КАК ДанныеУдержаний
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланВидовРасчета.Удержания КАК Удержания
	               |		ПО ДанныеУдержаний.ВидРасчета = Удержания.Ссылка
	               |			И (Удержания.КатегорияУдержания = ЗНАЧЕНИЕ(Перечисление.КатегорииУдержаний.ИсполнительныйЛист)
  	               |			    ИЛИ Удержания.ВычитатьИзРасчетнойБазыНалогиВзносы)
	               |			И (&УсловиеОчередностьРасчета)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ИСТИНА КАК ЗначениеИстина
	               |ИЗ
	               |	ВТУдержанияПоПрочимУдержаниям КАК УдержанияПоПрочимУдержаниям";
	
	Если ОчередностьРасчета = Неопределено Тогда
		ТекстУсловияОчередность = "ИСТИНА";
	Иначе
		ТекстУсловияОчередность = "Удержания.ОчередностьРасчета = &ОчередностьРасчета";
		Запрос.УстановитьПараметр("ОчередностьРасчета", ОчередностьРасчета);
	КонецЕсли;	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОчередностьРасчета", ТекстУсловияОчередность);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ИменаВТ.Добавить("ВТУдержанияПоПрочимУдержаниям");
	
	Если РезультатЗапроса.Пустой() Тогда
		ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, ИменаВТ);
		Возврат НалогиВзносы;
	КонецЕсли;
	
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	УдержанияПоПрочимУдержаниям.ГоловнаяОрганизация КАК ГоловнаяОрганизация,
	               |	УдержанияПоПрочимУдержаниям.ФизическоеЛицо КАК ФизическоеЛицо
	               |ПОМЕСТИТЬ ВТФизическиеЛицаПрочиеУдержания
	               |ИЗ
	               |	ВТУдержанияПоПрочимУдержаниям КАК УдержанияПоПрочимУдержаниям
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ФизическиеЛица.ФизическоеЛицо КАК ФизическоеЛицо
	               |ИЗ
	               |	ВТФизическиеЛицаПрочиеУдержания КАК ФизическиеЛица";
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	ИменаВТ.Добавить("ВТФизическиеЛицаПрочиеУдержания");
	
	МассивСтрок = ЗарплатаЗаМесяц.НалогиВзносыОтчисления.НайтиСтроки(Новый Структура("ВидНалогаВзносаОтчисления",Перечисления.ВидыНалоговВзносовОтчислений.ИПН));
	НалогиВзносыПоВидамДоходов = ЗарплатаЗаМесяц.НалогиВзносыОтчисления.Скопировать(МассивСтрок,"ФизическоеЛицо,МесяцНалоговогоПериода,ВидДохода,ВидНалогаВзносаОтчисления,НалогВзнос");
	
	МассивСтрок = ЗарплатаЗаМесяц.НалогиВзносыОтчисления.НайтиСтроки(Новый Структура("ВидНалогаВзносаОтчисления",Перечисления.ВидыНалоговВзносовОтчислений.ОПВ));
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ЗарплатаЗаМесяц.НалогиВзносыОтчисления.Скопировать(МассивСтрок,"ФизическоеЛицо,МесяцНалоговогоПериода,ВидДохода,ВидНалогаВзносаОтчисления,НалогВзнос"), НалогиВзносыПоВидамДоходов);
	
	МассивСтрок = ЗарплатаЗаМесяц.НалогиВзносыОтчисления.НайтиСтроки(Новый Структура("ВидНалогаВзносаОтчисления",Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС));
