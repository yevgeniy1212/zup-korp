		ИменаВТ.Добавить("ВТНалогиВзносыОтчисленияЕП");
		ИменаВТ.Добавить("ВТКомпонентыЕП");
	
	КонецЕсли;

	НалогиВзносыПоВидамДоходов.Колонки.МесяцНалоговогоПериода.Имя = "Месяц";
	
	Если НЕ НастройкиУдержаний.РассчитыватьТолькоПоТекущемуДокументу Тогда 
		
		Запрос.Текст = "ВЫБРАТЬ
		               |	НАЧАЛОПЕРИОДА(РанееИсчисленныйНалог.Месяц, МЕСЯЦ) КАК Месяц,
		               |	РанееИсчисленныйНалог.ФизическоеЛицо КАК ФизическоеЛицо,
