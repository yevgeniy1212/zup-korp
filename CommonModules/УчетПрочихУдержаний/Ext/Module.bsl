			|	ВТСведенияОПрочихДоходах_ПрочиеУдержания КАК ВТСведенияОДоходах_ПрочиеУдержания
			|ГДЕ
			|	ВТСведенияОДоходах_ПрочиеУдержания.СпособОбложенияСО <> ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.НеОблагаетсяЦеликом)
            |		И ВТСведенияОДоходах_ПрочиеУдержания.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтНалоговогоАгента)
			|
			|ОБЪЕДИНИТЬ ВСЕ
            |
			|ВЫБРАТЬ
			|	ВТСведенияОДоходах_ПрочиеУдержания.Месяц,
			|	ВТСведенияОДоходах_ПрочиеУдержания.ПериодРегистрации,
			|	ВТСведенияОДоходах_ПрочиеУдержания.Начисление,
			|	ВТСведенияОДоходах_ПрочиеУдержания.ФизическоеЛицо,
			|	ВТСведенияОДоходах_ПрочиеУдержания.Результат,
			|	ВТСведенияОДоходах_ПрочиеУдержания.ВидДохода,
			|	ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ЕП)
			|ИЗ
			|	ВТСведенияОПрочихДоходах_ПрочиеУдержания КАК ВТСведенияОДоходах_ПрочиеУдержания
			|ГДЕ
			|	ВТСведенияОДоходах_ПрочиеУдержания.СпособОбложенияЕП <> ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.НеОблагаетсяЦеликом)
			|";
            
        //ЗУПК В случае, если исправительный документ вводится другим периодом регистрации, меняем условие на период
        Если ИсправленныйДокумент <> Неопределено
            И ЗначениеЗаполнено(ИсправленныйДокумент) Тогда
            ТекстУсловияИсправительныйДокумент = "СведенияОДоходахФизическихЛиц.ПериодРегистрации МЕЖДУ &НачалоПериода И &ОкончаниеПериода";
            Запрос.Текст = СтрЗаменить(Запрос.Текст, "СведенияОДоходахФизическихЛиц.Период МЕЖДУ &НачалоПериода И &ОкончаниеПериода", ТекстУсловияИсправительныйДокумент);
        КонецЕсли; 
        //ЗУПК В случае, если исправительный документ вводится другим периодом регистрации, меняем условие на период

		СведенияОДоходахФизическихЛиц = Запрос.Выполнить().Выгрузить();
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(СведенияОДоходахФизическихЛиц, ОблагаемыеДоходы);
		ИменаВТ.Добавить("ВТСведенияОПрочихДоходах_ПрочиеУдержания");

	КонецЕсли;	
	
	ОблагаемыеДоходы.Свернуть("Месяц,ПериодРегистрации,ФизическоеЛицо,Начисление,ВидДохода,ВидНалогаВзносаОтчисления,Статус", "ОблагаемыйДоход");
	ОблагаемыеДоходы.Индексы.Добавить("Месяц,ФизическоеЛицо");
	
	Для Каждого СтрокаНалога Из НалогиВзносыПоВидамДоходов Цикл 
		КоэффициентыРаспределения = Новый Массив;
		Отбор = Новый Структура("Месяц,ФизическоеЛицо,ВидДохода,ВидНалогаВзносаОтчисления", СтрокаНалога.Месяц, СтрокаНалога.ФизическоеЛицо, СтрокаНалога.ВидДохода, СтрокаНалога.ВидНалогаВзносаОтчисления);
	    ДоходыФизическогоЛица = ОблагаемыеДоходы.НайтиСтроки(Отбор);
		Для Каждого СтрокаДохода Из ДоходыФизическогоЛица Цикл 
			КоэффициентыРаспределения.Добавить(СтрокаДохода.ОблагаемыйДоход);
		КонецЦикла;
		НалогВзнос = СтрокаНалога.НалогВзнос + СтрокаНалога.НалогВзносСПревышения;
		РезультатРаспределения = ЗарплатаКадрыКлиентСервер.РаспределитьПропорциональноКоэффициентам(НалогВзнос, КоэффициентыРаспределения);
		Если РезультатРаспределения <> Неопределено Тогда 
			Индекс = 0;
			Для Каждого СтрокаДохода Из ДоходыФизическогоЛица Цикл 
				НоваяСтрока = НалогиВзносы.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДохода);
                Если ИсправленныйДокумент <> Неопределено
                    И ЗначениеЗаполнено(ИсправленныйДокумент) Тогда
                    НоваяСтрока.Месяц = СтрокаДохода.ПериодРегистрации;
                КонецЕсли; 
				
				Если ПорядокОбложенияЕдинымПлатежом
					И СтрокаДохода.Статус = Перечисления.СтатусыФизическихЛицНалогоплательщиков.Резидент
					И СтрокаДохода.ВидДохода = Справочники.ВидыДоходов.ДоходыОтРаботодателя Тогда
					
					// в межрасчетных используем сумму ЕП (тк рассчитывается сумма ЕП только за счет работника)
					// в окончтальном расчете используем ОПВ, ВОСМС, ОПВ (вместо ЕП, тк появляется точное деление по компонентам ЕП)
					Если СтрокаНалога.ВидДохода = Справочники.ВидыДоходов.ДоходыОтРаботодателя Тогда
						
						Если НастройкиУдержаний.РассчитыватьТолькоПоТекущемуДокументу
							И СтрокаНалога.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ЕП Тогда
							НоваяСтрока.ЕП = РезультатРаспределения[Индекс];
						Иначе
							Если НЕ СтрокаНалога.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ЕП Тогда
								НоваяСтрока.ЕП = НоваяСтрока.ЕП + РезультатРаспределения[Индекс];
							КонецЕсли;
						КонецЕсли;
					
						Индекс = Индекс + 1;
						
						Продолжить;
					
					КонецЕсли;
					
				КонецЕсли;
				
				Если СтрокаНалога.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ОПВ Тогда
					НоваяСтрока.ОПВ = РезультатРаспределения[Индекс];
				ИначеЕсли СтрокаНалога.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС Тогда
					НоваяСтрока.ВОСМС = РезультатРаспределения[Индекс];
				ИначеЕсли СтрокаНалога.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ИПН Тогда
					НоваяСтрока.ИПН = РезультатРаспределения[Индекс];
                ИначеЕсли СтрокаНалога.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.СО
                    И СтрокаНалога.ВидДохода = Справочники.ВидыДоходов.ДоходыОтНалоговогоАгента Тогда
					НоваяСтрока.СО = РезультатРаспределения[Индекс];
                КонецЕсли;
				Индекс = Индекс + 1;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;

	НалогиВзносы.Свернуть("Месяц,ФизическоеЛицо,Начисление", "ОПВ,ВОСМС,ИПН,ЕП,СО");
    НалогиВзносы.Индексы.Добавить("Месяц,ФизическоеЛицо,Начисление");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, ИменаВТ);
	
	Возврат НалогиВзносы;
	
КонецФункции

Процедура ЗаполнитьПоказателиПрочихУдержаний(ОчередностьРасчета, СтрокиПоИдентификатору, МенеджерВременныхТаблиц, МесяцНачисления) Экспорт
	
	УдалитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
    	Запрос.УстановитьПараметр("ОчередностьРасчета", ОчередностьРасчета);

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Удержания.ИдентификаторСтроки,
		|	Удержания.ДокументОснование КАК ИсполнительныйДокумент,
		|	Удержания.БазовыйПериодНачало КАК Период,
		|	НАЧАЛОПЕРИОДА(Удержания.БазовыйПериодНачало, МЕСЯЦ) КАК Месяц,
		|	Удержания.ФизическоеЛицо,
		|	Удержания.Организация,
		|	ВидыРасчета.ФормулаРасчетаДляВыполнения КАК ФормулаДляВыполнения,
		|	ВидыРасчета.ФормулаРасчета КАК ФормулаДляПредставления,
        |	ВидыРасчета.ВычитатьИзРасчетнойБазыНалогиВзносы КАК ВычитатьИзРасчетнойБазыНалогиВзносы
        |ИЗ
		|	ВТРегистрРасчета_Удержания КАК Удержания
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланВидовРасчета.Удержания КАК ВидыРасчета
		|		ПО (ВидыРасчета.Ссылка = Удержания.ВидРасчета)
		|			И (ВидыРасчета.ОчередностьРасчета = &ОчередностьРасчета)
		|			И (ВидыРасчета.ИспользуетФормулу = ИСТИНА)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Удержания.ИдентификаторСтроки";

    Выборка = Запрос.Выполнить().Выбрать();
    
    ПоказательРасчетнаяБаза = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.РасчетнаяБаза");
    ПоказательИсчисленныйПоУдержаниюОПВ = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ИсчисленныйПоУдержаниюОПВ");
    ПоказательИсчисленныйПоУдержаниюВОСМС = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ИсчисленныйПоУдержаниюВОСМС");
    ПоказательИсчисленныйПоУдержаниюИПН = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ИсчисленныйПоУдержаниюИПН");
	ПоказательИсчисленныйПоУдержаниюЕП = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ИсчисленныйПоУдержаниюЕП");
    Пока Выборка.СледующийПоЗначениюПоля("ИдентификаторСтроки") Цикл
        Строка = СтрокиПоИдентификатору[Выборка.ИдентификаторСтроки];
        Если Строка.ФиксЗаполнение Тогда 
            Строка.Результат = Строка.ЗаписьРасчета.Результат;
            Продолжить;
        КонецЕсли;
        Если НЕ Выборка.ВычитатьИзРасчетнойБазыНалогиВзносы Тогда
            Продолжить;
        КонецЕсли; 
        ИсходныеДанные = Новый Структура;
        Пока Выборка.Следующий() Цикл
            РасчетнаяБаза = Строка.Дополнительно.СуммаДополнения;
            ИсчисленныйПоУдержаниюОПВ = Строка.Дополнительно.СуммаОПВ;
            ИсчисленныйПоУдержаниюВОСМС = Строка.Дополнительно.СуммаВОСМС;
            ИсчисленныйПоУдержаниюИПН = Строка.Дополнительно.СуммаИПН;
            ИсчисленныйПоУдержаниюЕП = Строка.Дополнительно.СуммаЕП;
            Для Каждого СтрокаРасшифровки Из Строка.Дополнительно.РасшифровкаРасчетнойБазы Цикл
                РасчетнаяБаза = РасчетнаяБаза + СтрокаРасшифровки.Сумма + СтрокаРасшифровки.СуммаДополнения;
                Если Выборка.ВычитатьИзРасчетнойБазыНалогиВзносы Тогда
                    ИсчисленныйПоУдержаниюИПН = ИсчисленныйПоУдержаниюИПН + СтрокаРасшифровки.СуммаИПН;                  
                    ИсчисленныйПоУдержаниюОПВ = ИсчисленныйПоУдержаниюОПВ + СтрокаРасшифровки.СуммаОПВ;
                    ИсчисленныйПоУдержаниюВОСМС = ИсчисленныйПоУдержаниюВОСМС + СтрокаРасшифровки.СуммаВОСМС;
                    ИсчисленныйПоУдержаниюЕП = ИсчисленныйПоУдержаниюЕП + СтрокаРасшифровки.СуммаЕП;
                КонецЕсли;
            КонецЦикла;
            
            СтрокаПоказателя = РасчетЗарплатыРасширенный.СтрокаЗначенияПоказателяПоИдентификатору(Строка.Показатели, "РасчетнаяБаза");
            Если СтрокаПоказателя = Неопределено Тогда 
                СтрокаПоказателя = Строка.Показатели.Добавить();
                СтрокаПоказателя.Показатель = ПоказательРасчетнаяБаза;
            КонецЕсли;
            СтрокаПоказателя.Значение = РасчетнаяБаза;
            
            Если Выборка.ВычитатьИзРасчетнойБазыНалогиВзносы Тогда
                //ОПВ
                СтрокаПоказателя = РасчетЗарплатыРасширенный.СтрокаЗначенияПоказателяПоИдентификатору(Строка.Показатели, "ИсчисленныйПоУдержаниюОПВ");
                Если СтрокаПоказателя = Неопределено Тогда 
                    СтрокаПоказателя = Строка.Показатели.Добавить();
                    СтрокаПоказателя.Показатель = ПоказательИсчисленныйПоУдержаниюОПВ;
                КонецЕсли;
                СтрокаПоказателя.Значение = ИсчисленныйПоУдержаниюОПВ;
                
                // ВОСМС
                СтрокаПоказателя = РасчетЗарплатыРасширенный.СтрокаЗначенияПоказателяПоИдентификатору(Строка.Показатели, "ИсчисленныйПоУдержаниюВОСМС");
                Если СтрокаПоказателя = Неопределено Тогда 
                    СтрокаПоказателя = Строка.Показатели.Добавить();
                    СтрокаПоказателя.Показатель = ПоказательИсчисленныйПоУдержаниюВОСМС;
                КонецЕсли;
                СтрокаПоказателя.Значение = ИсчисленныйПоУдержаниюВОСМС;
                
                // ИПН
                СтрокаПоказателя = РасчетЗарплатыРасширенный.СтрокаЗначенияПоказателяПоИдентификатору(Строка.Показатели, "ИсчисленныйПоУдержаниюИПН");
                Если СтрокаПоказателя = Неопределено Тогда 
                    СтрокаПоказателя = Строка.Показатели.Добавить();
                    СтрокаПоказателя.Показатель = ПоказательИсчисленныйПоУдержаниюИПН;
                КонецЕсли;
                СтрокаПоказателя.Значение = ИсчисленныйПоУдержаниюИПН;
				
				// ЕП
                СтрокаПоказателя = РасчетЗарплатыРасширенный.СтрокаЗначенияПоказателяПоИдентификатору(Строка.Показатели, "ИсчисленныйПоУдержаниюЕП");
                Если СтрокаПоказателя = Неопределено Тогда 
                    СтрокаПоказателя = Строка.Показатели.Добавить();
                    СтрокаПоказателя.Показатель = ПоказательИсчисленныйПоУдержаниюЕП;
                КонецЕсли;
                СтрокаПоказателя.Значение = ИсчисленныйПоУдержаниюЕП;
            КонецЕсли;
        КонецЦикла;
    КонецЦикла;
    
КонецПроцедуры

#КонецОбласти
