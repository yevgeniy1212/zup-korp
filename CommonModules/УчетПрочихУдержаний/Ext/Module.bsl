		               |				И (КомпонентыЕП.Период МЕЖДУ &НачалоПериода И &ОкончаниеПериода)
		               |	ГДЕ
		               |		КомпонентыЕП.ОПВ <> 0
		               |		И &ПорядокЕдинымПлатежом
		               |	
		               |	ОБЪЕДИНИТЬ ВСЕ
		               |	
		               |	ВЫБРАТЬ
		               |		КомпонентыЕП.МесяцНалоговогоПериода,
		               |		КомпонентыЕП.ФизическоеЛицо,
		               |		КомпонентыЕП.ВОСМС,
		               |		ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ВОСМС),
		               |		ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		               |	ИЗ
		               |		РегистрНакопления.ЕПКомпоненты КАК КомпонентыЕП
		               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТФизическиеЛицаПрочиеУдержания КАК ФизическиеЛица
		               |			ПО КомпонентыЕП.Организация.ГоловнаяОрганизация = ФизическиеЛица.ГоловнаяОрганизация
		               |				И КомпонентыЕП.ФизическоеЛицо = ФизическиеЛица.ФизическоеЛицо
		               |				И (КомпонентыЕП.Регистратор <> &ИсключаемыйРегистратор)
		               |				И (КомпонентыЕП.Период МЕЖДУ &НачалоПериода И &ОкончаниеПериода)
		               |	ГДЕ
		               |		КомпонентыЕП.ВОСМС <> 0
		               |		И &ПорядокЕдинымПлатежом) КАК РанееИсчисленныйНалог
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	НАЧАЛОПЕРИОДА(РанееИсчисленныйНалог.Месяц, МЕСЯЦ),
		               |	РанееИсчисленныйНалог.ФизическоеЛицо,
		               |	РанееИсчисленныйНалог.ВидНалогаВзносаОтчисления,
		               |	РанееИсчисленныйНалог.ВидДохода";
		
		РанееИсчисленныйНалог = Запрос.Выполнить().Выгрузить();
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(РанееИсчисленныйНалог, НалогиВзносыПоВидамДоходов);

	КонецЕсли;
	
	ФизическиеЛица = Новый Соответствие;
	Выборка = РезультатыЗапроса[1].Выбрать();
	Пока Выборка.Следующий() Цикл 
		ФизическиеЛица.Вставить(Выборка.ФизическоеЛицо, Истина);
	КонецЦикла;
	
	НалогиВзносыПоВидамДоходов.Свернуть("Месяц,ФизическоеЛицо,ВидДохода,ВидНалогаВзносаОтчисления", "НалогВзнос");
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(СведенияОДоходах.Период, МЕСЯЦ) КАК Месяц,
        |   СведенияОДоходах.ПериодРегистрации КАК ПериодРегистрации, 
		|	СведенияОДоходах.ФизическоеЛицо КАК ФизическоеЛицо,
		// ЗУПК для договорников базу не используем, собираем базу по виду операци по зарплате ДоговорРаботыУслуги (подразумеваем, что сюда входит и ДоговорАвторскогоЗаказа)
		|	ВЫБОР
		|		КОГДА НалогообложениеНачислений.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтНалоговогоАгента)
		|			И НЕ (ТИПЗНАЧЕНИЯ(СведенияОДоходах.Начисление) = ТИП(Справочник.ВидыВыплатБывшимСотрудникам)
		|				ИЛИ ТИПЗНАЧЕНИЯ(СведенияОДоходах.Начисление) = ТИП(Справочник.ВидыПрочихДоходовФизическихЛиц))
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ВидыОсобыхНачисленийИУдержаний.ДоговорРаботыУслуги)
		|		ИНАЧЕ СведенияОДоходах.Начисление
		|	КОНЕЦ КАК Начисление,
		// ЗУПК для договорников базу не используем, собираем базу по виду операци по зарплате ДоговорРаботыУслуги (подразумеваем, что сюда входит и ДоговорАвторскогоЗаказа)
		|	СведенияОДоходах.СуммаДохода КАК Результат,
		|	ЕСТЬNULL(СтатусыФизическихЛицКакНалогоплательщиков.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.ПустаяСсылка)) КАК Статус,
		|	НалогообложениеНачислений.ВидДохода КАК ВидДохода,
		|	НалогообложениеНачислений.СпособОбложенияОПВ КАК СпособОбложенияОПВ,
		|	НалогообложениеНачислений.СпособОбложенияИПН КАК СпособОбложенияИПН,
		|	НалогообложениеНачислений.СпособОбложенияВОСМС КАК СпособОбложенияВОСМС,
        |	НалогообложениеНачислений.СпособОбложенияСО КАК СпособОбложенияСО,
        |	НалогообложениеНачислений.СпособОбложенияЕП КАК СпособОбложенияЕП
		|ПОМЕСТИТЬ ВТСведенияОДоходах_ПрочиеУдержания
		|ИЗ
		|	ВТРегистрНакопления_СведенияОДоходахФизическихЛиц КАК СведенияОДоходах
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТФизическиеЛицаПрочиеУдержания КАК ФизическиеЛица
		|		ПО (СведенияОДоходах.Период МЕЖДУ &НачалоПериода И &ОкончаниеПериода)
		|			И СведенияОДоходах.Организация.ГоловнаяОрганизация = ФизическиеЛица.ГоловнаяОрганизация
		|			И СведенияОДоходах.ФизическоеЛицо = ФизическиеЛица.ФизическоеЛицо
		|			И (&УсловиеСторно)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНалогообложениеНачислений КАК НалогообложениеНачислений
		|		ПО СведенияОДоходах.Начисление = НалогообложениеНачислений.Начисление
		|			И (НАЧАЛОПЕРИОДА(СведенияОДоходах.Период, МЕСЯЦ) = НалогообложениеНачислений.МесяцНалоговогоПериода)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтатусыФизическихЛицКакНалогоплательщиков КАК СтатусыФизическихЛицКакНалогоплательщиков
		|		ПО НАЧАЛОПЕРИОДА(СведенияОДоходах.Период, МЕСЯЦ) = СтатусыФизическихЛицКакНалогоплательщиков.МесяцНалоговогоПериода
		|			И СведенияОДоходах.ФизическоеЛицо = СтатусыФизическихЛицКакНалогоплательщиков.ФизическоеЛицо
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(СведенияОНеоблагаемыхДоходах.МесяцНалоговогоПериода, МЕСЯЦ) КАК Месяц,
		|	СведенияОНеоблагаемыхДоходах.ФизическоеЛицо КАК ФизическоеЛицо,
		// ЗУПК для договорников базу не используем, собираем базу по виду операци по зарплате ДоговорРаботыУслуги (подразумеваем, что сюда входит и ДоговорАвторскогоЗаказа)
		|	ВЫБОР
		|		КОГДА НалогообложениеНачислений.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтНалоговогоАгента)
		|			И НЕ (ТИПЗНАЧЕНИЯ(СведенияОНеоблагаемыхДоходах.Начисление) = ТИП(Справочник.ВидыВыплатБывшимСотрудникам)
		|				ИЛИ ТИПЗНАЧЕНИЯ(СведенияОНеоблагаемыхДоходах.Начисление) = ТИП(Справочник.ВидыПрочихДоходовФизическихЛиц))
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ВидыОсобыхНачисленийИУдержаний.ДоговорРаботыУслуги)
		|		ИНАЧЕ СведенияОНеоблагаемыхДоходах.Начисление
		|	КОНЕЦ КАК Начисление,
		// ЗУПК для договорников базу не используем, собираем базу по виду операци по зарплате ДоговорРаботыУслуги (подразумеваем, что сюда входит и ДоговорАвторскогоЗаказа)
		|	СведенияОНеоблагаемыхДоходах.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	НалогообложениеНачислений.ВидДохода КАК ВидДохода,
		|	ЕСТЬNULL(СтатусыФизическихЛицКакНалогоплательщиков.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.ПустаяСсылка)) КАК Статус,
		|	СведенияОНеоблагаемыхДоходах.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления
		|ПОМЕСТИТЬ ВТСведенияОНеоблагаемыхДоходах_ПрочиеУдержания
		|ИЗ
		|	ВТСведенияОНеоблагаемыхДоходах КАК СведенияОНеоблагаемыхДоходах
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТФизическиеЛицаПрочиеУдержания КАК ФизическиеЛица
		|		ПО (СведенияОНеоблагаемыхДоходах.МесяцНалоговогоПериода МЕЖДУ &НачалоПериода И &ОкончаниеПериода)
		|			И СведенияОНеоблагаемыхДоходах.ФизическоеЛицо = ФизическиеЛица.ФизическоеЛицо
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНалогообложениеНачислений КАК НалогообложениеНачислений
		|		ПО СведенияОНеоблагаемыхДоходах.Начисление = НалогообложениеНачислений.Начисление
		|			И (НАЧАЛОПЕРИОДА(СведенияОНеоблагаемыхДоходах.МесяцНалоговогоПериода, МЕСЯЦ) = НалогообложениеНачислений.МесяцНалоговогоПериода)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтатусыФизическихЛицКакНалогоплательщиков КАК СтатусыФизическихЛицКакНалогоплательщиков
		|		ПО НАЧАЛОПЕРИОДА(СведенияОНеоблагаемыхДоходах.МесяцНалоговогоПериода, МЕСЯЦ) = СтатусыФизическихЛицКакНалогоплательщиков.МесяцНалоговогоПериода
		|			И СведенияОНеоблагаемыхДоходах.ФизическоеЛицо = СтатусыФизическихЛицКакНалогоплательщиков.ФизическоеЛицо
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТСведенияОДоходах_ПрочиеУдержания.Месяц КАК Месяц,
        |   ВТСведенияОДоходах_ПрочиеУдержания.ПериодРегистрации КАК ПериодРегистрации, 
		|	ВТСведенияОДоходах_ПрочиеУдержания.Начисление КАК Начисление,
		|	ВТСведенияОДоходах_ПрочиеУдержания.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТСведенияОДоходах_ПрочиеУдержания.Результат КАК ОблагаемыйДоход,
		|	ВТСведенияОДоходах_ПрочиеУдержания.ВидДохода КАК ВидДохода,
		|	ВТСведенияОДоходах_ПрочиеУдержания.Статус КАК Статус,
		|	ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ОПВ) КАК ВидНалогаВзносаОтчисления
		|ИЗ
		|	ВТСведенияОДоходах_ПрочиеУдержания КАК ВТСведенияОДоходах_ПрочиеУдержания
		|ГДЕ
		|	(НЕ &ПорядокЕдинымПлатежом 
		|		ИЛИ ВТСведенияОДоходах_ПрочиеУдержания.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|		ИЛИ &ПорядокЕдинымПлатежом И НЕ ВТСведенияОДоходах_ПрочиеУдержания.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя))
		|	И ВТСведенияОДоходах_ПрочиеУдержания.СпособОбложенияОПВ <> ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.НеОблагаетсяЦеликом)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВТСведенияОДоходах_ПрочиеУдержания.Месяц,
        |   ВТСведенияОДоходах_ПрочиеУдержания.ПериодРегистрации, 
		|	ВТСведенияОДоходах_ПрочиеУдержания.Начисление,
		|	ВТСведенияОДоходах_ПрочиеУдержания.ФизическоеЛицо,
		|	ВТСведенияОДоходах_ПрочиеУдержания.Результат,
		|	ВТСведенияОДоходах_ПрочиеУдержания.ВидДохода,
		|	ВТСведенияОДоходах_ПрочиеУдержания.Статус,
		|	ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ИПН)
		|ИЗ
		|	ВТСведенияОДоходах_ПрочиеУдержания КАК ВТСведенияОДоходах_ПрочиеУдержания
		|ГДЕ
		|	(НЕ &ПорядокЕдинымПлатежом 
		|		ИЛИ ВТСведенияОДоходах_ПрочиеУдержания.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|		ИЛИ &ПорядокЕдинымПлатежом И НЕ ВТСведенияОДоходах_ПрочиеУдержания.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя))
		|	И ВТСведенияОДоходах_ПрочиеУдержания.СпособОбложенияИПН <> ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.НеОблагаетсяЦеликом)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВТСведенияОДоходах_ПрочиеУдержания.Месяц,
        |   ВТСведенияОДоходах_ПрочиеУдержания.ПериодРегистрации, 
		|	ВТСведенияОДоходах_ПрочиеУдержания.Начисление,
		|	ВТСведенияОДоходах_ПрочиеУдержания.ФизическоеЛицо,
		|	ВТСведенияОДоходах_ПрочиеУдержания.Результат,
		|	ВТСведенияОДоходах_ПрочиеУдержания.ВидДохода,
		|	ВТСведенияОДоходах_ПрочиеУдержания.Статус,
		|	ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ВОСМС)
		|ИЗ
		|	ВТСведенияОДоходах_ПрочиеУдержания КАК ВТСведенияОДоходах_ПрочиеУдержания
		|ГДЕ
		|	(НЕ &ПорядокЕдинымПлатежом 
		|		ИЛИ ВТСведенияОДоходах_ПрочиеУдержания.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|		ИЛИ &ПорядокЕдинымПлатежом И НЕ ВТСведенияОДоходах_ПрочиеУдержания.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя))
		|	И ВТСведенияОДоходах_ПрочиеУдержания.СпособОбложенияВОСМС <> ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.НеОблагаетсяЦеликом)
		|
		|ОБЪЕДИНИТЬ ВСЕ 
        |
		|ВЫБРАТЬ
		|	ВТСведенияОДоходах_ПрочиеУдержания.Месяц,
        |   ВТСведенияОДоходах_ПрочиеУдержания.ПериодРегистрации, 
		|	ВТСведенияОДоходах_ПрочиеУдержания.Начисление,
		|	ВТСведенияОДоходах_ПрочиеУдержания.ФизическоеЛицо,
		|	ВТСведенияОДоходах_ПрочиеУдержания.Результат,
		|	ВТСведенияОДоходах_ПрочиеУдержания.ВидДохода,
		|	ВТСведенияОДоходах_ПрочиеУдержания.Статус,
		|	ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.СО)
		|ИЗ
		|	ВТСведенияОДоходах_ПрочиеУдержания КАК ВТСведенияОДоходах_ПрочиеУдержания
		|ГДЕ
		|	(НЕ &ПорядокЕдинымПлатежом 
		|		ИЛИ ВТСведенияОДоходах_ПрочиеУдержания.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтНалоговогоАгента)
		|		ИЛИ &ПорядокЕдинымПлатежом И НЕ ВТСведенияОДоходах_ПрочиеУдержания.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтНалоговогоАгента))
		|	И ВТСведенияОДоходах_ПрочиеУдержания.СпособОбложенияСО <> ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.НеОблагаетсяЦеликом)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВТСведенияОДоходах_ПрочиеУдержания.Месяц,
        |   ВТСведенияОДоходах_ПрочиеУдержания.ПериодРегистрации, 
		|	ВТСведенияОДоходах_ПрочиеУдержания.Начисление,
		|	ВТСведенияОДоходах_ПрочиеУдержания.ФизическоеЛицо,
		|	ВТСведенияОДоходах_ПрочиеУдержания.Результат,
		|	ВТСведенияОДоходах_ПрочиеУдержания.ВидДохода,
		|	ВТСведенияОДоходах_ПрочиеУдержания.Статус,
		|	ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ЕП)
		|ИЗ
		|	ВТСведенияОДоходах_ПрочиеУдержания КАК ВТСведенияОДоходах_ПрочиеУдержания
		|ГДЕ
		|	&ПорядокЕдинымПлатежом
		|	И ВТСведенияОДоходах_ПрочиеУдержания.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|	И ВТСведенияОДоходах_ПрочиеУдержания.СпособОбложенияЕП <> ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.НеОблагаетсяЦеликом)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВТСведенияОНеоблагаемыхДоходах_ПрочиеУдержания.Месяц,
  		|	ВТСведенияОНеоблагаемыхДоходах_ПрочиеУдержания.Месяц,
		|	ВТСведенияОНеоблагаемыхДоходах_ПрочиеУдержания.Начисление,
		|	ВТСведенияОНеоблагаемыхДоходах_ПрочиеУдержания.ФизическоеЛицо,
		|	-ВТСведенияОНеоблагаемыхДоходах_ПрочиеУдержания.НеоблагаемыйДоход,
		|	ВТСведенияОНеоблагаемыхДоходах_ПрочиеУдержания.ВидДохода,
		|	ВТСведенияОНеоблагаемыхДоходах_ПрочиеУдержания.Статус,
		|	ВТСведенияОНеоблагаемыхДоходах_ПрочиеУдержания.ВидНалогаВзносаОтчисления
		|ИЗ
		|	ВТСведенияОНеоблагаемыхДоходах_ПрочиеУдержания КАК ВТСведенияОНеоблагаемыхДоходах_ПрочиеУдержания";
	
	Если ЭтоИсправлениеТекущимПериодом Тогда
		ТекстУсловияСторно = "НЕ СведенияОДоходах.Сторно";
	Иначе
		ТекстУсловияСторно = "ИСТИНА";
	КонецЕсли;	
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеСторно", ТекстУсловияСторно);
    
    //ЗУПК В случае, если исправительный документ вводится другим периодом регистрации, меняем условие на период
    Если ИсправленныйДокумент <> Неопределено
        И ЗначениеЗаполнено(ИсправленныйДокумент) Тогда
        ТекстУсловияИсправительныйДокумент = "СведенияОДоходах.ПериодРегистрации МЕЖДУ &НачалоПериода И &ОкончаниеПериода";
