#Область ПрограммныйИнтерфейс

Процедура ПередЗаписьюНачисления(Объект) Экспорт
	
	ЗаполнитьОбязательныеПоказателиПрочихУдержаний(Объект, РасчетЗарплатыРасширенный.ЕстьПоказательВКоллекции(Объект.Показатели, "РасчетнаяБаза"));

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаполнитьОбязательныеПоказателиПрочихУдержаний(Объект, ЕстьПоказательРасчетнаяБаза) Экспорт
    
    Если ЕстьПоказательРасчетнаяБаза Тогда
        Если Объект.ВычитатьИзРасчетнойБазыНалогиВзносы Тогда
            НоваяСтрока = Объект.Показатели.Добавить();
		    НоваяСтрока.ИспользоватьПриРасчете = Истина;
            НоваяСтрока.Показатель = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ИсчисленныйПоУдержаниюИПН");
            
            НоваяСтрока = Объект.Показатели.Добавить();
		    НоваяСтрока.ИспользоватьПриРасчете = Истина;
            НоваяСтрока.Показатель = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ИсчисленныйПоУдержаниюОПВ");
            
            НоваяСтрока = Объект.Показатели.Добавить();
		    НоваяСтрока.ИспользоватьПриРасчете = Истина;
            НоваяСтрока.Показатель = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ИсчисленныйПоУдержаниюВОСМС");
            
			НоваяСтрока = Объект.Показатели.Добавить();
			НоваяСтрока.ИспользоватьПриРасчете = Истина;
			НоваяСтрока.Показатель = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ИсчисленныйПоУдержаниюЕП");
        КонецЕсли; 
    Иначе
        Объект.ВычитатьИзРасчетнойБазыНалогиВзносы = Ложь;
        МассивУдаляемыхСтрок = Новый Массив;
        Для Каждого СтрокаПоказателя Из Объект.Показатели Цикл
            Если СтрокаПоказателя.Показатель = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ИсчисленныйПоУдержаниюВОСМС")
                ИЛИ СтрокаПоказателя.Показатель = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ИсчисленныйПоУдержаниюИПН")
                ИЛИ СтрокаПоказателя.Показатель = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ИсчисленныйПоУдержаниюОПВ")
				ИЛИ СтрокаПоказателя.Показатель = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.ИсчисленныйПоУдержаниюЕП") Тогда
                МассивУдаляемыхСтрок.Добавить(СтрокаПоказателя);
            КонецЕсли;
        КонецЦикла;
        
        Для Каждого СтрокаПоказателя Из МассивУдаляемыхСтрок Цикл
            Объект.Показатели.Удалить(СтрокаПоказателя);
        КонецЦикла;
    КонецЕсли; 
    
КонецПроцедуры

Функция ИсчисленныеНалогиВзносы(МенеджерВременныхТаблиц, ОписаниеВТ, МесяцНачисления, ЗарплатаЗаМесяц, ИсключаемыйРегистратор, НастройкиУдержаний, ОчередностьРасчета = Неопределено, ЭтоИсправлениеТекущимПериодом = Ложь, ИсправленныйДокумент = Неопределено) Экспорт 

   	Если МесяцНачисления >= Дата(2026, 1, 1) Тогда
		ИсчисленныеНалогиВзносы = ИсчисленныеНалогиВзносыПосле2026(МенеджерВременныхТаблиц, ОписаниеВТ, МесяцНачисления, ЗарплатаЗаМесяц, ИсключаемыйРегистратор, НастройкиУдержаний, ОчередностьРасчета, ЭтоИсправлениеТекущимПериодом, ИсправленныйДокумент);
   	ИначеЕсли МесяцНачисления >= Дата(2025, 1, 1) Тогда
		ИсчисленныеНалогиВзносы = ИсчисленныеНалогиВзносыПосле2025(МенеджерВременныхТаблиц, ОписаниеВТ, МесяцНачисления, ЗарплатаЗаМесяц, ИсключаемыйРегистратор, НастройкиУдержаний, ОчередностьРасчета, ЭтоИсправлениеТекущимПериодом, ИсправленныйДокумент);
   	ИначеЕсли МесяцНачисления >= Дата(2023, 1, 1) Тогда
		ИсчисленныеНалогиВзносы = ИсчисленныеНалогиВзносыПосле2023(МенеджерВременныхТаблиц, ОписаниеВТ, МесяцНачисления, ЗарплатаЗаМесяц, ИсключаемыйРегистратор, НастройкиУдержаний, ОчередностьРасчета, ЭтоИсправлениеТекущимПериодом, ИсправленныйДокумент);
   	Иначе
		ИсчисленныеНалогиВзносы = ИсчисленныеНалогиВзносыДо2022(МенеджерВременныхТаблиц, ОписаниеВТ, МесяцНачисления, ЗарплатаЗаМесяц, ИсключаемыйРегистратор, НастройкиУдержаний, ОчередностьРасчета, ЭтоИсправлениеТекущимПериодом, ИсправленныйДокумент);
	КонецЕсли;	
	
	Возврат ИсчисленныеНалогиВзносы;
	
КонецФункции

Функция ИсчисленныеНалогиВзносыПосле2023(МенеджерВременныхТаблиц, ОписаниеВТ, МесяцНачисления, ЗарплатаЗаМесяц, ИсключаемыйРегистратор, НастройкиУдержаний, ОчередностьРасчета = Неопределено, ЭтоИсправлениеТекущимПериодом = Ложь, ИсправленныйДокумент = Неопределено) 
	
	НалогиВзносы = РегистрыНакопления.СведенияОДоходахФизическихЛиц.СоздатьНаборЗаписей().Выгрузить(, "Период,ФизическоеЛицо,Начисление");
	НалогиВзносы.Колонки.Период.Имя = "Месяц";
	НалогиВзносы.Колонки.Добавить("ОПВ", Новый ОписаниеТипов("Число"));
	НалогиВзносы.Колонки.Добавить("ВОСМС", Новый ОписаниеТипов("Число"));
	НалогиВзносы.Колонки.Добавить("ИПН", Новый ОписаниеТипов("Число"));
	НалогиВзносы.Колонки.Добавить("ЕП", Новый ОписаниеТипов("Число"));
	
	Запрос = Новый Запрос;
	
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МИНИМУМ(Удержания.Организация) КАК Организация,
		|	МИНИМУМ(Удержания.НачалоПериода) КАК НачалоПериода,
		|	МАКСИМУМ(Удержания.ОкончаниеПериода) КАК ОкончаниеПериода
		|ИЗ
		|	ВТУдержания КАК Удержания";
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВТУдержания", ОписаниеВТ.ИмяВТ);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "Удержания.НачалоПериода", "Удержания." + ОписаниеВТ.ИмяПоляНачалоПериода);
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "Удержания.ОкончаниеПериода", "Удержания." + ОписаниеВТ.ИмяПоляОкончаниеПериода);
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	Если НЕ ЗарплатаКадры.ВТСуществует(МенеджерВременныхТаблиц, "ВТПериодыПоФизлицам")
		И НЕ ЗарплатаКадры.ВТСуществует(МенеджерВременныхТаблиц, "ВТРегистрНакопления_СведенияОДоходахФизическихЛиц") Тогда
		
		Возврат НалогиВзносы;
		
	КонецЕсли;
	
	ИменаВТ = Новый Массив;
	
	Запрос.УстановитьПараметр("НачалоПериода", НачалоМесяца(Выборка.НачалоПериода));
	Запрос.УстановитьПараметр("ОкончаниеПериода", КонецМесяца(Выборка.ОкончаниеПериода));
	Запрос.УстановитьПараметр("ИсключаемыйРегистратор", ИсключаемыйРегистратор);
	Запрос.УстановитьПараметр("ВидыУдержанийНалоговВзносов", Обработки.МенеджерРасчетаЗарплаты.ВидыНалоговВзносовДополненияРасчетнойБазыУдержаний());
	ВидыНалоговВзносов = Новый Массив;
	ВидыНалоговВзносов.Добавить(Перечисления.ВидыНалоговВзносовОтчислений.ИПН);
	ВидыНалоговВзносов.Добавить(Перечисления.ВидыНалоговВзносовОтчислений.ОПВ);
	ВидыНалоговВзносов.Добавить(Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС);
	ВидыНалоговВзносов.Добавить(Перечисления.ВидыНалоговВзносовОтчислений.ЕП);
	Если ЗарплатаКадрыРКПовтИсп.ПорядокОбложенияДоходовРаботников(Выборка.Организация, МесяцНачисления) = Перечисления.ПорядокОбложенияДоходовРаботников.ЕдиныйПлатеж Тогда
		ПорядокОбложенияЕдинымПлатежом = Истина;
	Иначе
		ПорядокОбложенияЕдинымПлатежом = Ложь;
	КонецЕсли;
	Запрос.УстановитьПараметр("ВидыНалоговВзносов", ВидыНалоговВзносов);
	Запрос.УстановитьПараметр("ПорядокЕдинымПлатежом", ПорядокОбложенияЕдинымПлатежом);
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ДанныеУдержаний.НомерСтроки КАК НомерСтроки,
	               |	ДанныеУдержаний.Организация КАК Организация,
	               |	ДанныеУдержаний.Организация.ГоловнаяОрганизация КАК ГоловнаяОрганизация,
	               |	ДанныеУдержаний.ФизическоеЛицо КАК ФизическоеЛицо,
	               |	ДанныеУдержаний.ВидРасчета КАК ВидРасчета,
	               |	ДанныеУдержаний.ДокументОснование КАК ИсполнительныйДокумент
	               |ПОМЕСТИТЬ ВТУдержанияПоПрочимУдержаниям
	               |ИЗ
	               |	ВТРегистрРасчета_Удержания КАК ДанныеУдержаний
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланВидовРасчета.Удержания КАК Удержания
	               |		ПО ДанныеУдержаний.ВидРасчета = Удержания.Ссылка
	               |			И (Удержания.КатегорияУдержания = ЗНАЧЕНИЕ(Перечисление.КатегорииУдержаний.ИсполнительныйЛист)
  	               |			    ИЛИ Удержания.ВычитатьИзРасчетнойБазыНалогиВзносы)
	               |			И (&УсловиеОчередностьРасчета)
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ИСТИНА КАК ЗначениеИстина
	               |ИЗ
	               |	ВТУдержанияПоПрочимУдержаниям КАК УдержанияПоПрочимУдержаниям";
	
	Если ОчередностьРасчета = Неопределено Тогда
		ТекстУсловияОчередность = "ИСТИНА";
	Иначе
		ТекстУсловияОчередность = "Удержания.ОчередностьРасчета = &ОчередностьРасчета";
		Запрос.УстановитьПараметр("ОчередностьРасчета", ОчередностьРасчета);
	КонецЕсли;	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеОчередностьРасчета", ТекстУсловияОчередность);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ИменаВТ.Добавить("ВТУдержанияПоПрочимУдержаниям");
	
	Если РезультатЗапроса.Пустой() Тогда
		ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, ИменаВТ);
		Возврат НалогиВзносы;
	КонецЕсли;

	Если НЕ ЗарплатаКадры.ВТСуществует(МенеджерВременныхТаблиц, "ВТДатыПоМесяцам") Тогда 
		
		// Таблица ВТДатыПоМесяцам: список налоговых периодов, в которых выполняется расчет.
		ЗарплатаКадрыОбщиеНаборыДанных.СоздатьВТПериоды(МенеджерВременныхТаблиц, НачалоГода(Выборка.НачалоПериода), НачалоМесяца(Выборка.ОкончаниеПериода),,,"ВТДатыПоМесяцам");
		ИменаВТ.Добавить("ВТДатыПоМесяцам");
		
	КонецЕсли;
	
	Если НЕ ЗарплатаКадры.ВТСуществует(МенеджерВременныхТаблиц, "ВТНалогообложениеНачислений") Тогда 
		
		УчетНалоговВзносовОтчислений.СоздатьВТНалогообложениеНачисленийПоПериодам(МенеджерВременныхТаблиц);
		ИменаВТ.Добавить("ВТНалогообложениеНачислений");
		
	КонецЕсли;
	
	Если НЕ ЗарплатаКадры.ВТСуществует(МенеджерВременныхТаблиц, "ВТСтатусыФизическихЛицКакНалогоплательщиков") Тогда 
		
		УчетНалоговВзносовОтчислений.СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
		ИменаВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
		
	КонецЕсли;
	
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	УдержанияПоПрочимУдержаниям.ГоловнаяОрганизация КАК ГоловнаяОрганизация,
	               |	УдержанияПоПрочимУдержаниям.ФизическоеЛицо КАК ФизическоеЛицо
	               |ПОМЕСТИТЬ ВТФизическиеЛицаПрочиеУдержания
	               |ИЗ
	               |	ВТУдержанияПоПрочимУдержаниям КАК УдержанияПоПрочимУдержаниям
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ФизическиеЛица.ФизическоеЛицо КАК ФизическоеЛицо
	               |ИЗ
	               |	ВТФизическиеЛицаПрочиеУдержания КАК ФизическиеЛица";
	
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	ИменаВТ.Добавить("ВТФизическиеЛицаПрочиеУдержания");
	
	МассивСтрок = ЗарплатаЗаМесяц.НалогиВзносыОтчисления.НайтиСтроки(Новый Структура("ВидНалогаВзносаОтчисления",Перечисления.ВидыНалоговВзносовОтчислений.ИПН));
	НалогиВзносыПоВидамДоходов = ЗарплатаЗаМесяц.НалогиВзносыОтчисления.Скопировать(МассивСтрок,"ФизическоеЛицо,МесяцНалоговогоПериода,ВидДохода,ВидНалогаВзносаОтчисления,НалогВзнос");
	
	МассивСтрок = ЗарплатаЗаМесяц.НалогиВзносыОтчисления.НайтиСтроки(Новый Структура("ВидНалогаВзносаОтчисления",Перечисления.ВидыНалоговВзносовОтчислений.ОПВ));
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ЗарплатаЗаМесяц.НалогиВзносыОтчисления.Скопировать(МассивСтрок,"ФизическоеЛицо,МесяцНалоговогоПериода,ВидДохода,ВидНалогаВзносаОтчисления,НалогВзнос"), НалогиВзносыПоВидамДоходов);
	
	МассивСтрок = ЗарплатаЗаМесяц.НалогиВзносыОтчисления.НайтиСтроки(Новый Структура("ВидНалогаВзносаОтчисления",Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС));
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ЗарплатаЗаМесяц.НалогиВзносыОтчисления.Скопировать(МассивСтрок,"ФизическоеЛицо,МесяцНалоговогоПериода,ВидДохода,ВидНалогаВзносаОтчисления,НалогВзнос"), НалогиВзносыПоВидамДоходов);
	
	МассивСтрокЕП = ЗарплатаЗаМесяц.НалогиВзносыОтчисления.НайтиСтроки(Новый Структура("ВидНалогаВзносаОтчисления, ВидДохода", Перечисления.ВидыНалоговВзносовОтчислений.ЕП, Справочники.ВидыДоходов.ДоходыОтРаботодателя));
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ЗарплатаЗаМесяц.НалогиВзносыОтчисления.Скопировать(МассивСтрокЕП,"ФизическоеЛицо,МесяцНалоговогоПериода,ВидДохода,ВидНалогаВзносаОтчисления,НалогВзнос"), НалогиВзносыПоВидамДоходов);
	
	Если НЕ НастройкиУдержаний.РассчитыватьТолькоПоТекущемуДокументу Тогда

		НалогиВзносыОтчисления = ЗарплатаЗаМесяц.НалогиВзносыОтчисления.Скопировать(МассивСтрокЕП, "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода, ВидНалогаВзносаОтчисления, ИдентификаторСтрокиНалогиВзносыОтчисления");
		Запрос.УстановитьПараметр("НалогиВзносыОтчисленияЕП", НалогиВзносыОтчисления);
		Если ЗарплатаЗаМесяц.КомпонентыЕП = Неопределено Тогда
			Запрос.УстановитьПараметр("КомпонентыЕП", УчетНалоговВзносовОтчисленийРасширенный.ПустаяТаблицаКомпонентыЕП());
		Иначе
			Запрос.УстановитьПараметр("КомпонентыЕП", ЗарплатаЗаМесяц.КомпонентыЕП);
		КонецЕсли;
		
		Запрос.Текст = "ВЫБРАТЬ
		               |	НалогиВзносыОтчисленияЕП.ФизическоеЛицо КАК ФизическоеЛицо,
		               |	НалогиВзносыОтчисленияЕП.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		               |	НалогиВзносыОтчисленияЕП.ИдентификаторСтрокиНалогиВзносыОтчисления КАК ИдентификаторСтрокиНалогиВзносыОтчисления
		               |ПОМЕСТИТЬ ВТНалогиВзносыОтчисленияЕП
		               |ИЗ
		               |	&НалогиВзносыОтчисленияЕП КАК НалогиВзносыОтчисленияЕП
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	КомпонентыЕП.ИдентификаторСтрокиНалогиВзносыОтчисления КАК ИдентификаторСтрокиНалогиВзносыОтчисления,
		               |	КомпонентыЕП.ОПВ КАК ОПВ,
		               |	КомпонентыЕП.ИПН КАК ИПН,
		               |	КомпонентыЕП.ВОСМС КАК ВОСМС
		               |ПОМЕСТИТЬ ВТКомпонентыЕП
		               |ИЗ
		               |	&КомпонентыЕП КАК КомпонентыЕП
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	НалогиВзносыОтчисленияЕП.ФизическоеЛицо КАК ФизическоеЛицо,
		               |	НалогиВзносыОтчисленияЕП.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		               |	НалогиВзносыОтчисленияЕП.ИдентификаторСтрокиНалогиВзносыОтчисления КАК ИдентификаторСтрокиНалогиВзносыОтчисления,
		               |	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя) КАК ВидДохода,
		               |	ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ИПН) КАК ВидНалогаВзносаОтчисления,
		               |	КомпонентыЕП.ИПН КАК НалогВзнос
		               |ИЗ
		               |	ВТНалогиВзносыОтчисленияЕП КАК НалогиВзносыОтчисленияЕП
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТКомпонентыЕП КАК КомпонентыЕП
		               |		ПО НалогиВзносыОтчисленияЕП.ИдентификаторСтрокиНалогиВзносыОтчисления = КомпонентыЕП.ИдентификаторСтрокиНалогиВзносыОтчисления
		               |ГДЕ
		               |	КомпонентыЕП.ИПН <> 0
					   |
					   |ОБЪЕДИНИТЬ ВСЕ
					   |
		               |ВЫБРАТЬ
		               |	НалогиВзносыОтчисленияЕП.ФизическоеЛицо КАК ФизическоеЛицо,
		               |	НалогиВзносыОтчисленияЕП.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		               |	НалогиВзносыОтчисленияЕП.ИдентификаторСтрокиНалогиВзносыОтчисления КАК ИдентификаторСтрокиНалогиВзносыОтчисления,
		               |	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя) КАК ВидДохода,
		               |	ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ОПВ) КАК ВидНалогаВзносаОтчисления,
		               |	КомпонентыЕП.ОПВ КАК НалогВзнос
		               |ИЗ
		               |	ВТНалогиВзносыОтчисленияЕП КАК НалогиВзносыОтчисленияЕП
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТКомпонентыЕП КАК КомпонентыЕП
		               |		ПО НалогиВзносыОтчисленияЕП.ИдентификаторСтрокиНалогиВзносыОтчисления = КомпонентыЕП.ИдентификаторСтрокиНалогиВзносыОтчисления
		               |ГДЕ
		               |	КомпонентыЕП.ОПВ <> 0
					   |
					   |ОБЪЕДИНИТЬ ВСЕ
					   |
		               |ВЫБРАТЬ
		               |	НалогиВзносыОтчисленияЕП.ФизическоеЛицо КАК ФизическоеЛицо,
		               |	НалогиВзносыОтчисленияЕП.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		               |	НалогиВзносыОтчисленияЕП.ИдентификаторСтрокиНалогиВзносыОтчисления КАК ИдентификаторСтрокиНалогиВзносыОтчисления,
		               |	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя) КАК ВидДохода,
		               |	ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ВОСМС) КАК ВидНалогаВзносаОтчисления,
		               |	КомпонентыЕП.ВОСМС КАК НалогВзнос
		               |ИЗ
		               |	ВТНалогиВзносыОтчисленияЕП КАК НалогиВзносыОтчисленияЕП
		               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТКомпонентыЕП КАК КомпонентыЕП
		               |		ПО НалогиВзносыОтчисленияЕП.ИдентификаторСтрокиНалогиВзносыОтчисления = КомпонентыЕП.ИдентификаторСтрокиНалогиВзносыОтчисления
		               |ГДЕ
		               |	КомпонентыЕП.ВОСМС <> 0
					   |";
		
		НалогиВзносыОтчисленияЕП = Запрос.Выполнить().Выгрузить();
		
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(НалогиВзносыОтчисленияЕП, НалогиВзносыПоВидамДоходов);
		
		ИменаВТ.Добавить("ВТНалогиВзносыОтчисленияЕП");
		ИменаВТ.Добавить("ВТКомпонентыЕП");
	
	КонецЕсли;

	НалогиВзносыПоВидамДоходов.Колонки.МесяцНалоговогоПериода.Имя = "Месяц";
	
	Если НЕ НастройкиУдержаний.РассчитыватьТолькоПоТекущемуДокументу Тогда 
		
		Запрос.Текст = "ВЫБРАТЬ
		               |	НАЧАЛОПЕРИОДА(РанееИсчисленныйНалог.Месяц, МЕСЯЦ) КАК Месяц,
		               |	РанееИсчисленныйНалог.ФизическоеЛицо КАК ФизическоеЛицо,
		               |	СУММА(РанееИсчисленныйНалог.НалогВзнос) КАК НалогВзнос,
		               |	РанееИсчисленныйНалог.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления,
		               |	РанееИсчисленныйНалог.ВидДохода КАК ВидДохода
		               |ИЗ
		               |	(ВЫБРАТЬ
		               |		СведенияОбИсчисленииНалоговВзносовОтчислений.Период КАК Месяц,
		               |		СведенияОбИсчисленииНалоговВзносовОтчислений.ФизическоеЛицо КАК ФизическоеЛицо,
		               |		СведенияОбИсчисленииНалоговВзносовОтчислений.НалогВзнос,
		               |		СведенияОбИсчисленииНалоговВзносовОтчислений.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления,
		               |		СведенияОбИсчисленииНалоговВзносовОтчислений.ВидДохода КАК ВидДохода
		               |	ИЗ
		               |		РегистрНакопления.СведенияОбИсчисленииНалоговВзносовОтчислений КАК СведенияОбИсчисленииНалоговВзносовОтчислений
		               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТФизическиеЛицаПрочиеУдержания КАК ФизическиеЛица
		               |			ПО СведенияОбИсчисленииНалоговВзносовОтчислений.Организация.ГоловнаяОрганизация = ФизическиеЛица.ГоловнаяОрганизация
		               |				И СведенияОбИсчисленииНалоговВзносовОтчислений.ФизическоеЛицо = ФизическиеЛица.ФизическоеЛицо
		               |				И (СведенияОбИсчисленииНалоговВзносовОтчислений.ВидНалогаВзносаОтчисления В (&ВидыНалоговВзносов))
		               |				И (СведенияОбИсчисленииНалоговВзносовОтчислений.Регистратор <> &ИсключаемыйРегистратор)
		               |				И (СведенияОбИсчисленииНалоговВзносовОтчислений.Период МЕЖДУ &НачалоПериода И &ОкончаниеПериода)
		               |				И (НЕ СведенияОбИсчисленииНалоговВзносовОтчислений.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ЕП)
		               |					ИЛИ СведенияОбИсчисленииНалоговВзносовОтчислений.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ЕП)
		               |						И СведенияОбИсчисленииНалоговВзносовОтчислений.ДанныеМежрасчетногоПериода)
		               |	
		               |	ОБЪЕДИНИТЬ ВСЕ
		               |	
		               |	ВЫБРАТЬ
		               |		КомпонентыЕП.МесяцНалоговогоПериода,
		               |		КомпонентыЕП.ФизическоеЛицо,
		               |		КомпонентыЕП.ИПН,
		               |		ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ИПН),
		               |		ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		               |	ИЗ
		               |		РегистрНакопления.ЕПКомпоненты КАК КомпонентыЕП
		               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТФизическиеЛицаПрочиеУдержания КАК ФизическиеЛица
		               |			ПО КомпонентыЕП.Организация.ГоловнаяОрганизация = ФизическиеЛица.ГоловнаяОрганизация
		               |				И КомпонентыЕП.ФизическоеЛицо = ФизическиеЛица.ФизическоеЛицо
		               |				И (КомпонентыЕП.Регистратор <> &ИсключаемыйРегистратор)
		               |				И (КомпонентыЕП.Период МЕЖДУ &НачалоПериода И &ОкончаниеПериода)
		               |	ГДЕ
		               |		КомпонентыЕП.ИПН <> 0
		               |		И &ПорядокЕдинымПлатежом
		               |	
		               |	ОБЪЕДИНИТЬ ВСЕ
		               |	
		               |	ВЫБРАТЬ
		               |		КомпонентыЕП.МесяцНалоговогоПериода,
		               |		КомпонентыЕП.ФизическоеЛицо,
		               |		КомпонентыЕП.ОПВ,
		               |		ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ОПВ),
		               |		ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		               |	ИЗ
		               |		РегистрНакопления.ЕПКомпоненты КАК КомпонентыЕП
		               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТФизическиеЛицаПрочиеУдержания КАК ФизическиеЛица
		               |			ПО КомпонентыЕП.Организация.ГоловнаяОрганизация = ФизическиеЛица.ГоловнаяОрганизация
		               |				И КомпонентыЕП.ФизическоеЛицо = ФизическиеЛица.ФизическоеЛицо
		               |				И (КомпонентыЕП.Регистратор <> &ИсключаемыйРегистратор)
		               |				И (КомпонентыЕП.Период МЕЖДУ &НачалоПериода И &ОкончаниеПериода)
		               |	ГДЕ
		               |		КомпонентыЕП.ОПВ <> 0
		               |		И &ПорядокЕдинымПлатежом
		               |	
		               |	ОБЪЕДИНИТЬ ВСЕ
		               |	
		               |	ВЫБРАТЬ
		               |		КомпонентыЕП.МесяцНалоговогоПериода,
		               |		КомпонентыЕП.ФизическоеЛицо,
		               |		КомпонентыЕП.ВОСМС,
		               |		ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ВОСМС),
		               |		ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		               |	ИЗ
		               |		РегистрНакопления.ЕПКомпоненты КАК КомпонентыЕП
		               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТФизическиеЛицаПрочиеУдержания КАК ФизическиеЛица
		               |			ПО КомпонентыЕП.Организация.ГоловнаяОрганизация = ФизическиеЛица.ГоловнаяОрганизация
		               |				И КомпонентыЕП.ФизическоеЛицо = ФизическиеЛица.ФизическоеЛицо
		               |				И (КомпонентыЕП.Регистратор <> &ИсключаемыйРегистратор)
		               |				И (КомпонентыЕП.Период МЕЖДУ &НачалоПериода И &ОкончаниеПериода)
		               |	ГДЕ
		               |		КомпонентыЕП.ВОСМС <> 0
		               |		И &ПорядокЕдинымПлатежом) КАК РанееИсчисленныйНалог
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	НАЧАЛОПЕРИОДА(РанееИсчисленныйНалог.Месяц, МЕСЯЦ),
		               |	РанееИсчисленныйНалог.ФизическоеЛицо,
		               |	РанееИсчисленныйНалог.ВидНалогаВзносаОтчисления,
		               |	РанееИсчисленныйНалог.ВидДохода";
		
		РанееИсчисленныйНалог = Запрос.Выполнить().Выгрузить();
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(РанееИсчисленныйНалог, НалогиВзносыПоВидамДоходов);

	КонецЕсли;
	
	ФизическиеЛица = Новый Соответствие;
	Выборка = РезультатыЗапроса[1].Выбрать();
	Пока Выборка.Следующий() Цикл 
		ФизическиеЛица.Вставить(Выборка.ФизическоеЛицо, Истина);
	КонецЦикла;
	
	НалогиВзносыПоВидамДоходов.Свернуть("Месяц,ФизическоеЛицо,ВидДохода,ВидНалогаВзносаОтчисления", "НалогВзнос");
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(СведенияОДоходах.Период, МЕСЯЦ) КАК Месяц,
        |   СведенияОДоходах.ПериодРегистрации КАК ПериодРегистрации, 
		|	СведенияОДоходах.ФизическоеЛицо КАК ФизическоеЛицо,
		// ЗУПК для договорников базу не используем, собираем базу по виду операци по зарплате ДоговорРаботыУслуги (подразумеваем, что сюда входит и ДоговорАвторскогоЗаказа)
		|	ВЫБОР
		|		КОГДА НалогообложениеНачислений.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтНалоговогоАгента)
		|			И НЕ (ТИПЗНАЧЕНИЯ(СведенияОДоходах.Начисление) = ТИП(Справочник.ВидыВыплатБывшимСотрудникам)
		|				ИЛИ ТИПЗНАЧЕНИЯ(СведенияОДоходах.Начисление) = ТИП(Справочник.ВидыПрочихДоходовФизическихЛиц))
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ВидыОсобыхНачисленийИУдержаний.ДоговорРаботыУслуги)
		|		ИНАЧЕ СведенияОДоходах.Начисление
		|	КОНЕЦ КАК Начисление,
		// ЗУПК для договорников базу не используем, собираем базу по виду операци по зарплате ДоговорРаботыУслуги (подразумеваем, что сюда входит и ДоговорАвторскогоЗаказа)
		|	СведенияОДоходах.СуммаДохода КАК Результат,
		|	ЕСТЬNULL(СтатусыФизическихЛицКакНалогоплательщиков.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.ПустаяСсылка)) КАК Статус,
		|	НалогообложениеНачислений.ВидДохода КАК ВидДохода,
		|	НалогообложениеНачислений.СпособОбложенияОПВ КАК СпособОбложенияОПВ,
		|	НалогообложениеНачислений.СпособОбложенияИПН КАК СпособОбложенияИПН,
		|	НалогообложениеНачислений.СпособОбложенияВОСМС КАК СпособОбложенияВОСМС,
		|	НалогообложениеНачислений.СпособОбложенияЕП КАК СпособОбложенияЕП
		|ПОМЕСТИТЬ ВТСведенияОДоходах_ПрочиеУдержания
		|ИЗ
		|	ВТРегистрНакопления_СведенияОДоходахФизическихЛиц КАК СведенияОДоходах
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТФизическиеЛицаПрочиеУдержания КАК ФизическиеЛица
		|		ПО (СведенияОДоходах.Период МЕЖДУ &НачалоПериода И &ОкончаниеПериода)
		|			И СведенияОДоходах.Организация.ГоловнаяОрганизация = ФизическиеЛица.ГоловнаяОрганизация
		|			И СведенияОДоходах.ФизическоеЛицо = ФизическиеЛица.ФизическоеЛицо
		|			И (&УсловиеСторно)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНалогообложениеНачислений КАК НалогообложениеНачислений
		|		ПО СведенияОДоходах.Начисление = НалогообложениеНачислений.Начисление
		|			И (НАЧАЛОПЕРИОДА(СведенияОДоходах.Период, МЕСЯЦ) = НалогообложениеНачислений.МесяцНалоговогоПериода)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтатусыФизическихЛицКакНалогоплательщиков КАК СтатусыФизическихЛицКакНалогоплательщиков
		|		ПО НАЧАЛОПЕРИОДА(СведенияОДоходах.Период, МЕСЯЦ) = СтатусыФизическихЛицКакНалогоплательщиков.МесяцНалоговогоПериода
		|			И СведенияОДоходах.ФизическоеЛицо = СтатусыФизическихЛицКакНалогоплательщиков.ФизическоеЛицо
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(СведенияОНеоблагаемыхДоходах.МесяцНалоговогоПериода, МЕСЯЦ) КАК Месяц,
		|	СведенияОНеоблагаемыхДоходах.ФизическоеЛицо КАК ФизическоеЛицо,
		// ЗУПК для договорников базу не используем, собираем базу по виду операци по зарплате ДоговорРаботыУслуги (подразумеваем, что сюда входит и ДоговорАвторскогоЗаказа)
		|	ВЫБОР
