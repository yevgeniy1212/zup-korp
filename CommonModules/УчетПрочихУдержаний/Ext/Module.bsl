        Запрос.Текст = СтрЗаменить(Запрос.Текст, "СведенияОДоходах.Период МЕЖДУ &НачалоПериода И &ОкончаниеПериода", ТекстУсловияИсправительныйДокумент);
    КонецЕсли; 
    //ЗУПК В случае, если исправительный документ вводится другим периодом регистрации, меняем условие на период
	
	Если ЗарплатаКадры.ВТСуществует(МенеджерВременныхТаблиц, "ВТРегистрНакопления_СведенияОДоходахФизическихЛиц") Тогда 
		ОблагаемыеДоходы = Запрос.Выполнить().Выгрузить();
   		ИменаВТ.Добавить("ВТСведенияОДоходах_ПрочиеУдержания");
   		ИменаВТ.Добавить("ВТСведенияОНеоблагаемыхДоходах_ПрочиеУдержания");
	Иначе 
		ОблагаемыеДоходы = РегистрыНакопления.СведенияОДоходахФизическихЛиц.СоздатьНаборЗаписей().Выгрузить(, "Период,ПериодРегистрации,ФизическоеЛицо,Начисление,СуммаДохода");
		ОблагаемыеДоходы.Колонки.СуммаДохода.Имя = "ОблагаемыйДоход";
		ОблагаемыеДоходы.Колонки.Период.Имя = "Месяц";
        ОблагаемыеДоходы.Колонки.ПериодРегистрации.Имя = "ПериодРегистрации";
		ОблагаемыеДоходы.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
		ОблагаемыеДоходы.Колонки.Добавить("ВидНалогаВзносаОтчисления", Новый ОписаниеТипов("ПеречислениеСсылка.ВидыНалоговВзносовОтчислений"));
