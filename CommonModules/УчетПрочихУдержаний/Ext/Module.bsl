		               |				И (КомпонентыЕП.Регистратор <> &ИсключаемыйРегистратор)
		               |				И (КомпонентыЕП.Период МЕЖДУ &НачалоПериода И &ОкончаниеПериода)
		               |	ГДЕ
		               |		КомпонентыЕП.ОПВ <> 0
		               |		И &ПорядокЕдинымПлатежом
		               |	
		               |	ОБЪЕДИНИТЬ ВСЕ
		               |	
		               |	ВЫБРАТЬ
		               |		КомпонентыЕП.МесяцНалоговогоПериода,
		               |		КомпонентыЕП.ФизическоеЛицо,
		               |		КомпонентыЕП.ВОСМС,
		               |		ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ВОСМС),
		               |		ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		               |	ИЗ
		               |		РегистрНакопления.ЕПКомпоненты КАК КомпонентыЕП
		               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТФизическиеЛицаПрочиеУдержания КАК ФизическиеЛица
		               |			ПО КомпонентыЕП.Организация.ГоловнаяОрганизация = ФизическиеЛица.ГоловнаяОрганизация
		               |				И КомпонентыЕП.ФизическоеЛицо = ФизическиеЛица.ФизическоеЛицо
		               |				И (КомпонентыЕП.Регистратор <> &ИсключаемыйРегистратор)
		               |				И (КомпонентыЕП.Период МЕЖДУ &НачалоПериода И &ОкончаниеПериода)
		               |	ГДЕ
		               |		КомпонентыЕП.ВОСМС <> 0
		               |		И &ПорядокЕдинымПлатежом) КАК РанееИсчисленныйНалог
		               |
		               |СГРУППИРОВАТЬ ПО
		               |	НАЧАЛОПЕРИОДА(РанееИсчисленныйНалог.Месяц, МЕСЯЦ),
		               |	РанееИсчисленныйНалог.ФизическоеЛицо,
		               |	РанееИсчисленныйНалог.ВидНалогаВзносаОтчисления,
		               |	РанееИсчисленныйНалог.ВидДохода";
		
		РанееИсчисленныйНалог = Запрос.Выполнить().Выгрузить();
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(РанееИсчисленныйНалог, НалогиВзносыПоВидамДоходов);

	КонецЕсли;
	
	ФизическиеЛица = Новый Соответствие;
	Выборка = РезультатыЗапроса[1].Выбрать();
	Пока Выборка.Следующий() Цикл 
		ФизическиеЛица.Вставить(Выборка.ФизическоеЛицо, Истина);
	КонецЦикла;
	
	НалогиВзносыПоВидамДоходов.Свернуть("Месяц,ФизическоеЛицо,ВидДохода,ВидНалогаВзносаОтчисления", "НалогВзнос,НалогВзносСПревышения");
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(СведенияОДоходах.Период, МЕСЯЦ) КАК Месяц,
        |   СведенияОДоходах.ПериодРегистрации КАК ПериодРегистрации, 
		|	СведенияОДоходах.ФизическоеЛицо КАК ФизическоеЛицо,
		// ЗУПК для договорников базу не используем, собираем базу по виду операци по зарплате ДоговорРаботыУслуги (подразумеваем, что сюда входит и ДоговорАвторскогоЗаказа)
		|	ВЫБОР
		|		КОГДА НалогообложениеНачислений.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтНалоговогоАгента)
		|			И НЕ (ТИПЗНАЧЕНИЯ(СведенияОДоходах.Начисление) = ТИП(Справочник.ВидыВыплатБывшимСотрудникам)
		|				ИЛИ ТИПЗНАЧЕНИЯ(СведенияОДоходах.Начисление) = ТИП(Справочник.ВидыПрочихДоходовФизическихЛиц))
		|			ТОГДА ЗНАЧЕНИЕ(Перечисление.ВидыОсобыхНачисленийИУдержаний.ДоговорРаботыУслуги)
		|		ИНАЧЕ СведенияОДоходах.Начисление
		|	КОНЕЦ КАК Начисление,
		// ЗУПК для договорников базу не используем, собираем базу по виду операци по зарплате ДоговорРаботыУслуги (подразумеваем, что сюда входит и ДоговорАвторскогоЗаказа)
		|	СведенияОДоходах.СуммаДохода КАК Результат,
		|	ЕСТЬNULL(СтатусыФизическихЛицКакНалогоплательщиков.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.ПустаяСсылка)) КАК Статус,
		|	НалогообложениеНачислений.ВидДохода КАК ВидДохода,
		|	НалогообложениеНачислений.СпособОбложенияОПВ КАК СпособОбложенияОПВ,
		|	НалогообложениеНачислений.СпособОбложенияИПН КАК СпособОбложенияИПН,
		|	НалогообложениеНачислений.СпособОбложенияВОСМС КАК СпособОбложенияВОСМС,
        |	НалогообложениеНачислений.СпособОбложенияСО КАК СпособОбложенияСО,
        |	НалогообложениеНачислений.СпособОбложенияЕП КАК СпособОбложенияЕП
		|ПОМЕСТИТЬ ВТСведенияОДоходах_ПрочиеУдержания
		|ИЗ
		|	ВТРегистрНакопления_СведенияОДоходахФизическихЛиц КАК СведенияОДоходах
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТФизическиеЛицаПрочиеУдержания КАК ФизическиеЛица
		|		ПО (СведенияОДоходах.Период МЕЖДУ &НачалоПериода И &ОкончаниеПериода)
		|			И СведенияОДоходах.Организация.ГоловнаяОрганизация = ФизическиеЛица.ГоловнаяОрганизация
		|			И СведенияОДоходах.ФизическоеЛицо = ФизическиеЛица.ФизическоеЛицо
		|			И (&УсловиеСторно)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНалогообложениеНачислений КАК НалогообложениеНачислений
		|		ПО СведенияОДоходах.Начисление = НалогообложениеНачислений.Начисление
		|			И (НАЧАЛОПЕРИОДА(СведенияОДоходах.Период, МЕСЯЦ) = НалогообложениеНачислений.МесяцНалоговогоПериода)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтатусыФизическихЛицКакНалогоплательщиков КАК СтатусыФизическихЛицКакНалогоплательщиков
		|		ПО НАЧАЛОПЕРИОДА(СведенияОДоходах.Период, МЕСЯЦ) = СтатусыФизическихЛицКакНалогоплательщиков.МесяцНалоговогоПериода
		|			И СведенияОДоходах.ФизическоеЛицо = СтатусыФизическихЛицКакНалогоплательщиков.ФизическоеЛицо
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(СведенияОНеоблагаемыхДоходах.МесяцНалоговогоПериода, МЕСЯЦ) КАК Месяц,
		|	СведенияОНеоблагаемыхДоходах.ФизическоеЛицо КАК ФизическоеЛицо,
		// ЗУПК для договорников базу не используем, собираем базу по виду операци по зарплате ДоговорРаботыУслуги (подразумеваем, что сюда входит и ДоговорАвторскогоЗаказа)
		|	ВЫБОР
		|		КОГДА НалогообложениеНачислений.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтНалоговогоАгента)
		|			И НЕ (ТИПЗНАЧЕНИЯ(СведенияОНеоблагаемыхДоходах.Начисление) = ТИП(Справочник.ВидыВыплатБывшимСотрудникам)
		|				ИЛИ ТИПЗНАЧЕНИЯ(СведенияОНеоблагаемыхДоходах.Начисление) = ТИП(Справочник.ВидыПрочихДоходовФизическихЛиц))
