	Запрос.УстановитьПараметр("ПрочиеРасчетыСПерсоналом", СтатьяРасчетПрочиеРасчетыСПерсоналом);
    // ЗУПК
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НачисленияУдержания.Регистратор КАК Регистратор,
	|	МИНИМУМ(НАЧАЛОПЕРИОДА(НачисленияУдержания.Период, МЕСЯЦ)) КАК Период
	|ПОМЕСТИТЬ ВТРегистраторы
	|ИЗ
	|	РегистрНакопления.НачисленияУдержанияПоКонтрагентамАкционерам КАК НачисленияУдержания
	|ГДЕ
	|	НачисленияУдержания.СтатьяРасходов = ЗНАЧЕНИЕ(Справочник.СтатьиРасходовЗарплата.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	НачисленияУдержания.Регистратор
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Регистратор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НачисленияУдержанияПоКонтрагентамАкционерам.Регистратор КАК Регистратор,	
	|	НачисленияУдержанияПоКонтрагентамАкционерам.НачислениеУдержание КАК Начисление,	
	|  	МАКСИМУМ(НалогообложениеНачислений.Период) КАК Период
    |ПОМЕСТИТЬ ВТМаксимумыМинимумыНалогообложение
	|ИЗ РегистрНакопления.НачисленияУдержанияПоКонтрагентамАкционерам КАК НачисленияУдержанияПоКонтрагентамАкционерам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТРегистраторы КАК Регистраторы  
	|   	ПО (Регистраторы.Регистратор = НачисленияУдержанияПоКонтрагентамАкционерам.Регистратор)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НалогообложениеНачислений КАК НалогообложениеНачислений  
	|   	ПО НачисленияУдержанияПоКонтрагентамАкционерам.НачислениеУдержание = НалогообложениеНачислений.Начисление
	|   		 И (НалогообложениеНачислений.Период <= Регистраторы.Период)
    |ГДЕ
	|	ТИПЗНАЧЕНИЯ(Регистраторы.Регистратор) = ТИП(Документ.РегистрацияПрочихДоходов)
	|		ИЛИ ТИПЗНАЧЕНИЯ(Регистраторы.Регистратор) = ТИП(Документ.ВыплатаБывшимСотрудникам)
	|
	|СГРУППИРОВАТЬ ПО
	|	НачисленияУдержанияПоКонтрагентамАкционерам.Регистратор,	
	|	НачисленияУдержанияПоКонтрагентамАкционерам.НачислениеУдержание	
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
    |ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НачисленияУдержанияПоКонтрагентамАкционерам.Регистратор КАК Регистратор,	
	|	НачисленияУдержанияПоКонтрагентамАкционерам.НачислениеУдержание КАК Начисление,	
	|  	МАКСИМУМ(НалогообложениеНачислений.Период) КАК Период
	|ИЗ РегистрНакопления.НачисленияУдержанияПоКонтрагентамАкционерам КАК НачисленияУдержанияПоКонтрагентамАкционерам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТРегистраторы КАК Регистраторы  
	|   	ПО (Регистраторы.Регистратор = НачисленияУдержанияПоКонтрагентамАкционерам.Регистратор)
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НалогообложениеНачислений КАК НалогообложениеНачислений  
	|   	ПО НачисленияУдержанияПоКонтрагентамАкционерам.НачислениеУдержание = НалогообложениеНачислений.Начисление
	|   		 И (НалогообложениеНачислений.Период <= Регистраторы.Период)
    |ГДЕ
	|	НЕ ТИПЗНАЧЕНИЯ(Регистраторы.Регистратор) = ТИП(Документ.РегистрацияПрочихДоходов)
	|		И НЕ ТИПЗНАЧЕНИЯ(Регистраторы.Регистратор) = ТИП(Документ.ВыплатаБывшимСотрудникам)
	|
	|СГРУППИРОВАТЬ ПО
	|	НачисленияУдержанияПоКонтрагентамАкционерам.Регистратор,	
	|	НачисленияУдержанияПоКонтрагентамАкционерам.НачислениеУдержание	
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Регистратор
	|
	|////////////////////////////////////////////////////////////////////////////////
	|;
    |ВЫБРАТЬ
	|	МаксимумыМинимумыНалогообложение.Регистратор КАК Регистратор,	
	|	МаксимумыМинимумыНалогообложение.Начисление КАК Начисление,	
	|  	НалогообложениеНачислений.ВидДохода КАК ВидДохода
    |ПОМЕСТИТЬ ВТНалогообложениеНачислений
	|ИЗ ВТМаксимумыМинимумыНалогообложение КАК МаксимумыМинимумыНалогообложение
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НалогообложениеНачислений КАК НалогообложениеНачислений  
	|   	ПО МаксимумыМинимумыНалогообложение.Начисление = НалогообложениеНачислений.Начисление
	|   		 И (МаксимумыМинимумыНалогообложение.Период = НалогообложениеНачислений.Период)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Регистратор
	|;
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НачисленияУдержания.Регистратор КАК Регистратор,
	|	НачисленияУдержания.НомерСтроки КАК НомерСтроки,
	|	ВЫБОР
    // ЗУПК
	|		КОГДА НачисленияУдержания.СтатьяРасходов = ЗНАЧЕНИЕ(Справочник.СтатьиРасходовЗарплата.ПустаяСсылка)
	|			ТОГДА ВЫБОР
	|					КОГДА НалогообложениеНачислений.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
    |						ТОГДА &СтатьяРасчетыПоОплатеТруда
	|					КОГДА НалогообложениеНачислений.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПрочиеДоходы)
    |						ТОГДА &ПрочиеРасчетыСПерсоналом
	|					КОГДА НалогообложениеНачислений.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
	|						ТОГДА &ПрочиеРасчетыСПерсоналом
	|					КОГДА НачисленияУдержания.НачислениеУдержание В (ЗНАЧЕНИЕ(Перечисление.ВидыОсобыхНачисленийИУдержаний.ДивидендыСотрудников), ЗНАЧЕНИЕ(Перечисление.ВидыОсобыхНачисленийИУдержаний.НФДЛДивидендыСотрудникам))
	|						ТОГДА &СтатьяРасчетыПоОплатеТруда
	|					ИНАЧЕ &СтатьяРасчетыСКонтрагентами
	|				КОНЕЦ
	|		ИНАЧЕ НачисленияУдержания.СтатьяРасходов
	|	КОНЕЦ КАК СтатьяРасходов,
	|	НачисленияУдержания.*
	|ИЗ
	|	РегистрНакопления.НачисленияУдержанияПоКонтрагентамАкционерам КАК НачисленияУдержания
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТРегистраторы КАК Регистраторы
	|		ПО НачисленияУдержания.Регистратор = Регистраторы.Регистратор
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНалогообложениеНачислений КАК НалогообложениеНачислений
	|		ПО НалогообложениеНачислений.Регистратор = НачисленияУдержания.Регистратор
	|			И (НалогообложениеНачислений.Начисление = НачисленияУдержания.НачислениеУдержание
	|				ИЛИ ТИПЗНАЧЕНИЯ(Регистраторы.Регистратор) = ТИП(Документ.РегистрацияПрочихДоходов)
	|					ИЛИ ТИПЗНАЧЕНИЯ(Регистраторы.Регистратор) = ТИП(Документ.ВыплатаБывшимСотрудникам))
	|
	|УПОРЯДОЧИТЬ ПО
	|	Регистратор,
	|	НомерСтроки";
	
	РезультатЗапроса = Запрос.Выполнить();
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Ложь);
	Если РезультатЗапроса.Пустой() Тогда
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
		Возврат;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.СледующийПоЗначениюПоля("Регистратор") Цикл
		
		Регистратор = Выборка.Регистратор;
		Если Не ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ПодготовитьОбновлениеДанных(ПараметрыОбновления, "РегистрНакопления.НачисленияУдержанияПоКонтрагентамАкционерам.НаборЗаписей", "Регистратор", Регистратор) Тогда
			Продолжить;
		КонецЕсли;
		
		НаборЗаписей = РегистрыНакопления.НачисленияУдержанияПоКонтрагентамАкционерам.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Регистратор.Установить(Выборка.Регистратор);
		
		Пока Выборка.СледующийПоЗначениюПоля("НомерСтроки") Цикл
			НоваяЗапись = НаборЗаписей.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяЗапись, Выборка);
		КонецЦикла;
		
		ОбновлениеИнформационнойБазы.ЗаписатьДанные(НаборЗаписей);
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
		
	КонецЦикла;

КонецПроцедуры

