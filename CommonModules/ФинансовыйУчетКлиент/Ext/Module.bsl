#Область СлужебныеПроцедурыИФункции

Процедура ОткрытьФормуРедактированияИстории(Форма, ИмяРегистра = "ФинансовыйУчетПодразделений", ИмяИзмерения = "Подразделение")
	
	ПараметрыФормы = Новый Структура("МассивЗаписей,ВедущийОбъект,ТолькоПросмотр");
	ПараметрыФормы.МассивЗаписей = Форма.Подключаемый_МассивЗаписейИсторииФинансовогоУчета();
	ПараметрыФормы.ВедущийОбъект = Форма.ОбъектФинансовогоУчета;
	ПараметрыФормы.ТолькоПросмотр = Форма.ТолькоПросмотр;
	ПараметрыФормы.Вставить("ИмяРегистра", ИмяРегистра);
	ПараметрыФормы.Вставить("ИмяИзмерения", ИмяИзмерения);
	Если ИмяРегистра = "ФинансовыйУчетПозицийКадровогоПлана" Тогда
		ПараметрыФормы.Вставить("Подразделение", Форма.Объект.Подразделение);
	КонецЕсли;
	
	ОткрытьФорму("ОбщаяФорма.РедактированиеИсторииСРаспределениемФинансовыйУчет", ПараметрыФормы, Форма);
	
КонецПроцедуры

Процедура ПериодСтрокойПриИзменении(Форма, ИмяРегистра = "ФинансовыйУчетПодразделений")
	ЗарплатаКадрыКлиент.ВводМесяцаПриИзменении(Форма, ИмяРегистра + ".Период", ИмяРегистра + "ПериодСтрокой", Форма.Модифицированность);
КонецПроцедуры

Процедура ПериодСтрокойНачалоВыбора(Форма, ИмяРегистра = "ФинансовыйУчетПодразделений")
	ЗарплатаКадрыКлиент.ВводМесяцаНачалоВыбора(Форма, Форма, ИмяРегистра + ".Период", ИмяРегистра + "ПериодСтрокой");
КонецПроцедуры

Процедура ПериодСтрокойРегулирование(Форма, Направление, ИмяРегистра = "ФинансовыйУчетПодразделений")
	ЗарплатаКадрыКлиент.ВводМесяцаРегулирование(Форма, ИмяРегистра + ".Период", ИмяРегистра + "ПериодСтрокой", Направление, Форма.Модифицированность);
КонецПроцедуры

Процедура ВариантПриИзменении(Форма, ИмяРегистра = "ФинансовыйУчетПодразделений")
	
	СтруктураЗаписи = Новый Структура("СпособОтражения,ДоляРаспределения,ИдентификаторСтроки");
	Если Форма.ФинансовыйУчетВариантНастройки = 0 Тогда
		ЗаполнитьЗначенияСвойств(Форма[ИмяРегистра], СтруктураЗаписи);
		Форма[ИмяРегистра + "Распределение"].Очистить();
	ИначеЕсли Форма.ФинансовыйУчетВариантНастройки = 1 Тогда
		Форма[ИмяРегистра + "Распределение"].Очистить();
	Иначе
		ЗаполнитьЗначенияСвойств(Форма[ИмяРегистра], СтруктураЗаписи);
	КонецЕсли;
	
	ФинансовыйУчетКлиентСервер.ФормаОбъектаУчетаОбновитьТекущуюСтраницу(Форма);
	
КонецПроцедуры

Процедура РаспределениеПриОкончанииРедактирования(Форма, ИмяРегистра = "ФинансовыйУчетПодразделений")
	
	Если Форма[ИмяРегистра + "Распределение"].Количество() > 0
		И Не ЗначениеЗаполнено(Форма[ИмяРегистра].Период) Тогда
		
		ЕстьДатаСоздания = ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма.Объект, "ДатаСоздания");
		Если ЕстьДатаСоздания И ЗначениеЗаполнено(Форма.Объект.ДатаСоздания) Тогда
			Форма[ИмяРегистра].Период = НачалоМесяца(Форма.Объект.ДатаСоздания);
		Иначе
			Форма[ИмяРегистра].Период = НачалоМесяца(ОбщегоНазначенияКлиент.ДатаСеанса());
		КонецЕсли;
		
		ЗарплатаКадрыКлиентСервер.ЗаполнитьМесяцПоДате(Форма, ИмяРегистра + ".Период", ИмяРегистра + "ПериодСтрокой");
	КонецЕсли;
	
КонецПроцедуры

Процедура ФинансовыйУчетЗавершение(Ответ, ДополнительныеПараметры) Экспорт
	
	Если Ответ = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	
	ФормаВладелец = ДополнительныеПараметры.ФормаВладелец;
	
	Если ДополнительныеПараметры.ЗаписатьЭлемент И Не ФормаВладелец.Записать() Тогда
		Возврат;
	КонецЕсли;
	
	СотрудникиКлиент.ОткрытьДополнительнуюФорму(
		СотрудникиКлиентСервер.ОписаниеДополнительнойФормы("ОбщаяФорма.СотрудникиФинансовыйУчет"), ФормаВладелец, Истина);
	
КонецПроцедуры

Процедура ОбработатьОповещениеОбъектаУчета(Форма, ИмяРегистра)
	
	Если ИмяРегистра = "ФинансовыйУчетСотрудников" Тогда
		Возврат;
	КонецЕсли;
	
	Форма[ИмяРегистра + "Распределение"].Очистить();
	Если Форма[ИмяРегистра + "НаборЗаписей"].Количество() > 0 Тогда
		ПоследняяЗапись = Форма[ИмяРегистра + "НаборЗаписей"][Форма[ИмяРегистра + "НаборЗаписей"].Количество()-1];
		Отбор = Новый Структура("Период", ПоследняяЗапись.Период);
		ПоследниеЗаписи = Форма[ИмяРегистра + "НаборЗаписей"].НайтиСтроки(Отбор);
		Если ПоследниеЗаписи.Количество() > 1 Тогда
			Для каждого ЗаписьНабора Из ПоследниеЗаписи Цикл
				ЗаполнитьЗначенияСвойств(Форма[ИмяРегистра + "Распределение"].Добавить(),ЗаписьНабора);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	ФинансовыйУчетКлиентСервер.ФормаОбъектаУчетаУстановитьВариантНастройки(Форма, ИмяРегистра);
	ФинансовыйУчетКлиентСервер.ФормаОбъектаУчетаОбновитьТекущуюСтраницу(Форма);

КонецПроцедуры

#КонецОбласти