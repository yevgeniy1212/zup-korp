#Область СлужебныйПрограммныйИнтерфейс

Функция ИмяФормыНастройкиФинансовогоУчета() Экспорт
	
	Возврат "ОбщаяФорма.ОрганизацияФинансовыйУчет";
	
КонецФункции

Процедура ОткрытьФормуНастройкиФинансовогоУчета(ФормаВладелец, СотрудникСсылка) Экспорт
	
	ДополнительныеПараметры = Новый Структура("ФормаВладелец, ЗаписатьЭлемент", ФормаВладелец, Истина);
	Если ФормаВладелец.СозданиеНового И Не ЗначениеЗаполнено(ФормаВладелец.Сотрудник.Ссылка) Тогда
		ТекстВопроса = НСтр("ru = 'Данные еще не записаны.
				|Переход к сведениям о финансовом учете возможен только после записи данных.
				|Данные будут записаны.'");
		Оповещение = Новый ОписаниеОповещения("ФинансовыйУчетЗавершение", ЭтотОбъект, ДополнительныеПараметры);
		ПоказатьВопрос(Оповещение, ТекстВопроса, РежимДиалогаВопрос.ОКОтмена);
	Иначе
		ДополнительныеПараметры.ЗаписатьЭлемент = Ложь;
		ФинансовыйУчетЗавершение(Неопределено, ДополнительныеПараметры);
	КонецЕсли;
	
КонецПроцедуры

Процедура ФинансовыйУчетОбработкаОповещения(Форма, ИмяСобытия, Параметр, Источник, ИмяОбъектаУчета = "ОбъектФинансовогоУчета") Экспорт
	
	Если Не (ИмяСобытия = "ОтредактированаИстория"
		И (Параметр.ИмяРегистра = "ФинансовыйУчетПодразделений" Или Параметр.ИмяРегистра = "ФинансовыйУчетПозицийКадровогоПлана"
			Или Параметр.ИмяРегистра = "ФинансовыйУчетСотрудников")
		И Форма[ИмяОбъектаУчета] = Источник) Тогда
		
		Возврат;
	КонецЕсли;
	
	Если Не Форма[Параметр.ИмяРегистра + "НаборЗаписейПрочитан"] Тогда
		Возврат;
	КонецЕсли;
	
	РедактированиеПериодическихСведенийКлиент.ОбработкаОповещения(
		Форма, Форма[ИмяОбъектаУчета], ИмяСобытия, Параметр, Источник);
	ФинансовыйУчетКлиентСервер.ОбновитьПолеСведенияОФинансовомУчетеПериод(
		Форма, ОбщегоНазначенияКлиент.ДатаСеанса(), Параметр.ИмяРегистра, ИмяОбъектаУчета);
	ОбработатьОповещениеОбъектаУчета(Форма, Параметр.ИмяРегистра);
	
КонецПроцедуры

Процедура ОткрытьФормуСпискаСотрудниковРаботающихВПериодеПоПараметрам(
	Форма, ВладелецФормыВыбора, НачалоПериода, ОкончаниеПериода, МножественныйВыбор = Истина, ЭтоПодбор = Ложь) Экспорт
	
	Объект = Форма.Объект;
	ПараметрыОткрытия = Неопределено;
	ОрганизацияОтбор = Неопределено;
	ПодразделениеОтбор = Неопределено;
	АдресСотрудников = "";
	
	Если ЭтоПодбор Тогда
		АдресСотрудников = Форма.АдресСпискаПодобранныхСотрудников();
	КонецЕсли;
	
	Если Форма.СтруктураПредприятияНеСоответствуетСтруктуреЮридическихЛиц Тогда
		Если ЗначениеЗаполнено(Объект.Подразделение) Тогда
			ПараметрыОткрытия = Новый Структура;
			ПараметрыОткрытия.Вставить("Отбор", Новый Структура);
			ПараметрыОткрытия.Отбор.Вставить("МестоВСтруктуреПредприятия",
				ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Объект.Подразделение));
		КонецЕсли;
	Иначе
		ОрганизацияОтбор = ?(Форма.ЭтоПодразделение, Неопределено, Форма.ИсточникПодразделенияПредприятия);
		ПодразделениеОтбор = ?(Форма.ЭтоПодразделение, Форма.ИсточникПодразделенияПредприятия, Неопределено);
	КонецЕсли;
	
	КадровыйУчетКлиент.ВыбратьСотрудниковРаботающихВПериодеПоПараметрамОткрытияФормыСписка(
		ВладелецФормыВыбора,
		ОрганизацияОтбор, 
		ПодразделениеОтбор,
		НачалоПериода, 
		ОкончаниеПериода,
		МножественныйВыбор, 
		АдресСотрудников,
		ПараметрыОткрытия);
	
КонецПроцедуры

