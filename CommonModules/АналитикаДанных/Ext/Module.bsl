// @strict-types

#Область СлужебныйПрограммныйИнтерфейс

Функция ДатаНачалаАналитики() Экспорт
	Возврат Дата(2010,01,01);
КонецФункции

// Добавляет роль для профиля, которому доступна работа с аналитикой данных.
// 
// Параметры:
// 	ОписаниеПрофиля - см. УправлениеДоступом.НовоеОписаниеПрофиляГруппДоступа.
//
Процедура ДобавитьРольБазовыеПраваАналитикаДанных(ОписаниеПрофиля) Экспорт
	ОписаниеПрофиля.Роли.Добавить(Метаданные.Роли.БазовыеПраваАналитикаДанных.Имя);
КонецПроцедуры

// Формирует временную таблицу ВТСотрудники, содержащую поля Сотрудник и ФизическоеЛицо
//
// Параметры:
//	Запрос - Запрос
//
Процедура СоздатьВТСотрудники(Запрос) Экспорт
	
	ПараметрыЗапроса = КадровыйУчет.ПараметрыПолученияСотрудниковОрганизацийПоСпискуФизическихЛиц();
	ПараметрыЗапроса.НачалоПериода = ДатаНачалаАналитики();
	ПараметрыЗапроса.ОкончаниеПериода = ТекущаяДатаСеанса();
	ПараметрыЗапроса.РаботникиПоДоговорамГПХ = Истина;
	ПараметрыЗапроса.ПодработкиРаботниковПоТрудовымДоговорам = Истина;
	
	УстановитьПривилегированныйРежим(Истина);
	КадровыйУчет.СоздатьВТСотрудникиОрганизации(Запрос.МенеджерВременныхТаблиц, Истина, ПараметрыЗапроса);
	УстановитьПривилегированныйРежим(Ложь);
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	СотрудникиОрганизации.Сотрудник КАК Сотрудник,
		|	&ДатаНачала КАК ДатаНачала,
		|	&ДатаОкончания КАК ДатаОкончания
		|ПОМЕСТИТЬ ВТСотрудники
		|ИЗ
		|	ВТСотрудникиОрганизации КАК СотрудникиОрганизации";
	Запрос.УстановитьПараметр("ДатаНачала", ПараметрыЗапроса.НачалоПериода);
	Запрос.УстановитьПараметр("ДатаОкончания", ПараметрыЗапроса.ОкончаниеПериода);
	Запрос.Выполнить();
	
КонецПроцедуры

Функция ЕстьНеактуальныеЗаписиАналитикиДанных() Экспорт
	
	НаборРегистров = НаборРегистровОбновленияАналитикиДанных();
	
	Если НаборРегистров.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	ПервыйПроход = Истина;
	Для Каждого ИмяРегистра Из НаборРегистров Цикл
		ТекстЗапроса = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	ИСТИНА
			|ИЗ
			|	#РегистрСведенийИмяТаблицы КАК ИмяТаблицы";
		Если ПервыйПроход Тогда
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ИСТИНА", "ИСТИНА КАК Поле1");
		КонецЕсли;
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "#РегистрСведенийИмяТаблицы", ИмяРегистра);
		Запрос.Текст = Запрос.Текст + ?(ПервыйПроход, "", " ОБЪЕДИНИТЬ ВСЕ ") + ТекстЗапроса;
		ПервыйПроход = Ложь;
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Не РезультатЗапроса.Пустой();
	
КонецФункции

// Набор регистров аналитики данных.
// 
// Возвращаемое значение:
//  Массив из Строка
Функция НаборРегистровОбновленияАналитикиДанных() Экспорт
	Возврат АналитикаДанныхВнутренний.НаборРегистровОбновленияАналитикиДанных();
КонецФункции

