// См. СинхронизацияДанныхЗарплатаКадрыИнтеграцияПодсистем.ЗаполнитьТаблицуЗависимыхДанных.
Процедура ПриЗаполненииТаблицыЗависимыхДанныхДляОбмена(ЗависимыеДанные) Экспорт
	АналитикаДанныхВнутренний.ПриЗаполненииТаблицыЗависимыхДанныхДляОбмена(ЗависимыеДанные);
КонецПроцедуры

// См. СинхронизацияДанныхЗарплатаКадрыИнтеграцияПодсистем.ЗаполнитьЗависимыеДанныеПослеСозданияНовогоУзлаРИБ.
Процедура ЗаполнитьЗависимыеДанныеПослеСозданияНовогоУзла(ПараметрыОбновления) Экспорт
	АналитикаДанныхВнутренний.ЗаполнитьЗависимыеДанныеПослеСозданияНовогоУзла(ПараметрыОбновления);
КонецПроцедуры

#КонецОбласти

// Удалить строки аналитики после даты отбора.
// 
// Параметры:
//  НаборЗаписей - РегистрСведенийНаборЗаписейИмяРегистраСведений
//  ДатаОтбора - Дата
//  ИмяДата - Строка - Имя измерения к которому применяется отбор
Процедура УдалитьСтрокиАналитикиПослеДатыОтбора(НаборЗаписей, ДатаОтбора, ИмяДата = "Дата") Экспорт
	
	Сч = НаборЗаписей.Количество() - 1;
	Пока Сч >= 0 Цикл
		СтрокаТаблицы = НаборЗаписей[Сч];
		Если СтрокаТаблицы[ИмяДата] >= ДатаОтбора Тогда
			НаборЗаписей.Удалить(Сч);
		КонецЕсли;
		Сч = Сч - 1;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область РегламентныеЗадания

Процедура ОбновлениеАналитикиДанных() Экспорт
	
	// Регламентные задания блокируются на время служебных операций с информационной базой.
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.ОбновлениеАналитикиДанных);
	
	АналитикаДанныхВнутренний.ПриОбновленииАналитикиДанных();
	
КонецПроцедуры

#КонецОбласти

#Область ОбновлениеАналитикиДанных

// Длительная операция для обновления источников аналитики данных.
// 
// Параметры:
//  Параметры - Структура
//  АдресРезультата - Строка
Процедура ОбновитьИсточникиАналитикиДанныхДлительнаяОперация(Параметры, АдресРезультата) Экспорт
	
	Попытка
		АналитикаДанныхВнутренний.ПриОбновленииАналитикиДанных();
	Исключение
		ИнформацияОбОшибке = ИнформацияОбОшибке();
		ИмяСобытия = НСтр("ru = 'Интеграция с 1С:Аналитикой'", ОбщегоНазначения.КодОсновногоЯзыка());
		ЗаписьЖурналаРегистрации(ИмяСобытия, УровеньЖурналаРегистрации.Ошибка,,, 
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке));
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Ошибка при обновлении источников данных 1С:Аналитики. Обратитесь к администратору.
					|Техническая информация:
					|При выполнении операции «%1» возникает
					|%2'"), 
			НСтр("ru = 'Обновление источников данных 1С:Аналитики'"),
			ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке));
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения);
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

#КонецОбласти

#КонецОбласти