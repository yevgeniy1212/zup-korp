	Настройка.ПослеОбработки = Истина;
	Настройка.Модуль = СинхронизацияДанныхБЗКПравилаПодчиненныеРегистры;
	
КонецПроцедуры

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляНезависимогоРегистра
Процедура ДляНезависимогоРегистра(Настройки, Измерение, РазделыДанных = Неопределено) Экспорт
	
	ОбщегоНазначенияКлиентСервер.Проверить(
		Настройки.Найти(СинхронизацияДанныхБЗКПравилаНезависимыеРегистры, "Модуль") = Неопределено,
		НСтр("ru = 'В настройках уже присутствует строка с модулем СинхронизацияДанныхБЗКПравилаНезависимыеРегистры'"),
		НСтр("ru = 'СинхронизацияДанныхБЗКНастройкиОбработчиков.ДляНезависимогоРегистра'"));
	
	Настройка = Настройки.Добавить();
	Настройка.ПриОбработкеПослеИзменения = Истина;
	Настройка.ПриОбработкеПередИзменением = Истина;
	Настройка.ПослеОбработки = Истина;
	Настройка.Модуль = СинхронизацияДанныхБЗКПравилаНезависимыеРегистры;
	Настройка.ДополнительныеПараметры.Вставить("Измерение", Измерение);
	
	Если РазделыДанных <> Неопределено Тогда
		Настройка.ДополнительныеПараметры.Вставить("РазделыДанных", РазделыДанных);
	КонецЕсли;
	
КонецПроцедуры

