////////////////////////////////////////////////////////////////////////////////
// Подсистема "Синхронизация данных".
// Серверные процедуры - шаблоны настроек обработчиков регистрации, вызываемые из методов
// НастройкиОбработчиковПравилРегистрации модулей менеджеров объектов.
//
////////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

#Область ОтборПоСвойствамПланаОбмена

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОтбораПоОрганизации
Процедура ДляОтбораПоОрганизации(Настройки, СвойстваОбъекта = "Организация",
	РазделыДанных = "РегламентированныеДанные") Экспорт
	
	ДляОтбораПоСвойствамПланаОбмена(Настройки, СинхронизацияДанныхЗарплатаКадрыСервер.ВидыОтборовРИБ().ПоОрганизациям,
		СвойстваОбъекта);
		
	Если РазделыДанных <> Неопределено Тогда
		ДляОтбораПоРазделамДанных(Настройки, РазделыДанных);
	КонецЕсли;
	
КонецПроцедуры

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОтбораПоПодразделению
Процедура ДляОтбораПоПодразделению(Настройки, СвойстваОбъекта = "Подразделение",
	РазделыДанных = "УправленческиеДанные") Экспорт
	
	ДляОтбораПоСвойствамПланаОбмена(Настройки, СинхронизацияДанныхЗарплатаКадрыСервер.ВидыОтборовРИБ().ПоПодразделениям,
		СвойстваОбъекта);
		
	Если РазделыДанных <> Неопределено Тогда
		ДляОтбораПоРазделамДанных(Настройки, РазделыДанных);
	КонецЕсли;
	
КонецПроцедуры

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОтбораПоСвойствамПланаОбмена
Процедура ДляОтбораПоСвойствамПланаОбмена(Настройки, ВидОтбора, СвойстваОбъекта) Экспорт
	
	ОбщегоНазначенияКлиентСервер.ПроверитьПараметр(
		"СинхронизацияДанныхБЗКНастройкиОбработчиков.ДляОтбораПоСвойствамПланаОбмена", "СвойстваОбъекта",
		СвойстваОбъекта, Новый ОписаниеТипов("Массив, Строка"));
	
	Настройка = Настройки.Добавить();
	Настройка.ПриОбработкеПослеИзменения = Истина;
	Настройка.ПриОбработкеПередИзменением = Истина;
	Настройка.Модуль = СинхронизацияДанныхБЗКПравилаОтборПоСвойствамПланаОбмена;
	
	Настройка.ДополнительныеПараметры.Вставить("СвойстваОбъекта", СвойстваОбъекта);
	Настройка.ДополнительныеПараметры.Вставить("ВидОтбора", ВидОтбора);

КонецПроцедуры

#КонецОбласти

#Область ОтборПоРазделамДанных

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляРегламентированныхДанных
Процедура ДляРегламентированныхДанных(Настройки) Экспорт
	ДляОтбораПоРазделамДанных(Настройки, "РегламентированныеДанные");
КонецПроцедуры

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляУправленческихДанных
Процедура ДляУправленческихДанных(Настройки) Экспорт
	ДляОтбораПоРазделамДанных(Настройки, "УправленческиеДанные");
КонецПроцедуры

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОтбораПоРазделамДанных
Процедура ДляОтбораПоРазделамДанных(Настройки, РазделыДанных) Экспорт
	
	ОбщегоНазначенияКлиентСервер.ПроверитьПараметр(
		"СинхронизацияДанныхБЗКНастройкиОбработчиков.ДляОтбораПоРазделамДанных", "РазделыДанных", РазделыДанных,
		Новый ОписаниеТипов("Массив,Строка"));
	
	Настройка = Настройки.Добавить();
	Настройка.ПриОбработкеПослеИзменения = Истина;
	Настройка.ПриОбработкеПередИзменением = Истина;
	Настройка.Модуль = СинхронизацияДанныхБЗКПравилаОтборПоРазделамДанных;
	
	Настройка.ДополнительныеПараметры.Вставить("РазделыДанных", РазделыДанных);

КонецПроцедуры

#КонецОбласти

