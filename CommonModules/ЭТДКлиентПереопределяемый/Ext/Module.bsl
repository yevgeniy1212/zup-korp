#Область СлужебныеПроцедурыИФункции

Функция ПолучитьСписокВыбораДокументОснованиеЭТДЗУП()
	
	СписокТипов = Новый СписокЗначений;
	СписокТипов.Добавить(Тип("ДокументСсылка.КадровыйПеревод"));
	СписокТипов.Добавить(Тип("ДокументСсылка.КадровыйПереводСписком"));
	СписокТипов.Добавить(Тип("ДокументСсылка.ПеремещениеВДругоеПодразделение"));
	СписокТипов.Добавить(Тип("ДокументСсылка.ПриемНаРаботу"));
	СписокТипов.Добавить(Тип("ДокументСсылка.ПриемНаРаботуСписком"));
	
	Возврат СписокТипов;
	
КонецФункции

Процедура ОткрытиеФормыВыбораВладельцаПрофиляЗУП(ВыбранныйЭлемент, Организация, Форма)
	
	ПолеОтбора = "";
	Если ВыбранныйЭлемент.Значение = Тип("СправочникСсылка.Сотрудники") Тогда
		ИмяОткрываемойФормы = "Справочник.Сотрудники.ФормаВыбора";
		ПолеОтбора = "Организация";
	ИначеЕсли ВыбранныйЭлемент.Значение = Тип("СправочникСсылка.ШтатноеРасписание") Тогда
		ИмяОткрываемойФормы = "Справочник.ШтатноеРасписание.ФормаВыбора";
		ПолеОтбора = "Владелец";
	ИначеЕсли ВыбранныйЭлемент.Значение = Тип("СправочникСсылка.Должности") Тогда
		ИмяОткрываемойФормы = "Справочник.Должности.ФормаВыбора";
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПолеОтбора) Тогда
		ПараметрыОтбора = Новый Структура(ПолеОтбора, Организация);
		ПараметрыФормы = Новый Структура("РежимВыбора, Отбор", Истина, ПараметрыОтбора);
	Иначе
		ПараметрыФормы = Новый Структура("РежимВыбора", Истина);
	КонецЕсли;
	Оповещение = Новый ОписаниеОповещения("ОбработкаВыбораВладельцаПрофиля", Форма);
	
	ОткрытьФорму(ИмяОткрываемойФормы, ПараметрыФормы, Форма, , , , Оповещение);
	
КонецПроцедуры

Процедура ОткрытиеФормыВыбораСотрудникаЗУП(Организация, Элемент)
	
	ПараметрыОтбора = Новый Структура("Организация", Организация);
	ПараметрыФормы = Новый Структура("Отбор", ПараметрыОтбора);
	ОткрытьФорму("Справочник.Сотрудники.ФормаВыбора", ПараметрыФормы, Элемент);
	
КонецПроцедуры

Процедура ОткрытиеФормыВыбораДолжностиПоШтатномуРасписаниюЗУП(Организация, Элемент)
	
	ПараметрыОтбора = Новый Структура("Владелец", Организация);
	ПараметрыФормы = Новый Структура("Отбор,РежимВыбора", ПараметрыОтбора, Истина);
	ОткрытьФорму("Справочник.ШтатноеРасписание.ФормаСписка", ПараметрыФормы, Элемент);
	
КонецПроцедуры

Функция ПолучитьИмяФормыВыбораДокументаОснованияЗУП(ВыбранныйЭлемент)
	
	ИмяОткрываемойФормы = "";
	
	Если ВыбранныйЭлемент.Значение = Тип("ДокументСсылка.КадровыйПеревод") Тогда
		ИмяОткрываемойФормы = "Документ.КадровыйПеревод.ФормаСписка";
	ИначеЕсли ВыбранныйЭлемент.Значение = Тип("ДокументСсылка.КадровыйПереводСписком") Тогда
		ИмяОткрываемойФормы = "Документ.КадровыйПереводСписком.ФормаСписка";
	ИначеЕсли ВыбранныйЭлемент.Значение = Тип("ДокументСсылка.ПеремещениеВДругоеПодразделение") Тогда
		ИмяОткрываемойФормы = "Документ.ПеремещениеВДругоеПодразделение.ФормаСписка";
	ИначеЕсли ВыбранныйЭлемент.Значение = Тип("ДокументСсылка.ПриемНаРаботу") Тогда
		ИмяОткрываемойФормы = "Документ.ПриемНаРаботу.ФормаСписка";
	ИначеЕсли ВыбранныйЭлемент.Значение = Тип("ДокументСсылка.ПриемНаРаботуСписком") Тогда
		ИмяОткрываемойФормы = "Документ.ПриемНаРаботуСписком.ФормаСписка";
	КонецЕсли;
	
	Возврат ИмяОткрываемойФормы;
	
КонецФункции

#КонецОбласти
