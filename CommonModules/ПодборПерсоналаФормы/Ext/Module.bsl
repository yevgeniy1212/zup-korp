#Область ПрограммныйИнтерфейс

// Дополняет колонки истории взаимоотношений.
// 
// Параметры:
//  Таблица - ТаблицаЗначений
Процедура ДополнитьКолонкиИсторииВзаимоотношений(Таблица) Экспорт
	Таблица.Колонки.Добавить("Кандидат", Новый ОписаниеТипов("СправочникСсылка.Кандидаты"));
	Таблица.Колонки.Добавить("ЛичныеДанныеКандидата", Новый ОписаниеТипов("СправочникСсылка.ЛичныеДанныеКандидатов"));
КонецПроцедуры

// Формирует запрос для поиска похожих физических лиц.
// 
// Параметры:
//  Запрос - Запрос
//  ПараметрыПоиска - см. СотрудникиКлиентСервер.ПараметрыПоискаПохожих
Процедура СформироватьЗапросПоискаПохожихФизическихЛиц(Запрос, ПараметрыПоиска) Экспорт
	
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ФизическиеЛица.Ссылка КАК Ссылка,
		|	ФизическиеЛица.Наименование КАК Наименование,
		|	ФизическиеЛица.УточнениеНаименования КАК УточнениеНаименования,
		|	1 КАК Приоритет
		|ИЗ
		|	Справочник.ФизическиеЛица КАК ФизическиеЛица
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеПоискаФизическихЛиц КАК ДанныеПоискаФизическихЛиц
		|		ПО (ДанныеПоискаФизическихЛиц.ФизическоеЛицо = ФизическиеЛица.Ссылка)
		|ГДЕ
		|	&НомерТелефона
		|	И ФизическиеЛица.Ссылка <> &ФизическоеЛицо
		|	И НЕ ФизическиеЛица.ПометкаУдаления
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ФизическиеЛица.Ссылка,
		|	ФизическиеЛица.Наименование,
		|	ФизическиеЛица.УточнениеНаименования,
		|	2
		|ИЗ
		|	Справочник.ФизическиеЛица КАК ФизическиеЛица
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеПоискаФизическихЛиц КАК ДанныеПоискаФизическихЛиц
		|		ПО (ДанныеПоискаФизическихЛиц.ФизическоеЛицо = ФизическиеЛица.Ссылка)
		|ГДЕ
		|	&АдресЭП
		|	И ФизическиеЛица.Ссылка <> &ФизическоеЛицо
		|	И НЕ ФизическиеЛица.ПометкаУдаления
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ФизическиеЛица.Ссылка,
		|	ФизическиеЛица.Наименование,
		|	ФизическиеЛица.УточнениеНаименования,
		|	3
		|ИЗ
		|	Справочник.ФизическиеЛица КАК ФизическиеЛица
		|ГДЕ
		|	ФизическиеЛица.Ссылка <> &ФизическоеЛицо
		|	И НЕ ФизическиеЛица.ПометкаУдаления
		|	И &ФИО";
		
	Если ЗначениеЗаполнено(ПараметрыПоиска.Телефон) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&НомерТелефона",
			"ДанныеПоискаФизическихЛиц.Телефоны ПОДОБНО &НомерТелефона");
		Запрос.УстановитьПараметр("НомерТелефона",
			"%" + ПоискФизическихЛиц.ТелефонВФорматеПоиска(ПараметрыПоиска.Телефон) + "%");
	Иначе
		Запрос.УстановитьПараметр("НомерТелефона", Ложь);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПараметрыПоиска.Email) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&АдресЭП",
			"ДанныеПоискаФизическихЛиц.АдресаЭлектроннойПочты ПОДОБНО &АдресЭП");
		Запрос.УстановитьПараметр("АдресЭП", "%" + ПараметрыПоиска.Email + "%");
	Иначе
		Запрос.УстановитьПараметр("АдресЭП", Ложь);
	КонецЕсли;
	
КонецПроцедуры

// Добавляет и заполняет колонку "СовпадающиеДанные" в таблице похожих кандидатов.
// 
// Параметры:
//  ТаблицаПохожих - ТаблицаЗначений -:
//   * Ссылка - СправочникСсылка.ФизическиеЛица -
//   * Наименование - Строка -
//   * Приоритет - Число -
//  ТаблицаДанных - ТаблицаЗначений
//  ИмяКолонкиПохожих - Строка
//  ИмяКолонкиДанных - Строка
Процедура ДобавитьЗаполнитьКолонкуСовпадающиеДанные(ТаблицаПохожих, ТаблицаДанных, ИмяКолонкиПохожих,
	ИмяКолонкиДанных) Экспорт

	Если ТаблицаДанных.Колонки.Найти("СовпадающиеДанные") = Неопределено Тогда
		ТаблицаДанных.Колонки.Добавить("СовпадающиеДанные", Новый ОписаниеТипов("Строка"));
	КонецЕсли;
	
	Для Каждого ТекущаяСтрока Из ТаблицаДанных Цикл
		
		НайденныеСтроки = ТаблицаПохожих.НайтиСтроки(Новый Структура(ИмяКолонкиПохожих, ТекущаяСтрока[ИмяКолонкиДанных]));
		ОбщегоНазначенияКлиентСервер.Проверить(НайденныеСтроки.Количество() > 0,
			СтрШаблон(НСтр("ru = 'Не найдены данные %1 в таблице похожих'"), ТекущаяСтрока[ИмяКолонкиДанных]),
			"ПодборПерсоналаФормы.ДобавитьЗаполнитьКолонкуСовпадающиеДанные");
		
		Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
			ТекущаяСтрока.СовпадающиеДанные = ТекущаяСтрока.СовпадающиеДанные
				+ СовпадающиеДанныеПоПриоритету()[НайденнаяСтрока.Приоритет] + ",";
		КонецЦикла;
		
		Если Не ПустаяСтрока(ТекущаяСтрока.СовпадающиеДанные) Тогда
			СтроковыеФункцииКлиентСервер.УдалитьПоследнийСимволВСтроке(ТекущаяСтрока.СовпадающиеДанные);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Добавляет в ДополнительныеСвойства объекта физического лица связанные данные.
//
// Параметры:
//  Форма - ФормаКлиентскогоПриложения
//  ФизическоеЛицоОбъект - СправочникОбъект.ФизическиеЛица
Процедура ЗаполнитьСвязанныеДанныеФизическогоЛица(Форма, ФизическоеЛицоОбъект) Экспорт
	
	Если Не ЗначениеЗаполнено(Форма.ЛичныеДанныеКандидатаСсылка) Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеФизическогоЛица = КадровыйУчет.НовыеДанныеФизическогоЛица();
	
	ДополнительныеПараметры = Новый Структура;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Форма, "АдресФотографии") Тогда
		ДополнительныеПараметры.Вставить("АдресФотографии", Форма.АдресФотографии);
	КонецЕсли;
	Справочники.ЛичныеДанныеКандидатов.ЗаполнитьДанныеФизическогоЛица(ДанныеФизическогоЛица,
		Форма.ЛичныеДанныеКандидатаСсылка, ДополнительныеПараметры);
	СвязанныеОбъекты = КадровыйУчет.СвязанныеОбъектыДанныхФизическогоЛица(ДанныеФизическогоЛица);
	СвязанныеОбъекты.Вставить("ЛичныеДанныеКандидата", Форма.ЛичныеДанныеКандидатаСсылка);
	
	ФизическоеЛицоОбъект.ДополнительныеСвойства.Вставить("СвязанныеОбъекты", СвязанныеОбъекты);
	
КонецПроцедуры

// Устанавливает параметры открытия формы физические лица с похожими данными.
// 
// Параметры:
//  ПараметрыФормы - Структура
Процедура ФизическиеЛицаСПохожимиДаннымиПриСозданииНаСервере(ПараметрыФормы) Экспорт
	
	Если Не ПараметрыФормы.Свойство("ДанныеКандидатов") Тогда
		Возврат;
	КонецЕсли;
	
	КоличествоНайденных = ПараметрыФормы.ДанныеФизическихЛиц.Количество()
		+ ПараметрыФормы.ДанныеКандидатов.Количество();
	ПараметрыФормы.КлючНазначенияИспользования = ?(КоличествоНайденных < 2, "БезСписка", "СоСписком");
	
	ПараметрыФормы.ДанныеФизическихЛицДоступны = 
		(ПараметрыФормы.ДанныеФизическихЛиц.Количество() = 0
			Или ПараметрыФормы.ДанныеФизическихЛицДоступны)
		И (ПараметрыФормы.ДанныеКандидатов.Количество() = 0
			Или ПараметрыФормы.ДанныеКандидатовДоступны);
			
КонецПроцедуры

// Дополняет однофамильцев кандидатами.
// 
// Параметры:
//  Однофамильцы - ДанныеФормыКоллекция
//  ДанныеКандидатов - ТаблицаЗначений
Процедура ДополнитьОднофамильцев(Однофамильцы, ДанныеКандидатов) Экспорт

	Для Каждого СтрокаДанных Из ДанныеКандидатов Цикл
		НоваяСтрока = Однофамильцы.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДанных);
		НоваяСтрока.ФИОПолные = СтрокаДанных.ФИО;
		Если ЗначениеЗаполнено(НоваяСтрока.ДатаРождения) Тогда
			НоваяСтрока.ВозрастПредставление = ФизическиеЛицаЗарплатаКадрыКлиентСервер.ПредставлениеВозраста(
				НоваяСтрока.ДатаРождения, ТекущаяДатаСеанса());
		КонецЕсли;
		НоваяСтрока.МобильныйТелефон = СтрокаДанных.Телефон;
		НоваяСтрока.АдресЭлектроннойПочты = СтрокаДанных.EMail;
		НоваяСтрока.ПолПредставление = ФизическиеЛицаЗарплатаКадрыКлиентСервер.ПредставлениеПола(СтрокаДанных.Пол);
		НоваяСтрока.АдресФотографии = ПодборПерсонала.АдресФотографииЛичныхДанныхКандидата(СтрокаДанных.ЛичныеДанныеКандидата);
	КонецЦикла;
	
КонецПроцедуры

// Добавляет реквизиты в форму поиска однофамильцев.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения
Процедура ДобавитьРеквизитыФормыПоискаОднофамильцев(Форма) Экспорт
	
	ДобавляемыеРеквизиты = Новый Массив;
	ОписаниеТиповЛичныеДанныеКандидатов = Новый ОписаниеТипов("СправочникСсылка.ЛичныеДанныеКандидатов");
	
	РеквизитЛичныеДанныеКандидата = Новый РеквизитФормы("ЛичныеДанныеКандидата", ОписаниеТиповЛичныеДанныеКандидатов);
	ДобавляемыеРеквизиты.Добавить(РеквизитЛичныеДанныеКандидата);
	
	КолонкаОднофамильцыЛичныеДанныеКандидата = Новый РеквизитФормы("ЛичныеДанныеКандидата", 
		ОписаниеТиповЛичныеДанныеКандидатов, "Однофамильцы");
	ДобавляемыеРеквизиты.Добавить(КолонкаОднофамильцыЛичныеДанныеКандидата);
	
	КолонкаВсеОднофамильцыЛичныеДанныеКандидата = Новый РеквизитФормы("ЛичныеДанныеКандидата",
		ОписаниеТиповЛичныеДанныеКандидатов, "ВсеОднофамильцы");
	ДобавляемыеРеквизиты.Добавить(КолонкаВсеОднофамильцыЛичныеДанныеКандидата);
	
	КолонкаИсторияЛичныеДанныеКандидата = Новый РеквизитФормы("ЛичныеДанныеКандидата", 
		ОписаниеТиповЛичныеДанныеКандидатов, "История");
	ДобавляемыеРеквизиты.Добавить(КолонкаИсторияЛичныеДанныеКандидата);
	
	КолонкаОднофамильцыСовпавшиеДанные = Новый РеквизитФормы("СовпадающиеДанные", Новый ОписаниеТипов("Строка"),
		"Однофамильцы");
	ДобавляемыеРеквизиты.Добавить(КолонкаОднофамильцыСовпавшиеДанные);
	
	КолонкаВсеОднофамильцыСовпавшиеДанные = Новый РеквизитФормы("СовпадающиеДанные", Новый ОписаниеТипов("Строка"),
		"ВсеОднофамильцы");
	ДобавляемыеРеквизиты.Добавить(КолонкаВсеОднофамильцыСовпавшиеДанные);
	
	Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
КонецПроцедуры

// Заполняет данные физического лица по кандидату в форме физического лица.
// 
// Параметры:
//  Форма - ФормаКлиентскогоПриложения -
Процедура ЗаполнитьФизическоеЛицоПоКандидату(Форма) Экспорт
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИдентификаторФормы", Форма.УникальныйИдентификатор);
	
	УстановитьПривилегированныйРежим(Истина);
	ФизическоеЛицоОбъект = Справочники.ЛичныеДанныеКандидатов.ОбъектФизическоеЛицоПоДаннымКандидата(
		Форма.ЛичныеДанныеКандидатаСсылка, ДополнительныеПараметры);
	УстановитьПривилегированныйРежим(Ложь);
	
	Форма.ЗначениеВРеквизитФормы(ФизическоеЛицоОбъект, "ФизическоеЛицо");
	Форма.ФизическоеЛицоМестоРождения = ПерсонифицированныйУчетКлиентСервер.ПредставлениеМестаРождения(
		Форма.ФизическоеЛицо.МестоРождения);
	Форма.АдресФотографии = ФизическоеЛицоОбъект.ДополнительныеСвойства.СвязанныеОбъекты.АдресФотографии;
	
	Для Каждого ЭлементКонтактнойИнформации Из Форма.ФизическоеЛицо.КонтактнаяИнформация Цикл
		Для Каждого ОписаниеРеквизита Из Форма.КонтактнаяИнформацияОписаниеДополнительныхРеквизитов Цикл
			Если ОписаниеРеквизита.Вид <> ЭлементКонтактнойИнформации.Вид Тогда
				Продолжить;
			КонецЕсли;
			ОписаниеРеквизита.Значение = ЭлементКонтактнойИнформации.Значение;
			ОписаниеРеквизита.Представление = ЭлементКонтактнойИнформации.Представление;
			Форма[ОписаниеРеквизита.ИмяРеквизита] = ЭлементКонтактнойИнформации.Представление;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

#Область ЗащитаПерсональныхДанных

// Вызывается при получении формой данных объекта. Дополняет состав элементов формы надписью о статусе согласия 
// на обработку персональных данных субъекта и декорацией отсутствия согласия. Формирует текст надписи.
//
// Параметры:
//	Форма				- ФормаКлиентскогоПриложения - форма, связанная с субъектом.
//	ТекущийОбъект		- СправочникОбъект - объект, который будет прочитан.
//	ИмяКлючевогоПоля	- Строка - "Ссылка" или заданное имя реквизита, содержащего ссылку на субъект.
//
Процедура ФормаСубъектаПриПолученииДанныхНаСервере(Форма, ТекущийОбъект, ИмяКлючевогоПоля = "Ссылка") Экспорт
	
	Элементы = Форма.Элементы;
	
	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьСкрытиеПерсональныхДанныхСубъектов") Тогда
		Возврат;
	КонецЕсли;
	
	ГруппаСведения = Элементы.Найти("ГруппаСведенияОСогласииНаОбработкуПДн");
	Если ГруппаСведения = НеОпределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПравоДоступа("Изменение", Метаданные.Справочники.ЛичныеДанныеКандидатов) Тогда
		Возврат;
	КонецЕсли;
	
	Субъект = ТекущийОбъект[ИмяКлючевогоПоля];
	
	ФизическоеЛицо = ПодборПерсонала.ФизическоеЛицоЛичныхДанныхКандидата(Субъект);
	Если ЗначениеЗаполнено(ФизическоеЛицо) Тогда
		Возврат;
	КонецЕсли;
	
	Если Элементы.Найти("ДекорацияПредупреждениеОбОтсутствииСогласия") = НеОпределено Тогда
		
		Элемент = Элементы.Добавить("ДекорацияПредупреждениеОбОтсутствииСогласия", Тип("ДекорацияФормы"), ГруппаСведения);
		Элемент.Заголовок = НСтр("ru = 'Предупреждение об отсутствии согласия'");
		Элемент.Вид = ВидДекорацииФормы.Картинка;
		Элемент.Картинка = БиблиотекаКартинок.Предупреждение;
		Элемент.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
		
	КонецЕсли;
	
	Если Элементы.Найти("СообщениеОСогласииНаОбработкуПДн") = НеОпределено Тогда
		
		Элемент = Элементы.Вставить("СообщениеОСогласииНаОбработкуПДн", Тип("ДекорацияФормы"), ГруппаСведения);
		Элемент.Заголовок = Новый ФорматированнаяСтрока("");
		Элемент.Вид = ВидДекорацииФормы.Надпись;
		Элемент.ЦветТекста = ЦветаСтиля.ПоясняющийТекст;
		Элемент.АвтоМаксимальнаяШирина = Ложь;
		Элемент.УстановитьДействие("ОбработкаНавигационнойСсылки", "Подключаемый_СообщениеОСогласииОбработкаНавигационнойСсылки");
		
	КонецЕсли;
	
	ЭлементНадписи = Элементы.Найти("СообщениеОСогласииНаОбработкуПДн");
	ЭлементДекорации = Элементы.ДекорацияПредупреждениеОбОтсутствииСогласия;
	
	ГруппаСведения.Видимость = ОбщегоНазначения.СсылкаСуществует(Субъект);
	
	СтатусСогласия = СтатусСогласияНаОбработкуПДнСубъекта(Субъект);
	
	ЭлементДекорации.Видимость = СтатусСогласия.Требуется;
	ЭлементНадписи.Заголовок = СтатусСогласия.Описание;
	
КонецПроцедуры

// В форме списка заполняет колонку с картинкой, сигнализирующей об отсутствии требуемого согласия 
// на обработку персональных данных кандидата.
// Вызывается из события ПриПолученииДанныхНаСервере формы списка.
//
// Параметры:
//	Настройки			- НастройкиКомпоновкиДанных - содержит копию полных настроек динамического списка.
//	Строки				- СтрокиДинамическогоСписка - коллекция содержит данные и оформление всех строк,
//							получаемых в списке, кроме строк группировок.
//	ИмяКлючевогоПоля	- Строка - "Ссылка" или заданное имя колонки, содержащей ссылку на субъект.
//
Процедура СписокСубъектовПриПолученииДанныхНаСервере(Настройки, Строки, ИмяКлючевогоПоля = "Ссылка") Экспорт
	
	Перем ТекущаяДата;
	
	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьСкрытиеПерсональныхДанныхКандидатов") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не Настройки.ДополнительныеСвойства.Свойство("ТекущаяДата", ТекущаяДата) Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Субъекты = Новый Массив;
	СубъектыПоКлючу = Новый Соответствие;
	СтрокиСубъектов = Новый Соответствие;
	
	СубъектыПоКлючу = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(Строки.ПолучитьКлючи(), ИмяКлючевогоПоля);
	
	Для Каждого Строка Из Строки Цикл
		
		Если ИмяКлючевогоПоля = "Ссылка" Тогда
			Субъект = Строка.Ключ;
		Иначе
			Субъект = СубъектыПоКлючу.Получить(Строка.Ключ);
		КонецЕсли;
		
		Субъекты.Добавить(Субъект);
		СтрокиСубъектов.Вставить(Субъект, Строка);
		
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаСубъектыДляСкрытияПерсональныхДанных(Истина) + "
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Субъекты.Субъект КАК Субъект
	|ИЗ
	|	ВТСубъектыДляСкрытия КАК Субъекты
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СубъектыДляСкрытияПерсональныхДанных КАК СубъектыДляСкрытияПДн
	|		ПО СубъектыДляСкрытияПДн.Субъект = Субъекты.Субъект
	|ГДЕ
	|	Субъекты.Субъект В(&Субъекты)
	|	И СубъектыДляСкрытияПДн.Субъект ЕСТЬ NULL
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СубъектыДляСкрытияПДн.Субъект
	|ИЗ
	|	РегистрСведений.СубъектыДляСкрытияПерсональныхДанных КАК СубъектыДляСкрытияПДн
	|ГДЕ
	|	СубъектыДляСкрытияПДн.Субъект В(&Субъекты)
	|	И СубъектыДляСкрытияПДн.ДатаСкрытия > &ПустаяДата
	|	И СубъектыДляСкрытияПДн.ДатаСкрытия <= &РасчетнаяДата
	|	И СубъектыДляСкрытияПДн.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияСубъектовДляСкрытия.ГотовКСкрытию)";
	
	Запрос.УстановитьПараметр("Субъекты", Субъекты);
	Запрос.УстановитьПараметр("ПустаяДата", '00010101');
	Запрос.УстановитьПараметр("РасчетнаяДата", ТекущаяДата);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		СтрокаСписка = СтрокиСубъектов.Получить(Выборка.Субъект).Значение;
		СтрокаСписка.Данные["ОтсутствуетСогласие"] = 1;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

Процедура ФизическиеЛицаФормаЭлементаПриСозданииНаСервере(Форма, ГруппаКоманд) Экспорт

	Если Не ПодборПерсонала.ИспользоватьКандидатов() Тогда
		Возврат;
	КонецЕсли;
	
	СоздатьКомандуДобавленияНовогоКандидата(Форма, ГруппаКоманд);	
	
КонецПроцедуры

Процедура ПриНастройкеОтбораИсторииВзаимоотношенийФизическогоЛица(Форма, ПереключательОтбора) Экспорт 

	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьПодборПерсонала") Тогда
		Возврат;
	КонецЕсли;

	ПереключательОтбора.СписокВыбора.Добавить(3, НСтр("ru = 'Кандидаты'"));

КонецПроцедуры

// Добавляет команды в подменю "Оформить документ" для справочника "Сотрудники".
// См. СотрудникиФормыРасширенный.ОписаниеМенюВводаНаОсновании.
// 
// Параметры:
// 	ОписаниеМеню
//
Процедура ДобавитьПодменюПодбораПерсонала(ОписаниеМеню) Экспорт
	
	Если Не ПравоДоступа("Изменение", Метаданные.Справочники.Вакансии) Тогда
		Возврат;
	КонецЕсли;
	
	ПунктыМеню = Новый Массив;
	ПунктыМеню.Добавить("Справочники.Вакансии");

	Представления = Новый Соответствие;
	Представления.Вставить("Справочники.Вакансии", НСтр("ru = 'Открыть вакансию'"));

	РазделМеню = СотрудникиФормы.РазделМеню(НСтр("ru = 'Подбор персонала'"), ПунктыМеню, , Представления); 

	ОписаниеМеню.Пункты.Добавить(РазделМеню);
	
КонецПроцедуры

Процедура ДобавитьВМассивСоздаваемыеРеквизитыФормыСотрудника(МассивДобавляемыхРеквизитов, Отказ = Ложь) Экспорт
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	ЛичныеДанныеКандидатаСсылкаРеквизитФормы = Новый РеквизитФормы("ЛичныеДанныеКандидатаСсылка",
		Новый ОписаниеТипов("СправочникСсылка.ЛичныеДанныеКандидатов"));
	МассивДобавляемыхРеквизитов.Добавить(ЛичныеДанныеКандидатаСсылкаРеквизитФормы);
	
	Если ПодборПерсонала.ИспользоватьКандидатов() Тогда
		КандидатРеквизитФормы = Новый РеквизитФормы("КандидатСсылка", Новый ОписаниеТипов("СправочникСсылка.Кандидаты"));
		МассивДобавляемыхРеквизитов.Добавить(КандидатРеквизитФормы);
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  Форма - Форма
Процедура ПриСозданииНаСервереФормыСотрудника(Форма) Экспорт

	Если Не ПодборПерсонала.ИспользоватьКандидатов() Тогда
		Возврат;
	КонецЕсли;
	
	Кандидат = ПодборПерсонала.КандидатСотрудника(Форма.СотрудникСсылка);
	
	Если Кандидат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ГиперссылкаКандидата = Форма.Элементы.Добавить("Кнопка", Тип("КнопкаФормы"), Форма.Элементы.ГруппаПодборПерсонала);
	ГиперссылкаКандидата.Вид = ВидКнопкиФормы.Гиперссылка;
	
	Команда = Форма.Команды.Добавить("ОткрытьКандидатаСотрудника");
	Команда.Заголовок = НСтр("ru = 'Открыть кандидата сотрудника'");
	Команда.Подсказка = НСтр("ru = 'Перейти к кандидату'");
	Команда.Действие = "Подключаемый_ОткрытьКандидатаСотрудника";
	
	ГиперссылкаКандидата.ИмяКоманды = "ОткрытьКандидатаСотрудника";
	ГиперссылкаКандидата.Заголовок = НСтр("ru = 'О кандидате'");
	
	Форма.КандидатСсылка = Кандидат;
	
КонецПроцедуры

Процедура ЗаполнитьОжидаемыйДоходВВалютеПоУмолчанию(Настройки, Строки) Экспорт
	
	Кандидаты = Строки.ПолучитьКлючи();
	ДанныеКандидатов = Справочники.Кандидаты.ДанныеКандидатов(Кандидаты);
	
	Если ДанныеКандидатов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	КурсыВалют = Новый Соответствие;
	Если Настройки.ДополнительныеСвойства.Свойство("КурсыВалют") Тогда
		КурсыВалют = Настройки.ДополнительныеСвойства["КурсыВалют"];
	Иначе
		Настройки.ДополнительныеСвойства.Вставить("КурсыВалют", КурсыВалют);
	КонецЕсли;
	
	КолонкаОжидаемыйДоходВВалютеПоУмолчанию = Строки.Получить(Кандидаты[0]).Оформление.Получить("ОжидаемыйДоходВВалютеПоУмолчанию");
	КолонкаОжидаемыйДоход = Строки.Получить(Кандидаты[0]).Оформление.Получить("ОжидаемыйДоход");
	
	Для Каждого Кандидат Из ДанныеКандидатов Цикл
		СтрокаКандидат = Строки.Получить(Кандидат.Кандидат);
		Если СтрокаКандидат = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ОформлениеСтроки = СтрокаКандидат.Оформление;
		Если КолонкаОжидаемыйДоходВВалютеПоУмолчанию <> Неопределено Тогда
			ОжидаемыйДоходВВалютеПоУмолчанию = ПодборПерсоналаКлиентСервер.ОжидаемыйДоходВВалютеПоУмолчанию(
				Кандидат.ОжидаемыйДоход, Кандидат.ВалютаДохода, Кандидат.ПериодичностьДохода, КурсыВалют);
			ОформлениеСтроки["ОжидаемыйДоходВВалютеПоУмолчанию"].УстановитьЗначениеПараметра("Текст", ОжидаемыйДоходВВалютеПоУмолчанию);
		КонецЕсли;
		Если КолонкаОжидаемыйДоход <> Неопределено Тогда
			Если ЗначениеЗаполнено(Кандидат.ОжидаемыйДоход) Тогда
				ОжидаемыйДоход = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = '%1 %2 %3'"),
					Кандидат.ОжидаемыйДоход, Кандидат.ВалютаДохода, Кандидат.ПериодичностьДохода);
			Иначе
				ОжидаемыйДоход = Формат(Кандидат.ОжидаемыйДоход, "ЧН=' '");
			КонецЕсли;
			ОформлениеСтроки["ОжидаемыйДоход"].УстановитьЗначениеПараметра("Текст", ОжидаемыйДоход);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#Область ПоискПохожихКандидатов

// Возвращает структуру параметров поиска похожих кандидатов.
// 
// Возвращаемое значение:
//  Структура:
//   * Ссылка - СправочникСсылка.ЛичныеДанныеКандидатов -
//   * Фамилия - Строка -
//   * Имя - Строка -
//   * Отчество - Строка -
//   * УточнениеНаименования - Строка -
//   * Телефон - Строка -
//   * Email - Строка -
Функция ПараметрыПоискаПохожихКандидатов() Экспорт
	
	ПараметрыПоиска = Новый Структура;
	ПараметрыПоиска.Вставить("Ссылка", Справочники.ЛичныеДанныеКандидатов.ПустаяСсылка());
	ПараметрыПоиска.Вставить("Фамилия", "");
	ПараметрыПоиска.Вставить("Имя", "");
	ПараметрыПоиска.Вставить("Отчество", "");
	ПараметрыПоиска.Вставить("УточнениеНаименования", "");
	ПараметрыПоиска.Вставить("Телефон", "");
	ПараметрыПоиска.Вставить("EMail", "");
	
	Возврат ПараметрыПоиска;
	
КонецФункции

// Подбирает похожих кандидатов.
// 
// Параметры:
//  ПараметрыПоиска - См. ПараметрыПоискаПохожихКандидатов
//  ИсключитьСвязанныхСФизЛицами - Булево
// 
// Возвращаемое значение:
//  Структура:
//   * Фамилия - Строка
//   * Имя - Строка
//   * Отчество - Строка
//   * Телефон - Строка
//   * EMail - Строка
//   * ДанныеКандидатовДоступны - Булево
//   * ДанныеКандидатов - Массив из Структура:
//      ** ЛичныеДанныеКандидата - СправочникСсылка.ЛичныеДанныеКандидатов 
//      ** Наименование - Строка 
//      ** УточнениеНаименования - Строка 
//      ** ФизическоеЛицо - СправочникСсылка.ФизическиеЛица 
//      ** НомерТелефона - Строка 
//      ** Email - Строка 
//      ** Приоритет - Число 
//   * КандидатУникален - Булево
Функция ПодобратьПохожихКандидатов(ПараметрыПоиска, ИсключитьСвязанныхСФизЛицами = Ложь) Экспорт
	
	СтруктураВозврат = Новый Структура;
	СтруктураВозврат.Вставить("Фамилия", ПараметрыПоиска.Фамилия);
	СтруктураВозврат.Вставить("Имя", ПараметрыПоиска.Имя);
	СтруктураВозврат.Вставить("Отчество", ПараметрыПоиска.Отчество);
	СтруктураВозврат.Вставить("Телефон", ПараметрыПоиска.Телефон);
	СтруктураВозврат.Вставить("EMail", ПараметрыПоиска.EMail);
	СтруктураВозврат.Вставить("ДанныеКандидатовДоступны", Истина);
	СтруктураВозврат.Вставить("ДанныеКандидатов", Новый Массив);
	СтруктураВозврат.Вставить("КандидатУникален", Истина);
	
	ПараметрыПоиска.Фамилия  = СОКРЛП(ПараметрыПоиска.Фамилия);
	ПараметрыПоиска.Имя = СОКРЛП(ПараметрыПоиска.Имя);
	ПараметрыПоиска.Отчество = СОКРЛП(ПараметрыПоиска.Отчество);
	
	УстановитьПривилегированныйРежим(Истина);
	ТаблицаПохожих = ПохожиеКандидаты(ПараметрыПоиска, ИсключитьСвязанныхСФизЛицами);
	МассивНайденных = ОбщегоНазначения.ВыгрузитьКолонку(ТаблицаПохожих, "ЛичныеДанныеКандидата", Истина);
	УстановитьПривилегированныйРежим(Ложь);
	
	Если МассивНайденных.Количество() = 0 Тогда
		Возврат СтруктураВозврат;
	КонецЕсли;
		
	СтруктураВозврат.КандидатУникален = Ложь;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивЛичныхДанныхКандидатов", МассивНайденных);
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЛичныеДанныеКандидатов.Ссылка КАК ЛичныеДанныеКандидата
		|ИЗ
		|	Справочник.ЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатов
		|ГДЕ
		|	ЛичныеДанныеКандидатов.Ссылка В (&МассивЛичныхДанныхКандидатов)";
	МассивДоступных = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("ЛичныеДанныеКандидата");
	
	СтруктураВозврат.ДанныеКандидатовДоступны = МассивДоступных.Количество() = МассивНайденных.Количество();
	ДанныеКандидатов = ПодборПерсонала.ОсновныеСведенияОЛичныхДанныхКандидатов(МассивДоступных);
	ДобавитьЗаполнитьКолонкуСовпадающиеДанные(ТаблицаПохожих, ДанныеКандидатов, "ЛичныеДанныеКандидата",
		"ЛичныеДанныеКандидата");
	
	СтруктураВозврат.ДанныеКандидатов = ОбщегоНазначения.ТаблицаЗначенийВМассив(ДанныеКандидатов);
	
	Возврат СтруктураВозврат;
	
КонецФункции

#КонецОбласти

Процедура ЗаполнитьИспытательныйСрок(Настройки, Строки) Экспорт
	
	ПрофилиДолжности = Строки.ПолучитьКлючи();
	ДанныеПрофилейДолжности = Справочники.ПрофилиДолжностей.ДанныеПрофилейДолжности(ПрофилиДолжности);
	
	Если ДанныеПрофилейДолжности.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ПрофильДолжности Из ДанныеПрофилейДолжности Цикл
		Если Не ЗначениеЗаполнено(ПрофильДолжности.ИспытательныйСрок) Тогда
			Продолжить;
		КонецЕсли;
		СтрокаПрофиль = Строки.Получить(ПрофильДолжности.Ссылка);
		Если СтрокаПрофиль = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ОформлениеСтроки = СтрокаПрофиль.Оформление;
		ОформлениеСтроки["ИспытательныйСрок"].УстановитьЗначениеПараметра("Текст", 
			СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(
			НСтр("ru = ';%1 месяц;;%1 месяца;%1 месяцев;'"), ПрофильДолжности.ИспытательныйСрок));
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  Форма - ФормаКлиентскогоПриложения
Процедура НастройкиПользователейИПравПриСозданииНаСервере(Форма) Экспорт
	
	Если ОбщегоНазначения.ПодсистемаСуществует("СтандартныеПодсистемы.УправлениеДоступом") Тогда
		
		Элементы = Форма.Элементы;
		
		НоваяГруппа = Элементы.Добавить("ДоступПоКандидатамГруппыДоступа", Тип("ГруппаФормы"),
			Элементы.ОграниченияПодробноФлаги);
		НоваяГруппа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		НоваяГруппа.ОтображатьЗаголовок = Ложь;
		НоваяГруппа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
		НоваяГруппа.Подсказка = НСтр("ru = 'Можно ограничивать доступ по группам кандидатов. 
			|Это потребует дополнительных ресурсов - применяйте только в случае необходимости.'");
		НоваяГруппа.ОтображениеПодсказки = ОтображениеПодсказки.ОтображатьСнизу;
		
		ИмяРеквизита = "ОграничиватьДоступНаУровнеЗаписейЛичныеДанныеКандидатов";
		НовыйРеквизит = Новый РеквизитФормы(ИмяРеквизита, Новый ОписаниеТипов("Булево"), , , Ложь);
		ДобавляемыеРеквизиты = Новый Массив;
		ДобавляемыеРеквизиты.Добавить(НовыйРеквизит);
		Форма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
		Форма[ИмяРеквизита] = Константы.ОграничиватьДоступНаУровнеЗаписейЛичныеДанныеКандидатов.Получить();
		
		НовыйФлажок = Элементы.Добавить("ОграничиватьДоступНаУровнеЗаписейЛичныеДанныеКандидатов", Тип("ПолеФормы"),
			НоваяГруппа);
		НовыйФлажок.Вид = ВидПоляФормы.ПолеФлажка;
		НовыйФлажок.Заголовок = НСтр("ru = 'Доступ по группам кандидатов'");
		НовыйФлажок.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
		НовыйФлажок.ПутьКДанным = ИмяРеквизита;
		НовыйФлажок.УстановитьДействие("ПриИзменении",
			"Подключаемый_ОграничиватьДоступНаУровнеЗаписейЛичныеДанныеКандидатовПриИзменении");
	
		Если ОбщегоНазначения.ЭтоАвтономноеРабочееМесто() Тогда
			НовыйФлажок.Доступность = Ложь;
		КонецЕсли;
		
		ФорматированнаяСтрока = СтроковыеФункции.ФорматированнаяСтрока(
			НСтр("ru = '<a href=""%1"">Группы кандидатов</a>'"), "e1cib/list/Справочник.ГруппыДоступаКандидатов");
		Декорация = Элементы.Добавить("ГруппыДоступаКандидатовОткрытьСписок", Тип("ДекорацияФормы"), НоваяГруппа);
		Декорация.Вид = ВидДекорацииФормы.Надпись;
		Декорация.Заголовок = ФорматированнаяСтрока;
		Декорация.Видимость = ПолучитьФункциональнуюОпцию("ОграничиватьДоступНаУровнеЗаписейЛичныеДанныеКандидатов");
		
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  Форма - ФормаКлиентскогоПриложения
Процедура ПрочитатьДанныеСвязанныеССотрудником(Форма) Экспорт
	
	Если Форма.СозданиеНового И Форма.ЛичныеДанныеКандидатаСсылка <> Неопределено
		И Не Форма.ЛичныеДанныеКандидатаСсылка.Пустая() Тогда
		
		УстановитьПривилегированныйРежим(Истина);
		ФизическоеЛицоОбъект =
			Справочники.ЛичныеДанныеКандидатов.ОбъектФизическоеЛицоПоДаннымКандидата(Форма.ЛичныеДанныеКандидатаСсылка);
		Форма.ЗначениеВРеквизитФормы(ФизическоеЛицоОбъект, "ФизическоеЛицо");
		УстановитьПривилегированныйРежим(Ложь);
		
		СотрудникиФормыБазовый.ПрочитатьТекущиеДанныеСотрудника(Форма);
	Иначе
		СотрудникиФормыБазовый.ПрочитатьДанныеСвязанныеССотрудником(Форма);
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  ФизическоеЛицоОбъект  - СправочникОбъект.ФизическиеЛица
//  СвязанныеОбъекты - Структура
Процедура ЗаписатьСвязанныеОбъектыФизическогоЛица(ФизическоеЛицоОбъект, СвязанныеОбъекты) Экспорт
	
	Если СвязанныеОбъекты.Свойство("ЛичныеДанныеКандидата") Тогда
		РегистрыСведений.ФизическиеЛицаКандидатов.УстановитьСвязьКандидатаСФизическимЛицом(
			СвязанныеОбъекты.ЛичныеДанныеКандидата, ФизическоеЛицоОбъект.Ссылка);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьЭтапыРаботыСКандидатамиПоУмолчанию(Форма, ЭтапыРаботыСКандидатами, ГруппаРезультатыПроверки) Экспорт
	
	Если ЭтапыРаботыСоответствуютУмолчанию(ЭтапыРаботыСКандидатами) Тогда
		ГруппаРезультатыПроверки.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	ГруппаРезультатыПроверки.Видимость = Истина;
	Если Форма.Элементы.Найти("ЭтапыПоУмолчаниюПредупреждение") = Неопределено Тогда
		Картинка = Форма.Элементы.Добавить("ЭтапыПоУмолчаниюПредупреждение", Тип("ДекорацияФормы"), ГруппаРезультатыПроверки);
		Картинка.Вид = ВидДекорацииФормы.Картинка;
		Картинка.Картинка = БиблиотекаКартинок.Предупреждение32;
		Картинка.РасширеннаяПодсказка.Заголовок = СтроковыеФункции.ФорматированнаяСтрока(
			НСтр("ru = 'Состав этапов работы отличается от предусмотренных программой по умолчанию.
				 |<a href = ""УстановитьЭтапыПоУмолчанию"">Нажмите здесь</a>, чтобы установить состав этапов по умолчанию.'"));
		Картинка.РасширеннаяПодсказка.АвтоМаксимальнаяШирина = Ложь;
		Картинка.ОтображениеПодсказки = ОтображениеПодсказки.ОтображатьСправа;
	КонецЕсли;
	
КонецПроцедуры

Функция ЭтапыРаботыСоответствуютУмолчанию(ЭтапыРаботыСКандидатами)

	ЭтапыРаботы = ОбщегоНазначения.ВыгрузитьКолонку(ЭтапыРаботыСКандидатами, "ЭтапРаботы", Истина);

	// Есть все из действующих.
	Если РазностьМассивов(Перечисления.ЭтапыРаботыСКандидатами.Действующие(), ЭтапыРаботы).Количество() > 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	
	// Нет ни одного из тех, которые есть во всех, но нет в действующих
	Недействующие = РазностьМассивов(Перечисления.ЭтапыРаботыСКандидатами.ВсеЭтапы(), 
		Перечисления.ЭтапыРаботыСКандидатами.Действующие());
	Если РазностьМассивов(Недействующие, ЭтапыРаботы).Количество() < Недействующие.Количество() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

Функция РазностьМассивов(Массив, МассивВычитания)
	Возврат ОбщегоНазначенияКлиентСервер.РазностьМассивов(Массив, МассивВычитания);
КонецФункции

#КонецОбласти

