#Область ЗащитаПерсональныхДанных

Функция СтатусСогласияНаОбработкуПДнСубъекта(Субъект)
	
	СтатусСогласия = Новый Структура();
	СтатусСогласия.Вставить("Требуется", Ложь);
	СтатусСогласия.Вставить("Описание", ТекстСообщенияОтсутствующегоСогласия());
	
	Если ЗащитаПерсональныхДанных.ЭтоОбъектСУничтоженнымиПерсональнымиДанными(Субъект) Тогда
		СтатусСогласия.Описание = ТекстСообщенияСкрытогоСубъекта(
			ЗащитаПерсональныхДанных.ДатаУничтоженияДанныхСубъекта(Субъект));
		Возврат СтатусСогласия;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаСогласияНаОбработкуПерсональныхДанных();
	Запрос.УстановитьПараметр("Субъект", Субъект);
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		ВыборкаДетальныеЗаписи.Следующий();
		Если ТипЗнч(ВыборкаДетальныеЗаписи.Регистратор) = Тип("ДокументСсылка.СогласиеНаОбработкуПерсональныхДанных") Тогда
			Если ВыборкаДетальныеЗаписи.СрокХранения = Дата(3999, 12, 31) Тогда
				СтатусСогласия.Описание = ТекстСообщенияБессрочногоСогласия(ВыборкаДетальныеЗаписи.Регистратор);
			Иначе
				СтатусСогласия.Описание = ТекстСообщенияДействующегоСогласия(ВыборкаДетальныеЗаписи.Регистратор);
			КонецЕсли;
		Иначе
			СтатусСогласия.Описание = ТекстСообщенияОтзываемогоСогласия(ВыборкаДетальныеЗаписи.Регистратор);
			СтатусСогласия.Требуется = Истина;
		КонецЕсли;
	КонецЕсли;
	
	Возврат СтатусСогласия;
	
КонецФункции

Функция ТекстЗапросаСогласияНаОбработкуПерсональныхДанных()
	
	ТекстЗапроса =
		"ВЫБРАТЬ
		|	СогласияНаОбработку.Субъект КАК Субъект,
		|	ВЫБОР
		|		КОГДА СогласияНаОбработку.Действует
		|			ТОГДА ВЫБОР
		|				КОГДА СогласияНаОбработку.СрокДействия = ДАТАВРЕМЯ(1, 1, 1)
		|					ТОГДА ДАТАВРЕМЯ(3999, 12, 31)
		|				ИНАЧЕ СогласияНаОбработку.СрокДействия
		|			КОНЕЦ
		|		ИНАЧЕ СогласияНаОбработку.Период
		|	КОНЕЦ КАК СрокХранения,
		|	СогласияНаОбработку.Действует КАК Действует,
		|	СогласияНаОбработку.Регистратор
		|ПОМЕСТИТЬ ВТСогласияНаОбработку
		|ИЗ
		|	РегистрСведений.СогласияНаОбработкуПерсональныхДанных.СрезПоследних(, Субъект = &Субъект) КАК СогласияНаОбработку
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТСогласияНаОбработку.Субъект КАК Субъект,
		|	МАКСИМУМ(ВТСогласияНаОбработку.СрокХранения) КАК СрокХранения
		|ПОМЕСТИТЬ ВТМаксимальныйСрокХранения
		|ИЗ
		|	ВТСогласияНаОбработку КАК ВТСогласияНаОбработку
		|СГРУППИРОВАТЬ ПО
		|	ВТСогласияНаОбработку.Субъект
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТСогласияНаОбработку.Субъект КАК Субъект,
		|	ВТСогласияНаОбработку.СрокХранения КАК СрокХранения,
		|	МАКСИМУМ(ВТСогласияНаОбработку.Действует) КАК Действует,
		|	МАКСИМУМ(ВТСогласияНаОбработку.Регистратор) КАК Регистратор
		|ИЗ
		|	ВТСогласияНаОбработку КАК ВТСогласияНаОбработку
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТМаксимальныйСрокХранения КАК ВТМаксимальныйСрокХранения
		|		ПО ВТСогласияНаОбработку.Субъект = ВТМаксимальныйСрокХранения.Субъект
		|		И ВТСогласияНаОбработку.СрокХранения = ВТМаксимальныйСрокХранения.СрокХранения
		|СГРУППИРОВАТЬ ПО
		|	ВТСогласияНаОбработку.Субъект,
		|	ВТСогласияНаОбработку.СрокХранения";
	
	Возврат ТекстЗапроса;
	
КонецФункции

Функция ГиперСсылкаСогласие(Согласие)
	
	Возврат Новый ФорматированнаяСтрока(НСтр("ru = 'согласие на обработку ПДн'"), , , , ПолучитьНавигационнуюСсылку(Согласие));
	
КонецФункции

Функция ГиперСсылкаОтзывСогласия(ОтзывСогласия)
	
	Возврат Новый ФорматированнаяСтрока(НСтр("ru = 'отзывается'"), , , , ПолучитьНавигационнуюСсылку(ОтзывСогласия));
	
КонецФункции

Функция ГиперСсылкаНовоеСогласие()
	
	Возврат Новый ФорматированнаяСтрока(НСтр("ru = 'ввести новое согласие'"), , , , "НовоеСогласие");
	
КонецФункции

Процедура ДобавитьЧастиВводаСогласия(ЧастиСообщения)
	
	ЧастиСообщения.Добавить(ГиперСсылкаНовоеСогласие());
	ЧастиСообщения.Добавить(НСтр("ru='.'"));
	
КонецПроцедуры

// Возвращаемое значение:
//  ФорматированнаяСтрока
Функция ТекстСообщенияДействующегоСогласия(Согласие)
	
	ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Согласие, "ДатаПолучения,СрокДействия");
	
	ДатаПолучения = ЗначенияРеквизитов.ДатаПолучения;
	СрокДействия = ЗначенияРеквизитов.СрокДействия;
	
	ЧастиСообщения = Новый Массив;
	ЧастиСообщения.Добавить(СтрШаблон(НСтр("ru='У субъекта %1 было получено'"), Формат(ДатаПолучения, "ДЛФ=D")) + " ");
	ЧастиСообщения.Добавить(ГиперСсылкаСогласие(Согласие));
	
	Если СрокДействия > ТекущаяДатаСеанса() Тогда
		ЧастиСообщения.Добавить(" " + СтрШаблон(НСтр("ru=', которое действует до %1.'"), Формат(СрокДействия, "ДЛФ=D")));
	Иначе
		
		ЧастиСообщения.Добавить(" " + СтрШаблон(НСтр("ru=', которое действовало до %1. Можно'") + " ", Формат(СрокДействия, "ДЛФ=D")));
		ДобавитьЧастиВводаСогласия(ЧастиСообщения);
		
	КонецЕсли;
	
	Возврат Новый ФорматированнаяСтрока(ЧастиСообщения);
	
КонецФункции

Функция ТекстСообщенияБессрочногоСогласия(Согласие)
	
	ДатаПолучения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Согласие, "ДатаПолучения");
	
	ЧастиСообщения = Новый Массив;
	ЧастиСообщения.Добавить(СтрШаблон(НСтр("ru='У субъекта %1 было получено'"), Формат(ДатаПолучения, "ДЛФ=D")) + " ");
	ЧастиСообщения.Добавить(ГиперСсылкаСогласие(Согласие));
	ЧастиСообщения.Добавить(" " + НСтр("ru=', которое действует бессрочно.'"));
	
	Возврат Новый ФорматированнаяСтрока(ЧастиСообщения);
	
КонецФункции

Функция ТекстСообщенияОтсутствующегоСогласия()
	
	ЧастиСообщения = Новый Массив;
	ЧастиСообщения.Добавить(НСтр("ru='У субъекта не было получено согласие на обработку ПДн. Можно'") + " ");
	
	ДобавитьЧастиВводаСогласия(ЧастиСообщения);
	
	Возврат Новый ФорматированнаяСтрока(ЧастиСообщения);
	
КонецФункции

Функция ТекстСообщенияОтзываемогоСогласия(ОтзывСогласия)
	
	ДатаОтзыва = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ОтзывСогласия, "ДатаОтзыва");
	
	ЧастиСообщения = Новый Массив;
	ЧастиСообщения.Добавить(НСтр("ru='Согласие на обработку ПДн'") + " ");
	ЧастиСообщения.Добавить(ГиперСсылкаОтзывСогласия(ОтзывСогласия));
	ЧастиСообщения.Добавить(" " + СтрШаблон(НСтр("ru='%1. Можно'"), Формат(ДатаОтзыва, "ДЛФ=D")) + " ");
	
	ДобавитьЧастиВводаСогласия(ЧастиСообщения);
	
	Возврат Новый ФорматированнаяСтрока(ЧастиСообщения);
	
КонецФункции

Функция ТекстСообщенияСкрытогоСубъекта(ДатаСкрытия)
	
	ЧастиСообщения = Новый Массив;
	ЧастиСообщения.Добавить(СтрШаблон(НСтр("ru='Персональные данные субъекта уничтожены %1.'"), Формат(ДатаСкрытия, "ДЛФ=D")) + " ");
	ЧастиСообщения.Добавить(СтрШаблон(НСтр("ru='Истек срок согласия на обработку ПДн или согласие не было получено.'")));
	
	Возврат Новый ФорматированнаяСтрока(ЧастиСообщения);
	
КонецФункции

Функция ТекстЗапросаСубъектыДляСкрытияПерсональныхДанных(ВоВременнуюТаблицу = Ложь)
	
	ТекстЗапроса = "";
	ОсновнаяТаблица = Истина;
	МетаданныеПоТипамСубъекта = ЗащитаПерсональныхДанныхПовтИсп.МетаданныеПоТипамСубъекта();
	
	Для Каждого ТипСубъектаИМетаданные Из МетаданныеПоТипамСубъекта Цикл
		
		МетаданныеСубъекта = ТипСубъектаИМетаданные.Значение;
		
		ТекстЗапроса = ТекстЗапроса + ?(ПустаяСтрока(ТекстЗапроса),"", " ОБЪЕДИНИТЬ ВСЕ") + "
		|
		|ВЫБРАТЬ
		|	СправочникСубъекта.Ссылка КАК Субъект
		|[ПомещениеВоВременнуюТаблицу]
		|ИЗ
		|	Справочник." + МетаданныеСубъекта.Имя + " КАК СправочникСубъекта
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СубъектыДляСкрытияПерсональныхДанных КАК СубъектыДляСкрытияПерсональныхДанных 
		|		ПО СправочникСубъекта.Ссылка = СубъектыДляСкрытияПерсональныхДанных.Субъект
		|ГДЕ
		|	СубъектыДляСкрытияПерсональныхДанных.Субъект ЕСТЬ NULL";
		
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "[ПомещениеВоВременнуюТаблицу]",
			?(ВоВременнуюТаблицу И ОсновнаяТаблица, "ПОМЕСТИТЬ ВТСубъектыДляСкрытия", ""));
		
		ОсновнаяТаблица = Ложь;
		
	КонецЦикла;
	
	Возврат ТекстЗапроса;
	
КонецФункции

#КонецОбласти

Процедура УстановитьВидимостьЭлементаФормы(Элемент) Экспорт
	
	РекрутинговыеСайтыФормы.УстановитьВидимостьЭлементаФормы(Элемент);
	
КонецПроцедуры

Функция НавигациннаяСсылкаЭтапаКандидата(ЭтапРаботы) Экспорт
	
	ОбщегоНазначенияКлиентСервер.ПроверитьПараметр("СтрокаНавигационнойСсылкиЭтапаКандидатов", 
		"ЭтапРаботы", ЭтапРаботы, Метаданные.ОпределяемыеТипы.ЭтапРаботыСКандидатами.Тип);
	
	Строка = "ЭтапКандидата";
	Если ТипЗнч(ЭтапРаботы) = Тип("СправочникСсылка.ЭтапыРаботыСКандидатами") Тогда
		Строка = Строка + "_" + Метаданные.Справочники.ЭтапыРаботыСКандидатами.ПолноеИмя();
		Строка = Строка + "_" + ?(ЭтапРаботы.Пустая(), ИдентификаторПустогоЭтапа(), 
			ЭтапРаботы.УникальныйИдентификатор());
	ИначеЕсли ТипЗнч(ЭтапРаботы) = Тип("ПеречислениеСсылка.ЭтапыРаботыСКандидатами") Тогда
		Строка = Строка + "_" + Метаданные.Перечисления.ЭтапыРаботыСКандидатами.ПолноеИмя();
		Строка = Строка + "_" + ?(ЭтапРаботы.Пустая(), ИдентификаторПустогоЭтапа(), 
			ОбщегоНазначения.ИмяЗначенияПеречисления(ЭтапРаботы));
	Иначе
		ОбщегоНазначенияКлиентСервер.Проверить(Ложь, 
			СтрШаблон(НСтр("ru = 'Неожиданное значение этап работы = %1'"), ЭтапРаботы), 
			Метаданные.Справочники.Вакансии.ПолноеИмя());
	КонецЕсли;

	Возврат Строка;
	
КонецФункции

Функция ЭтапКандидатаПоНавигационнойСсылке(НавигационнаяСсылка) Экспорт
	
	Части = СтрРазделить(НавигационнаяСсылка, "_");
	ОбщегоНазначенияКлиентСервер.Проверить(Части.Количество() = 3, 
		СтрШаблон(НСтр("ru = 'Некорректная навигационная ссылка этапа кандидатов %1'"), НавигационнаяСсылка), 
		"ПодборПерсоналаФормы.ЭтапКандидатаПоНавигационнойСсылке");
	
	Если Части[1] = Метаданные.Справочники.ЭтапыРаботыСКандидатами.ПолноеИмя() Тогда
		Возврат ?(Части[2] = ИдентификаторПустогоЭтапа(), 
			Справочники.ЭтапыРаботыСКандидатами.ПустаяСсылка(), 
			Справочники.ЭтапыРаботыСКандидатами.ПолучитьСсылку(Новый УникальныйИдентификатор(Части[2])));
	ИначеЕсли Части[1] = Метаданные.Перечисления.ЭтапыРаботыСКандидатами.ПолноеИмя() Тогда
		Возврат ?(Части[2] = ИдентификаторПустогоЭтапа(), 
			Перечисления.ЭтапыРаботыСКандидатами.ПустаяСсылка(), 
			Перечисления.ЭтапыРаботыСКандидатами[Части[2]]);
	Иначе
		ОбщегоНазначенияКлиентСервер.Проверить(Ложь, 
			СтрШаблон(НСтр("ru = 'Некорректная навигационная ссылка этапа кандидатов %1'"), НавигационнаяСсылка), 
			"ПодборПерсоналаФормы.ЭтапКандидатаПоНавигационнойСсылке");
	КонецЕсли;
	
КонецФункции

Функция ИдентификаторПустогоЭтапа()
	Возврат "ПустаяСсылка";
КонецФункции

Функция СостояниеКандидатаЭтапСсылкаПоНавигационнойСтроке(НавигационнаяСсылкаФорматированнойСтроки) Экспорт

	СтрокаИдентификатора = СтрЗаменить(НавигационнаяСсылкаФорматированнойСтроки, "СостояниеКандидата_Этап_", "");
	Если СтрокаИдентификатора = "ПустаяСсылка" Тогда
		Возврат Справочники.ЭтапыРаботыСКандидатами.ПустаяСсылка();
	КонецЕсли;
	
	Возврат Справочники.ЭтапыРаботыСКандидатами.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаИдентификатора));
	
КонецФункции

Процедура СоздатьКомандуДобавленияНовогоКандидата(Форма, ГруппаКоманд)

	Гиперссылка = Форма.Элементы.Добавить("Кнопка", Тип("КнопкаФормы"), ГруппаКоманд);
	Гиперссылка.Вид = ВидКнопкиФормы.Гиперссылка;
	
	Команда = Форма.Команды.Добавить(ПодборПерсоналаКлиентСервер.ИмяКомандыНовыйКандидатВФормеФизическиеЛица());
	Команда.Заголовок = НСтр("ru = 'Новый кандидат'");
	Команда.Подсказка = НСтр("ru = 'Зарегистрировать обращение этого человека на вакансию'");
	Команда.Действие = "Подключаемый_ПодборПерсонала";
	
	Гиперссылка.ИмяКоманды = "НовыйКандидат";
	Гиперссылка.Заголовок = НСтр("ru = 'Новый кандидат'");
	
КонецПроцедуры

// Возвращает таблицу похожих кандидатов.
// 
// Параметры:
//  ЛичныеДанныеКандидата - Структура:
//   * Ссылка - СправочникСсылка.ЛичныеДанныеКандидатов
//   * Фамилия - Строка
//   * Имя - Строка
//   * Отчество - Строка
//   * УточнениеНаименования - Строка
//   * Телефон - Строка
//   * Email - Строка
//  ИсключитьСвязанныхСФизЛицами - Булево
// 
// Возвращаемое значение:
//  ТаблицаЗначений:
//   * Приоритет - Число
//   * ЛичныеДанныеКандидата - СправочникСсылка.ЛичныеДанныеКандидатов 
//   * Наименование - Строка 
//   * УточнениеНаименования - Строка 
//   * ФИОПолные - Строка 
//   * Фамилия - Строка 
//   * Имя - Строка 
//   * Отчество - Строка 
//   * Телефоны - Строка 
//   * АдресаЭлектроннойПочты - Строка 
//   * ДатаРождения - Дата 
//   * Пол - ПеречислениеСсылка.ПолФизическогоЛица 
//   * ИНН - Строка 
//   * СтраховойНомерПФР - Строка 
//   * МестоРождения - Строка 
//   * ТелефонПредставление - Строка 
//   * EmailПредставление - Строка 
Функция ПохожиеКандидаты(ЛичныеДанныеКандидата, ИсключитьСвязанныхСФизЛицами = Истина)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ЛичныеДанныеКандидатов.Ссылка КАК ЛичныеДанныеКандидата,
		|	1 КАК Приоритет,
		|	ДанныеПоискаФизическихЛиц.Телефоны КАК Телефоны,
		|	ДанныеПоискаФизическихЛиц.АдресаЭлектроннойПочты КАК АдресаЭлектроннойПочты
		|ПОМЕСТИТЬ ВТЛичныеДанныеКандидатов
		|ИЗ
		|	Справочник.ЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеПоискаФизическихЛиц КАК ДанныеПоискаФизическихЛиц
		|		ПО (ДанныеПоискаФизическихЛиц.ФизическоеЛицо = ЛичныеДанныеКандидатов.Ссылка)
		|ГДЕ
		|	&НомерТелефона
		|	И ЛичныеДанныеКандидатов.Ссылка <> &Ссылка
		|	И НЕ ЛичныеДанныеКандидатов.ПометкаУдаления
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЛичныеДанныеКандидатов.Ссылка,
		|	2,
		|	ДанныеПоискаФизическихЛиц.Телефоны,
		|	ДанныеПоискаФизическихЛиц.АдресаЭлектроннойПочты
		|ИЗ
		|	Справочник.ЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеПоискаФизическихЛиц КАК ДанныеПоискаФизическихЛиц
		|		ПО (ДанныеПоискаФизическихЛиц.ФизическоеЛицо = ЛичныеДанныеКандидатов.Ссылка)
		|ГДЕ
		|	&АдресЭП
		|	И ЛичныеДанныеКандидатов.Ссылка <> &Ссылка
		|	И НЕ ЛичныеДанныеКандидатов.ПометкаУдаления
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЛичныеДанныеКандидатов.Ссылка,
		|	3,
		|	"""",
		|	""""
		|ИЗ
		|	Справочник.ЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатов
		|ГДЕ
		|	&ФИО
		|	И ЛичныеДанныеКандидатов.Ссылка <> &Ссылка
		|	И НЕ ЛичныеДанныеКандидатов.ПометкаУдаления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЛичныеДанныеКандидатов.Приоритет КАК Приоритет,
		|	ЛичныеДанныеКандидатов.ЛичныеДанныеКандидата КАК ЛичныеДанныеКандидата,
		|	ЛичныеДанныеКандидатов.Телефоны КАК Телефоны,
		|	ЛичныеДанныеКандидатов.АдресаЭлектроннойПочты КАК АдресаЭлектроннойПочты
		|ИЗ
		|	ВТЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатов
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФизическиеЛицаКандидатов КАК ФизическиеЛицаКандидатов
		|		ПО ФизическиеЛицаКандидатов.ЛичныеДанныеКандидата = ЛичныеДанныеКандидатов.ЛичныеДанныеКандидата
		|		И НЕ ФизическиеЛицаКандидатов.ФизическоеЛицо.ПометкаУдаления
		|ГДЕ
		|	&ФизЛицо";
	
	Фамилия = ФизическиеЛицаЗарплатаКадры.ФамилияДляПоиска(ЛичныеДанныеКандидата.Фамилия);
	Имя = ФизическиеЛицаЗарплатаКадры.ИмяДляПоиска(ЛичныеДанныеКандидата.Имя);
	Отчество = ФизическиеЛицаЗарплатаКадры.ОтчествоДляПоиска(ЛичныеДанныеКандидата.Отчество);
	
	Запрос.УстановитьПараметр("Ссылка", ЛичныеДанныеКандидата.Ссылка);
		
	Если ЗначениеЗаполнено(ЛичныеДанныеКандидата.Телефон) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&НомерТелефона",
			"ДанныеПоискаФизическихЛиц.Телефоны ПОДОБНО &НомерТелефона");
		Запрос.УстановитьПараметр("НомерТелефона",
			"%" + ПоискФизическихЛиц.ТелефонВФорматеПоиска(ЛичныеДанныеКандидата.Телефон) + "%");
	Иначе
		Запрос.УстановитьПараметр("НомерТелефона", Ложь);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЛичныеДанныеКандидата.Email) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&АдресЭП",
			"ДанныеПоискаФизическихЛиц.АдресаЭлектроннойПочты ПОДОБНО &АдресЭП");
		Запрос.УстановитьПараметр("АдресЭП", "%" + ЛичныеДанныеКандидата.Email + "%");
	Иначе
		Запрос.УстановитьПараметр("АдресЭП", Ложь);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Фамилия + Имя + Отчество) Тогда
		УсловиеНаФИО = "
		|	(ЛичныеДанныеКандидатов.НаименованиеСлужебное ПОДОБНО &Фамилия СПЕЦСИМВОЛ ""~""
		|	ИЛИ ЛичныеДанныеКандидатов.НаименованиеСлужебное ПОДОБНО &ФамилияИмя СПЕЦСИМВОЛ ""~""
		|	ИЛИ ЛичныеДанныеКандидатов.НаименованиеСлужебное ПОДОБНО &ФамилияИмяОтчество СПЕЦСИМВОЛ ""~""
		|	ИЛИ ЛичныеДанныеКандидатов.НаименованиеСлужебное ПОДОБНО &ФамилияИмяОтчествоУточнение СПЕЦСИМВОЛ ""~"")";
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ФИО", УсловиеНаФИО);
		
		Запрос.УстановитьПараметр("ФамилияИмяОтчество", Фамилия + ?(ПустаяСтрока(Имя), "", " " + Имя)
			+ ?(ПустаяСтрока(Отчество), "%", " " + Отчество));
		Запрос.УстановитьПараметр("Фамилия", Фамилия);
		Запрос.УстановитьПараметр("ФамилияИмя", Фамилия + ?(ПустаяСтрока(Имя), "", " " + Имя));
		Запрос.УстановитьПараметр("ФамилияИмяОтчествоУточнение", Фамилия + ?(ПустаяСтрока(Имя), "", " " + Имя)
			+ ?(ПустаяСтрока(Отчество), "", " " + Отчество) + ?(ПустаяСтрока(Отчество), "", " "
			+ ЛичныеДанныеКандидата.УточнениеНаименования));
	Иначе
		Запрос.УстановитьПараметр("ФИО", Ложь);
	КонецЕсли;
	
	Если ИсключитьСвязанныхСФизЛицами Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ФизЛицо", "ФизическиеЛицаКандидатов.ФизическоеЛицо ЕСТЬ NULL");
	Иначе
		Запрос.УстановитьПараметр("ФизЛицо", Истина);
	КонецЕсли;
	
	ТаблицаПохожих = Запрос.Выполнить().Выгрузить();
	ТаблицаПохожих.Колонки.Добавить("ТелефонПредставление", Новый ОписаниеТипов("Строка"));
	ТаблицаПохожих.Колонки.Добавить("EmailПредставление", Новый ОписаниеТипов("Строка"));
	Для Каждого СтрокаДанных Из ТаблицаПохожих Цикл
		СтрокаДанных.ТелефонПредставление = УправлениеКонтактнойИнформацией.ПредставлениеКонтактнойИнформацииОбъекта(
			СтрокаДанных.ЛичныеДанныеКандидата, Справочники.ВидыКонтактнойИнформации.ТелефонЛичныеДанныеКандидатов);
		СтрокаДанных.EmailПредставление = УправлениеКонтактнойИнформацией.ПредставлениеКонтактнойИнформацииОбъекта(
			СтрокаДанных.ЛичныеДанныеКандидата, Справочники.ВидыКонтактнойИнформации.EMailЛичныеДанныеКандидатов);
	КонецЦикла;
	ОбщегоНазначенияБЗК.ДобавитьИндексКоллекции(ТаблицаПохожих, "ЛичныеДанныеКандидата");
	
	Возврат ТаблицаПохожих;
	
КонецФункции

Функция СовпадающиеДанныеПоПриоритету()
	
	Результат = Новый Соответствие();
	Результат.Вставить(1, "Телефон");
	Результат.Вставить(2, "E-mail");
	Результат.Вставить(3, "ФИО");
	
	Возврат Результат;
	
КонецФункции

// Представление автора комментария.
// 
// Параметры:
//  АвторКомментария - СправочникСсылка.Пользователи
// 
// Возвращаемое значение:
//  Строка - Представление автора комментария
Функция ПредставлениеАвтораКомментария(АвторКомментария) Экспорт
	
	Если АвторКомментария = Пользователи.СсылкаНеуказанногоПользователя() Тогда
		Возврат Пользователи.ПолноеИмяНеуказанногоПользователя();
	КонецЕсли;
	
	ФизическоеЛицоАвтора = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(АвторКомментария, "ФизическоеЛицо");
	Если Не ЗначениеЗаполнено(ФизическоеЛицоАвтора) Тогда
		Возврат Строка(АвторКомментария);
	КонецЕсли;

	УстановитьПривилегированныйРежим(Истина);
	ФИОАвтора = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ФизическоеЛицоАвтора, "Фамилия, Имя");
	УстановитьПривилегированныйРежим(Ложь);

	Возврат ФИОАвтора.Фамилия + ?(Не ПустаяСтрока(ФИОАвтора.Имя), " " + ФИОАвтора.Имя, "");
	
КонецФункции

// Установить этапы по умолчанию на сервере.
// 
// Параметры:
//  ЭтапыРаботыСКандидатами - ТабличнаяЧасть -
// 
// Возвращаемое значение:
//  Структура -- Установить этапы по умолчанию на сервере::
// * Добавленные - Массив из ПеречислениеСсылка.ЭтапыРаботыСКандидатами -
// * Удаленные - Массив из ПеречислениеСсылка.ЭтапыРаботыСКандидатами -
Функция УстановитьЭтапыПоУмолчанию(ЭтапыРаботыСКандидатами) Экспорт
	Результат = Новый Структура();
	Результат.Вставить("Добавленные", ПодборПерсонала.ДобавитьДействующиеПредопределенныеЭтапы(ЭтапыРаботыСКандидатами));
	Результат.Вставить("Удаленные", ПодборПерсонала.УдалитьНедействующиеПредопределенныеЭтапы(ЭтапыРаботыСКандидатами));
	Возврат Результат;
КонецФункции

#КонецОбласти