// См. ЦентрМониторингаПереопределяемый.ПриСбореПоказателейСтатистикиКонфигурации.
Процедура ПриСбореПоказателейСтатистикиКонфигурации() Экспорт
	
	ИмяКонфигурации = КонфигурацииЗарплатаКадры.КраткоеНазваниеПрограммыСлужебный();
	// АПК:1297-выкл Имя подсистемы для статистики, не локализуется
	ИмяПодсистемы = "Ключевые показатели эффективности";
	// АПК:1297-вкл
	
	ВидСтатистики = СборСтатистики.ВидыСтатистики().Накопительная;
	
	Статистика = Новый Соответствие;
	Статистика.Вставить("Настройки ключевых показателей эффективности", СтатистикаНастроек());
	Статистика.Вставить("Структура целей", СтатистикаСтруктурыЦелей());
	СборСтатистики.ЗаписатьСтатистикуПоОбъектам(ИмяКонфигурации, ИмяПодсистемы, Статистика, ВидСтатистики);
	
	НачалоПериода = СборСтатистики.НачалоПериодаСбораСтатистики();
	ВидСтатистики = СборСтатистики.ВидыСтатистики().Периодическая;
	
	Журнал = Метаданные.ЖурналыДокументов.ПланПоказателейЭффективности;
	СтатистикаПоДокументам = СборСтатистики.СтандартныеПоказателиПоЖурналу(Журнал, НачалоПериода);
	СборСтатистики.ЗаписатьСтатистикуПоОбъектам(ИмяКонфигурации, ИмяПодсистемы, СтатистикаПоДокументам, ВидСтатистики);
	
	Журнал = Метаданные.ЖурналыДокументов.ФактПоказателейЭффективности;
	СтатистикаПоДокументам = СборСтатистики.СтандартныеПоказателиПоЖурналу(Журнал, НачалоПериода);
	СборСтатистики.ЗаписатьСтатистикуПоОбъектам(ИмяКонфигурации, ИмяПодсистемы, СтатистикаПоДокументам, ВидСтатистики);
	
	Статистика = Новый Соответствие;
	Статистика.Вставить("Плановые значения показателей эффективности подразделений", СтатистикаПодразделений(НачалоПериода));
	Статистика.Вставить("Плановые значения показателей эффективности позиций", СтатистикаПозиций(НачалоПериода));
	Статистика.Вставить("Плановые значения показателей эффективности сотрудников", СтатистикаСотрудников(НачалоПериода));
	СборСтатистики.ЗаписатьСтатистикуПоОбъектам(ИмяКонфигурации, ИмяПодсистемы, Статистика, ВидСтатистики);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область СтатистикиКонфигурации

// АПК:1297-выкл Статистика, не локализуется

Функция СтатистикаНастроек()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НастройкиКлючевыхПоказателейЭффективности.ИспользоватьДолгосрочныеГоризонтыОценки КАК ИспользоватьДолгосрочныеГоризонтыОценки,
		|	НастройкиКлючевыхПоказателейЭффективности.ИспользоватьГоризонтКвартал КАК ИспользоватьГоризонтКвартал,
		|	НастройкиКлючевыхПоказателейЭффективности.ИспользоватьГоризонтПолугодие КАК ИспользоватьГоризонтПолугодие,
		|	НастройкиКлючевыхПоказателейЭффективности.ИспользоватьГоризонтГод КАК ИспользоватьГоризонтГод
		|ИЗ
		|	РегистрСведений.НастройкиКлючевыхПоказателейЭффективности КАК НастройкиКлючевыхПоказателейЭффективности";
	
	ТаблицаНастроек = Запрос.Выполнить().Выгрузить();
	
	ПоказателиСтатистики = Новый Соответствие();
	
	Результат = ТаблицаНастроек.ВыгрузитьКолонку("ИспользоватьДолгосрочныеГоризонтыОценки");
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Возврат ПоказателиСтатистики;
	КонецЕсли;
	
	ИспользоватьДолгосрочныеГоризонтыОценки = Число(Результат[0]);
	ПоказателиСтатистики.Вставить("Использовать долгосрочные горизонты оценки", ИспользоватьДолгосрочныеГоризонтыОценки);
	
	Если ИспользоватьДолгосрочныеГоризонтыОценки Тогда
		ИспользоватьГоризонтКвартал = Число(ТаблицаНастроек.ВыгрузитьКолонку("ИспользоватьГоризонтКвартал")[0]);
		ПоказателиСтатистики.Вставить("Использовать горизонт квартал", ИспользоватьГоризонтКвартал);
		
		ИспользоватьГоризонтПолугодие = Число(ТаблицаНастроек.ВыгрузитьКолонку("ИспользоватьГоризонтПолугодие")[0]);
		ПоказателиСтатистики.Вставить("Использовать горизонт полугодие", ИспользоватьГоризонтПолугодие);
		
		ИспользоватьГоризонтГод = Число(ТаблицаНастроек.ВыгрузитьКолонку("ИспользоватьГоризонтГод")[0]);
		ПоказателиСтатистики.Вставить("Использовать горизонт год", ИспользоватьГоризонтГод);
	КонецЕсли;
	
	Возврат ПоказателиСтатистики;
	
КонецФункции

Функция СтатистикаСтруктурыЦелей()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(СтруктураЦелей.Ссылка) КАК Показателей,
		|	СтруктураЦелей.СпособОценки КАК СпособОценки,
		|	СтруктураЦелей.ГраницыШкалы КАК ГраницыШкалы,
		|	СтруктураЦелей.Суммируемый КАК Суммируемый,
		|	СтруктураЦелей.ОбратнаяШкала КАК ОбратнаяШкала
		|ИЗ
		|	Справочник.СтруктураЦелей КАК СтруктураЦелей
		|ГДЕ
		|	СтруктураЦелей.ПометкаУдаления = ЛОЖЬ
		|
		|СГРУППИРОВАТЬ ПО
		|	СтруктураЦелей.СпособОценки,
		|	СтруктураЦелей.ГраницыШкалы,
		|	СтруктураЦелей.Суммируемый,
		|	СтруктураЦелей.ОбратнаяШкала
		|ИТОГИ
		|	СУММА(Показателей)
		|ПО
		|	ОБЩИЕ,
		|	СпособОценки,
		|	ГраницыШкалы,
		|	Суммируемый,
		|	ОбратнаяШкала";
	
	ПоказателиСтатистики = Новый Соответствие;
	ВыборкаВсего = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаВсего.Следующий() Цикл
		
		ПоказателиСтатистики.Вставить("Показателей", ВыборкаВсего.Показателей);
		
		ВыборкаСпособОценки = ВыборкаВсего.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "СпособОценки");
		Пока ВыборкаСпособОценки.Следующий() Цикл
			ПредставлениеПеречисления = Строка(ВыборкаСпособОценки.СпособОценки);
			Если Не ЗначениеЗаполнено(ПредставлениеПеречисления) Тогда
				ПредставлениеПеречисления = "Пустых способов оценки";
			КонецЕсли;
			ПоказателиСтатистики.Вставить(ПредставлениеПеречисления, ВыборкаСпособОценки.Показателей);
		КонецЦикла;
		
		ВыборкаГраницыШкалы = ВыборкаВсего.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ГраницыШкалы");
		Пока ВыборкаГраницыШкалы.Следующий() Цикл
			ПредставлениеПеречисления = Строка(ВыборкаГраницыШкалы.ГраницыШкалы);
			Если Не ЗначениеЗаполнено(ПредставлениеПеречисления) Тогда
				ПредставлениеПеречисления = "Пустых границ шкалы";
			КонецЕсли;
			ПоказателиСтатистики.Вставить(ПредставлениеПеречисления, ВыборкаСпособОценки.Показателей);
		КонецЦикла;
		
		ВыборкаСуммируемый = ВыборкаВсего.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Суммируемый");
		Пока ВыборкаСуммируемый.Следующий() Цикл
			Если ВыборкаСуммируемый.Суммируемый Тогда
				Ключ = "Суммируемых";
			Иначе
				Ключ = "Не суммируемых";
			КонецЕсли;
			ПоказателиСтатистики.Вставить(Ключ, ВыборкаСуммируемый.Показателей);
		КонецЦикла;
		
		ВыборкаОбратнаяШкала = ВыборкаВсего.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ОбратнаяШкала");
		Пока ВыборкаОбратнаяШкала.Следующий() Цикл
			Если ВыборкаОбратнаяШкала.ОбратнаяШкала Тогда
				Ключ = "Обратных шкал";
			Иначе
				Ключ = "Прямых шкал";
			КонецЕсли;
			ПоказателиСтатистики.Вставить(Ключ, ВыборкаОбратнаяШкала.Показателей);
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ПоказателиСтатистики;
	
КонецФункции

Функция СтатистикаПодразделений(НачалоПериода)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", ТекущаяДатаСеанса());
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПлановыеЗначенияПоказателейЭффективностиПодразделений.Подразделение КАК Подразделение,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПлановыеЗначенияПоказателейЭффективностиПодразделений.Показатель) КАК КоличествоПоказателей
		|ИЗ
		|	РегистрСведений.ПлановыеЗначенияПоказателейЭффективностиПодразделений КАК ПлановыеЗначенияПоказателейЭффективностиПодразделений
		|ГДЕ
		|	ПлановыеЗначенияПоказателейЭффективностиПодразделений.ПериодДействия > &НачалоПериода
		|	И ПлановыеЗначенияПоказателейЭффективностиПодразделений.ПериодДействия <= &КонецПериода
		|
		|СГРУППИРОВАТЬ ПО
		|	ПлановыеЗначенияПоказателейЭффективностиПодразделений.Подразделение";
	
	ТаблицаПодразделений = Запрос.Выполнить().Выгрузить();
	
	ПоказателиСтатистики = Новый Соответствие;
	
	КоличествоПодразделений = ТаблицаПодразделений.Количество();
	ПоказателейНаОдноПодразделениеВСреднем =
		?(КоличествоПодразделений > 0, ТаблицаПодразделений.Итог("КоличествоПоказателей") / КоличествоПодразделений, 0);
	
	ПоказателиСтатистики.Вставить("Показателей на одно подразделение в среднем", ПоказателейНаОдноПодразделениеВСреднем);
	
	Возврат ПоказателиСтатистики;
	
КонецФункции

