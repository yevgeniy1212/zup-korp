Функция ПорядокОбложенияДоходовРаботников(Организация, Период) Экспорт
	
	Если Период < Дата(2023, 1, 1) Тогда
		
		Возврат Перечисления.ПорядокОбложенияДоходовРаботников.ПустаяСсылка();
		
	КонецЕсли;
	
	УчетнаяПолитикаНУ = РегистрыСведений.УчетнаяПолитикаПоНалоговомуУчету.СрезПоследних(Период, Новый Структура("Организация", Организация));
	ПорядокОбложенияДоходовРаботников = Перечисления.ПорядокОбложенияДоходовРаботников.ПустаяСсылка();
	Если УчетнаяПолитикаНУ.Количество() > 0 Тогда
		ПорядокОбложенияДоходовРаботников = УчетнаяПолитикаНУ[0].ПорядокОбложенияДоходовРаботников;
	КонецЕсли;
	
	Возврат ПорядокОбложенияДоходовРаботников;
	
КонецФункции

