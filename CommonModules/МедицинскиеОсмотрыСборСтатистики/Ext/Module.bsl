// См. ЦентрМониторингаПереопределяемый.ПриСбореПоказателейСтатистикиКонфигурации.
Процедура ПриСбореПоказателейСтатистикиКонфигурации() Экспорт
	
	ИмяКонфигурации = КонфигурацииЗарплатаКадры.КраткоеНазваниеПрограммыСлужебный();
	// АПК:1297-выкл Имя подсистемы для статистики, не локализуется
	ИмяПодсистемы = "Медицинские осмотры";
	// АПК:1297-вкл
	
	ВидСтатистики = СборСтатистики.ВидыСтатистики().Накопительная;
	
	Статистика = Новый Соответствие;
	Статистика.Вставить("Виды работ медицинских осмотров", СтатистикаВидовРаботМедицинскихОсмотров());
	Статистика.Вставить("Вредные факторы №29н(Виды работ медицинских осмотров)", СтатистикаВредныхФакторов());
	Статистика.Вставить("Виды работ медицинских осмотров рабочего места", СтатистикаВидовРаботМедицинскихОсмотровРабочегоМеста());
	Статистика.Вставить("Вредные факторы и виды работ рабочего места", СтатистикаВредныхФакторовИВидовРаботРабочегоМеста());
	Статистика.Вставить("Вредные факторы рабочего места", СтатистикаВредныхФакторовРабочегоМеста());
	СборСтатистики.ЗаписатьСтатистикуПоОбъектам(ИмяКонфигурации, ИмяПодсистемы, Статистика, ВидСтатистики);
	
	НачалоПериода = СборСтатистики.НачалоПериодаСбораСтатистики();
	ВидСтатистики = СборСтатистики.ВидыСтатистики().Периодическая;
	
	Статистика = Новый Соответствие;
	Статистика.Вставить("Заключение медицинского осмотра", СтатистикаЗаключений(НачалоПериода));
	Статистика.Вставить("Направление на медицинский осмотр", СтатистикаНаправлений(НачалоПериода));
	СборСтатистики.ЗаписатьСтатистикуПоОбъектам(ИмяКонфигурации, ИмяПодсистемы, Статистика, ВидСтатистики);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

