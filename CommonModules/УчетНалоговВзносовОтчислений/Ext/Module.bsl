#Область СлужебныйПрограммныйИнтерфейс

// Функция возвращает таблицу доходов и примененных льгот налогообложения для списка сотрудников
//
Функция СведенияОДоходахПримененныхЛьготах(Сотрудники, Организация, Дата) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НачалоНП",          НачалоГода(Дата));
	Запрос.УстановитьПараметр("КонецНП",           Дата);
	Запрос.УстановитьПараметр("Организация",       Организация);
	Запрос.УстановитьПараметр("СписокСотрудников", Сотрудники);

	Запрос.Текст = "ВЫБРАТЬ
	|	СведенияОДоходахФизическихЛиц.Период КАК МесяцНалоговогоПериода,
	|	СведенияОДоходахФизическихЛиц.ФизическоеЛицо КАК ФизическоеЛицо,
	|	СУММА(СведенияОДоходахФизическихЛиц.СуммаДоходаОборот) КАК СуммаДохода,
	|	0 КАК ПримененнаяЛьгота
	|ПОМЕСТИТЬ ВТДоходыЛьготы
	|ИЗ
	|	РегистрНакопления.СведенияОДоходахФизическихЛиц.Обороты(
	|			&НачалоНП,
	|			&КонецНП,
	|			Месяц,
	|			Организация = &Организация
	|				И ФизическоеЛицо В (&СписокСотрудников)) КАК СведенияОДоходахФизическихЛиц
	|
	|СГРУППИРОВАТЬ ПО
	|	СведенияОДоходахФизическихЛиц.ФизическоеЛицо,
	|	МЕСЯЦ(СведенияОДоходахФизическихЛиц.ПериодРегистрации),
	|	СведенияОДоходахФизическихЛиц.Период
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	СведенияОбИсчисленииНалоговВзносовОтчислений.Период,
	|	СведенияОбИсчисленииНалоговВзносовОтчислений.ФизическоеЛицо,
	|	0,
	|	СУММА(СведенияОбИсчисленииНалоговВзносовОтчислений.ПримененнаяЛьготаОборот)
	|ИЗ
	|	РегистрНакопления.СведенияОбИсчисленииНалоговВзносовОтчислений.Обороты(
	|			&НачалоНП,
	|			&КонецНП,
	|			Месяц,
	|			Организация = &Организация
	|				И ФизическоеЛицо В (&СписокСотрудников)
	|				И ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ИПН)) КАК СведенияОбИсчисленииНалоговВзносовОтчислений
	|
	|СГРУППИРОВАТЬ ПО
	|	СведенияОбИсчисленииНалоговВзносовОтчислений.ФизическоеЛицо,
	|	СведенияОбИсчисленииНалоговВзносовОтчислений.Период
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТДоходыЛьготы.МесяцНалоговогоПериода,
	|	ВТДоходыЛьготы.ФизическоеЛицо,
	|	СУММА(ВТДоходыЛьготы.СуммаДохода) КАК СуммаДохода,
	|	СУММА(ВТДоходыЛьготы.ПримененнаяЛьгота) КАК ПримененнаяЛьгота
	|ИЗ
	|	ВТДоходыЛьготы КАК ВТДоходыЛьготы
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТДоходыЛьготы.МесяцНалоговогоПериода,
	|	ВТДоходыЛьготы.ФизическоеЛицо";
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Процедура УчетнаяПолитикаОрганизацииПриЗаписиУчетОППВПриЗаписи(Источник, Отказ, Замещение) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	УчетнаяПолитикаПоНалоговомуУчету.ПлательщикОППВ
	|ИЗ
	|	РегистрСведений.УчетнаяПолитикаПоНалоговомуУчету КАК УчетнаяПолитикаПоНалоговомуУчету
	|ГДЕ
	|	УчетнаяПолитикаПоНалоговомуУчету.ПлательщикОППВ";
	
	Результат = Запрос.Выполнить();
	
	Константы.ИспользуетсяОППВ.Установить(Не Результат.Пустой());
	
КонецПроцедуры

// Возвращает массив вычетов соответствующего года
//
// Параметры:
//	НалоговыйПериод - число - налоговый период (год).
//
// Возвращаемое значение:
//	Массив значений типа СправочникСсылка.ВидыВычетовНДФЛ
//
Функция ВычетыНалогоплательщика(НалоговыйПериод) Экспорт

	МассивДоступныхВычетов = Новый Массив;
	
	Если НалоговыйПериод >= 2026 Тогда
		МассивДоступныхВычетов.Добавить(Справочники.ВидыВычетовИПН.ВычетСО);
		МассивДоступныхВычетов.Добавить(Справочники.ВидыВычетовИПН.БазовыйНалоговыйВычет);
		МассивДоступныхВычетов.Добавить(Справочники.ВидыВычетовИПН.СоциальныйНалоговыйВычетРодители);
		МассивДоступныхВычетов.Добавить(Справочники.ВидыВычетовИПН.СоциальныйНалоговыйВычет1_2Группа);
		МассивДоступныхВычетов.Добавить(Справочники.ВидыВычетовИПН.СоциальныйНалоговыйВычет3Группа);
	КонецЕсли;
	
	Если НалоговыйПериод = 2025 Тогда
		МассивДоступныхВычетов.Добавить(Справочники.ВидыВычетовИПН.ВычетСО);
		МассивДоступныхВычетов.Добавить(Справочники.ВидыВычетовИПН.ВычетДляМногодетнойСемьиДляОдногоИзРодителей);
		МассивДоступныхВычетов.Добавить(Справочники.ВидыВычетовИПН.ВычетДляМногодетнойСемьиДляКаждогоРодителя);
		МассивДоступныхВычетов.Добавить(Справочники.ВидыВычетовИПН.ПредварительнаяСуммаНалоговыхВычетов);
	КонецЕсли;
	
	Если НалоговыйПериод < 2026 Тогда
		МассивДоступныхВычетов.Добавить(Справочники.ВидыВычетовИПН.Стандартный1МЗП);
		МассивДоступныхВычетов.Добавить(Справочники.ВидыВычетовИПН.Стандартный75МЗПИнвалиды);
		МассивДоступныхВычетов.Добавить(Справочники.ВидыВычетовИПН.Стандартный75МЗПРодители);
	КонецЕсли;
		
	Если НалоговыйПериод < 2025 Тогда
		МассивДоступныхВычетов.Добавить(Справочники.ВидыВычетовИПН.ДобровольныеПенсионныеВзносы);
		МассивДоступныхВычетов.Добавить(Справочники.ВидыВычетовИПН.ВознагражденияПоЖилищнымЗаймам);
		МассивДоступныхВычетов.Добавить(Справочники.ВидыВычетовИПН.НаОплатуМедицинскихУслуг);
	КонецЕсли;
	
	МассивДоступныхВычетов.Добавить(Справочники.ВидыВычетовИПН.ВычетОПВ);
	МассивДоступныхВычетов.Добавить(Справочники.ВидыВычетовИПН.ВычетВОСМС);

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылки", МассивДоступныхВычетов);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВидыВычетовИПН.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыВычетовИПН КАК ВидыВычетовИПН
	|ГДЕ
	|	(НЕ ВидыВычетовИПН.Предопределенный
	|				И НЕ ВидыВычетовИПН.НеИспользуется
	|			ИЛИ ВидыВычетовИПН.Ссылка В (&Ссылки))";
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

// Возвращает массив вычетов соответствующего года
//
// Параметры:
//	НалоговыйПериод - число - налоговый период (год).
//
// Возвращаемое значение:
//	Массив значений типа СправочникСсылка.ВидыВычетовНДФЛ
//
Функция ТаблицаПределовДляНалоговыхБаз() Экспорт

	ТаблицаПределовДляНалоговыхБаз = Новый ТаблицаЗначений;
	ТаблицаПределовДляНалоговыхБаз.Колонки.Добавить("НалоговыйПериод", Новый ОписаниеТипов("Дата"));
	ТаблицаПределовДляНалоговыхБаз.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	ТаблицаПределовДляНалоговыхБаз.Колонки.Добавить("Предел", Новый ОписаниеТипов("Число"));
	ТаблицаПределовДляНалоговыхБаз.Колонки.Добавить("ПределНерезидента", Новый ОписаниеТипов("Число"));
	
	ЗаполнитьЗначенияСвойств(ТаблицаПределовДляНалоговыхБаз.Добавить(), Новый Структура("НалоговыйПериод, ВидДохода, Предел, ПределНерезидента", '20260101', Справочники.ВидыДоходов.ДоходыОтРаботодателя, 8500, 8500));
	ЗаполнитьЗначенияСвойств(ТаблицаПределовДляНалоговыхБаз.Добавить(), Новый Структура("НалоговыйПериод, ВидДохода, Предел, ПределНерезидента", '20260101', Справочники.ВидыДоходов.ДоходыОтНалоговогоАгента, 8500, 0));
	ЗаполнитьЗначенияСвойств(ТаблицаПределовДляНалоговыхБаз.Добавить(), Новый Структура("НалоговыйПериод, ВидДохода, Предел, ПределНерезидента", '20260101', Справочники.ВидыДоходов.Дивиденды, 230000, 230000));
	ЗаполнитьЗначенияСвойств(ТаблицаПределовДляНалоговыхБаз.Добавить(), Новый Структура("НалоговыйПериод, ВидДохода, Предел, ПределНерезидента", '20260101', Справочники.ВидыДоходов.Выигрыши, 8500, 0));
	ЗаполнитьЗначенияСвойств(ТаблицаПределовДляНалоговыхБаз.Добавить(), Новый Структура("НалоговыйПериод, ВидДохода, Предел, ПределНерезидента", '20260101', Справочники.ВидыДоходов.Вознаграждения, 8500, 0));
	ЗаполнитьЗначенияСвойств(ТаблицаПределовДляНалоговыхБаз.Добавить(), Новый Структура("НалоговыйПериод, ВидДохода, Предел, ПределНерезидента", '20260101', Справочники.ВидыДоходов.ПрочиеДоходы, 8500));
	
	Возврат ТаблицаПределовДляНалоговыхБаз;
	
КонецФункции

////////////////////////////////////////////////////////////////////////////////
// ПРОВЕДЕНИЕ И ФОРМИРОВАНИЕ ДВИЖЕНИЙ
////////////////////////////////////////////////////////////////////////////////

// Формирует движения по регистрам подсистемы.
// Параметры:
//		Движения - коллекция движений регистратора.
//		Отказ - признак отказа от заполнения движений.
//		ДанныеДокумента - Таблица значений с колонками
//			МесяцРегистрации
//			ФизическоеЛицо
//			Организация
//			ИзменитьСтандартныйВычет
//			ПредоставлятьСтандартныйВычет
//			ИзменитьЛьготу
//			ПредоставлятьЛьготу
//			КатегорияЛицаПолучателяЛьготы
//			ДействуетДо
//			ДокументПодтверждающийПравоНаЛьготу
//			ИзменитьПрочиеВычеты
//			ПрочиеВычеты: таблица значений, соответствующая по структуре регистру ПрочиеВычетыФизическихЛицИПН
//			ВидВычетаИПН
//			Размер
//			ДействуетДо
//			ДокументПодтверждающийПравоНаВычет.
//		Записывать - Булево - признак того, надо ли записывать движения сразу, или они будут записаны позже.
//
Процедура СформироватьПрименениеСтандартныхВычетов(Движения, 
	Отказ, ДанныеДокумента, Записывать = Ложь, ЗаполнятьДополнительныеДанные = Истина) Экспорт
	
	Если ДанныеДокумента = Неопределено Тогда
		Возврат
	КонецЕсли;
	
	//Проверка схемы проведения по регистрам после 01 января 2018 года.
	Если ДанныеДокумента.Свойство("НаличиеЗаявления")
			И НЕ ДанныеДокумента.НаличиеЗаявления
			И ДанныеДокумента.МесяцРегистрации >= '2018-01-01' Тогда
		Возврат;
	КонецЕсли;
	
	ЗаписьОПримененииВычета						= Движения.ПрименениеВычетовИПН.Добавить();
	ЗаписьОПримененииВычета.Период				= ДанныеДокумента.МесяцРегистрации;
	ЗаписьОПримененииВычета.ФизическоеЛицо		= ДанныеДокумента.ФизическоеЛицо;
	ЗаписьОПримененииВычета.Организация			= ДанныеДокумента.Организация;
	Если Записывать Тогда
		Движения.ПрименениеВычетовИПН.Записать();
		Движения.ПрименениеВычетовИПН.Записывать = Ложь;
	Иначе
		Движения.ПрименениеВычетовИПН.Записывать = Истина;
	КонецЕсли;

	//Схема проведения по регистрам до 01 января 2018 года.
	Если ДанныеДокумента.МесяцРегистрации < '2018-01-01' Тогда
		
		Если ДанныеДокумента.ИзменитьПрочиеВычеты Тогда
			Для Каждого ПрочийВычет Из ДанныеДокумента.ПрочиеВычеты Цикл
				ЗаписьПрочийВычет								= Движения.ПрочиеВычетыФизическихЛицИПН.Добавить();
				ЗаписьПрочийВычет.Период						= ПрочийВычет.МесяцРегистрации;
				ЗаписьПрочийВычет.ДействуетС					= ПрочийВычет.ДействуетС;
				ЗаписьПрочийВычет.ФизическоеЛицо				= ПрочийВычет.ФизическоеЛицо;
				ЗаписьПрочийВычет.ВидВычета						= ПрочийВычет.ВидВычета;
				
				Если ЗаполнятьДополнительныеДанные Тогда
					ЗаписьПрочийВычет.ДействуетПо					= ПрочийВычет.ДействуетПо;
					ЗаписьПрочийВычет.Размер						= ПрочийВычет.Размер;
					ЗаписьПрочийВычет.Основание						= ПрочийВычет.ДокументПодтверждающийПравоНаВычет;
				КонецЕсли;
			КонецЦикла;
			
			Если Записывать Тогда
				Движения.ПрочиеВычетыФизическихЛицИПН.Записать();
				Движения.ПрочиеВычетыФизическихЛицИПН.Записывать = Ложь;
			Иначе
				Движения.ПрочиеВычетыФизическихЛицИПН.Записывать = Истина;
			КонецЕсли;
		КонецЕсли;
		
		Если ДанныеДокумента.ИзменитьСтандартныйВычет Тогда
			ЗаписьОСтандартномВычете					= Движения.ВычетыФизическихЛицИПН.Добавить();
			ЗаписьОСтандартномВычете.Период				= ДанныеДокумента.МесяцРегистрации;
			ЗаписьОСтандартномВычете.ФизическоеЛицо		= ДанныеДокумента.ФизическоеЛицо;
			Если ЗаполнятьДополнительныеДанные Тогда
				ЗаписьОСтандартномВычете.ПредоставлятьВычет	= ДанныеДокумента.ПредоставлятьСтандартныйВычет;
			КонецЕсли;
			Если Записывать Тогда
				Движения.ВычетыФизическихЛицИПН.Записать();
				Движения.ВычетыФизическихЛицИПН.Записывать = Ложь;
			Иначе
				Движения.ВычетыФизическихЛицИПН.Записывать = Истина;
			КонецЕсли;
		КонецЕсли;
		
		Если ДанныеДокумента.ИзменитьЛьготу Тогда
			ЗаписьОЛьготе								= Движения.ЛьготыФизическихЛицИПН.Добавить();
			ЗаписьОЛьготе.Период						= ДанныеДокумента.МесяцРегистрации;
			ЗаписьОЛьготе.ФизическоеЛицо				= ДанныеДокумента.ФизическоеЛицо;
			
			Если ЗаполнятьДополнительныеДанные Тогда
				ЗаписьОЛьготе.ПредоставлятьЛьготу			= ДанныеДокумента.ПредоставлятьЛьготу;
				ЗаписьОЛьготе.ДействуетДо					= ДанныеДокумента.ДействуетДо;
				ЗаписьОЛьготе.КатегорияЛицаПолучателяЛьготы	= ДанныеДокумента.КатегорияЛицаПолучателяЛьготы;
				ЗаписьОЛьготе.Основание						= ДанныеДокумента.ДокументПодтверждающийПравоНаЛьготу;
			КонецЕсли;
			Если Записывать Тогда
				Движения.ЛьготыФизическихЛицИПН.Записать();
				Движения.ЛьготыФизическихЛицИПН.Записывать = Ложь;
			Иначе
				Движения.ЛьготыФизическихЛицИПН.Записывать = Истина;
			КонецЕсли;
		КонецЕсли;
		
	//Схема проведения по регистрам после 01 января 2018 года.
	Иначе
		
		Для Каждого Вычет Из ДанныеДокумента.Вычеты Цикл
			ЗаписьВычет								= Движения.ВычетыФизическихЛицИПН.Добавить();
			ЗаписьВычет.Период						= Вычет.МесяцРегистрации;
			ЗаписьВычет.ФизическоеЛицо				= Вычет.ФизическоеЛицо;
			ЗаписьВычет.ВидВычета					= Вычет.ВидВычета;
			ЗаписьВычет.ПредоставлятьВычет			= Вычет.ПредоставлятьВычет;
			
			Если ЗаполнятьДополнительныеДанные Тогда
				ЗаписьВычет.ДействуетПо				= Вычет.ДействуетПо;
			КонецЕсли;
		КонецЦикла;
		
		Если Записывать Тогда
			Движения.ВычетыФизическихЛицИПН.Записать();
			Движения.ВычетыФизическихЛицИПН.Записывать = Ложь;
		Иначе
			Движения.ВычетыФизическихЛицИПН.Записывать = Истина;
		КонецЕсли;
		
		Для Каждого ПрочийВычет Из ДанныеДокумента.ПрочиеВычеты Цикл
			ЗаписьПрочийВычет								= Движения.ПрочиеВычетыФизическихЛицИПН.Добавить();
			ЗаписьПрочийВычет.Период						= ДанныеДокумента.МесяцРегистрации;
			ЗаписьПрочийВычет.ФизическоеЛицо				= ПрочийВычет.ФизическоеЛицо;
			ЗаписьПрочийВычет.ВидВычета						= ПрочийВычет.ВидВычета;
			ЗаписьПрочийВычет.ДействуетС					= ПрочийВычет.ДействуетС;
			ЗаписьПрочийВычет.Размер						= ПрочийВычет.Размер;
			
			Если ЗаполнятьДополнительныеДанные Тогда
				ЗаписьПрочийВычет.ДействуетПо					= ПрочийВычет.ДействуетПо;
				ЗаписьПрочийВычет.Основание						= ПрочийВычет.ДокументПодтверждающийПравоНаВычет;
			КонецЕсли;
		КонецЦикла;
		
		Если Записывать Тогда
			Движения.ПрочиеВычетыФизическихЛицИПН.Записать();
			Движения.ПрочиеВычетыФизическихЛицИПН.Записывать = Ложь;
		Иначе
			Движения.ПрочиеВычетыФизическихЛицИПН.Записывать = Истина;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

// Формирует движения по налогам, взносам и отчислениям.
//
// Параметры:
//		Регистратор - ДокументСсылка -
//		Движения - коллекция движений регистратора.
//		Отказ - булево - признак отказа от заполнения движений.
//		Организация - СправочникСсылка.Организации -
//		ПериодРегистрации - реквизиты регистратора.
//		ПорядокВыплаты - ПеречислениеСсылка.ХарактерВыплатыЗарплаты - Межрасчет / Зарплата / Аванс
//		ДанныеДляПроведения - структура - структура данных, используемая при проведении документов
//				обязательные поля
//					МенеджерВременныхТаблиц с вр.таблицами ВТНачисления, ВТФизическиеЛица.
//					НалогиВзносыОтчисления - таблица значений с данными об исчисленных налогах, взносах и отчислениях.
//					УдержанияПоСотрудникам - таблица значений с данными о суммах удержаний.
//		Записывать - булево - признак того, надо ли записывать движения сразу, или они будут записаны позже.
//		РегистрироватьСуммыНалоговВзносов - булево - признак того, надо ли писать движения по исчисленным налогам,
//					если не указан будет определяться по значению параметра ПорядокВыплаты: истине соответствует Межрасчет.
//
Процедура ЗарегистрироватьДоходыИСуммыНалоговВзносовОтчисленийПоВременнойТаблицеНачислений(Движения, Отказ, Организация, ПериодРегистрации, ПорядокВыплаты, ДанныеДляПроведения, Записывать = Ложь, РегистрироватьСуммыНалоговВзносов = Неопределено, ЕстьРеквизитИсправленныйДокумент = Ложь, ЕстьРеквизитМесяцНачисления = Ложь) Экспорт 
	
	Если РегистрироватьСуммыНалоговВзносов = Неопределено Тогда 
		РегистрироватьСуммыНалоговВзносов = РасчетЗарплатыРасширенный.ЭтоМежрасчетнаяВыплата(ПорядокВыплаты);
	КонецЕсли;
	
	// регистрация доходов
	СформироватьСведенияОДоходахПоНачислениям(Движения, Отказ, Организация, ДанныеДляПроведения.МенеджерВременныхТаблиц, ПериодРегистрации, Записывать, Не РегистрироватьСуммыНалоговВзносов,, ЕстьРеквизитИсправленныйДокумент, ЕстьРеквизитМесяцНачисления);
	
	Если РегистрироватьСуммыНалоговВзносов Тогда
		
		// Сведения о необлагаемых доходах физических лиц
		СформироватьСведенияОНеоблагаемыхДоходахПоНачислениям(ДанныеДляПроведения, Движения, Отказ, Организация, Записывать, Не РегистрироватьСуммыНалоговВзносов);
		
		// Сведения об исчислении налогов взносов отчислений
		СформироватьСведенияОбИсчисленииНалоговВзносовОтчислений(ДанныеДляПроведения, Движения, Отказ, Организация, ПериодРегистрации, Не РегистрироватьСуммыНалоговВзносов);
		
		// Сведения об исчислении вычетов ИПН
		СформироватьСведенияОбИсчисленииВычетовИПН(ДанныеДляПроведения, Движения, Отказ, Организация, ПериодРегистрации, Не РегистрироватьСуммыНалоговВзносов);
		
		// Учет исчисленных налогов, взносов, отчислений
		СформироватьНалогиВзносыОтчисленияРасчетыСБюджетом(ДанныеДляПроведения, Движения, Отказ, Организация, ПериодРегистрации);
		
		СформироватьНалогиВзносыРасчетыНалогоплательщиков(ДанныеДляПроведения, Движения, Отказ, Организация, ПериодРегистрации);
		
		ЗарегистрироватьНалогиВзносыОтчисления(Движения, Отказ, Организация, ПериодРегистрации, ДанныеДляПроведения.НалогиВзносыОтчисления, ДанныеДляПроведения.МенеджерВременныхТаблиц, ПорядокВыплаты);
		
		РеквизитыДляПроведения = Новый Структура("Организация, МесяцНачисления,Ссылка", Организация, ПериодРегистрации, );
		ЗарегистрироватьЕдиныйПлатеж(Движения, Отказ, РеквизитыДляПроведения, ДанныеДляПроведения, ДанныеДляПроведения.МенеджерВременныхТаблиц, ПорядокВыплаты);

	КонецЕсли;
	
КонецПроцедуры

// Формирует движения по регистрам подсистемы.
// Параметры:
//		Движения - коллекция движений регистратора.
//		Отказ - булево - признак отказа от заполнения движений.
//		Организация
//		МесяцНачисления - дата - период, в котором зарегистрированы начисления.
//		СведенияОДоходах - Таблица значений с колонками
//			ФизическоеЛицо, с непустым значением
//			Сотрудник
//         	МесяцНалоговогоПериода, с непустым значением
//			Подразделение, тип СправочникСсылка.ПодразделенияОрганизаций
//			Начисление, с непустым значением
//			СуммаДохода
//		Записывать - булево - признак того, надо ли записывать движения сразу, или они будут записаны позже.
//
Процедура СформироватьСведенияОДоходах(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты = Истина, НаборыЗаписей = Неопределено) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	// Метаданные документа используем для обращения к таблице.
	МетаданныеДокумента = Метаданные.НайтиПоТипу(ТипЗнч(ДокументСсылка));

	// Для формирования доходов создаем коллекцию наборов записей.
	Если НаборыЗаписей = Неопределено Тогда 
		НаборыЗаписей = ЗарплатаКадры.НаборыЗаписейРегистратора(МетаданныеДокумента);
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Если ВТСуществует(МенеджерВременныхТаблиц,"ВТНачисления") Тогда
		
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	Начисления.Сотрудник.ФизическоеЛицо КАК ФизическоеЛицо,
		|	СУММА(Начисления.СуммаДохода) КАК СуммаДохода,
		|	Начисления.Подразделение,
		|	Начисления.Сотрудник,
		|	Начисления.Начисление,
		|	Начисления.ИсправленныйДокумент,
		|	Начисления.СторнируемыйДокумент
		|ПОМЕСТИТЬ ВТНачисленияСведенияОДоходах
		|ИЗ
		|	ВТНачисления КАК Начисления
		|ГДЕ
		|	Начисления.СуммаДохода <> 0
		|
		|СГРУППИРОВАТЬ ПО
		|	Начисления.Сотрудник.ФизическоеЛицо,
		|	Начисления.Подразделение,
		|	Начисления.Сотрудник,
		|	Начисления.Начисление,
		|	Начисления.ИсправленныйДокумент,
		|	Начисления.СторнируемыйДокумент";
		
		Запрос = Новый Запрос(ТекстЗапроса);
		Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
		Запрос.Выполнить();
		СформироватьСведенияОДоходахПоНачислениям(
			НаборыЗаписей, Ложь, Организация, МенеджерВременныхТаблиц, МесяцНачисления, Ложь, ОкончательныйРасчетЗарплаты, "ВТНачисленияСведенияОДоходах", МетаданныеДокумента.Реквизиты.Найти("ИсправленныйДокумент") <> Неопределено, МетаданныеДокумента.Реквизиты.Найти("МесяцНачисления") <> Неопределено);
			
		УничтожитьВТ.Добавить("ВТНачисленияСведенияОДоходах");
	КонецЕсли;
	
	// Формируем доходы по начислениям по договорам.
	Если ВТСуществует(МенеджерВременныхТаблиц,"ВТНачисленияПоДоговорам") Тогда
		
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	НачисленияПоДоговорам.ФизическоеЛицо КАК ФизическоеЛицо,
		|	СУММА(НачисленияПоДоговорам.Сумма) КАК СуммаДохода,
		|	НачисленияПоДоговорам.Подразделение,
		|	НачисленияПоДоговорам.Сотрудник,
		|	НачисленияПоДоговорам.ВидДохода КАК Начисление
		|ПОМЕСТИТЬ ВТНачисленияПоДоговорамСведенияОДоходах
		|ИЗ
		|	ВТНачисленияПоДоговорам КАК НачисленияПоДоговорам
		|ГДЕ
		|	НачисленияПоДоговорам.Сумма <> 0
		|
		|СГРУППИРОВАТЬ ПО
		|	НачисленияПоДоговорам.ФизическоеЛицо,
		|	НачисленияПоДоговорам.Подразделение,
		|	НачисленияПоДоговорам.Сотрудник,
		|	НачисленияПоДоговорам.ВидДохода
		|";
	
		Запрос = Новый Запрос(ТекстЗапроса);
		Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
		Запрос.Выполнить();
		
		СформироватьСведенияОДоходахПоНачислениям(
			НаборыЗаписей, Ложь, Организация, МенеджерВременныхТаблиц, МесяцНачисления, Ложь, ОкончательныйРасчетЗарплаты, "ВТНачисленияПоДоговорамСведенияОДоходах");
			
		УничтожитьВТ.Добавить("ВТНачисленияПоДоговорамСведенияОДоходах");
	КонецЕсли;
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
КонецПроцедуры

Процедура СформироватьСведенияОДоходахПоНачислениям(Движения, Отказ, Организация, МенеджерВременныхТаблиц, МесяцНачисления, Записывать = Ложь, ОкончательныйРасчет = Истина, ИмяВТНачисления = "ВТНачисления", ЕстьРеквизитИсправленныйДокумент = Ложь, ЕстьРеквизитМесяцНачисления = Ложь, ЕстьРеквизитФизическоеЛицо = Ложь) Экспорт
	
	ДатаКорректировкиВеденияУчетаПоДаннымНВО = Константы.ДатаКорректировкиВеденияУчетаПоДаннымНВО.Получить();
	Если МесяцНачисления >= НачалоМесяца(ДатаКорректировкиВеденияУчетаПоДаннымНВО)
		И ИмяВТНачисления = "ВТНачисления" Тогда
		ПолеДатаНачала = "ВЫБОР
		|		КОГДА НачислениеСсылка.КатегорияНачисленияИлиНеоплаченногоВремени = ЗНАЧЕНИЕ(Перечисление.КатегорииНачисленийИНеоплаченногоВремени.ОплатаПоДоговорамПодряда)
		// в регистре НачисленияУдержанияПоКонтрагентамАкционерам нет даты начала
		|			ТОГДА НАЧАЛОПЕРИОДА(Начисления.ДатаНачала, МЕСЯЦ)
		|		ИНАЧЕ Начисления.ДатаНачала
		|	КОНЕЦ КАК ДатаНачала,";
		ПолеДатаНачалаГруппировка = СтрЗаменить(ПолеДатаНачала, " КАК ДатаНачала", "");
		СоединениеПВРНачисления = "ЛЕВОЕ СОЕДИНЕНИЕ ПланВидовРасчета.Начисления КАК НачислениеСсылка
		|		ПО НачислениеСсылка.Ссылка = Начисления.Начисление";
	ИначеЕсли МесяцНачисления >= НачалоМесяца(ДатаКорректировкиВеденияУчетаПоДаннымНВО) Тогда
		ПолеДатаНачала = "&МесяцНачисления КАК ДатаНачала,";
		ПолеДатаНачалаГруппировка = "";
		СоединениеПВРНачисления = "";
	Иначе
		ПолеДатаНачала = "ДАТАВРЕМЯ(1,1,1) КАК ДатаНачала,";
		ПолеДатаНачалаГруппировка = "";
		СоединениеПВРНачисления = "";
	КонецЕсли;
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	Начисления.Сотрудник.ФизическоеЛицо КАК ФизическоеЛицо,
		|	СУММА(Начисления.СуммаДохода) КАК СуммаДохода,
		|	Начисления.Подразделение КАК Подразделение,
		|	ИсторияРегистрацийВНалоговомОрганеСрезПоследних.РегистрацияВНалоговомОргане КАК РегистрацияВНалоговомОргане,
		|	Начисления.Сотрудник,
		|	Начисления.Начисление,
		|	" + ПолеДатаНачала + "
		|	&МесяцНачисления КАК ПериодРегистрации,
		|	&МесяцНалоговогоПериода КАК МесяцНалоговогоПериода
		|ИЗ
		|	#ИмяВТНачисления КАК Начисления
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИсторияРегистрацийВНалоговомОргане.СрезПоследних(
		|				&КонецМесяцаНачисления,
		|				СтруктурнаяЕдиница В
		|					(ВЫБРАТЬ
		|						Начисления.Подразделение
		|					ИЗ
		|						#ИмяВТНачисления КАК Начисления)) КАК ИсторияРегистрацийВНалоговомОрганеСрезПоследних
		|		ПО Начисления.Подразделение = ИсторияРегистрацийВНалоговомОрганеСрезПоследних.СтруктурнаяЕдиница
		|		" + СоединениеПВРНачисления + "
		|ГДЕ
		|	Начисления.СуммаДохода <> 0
		|
		|СГРУППИРОВАТЬ ПО
		|	Начисления.Подразделение,
		|	ИсторияРегистрацийВНалоговомОрганеСрезПоследних.РегистрацияВНалоговомОргане,
		|	Начисления.Сотрудник,
		|	Начисления.Начисление,
		|	" + ПолеДатаНачалаГруппировка + "
		|	Начисления.Сотрудник.ФизическоеЛицо
		|
		|УПОРЯДОЧИТЬ ПО
		|	ФизическоеЛицо";
		
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "#ИмяВТНачисления", ИмяВТНачисления);		
	Если ЕстьРеквизитФизическоеЛицо Тогда 
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Начисления.Сотрудник.ФизическоеЛицо", "Начисления.ФизическоеЛицо");
	КонецЕсли;
	
	Если ЕстьРеквизитИсправленныйДокумент Тогда
		// При внесении исправлений корректировки относим на месяц налогового периода по документу-исправлению
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&МесяцНалоговогоПериода КАК", 
			"ВЫБОР
			|		КОГДА НЕ Начисления.ИсправленныйДокумент.ПериодРегистрации ЕСТЬ NULL
			|			ТОГДА Начисления.ИсправленныйДокумент.ПериодРегистрации
			|		КОГДА НЕ Начисления.СторнируемыйДокумент.ПериодРегистрации ЕСТЬ NULL
			|			ТОГДА Начисления.СторнируемыйДокумент.ПериодРегистрации
			|		ИНАЧЕ &МесяцНалоговогоПериода
			|	КОНЕЦ КАК");
			
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "УПОРЯДОЧИТЬ ПО", ",
			|ВЫБОР
			|		КОГДА НЕ Начисления.ИсправленныйДокумент.ПериодРегистрации ЕСТЬ NULL
			|			ТОГДА Начисления.ИсправленныйДокумент.ПериодРегистрации
			|		КОГДА НЕ Начисления.СторнируемыйДокумент.ПериодРегистрации ЕСТЬ NULL
			|			ТОГДА Начисления.СторнируемыйДокумент.ПериодРегистрации
			|		ИНАЧЕ &МесяцНалоговогоПериода
			|	КОНЕЦ
			|
			|УПОРЯДОЧИТЬ ПО");
			
		Если ЕстьРеквизитМесяцНачисления Тогда
			ТекстЗапроса = СтрЗаменить(ТекстЗапроса, ".ПериодРегистрации", ".МесяцНачисления");
		КонецЕсли;
		
	КонецЕсли;

	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("МесяцНачисления", НачалоМесяца(МесяцНачисления));
	Запрос.УстановитьПараметр("МесяцНалоговогоПериода", НачалоМесяца(МесяцНачисления));
	Запрос.УстановитьПараметр("КонецМесяцаНачисления", КонецМесяца(МесяцНачисления));
	
	РегистрацияОрганизации = ?(ЗначениеЗаполнено(Организация),ЗарплатаКадры.РегистрацияВНалоговомОргане(Организация, КонецМесяца(МесяцНачисления)),Справочники.РегистрацииВНалоговомОргане.ПустаяСсылка());
	
	Выборка = Запрос.Выполнить().Выбрать();
		
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = СтрокаСведенийОДоходах(Движения.СведенияОДоходахФизическихЛиц, Организация, МесяцНачисления, Выборка, ОкончательныйРасчет);
		ПроставитьРегистрациюВНалоговомОрганеВСтроке(НоваяСтрока, Выборка.РегистрацияВНалоговомОргане, РегистрацияОрганизации);
	КонецЦикла;
	
	Если Записывать Тогда
		// Записываем сразу и не выставляем признак Записывать этому набору записей движений документа.
		УстановитьПривилегированныйРежим(Истина);
		Движения.СведенияОДоходахФизическихЛиц.Записать();
		Движения.СведенияОДоходахФизическихЛиц.Записывать = Ложь;
	Иначе
		Движения.СведенияОДоходахФизическихЛиц.Записывать = Истина;
	КонецЕсли;

КонецПроцедуры

Процедура СформироватьСведенияОНеоблагаемыхДоходахПоНачислениям(ДанныеДляПроведения, Движения, Отказ, Организация, Записывать = Ложь, ОкончательныйРасчет = Истина) Экспорт
	
	Для Каждого СтрокаНеоблагаемыхДоходов Из ДанныеДляПроведения.ДоходыНеПодлежащиеНалогообложению Цикл
		НоваяСтрока =  Движения.СведенияОНеоблагаемыхДоходахФизическихЛиц.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаНеоблагаемыхДоходов);
		НоваяСтрока.ДанныеМежрасчетногоПериода = Не ОкончательныйРасчет;		
	КонецЦикла;
	
	Если Записывать Тогда
		УстановитьПривилегированныйРежим(Истина);
		Движения.СведенияОНеоблагаемыхДоходахФизическихЛиц.Записать();
		Движения.СведенияОНеоблагаемыхДоходахФизическихЛиц.Записывать = Ложь;
	Иначе
		Движения.СведенияОНеоблагаемыхДоходахФизическихЛиц.Записывать = Истина;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьДанныеДляПроведенияПоНалогамВзносамОтчислениям(ДанныеДляПроведения, ДокументСсылка, ИмяПоляМесяц = "Ссылка.МесяцНачисления") Экспорт
	
	ТекстЗапроса = 
		"ВЫБРАТЬ
		|	НалогиВзносыОтчисления.Ссылка КАК ДокументСсылка,
		|	НалогиВзносыОтчисления.НомерСтроки КАК НомерСтроки,
		|	НалогиВзносыОтчисления.ФизическоеЛицо КАК ФизическоеЛицо,
		|	НалогиВзносыОтчисления.Подразделение КАК Подразделение,
		|	НалогиВзносыОтчисления.ВидДохода КАК ВидДохода,
		|	НалогиВзносыОтчисления.Ссылка.Организация КАК Организация,
		|	НалогиВзносыОтчисления.Ссылка.МесяцНачисления КАК ПериодРегистрации,
		|	НалогиВзносыОтчисления.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	НалогиВзносыОтчисления.МесяцНалоговогоПериода КАК ДатаНачала,
		|	ВЫБОР
		|		КОГДА ТИПЗНАЧЕНИЯ(НалогиВзносыОтчисления.Ссылка) В (ТИП(Документ.НачислениеПоДоговорам),
		|			ТИП(Документ.ВыплатаБывшимСотрудникам),
		|			ТИП(Документ.РегистрацияПрочихДоходов))
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ДанныеМежрасчетногоПериода,
		|	НалогиВзносыОтчисления.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления,
		|	СУММА(НалогиВзносыОтчисления.НалогВзнос) КАК НалогВзнос,
		|	СУММА(НалогиВзносыОтчисления.НалогВзносСПревышения) КАК НалогВзносСПревышения,
		|	СУММА(НалогиВзносыОтчисления.ОбъектИсчисления) КАК ОбъектИсчисления,
		|	СУММА(НалогиВзносыОтчисления.РазрешенныйВычет) КАК РазрешенныйВычет,
		|	СУММА(НалогиВзносыОтчисления.ПримененныйВычет) КАК ПримененныйВычет,
		|	СУММА(НалогиВзносыОтчисления.ПримененнаяЛьгота) КАК ПримененнаяЛьгота,
		|	СУММА(НалогиВзносыОтчисления.ПрочиеВычеты) КАК ПрочиеВычеты,
		|	СУММА(НалогиВзносыОтчисления.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	СУММА(НалогиВзносыОтчисления.НеоблагаемыйДоход) КАК НеоблагаемыйДоход
		|ПОМЕСТИТЬ ВТНалогиВзносыОтчисления
		|ИЗ
		|	#НалогиВзносыОтчисления КАК НалогиВзносыОтчисления
		|ГДЕ
		|	НалогиВзносыОтчисления.Ссылка = &ДокументСсылка
		|
		|СГРУППИРОВАТЬ ПО
		|	НалогиВзносыОтчисления.Ссылка,
		|	НалогиВзносыОтчисления.НомерСтроки,
		|	НалогиВзносыОтчисления.ФизическоеЛицо,
		|	НалогиВзносыОтчисления.Подразделение,
		|	НалогиВзносыОтчисления.ВидДохода,
		|	НалогиВзносыОтчисления.Ссылка.МесяцНачисления,
		|	НалогиВзносыОтчисления.Ссылка.Организация,
		|	НалогиВзносыОтчисления.МесяцНалоговогоПериода,
		|	НалогиВзносыОтчисления.ВидНалогаВзносаОтчисления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НалогиВзносыОтчисления.ДокументСсылка КАК ДокументСсылка,
		|	НалогиВзносыОтчисления.ФизическоеЛицо КАК ФизическоеЛицо,
		|	НалогиВзносыОтчисления.Организация КАК Организация,
		|	НалогиВзносыОтчисления.Подразделение КАК Подразделение,
		|	НалогиВзносыОтчисления.ВидДохода КАК ВидДохода,
		|	НалогиВзносыОтчисления.ПериодРегистрации КАК ПериодРегистрации,
		|	НалогиВзносыОтчисления.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	НалогиВзносыОтчисления.ДатаНачала КАК ДатаНачала,
		|	НалогиВзносыОтчисления.ДанныеМежрасчетногоПериода КАК ДанныеМежрасчетногоПериода,
		|	НалогиВзносыОтчисления.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления,
		|	НалогиВзносыОтчисления.НалогВзнос + НалогиВзносыОтчисления.НалогВзносСПревышения КАК Сумма,
		|	НалогиВзносыОтчисления.НалогВзнос КАК НалогВзнос,
		|	НалогиВзносыОтчисления.НалогВзносСПревышения КАК НалогВзносСПревышения
		|ИЗ
		|	ВТНалогиВзносыОтчисления КАК НалогиВзносыОтчисления
		|ГДЕ
		|	(НалогиВзносыОтчисления.НалогВзнос <> 0
		|			ИЛИ НалогиВзносыОтчисления.НалогВзносСПревышения <> 0
		|			ИЛИ НалогиВзносыОтчисления.ОбъектИсчисления <> 0
		|			ИЛИ НалогиВзносыОтчисления.РазрешенныйВычет <> 0
		|			ИЛИ НалогиВзносыОтчисления.ПримененныйВычет <> 0
		|			ИЛИ НалогиВзносыОтчисления.ПримененнаяЛьгота <> 0
		|			ИЛИ НалогиВзносыОтчисления.ПрочиеВычеты <> 0
		|			ИЛИ НалогиВзносыОтчисления.ОблагаемыйДоход <> 0
		|			ИЛИ НалогиВзносыОтчисления.НеоблагаемыйДоход <> 0)";
		
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Ссылка.МесяцНачисления", ИмяПоляМесяц);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "#НалогиВзносыОтчисления", ДокументСсылка.Метаданные().ПолноеИмя() + ".НалогиВзносыОтчисления");
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.МенеджерВременныхТаблиц = ДанныеДляПроведения.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	
	ДанныеДляПроведения.НалогиВзносыОтчисления = Запрос.Выполнить().Выгрузить();
		
КонецПроцедуры

Процедура ЗаполнитьДанныеДляПроведенияПоДоходамНеПодлежащимНалогообложению(ДанныеДляПроведения, ДокументСсылка, ИмяПоляМесяц = "Ссылка.МесяцНачисления") Экспорт
	
