Функция РезультатРасчетаВОСМС(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты) Экспорт
	
    Если МесяцНачисления >= Дата(2026, 1, 1) Тогда

		ВОСМС = РассчитатьВОСМСПосле2026(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления,ОкончательныйРасчетЗарплаты);
        
    ИначеЕсли МесяцНачисления >= Дата(2025, 1, 1) Тогда

		ВОСМС = РассчитатьВОСМСПосле2025(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления,ОкончательныйРасчетЗарплаты);
        
    ИначеЕсли МесяцНачисления >= Дата(2023, 1, 1) Тогда

		ВОСМС = РассчитатьВОСМСПосле2023(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления,ОкончательныйРасчетЗарплаты);
        
    ИначеЕсли МесяцНачисления >= Дата(2022, 1, 1) Тогда

		ВОСМС = РассчитатьВОСМСПосле2022(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления,ОкончательныйРасчетЗарплаты);
        
    ИначеЕсли МесяцНачисления >= Дата(2021, 1, 1) Тогда

		ВОСМС = РассчитатьВОСМСПосле2021(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления,ОкончательныйРасчетЗарплаты);
        
    ИначеЕсли МесяцНачисления >= Дата(2020, 1, 1) Тогда

		ВОСМС = РассчитатьВОСМСПосле2020(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления,ОкончательныйРасчетЗарплаты);
		
	ИначеЕсли (МесяцНачисления >= Дата(2017, 7, 1) И МесяцНачисления < Дата(2018, 1, 1)) Тогда
		// С 1 июля 2017 года введено обязательное социальное медицинское страхование
		// С 1 января 2018 года уплата взносов ОСМС отложена до 2020 года
		ВОСМС = РассчитатьВОСМСДо2019(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления,ОкончательныйРасчетЗарплаты);
		
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ДанныеОРезультатахРасчетаВОСМСДляДокумента(ВОСМС);

КонецФункции

Функция РезультатРасчетаООСМС(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты) Экспорт
	
   	Если МесяцНачисления >= Дата(2026, 1, 1) Тогда
		ООСМС = РассчитатьООСМСПосле2026(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления,ОкончательныйРасчетЗарплаты);
   	ИначеЕсли МесяцНачисления >= Дата(2023, 1, 1) Тогда
		ООСМС = РассчитатьООСМСПосле2023(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления,ОкончательныйРасчетЗарплаты);
   	ИначеЕсли МесяцНачисления >= Дата(2022, 1, 1) Тогда
		ООСМС = РассчитатьООСМСПосле2022(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления,ОкончательныйРасчетЗарплаты);
   	ИначеЕсли МесяцНачисления >= Дата(2021, 1, 1) Тогда
		ООСМС = РассчитатьООСМСПосле2021(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления,ОкончательныйРасчетЗарплаты);
    ИначеЕсли МесяцНачисления >= Дата(2020, 1, 1) Тогда
		ООСМС = РассчитатьООСМСПосле2020(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления,ОкончательныйРасчетЗарплаты);
	ИначеЕсли МесяцНачисления >= Дата(2019, 1, 1) Тогда
		ООСМС = РассчитатьООСМСПосле2019(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления,ОкончательныйРасчетЗарплаты);
	ИначеЕсли МесяцНачисления >= Дата(2017, 7, 1) Тогда
		// С 1 июля 2017 года введено обязательное социальное медицинское страхование
		ООСМС = РассчитатьООСМС(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления,ОкончательныйРасчетЗарплаты);
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ДанныеОРезультатахРасчетаООСМСДляДокумента(ООСМС)
		
КонецФункции

