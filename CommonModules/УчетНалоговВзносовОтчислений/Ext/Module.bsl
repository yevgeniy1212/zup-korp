		|			И ПериодыПоФизлицам.ФизическоеЛицо = ДоходыПредыдущегоМестаРаботы.ФизическоеЛицо
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ВидыВычетовИПН КАК ВидыВычетовИПН
		|		ПО (ВидыВычетовИПН.ПредоставлениеВычета = ЗНАЧЕНИЕ(Перечисление.ВидыПредоставленияВычетов.Стандартный))
		|			И (ВидыВычетовИПН.ПериодПредоставления = ЗНАЧЕНИЕ(Перечисление.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахКалендарногоГода))
		|ГДЕ
		|	ДоходыПредыдущегоМестаРаботы.Организация = &Организация
		|
		|СГРУППИРОВАТЬ ПО
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода,
		|	ПериодыПоФизлицам.ФизическоеЛицо,
		|	ВидыВычетовИПН.Ссылка
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	МесяцНалоговогоПериода,
		|	ФизическоеЛицо,
		|	ВидВычета";
		
	Если ОкончательныйРасчет Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОкончательныйРасчетДоходы", "Истина");
	Иначе
		// необходимо учесть суммы годовых вычетов, предоставленные ранее в документах окончательного расчета
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОкончательныйРасчетДоходы", "(СведенияОбИсчисленииВычетовИПНОбороты.ДанныеМежрасчетногоПериода ИЛИ СведенияОбИсчисленииВычетовИПНОбороты.Период < ПериодыПоФизлицам.МесяцНалоговогоПериода)");
	КонецЕсли;
	
	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВТКадровыеДанныеСотрудниковПоПериодам КАК ПериодыПоФизлицам", "ВТКадровыеДанныеСотрудниковПоПериодамОбъединенная КАК ПериодыПоФизлицам");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВТПериодыПоФизлицам КАК ПериодыПоФизлицам", "ВТПериодыПоФизлицамОбъединенная КАК ПериодыПоФизлицам");
		
	КонецЕсли;
	
	Запрос.Выполнить();
	
КонецПроцедуры

Процедура СоздатьВТДанныеДляРасчетаВычетовИПН(МенеджерВременныхТаблиц, Организация, ПредоставлятьВычетВМесяцеОтсутствияДохода = Ложь, МесяцНачисления) Экспорт
	
	Если МесяцНачисления >= Дата(2026,1,1) Тогда
		СоздатьВТДанныеДляРасчетаВычетовИПНПосле2026(МенеджерВременныхТаблиц, Организация, ПредоставлятьВычетВМесяцеОтсутствияДохода, МесяцНачисления);
	ИначеЕсли МесяцНачисления >= Дата(2025,1,1) Тогда
		СоздатьВТДанныеДляРасчетаВычетовИПНПосле2025(МенеджерВременныхТаблиц, Организация, ПредоставлятьВычетВМесяцеОтсутствияДохода, МесяцНачисления);
	ИначеЕсли МесяцНачисления >= Дата(2021,1,1) Тогда
		СоздатьВТДанныеДляРасчетаВычетовИПНПосле2021(МенеджерВременныхТаблиц, Организация, ПредоставлятьВычетВМесяцеОтсутствияДохода, МесяцНачисления);
    ИначеЕсли МесяцНачисления >= Дата(2019, 1, 1) Тогда
        СоздатьВТДанныеДляРасчетаВычетовИПНДо2021(МенеджерВременныхТаблиц, Организация, ПредоставлятьВычетВМесяцеОтсутствияДохода, МесяцНачисления);
    Иначе
        СоздатьВТДанныеДляРасчетаВычетовИПНДо2018(МенеджерВременныхТаблиц, Организация, ПредоставлятьВычетВМесяцеОтсутствияДохода, МесяцНачисления);
    КонецЕсли;

КонецПроцедуры

Процедура СоздатьВТДанныеДляРасчетаВычетовИПНПосле2026(МенеджерВременныхТаблиц, Организация, ПредоставлятьВычетВМесяцеОтсутствияДохода = Ложь, МесяцНачисления) Экспорт
    
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("НачалоПериода", МесяцНачисления);
	Запрос.УстановитьПараметр("КонецПериода", КонецМесяца(МесяцНачисления));
	
	Если НЕ ВТСуществует(МенеджерВременныхТаблиц, "ВТИсчисленныеОПВПоПодразделениям") Тогда
		Запрос.Текст =
			"ВЫБРАТЬ
			|	NULL КАК МесяцНалоговогоПериода,
			|	NULL КАК ФизическоеЛицо,
    		|	NULL КАК Подразделение,
			|	NULL КАК ВидДохода,
			|	0 КАК ИсчисленныеОПВ
			|ПОМЕСТИТЬ ВТИсчисленныеОПВПоПодразделениям";
		Запрос.Выполнить();
	КонецЕсли;
	
    Если НЕ ВТСуществует(МенеджерВременныхТаблиц, "ВТИсчисленныеВОСМСПоПодразделениям") Тогда
    	Запрос.Текст =
    		"ВЫБРАТЬ
    		|	NULL КАК МесяцНалоговогоПериода,
    		|	NULL КАК ФизическоеЛицо,
    		|	NULL КАК Подразделение,
    		|	NULL КАК ВидДохода,
    		|	0 КАК ИсчисленныеВОСМС
    		|ПОМЕСТИТЬ ВТИсчисленныеВОСМСПоПодразделениям";
    	Запрос.Выполнить();
    КонецЕсли;

	Если НЕ ВТСуществует(МенеджерВременныхТаблиц, "ВТИсчисленныеСОПоПодразделениям") Тогда
        // в межрасчете (где СО не рассчитывается) при наличии в месяце данных сумм ГПХ необходимо получать сумму вычета СО по ГПХ для дельты расчета 
		Запрос.Текст =
			// механизм исправления межрасчетных документов может ошибочно сторнировать вычета СО предыдущего периода
			"ВЫБРАТЬ
			|	СведенияОбИсчисленииВычетовИПН.ПериодРегистрации КАК МесяцНалоговогоПериода,
			|	СведенияОбИсчисленииВычетовИПН.ФизическоеЛицо КАК ФизическоеЛицо,
			|	СведенияОбИсчисленииВычетовИПН.Подразделение КАК Подразделение,
			|	СведенияОбИсчисленииВычетовИПН.ВидДохода КАК ВидДохода,
			|	СУММА(СведенияОбИсчисленииВычетовИПН.ПримененныйВычет) КАК ИсчисленныеСО
			|ПОМЕСТИТЬ ВТИсчисленныеСОПоПодразделениям
			|ИЗ
			|	РегистрНакопления.СведенияОбИсчисленииВычетовИПН КАК СведенияОбИсчисленииВычетовИПН
            |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
			|		ПО СведенияОбИсчисленииВычетовИПН.ФизическоеЛицо = ПериодыПоФизлицам.ФизическоеЛицо			
			|			И СведенияОбИсчисленииВычетовИПН.ПериодРегистрации = ПериодыПоФизлицам.МесяцНалоговогоПериода
			|			И СведенияОбИсчисленииВычетовИПН.ПериодРегистрации < &НачалоПериода
			|			И Организация = &Организация
			|			И ВидВычета = ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ВычетСО)
			|
			|СГРУППИРОВАТЬ ПО
			|	СведенияОбИсчисленииВычетовИПН.ПериодРегистрации,
			|	СведенияОбИсчисленииВычетовИПН.ФизическоеЛицо,
			|	СведенияОбИсчисленииВычетовИПН.Подразделение,
			|	СведенияОбИсчисленииВычетовИПН.ВидДохода
			|	
			|ОБЪЕДИНИТЬ ВСЕ
			|	
			|ВЫБРАТЬ
			|	СведенияОбИсчисленииВычетовИПН.ПериодРегистрации КАК МесяцНалоговогоПериода,
			|	СведенияОбИсчисленииВычетовИПН.ФизическоеЛицо КАК ФизическоеЛицо,
			|	СведенияОбИсчисленииВычетовИПН.Подразделение КАК Подразделение,
			|	СведенияОбИсчисленииВычетовИПН.ВидДохода КАК ВидДохода,
			|	СведенияОбИсчисленииВычетовИПН.ПримененныйВычетОборот КАК ИсчисленныеСО
			|ИЗ
			|	РегистрНакопления.СведенияОбИсчисленииВычетовИПН.Обороты(
			|			&НачалоПериода,
			|			&КонецПериода,
			|			,
			|			&Организация = &Организация
			|				И ВидВычета = ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ВычетСО)
			|				И ФизическоеЛицо В
			|					(ВЫБРАТЬ
			|						ВТФизическиеЛица.ФизическоеЛицо
			|					ИЗ
			|						ВТФизическиеЛица)
			|				И ДанныеМежрасчетногоПериода) КАК СведенияОбИсчисленииВычетовИПН";
    	Запрос.Выполнить();
		// учтем вызов "от обратного" в документе окончательного расчета при наличии в месяце данных сумм ГПХ
		УничтожитьВТ.Добавить("ВТИсчисленныеСОПоПодразделениям");
	КонецЕсли;
	
	// Применение вычетов ИПН
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(ПрименениеВычетовИПН.Период) КАК Период,
		|	ПрименениеВычетовИПН.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода
		|ПОМЕСТИТЬ ВТПериодыПримененияВычетов
		|ИЗ
		|	ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПрименениеВычетовИПН КАК ПрименениеВычетовИПН
		|		ПО ПериодыПоФизлицам.МесяцНалоговогоПериода >= ПрименениеВычетовИПН.Период
		|			И ПериодыПоФизлицам.ФизическоеЛицо = ПрименениеВычетовИПН.ФизическоеЛицо
		|			И (ПрименениеВычетовИПН.Активность)
		|
		|СГРУППИРОВАТЬ ПО
		|	ПрименениеВычетовИПН.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТПериодыПримененияВычетов.ФизическоеЛицо,
		|	ВТПериодыПримененияВычетов.МесяцНалоговогоПериода,
		|	ПрименениеВычетовИПН.Организация
		|ПОМЕСТИТЬ ВТПрименениеВычетовИПН
		|ИЗ
		|	ВТПериодыПримененияВычетов КАК ВТПериодыПримененияВычетов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПрименениеВычетовИПН КАК ПрименениеВычетовИПН
		|		ПО ВТПериодыПримененияВычетов.Период = ПрименениеВычетовИПН.Период
		|			И ВТПериодыПримененияВычетов.ФизическоеЛицо = ПрименениеВычетовИПН.ФизическоеЛицо
		|			И (ПрименениеВычетовИПН.Активность)
		|ГДЕ
		|	ПрименениеВычетовИПН.Организация = &Организация";
	
	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"ВТПериодыПоФизлицам КАК ПериодыПоФизлицам","ВТПериодыПоФизлицамОбъединенная КАК ПериодыПоФизлицам");
	КонецЕсли;
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТПериодыПримененияВычетов");
	УничтожитьВТ.Добавить("ВТПрименениеВычетовИПН");
	
	// Назначенные вычеты ИПН
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(ВычетыФизическихЛицИПН.Период) КАК Период,
		|	ВычетыФизическихЛицИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВычетыФизическихЛицИПН.ВидВычета КАК ВидВычета,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода
		|ПОМЕСТИТЬ ВТПериодыВычетовИПН
		|ИЗ
		|	ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ВычетыФизическихЛицИПН КАК ВычетыФизическихЛицИПН
		|		ПО ПериодыПоФизлицам.МесяцНалоговогоПериода >= ВычетыФизическихЛицИПН.Период
		|			И ПериодыПоФизлицам.ФизическоеЛицо = ВычетыФизическихЛицИПН.ФизическоеЛицо
		|			И (ВычетыФизическихЛицИПН.Активность)
		|ГДЕ
		|	ВычетыФизическихЛицИПН.ВидВычета <> ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ВычетОПВ)
		|	И ВычетыФизическихЛицИПН.ВидВычета <> ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ВычетВОСМС)
		|	И ВычетыФизическихЛицИПН.ВидВычета <> ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ВычетСО)
		|
		|СГРУППИРОВАТЬ ПО
		|	ВычетыФизическихЛицИПН.ФизическоеЛицо,
		|	ВычетыФизическихЛицИПН.ВидВычета,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
        // сгруппируем вычеты, если есть остатки и сумма разрешшенного вычета в текущем месяце, то выберем строку с суммой разрешенного в текущем месяце вычета
		|ВЫБРАТЬ
		|	ВычетыФизическихЛицИПН.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВычетыФизическихЛицИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВычетыФизическихЛицИПН.ВидВычета КАК ВидВычета,
		|	ВычетыФизическихЛицИПН.ПредоставлятьВычет КАК ПредоставлятьВычет,
		|	МАКСИМУМ(ВычетыФизическихЛицИПН.ДействуетПо) КАК ДействуетПо
		|ПОМЕСТИТЬ ВТВычетыФизическихЛицИПН
		|ИЗ
		|	(ВЫБРАТЬ
		|		ВТПериодыВычетовИПН.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|		ВТПериодыВычетовИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|		ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка) КАК Подразделение,
		|		ВТПериодыВычетовИПН.ВидВычета КАК ВидВычета,
		|		ВычетыФизическихЛицИПН.ПредоставлятьВычет КАК ПредоставлятьВычет,
		|		ВычетыФизическихЛицИПН.ДействуетПо КАК ДействуетПо
		|	ИЗ
		|		ВТПериодыВычетовИПН КАК ВТПериодыВычетовИПН
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ВычетыФизическихЛицИПН КАК ВычетыФизическихЛицИПН
		|			ПО ВТПериодыВычетовИПН.Период = ВычетыФизическихЛицИПН.Период
		|				И ВТПериодыВычетовИПН.ФизическоеЛицо = ВычетыФизическихЛицИПН.ФизическоеЛицо
		|				И ВТПериодыВычетовИПН.ВидВычета = ВычетыФизическихЛицИПН.ВидВычета
		|				И (ВычетыФизическихЛицИПН.Активность)
		|	ГДЕ
		|		ВычетыФизическихЛицИПН.ПредоставлятьВычет
		|		И ВЫБОР
		|				КОГДА ВычетыФизическихЛицИПН.ДействуетПо = ДАТАВРЕМЯ(1, 1, 1)
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ НАЧАЛОПЕРИОДА(ВТПериодыВычетовИПН.МесяцНалоговогоПериода, МЕСЯЦ) <= НАЧАЛОПЕРИОДА(ВычетыФизическихЛицИПН.ДействуетПо, МЕСЯЦ)
		|			КОНЕЦ
		|	
		// добавим суммы остатков переносимых по графику вычетов 
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		ПериодыПоФизлицам.МесяцНалоговогоПериода,
		|		ПериодыПоФизлицам.ФизическоеЛицо,
		|		НакопленныеДанныеПоВычетам.Подразделение,
		|		НакопленныеДанныеПоВычетам.ВидВычета,
		|		ИСТИНА,
		|		ДАТАВРЕМЯ(1, 1, 1)
		|	ИЗ
		|		ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНакопленныеДанныеПоВычетам КАК НакопленныеДанныеПоВычетам
		|			ПО ПериодыПоФизлицам.МесяцНалоговогоПериода = НакопленныеДанныеПоВычетам.МесяцНалоговогоПериода
