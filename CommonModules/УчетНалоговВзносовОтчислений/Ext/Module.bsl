		|	СведенияОбИсчисленииНалоговВзносовОтчисленийОбороты.Регистратор <> &Регистратор";
		
	//Запрос.Текст = СтрЗаменить(Запрос.Текст, "#НалогиВзносыОтчисленияИсчисленные", "&НалогиВзносыОтчисленияИсчисленные");
	
	Результат = Запрос.ВыполнитьПакет();
	ВсегоРезультатов = Результат.Количество();

	БазаРасчетаСН = Результат[ВсегоРезультатов-6].Выгрузить();
	БазаРасчетаСО = Результат[ВсегоРезультатов-5].Выгрузить();
	БазаРасчетаОППВ = Результат[ВсегоРезультатов-4].Выгрузить();
	БазаРасчетаООСМС = Результат[ВсегоРезультатов-3].Выгрузить();
	БазаРасчетаОПВР = Результат[ВсегоРезультатов-2].Выгрузить();
	ИсчисленныеНалогиВзносы = Результат[ВсегоРезультатов-1].Выгрузить();
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(НалогиВзносыОтчисленияИсчисленные, ИсчисленныеНалогиВзносы);
	
	СтруктураОтбора = Новый Структура("ВидНалогаВзносаОтчисления");
	// СН
	СтруктураОтбора.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.СН;
	ТаблицаСН = ИсчисленныеНалогиВзносы.Скопировать(СтруктураОтбора);
	// СО
	СтруктураОтбора.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.СО;
	ТаблицаСО = ИсчисленныеНалогиВзносы.Скопировать(СтруктураОтбора);
	
	// ОППВ
	СтруктураОтбора.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ОППВ;
	ТаблицаОППВ = ИсчисленныеНалогиВзносы.Скопировать(СтруктураОтбора);
	
	// ООСМС
	СтруктураОтбора.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ООСМС;
	ТаблицаООСМС = ИсчисленныеНалогиВзносы.Скопировать(СтруктураОтбора);
	
	// ОПВР
	СтруктураОтбора.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ОПВР;
	ТаблицаОПВР = ИсчисленныеНалогиВзносы.Скопировать(СтруктураОтбора);
	
    ЗапросСпособовОкругления = Новый Запрос;
	ЗапросСпособовОкругления.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	// Таблица ВТСпособыОкругления
	СоздатьВТСпособыОкругления(Организация, ПериодРегистрации, ЗапросСпособовОкругления.МенеджерВременныхТаблиц);

	ТочностьОкругленияДляРаспределенияСН = ПолучитьТочностьОкругленияДляРаспределения(ЗапросСпособовОкругления.МенеджерВременныхТаблиц, ПериодРегистрации, Перечисления.ВидыНалоговВзносовОтчислений.СН);
	ТочностьОкругленияДляРаспределенияСО = ПолучитьТочностьОкругленияДляРаспределения(ЗапросСпособовОкругления.МенеджерВременныхТаблиц, ПериодРегистрации, Перечисления.ВидыНалоговВзносовОтчислений.СО);
	ТочностьОкругленияДляРаспределенияОППВ = ПолучитьТочностьОкругленияДляРаспределения(ЗапросСпособовОкругления.МенеджерВременныхТаблиц, ПериодРегистрации, Перечисления.ВидыНалоговВзносовОтчислений.ОППВ);
	ТочностьОкругленияДляРаспределенияООСМС = ПолучитьТочностьОкругленияДляРаспределения(ЗапросСпособовОкругления.МенеджерВременныхТаблиц, ПериодРегистрации, Перечисления.ВидыНалоговВзносовОтчислений.ООСМС);
	ТочностьОкругленияДляРаспределенияОПВР = ПолучитьТочностьОкругленияДляРаспределения(ЗапросСпособовОкругления.МенеджерВременныхТаблиц, ПериодРегистрации, Перечисления.ВидыНалоговВзносовОтчислений.ОПВР);

	НоваяТаблицаРаспределения = Движения.НалогиВзносыОтчисленияПоСотрудникам.ВыгрузитьКолонки();
	// СН
	СНПоСотрудникам = НалогиВзносыОтчисленияПоСотрудникам(ТаблицаСН, БазаРасчетаСН, ТочностьОкругленияДляРаспределенияСН);
	СНПоСотрудникам.Колонки.Сумма.Имя = "СН";
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(СНПоСотрудникам, НоваяТаблицаРаспределения);
	// СО
	СОПоСотрудникам = НалогиВзносыОтчисленияПоСотрудникам(ТаблицаСО, БазаРасчетаСО, ТочностьОкругленияДляРаспределенияСО);
	СОПоСотрудникам.Колонки.Сумма.Имя = "СО";
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(СОПоСотрудникам, НоваяТаблицаРаспределения);
	
	// ОППВ
	ОППВПоСотрудникам = НалогиВзносыОтчисленияПоСотрудникам(ТаблицаОППВ, БазаРасчетаОППВ, ТочностьОкругленияДляРаспределенияОППВ);
	ОППВПоСотрудникам.Колонки.Сумма.Имя = "ОППВ";
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ОППВПоСотрудникам, НоваяТаблицаРаспределения);
	
	// ООСМС
	ООСМСПоСотрудникам = НалогиВзносыОтчисленияПоСотрудникам(ТаблицаООСМС, БазаРасчетаООСМС, ТочностьОкругленияДляРаспределенияООСМС);
	ООСМСПоСотрудникам.Колонки.Сумма.Имя = "ООСМС";
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ООСМСПоСотрудникам, НоваяТаблицаРаспределения);

	// ОПВР
	ОПВРПоСотрудникам = НалогиВзносыОтчисленияПоСотрудникам(ТаблицаОПВР, БазаРасчетаОПВР, ТочностьОкругленияДляРаспределенияОПВР);
	ОПВРПоСотрудникам.Колонки.Сумма.Имя = "ОПВР";
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ОПВРПоСотрудникам, НоваяТаблицаРаспределения);

	ТекстКорректировкаРаспределения = 
		"ВЫБРАТЬ
		|	НалогиВзносыОтчисленияПоСотрудникам.Период,
		|	НалогиВзносыОтчисленияПоСотрудникам.Организация,
		|	НалогиВзносыОтчисленияПоСотрудникам.ФизическоеЛицо,
		|	НалогиВзносыОтчисленияПоСотрудникам.Сотрудник,
		|	НалогиВзносыОтчисленияПоСотрудникам.ВидДохода,
		|	НалогиВзносыОтчисленияПоСотрудникам.Подразделение,
		|	НалогиВзносыОтчисленияПоСотрудникам.Начисление,
		|	-НалогиВзносыОтчисленияПоСотрудникам.СООборот КАК СО,
		|	-НалогиВзносыОтчисленияПоСотрудникам.СНОборот КАК СН,
		|	-НалогиВзносыОтчисленияПоСотрудникам.ОППВОборот КАК ОППВ,
		|	-НалогиВзносыОтчисленияПоСотрудникам.ООСМСОборот КАК ООСМС,
		|	-НалогиВзносыОтчисленияПоСотрудникам.ОПВРОборот КАК ОПВР
		|ИЗ
		|	РегистрНакопления.НалогиВзносыОтчисленияПоСотрудникам.Обороты(
		|			НАЧАЛОПЕРИОДА(&ПериодРегистрации, МЕСЯЦ),
		|			КОНЕЦПЕРИОДА(&ПериодРегистрации, МЕСЯЦ),
		|			Регистратор,
		|			Организация = &Организация
		|				И ФизическоеЛицо В (&ФизическиеЛица)) КАК НалогиВзносыОтчисленияПоСотрудникам
		|ГДЕ
		|	НалогиВзносыОтчисленияПоСотрудникам.Регистратор <> &Регистратор
	    |
		|ОБЪЕДИНИТЬ ВСЕ
		|
		// при перепроведении сторнируем суммы будущих периодов (механизм исправления в последующем периоде)
		|ВЫБРАТЬ
		|	НалогиВзносыОтчисленияПоСотрудникам.Период,
		|	НалогиВзносыОтчисленияПоСотрудникам.Организация,
		|	НалогиВзносыОтчисленияПоСотрудникам.ФизическоеЛицо,
		|	НалогиВзносыОтчисленияПоСотрудникам.Сотрудник,
		|	НалогиВзносыОтчисленияПоСотрудникам.ВидДохода,
		|	НалогиВзносыОтчисленияПоСотрудникам.Подразделение,
		|	НалогиВзносыОтчисленияПоСотрудникам.Начисление,
		|	НалогиВзносыОтчисленияПоСотрудникам.СО КАК СО,
		|	НалогиВзносыОтчисленияПоСотрудникам.СН КАК СН,
		|	НалогиВзносыОтчисленияПоСотрудникам.ОППВ КАК ОППВ,
		|	НалогиВзносыОтчисленияПоСотрудникам.ООСМС КАК ООСМС,
		|	НалогиВзносыОтчисленияПоСотрудникам.ОПВР КАК ОПВР
		|ИЗ
		|	РегистрНакопления.НалогиВзносыОтчисленияПоСотрудникам КАК НалогиВзносыОтчисленияПоСотрудникам
		|ГДЕ
		|	НалогиВзносыОтчисленияПоСотрудникам.Регистратор <> &Регистратор
		|	И НалогиВзносыОтчисленияПоСотрудникам.Период МЕЖДУ НАЧАЛОПЕРИОДА(&ПериодРегистрации, МЕСЯЦ) И	КОНЕЦПЕРИОДА(&ПериодРегистрации, МЕСЯЦ)
		|	И НалогиВзносыОтчисленияПоСотрудникам.Организация = &Организация
		|	И НалогиВзносыОтчисленияПоСотрудникам.ФизическоеЛицо В (&ФизическиеЛица)
		|	И НалогиВзносыОтчисленияПоСотрудникам.Сторно
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		// при перепроведении исключаем перерасчеты других документов начисления зарплаты текущего периода, где уже было сторнирование (механизм исправления в последующем периоде) 
		|ВЫБРАТЬ
		|	НалогиВзносыОтчисленияПоСотрудникам.Период,
		|	НалогиВзносыОтчисленияПоСотрудникам.Организация,
		|	НалогиВзносыОтчисленияПоСотрудникам.ФизическоеЛицо,
		|	НалогиВзносыОтчисленияПоСотрудникам.Сотрудник,
		|	НалогиВзносыОтчисленияПоСотрудникам.ВидДохода,
		|	НалогиВзносыОтчисленияПоСотрудникам.Подразделение,
		|	НалогиВзносыОтчисленияПоСотрудникам.Начисление,
		|	-НалогиВзносыОтчисленияПоСотрудникам.СО КАК СО,
		|	-НалогиВзносыОтчисленияПоСотрудникам.СН КАК СН,
		|	-НалогиВзносыОтчисленияПоСотрудникам.ОППВ КАК ОППВ,
		|	-НалогиВзносыОтчисленияПоСотрудникам.ООСМС КАК ООСМС,
		|	-НалогиВзносыОтчисленияПоСотрудникам.ОПВР КАК ОПВР
		|ИЗ
		|	РегистрНакопления.НалогиВзносыОтчисленияПоСотрудникам КАК НалогиВзносыОтчисленияПоСотрудникам
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.НачислениеЗарплаты КАК НачислениеЗарплаты
		|		ПО НалогиВзносыОтчисленияПоСотрудникам.Регистратор = НачислениеЗарплаты.Ссылка
		|			И НачислениеЗарплаты.МесяцНачисления = НАЧАЛОПЕРИОДА(&ПериодРегистрации, МЕСЯЦ)
		|ГДЕ
		|	НалогиВзносыОтчисленияПоСотрудникам.Регистратор <> &Регистратор
		|	И НалогиВзносыОтчисленияПоСотрудникам.Период < НАЧАЛОПЕРИОДА(&ПериодРегистрации, МЕСЯЦ)
		|	И НалогиВзносыОтчисленияПоСотрудникам.Организация = &Организация
		|	И НалогиВзносыОтчисленияПоСотрудникам.ФизическоеЛицо В (&ФизическиеЛица)

		|	И (НалогиВзносыОтчисленияПоСотрудникам.СО < 0
		|			ИЛИ НалогиВзносыОтчисленияПоСотрудникам.СН < 0
		|			ИЛИ НалогиВзносыОтчисленияПоСотрудникам.ОППВ < 0
		|			ИЛИ НалогиВзносыОтчисленияПоСотрудникам.ООСМС < 0
		|			ИЛИ НалогиВзносыОтчисленияПоСотрудникам.ОПВР < 0)
		|";
		
	Запрос.Текст = ТекстКорректировкаРаспределения;
	РанееИсчисленныеНалогиВзносыОтчисления = Запрос.Выполнить().Выгрузить();
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(РанееИсчисленныеНалогиВзносыОтчисления, НоваяТаблицаРаспределения);
	НоваяТаблицаРаспределения.Свернуть("Период, Организация, ФизическоеЛицо, Сотрудник, ВидДохода, Подразделение, Начисление, Сторно", "СО, СН, ОППВ, ООСМС, ОПВР");
	
	КоличествоЗаписей = НоваяТаблицаРаспределения.Количество();
	
	Для Н = 1 По КоличествоЗаписей Цикл

		СтрокаТаблицы = НоваяТаблицаРаспределения[КоличествоЗаписей - Н];
		Если СтрокаТаблицы.СО = 0  
			И СтрокаТаблицы.СН = 0
			И СтрокаТаблицы.ОППВ = 0
			И СтрокаТаблицы.ООСМС = 0
			И СтрокаТаблицы.ОПВР = 0 Тогда
			НоваяТаблицаРаспределения.Удалить(КоличествоЗаписей - Н);
		КонецЕсли;
				
	КонецЦикла;
	
	Движения.НалогиВзносыОтчисленияПоСотрудникам.Загрузить(НоваяТаблицаРаспределения);

	Движения.НалогиВзносыОтчисленияПоСотрудникам.Записывать = Истина;
	Если ЗаписыватьДвижения Тогда
		Движения.НалогиВзносыОтчисленияПоСотрудникам.Записать();
		Движения.НалогиВзносыОтчисленияПоСотрудникам.Записывать = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Процедура СформироватьНалогиВзносыОтчисленияПоСотрудникамПосле2025(Движения, Отказ, Организация, ПериодРегистрации, НалогиВзносыОтчисленияИсчисленные, ЗаписыватьДвижения = Ложь) Экспорт

	Если НалогиВзносыОтчисленияИсчисленные.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
		
	Регистратор = Движения.НалогиВзносыОтчисленияПоСотрудникам.Отбор.Регистратор.Значение;
	
	ОкончательныйРасчет = ТипЗнч(Регистратор) = Тип("ДокументСсылка.НачислениеЗарплаты")
							ИЛИ ТипЗнч(Регистратор) = Тип("ДокументСсылка.Увольнение")
							ИЛИ ТипЗнч(Регистратор) = Тип("ДокументСсылка.УвольнениеСписком");
	
	МассивФизическихЛиц = ОбщегоНазначения.ВыгрузитьКолонку(НалогиВзносыОтчисленияИсчисленные, "ФизическоеЛицо", Истина);
	
	МассивОблагаемыхНачислений = Новый Массив;
	МассивОблагаемыхНачислений.Добавить(Перечисления.СпособыНалогообложенияДоходов.ОблагаетсяЦеликом);
	МассивОблагаемыхНачислений.Добавить(Перечисления.СпособыНалогообложенияДоходов.НеОблагаетсяЧастично);
	
	Запрос = Новый Запрос;
    Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ФизическиеЛица", МассивФизическихЛиц);
	Запрос.УстановитьПараметр("ПериодРегистрации", ПериодРегистрации);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("Регистратор", Регистратор);
	Запрос.УстановитьПараметр("ОкончательныйРасчет", ОкончательныйРасчет);
	Запрос.УстановитьПараметр("МассивОблагаемыхНачислений", МассивОблагаемыхНачислений);
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СведенияОДоходах.ФизическоеЛицо,
		|	СведенияОДоходах.Сотрудник,
		|	СведенияОДоходах.Организация КАК Организация,
		|	СведенияОДоходах.Подразделение,
		|	СУММА(СведенияОДоходах.СуммаДохода) КАК Сумма,
		|	СведенияОДоходах.Период КАК МесяцНалоговогоПериода,
		|	СведенияОДоходах.ДатаНачала КАК ДатаНачала,
		|	ВЫБОР
		|		КОГДА ТИПЗНАЧЕНИЯ(&Регистратор) В (ТИП(Документ.НачислениеПоДоговорам),
		|			ТИП(Документ.ВыплатаБывшимСотрудникам),
		|			ТИП(Документ.РегистрацияПрочихДоходов))
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК ДанныеМежрасчетногоПериода,
		|	ВЫБОР
		|		КОГДА СведенияОДоходах.Период <> &ПериодРегистрации
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК Сторно,
		|	СведенияОДоходах.Начисление
