		|			И РазмерыНеоблагаемыхДоходов.ДоходНеПодлежащийНалогообложению = СведенияОНеоблагаемыхДоходах.ДоходНеПодлежащийНалогообложению
		|
		|
		|СГРУППИРОВАТЬ ПО
		|	РазмерыНеоблагаемыхДоходов.МесяцНалоговогоПериода,
		|	РазмерыНеоблагаемыхДоходов.ФизическоеЛицо,
		|	РазмерыНеоблагаемыхДоходов.ВидНалогаВзносаОтчисления,
		|	РазмерыНеоблагаемыхДоходов.ДоходНеПодлежащийНалогообложению,
		|	РазмерыНеоблагаемыхДоходов.МаксимальныйРазмерНеоблагаемогоДохода,
		|	РазмерыНеоблагаемыхДоходов.ПериодПредоставления,
		|	РазмерыНеоблагаемыхДоходов.Начисление,
		|	РазмерыНеоблагаемыхДоходов.СуммаДохода
		|
		|УПОРЯДОЧИТЬ ПО
		|	ФизическоеЛицо,
		|	ДоходНеПодлежащийНалогообложению,
		|	ВидНалогаВзносаОтчисления,
		|	МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыНеоблагаемые.МесяцНалоговогоПериода,
		|	ДоходыНеоблагаемые.ФизическоеЛицо,
		|	ДоходыНеоблагаемые.ДоходНеПодлежащийНалогообложению,
		|	ДоходыНеоблагаемые.ВидНалогаВзносаОтчисления,
		|	ДоходыНеоблагаемые.Подразделение,
		|	ДоходыНеоблагаемые.Начисление,
		|	ДоходыНеоблагаемые.СуммаДохода
		|ИЗ
		|	ВТДоходыНеоблагаемые КАК ДоходыНеоблагаемые
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СведенияОНеоблагаемыхДоходах.МесяцНалоговогоПериода,
		|	СведенияОНеоблагаемыхДоходах.Подразделение,
		|	СведенияОНеоблагаемыхДоходах.ФизическоеЛицо,
		|	СведенияОНеоблагаемыхДоходах.Начисление,
		|	СведенияОНеоблагаемыхДоходах.ВидНалогаВзносаОтчисления,
		|	СведенияОНеоблагаемыхДоходах.ДоходНеПодлежащийНалогообложению,
		|	- СведенияОНеоблагаемыхДоходах.СуммаДохода КАК СуммаДохода,
		|	- СведенияОНеоблагаемыхДоходах.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	СведенияОНеоблагаемыхДоходах.СуммаДохода КАК СуммаДоходаИсчисленногоРанее,
		|	СведенияОНеоблагаемыхДоходах.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее
		|ИЗ
		|	ВТСведенияОНеоблагаемыхЧастичноДоходахРанееИсчисленные КАК СведенияОНеоблагаемыхДоходах
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ПО (СведенияОНеоблагаемыхДоходах.МесяцНалоговогоПериода = ПериодыПоФизлицам.МесяцНалоговогоПериода)
		|			И СведенияОНеоблагаемыхДоходах.ФизическоеЛицо = ПериодыПоФизлицам.ФизическоеЛицо
		|";
		
	Если ОкончательныйРасчет Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОкончательныйРасчетДоходы", "Истина");
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОкончательныйРасчетДоходы", "ДанныеМежрасчетногоПериода");
	КонецЕсли;
		
	Результат = Запрос.ВыполнитьПакет();
	УничтожитьВТ.Добавить("ВТСведенияОНеоблагаемыхЧастичноДоходахРанееИсчисленные");
	УничтожитьВТ.Добавить("ВТПорядокОбложенияНачислений");
	УничтожитьВТ.Добавить("ВТДоходыНеоблагаемые");
	УничтожитьВТ.Добавить("ВТРазмерыНеоблагаемыхДоходов");
	УничтожитьВТ.Добавить("ВТДанныеДоходовНеоблагамыхЧастично");
	
	ВсегоРезультатов = Результат.Количество();
	НеоблагаемыеДоходыПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	Выборка = Результат[ВсегоРезультатов - 3].Выбрать();

	КвалификаторЧисла = Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15,2));
	
	ВспомогательнаяТаблицаРасчета = Новый ТаблицаЗначений;
	ВспомогательнаяТаблицаРасчета.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	ВспомогательнаяТаблицаРасчета.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	ВспомогательнаяТаблицаРасчета.Колонки.Добавить("ВидНалогаВзносаОтчисления", Новый ОписаниеТипов("ПеречислениеСсылка.ВидыНалоговВзносовОтчислений"));
	ВспомогательнаяТаблицаРасчета.Колонки.Добавить("ДоходНеПодлежащийНалогообложению", Новый ОписаниеТипов("СправочникСсылка.ДоходыНеПодлежащиеНалогообложениюЧастично"));
	ВспомогательнаяТаблицаРасчета.Колонки.Добавить("НеоблагаемыйДоход", КвалификаторЧисла);
	
	МассивТиповНачислений = Новый Массив;
	МассивТиповНачислений.Добавить(Тип("ПланВидовРасчетаСсылка.Начисления"));
	МассивТиповНачислений.Добавить(Тип("СправочникСсылка.ВидыВыплатБывшимСотрудникам"));
	МассивТиповНачислений.Добавить(Тип("СправочникСсылка.ВидыПрочихДоходовФизическихЛиц"));
	МассивТиповНачислений.Добавить(Тип("СправочникСсылка.ВидыДивидендов"));
	
	РезультатыРасчетов = ВспомогательнаяТаблицаРасчета.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("Начисление", Новый ОписаниеТипов(МассивТиповНачислений));
	РезультатыРасчетов.Колонки.Добавить("СуммаДохода", КвалификаторЧисла);
	РезультатыРасчетов.Колонки.Добавить("СуммаДоходаВЦеломЗаПериод", КвалификаторЧисла);
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", КвалификаторЧисла);
	РезультатыРасчетов.Колонки.Добавить("СуммаДоходаИсчисленногоРанее", КвалификаторЧисла);
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", КвалификаторЧисла);

	ТекущееФизическоеЛицо 					= Неопределено;
	ТекущийДоходНеПодлежащийНалогообложению = Неопределено;
	ТекущийВидНалогаВзносаОтчисления		= Неопределено;
	
	НеоблагаемыйДоходВТекущемРасчете = 0;
	
	Пока Выборка.Следующий() Цикл
		
		Если ТекущееФизическоеЛицо <> Выборка.ФизическоеЛицо 
			ИЛИ ТекущийДоходНеПодлежащийНалогообложению <> Выборка.ДоходНеПодлежащийНалогообложению
			ИЛИ ТекущийВидНалогаВзносаОтчисления <> Выборка.ВидНалогаВзносаОтчисления Тогда
			
			ТекущееФизическоеЛицо 					= Выборка.ФизическоеЛицо;
			ТекущийДоходНеПодлежащийНалогообложению = Выборка.ДоходНеПодлежащийНалогообложению;
			ТекущийВидНалогаВзносаОтчисления		= Выборка.ВидНалогаВзносаОтчисления;
			
			НеоблагаемыйДоходВТекущемРасчете = 0;
		КонецЕсли;
		
		Если Выборка.ПериодПредоставления = Перечисления.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахМесяца Тогда
			НеоблагаемыйДоход = Мин(Выборка.СуммаДохода, Выборка.МаксимальныйРазмерНеоблагаемогоДохода);
		ИначеЕсли Выборка.ПериодПредоставления = Перечисления.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахКалендарногоГода Тогда
			ОстатокНеоблагаемогоДохода = Выборка.МаксимальныйРазмерНеоблагаемогоДохода - Выборка.СуммаНеоблагаемогоДоходаСНачалаГода - НеоблагаемыйДоходВТекущемРасчете;
			НеоблагаемыйДоход = Мин(Выборка.СуммаДохода, ОстатокНеоблагаемогоДохода);			
		ИначеЕсли НЕ ЗначениеЗаполнено(Выборка.ДоходНеПодлежащийНалогообложению) Тогда
			НеоблагаемыйДоход = Выборка.СуммаДохода;
		КонецЕсли;
		
		НоваяСтрока = ВспомогательнаяТаблицаРасчета.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		НоваяСтрока.НеоблагаемыйДоход = НеоблагаемыйДоход;
		НеоблагаемыйДоходВТекущемРасчете = НеоблагаемыйДоходВТекущемРасчете + НоваяСтрока.НеоблагаемыйДоход;
	КонецЦикла;
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ДоходНеПодлежащийНалогообложению, ВидНалогаВзносаОтчисления";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из ВспомогательнаяТаблицаРасчета Цикл
		СтруктураПоиска.ФизическоеЛицо 						= СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода 				= СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ДоходНеПодлежащийНалогообложению 	= СтрокаРасчета.ДоходНеПодлежащийНалогообложению;
		СтруктураПоиска.ВидНалогаВзносаОтчисления 			= СтрокаРасчета.ВидНалогаВзносаОтчисления;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		
		Коэффициенты = ОбщегоНазначения.ВыгрузитьКолонку(ДоходыМесяца, "СуммаДохода");    

		РаспределениеРесурса = ОбщегоНазначения.РаспределитьСуммуПропорциональноКоэффициентам(СтрокаРасчета.НеоблагаемыйДоход, Коэффициенты);
		Если РаспределениеРесурса = Неопределено Тогда
			НоваяСтрока = РезультатыРасчетов.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаРасчета,, "НеоблагаемыйДоход");
			НоваяСтрока.НеоблагаемыйДоход = СтрокаРасчета.НеоблагаемыйДоход;
		Иначе
			Индекс = 0;
			Для Каждого СтрокаДоходы Из ДоходыМесяца Цикл
				НоваяСтрока = РезультатыРасчетов.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаРасчета,, "НеоблагаемыйДоход");
				НоваяСтрока.Подразделение = СтрокаДоходы.Подразделение;
				НоваяСтрока.Начисление = СтрокаДоходы.Начисление;
				НоваяСтрока.СуммаДохода = СтрокаДоходы.СуммаДохода;
				НоваяСтрока.СуммаДоходаВЦеломЗаПериод = СтрокаДоходы.СуммаДохода;
				НоваяСтрока.НеоблагаемыйДоход = РаспределениеРесурса[Индекс];
				НоваяСтрока.НеоблагаемыйДоходВЦеломЗаПериод = РаспределениеРесурса[Индекс];
				Индекс = Индекс + 1;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(НеоблагаемыеДоходыПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ДоходНеПодлежащийНалогообложению, Начисление, ВидНалогаВзносаОтчисления",
								"СуммаДоходаВЦеломЗаПериод,    НеоблагаемыйДоходВЦеломЗаПериод, 
								|СуммаДоходаИсчисленногоРанее, НеоблагаемыйДоходИсчисленныйРанее,
								|СуммаДохода, 				   НеоблагаемыйДоход");

	Запрос.УстановитьПараметр("ТаблицаСведенияОНеоблагаемыхДоходах", РезультатыРасчетов);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СведенияОНеоблагаемыхДоходах.ФизическоеЛицо,
		|	СведенияОНеоблагаемыхДоходах.Подразделение,
		|	СведенияОНеоблагаемыхДоходах.МесяцНалоговогоПериода,
		|	СведенияОНеоблагаемыхДоходах.МесяцНалоговогоПериода КАК ПериодРегистрации,
		|	СведенияОНеоблагаемыхДоходах.ДоходНеПодлежащийНалогообложению,
		|	СведенияОНеоблагаемыхДоходах.Начисление,
		|	СведенияОНеоблагаемыхДоходах.ВидНалогаВзносаОтчисления,
		|	СведенияОНеоблагаемыхДоходах.НеоблагаемыйДоходВЦеломЗаПериод КАК НеоблагаемыйДоход
		|ПОМЕСТИТЬ ВТСведенияОНеоблагаемыхДоходах
		|ИЗ
		|	&ТаблицаСведенияОНеоблагаемыхДоходах КАК СведенияОНеоблагаемыхДоходах
		|ГДЕ 
		|	НЕ СведенияОНеоблагаемыхДоходах.ДоходНеПодлежащийНалогообложению = ЗНАЧЕНИЕ(Справочник.ДоходыНеПодлежащиеНалогообложениюЧастично.ПустаяСсылка)
		|";
	Запрос.Выполнить();
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	РезультатыРасчетов.Колонки.Добавить("ФиксСтрока", Новый ОписаниеТипов("Булево"));
	РезультатыРасчетов.Колонки.Добавить("ФиксРасчет", Новый ОписаниеТипов("Булево"));
	НомерСтроки = 0;
	СтрокиДляУдаления = Новый Массив;
	
	Для Каждого СтрокаРасчета Из РезультатыРасчетов Цикл
		
		Если СтрокаРасчета.СуммаДохода = 0 
			И СтрокаРасчета.НеоблагаемыйДоход = 0 Тогда
			
			СтрокиДляУдаления.Добавить(СтрокаРасчета);
			Продолжить;
			
		КонецЕсли;
		
		НомерСтроки = НомерСтроки + 1;
		СтрокаРасчета.НомерСтроки = НомерСтроки;
		
	КонецЦикла;
	
	Для Каждого СтрокаУдаления Из СтрокиДляУдаления Цикл
		РезультатыРасчетов.Удалить(СтрокаУдаления);
	КонецЦикла;	
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов; 
		
КонецФункции

// Подготовка данных к расчету налогов, взносов, отчислений

Процедура СоздатьВТПериодыПоФизлицам(Организация, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет)  
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ПериодРегистрации", НачалоМесяца(МесяцНачисления));
	
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	НАЧАЛОПЕРИОДА(СведенияОДоходахФизическихЛицОбороты.Период, МЕСЯЦ) КАК МесяцНалоговогоПериода,
		|	НАЧАЛОПЕРИОДА(СведенияОДоходахФизическихЛицОбороты.Период, ГОД) КАК НачалоГодаНалоговогоПериода,
		|	СведенияОДоходахФизическихЛицОбороты.ФизическоеЛицо КАК ФизическоеЛицо
		|ПОМЕСТИТЬ ВТПериодыПоФизлицам
		|ИЗ
		|	РегистрНакопления.СведенияОДоходахФизическихЛиц.Обороты(
		|			,
		|			,
		|			Месяц,
		|			Организация = &Организация
		|				И ПериодРегистрации = &ПериодРегистрации
		|				И ФизическоеЛицо В
		|					(ВЫБРАТЬ
		|						СписокСотрудников.ФизическоеЛицо
		|					ИЗ
		|						ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОДоходахФизическихЛицОбороты
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(СведенияОДоходахФизическихЛиц.Период, МЕСЯЦ),
		|	НАЧАЛОПЕРИОДА(СведенияОДоходахФизическихЛиц.Период, ГОД),
		|	СведенияОДоходахФизическихЛиц.ФизическоеЛицо
		|ИЗ
		|	ВТРегистрНакопления_СведенияОДоходахФизическихЛиц КАК СведенияОДоходахФизическихЛиц
		|ГДЕ
		|	СведенияОДоходахФизическихЛиц.Организация = &Организация
		|	И СведенияОДоходахФизическихЛиц.ПериодРегистрации = &ПериодРегистрации
		|	И СведенияОДоходахФизическихЛиц.ФизическоеЛицо В
		|			(ВЫБРАТЬ
		|				СписокСотрудников.ФизическоеЛицо
		|			ИЗ
		|				ВТФизическиеЛица КАК СписокСотрудников)";

		
	Запрос.Выполнить();
	
КонецПроцедуры

Процедура СоздатьВТСведенияОДоходах(Организация, Регистратор, МенеджерВременныхТаблиц, ПервыйМесяцНалоговогоПериода, ПоследнийМесяцНалоговогоПериода, ОкончательныйРасчет, ИсключатьДоходыРегистратора) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ПервыйМесяцНалоговогоПериода", НачалоМесяца(ПервыйМесяцНалоговогоПериода));
	Запрос.УстановитьПараметр("ПоследнийМесяцНалоговогоПериода", КонецМесяца(ПоследнийМесяцНалоговогоПериода));
	Запрос.УстановитьПараметр("ПервыйМесяцНалоговогоГода", НачалоГода(ПервыйМесяцНалоговогоПериода));
	Запрос.УстановитьПараметр("ПоследнийМесяцДоРасчета", КонецМесяца(ДобавитьМесяц(ПоследнийМесяцНалоговогоПериода, -1)));
	Запрос.УстановитьПараметр("ИсключаемыйРегистратор", ?(ИсключатьДоходыРегистратора, Регистратор, Неопределено));
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СведенияОДоходах.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	СведенияОДоходах.ПериодРегистрации КАК ПериодРегистрации,
		|	СведенияОДоходах.Подразделение КАК Подразделение,
		|	СведенияОДоходах.ФизическоеЛицо КАК ФизическоеЛицо,
		|	СведенияОДоходах.Начисление КАК Начисление,
		|	СУММА(СведенияОДоходах.СуммаДохода) КАК СуммаДохода
		|ПОМЕСТИТЬ ВТСведенияОДоходах
		|ИЗ
		|	(ВЫБРАТЬ
		|		НАЧАЛОПЕРИОДА(СведенияОДоходахФизическихЛицОбороты.Период, МЕСЯЦ) КАК МесяцНалоговогоПериода,
		|		СведенияОДоходахФизическихЛицОбороты.ПериодРегистрации КАК ПериодРегистрации,
		|		СведенияОДоходахФизическихЛицОбороты.Подразделение КАК Подразделение,
		|		СведенияОДоходахФизическихЛицОбороты.ФизическоеЛицо КАК ФизическоеЛицо,
		|		СведенияОДоходахФизическихЛицОбороты.Начисление КАК Начисление,
		|		СведенияОДоходахФизическихЛицОбороты.СуммаДоходаОборот КАК СуммаДохода
		|	ИЗ
		|		РегистрНакопления.СведенияОДоходахФизическихЛиц.Обороты(
		|				&ПервыйМесяцНалоговогоПериода,
		|				&ПоследнийМесяцНалоговогоПериода,
		|				Регистратор,
		|				Организация = &Организация
		|					И ФизическоеЛицо В
		|						(ВЫБРАТЬ
		|							СписокСотрудников.ФизическоеЛицо
		|						ИЗ
		|							ВТФизическиеЛица КАК СписокСотрудников)
		|					И &ОкончательныйРасчетДоходы) КАК СведенияОДоходахФизическихЛицОбороты
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|			ПО (НАЧАЛОПЕРИОДА(СведенияОДоходахФизическихЛицОбороты.Период, МЕСЯЦ) = ПериодыПоФизлицам.МесяцНалоговогоПериода)
		// данные документов-исправлений будущего периода не учитываем
		|				И НАЧАЛОПЕРИОДА(СведенияОДоходахФизическихЛицОбороты.ПериодРегистрации, МЕСЯЦ) <= &ПоследнийМесяцНалоговогоПериода
		|				И СведенияОДоходахФизическихЛицОбороты.ФизическоеЛицо = ПериодыПоФизлицам.ФизическоеЛицо
		|	ГДЕ
		|		СведенияОДоходахФизическихЛицОбороты.Регистратор <> &ИсключаемыйРегистратор
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		НАЧАЛОПЕРИОДА(СведенияОДоходах.Период, МЕСЯЦ),
		|		СведенияОДоходах.ПериодРегистрации,
		|		СведенияОДоходах.Подразделение,
		|		СведенияОДоходах.ФизическоеЛицо,
		|		СведенияОДоходах.Начисление,
		|		СведенияОДоходах.СуммаДохода
		|	ИЗ
		|		ВТРегистрНакопления_СведенияОДоходахФизическихЛиц КАК СведенияОДоходах
		|	ГДЕ
		|		СведенияОДоходах.Период МЕЖДУ &ПервыйМесяцНалоговогоПериода И &ПоследнийМесяцНалоговогоПериода
		|		И СведенияОДоходах.Организация = &Организация
		|		И СведенияОДоходах.ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОДоходах
		|
		|СГРУППИРОВАТЬ ПО
		|	СведенияОДоходах.МесяцНалоговогоПериода,
		|	СведенияОДоходах.ПериодРегистрации,
		|	СведенияОДоходах.Подразделение,
		|	СведенияОДоходах.ФизическоеЛицо,
		|	СведенияОДоходах.Начисление";

		
	Если ОкончательныйРасчет Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОкончательныйРасчетДоходы", "Истина");
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОкончательныйРасчетДоходы", "ДанныеМежрасчетногоПериода");
	КонецЕсли;

	Запрос.Выполнить();
	
КонецПроцедуры

Процедура СоздатьВТСтавкиНалоговВзносовПоПериодам(Организация, МенеджерВременныхТаблиц, ИмяВТСтавки = "ВТСтавки") Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	1 КАК Приоритет,
		|	МАКСИМУМ(ЕСТЬNULL(СведенияОСтавкахНалоговСборовОтчислений.Период, ДАТАВРЕМЯ(1, 1, 1))) КАК ПериодСтавки,
		|	ПериодыРасчета.Период КАК МесяцНалоговогоПериода,
		|	СведенияОСтавкахНалоговСборовОтчислений.Организация КАК Организация,
		|	СведенияОСтавкахНалоговСборовОтчислений.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления,
		|	СведенияОСтавкахНалоговСборовОтчислений.ВидДохода КАК ВидДохода
		|ПОМЕСТИТЬ ВТПериодыСтавок
		|ИЗ
		|	ВТДатыПоМесяцам КАК ПериодыРасчета
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОСтавкахНалоговСборовОтчислений КАК СведенияОСтавкахНалоговСборовОтчислений
		|		ПО ПериодыРасчета.Период >= СведенияОСтавкахНалоговСборовОтчислений.Период
		|ГДЕ
		|	СведенияОСтавкахНалоговСборовОтчислений.Организация = &Организация
		|	И СведенияОСтавкахНалоговСборовОтчислений.ВидДохода <> ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка)
		|
		|СГРУППИРОВАТЬ ПО
		|	ПериодыРасчета.Период,
		|	СведенияОСтавкахНалоговСборовОтчислений.Организация,
		|	СведенияОСтавкахНалоговСборовОтчислений.ВидНалогаВзносаОтчисления,
		|	СведенияОСтавкахНалоговСборовОтчислений.ВидДохода
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	2,
		|	МАКСИМУМ(ЕСТЬNULL(СведенияОСтавкахНалоговСборовОтчислений.Период, ДАТАВРЕМЯ(1, 1, 1))),
		|	ПериодыРасчета.Период,
		|	ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка),
		|	СведенияОСтавкахНалоговСборовОтчислений.ВидНалогаВзносаОтчисления,
		|	СведенияОСтавкахНалоговСборовОтчислений.ВидДохода
		|ИЗ
		|	ВТДатыПоМесяцам КАК ПериодыРасчета
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОСтавкахНалоговСборовОтчислений КАК СведенияОСтавкахНалоговСборовОтчислений
		|		ПО ПериодыРасчета.Период >= СведенияОСтавкахНалоговСборовОтчислений.Период
		|ГДЕ
		|	СведенияОСтавкахНалоговСборовОтчислений.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)
		|
		|СГРУППИРОВАТЬ ПО
		|	ПериодыРасчета.Период,
		|	СведенияОСтавкахНалоговСборовОтчислений.ВидНалогаВзносаОтчисления,
		|	СведенияОСтавкахНалоговСборовОтчислений.ВидДохода
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ПериодСтавки,
		|	Организация,
		|	ВидНалогаВзносаОтчисления,
		|	ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПериодыСтавок.Приоритет КАК Приоритет,
		|	ПериодыСтавок.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ПериодыСтавок.ПериодСтавки КАК ПериодСтавки,
		|	ЕСТЬNULL(СведенияОСтавкахНалоговСборовОтчислений.Ставка, 0) / 100 КАК Ставка,
		|	ПериодыСтавок.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления,
		|	ПериодыСтавок.ВидДохода КАК ВидДохода
		|ПОМЕСТИТЬ ВТСтавкиПоПриоритетам
		|ИЗ
		|	ВТПериодыСтавок КАК ПериодыСтавок
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОСтавкахНалоговСборовОтчислений КАК СведенияОСтавкахНалоговСборовОтчислений
		|		ПО ПериодыСтавок.ПериодСтавки = СведенияОСтавкахНалоговСборовОтчислений.Период
		|			И ПериодыСтавок.Организация = СведенияОСтавкахНалоговСборовОтчислений.Организация
		|			И ПериодыСтавок.ВидНалогаВзносаОтчисления = СведенияОСтавкахНалоговСборовОтчислений.ВидНалогаВзносаОтчисления
		|			И ПериодыСтавок.ВидДохода = СведенияОСтавкахНалоговСборовОтчислений.ВидДохода
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	МесяцНалоговогоПериода,
		|	ПериодСтавки,
		|	ВидНалогаВзносаОтчисления,
		|	ВидДохода,
		|	Приоритет
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТСтавкиПоПриоритетам.Приоритет КАК Приоритет,
		|	МаксимумСтавок.ПериодСтавки КАК ПериодСтавки,
		|	МаксимумСтавок.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	МаксимумСтавок.ВидДохода КАК ВидДохода,
		|	МаксимумСтавок.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления
		|ПОМЕСТИТЬ ВТ_МаксимумыСтавокПоПериоду
		|ИЗ
		|	(ВЫБРАТЬ
		|		МАКСИМУМ(ПриоритетСтавок.ПериодСтавки) КАК ПериодСтавки,
		|		ПриоритетСтавок.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|		ПриоритетСтавок.ВидДохода КАК ВидДохода,
		|		ПриоритетСтавок.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления
		|	ИЗ
		|		ВТСтавкиПоПриоритетам КАК ПриоритетСтавок
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ПриоритетСтавок.МесяцНалоговогоПериода,
		|		ПриоритетСтавок.ВидНалогаВзносаОтчисления,
		|		ПриоритетСтавок.ВидДохода) КАК МаксимумСтавок
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиПоПриоритетам КАК ВТСтавкиПоПриоритетам
		|		ПО МаксимумСтавок.ПериодСтавки = ВТСтавкиПоПриоритетам.ПериодСтавки
		|			И МаксимумСтавок.МесяцНалоговогоПериода = ВТСтавкиПоПриоритетам.МесяцНалоговогоПериода
		|			И МаксимумСтавок.ВидДохода = ВТСтавкиПоПриоритетам.ВидДохода
		|			И МаксимумСтавок.ВидНалогаВзносаОтчисления = ВТСтавкиПоПриоритетам.ВидНалогаВзносаОтчисления
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	МесяцНалоговогоПериода,
		|	ВидНалогаВзносаОтчисления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПриоритетСтавок.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТСтавкиПоПриоритетам.Ставка КАК Ставка,
		|	ВТСтавкиПоПриоритетам.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления,
		|	ВТСтавкиПоПриоритетам.ВидДохода КАК ВидДохода
		|ПОМЕСТИТЬ #ВТСтавки
		|ИЗ
		|	(ВЫБРАТЬ
		|		МИНИМУМ(ПриоритетСтавок.Приоритет) КАК Приоритет,
		|		ПриоритетСтавок.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|		ПриоритетСтавок.ВидДохода КАК ВидДохода,
		|		ПриоритетСтавок.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления
		|	ИЗ
		|		ВТ_МаксимумыСтавокПоПериоду КАК ПриоритетСтавок
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ПриоритетСтавок.МесяцНалоговогоПериода,
		|		ПриоритетСтавок.ВидНалогаВзносаОтчисления,
		|		ПриоритетСтавок.ВидДохода) КАК ПриоритетСтавок
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиПоПриоритетам КАК ВТСтавкиПоПриоритетам
		|		ПО ПриоритетСтавок.Приоритет = ВТСтавкиПоПриоритетам.Приоритет
		|			И ПриоритетСтавок.МесяцНалоговогоПериода = ВТСтавкиПоПриоритетам.МесяцНалоговогоПериода
		|			И ПриоритетСтавок.ВидНалогаВзносаОтчисления = ВТСтавкиПоПриоритетам.ВидНалогаВзносаОтчисления
		|			И ПриоритетСтавок.ВидДохода = ВТСтавкиПоПриоритетам.ВидДохода";
		
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "#ВТСтавки", ИмяВТСтавки);
	
	Запрос.Выполнить();	
	УничтожитьВТ.Добавить("ВТПериодыСтавок");
	УничтожитьВТ.Добавить("ВТСтавкиПоПриоритетам");
	УничтожитьВТ.Добавить("ВТ_МаксимумыСтавокПоПериоду");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
КонецПроцедуры

Процедура СоздатьВТРанееИсчисленныеНалогиВзносы(Организация, Регистратор, МенеджерВременныхТаблиц, ПервыйМесяцНалоговогоПериода, ПоследнийМесяцНалоговогоПериода, ОкончательныйРасчет, ИсключатьДоходыРегистратора, ПредоставлятьВычетВМесяцеОтсутствияДохода = Ложь) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
