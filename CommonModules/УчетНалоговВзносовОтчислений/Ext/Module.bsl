	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеОППВПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияОППВВЦеломЗаПериод, ИсчисленныеОППВВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектОППВИсчисленныйРанее, 		РанееИсчисленныеОППВ,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияОППВ, 				ИсчисленныеОППВ");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0
			И (СтрокаТЗ.ИсчисленныеОППВ < 1 И СтрокаТЗ.ИсчисленныеОППВ > 0
				ИЛИ СтрокаТЗ.ИсчисленныеОППВ > -1 И СтрокаТЗ.ИсчисленныеОППВ < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеОППВ = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеОППВ = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеОППВ, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
			
		КонецЕсли;
		
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьООСМС(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	Если МесяцНачисления >= Дата(2018,1,1) Тогда
		// С 1 января 2018 г исключен минимальный предел на объект исчисления
		РезультатыРасчетов = РассчитатьООСМСПосле2018(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет, ИсключатьДоходыРегистратора);
	Иначе
		// Расчет отчислений ОСМС по объекту в пределах от 1 до 15 МЗП
		РезультатыРасчетов = РассчитатьООСМСДо2018(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет, ИсключатьДоходыРегистратора);
	КонецЕсли;
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьООСМСДо2018(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) 
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	СоздатьВТИсключаемыеЛицаОСМС(МенеджерВременныхТаблиц, "ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС");
	
	ВидНалогаВзносаООСМС =  Перечисления.ВидыНалоговВзносовОтчислений.ООСМС;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС, "ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС", Ложь);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ООСМС
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// - Исчисленные ООСМС
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 15 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода, 
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход
		|	КОНЕЦ КАК ОбъектИсчисленияООСМС,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход
		|	КОНЕЦ * ЕСТЬNULL(СтавкиОСМС.СтавкаОтчисления, 0) КАК ИсчисленныеООСМС
		|ПОМЕСТИТЬ ВТИсчисленныеООСМС
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМС КАК СтавкиОСМС
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОСМС.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиОСМС.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеООСМС.МесяцНалоговогоПериода,
		|	ВТИсчисленныеООСМС.ФизическоеЛицо,
		|	ВТИсчисленныеООСМС.ВидДохода,
		|	ВТИсчисленныеООСМС.ОбъектИсчисленияООСМС,
		|	ВТИсчисленныеООСМС.ИсчисленныеООСМС
		|ИЗ
		|	ВТИсчисленныеООСМС КАК ВТИсчисленныеООСМС
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеООСМСПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеООСМСПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеООСМСПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеООСМСПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектООСМСИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.НалогВзнос КАК РанееИсчисленныеООСМС,
		|	-ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеООСМСПоПодразделениям.НалогВзнос КАК ИсчисленныеООСМС,
		|	-ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияООСМС
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеООСМСПоПодразделениям
		|";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТИсчисленныеООСМС");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеООСМСПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	РезультатЗапроса = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеООСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияООСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектООСМСИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеООСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияООСМС,ИсчисленныеООСМС");
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеООСМСПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияООСМСВЦеломЗаПериод,	ИсчисленныеООСМСВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектООСМСИсчисленныйРанее, 		 	РанееИсчисленныеООСМС,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияООСМС, 					ИсчисленныеООСМС");
	
	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		СтрокаТЗ.ИсчисленныеООСМС = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеООСМС, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьООСМСПосле2018(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) 

	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	СоздатьВТИсключаемыеЛицаОСМС(МенеджерВременныхТаблиц, "ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС");
	
	ВидНалогаВзносаООСМС =  Перечисления.ВидыНалоговВзносовОтчислений.ООСМС;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС, "ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС", Ложь);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ООСМС
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// Получаем применение минимального ограничения
	УчетнаяПолитикаНУ = РегистрыСведений.УчетнаяПолитикаПоНалоговомуУчету.СрезПоследних(МесяцНачисления, Новый Структура("Организация", Организация));
	Если УчетнаяПолитикаНУ.Количество() > 0 Тогда
		ПрименятьОграничениеНаМинимальныйОбъектОСМС = УчетнаяПолитикаНУ[0].ПрименятьОграничениеНаМинимальныйОбъектОСМС;
	Иначе 
		ПрименятьОграничениеНаМинимальныйОбъектОСМС = Ложь;
	КонецЕсли;
	
	// - Исчисленные ООСМС
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	0 КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 15 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход
		|	КОНЕЦ КАК ОбъектИсчисленияООСМС,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход
		|	КОНЕЦ * ЕСТЬNULL(СтавкиОСМС.СтавкаОтчисления, 0) КАК ИсчисленныеООСМС
		|ПОМЕСТИТЬ ВТИсчисленныеООСМС
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМС КАК СтавкиОСМС
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОСМС.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиОСМС.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеООСМС.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеООСМС.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеООСМС.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеООСМС.ОбъектИсчисленияООСМС КАК ОбъектИсчисленияООСМС,
		|	ВТИсчисленныеООСМС.ИсчисленныеООСМС КАК ИсчисленныеООСМС
		|ИЗ
		|	ВТИсчисленныеООСМС КАК ВТИсчисленныеООСМС
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеООСМСПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеООСМСПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеООСМСПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеООСМСПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектООСМСИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.НалогВзнос КАК РанееИсчисленныеООСМС,
		|	-ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеООСМСПоПодразделениям.НалогВзнос КАК ИсчисленныеООСМС,
		|	-ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияООСМС
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеООСМСПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.НалогВзнос <> 0)";
		
	Если ПрименятьОграничениеНаМинимальныйОбъектОСМС Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "0 КАК МинимальныйРазмерОрганиченияДохода", "РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода");		
	КонецЕсли;
			
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТИсчисленныеООСМС");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеООСМСПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	РезультатЗапроса = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеООСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияООСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектООСМСИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеООСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияООСМС,ИсчисленныеООСМС");
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеООСМСПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияООСМСВЦеломЗаПериод,	ИсчисленныеООСМСВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектООСМСИсчисленныйРанее, 		 	РанееИсчисленныеООСМС,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияООСМС, 					ИсчисленныеООСМС");
	
	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		СтрокаТЗ.ИсчисленныеООСМС = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеООСМС, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьООСМСПосле2019(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) 

	УничтожитьВТ = Новый Массив;
	
	ПрименятьКорректировкуПрочихНалоговВзносовОтчислений = ЗарплатаКадрыРКПовтИсп.ПрименятьКорректировкуПрочихНалоговВзносовОтчислений(ЗарплатаКадрыПовтИсп.ГоловнаяОрганизация(Организация), МесяцНачисления);	
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ПрименятьКорректировкуПрочихНалоговВзносовОтчислений", ПрименятьКорректировкуПрочихНалоговВзносовОтчислений);
	
	СоздатьВТИсключаемыеЛицаОСМС(МенеджерВременныхТаблиц, "ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС");
	
	ВидНалогаВзносаООСМС =  Перечисления.ВидыНалоговВзносовОтчислений.ООСМС;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС, "ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС", Ложь);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ООСМС
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	СоздатьВТДанныеПоКорректировкеДоходаИПН(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет, ИсключатьДоходыРегистратора, ПрименятьКорректировкуПрочихНалоговВзносовОтчислений);
	
	// Получаем применение минимального ограничения
	УчетнаяПолитикаНУ = РегистрыСведений.УчетнаяПолитикаПоНалоговомуУчету.СрезПоследних(МесяцНачисления, Новый Структура("Организация", Организация));
	Если УчетнаяПолитикаНУ.Количество() > 0 Тогда
		ПрименятьОграничениеНаМинимальныйОбъектОСМС = УчетнаяПолитикаНУ[0].ПрименятьОграничениеНаМинимальныйОбъектОСМС;
	Иначе 
		ПрименятьОграничениеНаМинимальныйОбъектОСМС = Ложь;
	КонецЕсли;
	
	// - Исчисленные ООСМС
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	0 КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 10 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДанныеИПН.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДанныеИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|	СУММА(ДанныеИПН.СуммаКорректировки) КАК СуммаКорректировки
		|ПОМЕСТИТЬ ВТСуммыКорректировки
		|ИЗ
		|	(ВЫБРАТЬ
		|		ИсчисленныйИПН.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|		ИсчисленныйИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|		ЕСТЬNULL(ИсчисленныйИПН.ПримененнаяКорректировка, 0) КАК СуммаКорректировки
		|	ИЗ
		|		ВТИсчисленныйИПН КАК ИсчисленныйИПН
		|	ГДЕ	
		|		&ПрименятьКорректировкуПрочихНалоговВзносовОтчислений	
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		Доходы.МесяцНалоговогоПериода,
		|		Доходы.ФизическоеЛицо,
		|		ЕСТЬNULL(ДанныеПоКорректировкеДоходаИПН.ПримененнаяКорректировка, 0)
		|	ИЗ
		|		ВТДоходы КАК Доходы
		|			ЛЕВОЕ СОЕДИНЕНИЕ ВТДанныеПоКорректировкеДоходаИПН КАК ДанныеПоКорректировкеДоходаИПН
		|			ПО Доходы.МесяцНалоговогоПериода = ДанныеПоКорректировкеДоходаИПН.МесяцНалоговогоПериода
		|				И Доходы.ФизическоеЛицо = ДанныеПоКорректировкеДоходаИПН.ФизическоеЛицо) КАК ДанныеИПН
		|
		|СГРУППИРОВАТЬ ПО
		|	ДанныеИПН.МесяцНалоговогоПериода,
		|	ДанныеИПН.ФизическоеЛицо
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0) >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0)
		|	КОНЕЦ КАК ОбъектИсчисленияООСМС,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0) >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0)
		|	КОНЕЦ * ЕСТЬNULL(СтавкиОСМС.СтавкаОтчисления, 0) КАК ИсчисленныеООСМС
		|ПОМЕСТИТЬ ВТИсчисленныеООСМС
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМС КАК СтавкиОСМС
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОСМС.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиОСМС.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСуммыКорректировки КАК СуммыКорректировки
		|		ПО Доходы.МесяцНалоговогоПериода = СуммыКорректировки.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = СуммыКорректировки.ФизическоеЛицо
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеООСМС.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеООСМС.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеООСМС.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеООСМС.ОбъектИсчисленияООСМС КАК ОбъектИсчисленияООСМС,
		|	ВТИсчисленныеООСМС.ИсчисленныеООСМС КАК ИсчисленныеООСМС
		|ИЗ
		|	ВТИсчисленныеООСМС КАК ВТИсчисленныеООСМС
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеООСМСПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеООСМСПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеООСМСПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеООСМСПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектООСМСИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.НалогВзнос КАК РанееИсчисленныеООСМС,
		|	-ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеООСМСПоПодразделениям.НалогВзнос КАК ИсчисленныеООСМС,
		|	-ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияООСМС
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеООСМСПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.НалогВзнос <> 0)";
		
	Если ПрименятьОграничениеНаМинимальныйОбъектОСМС Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "0 КАК МинимальныйРазмерОрганиченияДохода", "РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода");		
	КонецЕсли;
			
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТИсчисленныеООСМС");
	УничтожитьВТ.Добавить("ВТДанныеПоКорректировкеДоходаИПН");
	УничтожитьВТ.Добавить("ВТСуммыКорректировки");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеООСМСПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	РезультатЗапроса = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеООСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияООСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектООСМСИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеООСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияООСМС,ИсчисленныеООСМС");
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеООСМСПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияООСМСВЦеломЗаПериод,	ИсчисленныеООСМСВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектООСМСИсчисленныйРанее, 		 	РанееИсчисленныеООСМС,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияООСМС, 					ИсчисленныеООСМС");
	
	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		СтрокаТЗ.ИсчисленныеООСМС = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеООСМС, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьООСМСПосле2020(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) 

	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	СоздатьВТИсключаемыеЛицаОСМС(МенеджерВременныхТаблиц, "ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС");
	
	ВидНалогаВзносаООСМС =  Перечисления.ВидыНалоговВзносовОтчислений.ООСМС;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС, "ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС", Ложь);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ООСМС
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	ПрименятьКорректировкуПрочихНалоговВзносовОтчислений = ЗарплатаКадрыРКПовтИсп.ПрименятьКорректировкуПрочихНалоговВзносовОтчислений(Организация, МесяцНачисления);
	Запрос.УстановитьПараметр("ПрименятьКорректировкуПрочихНалоговВзносовОтчислений", ПрименятьКорректировкуПрочихНалоговВзносовОтчислений);
	
	СоздатьВТДанныеПоКорректировкеДоходаИПН(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет, ИсключатьДоходыРегистратора, ПрименятьКорректировкуПрочихНалоговВзносовОтчислений);
	
	// Получаем применение минимального ограничения
	УчетнаяПолитикаНУ = РегистрыСведений.УчетнаяПолитикаПоНалоговомуУчету.СрезПоследних(МесяцНачисления, Новый Структура("Организация", Организация));
	Если УчетнаяПолитикаНУ.Количество() > 0 Тогда
		ПрименятьОграничениеНаМинимальныйОбъектОСМС = УчетнаяПолитикаНУ[0].ПрименятьОграничениеНаМинимальныйОбъектОСМС;
	Иначе 
		ПрименятьОграничениеНаМинимальныйОбъектОСМС = Ложь;
	КонецЕсли;
	
	// - Исчисленные ООСМС
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	0 КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 10 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДанныеИПН.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДанныеИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|	СУММА(ДанныеИПН.СуммаКорректировки) КАК СуммаКорректировки
		|ПОМЕСТИТЬ ВТСуммыКорректировки
		|ИЗ
		|	(ВЫБРАТЬ
		|		ИсчисленныйИПН.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|		ИсчисленныйИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|		ЕСТЬNULL(ИсчисленныйИПН.ПримененнаяКорректировка, 0) КАК СуммаКорректировки
		|	ИЗ
		|		ВТИсчисленныйИПН КАК ИсчисленныйИПН
		|ГДЕ	
		|		&ПрименятьКорректировкуПрочихНалоговВзносовОтчислений	
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		Доходы.МесяцНалоговогоПериода,
		|		Доходы.ФизическоеЛицо,
		|		ЕСТЬNULL(ДанныеПоКорректировкеДоходаИПН.ПримененнаяКорректировка, 0)
		|	ИЗ
		|		ВТДоходы КАК Доходы
		|			ЛЕВОЕ СОЕДИНЕНИЕ ВТДанныеПоКорректировкеДоходаИПН КАК ДанныеПоКорректировкеДоходаИПН
		|			ПО Доходы.МесяцНалоговогоПериода = ДанныеПоКорректировкеДоходаИПН.МесяцНалоговогоПериода
		|				И Доходы.ФизическоеЛицо = ДанныеПоКорректировкеДоходаИПН.ФизическоеЛицо) КАК ДанныеИПН
		|
		|СГРУППИРОВАТЬ ПО
		|	ДанныеИПН.МесяцНалоговогоПериода,
		|	ДанныеИПН.ФизическоеЛицо
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0) >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0)
		|	КОНЕЦ КАК ОбъектИсчисленияООСМС,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0) >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0)
		|	КОНЕЦ * ЕСТЬNULL(СтавкиОСМС.СтавкаОтчисления, 0) КАК ИсчисленныеООСМС
		|ПОМЕСТИТЬ ВТИсчисленныеООСМС
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМС КАК СтавкиОСМС
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОСМС.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиОСМС.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСуммыКорректировки КАК СуммыКорректировки
		|		ПО Доходы.МесяцНалоговогоПериода = СуммыКорректировки.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = СуммыКорректировки.ФизическоеЛицо
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеООСМС.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеООСМС.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеООСМС.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеООСМС.ОбъектИсчисленияООСМС КАК ОбъектИсчисленияООСМС,
		|	ВТИсчисленныеООСМС.ИсчисленныеООСМС КАК ИсчисленныеООСМС
		|ИЗ
		|	ВТИсчисленныеООСМС КАК ВТИсчисленныеООСМС
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеООСМСПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеООСМСПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеООСМСПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеООСМСПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектООСМСИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.НалогВзнос КАК РанееИсчисленныеООСМС,
		|	-ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеООСМСПоПодразделениям.НалогВзнос КАК ИсчисленныеООСМС,
		|	-ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияООСМС
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеООСМСПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.НалогВзнос <> 0)";
		
	Если ПрименятьОграничениеНаМинимальныйОбъектОСМС Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "0 КАК МинимальныйРазмерОрганиченияДохода", "РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода");		
	КонецЕсли;
			
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТИсчисленныеООСМС");
	УничтожитьВТ.Добавить("ВТДанныеПоКорректировкеДоходаИПН");
	УничтожитьВТ.Добавить("ВТСуммыКорректировки");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеООСМСПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	РезультатЗапроса = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеООСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияООСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектООСМСИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеООСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
	
	Если ТочностьОкругления = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругления <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;
			
	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияООСМС,ИсчисленныеООСМС", ТочностьРаспределения);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеООСМСПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияООСМСВЦеломЗаПериод,	ИсчисленныеООСМСВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектООСМСИсчисленныйРанее, 		 	РанееИсчисленныеООСМС,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияООСМС, 					ИсчисленныеООСМС");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0
			И НЕ ОписаниеСпособаОкругления.ПравилоОкругления = Перечисления.ПравилаОкругленияПриРасчетеЗарплаты.Авто
			И (СтрокаТЗ.ИсчисленныеООСМС < 1 И СтрокаТЗ.ИсчисленныеООСМС > 0
				ИЛИ СтрокаТЗ.ИсчисленныеООСМС > -1 И СтрокаТЗ.ИсчисленныеООСМС < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеООСМС = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеООСМС = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеООСМС, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
			
		КонецЕсли;
		
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьООСМСПосле2021(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) 

	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	СоздатьВТИсключаемыеЛицаОСМС(МенеджерВременныхТаблиц, "ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС");
	
	ВидНалогаВзносаООСМС =  Перечисления.ВидыНалоговВзносовОтчислений.ООСМС;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС, "ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС", Ложь);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ООСМС
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	// Получаем применение минимального ограничения
	УчетнаяПолитикаНУ = РегистрыСведений.УчетнаяПолитикаПоНалоговомуУчету.СрезПоследних(МесяцНачисления, Новый Структура("Организация", Организация));
	Если УчетнаяПолитикаНУ.Количество() > 0 Тогда
		ПрименятьОграничениеНаМинимальныйОбъектОСМС = УчетнаяПолитикаНУ[0].ПрименятьОграничениеНаМинимальныйОбъектОСМС;
	Иначе 
		ПрименятьОграничениеНаМинимальныйОбъектОСМС = Ложь;
	КонецЕсли;
	
	// - Исчисленные ООСМС
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	0 КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 10 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход 
		|	КОНЕЦ КАК ОбъектИсчисленияООСМС,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход 
        |	КОНЕЦ * ЕСТЬNULL(СтавкиОСМС.СтавкаОтчисления, 0) КАК ИсчисленныеООСМС
		|ПОМЕСТИТЬ ВТИсчисленныеООСМС
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМС КАК СтавкиОСМС
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОСМС.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиОСМС.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеООСМС.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеООСМС.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеООСМС.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеООСМС.ОбъектИсчисленияООСМС КАК ОбъектИсчисленияООСМС,
		|	ВТИсчисленныеООСМС.ИсчисленныеООСМС КАК ИсчисленныеООСМС
		|ИЗ
		|	ВТИсчисленныеООСМС КАК ВТИсчисленныеООСМС
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеООСМСПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеООСМСПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеООСМСПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеООСМСПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектООСМСИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.НалогВзнос КАК РанееИсчисленныеООСМС,
		|	-ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеООСМСПоПодразделениям.НалогВзнос КАК ИсчисленныеООСМС,
		|	-ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияООСМС
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеООСМСПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.НалогВзнос <> 0)";
		
	Если ПрименятьОграничениеНаМинимальныйОбъектОСМС Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "0 КАК МинимальныйРазмерОрганиченияДохода", "РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода");		
	КонецЕсли;
			
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТИсчисленныеООСМС");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеООСМСПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	РезультатЗапроса = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеООСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияООСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектООСМСИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеООСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
	
	Если ТочностьОкругления = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругления <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;
			
	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияООСМС,ИсчисленныеООСМС", ТочностьРаспределения);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеООСМСПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияООСМСВЦеломЗаПериод,	ИсчисленныеООСМСВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектООСМСИсчисленныйРанее, 		 	РанееИсчисленныеООСМС,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияООСМС, 					ИсчисленныеООСМС");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0
			И НЕ ОписаниеСпособаОкругления.ПравилоОкругления = Перечисления.ПравилаОкругленияПриРасчетеЗарплаты.Авто
			И (СтрокаТЗ.ИсчисленныеООСМС < 1 И СтрокаТЗ.ИсчисленныеООСМС > 0
				ИЛИ СтрокаТЗ.ИсчисленныеООСМС > -1 И СтрокаТЗ.ИсчисленныеООСМС < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеООСМС = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеООСМС = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеООСМС, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
			
		КонецЕсли;
		
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьООСМСПосле2022(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) 
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	СоздатьВТИсключаемыеЛицаОСМС(МенеджерВременныхТаблиц, "ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС");
	
	ВидНалогаВзносаООСМС =  Перечисления.ВидыНалоговВзносовОтчислений.ООСМС;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС, "ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС", Ложь);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ООСМС
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	// - Исчисленные ООСМС
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	0 КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 10 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход 
		|	КОНЕЦ КАК ОбъектИсчисленияООСМС,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход 
        |	КОНЕЦ * ЕСТЬNULL(СтавкиОСМС.СтавкаОтчисления, 0) КАК ИсчисленныеООСМС
		|ПОМЕСТИТЬ ВТИсчисленныеООСМС
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМС КАК СтавкиОСМС
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОСМС.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиОСМС.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеООСМС.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеООСМС.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеООСМС.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеООСМС.ОбъектИсчисленияООСМС КАК ОбъектИсчисленияООСМС,
		|	ВТИсчисленныеООСМС.ИсчисленныеООСМС КАК ИсчисленныеООСМС
		|ИЗ
		|	ВТИсчисленныеООСМС КАК ВТИсчисленныеООСМС
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	СУММА(ДоходыПоПодразделениям.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	СУММА(ДоходыПоПодразделениям.НеоблагаемыйДоход) КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
        |
		|СГРУППИРОВАТЬ ПО
		|	ДоходыПоПодразделениям.Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеООСМСПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеООСМСПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеООСМСПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеООСМСПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектООСМСИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.НалогВзнос КАК РанееИсчисленныеООСМС,
		|	-ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеООСМСПоПодразделениям.НалогВзнос КАК ИсчисленныеООСМС,
		|	-ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияООСМС
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеООСМСПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.НалогВзнос <> 0)";
			
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТИсчисленныеООСМС");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеООСМСПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	РезультатЗапроса = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеООСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияООСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектООСМСИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеООСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	ДанныеОкругления = ПолучитьСпособОкругленияСПериодом(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС);
	СпособОкругления = ДанныеОкругления.СпособОкругления;
	ПериодОкругления = ДанныеОкругления.Период;
	
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	Если ПериодОкругления >= '20220101' Тогда
		// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
		ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
		ПравилоОкругления = ОписаниеСпособаОкругления.ПравилоОкругления;		
	Иначе
		ТочностьОкругления = 1;
		ПравилоОкругления = Перечисления.ПравилаОкругленияПриРасчетеЗарплаты.Авто;		
	КонецЕсли;

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругленияДляРаспределения = ТочностьОкругления - Цел(ТочностьОкругления);
	
	Если ТочностьОкругленияДляРаспределения = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругленияДляРаспределения <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияООСМС,ИсчисленныеООСМС", ТочностьРаспределения);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеООСМСПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияООСМСВЦеломЗаПериод,	ИсчисленныеООСМСВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектООСМСИсчисленныйРанее, 		 	РанееИсчисленныеООСМС,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияООСМС, 					ИсчисленныеООСМС");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0
			И (СтрокаТЗ.ИсчисленныеООСМС < 1 И СтрокаТЗ.ИсчисленныеООСМС > 0
				ИЛИ СтрокаТЗ.ИсчисленныеООСМС > -1 И СтрокаТЗ.ИсчисленныеООСМС < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеООСМС = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеООСМС = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеООСМС, ТочностьОкругления, ПравилоОкругления);
			
		КонецЕсли;
		
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьООСМСПосле2023(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) 
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	СоздатьВТИсключаемыеЛицаОСМС(МенеджерВременныхТаблиц, "ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС");
	
	ВидНалогаВзносаООСМС =  Перечисления.ВидыНалоговВзносовОтчислений.ООСМС;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходыПосле2023(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС, "ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС", Ложь);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ООСМС
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// - Исчисленные ООСМС
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	0 КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 10 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход 
		|	КОНЕЦ КАК ОбъектИсчисленияООСМС,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход 
        |	КОНЕЦ * ЕСТЬNULL(СтавкиОСМС.СтавкаОтчисления, 0) КАК ИсчисленныеООСМС
		|ПОМЕСТИТЬ ВТИсчисленныеООСМС
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМС КАК СтавкиОСМС
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОСМС.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиОСМС.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеООСМС.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеООСМС.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеООСМС.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеООСМС.ОбъектИсчисленияООСМС КАК ОбъектИсчисленияООСМС,
		|	ВТИсчисленныеООСМС.ИсчисленныеООСМС КАК ИсчисленныеООСМС
		|ИЗ
		|	ВТИсчисленныеООСМС КАК ВТИсчисленныеООСМС
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	СУММА(ДоходыПоПодразделениям.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	СУММА(ДоходыПоПодразделениям.НеоблагаемыйДоход) КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
        |
		|СГРУППИРОВАТЬ ПО
		|	ДоходыПоПодразделениям.Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеООСМСПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеООСМСПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеООСМСПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеООСМСПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектООСМСИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.НалогВзнос КАК РанееИсчисленныеООСМС,
		|	-ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеООСМСПоПодразделениям.НалогВзнос КАК ИсчисленныеООСМС,
		|	-ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияООСМС
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеООСМСПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.НалогВзнос <> 0)";
			
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТИсчисленныеООСМС");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеООСМСПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	РезультатЗапроса = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеООСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияООСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектООСМСИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеООСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	ДанныеОкругления = ПолучитьСпособОкругленияСПериодом(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС);
	СпособОкругления = ДанныеОкругления.СпособОкругления;
	ПериодОкругления = ДанныеОкругления.Период;
	
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	Если ПериодОкругления >= '20220101' Тогда
		// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
		ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
		ПравилоОкругления = ОписаниеСпособаОкругления.ПравилоОкругления;		
	Иначе
		ТочностьОкругления = 1;
		ПравилоОкругления = Перечисления.ПравилаОкругленияПриРасчетеЗарплаты.Авто;		
	КонецЕсли;

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругленияДляРаспределения = ТочностьОкругления - Цел(ТочностьОкругления);
	
	Если ТочностьОкругленияДляРаспределения = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругленияДляРаспределения <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияООСМС,ИсчисленныеООСМС", ТочностьРаспределения);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеООСМСПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияООСМСВЦеломЗаПериод,	ИсчисленныеООСМСВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектООСМСИсчисленныйРанее, 		 	РанееИсчисленныеООСМС,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияООСМС, 					ИсчисленныеООСМС");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0
			И (СтрокаТЗ.ИсчисленныеООСМС < 1 И СтрокаТЗ.ИсчисленныеООСМС > 0
				ИЛИ СтрокаТЗ.ИсчисленныеООСМС > -1 И СтрокаТЗ.ИсчисленныеООСМС < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеООСМС = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеООСМС = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеООСМС, ТочностьОкругления, ПравилоОкругления);
			
		КонецЕсли;
		
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьООСМСПосле2026(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) 
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	СоздатьВТИсключаемыеЛицаОСМС(МенеджерВременныхТаблиц, "ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС");
	
	ВидНалогаВзносаООСМС =  Перечисления.ВидыНалоговВзносовОтчислений.ООСМС;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
    ПараметрыПолученияДанных = Новый Структура("Организация, ВидНалогаВзносаОтчисления, МесяцНачисления", Организация, ВидНалогаВзносаООСМС, МесяцНачисления);
	СоздатьВТДоходыПосле2026(МенеджерВременныхТаблиц, ПараметрыПолученияДанных, "ВТИсключаемыеФизическиеЛицаПриРасчетеООСМС", Ложь);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ООСМС
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// - Исчисленные ООСМС
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	0 КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 40 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход 
		|	КОНЕЦ КАК ОбъектИсчисленияООСМС,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход 
        |	КОНЕЦ * ЕСТЬNULL(СтавкиОСМС.СтавкаОтчисления, 0) КАК ИсчисленныеООСМС
		|ПОМЕСТИТЬ ВТИсчисленныеООСМС
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМС КАК СтавкиОСМС
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОСМС.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиОСМС.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеООСМС.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеООСМС.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеООСМС.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеООСМС.ОбъектИсчисленияООСМС КАК ОбъектИсчисленияООСМС,
		|	ВТИсчисленныеООСМС.ИсчисленныеООСМС КАК ИсчисленныеООСМС
		|ИЗ
		|	ВТИсчисленныеООСМС КАК ВТИсчисленныеООСМС
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	СУММА(ДоходыПоПодразделениям.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	СУММА(ДоходыПоПодразделениям.НеоблагаемыйДоход) КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
        |
		|СГРУППИРОВАТЬ ПО
		|	ДоходыПоПодразделениям.Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеООСМСПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеООСМСПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеООСМСПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеООСМСПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектООСМСИсчисленныйРанее,
		|	ИсчисленныеООСМСПоПодразделениям.НалогВзнос КАК РанееИсчисленныеООСМС,
		|	-ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеООСМСПоПодразделениям.НалогВзнос КАК ИсчисленныеООСМС,
		|	-ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияООСМС
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеООСМСПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеООСМСПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеООСМСПоПодразделениям.НалогВзнос <> 0)";
			
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТИсчисленныеООСМС");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеООСМСПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	РезультатЗапроса = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеООСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияООСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектООСМСИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеООСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	ДанныеОкругления = ПолучитьСпособОкругленияСПериодом(МенеджерВременныхТаблиц, ВидНалогаВзносаООСМС);
	СпособОкругления = ДанныеОкругления.СпособОкругления;
	ПериодОкругления = ДанныеОкругления.Период;
	
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	Если ПериодОкругления >= '20220101' Тогда
		// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
		ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
		ПравилоОкругления = ОписаниеСпособаОкругления.ПравилоОкругления;		
	Иначе
		ТочностьОкругления = 1;
		ПравилоОкругления = Перечисления.ПравилаОкругленияПриРасчетеЗарплаты.Авто;		
	КонецЕсли;

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругленияДляРаспределения = ТочностьОкругления - Цел(ТочностьОкругления);
	
	Если ТочностьОкругленияДляРаспределения = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругленияДляРаспределения <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияООСМС,ИсчисленныеООСМС", ТочностьРаспределения);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеООСМСПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияООСМСВЦеломЗаПериод,	ИсчисленныеООСМСВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектООСМСИсчисленныйРанее, 		 	РанееИсчисленныеООСМС,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияООСМС, 					ИсчисленныеООСМС");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	                                                                                                     
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0
			И (СтрокаТЗ.ИсчисленныеООСМС < 1 И СтрокаТЗ.ИсчисленныеООСМС > 0
				ИЛИ СтрокаТЗ.ИсчисленныеООСМС > -1 И СтрокаТЗ.ИсчисленныеООСМС < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеООСМС = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеООСМС = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеООСМС, ТочностьОкругления, ПравилоОкругления);
			
		КонецЕсли;
		
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьВОСМСДо2019(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;

	СоздатьВТИсключаемыеЛицаОСМС(МенеджерВременныхТаблиц, "ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС");
	
	ВидНалогаВзносаВОСМС =  Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаВОСМС, "ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС", Ложь);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ВОСМС
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаВОСМС);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	// - Исчисленные ВОСМС
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 15 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход
		|	КОНЕЦ КАК ОбъектИсчисленияВОСМС,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход
		|	КОНЕЦ * ЕСТЬNULL(СтавкиОСМС.СтавкаВзносы, 0) КАК ИсчисленныеВОСМС
		|ПОМЕСТИТЬ ВТИсчисленныеВОСМС
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМС КАК СтавкиОСМС
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОСМС.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиОСМС.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеВОСМС.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМС.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеВОСМС.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеВОСМС.ОбъектИсчисленияВОСМС КАК ОбъектИсчисленияВОСМС,
		|	ВТИсчисленныеВОСМС.ИсчисленныеВОСМС КАК ИсчисленныеВОСМС
		|ИЗ
		|	ВТИсчисленныеВОСМС КАК ВТИсчисленныеВОСМС
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеВОСМСПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеВОСМСПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектВОСМСИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.НалогВзнос КАК РанееИсчисленныеВОСМС,
		|	-ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеВОСМСПоПодразделениям.НалогВзнос КАК ИсчисленныеВОСМС,
		|	-ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияВОСМС
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеВОСМСПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.НалогВзнос <> 0)";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеВОСМСПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	РезультатЗапроса = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеВОСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияВОСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектВОСМСИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияВОСМС,ИсчисленныеВОСМС");
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеВОСМСПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияВОСМСВЦеломЗаПериод,	ИсчисленныеВОСМСВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектВОСМСИсчисленныйРанее, 		 	РанееИсчисленныеВОСМС,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияВОСМС, 					ИсчисленныеВОСМС");
	
	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаВОСМС);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		СтрокаТЗ.ИсчисленныеВОСМС = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеВОСМС, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьВОСМСПосле2020(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина, ДополнительныеПараметры = Неопределено) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;

	Если ДополнительныеПараметры <> Неопределено Тогда
		Если ДополнительныеПараметры.Свойство("ТолькоДоходОтНалоговогоАгента") Тогда
			ТолькоДоходОтНалоговогоАгента = ДополнительныеПараметры.ТолькоДоходОтНалоговогоАгента;	
		КонецЕсли;
	Иначе
		ТолькоДоходОтНалоговогоАгента = Ложь;
	КонецЕсли;

	ПрименятьКорректировкуПрочихНалоговВзносовОтчислений = ЗарплатаКадрыРКПовтИсп.ПрименятьКорректировкуПрочихНалоговВзносовОтчислений(ЗарплатаКадрыПовтИсп.ГоловнаяОрганизация(Организация), МесяцНачисления);
	
	Если ТолькоДоходОтНалоговогоАгента Тогда
		ПрименятьКорректировкуПрочихНалоговВзносовОтчислений = Ложь;	
	КонецЕсли;
	
	Если ПрименятьКорректировкуПрочихНалоговВзносовОтчислений Тогда
		ПолеКорректировки = "- ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0)";
	Иначе
		ПолеКорректировки = "0";
	КонецЕсли;
	
	СоздатьВТИсключаемыеЛицаОСМС(МенеджерВременныхТаблиц, "ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС");
	
	ВидНалогаВзносаВОСМС =  Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаВОСМС, "ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС", Ложь);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ВОСМС
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаВОСМС);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	СоздатьВТДанныеПоКорректировкеДоходаИПН(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет, ИсключатьДоходыРегистратора, ПрименятьКорректировкуПрочихНалоговВзносовОтчислений);
		
	// - Исчисленные ВОСМС
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	0 КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 10 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|" + ?(ПрименятьКорректировкуПрочихНалоговВзносовОтчислений, "
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДанныеИПН.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДанныеИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|	СУММА(ДанныеИПН.СуммаКорректировки) КАК СуммаКорректировки
		|ПОМЕСТИТЬ ВТСуммыКорректировки
		|ИЗ
		|	(ВЫБРАТЬ
		|		ИсчисленныйИПН.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|		ИсчисленныйИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|		ЕСТЬNULL(ИсчисленныйИПН.ПримененнаяКорректировка, 0) КАК СуммаКорректировки
		|	ИЗ
		|		ВТИсчисленныйИПН КАК ИсчисленныйИПН
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		Доходы.МесяцНалоговогоПериода,
		|		Доходы.ФизическоеЛицо,
		|		ЕСТЬNULL(ДанныеПоКорректировкеДоходаИПН.ПримененнаяКорректировка, 0)
		|	ИЗ
		|		ВТДоходы КАК Доходы
		|			ЛЕВОЕ СОЕДИНЕНИЕ ВТДанныеПоКорректировкеДоходаИПН КАК ДанныеПоКорректировкеДоходаИПН
		|			ПО Доходы.МесяцНалоговогоПериода = ДанныеПоКорректировкеДоходаИПН.МесяцНалоговогоПериода
		|				И Доходы.ФизическоеЛицо = ДанныеПоКорректировкеДоходаИПН.ФизическоеЛицо) КАК ДанныеИПН
		|
		|СГРУППИРОВАТЬ ПО
		|	ДанныеИПН.МесяцНалоговогоПериода,
		|	ДанныеИПН.ФизическоеЛицо", "") + "
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	МАКСИМУМ(Доходы.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода, 0)) КАК МинимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода, 0)) КАК МаксимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(" + ПолеКорректировки + ") КАК СуммаКорректировки,
		|	ЕСТЬNULL(СтавкиОСМС.СтавкаВзносы, 0) КАК Ставка,
		|	МАКСИМУМ(ВЫБОР КОГДА ДругиеВидыДоходов.ВидДохода ЕСТЬ NULL ТОГДА ЛОЖЬ ИНАЧЕ ИСТИНА КОНЕЦ) КАК ЕстьНесколькоВидовДоходов,
		|	МАКСИМУМ(ВЫБОР КОГДА НЕ ДругиеВидыДоходов.ВидДохода ЕСТЬ NULL ИЛИ РанееИсчисленныеНалогиВзносы.ВОСМСПредыдущегоМестаРаботы ЕСТЬ NULL ТОГДА 0 ИНАЧЕ РанееИсчисленныеНалогиВзносы.ВОСМСПредыдущегоМестаРаботы КОНЕЦ) КАК ВОСМСПредыдущегоМестаРаботы,
		|	0 КАК ОбъектИсчисленияВОСМС,
		|	0 КАК ИсчисленныеВОСМС
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМС КАК СтавкиОСМС
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОСМС.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиОСМС.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДоходы КАК ДругиеВидыДоходов
		|		ПО ДругиеВидыДоходов.МесяцНалоговогоПериода = Доходы.МесяцНалоговогоПериода
		|			И ДругиеВидыДоходов.ФизическоеЛицо = Доходы.ФизическоеЛицо
		|			И НЕ ДругиеВидыДоходов.ВидДохода = Доходы.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРанееИсчисленныеНалогиВзносы КАК РанееИсчисленныеНалогиВзносы
		|		ПО Доходы.МесяцНалоговогоПериода = РанееИсчисленныеНалогиВзносы.МесяцНалоговогоПериода
		|			И РанееИсчисленныеНалогиВзносы.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ВОСМС)
		|			И Доходы.ФизическоеЛицо = РанееИсчисленныеНалогиВзносы.ФизическоеЛицо
		|" + ?(ПрименятьКорректировкуПрочихНалоговВзносовОтчислений, "
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСуммыКорректировки КАК СуммыКорректировки
		|		ПО Доходы.МесяцНалоговогоПериода = СуммыКорректировки.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = СуммыКорректировки.ФизическоеЛицо
		|			И Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)", "") + "
		|СГРУППИРОВАТЬ ПО
		|	Доходы.МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо,
		|	Доходы.ВидДохода,
		|	ЕСТЬNULL(СтавкиОСМС.СтавкаВзносы, 0)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Доходы.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеВОСМСПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеВОСМСПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектВОСМСИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.НалогВзнос КАК РанееИсчисленныеВОСМС,
		|	-ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеВОСМСПоПодразделениям.НалогВзнос КАК ИсчисленныеВОСМС,
		|	-ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияВОСМС
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеВОСМСПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.НалогВзнос <> 0)";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТДанныеПоКорректировкеДоходаИПН");
	
	Если ПрименятьКорректировкуПрочихНалоговВзносовОтчислений Тогда
		УничтожитьВТ.Добавить("ВТСуммыКорректировки");
	КонецЕсли;
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеВОСМСПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	РезультатЗапроса.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатЗапроса.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатЗапроса.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатЗапроса.Колонки.Добавить("ОбъектИсчисленияВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИсчисленныеВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаДляОбработки = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеВОСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияВОСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектВОСМСИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ВОСМСПредыдущегоМестаРаботы", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам = Новый ТаблицаЗначений;
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ОбъектИсчисления", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Индексы.Добавить("ФизическоеЛицо, МесяцНалоговогоПериода");
	
	СтруктураПоискаПоФизЛицам = Новый Структура("ФизическоеЛицо, МесяцНалоговогоПериода");
	
	Для Каждого СтрокаТаблицы Из ТаблицаДляОбработки Цикл
		
		ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
		
		// корректируем максимальный доход только в окончательном расчете, если есть несколько видов дохода в месяце начисления
		НеобходимаКорректировкаМакисмальногоОграничения = ОкончательныйРасчет И СтрокаТаблицы.ЕстьНесколькоВидовДоходов;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			ЗаполнитьЗначенияСвойств(СтруктураПоискаПоФизЛицам, СтрокаТаблицы);

			// сумма взносов исчисленная
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			
			Если МассивВзносов.Количество() > 0 Тогда
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = МассивВзносов[0].ОбъектИсчисления;
			Иначе
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			КонецЕсли;
			
		Иначе
			
			ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			
		КонецЕсли;
		
		МаксимальныйРазмерОрганиченияДохода = СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода - ОбъектИсчисленияПоДругимВидамВДанномРасчете - ?(СтрокаТаблицы.Ставка = 0, 0, СтрокаТаблицы.ВОСМСПредыдущегоМестаРаботы / СтрокаТаблицы.Ставка);
		
		Если СтрокаТаблицы.ОблагаемыйДоход <= 0 Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = 0;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход + СтрокаТаблицы.СуммаКорректировки < СтрокаТаблицы.МинимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = 0;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход + СтрокаТаблицы.СуммаКорректировки >= МаксимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = МаксимальныйРазмерОрганиченияДохода;
			
		Иначе
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = СтрокаТаблицы.ОблагаемыйДоход + СтрокаТаблицы.СуммаКорректировки;
			
		КонецЕсли;
		
		СтрокаТаблицы.ИсчисленныеВОСМС = СтрокаТаблицы.ОбъектИсчисленияВОСМС * СтрокаТаблицы.Ставка;	
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			Если МассивВзносов.Количество() > 0 Тогда
				СтрокаВзносовТаблицаВзносовПоФизЛицам = МассивВзносов[0];
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления + СтрокаТаблицы.ОбъектИсчисленияВОСМС;
			Иначе
				СтрокаВзносовТаблицаВзносовПоФизЛицам = ТаблицаВзносовПоФизЛицамПоДругимДоходам.Добавить();
				СтрокаВзносовТаблицаВзносовПоФизЛицам.МесяцНалоговогоПериода = СтрокаТаблицы.МесяцНалоговогоПериода;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ФизическоеЛицо = СтрокаТаблицы.ФизическоеЛицо;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаТаблицы.ОбъектИсчисленияВОСМС;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаДляОбработки, РезультатЗапроса);
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияВОСМС,ИсчисленныеВОСМС", 0);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеВОСМСПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияВОСМСВЦеломЗаПериод,	ИсчисленныеВОСМСВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектВОСМСИсчисленныйРанее, 		 	РанееИсчисленныеВОСМС,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияВОСМС, 					ИсчисленныеВОСМС");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0 
			И (СтрокаТЗ.ИсчисленныеВОСМС < 1 И СтрокаТЗ.ИсчисленныеВОСМС > 0
				ИЛИ СтрокаТЗ.ИсчисленныеВОСМС > -1 И СтрокаТЗ.ИсчисленныеВОСМС < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеВОСМС = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеВОСМС = Окр(СтрокаТЗ.ИсчисленныеВОСМС, 0, РежимОкругления.Окр15как20);
			
		КонецЕсли;
		
	КонецЦикла; 

	// для вычетов ИПН передаем общую таблицу округленных сумм
	ТаблицаДляВычетовИПН = РезультатЗапроса.Скопировать();
	
	Для каждого СтрокаТЗ Из ТаблицаДляВычетовИПН Цикл
		СтрокаТЗ.ИсчисленныеВОСМС = Окр(СтрокаТЗ.ИсчисленныеВОСМС, 0, РежимОкругления.Окр15как20);
	КонецЦикла; 
	
	Запрос.УстановитьПараметр("ИсчисленныеВОСМС", ТаблицаДляВычетовИПН);
	
	Запрос.Текст = "
		|ВЫБРАТЬ
		|	ВТИсчисленныеВОСМС.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМС.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеВОСМС.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеВОСМС.ОбъектИсчисленияВОСМС КАК ОбъектИсчисленияВОСМС,
		|	ВТИсчисленныеВОСМС.ИсчисленныеВОСМС КАК ИсчисленныеВОСМС
		|ПОМЕСТИТЬ ВТИсчисленныеВОСМСПоПодразделениям
		|ИЗ
		|	&ИсчисленныеВОСМС КАК ВТИсчисленныеВОСМС
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисленияВОСМС) КАК ОбъектИсчисленияВОСМС,
		|	СУММА(ВТИсчисленныеВОСМСПоПодразделениям.ИсчисленныеВОСМС) КАК ИсчисленныеВОСМС
		|ПОМЕСТИТЬ ВТИсчисленныеВОСМС" + ?(ТолькоДоходОтНалоговогоАгента, "ДоходОтНалоговогоАгента", "") + "
		|ИЗ
		|	ВТИсчисленныеВОСМСПоПодразделениям КАК ВТИсчисленныеВОСМСПоПодразделениям
		|" + ?(ТолькоДоходОтНалоговогоАгента, "
		|ГДЕ
		|	ВТИсчисленныеВОСМСПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтНалоговогоАгента)
		|", "") + "
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ВидДохода
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ВТИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ВидДохода
		|";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеВОСМСПоПодразделениям");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьВОСМСПосле2021(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	СоздатьВТИсключаемыеЛицаОСМС(МенеджерВременныхТаблиц, "ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС");
	
	ВидНалогаВзносаВОСМС =  Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаВОСМС, "ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС", Ложь);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ВОСМС
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаВОСМС);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	// - Исчисленные ВОСМС
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	0 КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 10 КАК МаксимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 1.4 КАК ОбъектИсчисленияДляИП
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	МАКСИМУМ(ВЫБОР КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства) ТОГДА ЕСТЬNULL(РазмерыОграниченийПоДоходам.ОбъектИсчисленияДляИП, 0) ИНАЧЕ Доходы.ОблагаемыйДоход КОНЕЦ) КАК ОблагаемыйДоход,
		|	МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода, 0)) КАК МинимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода, 0)) КАК МаксимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(0) КАК СуммаКорректировки,
		|	ЕСТЬNULL(СтавкиОСМС.СтавкаВзносы, 0) КАК Ставка,
		|	МАКСИМУМ(ВЫБОР КОГДА ДругиеВидыДоходов.ВидДохода ЕСТЬ NULL ТОГДА ЛОЖЬ ИНАЧЕ ИСТИНА КОНЕЦ) КАК ЕстьНесколькоВидовДоходов,
		|	МАКСИМУМ(ВЫБОР КОГДА НЕ ДругиеВидыДоходов.ВидДохода ЕСТЬ NULL ИЛИ РанееИсчисленныеНалогиВзносы.ВОСМСПредыдущегоМестаРаботы ЕСТЬ NULL ТОГДА 0 ИНАЧЕ РанееИсчисленныеНалогиВзносы.ВОСМСПредыдущегоМестаРаботы КОНЕЦ) КАК ВОСМСПредыдущегоМестаРаботы,
		|	0 КАК ОбъектИсчисленияВОСМС,
		|	0 КАК ИсчисленныеВОСМС
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМС КАК СтавкиОСМС
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОСМС.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиОСМС.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДоходы КАК ДругиеВидыДоходов
		|		ПО ДругиеВидыДоходов.МесяцНалоговогоПериода = Доходы.МесяцНалоговогоПериода
		|			И ДругиеВидыДоходов.ФизическоеЛицо = Доходы.ФизическоеЛицо
		|			И НЕ ДругиеВидыДоходов.ВидДохода = Доходы.ВидДохода
		|			И НЕ ДругиеВидыДоходов.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРанееИсчисленныеНалогиВзносы КАК РанееИсчисленныеНалогиВзносы
		|		ПО Доходы.МесяцНалоговогоПериода = РанееИсчисленныеНалогиВзносы.МесяцНалоговогоПериода
		|			И РанееИсчисленныеНалогиВзносы.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ВОСМС)
		|			И Доходы.ФизическоеЛицо = РанееИсчисленныеНалогиВзносы.ФизическоеЛицо
		|СГРУППИРОВАТЬ ПО
		|	Доходы.МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо,
		|	Доходы.ВидДохода,
		|	ЕСТЬNULL(СтавкиОСМС.СтавкаВзносы, 0)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Доходы.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеВОСМСПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеВОСМСПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектВОСМСИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.НалогВзнос КАК РанееИсчисленныеВОСМС,
		|	-ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеВОСМСПоПодразделениям.НалогВзнос КАК ИсчисленныеВОСМС,
		|	-ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияВОСМС
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеВОСМСПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.НалогВзнос <> 0)
		|	И НЕ ИсчисленныеВОСМСПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеВОСМСПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	РезультатЗапроса.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатЗапроса.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатЗапроса.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатЗапроса.Колонки.Добавить("ОбъектИсчисленияВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИсчисленныеВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаДляОбработки = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеВОСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияВОСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектВОСМСИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ВОСМСПредыдущегоМестаРаботы", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам = Новый ТаблицаЗначений;
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ОбъектИсчисления", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Индексы.Добавить("ФизическоеЛицо, МесяцНалоговогоПериода");
	
	СтруктураПоискаПоФизЛицам = Новый Структура("ФизическоеЛицо, МесяцНалоговогоПериода");
	
	Для Каждого СтрокаТаблицы Из ТаблицаДляОбработки Цикл
		
		ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
		
		// корректируем максимальный доход только в окончательном расчете, если есть несколько видов дохода в месяце начисления
		НеобходимаКорректировкаМакисмальногоОграничения = ОкончательныйРасчет И СтрокаТаблицы.ЕстьНесколькоВидовДоходов;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			ЗаполнитьЗначенияСвойств(СтруктураПоискаПоФизЛицам, СтрокаТаблицы);

			// сумма взносов исчисленная
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			
			Если МассивВзносов.Количество() > 0 Тогда
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = МассивВзносов[0].ОбъектИсчисления;
			Иначе
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			КонецЕсли;
			
		Иначе
			
			ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			
		КонецЕсли;
		
		МаксимальныйРазмерОрганиченияДохода = СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода - ОбъектИсчисленияПоДругимВидамВДанномРасчете - ?(СтрокаТаблицы.Ставка = 0, 0, СтрокаТаблицы.ВОСМСПредыдущегоМестаРаботы / СтрокаТаблицы.Ставка);
		
		Если СтрокаТаблицы.ОблагаемыйДоход <= 0 Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = 0;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход + СтрокаТаблицы.СуммаКорректировки < СтрокаТаблицы.МинимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = 0;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход + СтрокаТаблицы.СуммаКорректировки >= МаксимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = МаксимальныйРазмерОрганиченияДохода;
			
		Иначе
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = СтрокаТаблицы.ОблагаемыйДоход + СтрокаТаблицы.СуммаКорректировки;
			
		КонецЕсли;
		
		СтрокаТаблицы.ИсчисленныеВОСМС = СтрокаТаблицы.ОбъектИсчисленияВОСМС * СтрокаТаблицы.Ставка;	
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			Если МассивВзносов.Количество() > 0 Тогда
				СтрокаВзносовТаблицаВзносовПоФизЛицам = МассивВзносов[0];
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления + СтрокаТаблицы.ОбъектИсчисленияВОСМС;
			Иначе
				СтрокаВзносовТаблицаВзносовПоФизЛицам = ТаблицаВзносовПоФизЛицамПоДругимДоходам.Добавить();
				СтрокаВзносовТаблицаВзносовПоФизЛицам.МесяцНалоговогоПериода = СтрокаТаблицы.МесяцНалоговогоПериода;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ФизическоеЛицо = СтрокаТаблицы.ФизическоеЛицо;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаТаблицы.ОбъектИсчисленияВОСМС;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаДляОбработки, РезультатЗапроса);
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияВОСМС,ИсчисленныеВОСМС", 0);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеВОСМСПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияВОСМСВЦеломЗаПериод,	ИсчисленныеВОСМСВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектВОСМСИсчисленныйРанее, 		 	РанееИсчисленныеВОСМС,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияВОСМС, 					ИсчисленныеВОСМС");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0 
			И (СтрокаТЗ.ИсчисленныеВОСМС < 1 И СтрокаТЗ.ИсчисленныеВОСМС > 0
				ИЛИ СтрокаТЗ.ИсчисленныеВОСМС > -1 И СтрокаТЗ.ИсчисленныеВОСМС < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеВОСМС = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеВОСМС = Окр(СтрокаТЗ.ИсчисленныеВОСМС, 0, РежимОкругления.Окр15как20);
			
		КонецЕсли;
		
	КонецЦикла; 

	// для вычетов ИПН передаем общую таблицу округленных сумм
	ТаблицаДляВычетовИПН = РезультатЗапроса.Скопировать();
	
	Для каждого СтрокаТЗ Из ТаблицаДляВычетовИПН Цикл
		СтрокаТЗ.ИсчисленныеВОСМС = Окр(СтрокаТЗ.ИсчисленныеВОСМС, 0, РежимОкругления.Окр15как20);
	КонецЦикла; 
	
	Запрос.УстановитьПараметр("ИсчисленныеВОСМС", ТаблицаДляВычетовИПН);
	
	Запрос.Текст = "
		|ВЫБРАТЬ
		|	ВТИсчисленныеВОСМС.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМС.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеВОСМС.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеВОСМС.ОбъектИсчисленияВОСМС КАК ОбъектИсчисленияВОСМС,
		|	ВТИсчисленныеВОСМС.ИсчисленныеВОСМС КАК ИсчисленныеВОСМС
		|ПОМЕСТИТЬ ВТИсчисленныеВОСМСПоПодразделениям
		|ИЗ
		|	&ИсчисленныеВОСМС КАК ВТИсчисленныеВОСМС
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисленияВОСМС) КАК ОбъектИсчисленияВОСМС,
		|	СУММА(ВТИсчисленныеВОСМСПоПодразделениям.ИсчисленныеВОСМС) КАК ИсчисленныеВОСМС
		|ПОМЕСТИТЬ ВТИсчисленныеВОСМС
		|ИЗ
		|	ВТИсчисленныеВОСМСПоПодразделениям КАК ВТИсчисленныеВОСМСПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ВидДохода
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ВТИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ВидДохода
		|";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеВОСМСПоПодразделениям");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьВОСМСПосле2022(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	СоздатьВТИсключаемыеЛицаОСМС(МенеджерВременныхТаблиц, "ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС");
	
	ВидНалогаВзносаВОСМС =  Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаВОСМС, "ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС", Ложь);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ВОСМС
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаВОСМС);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	// - Исчисленные ВОСМС
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	0 КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 10 КАК МаксимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 1.4 КАК ОбъектИсчисленияДляИП
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	МАКСИМУМ(ВЫБОР КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства) ТОГДА ЕСТЬNULL(РазмерыОграниченийПоДоходам.ОбъектИсчисленияДляИП, 0) ИНАЧЕ Доходы.ОблагаемыйДоход КОНЕЦ) КАК ОблагаемыйДоход,
		|	МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода, 0)) КАК МинимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода, 0)) КАК МаксимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(0) КАК СуммаКорректировки,
		|	ЕСТЬNULL(СтавкиОСМС.СтавкаВзносы, 0) КАК Ставка,
		|	МАКСИМУМ(ВЫБОР КОГДА ДругиеВидыДоходов.ВидДохода ЕСТЬ NULL ТОГДА ЛОЖЬ ИНАЧЕ ИСТИНА КОНЕЦ) КАК ЕстьНесколькоВидовДоходов,
		|	МАКСИМУМ(ВЫБОР КОГДА НЕ ДругиеВидыДоходов.ВидДохода ЕСТЬ NULL ИЛИ РанееИсчисленныеНалогиВзносы.ВОСМСПредыдущегоМестаРаботы ЕСТЬ NULL ТОГДА 0 ИНАЧЕ РанееИсчисленныеНалогиВзносы.ВОСМСПредыдущегоМестаРаботы КОНЕЦ) КАК ВОСМСПредыдущегоМестаРаботы,
		|	0 КАК ОбъектИсчисленияВОСМС,
		|	0 КАК ИсчисленныеВОСМС
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМС КАК СтавкиОСМС
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОСМС.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиОСМС.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДоходы КАК ДругиеВидыДоходов
		|		ПО ДругиеВидыДоходов.МесяцНалоговогоПериода = Доходы.МесяцНалоговогоПериода
		|			И ДругиеВидыДоходов.ФизическоеЛицо = Доходы.ФизическоеЛицо
		|			И НЕ ДругиеВидыДоходов.ВидДохода = Доходы.ВидДохода
		|			И НЕ ДругиеВидыДоходов.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРанееИсчисленныеНалогиВзносы КАК РанееИсчисленныеНалогиВзносы
		|		ПО Доходы.МесяцНалоговогоПериода = РанееИсчисленныеНалогиВзносы.МесяцНалоговогоПериода
		|			И РанееИсчисленныеНалогиВзносы.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ВОСМС)
		|			И Доходы.ФизическоеЛицо = РанееИсчисленныеНалогиВзносы.ФизическоеЛицо
		|СГРУППИРОВАТЬ ПО
		|	Доходы.МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо,
		|	Доходы.ВидДохода,
		|	ЕСТЬNULL(СтавкиОСМС.СтавкаВзносы, 0)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Доходы.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	СУММА(ДоходыПоПодразделениям.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	СУММА(ДоходыПоПодразделениям.НеоблагаемыйДоход) КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
        |
		|СГРУППИРОВАТЬ ПО
		|	ДоходыПоПодразделениям.Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеВОСМСПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеВОСМСПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектВОСМСИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.НалогВзнос КАК РанееИсчисленныеВОСМС,
		|	-ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеВОСМСПоПодразделениям.НалогВзнос КАК ИсчисленныеВОСМС,
		|	-ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияВОСМС
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеВОСМСПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.НалогВзнос <> 0)
		|	И НЕ ИсчисленныеВОСМСПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеВОСМСПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	РезультатЗапроса.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатЗапроса.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатЗапроса.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатЗапроса.Колонки.Добавить("ОбъектИсчисленияВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИсчисленныеВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаДляОбработки = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеВОСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияВОСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектВОСМСИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ВОСМСПредыдущегоМестаРаботы", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам = Новый ТаблицаЗначений;
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ОбъектИсчисления", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Индексы.Добавить("ФизическоеЛицо, МесяцНалоговогоПериода");
	
	СтруктураПоискаПоФизЛицам = Новый Структура("ФизическоеЛицо, МесяцНалоговогоПериода");
	ДанныеОкругления = ПолучитьСпособОкругленияСПериодом(МенеджерВременныхТаблиц, ВидНалогаВзносаВОСМС);
	СпособОкругления = ДанныеОкругления.СпособОкругления;
	ПериодОкругления = ДанныеОкругления.Период;
	
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	Если ПериодОкругления >= '20220101' Тогда
		// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
		ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
		ПравилоОкругления = ОписаниеСпособаОкругления.ПравилоОкругления;		
	Иначе
		ТочностьОкругления = 1;
		ПравилоОкругления = Перечисления.ПравилаОкругленияПриРасчетеЗарплаты.Авто;		
	КонецЕсли;

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругленияДляРаспределения = ТочностьОкругления - Цел(ТочностьОкругления);
	
	Если ТочностьОкругленияДляРаспределения = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругленияДляРаспределения <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;
	
	МаксимальныйВОСМСПриДостиженииПредела = 0;
	
	Для Каждого СтрокаТаблицы Из ТаблицаДляОбработки Цикл
		
		ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
		
		// корректируем максимальный доход только в окончательном расчете, если есть несколько видов дохода в месяце начисления
		НеобходимаКорректировкаМакисмальногоОграничения = ОкончательныйРасчет И СтрокаТаблицы.ЕстьНесколькоВидовДоходов;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			ЗаполнитьЗначенияСвойств(СтруктураПоискаПоФизЛицам, СтрокаТаблицы);

			// сумма взносов исчисленная
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			
			Если МассивВзносов.Количество() > 0 Тогда
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = МассивВзносов[0].ОбъектИсчисления;
			Иначе
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			КонецЕсли;
			
		Иначе
			
			ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			
		КонецЕсли;
		
		МаксимальныйРазмерОрганиченияДохода = СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода - ОбъектИсчисленияПоДругимВидамВДанномРасчете - ?(СтрокаТаблицы.Ставка = 0, 0, СтрокаТаблицы.ВОСМСПредыдущегоМестаРаботы / СтрокаТаблицы.Ставка);
		
		Если СтрокаТаблицы.ОблагаемыйДоход <= 0 Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = 0;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход + СтрокаТаблицы.СуммаКорректировки < СтрокаТаблицы.МинимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = 0;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход + СтрокаТаблицы.СуммаКорректировки >= МаксимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = МаксимальныйРазмерОрганиченияДохода;
			
			ВОСМСРанееИсчисленный = ЗарплатаКадрыКлиентСервер.Округлить((СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода - МаксимальныйРазмерОрганиченияДохода) * СтрокаТаблицы.Ставка, ТочностьОкругления, ПравилоОкругления);	
			
			МаксимальныйВОСМСПриДостиженииПредела = СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода * СтрокаТаблицы.Ставка - ВОСМСРанееИсчисленный;
			
		Иначе
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = СтрокаТаблицы.ОблагаемыйДоход + СтрокаТаблицы.СуммаКорректировки;
			
		КонецЕсли;
		
		СтрокаТаблицы.ИсчисленныеВОСМС = СтрокаТаблицы.ОбъектИсчисленияВОСМС * СтрокаТаблицы.Ставка;	

		Если НЕ МаксимальныйВОСМСПриДостиженииПредела = 0
			И СтрокаТаблицы.ИсчисленныеВОСМС > МаксимальныйВОСМСПриДостиженииПредела Тогда
			
			СтрокаТаблицы.ИсчисленныеВОСМС = МаксимальныйВОСМСПриДостиженииПредела;	
			МаксимальныйВОСМСПриДостиженииПредела = 0;

		КонецЕсли;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			Если МассивВзносов.Количество() > 0 Тогда
				СтрокаВзносовТаблицаВзносовПоФизЛицам = МассивВзносов[0];
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления + СтрокаТаблицы.ОбъектИсчисленияВОСМС;
			Иначе
				СтрокаВзносовТаблицаВзносовПоФизЛицам = ТаблицаВзносовПоФизЛицамПоДругимДоходам.Добавить();
				СтрокаВзносовТаблицаВзносовПоФизЛицам.МесяцНалоговогоПериода = СтрокаТаблицы.МесяцНалоговогоПериода;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ФизическоеЛицо = СтрокаТаблицы.ФизическоеЛицо;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаТаблицы.ОбъектИсчисленияВОСМС;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаДляОбработки, РезультатЗапроса);
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияВОСМС,ИсчисленныеВОСМС", ТочностьРаспределения);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеВОСМСПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияВОСМСВЦеломЗаПериод,	ИсчисленныеВОСМСВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектВОСМСИсчисленныйРанее, 		 	РанееИсчисленныеВОСМС,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияВОСМС, 					ИсчисленныеВОСМС");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0 
			И (СтрокаТЗ.ИсчисленныеВОСМС < 1 И СтрокаТЗ.ИсчисленныеВОСМС > 0
				ИЛИ СтрокаТЗ.ИсчисленныеВОСМС > -1 И СтрокаТЗ.ИсчисленныеВОСМС < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеВОСМС = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеВОСМС = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеВОСМС, ТочностьОкругления, ПравилоОкругления);
			
		КонецЕсли;
		
	КонецЦикла; 

	// для вычетов ИПН передаем общую таблицу округленных сумм
	ТаблицаДляВычетовИПН = РезультатЗапроса.Скопировать();
	
	Для каждого СтрокаТЗ Из ТаблицаДляВычетовИПН Цикл
		СтрокаТЗ.ИсчисленныеВОСМС = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеВОСМС, ТочностьОкругления, ПравилоОкругления);
	КонецЦикла; 
	
	Запрос.УстановитьПараметр("ИсчисленныеВОСМС", ТаблицаДляВычетовИПН);
	
	Запрос.Текст = "
		|ВЫБРАТЬ
		|	ВТИсчисленныеВОСМС.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМС.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеВОСМС.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеВОСМС.ОбъектИсчисленияВОСМС КАК ОбъектИсчисленияВОСМС,
		|	ВТИсчисленныеВОСМС.ИсчисленныеВОСМС КАК ИсчисленныеВОСМС
		|ПОМЕСТИТЬ ВТИсчисленныеВОСМСПоПодразделениям
		|ИЗ
		|	&ИсчисленныеВОСМС КАК ВТИсчисленныеВОСМС
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисленияВОСМС) КАК ОбъектИсчисленияВОСМС,
		|	СУММА(ВТИсчисленныеВОСМСПоПодразделениям.ИсчисленныеВОСМС) КАК ИсчисленныеВОСМС
		|ПОМЕСТИТЬ ВТИсчисленныеВОСМС
		|ИЗ
		|	ВТИсчисленныеВОСМСПоПодразделениям КАК ВТИсчисленныеВОСМСПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ВидДохода
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ВТИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ВидДохода
		|";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеВОСМСПоПодразделениям");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьВОСМСПосле2023(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	СоздатьВТИсключаемыеЛицаОСМС(МенеджерВременныхТаблиц, "ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС");
	
	ВидНалогаВзносаВОСМС =  Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходыПосле2023(МенеджерВременныхТаблиц, ВидНалогаВзносаВОСМС, "ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС", Ложь);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ВОСМС
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаВОСМС);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// - Исчисленные ВОСМС
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	0 КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 10 КАК МаксимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 1.4 КАК ОбъектИсчисленияДляИП
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	МАКСИМУМ(ВЫБОР КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства) ТОГДА ЕСТЬNULL(РазмерыОграниченийПоДоходам.ОбъектИсчисленияДляИП, 0) ИНАЧЕ Доходы.ОблагаемыйДоход КОНЕЦ) КАК ОблагаемыйДоход,
		|	МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода, 0)) КАК МинимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода, 0)) КАК МаксимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(0) КАК СуммаКорректировки,
		|	ЕСТЬNULL(СтавкиОСМС.СтавкаВзносы, 0) КАК Ставка,
		|	МАКСИМУМ(ВЫБОР КОГДА ДругиеВидыДоходов.ВидДохода ЕСТЬ NULL ТОГДА ЛОЖЬ ИНАЧЕ ИСТИНА КОНЕЦ) КАК ЕстьНесколькоВидовДоходов,
		|	МАКСИМУМ(ВЫБОР КОГДА НЕ ДругиеВидыДоходов.ВидДохода ЕСТЬ NULL ИЛИ РанееИсчисленныеНалогиВзносы.ВОСМСПредыдущегоМестаРаботы ЕСТЬ NULL ТОГДА 0 ИНАЧЕ РанееИсчисленныеНалогиВзносы.ВОСМСПредыдущегоМестаРаботы КОНЕЦ) КАК ВОСМСПредыдущегоМестаРаботы,
		|	0 КАК ОбъектИсчисленияВОСМС,
		|	0 КАК ИсчисленныеВОСМС
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМС КАК СтавкиОСМС
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОСМС.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиОСМС.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДоходы КАК ДругиеВидыДоходов
		|		ПО ДругиеВидыДоходов.МесяцНалоговогоПериода = Доходы.МесяцНалоговогоПериода
		|			И ДругиеВидыДоходов.ФизическоеЛицо = Доходы.ФизическоеЛицо
		|			И НЕ ДругиеВидыДоходов.ВидДохода = Доходы.ВидДохода
		|			И НЕ ДругиеВидыДоходов.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРанееИсчисленныеНалогиВзносы КАК РанееИсчисленныеНалогиВзносы
		|		ПО Доходы.МесяцНалоговогоПериода = РанееИсчисленныеНалогиВзносы.МесяцНалоговогоПериода
		|			И РанееИсчисленныеНалогиВзносы.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ВОСМС)
		|			И Доходы.ФизическоеЛицо = РанееИсчисленныеНалогиВзносы.ФизическоеЛицо
		|СГРУППИРОВАТЬ ПО
		|	Доходы.МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо,
		|	Доходы.ВидДохода,
		|	ЕСТЬNULL(СтавкиОСМС.СтавкаВзносы, 0)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Доходы.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	СУММА(ДоходыПоПодразделениям.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	СУММА(ДоходыПоПодразделениям.НеоблагаемыйДоход) КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
        |
		|СГРУППИРОВАТЬ ПО
		|	ДоходыПоПодразделениям.Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеВОСМСПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеВОСМСПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектВОСМСИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.НалогВзнос КАК РанееИсчисленныеВОСМС,
		|	-ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеВОСМСПоПодразделениям.НалогВзнос КАК ИсчисленныеВОСМС,
		|	-ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияВОСМС
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеВОСМСПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.НалогВзнос <> 0)
		|	И НЕ ИсчисленныеВОСМСПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеВОСМСПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	РезультатЗапроса.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатЗапроса.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатЗапроса.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатЗапроса.Колонки.Добавить("ОбъектИсчисленияВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИсчисленныеВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаДляОбработки = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеВОСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияВОСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектВОСМСИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ВОСМСПредыдущегоМестаРаботы", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам = Новый ТаблицаЗначений;
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ОбъектИсчисления", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Индексы.Добавить("ФизическоеЛицо, МесяцНалоговогоПериода");
	
	СтруктураПоискаПоФизЛицам = Новый Структура("ФизическоеЛицо, МесяцНалоговогоПериода");
	ДанныеОкругления = ПолучитьСпособОкругленияСПериодом(МенеджерВременныхТаблиц, ВидНалогаВзносаВОСМС);
	СпособОкругления = ДанныеОкругления.СпособОкругления;
	ПериодОкругления = ДанныеОкругления.Период;
	
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	Если ПериодОкругления >= '20220101' Тогда
		// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
		ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
		ПравилоОкругления = ОписаниеСпособаОкругления.ПравилоОкругления;		
	Иначе
		ТочностьОкругления = 1;
		ПравилоОкругления = Перечисления.ПравилаОкругленияПриРасчетеЗарплаты.Авто;		
	КонецЕсли;

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругленияДляРаспределения = ТочностьОкругления - Цел(ТочностьОкругления);
	
	Если ТочностьОкругленияДляРаспределения = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругленияДляРаспределения <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;
	
	МаксимальныйВОСМСПриДостиженииПредела = 0;
	
	Для Каждого СтрокаТаблицы Из ТаблицаДляОбработки Цикл
		
		ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
		
		// корректируем максимальный доход только в окончательном расчете, если есть несколько видов дохода в месяце начисления
		НеобходимаКорректировкаМакисмальногоОграничения = ОкончательныйРасчет И СтрокаТаблицы.ЕстьНесколькоВидовДоходов;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			ЗаполнитьЗначенияСвойств(СтруктураПоискаПоФизЛицам, СтрокаТаблицы);

			// сумма взносов исчисленная
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			
			Если МассивВзносов.Количество() > 0 Тогда
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = МассивВзносов[0].ОбъектИсчисления;
			Иначе
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			КонецЕсли;
			
		Иначе
			
			ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			
		КонецЕсли;
		
		МаксимальныйРазмерОрганиченияДохода = СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода - ОбъектИсчисленияПоДругимВидамВДанномРасчете - ?(СтрокаТаблицы.Ставка = 0, 0, СтрокаТаблицы.ВОСМСПредыдущегоМестаРаботы / СтрокаТаблицы.Ставка);
		
		Если СтрокаТаблицы.ОблагаемыйДоход <= 0 Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = 0;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход + СтрокаТаблицы.СуммаКорректировки < СтрокаТаблицы.МинимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = 0;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход + СтрокаТаблицы.СуммаКорректировки >= МаксимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = МаксимальныйРазмерОрганиченияДохода;
			
			ВОСМСРанееИсчисленный = ЗарплатаКадрыКлиентСервер.Округлить((СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода - МаксимальныйРазмерОрганиченияДохода) * СтрокаТаблицы.Ставка, ТочностьОкругления, ПравилоОкругления);	
			
			МаксимальныйВОСМСПриДостиженииПредела = СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода * СтрокаТаблицы.Ставка - ВОСМСРанееИсчисленный;
			
		Иначе
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = СтрокаТаблицы.ОблагаемыйДоход + СтрокаТаблицы.СуммаКорректировки;
			
		КонецЕсли;
		
		СтрокаТаблицы.ИсчисленныеВОСМС = СтрокаТаблицы.ОбъектИсчисленияВОСМС * СтрокаТаблицы.Ставка;	

		Если НЕ МаксимальныйВОСМСПриДостиженииПредела = 0
			И СтрокаТаблицы.ИсчисленныеВОСМС > МаксимальныйВОСМСПриДостиженииПредела Тогда
			
			СтрокаТаблицы.ИсчисленныеВОСМС = МаксимальныйВОСМСПриДостиженииПредела;	
			МаксимальныйВОСМСПриДостиженииПредела = 0;

		КонецЕсли;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			Если МассивВзносов.Количество() > 0 Тогда
				СтрокаВзносовТаблицаВзносовПоФизЛицам = МассивВзносов[0];
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления + СтрокаТаблицы.ОбъектИсчисленияВОСМС;
			Иначе
				СтрокаВзносовТаблицаВзносовПоФизЛицам = ТаблицаВзносовПоФизЛицамПоДругимДоходам.Добавить();
				СтрокаВзносовТаблицаВзносовПоФизЛицам.МесяцНалоговогоПериода = СтрокаТаблицы.МесяцНалоговогоПериода;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ФизическоеЛицо = СтрокаТаблицы.ФизическоеЛицо;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаТаблицы.ОбъектИсчисленияВОСМС;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаДляОбработки, РезультатЗапроса);
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияВОСМС,ИсчисленныеВОСМС", ТочностьРаспределения);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеВОСМСПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияВОСМСВЦеломЗаПериод,	ИсчисленныеВОСМСВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектВОСМСИсчисленныйРанее, 		 	РанееИсчисленныеВОСМС,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияВОСМС, 					ИсчисленныеВОСМС");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0 
			И (СтрокаТЗ.ИсчисленныеВОСМС < 1 И СтрокаТЗ.ИсчисленныеВОСМС > 0
				ИЛИ СтрокаТЗ.ИсчисленныеВОСМС > -1 И СтрокаТЗ.ИсчисленныеВОСМС < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеВОСМС = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеВОСМС = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеВОСМС, ТочностьОкругления, ПравилоОкругления);
			
		КонецЕсли;
		
	КонецЦикла; 

	// для вычетов ИПН передаем общую таблицу округленных сумм
	ТаблицаДляВычетовИПН = РезультатЗапроса.Скопировать();
	
	Для каждого СтрокаТЗ Из ТаблицаДляВычетовИПН Цикл
		СтрокаТЗ.ИсчисленныеВОСМС = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеВОСМС, ТочностьОкругления, ПравилоОкругления);
	КонецЦикла; 
	
	Запрос.УстановитьПараметр("ИсчисленныеВОСМС", ТаблицаДляВычетовИПН);
	
	Запрос.Текст = "
		|ВЫБРАТЬ
		|	ВТИсчисленныеВОСМС.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМС.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеВОСМС.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеВОСМС.ОбъектИсчисленияВОСМС КАК ОбъектИсчисленияВОСМС,
		|	ВТИсчисленныеВОСМС.ИсчисленныеВОСМС КАК ИсчисленныеВОСМС
		|ПОМЕСТИТЬ ВТИсчисленныеВОСМСПоПодразделениям
		|ИЗ
		|	&ИсчисленныеВОСМС КАК ВТИсчисленныеВОСМС
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисленияВОСМС) КАК ОбъектИсчисленияВОСМС,
		|	СУММА(ВТИсчисленныеВОСМСПоПодразделениям.ИсчисленныеВОСМС) КАК ИсчисленныеВОСМС
		|ПОМЕСТИТЬ ВТИсчисленныеВОСМС
		|ИЗ
		|	ВТИсчисленныеВОСМСПоПодразделениям КАК ВТИсчисленныеВОСМСПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ВидДохода
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ВТИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ВидДохода
		|";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеВОСМСПоПодразделениям");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьВОСМСПосле2025(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	СоздатьВТИсключаемыеЛицаОСМС(МенеджерВременныхТаблиц, "ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС");
	
	ВидНалогаВзносаВОСМС =  Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходыПосле2023(МенеджерВременныхТаблиц, ВидНалогаВзносаВОСМС, "ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС", Ложь);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ВОСМС
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаВОСМС);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// - Исчисленные ВОСМС
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	0 КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 10 КАК МаксимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 1.4 КАК ОбъектИсчисленияДляИП
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	МАКСИМУМ(ВЫБОР КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства) ТОГДА ЕСТЬNULL(РазмерыОграниченийПоДоходам.ОбъектИсчисленияДляИП, 0) ИНАЧЕ Доходы.ОблагаемыйДоход КОНЕЦ) КАК ОблагаемыйДоход,
		|	МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода, 0)) КАК МинимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода, 0)) КАК МаксимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(0) КАК СуммаКорректировки,
		|	ЕСТЬNULL(СтавкиОСМС.СтавкаВзносы, 0) КАК Ставка,
		|	МАКСИМУМ(ВЫБОР КОГДА ДругиеВидыДоходов.ВидДохода ЕСТЬ NULL ТОГДА ЛОЖЬ ИНАЧЕ ИСТИНА КОНЕЦ) КАК ЕстьНесколькоВидовДоходов,
		|	МАКСИМУМ(ВЫБОР КОГДА НЕ ДругиеВидыДоходов.ВидДохода ЕСТЬ NULL ИЛИ РанееИсчисленныеНалогиВзносы.ВОСМСПредыдущегоМестаРаботы ЕСТЬ NULL ТОГДА 0 ИНАЧЕ РанееИсчисленныеНалогиВзносы.ВОСМСПредыдущегоМестаРаботы КОНЕЦ) КАК ВОСМСПредыдущегоМестаРаботы,
		|	0 КАК ОбъектИсчисленияВОСМС,
		|	0 КАК ИсчисленныеВОСМС
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМС КАК СтавкиОСМС
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОСМС.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиОСМС.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДоходы КАК ДругиеВидыДоходов
		|		ПО ДругиеВидыДоходов.МесяцНалоговогоПериода = Доходы.МесяцНалоговогоПериода
		|			И ДругиеВидыДоходов.ФизическоеЛицо = Доходы.ФизическоеЛицо
		|			И НЕ ДругиеВидыДоходов.ВидДохода = Доходы.ВидДохода
		|			И НЕ ДругиеВидыДоходов.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРанееИсчисленныеНалогиВзносы КАК РанееИсчисленныеНалогиВзносы
		|		ПО Доходы.МесяцНалоговогоПериода = РанееИсчисленныеНалогиВзносы.МесяцНалоговогоПериода
		|			И РанееИсчисленныеНалогиВзносы.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ВОСМС)
		|			И Доходы.ФизическоеЛицо = РанееИсчисленныеНалогиВзносы.ФизическоеЛицо
		|СГРУППИРОВАТЬ ПО
		|	Доходы.МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо,
		|	Доходы.ВидДохода,
		|	ЕСТЬNULL(СтавкиОСМС.СтавкаВзносы, 0)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Доходы.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	СУММА(ДоходыПоПодразделениям.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	СУММА(ДоходыПоПодразделениям.НеоблагаемыйДоход) КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
        |
		|СГРУППИРОВАТЬ ПО
		|	ДоходыПоПодразделениям.Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеВОСМСПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеВОСМСПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектВОСМСИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.НалогВзнос КАК РанееИсчисленныеВОСМС,
		|	-ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеВОСМСПоПодразделениям.НалогВзнос КАК ИсчисленныеВОСМС,
		|	-ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияВОСМС
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеВОСМСПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.НалогВзнос <> 0)
		|	И НЕ ИсчисленныеВОСМСПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеВОСМСПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	РезультатЗапроса.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатЗапроса.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатЗапроса.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатЗапроса.Колонки.Добавить("ОбъектИсчисленияВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИсчисленныеВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаДляОбработки = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеВОСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияВОСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектВОСМСИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ВОСМСПредыдущегоМестаРаботы", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам = Новый ТаблицаЗначений;
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ОбъектИсчисления", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Индексы.Добавить("ФизическоеЛицо, МесяцНалоговогоПериода");
	
	СтруктураПоискаПоФизЛицам = Новый Структура("ФизическоеЛицо, МесяцНалоговогоПериода");
	ДанныеОкругления = ПолучитьСпособОкругленияСПериодом(МенеджерВременныхТаблиц, ВидНалогаВзносаВОСМС);
	СпособОкругления = ДанныеОкругления.СпособОкругления;
	ПериодОкругления = ДанныеОкругления.Период;
	
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	МаксимальныйВОСМСПриДостиженииПредела = 0;
	
	Для Каждого СтрокаТаблицы Из ТаблицаДляОбработки Цикл
		
		ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
		
		// корректируем максимальный доход только в окончательном расчете, если есть несколько видов дохода в месяце начисления
		НеобходимаКорректировкаМакисмальногоОграничения = ОкончательныйРасчет И СтрокаТаблицы.ЕстьНесколькоВидовДоходов;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			ЗаполнитьЗначенияСвойств(СтруктураПоискаПоФизЛицам, СтрокаТаблицы);

			// сумма взносов исчисленная
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			
			Если МассивВзносов.Количество() > 0 Тогда
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = МассивВзносов[0].ОбъектИсчисления;
			Иначе
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			КонецЕсли;
			
		Иначе
			
			ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			
		КонецЕсли;
		
		МаксимальныйРазмерОрганиченияДохода = СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода - ОбъектИсчисленияПоДругимВидамВДанномРасчете - ?(СтрокаТаблицы.Ставка = 0, 0, СтрокаТаблицы.ВОСМСПредыдущегоМестаРаботы / СтрокаТаблицы.Ставка);
		
		Если СтрокаТаблицы.ОблагаемыйДоход <= 0 Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = 0;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход + СтрокаТаблицы.СуммаКорректировки < СтрокаТаблицы.МинимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = 0;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход + СтрокаТаблицы.СуммаКорректировки >= МаксимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = МаксимальныйРазмерОрганиченияДохода;
			
			ВОСМСРанееИсчисленный = ЗарплатаКадрыКлиентСервер.Округлить((СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода - МаксимальныйРазмерОрганиченияДохода) * СтрокаТаблицы.Ставка, 1);	
			
			МаксимальныйВОСМСПриДостиженииПредела = СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода * СтрокаТаблицы.Ставка - ВОСМСРанееИсчисленный;
			
		Иначе
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = СтрокаТаблицы.ОблагаемыйДоход + СтрокаТаблицы.СуммаКорректировки;
			
		КонецЕсли;
		
		СтрокаТаблицы.ИсчисленныеВОСМС = СтрокаТаблицы.ОбъектИсчисленияВОСМС * СтрокаТаблицы.Ставка;	
		
		// сначала применим округление к сумме ИПН, после чего распределим ниже (ранее округление выполнялось после распределения, что приводило к погрешностям расчета)
		СтрокаТаблицы.ИсчисленныеВОСМС = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТаблицы.ИсчисленныеВОСМС, 1);

		Если НЕ МаксимальныйВОСМСПриДостиженииПредела = 0
			И СтрокаТаблицы.ИсчисленныеВОСМС > МаксимальныйВОСМСПриДостиженииПредела Тогда
			
			СтрокаТаблицы.ИсчисленныеВОСМС = МаксимальныйВОСМСПриДостиженииПредела;	
			МаксимальныйВОСМСПриДостиженииПредела = 0;

		КонецЕсли;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			Если МассивВзносов.Количество() > 0 Тогда
				СтрокаВзносовТаблицаВзносовПоФизЛицам = МассивВзносов[0];
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления + СтрокаТаблицы.ОбъектИсчисленияВОСМС;
			Иначе
				СтрокаВзносовТаблицаВзносовПоФизЛицам = ТаблицаВзносовПоФизЛицамПоДругимДоходам.Добавить();
				СтрокаВзносовТаблицаВзносовПоФизЛицам.МесяцНалоговогоПериода = СтрокаТаблицы.МесяцНалоговогоПериода;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ФизическоеЛицо = СтрокаТаблицы.ФизическоеЛицо;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаТаблицы.ОбъектИсчисленияВОСМС;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаДляОбработки, РезультатЗапроса);
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияВОСМС,ИсчисленныеВОСМС", 0);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеВОСМСПоПодразделениям, РезультатыРасчетов);

	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0 
			И (СтрокаТЗ.ИсчисленныеВОСМС < 1 И СтрокаТЗ.ИсчисленныеВОСМС > 0
				ИЛИ СтрокаТЗ.ИсчисленныеВОСМС > -1 И СтрокаТЗ.ИсчисленныеВОСМС < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеВОСМС = 0;
			
		КонецЕсли;
		
	КонецЦикла; 

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияВОСМСВЦеломЗаПериод,	ИсчисленныеВОСМСВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектВОСМСИсчисленныйРанее, 		 	РанееИсчисленныеВОСМС,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияВОСМС, 					ИсчисленныеВОСМС");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
	КонецЦикла; 

	// для вычетов ИПН передаем общую таблицу округленных сумм
	ТаблицаДляВычетовИПН = РезультатЗапроса.Скопировать();
	
	Для каждого СтрокаТЗ Из ТаблицаДляВычетовИПН Цикл
		СтрокаТЗ.ИсчисленныеВОСМС = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеВОСМС, 1);
	КонецЦикла; 
	
	Запрос.УстановитьПараметр("ИсчисленныеВОСМС", ТаблицаДляВычетовИПН);
	
	Запрос.Текст = "
		|ВЫБРАТЬ
		|	ВТИсчисленныеВОСМС.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМС.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеВОСМС.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеВОСМС.ОбъектИсчисленияВОСМС КАК ОбъектИсчисленияВОСМС,
		|	ВТИсчисленныеВОСМС.ИсчисленныеВОСМС КАК ИсчисленныеВОСМС
		|ПОМЕСТИТЬ ВТИсчисленныеВОСМСПоПодразделениям
		|ИЗ
		|	&ИсчисленныеВОСМС КАК ВТИсчисленныеВОСМС
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисленияВОСМС) КАК ОбъектИсчисленияВОСМС,
		|	СУММА(ВТИсчисленныеВОСМСПоПодразделениям.ИсчисленныеВОСМС) КАК ИсчисленныеВОСМС
		|ПОМЕСТИТЬ ВТИсчисленныеВОСМС
		|ИЗ
		|	ВТИсчисленныеВОСМСПоПодразделениям КАК ВТИсчисленныеВОСМСПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ВидДохода
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ВТИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ВидДохода
		|";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеВОСМСПоПодразделениям");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьВОСМСПосле2026(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	СоздатьВТИсключаемыеЛицаОСМС(МенеджерВременныхТаблиц, "ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС");
	
	ВидНалогаВзносаВОСМС =  Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
    ПараметрыПолученияДанных = Новый Структура("Организация, ВидНалогаВзносаОтчисления, МесяцНачисления", Организация, ВидНалогаВзносаВОСМС, МесяцНачисления);
	СоздатьВТДоходыПосле2026(МенеджерВременныхТаблиц, ПараметрыПолученияДанных, "ВТИсключаемыеФизическиеЛицаПриРасчетеВОСМС", Ложь);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ВОСМС
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаВОСМС);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// - Исчисленные ВОСМС
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	0 КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 20 КАК МаксимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 1.4 КАК ОбъектИсчисленияДляИП
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	МАКСИМУМ(ВЫБОР КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства) ТОГДА ЕСТЬNULL(РазмерыОграниченийПоДоходам.ОбъектИсчисленияДляИП, 0) ИНАЧЕ Доходы.ОблагаемыйДоход КОНЕЦ) КАК ОблагаемыйДоход,
		|	МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода, 0)) КАК МинимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода, 0)) КАК МаксимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(0) КАК СуммаКорректировки,
		|	ЕСТЬNULL(СтавкиОСМС.СтавкаВзносы, 0) КАК Ставка,
		|	МАКСИМУМ(ВЫБОР КОГДА ДругиеВидыДоходов.ВидДохода ЕСТЬ NULL ТОГДА ЛОЖЬ ИНАЧЕ ИСТИНА КОНЕЦ) КАК ЕстьНесколькоВидовДоходов,
		|	МАКСИМУМ(ВЫБОР КОГДА НЕ ДругиеВидыДоходов.ВидДохода ЕСТЬ NULL ИЛИ РанееИсчисленныеНалогиВзносы.ВОСМСПредыдущегоМестаРаботы ЕСТЬ NULL ТОГДА 0 ИНАЧЕ РанееИсчисленныеНалогиВзносы.ВОСМСПредыдущегоМестаРаботы КОНЕЦ) КАК ВОСМСПредыдущегоМестаРаботы,
		|	0 КАК ОбъектИсчисленияВОСМС,
		|	0 КАК ИсчисленныеВОСМС
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМС КАК СтавкиОСМС
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОСМС.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиОСМС.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДоходы КАК ДругиеВидыДоходов
		|		ПО ДругиеВидыДоходов.МесяцНалоговогоПериода = Доходы.МесяцНалоговогоПериода
		|			И ДругиеВидыДоходов.ФизическоеЛицо = Доходы.ФизическоеЛицо
		|			И НЕ ДругиеВидыДоходов.ВидДохода = Доходы.ВидДохода
		|			И НЕ ДругиеВидыДоходов.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРанееИсчисленныеНалогиВзносы КАК РанееИсчисленныеНалогиВзносы
		|		ПО Доходы.МесяцНалоговогоПериода = РанееИсчисленныеНалогиВзносы.МесяцНалоговогоПериода
		|			И РанееИсчисленныеНалогиВзносы.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ВОСМС)
		|			И Доходы.ФизическоеЛицо = РанееИсчисленныеНалогиВзносы.ФизическоеЛицо
		|СГРУППИРОВАТЬ ПО
		|	Доходы.МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо,
		|	Доходы.ВидДохода,
		|	ЕСТЬNULL(СтавкиОСМС.СтавкаВзносы, 0)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Доходы.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	СУММА(ДоходыПоПодразделениям.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	СУММА(ДоходыПоПодразделениям.НеоблагаемыйДоход) КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
        |
		|СГРУППИРОВАТЬ ПО
		|	ДоходыПоПодразделениям.Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеВОСМСПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеВОСМСПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектВОСМСИсчисленныйРанее,
		|	ИсчисленныеВОСМСПоПодразделениям.НалогВзнос КАК РанееИсчисленныеВОСМС,
		|	-ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеВОСМСПоПодразделениям.НалогВзнос КАК ИсчисленныеВОСМС,
		|	-ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияВОСМС
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеВОСМСПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеВОСМСПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеВОСМСПоПодразделениям.НалогВзнос <> 0)
		|	И НЕ ИсчисленныеВОСМСПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеВОСМСПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	РезультатЗапроса.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатЗапроса.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатЗапроса.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатЗапроса.Колонки.Добавить("ОбъектИсчисленияВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИсчисленныеВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаДляОбработки = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеВОСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияВОСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектВОСМСИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ВОСМСПредыдущегоМестаРаботы", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам = Новый ТаблицаЗначений;
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ОбъектИсчисления", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Индексы.Добавить("ФизическоеЛицо, МесяцНалоговогоПериода");
	
	СтруктураПоискаПоФизЛицам = Новый Структура("ФизическоеЛицо, МесяцНалоговогоПериода");
	ДанныеОкругления = ПолучитьСпособОкругленияСПериодом(МенеджерВременныхТаблиц, ВидНалогаВзносаВОСМС);
	СпособОкругления = ДанныеОкругления.СпособОкругления;
	ПериодОкругления = ДанныеОкругления.Период;
	
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	МаксимальныйВОСМСПриДостиженииПредела = 0;
	
	Для Каждого СтрокаТаблицы Из ТаблицаДляОбработки Цикл
		
		ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
		
		// корректируем максимальный доход только в окончательном расчете, если есть несколько видов дохода в месяце начисления
		НеобходимаКорректировкаМакисмальногоОграничения = ОкончательныйРасчет И СтрокаТаблицы.ЕстьНесколькоВидовДоходов;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			ЗаполнитьЗначенияСвойств(СтруктураПоискаПоФизЛицам, СтрокаТаблицы);

			// сумма взносов исчисленная
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			
			Если МассивВзносов.Количество() > 0 Тогда
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = МассивВзносов[0].ОбъектИсчисления;
			Иначе
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			КонецЕсли;
			
		Иначе
			
			ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			
		КонецЕсли;
		
		МаксимальныйРазмерОрганиченияДохода = СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода - ОбъектИсчисленияПоДругимВидамВДанномРасчете - ?(СтрокаТаблицы.Ставка = 0, 0, СтрокаТаблицы.ВОСМСПредыдущегоМестаРаботы / СтрокаТаблицы.Ставка);
		
		Если СтрокаТаблицы.ОблагаемыйДоход <= 0 Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = 0;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход + СтрокаТаблицы.СуммаКорректировки < СтрокаТаблицы.МинимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = 0;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход + СтрокаТаблицы.СуммаКорректировки >= МаксимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = МаксимальныйРазмерОрганиченияДохода;
			
			ВОСМСРанееИсчисленный = ЗарплатаКадрыКлиентСервер.Округлить((СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода - МаксимальныйРазмерОрганиченияДохода) * СтрокаТаблицы.Ставка, 1);	
			
			МаксимальныйВОСМСПриДостиженииПредела = СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода * СтрокаТаблицы.Ставка - ВОСМСРанееИсчисленный;
			
		Иначе
			
			СтрокаТаблицы.ОбъектИсчисленияВОСМС = СтрокаТаблицы.ОблагаемыйДоход + СтрокаТаблицы.СуммаКорректировки;
			
		КонецЕсли;
		
		СтрокаТаблицы.ИсчисленныеВОСМС = СтрокаТаблицы.ОбъектИсчисленияВОСМС * СтрокаТаблицы.Ставка;	
		
		// сначала применим округление к сумме ИПН, после чего распределим ниже (ранее округление выполнялось после распределения, что приводило к погрешностям расчета)
		СтрокаТаблицы.ИсчисленныеВОСМС = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТаблицы.ИсчисленныеВОСМС, 1);

		Если НЕ МаксимальныйВОСМСПриДостиженииПредела = 0
			И СтрокаТаблицы.ИсчисленныеВОСМС > МаксимальныйВОСМСПриДостиженииПредела Тогда
			
			СтрокаТаблицы.ИсчисленныеВОСМС = МаксимальныйВОСМСПриДостиженииПредела;	
			МаксимальныйВОСМСПриДостиженииПредела = 0;

		КонецЕсли;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			Если МассивВзносов.Количество() > 0 Тогда
				СтрокаВзносовТаблицаВзносовПоФизЛицам = МассивВзносов[0];
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления + СтрокаТаблицы.ОбъектИсчисленияВОСМС;
			Иначе
				СтрокаВзносовТаблицаВзносовПоФизЛицам = ТаблицаВзносовПоФизЛицамПоДругимДоходам.Добавить();
				СтрокаВзносовТаблицаВзносовПоФизЛицам.МесяцНалоговогоПериода = СтрокаТаблицы.МесяцНалоговогоПериода;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ФизическоеЛицо = СтрокаТаблицы.ФизическоеЛицо;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаТаблицы.ОбъектИсчисленияВОСМС;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаДляОбработки, РезультатЗапроса);
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияВОСМС,ИсчисленныеВОСМС", 0);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеВОСМСПоПодразделениям, РезультатыРасчетов);

	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0 
			И (СтрокаТЗ.ИсчисленныеВОСМС < 1 И СтрокаТЗ.ИсчисленныеВОСМС > 0
				ИЛИ СтрокаТЗ.ИсчисленныеВОСМС > -1 И СтрокаТЗ.ИсчисленныеВОСМС < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеВОСМС = 0;
			
		КонецЕсли;
		
	КонецЦикла; 

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияВОСМСВЦеломЗаПериод,	ИсчисленныеВОСМСВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектВОСМСИсчисленныйРанее, 		 	РанееИсчисленныеВОСМС,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияВОСМС, 					ИсчисленныеВОСМС");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
	КонецЦикла; 

	// для вычетов ИПН передаем общую таблицу округленных сумм
	ТаблицаДляВычетовИПН = РезультатыРасчетов.Скопировать(, "МесяцНалоговогоПериода, ФизическоеЛицо, Подразделение, ВидДохода, ИсчисленныеВОСМСВЦеломЗаПериод");
	
	Для каждого СтрокаТЗ Из ТаблицаДляВычетовИПН Цикл
		СтрокаТЗ.ИсчисленныеВОСМСВЦеломЗаПериод = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеВОСМСВЦеломЗаПериод, 1);
	КонецЦикла; 
	
	Запрос.УстановитьПараметр("ИсчисленныеВОСМС", ТаблицаДляВычетовИПН);
	
	Запрос.Текст = "
		|ВЫБРАТЬ
		|	ВТИсчисленныеВОСМС.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМС.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеВОСМС.Подразделение КАК Подразделение,
		|	ВТИсчисленныеВОСМС.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеВОСМС.ИсчисленныеВОСМСВЦеломЗаПериод КАК ИсчисленныеВОСМС
		|ПОМЕСТИТЬ ВТИсчисленныеВОСМСПоПодразделениям
		|ИЗ
		|	&ИсчисленныеВОСМС КАК ВТИсчисленныеВОСМС
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеВОСМСПоПодразделениям.ИсчисленныеВОСМС) КАК ИсчисленныеВОСМС
		|ПОМЕСТИТЬ ВТИсчисленныеВОСМС
		|ИЗ
		|	ВТИсчисленныеВОСМСПоПодразделениям КАК ВТИсчисленныеВОСМСПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ВидДохода
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ВТИсчисленныеВОСМСПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеВОСМСПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеВОСМСПоПодразделениям.ВидДохода
		|";
	
	Запрос.Выполнить();
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьОПВРПосле2024(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) 
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	СоздатьВТИсключаемыеФизическиеЛицаПриРасчетеОПВР(МенеджерВременныхТаблиц, МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеОПВР");
	
	ВидНалогаВзносаОПВР = Перечисления.ВидыНалоговВзносовОтчислений.ОПВР;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходыПосле2023(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВР, "ВТИсключаемыеФизическиеЛицаПриРасчетеОПВР", Истина);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ОПВР
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВР);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	// - ОПВР
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 50 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход 
		|	КОНЕЦ КАК ОбъектИсчисленияОПВР,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход 
        |	КОНЕЦ * ЕСТЬNULL(СтавкиОПВР.Ставка, 0) КАК ИсчисленныеОПВР
		|ПОМЕСТИТЬ ВТИсчисленныеОПВР
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиОПВР
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОПВР.МесяцНалоговогоПериода
		|			И (СтавкиОПВР.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ОПВР))
		|			И Доходы.ВидДохода = СтавкиОПВР.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеОПВР.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВР.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеОПВР.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеОПВР.ОбъектИсчисленияОПВР КАК ОбъектИсчисленияОПВР,
		|	ВТИсчисленныеОПВР.ИсчисленныеОПВР КАК ИсчисленныеОПВР
		|ИЗ
		|	ВТИсчисленныеОПВР КАК ВТИсчисленныеОПВР
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	СУММА(ДоходыПоПодразделениям.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	СУММА(ДоходыПоПодразделениям.НеоблагаемыйДоход) КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
        |
		|СГРУППИРОВАТЬ ПО
		|	ДоходыПоПодразделениям.Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеОПВРПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеОПВРПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеОПВРПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеОПВРПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеОПВРПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеОПВРПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеОПВРПоПодразделениям.ОбъектИсчисления КАК ОбъектОПВРИсчисленныйРанее,
		|	ИсчисленныеОПВРПоПодразделениям.НалогВзнос КАК РанееИсчисленныеОПВР,
		|	-ИсчисленныеОПВРПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеОПВРПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеОПВРПоПодразделениям.НалогВзнос КАК ИсчисленныеОПВР,
		|	-ИсчисленныеОПВРПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияОПВР
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеОПВРПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеОПВРПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеОПВРПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеОПВРПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеОПВРПоПодразделениям.НалогВзнос <> 0)";
			
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТИсчисленныеОПВР");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеОПВРПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	РезультатЗапроса = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеОПВРВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияОПВРВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектОПВРИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеОПВР", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	ДанныеОкругления = ПолучитьСпособОкругленияСПериодом(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВР);
	СпособОкругления = ДанныеОкругления.СпособОкругления;
	ПериодОкругления = ДанныеОкругления.Период;
	
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
	ПравилоОкругления = ОписаниеСпособаОкругления.ПравилоОкругления;		

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругленияДляРаспределения = ТочностьОкругления - Цел(ТочностьОкругления);
	
	Если ТочностьОкругленияДляРаспределения = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругленияДляРаспределения <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияОПВР,ИсчисленныеОПВР", ТочностьРаспределения);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеОПВРПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияОПВРВЦеломЗаПериод,	ИсчисленныеОПВРВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектОПВРИсчисленныйРанее, 		РанееИсчисленныеОПВР,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияОПВР, 				ИсчисленныеОПВР");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0
			И (СтрокаТЗ.ИсчисленныеОПВР < 1 И СтрокаТЗ.ИсчисленныеОПВР > 0
				ИЛИ СтрокаТЗ.ИсчисленныеОПВР > -1 И СтрокаТЗ.ИсчисленныеОПВР < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеОПВР = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеОПВР = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеОПВР, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
			
		КонецЕсли;
		
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Процедура СоздатьВТРазмерыМРППоПериодам(МенеджерВременныхТаблиц) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(МесячныйРасчетныйПоказатель.Период) КАК ПериодМРП,
		|	МАКСИМУМ(МесячныйРасчетныйПоказательНаНачалоГода.Период) КАК ПериодМРПНаНачалоГода,
		|	ПериодыРасчета.Период КАК МесяцНалоговогоПериода
		|ПОМЕСТИТЬ ВТПериодыМРП
		|ИЗ
		|	ВТДатыПоМесяцам КАК ПериодыРасчета
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.МесячныйРасчетныйПоказатель КАК МесячныйРасчетныйПоказатель
		|		ПО ПериодыРасчета.Период >= МесячныйРасчетныйПоказатель.Период
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.МесячныйРасчетныйПоказатель КАК МесячныйРасчетныйПоказательНаНачалоГода
		|		ПО НАЧАЛОПЕРИОДА(ПериодыРасчета.Период, ГОД) >= МесячныйРасчетныйПоказательНаНачалоГода.Период
		|
		|СГРУППИРОВАТЬ ПО
		|	ПериодыРасчета.Период
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТПериодыМРП.МесяцНалоговогоПериода,
		|	ЕСТЬNULL(МесячныйРасчетныйПоказатель.Размер, 0) КАК РазмерМРП,
		|	ЕСТЬNULL(МесячныйРасчетныйПоказательНаНачалоГода.Размер, 0) КАК РазмерМРПНаНачалоГода
		|ПОМЕСТИТЬ ВТРазмерыМРППоПериодам
		|ИЗ
		|	ВТПериодыМРП КАК ВТПериодыМРП
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.МесячныйРасчетныйПоказатель КАК МесячныйРасчетныйПоказатель
		|		ПО ВТПериодыМРП.ПериодМРП = МесячныйРасчетныйПоказатель.Период
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.МесячныйРасчетныйПоказатель КАК МесячныйРасчетныйПоказательНаНачалоГода
		|		ПО ВТПериодыМРП.ПериодМРПНаНачалоГода = МесячныйРасчетныйПоказательНаНачалоГода.Период
		|";
		
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТПериодыМРП");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
КонецПроцедуры

Процедура ЗаполнитьТаблицуСтавкиНалоговВзносовОтчисленийДляОценочныхОбязательств(ТаблицаСтавкиНалоговВзносовОтчислений, Организация, ПериодРегистрации) Экспорт
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Организация",            Организация);
		Запрос.УстановитьПараметр("ПериодРегистрацииКонец", КонецМесяца(ПериодРегистрации));

        Запрос.Текст = 
        "ВЫБРАТЬ РАЗРЕШЕННЫЕ
        |   МАКСИМУМ(СведенияОСтавкахНалоговСборовОтчислений.Период) КАК Период,
        |   СведенияОСтавкахНалоговСборовОтчислений.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления
        |ПОМЕСТИТЬ ВТМаксимальныйПериодСтавок
        |ИЗ
        |   РегистрСведений.СведенияОСтавкахНалоговСборовОтчислений.СрезПоследних(
        |           &ПериодРегистрацииКонец,
        |           (Организация = &Организация
        |               ИЛИ Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка))
        |               И (ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
        |                   ИЛИ ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка))) КАК СведенияОСтавкахНалоговСборовОтчислений
        |
        |СГРУППИРОВАТЬ ПО
        |   СведенияОСтавкахНалоговСборовОтчислений.ВидНалогаВзносаОтчисления
        |;
        |
        |////////////////////////////////////////////////////////////////////////////////
        |ВЫБРАТЬ РАЗРЕШЕННЫЕ
        |   МАКСИМУМ(СведенияОСтавкахОСМС.Период) КАК Период
        |ПОМЕСТИТЬ ВТМаксимальныйПериодСтавокОСМС
        |ИЗ
        |   РегистрСведений.СведенияОСтавкахОСМС.СрезПоследних(
        |           &ПериодРегистрацииКонец,
        |           (Организация = &Организация
        |               ИЛИ Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка))
        |               И ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)) КАК СведенияОСтавкахОСМС
        |;
        |
        |////////////////////////////////////////////////////////////////////////////////
        |ВЫБРАТЬ РАЗРЕШЕННЫЕ
        |   1 КАК Приоритет,
        |   СтавкиНалоговСборовОтчислений.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления,
        |   СтавкиНалоговСборовОтчислений.Ставка КАК Ставка
        |ПОМЕСТИТЬ ВТСтавкиПоПриоритетам
        |ИЗ
        |   ВТМаксимальныйПериодСтавок КАК Максимум
        |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОСтавкахНалоговСборовОтчислений КАК СтавкиНалоговСборовОтчислений
        |       ПО Максимум.Период = СтавкиНалоговСборовОтчислений.Период
        |           И Максимум.ВидНалогаВзносаОтчисления = СтавкиНалоговСборовОтчислений.ВидНалогаВзносаОтчисления
        |           И (СтавкиНалоговСборовОтчислений.Организация = &Организация)
        |           И (СтавкиНалоговСборовОтчислений.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя))
        |
        |ОБЪЕДИНИТЬ ВСЕ
        |
        |ВЫБРАТЬ 
        |   2,
        |   СтавкиНалоговСборовОтчислений.ВидНалогаВзносаОтчисления,
        |   СтавкиНалоговСборовОтчислений.Ставка
        |ИЗ
        |   ВТМаксимальныйПериодСтавок КАК Максимум
        |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОСтавкахНалоговСборовОтчислений КАК СтавкиНалоговСборовОтчислений
        |       ПО Максимум.Период = СтавкиНалоговСборовОтчислений.Период
        |           И Максимум.ВидНалогаВзносаОтчисления = СтавкиНалоговСборовОтчислений.ВидНалогаВзносаОтчисления
        |           И (СтавкиНалоговСборовОтчислений.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка))
        |           И (СтавкиНалоговСборовОтчислений.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя))
        |
        |ОБЪЕДИНИТЬ ВСЕ
        |
        |ВЫБРАТЬ
        |   1,
        |   ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ООСМС),
        |   СведенияОСтавкахОСМС.СтавкаОтчисления
        |ИЗ
        |   ВТМаксимальныйПериодСтавокОСМС КАК Максимум
        |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОСтавкахОСМС КАК СведенияОСтавкахОСМС
        |       ПО Максимум.Период = СведенияОСтавкахОСМС.Период
        |           И (СведенияОСтавкахОСМС.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя))
        |           И (СведенияОСтавкахОСМС.Организация = &Организация)
        |
        |ОБЪЕДИНИТЬ ВСЕ
        |
        |ВЫБРАТЬ
        |   2,
        |   ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ООСМС),
        |   СведенияОСтавкахОСМС.СтавкаОтчисления
        |ИЗ
        |   ВТМаксимальныйПериодСтавокОСМС КАК Максимум
        |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОСтавкахОСМС КАК СведенияОСтавкахОСМС
        |       ПО Максимум.Период = СведенияОСтавкахОСМС.Период
        |           И (СведенияОСтавкахОСМС.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя))
        |           И (СведенияОСтавкахОСМС.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка))
        |
        |ОБЪЕДИНИТЬ ВСЕ
        |
        |ВЫБРАТЬ
        |   1,
        |   ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ВОСМС),
        |   СведенияОСтавкахОСМС.СтавкаВзносы
        |ИЗ
        |   ВТМаксимальныйПериодСтавокОСМС КАК Максимум
        |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОСтавкахОСМС КАК СведенияОСтавкахОСМС
        |       ПО Максимум.Период = СведенияОСтавкахОСМС.Период
        |           И (СведенияОСтавкахОСМС.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя))
        |           И (СведенияОСтавкахОСМС.Организация = &Организация)
        |
        |ОБЪЕДИНИТЬ ВСЕ
        |
        |ВЫБРАТЬ
        |   2,
        |   ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ВОСМС),
        |   СведенияОСтавкахОСМС.СтавкаВзносы
        |ИЗ
        |   ВТМаксимальныйПериодСтавокОСМС КАК Максимум
        |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОСтавкахОСМС КАК СведенияОСтавкахОСМС
        |       ПО Максимум.Период = СведенияОСтавкахОСМС.Период
        |           И (СведенияОСтавкахОСМС.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя))
        |           И (СведенияОСтавкахОСМС.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка))
        |
        |ИНДЕКСИРОВАТЬ ПО
        |   ВидНалогаВзносаОтчисления,
        |   Приоритет
        |;
        |
        |////////////////////////////////////////////////////////////////////////////////
        |ВЫБРАТЬ
        |   ВТСтавкиПоПриоритетам.Ставка КАК Ставка,
        |   ВТСтавкиПоПриоритетам.ВидНалогаВзносаОтчисления КАК Налог
        |ИЗ
        |   (ВЫБРАТЬ
        |       МИНИМУМ(ПриоритетСтавок.Приоритет) КАК Приоритет,
        |       ПриоритетСтавок.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления
        |   ИЗ
        |       ВТСтавкиПоПриоритетам КАК ПриоритетСтавок
        |   
        |   СГРУППИРОВАТЬ ПО
        |       ПриоритетСтавок.ВидНалогаВзносаОтчисления) КАК ПриоритетСтавок
        |       ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиПоПриоритетам КАК ВТСтавкиПоПриоритетам
        |       ПО ПриоритетСтавок.Приоритет = ВТСтавкиПоПриоритетам.Приоритет
        |           И ПриоритетСтавок.ВидНалогаВзносаОтчисления = ВТСтавкиПоПриоритетам.ВидНалогаВзносаОтчисления";
		
		РезультатЗапроса = Запрос.Выполнить().Выгрузить();

        Если РезультатЗапроса.Количество()>0 Тогда
            
            ТаблицаСтавкиНалоговВзносовОтчислений.Загрузить(РезультатЗапроса);
            
        КонецЕсли; 
        		
КонецПроцедуры

Процедура СоздатьВТДолиЕППоПериодам(МенеджерВременныхТаблиц, ИмяВТДолиЕП = "ВТДолиЕП") Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	МАКСИМУМ(ЕСТЬNULL(СведенияОДоляхЕП.Период, ДАТАВРЕМЯ(1, 1, 1))) КАК ПериодСтавки,
		|	ПериодыРасчета.Период КАК МесяцНалоговогоПериода
		|ПОМЕСТИТЬ ВТПериодыДолейЕП
		|ИЗ
		|	ВТДатыПоМесяцам КАК ПериодыРасчета
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОДоляхЕП КАК СведенияОДоляхЕП
		|		ПО ПериодыРасчета.Период >= СведенияОДоляхЕП.Период
		|
		|СГРУППИРОВАТЬ ПО
		|	ПериодыРасчета.Период
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ПериодСтавки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПериодыДолейЕП.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ЕСТЬNULL(СведенияОДоляхЕП.ДоляОПВ, 0) / 100 КАК ДоляОПВ,
		|	ЕСТЬNULL(СведенияОДоляхЕП.ДоляВОСМС, 0) / 100 КАК ДоляВОСМС,
		|	ЕСТЬNULL(СведенияОДоляхЕП.ДоляИПН, 0) / 100 КАК ДоляИПН,
		|	ЕСТЬNULL(СведенияОДоляхЕП.ДоляСО, 0) / 100 КАК ДоляСО,
		|	ЕСТЬNULL(СведенияОДоляхЕП.ДоляООСМС, 0) / 100 КАК ДоляООСМС,
		|	ЕСТЬNULL(СведенияОДоляхЕП.ДоляОПВР, 0) / 100 КАК ДоляОПВР
		|ПОМЕСТИТЬ #ВТДолиЕП
		|ИЗ
		|	ВТПериодыДолейЕП КАК ПериодыДолейЕП
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОДоляхЕП КАК СведенияОДоляхЕП
		|		ПО ПериодыДолейЕП.ПериодСтавки = СведенияОДоляхЕП.Период
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	МесяцНалоговогоПериода";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "#ВТДолиЕП", ИмяВТДолиЕП);
	
	Запрос.Выполнить();	
	УничтожитьВТ.Добавить("ВТПериодыДолейЕП");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
КонецПроцедуры

// ЕП

Функция ДанныеОРезультатахРасчетаЕПДляДокумента(ЕП, ОкончательныйРасчетЗарплаты) 
	
	ВидНалогаВзноса = Перечисления.ВидыНалоговВзносовОтчислений.ЕП;

	// Приводим таблицу к структуре, соответствующей документам расчета.
	ЕП.Колонки.Добавить("ИдентификаторСтрокиНалогиВзносыОтчисления", Новый ОписаниеТипов("Число"));
	ЕП.Колонки.Добавить("НалогВзнос", Новый ОписаниеТипов("Число"));
	ЕП.Колонки.Добавить("ОбъектИсчисления", Новый ОписаниеТипов("Число"));
	ЕП.Колонки.Добавить("ВидНалогаВзносаОтчисления", Новый ОписаниеТипов("ПеречислениеСсылка.ВидыНалоговВзносовОтчислений"));
	
	Для Каждого СтрокаЕП Из ЕП Цикл
		СтрокаЕП.НалогВзнос = СтрокаЕП.ИсчисленныйЕП;
		СтрокаЕП.ОбъектИсчисления = СтрокаЕП.ОбъектИсчисленияЕП;
		СтрокаЕП.ВидНалогаВзносаОтчисления = ВидНалогаВзноса;
	КонецЦикла;
	
	Если ОкончательныйРасчетЗарплаты Тогда
		
		КомпонентыЕП = Новый ТаблицаЗначений;
		КомпонентыЕП.Колонки.Добавить("ИдентификаторСтрокиНалогиВзносыОтчисления", Новый ОписаниеТипов("Число"));
		КомпонентыЕП.Колонки.Добавить("ОПВ", Новый ОписаниеТипов("Число"));
		КомпонентыЕП.Колонки.Добавить("ИПН", Новый ОписаниеТипов("Число"));
		КомпонентыЕП.Колонки.Добавить("ВОСМС", Новый ОписаниеТипов("Число"));
		КомпонентыЕП.Колонки.Добавить("СО", Новый ОписаниеТипов("Число"));
		КомпонентыЕП.Колонки.Добавить("ООСМС", Новый ОписаниеТипов("Число"));
		КомпонентыЕП.Колонки.Добавить("ОПВР", Новый ОписаниеТипов("Число"));
		
		// Заполняем таблицу КомпонентыЕП: 
		Для Каждого СтрокаЕП Из ЕП Цикл
			
			СтрокаЕП.ИдентификаторСтрокиНалогиВзносыОтчисления = ЕП.Индекс(СтрокаЕП);

			Если СтрокаЕП.НалогВзнос <> 0 Тогда
				
				СтрокаКомпонентыЕП = КомпонентыЕП.Добавить();
				СтрокаКомпонентыЕП.ИдентификаторСтрокиНалогиВзносыОтчисления = СтрокаЕП.ИдентификаторСтрокиНалогиВзносыОтчисления;
				СтрокаКомпонентыЕП.ОПВ 	 = СтрокаЕП.ОПВ;
				СтрокаКомпонентыЕП.ИПН 	 = СтрокаЕП.ИПН;
				СтрокаКомпонентыЕП.ВОСМС = СтрокаЕП.ВОСМС;
				СтрокаКомпонентыЕП.СО	 = СтрокаЕП.СО;
				СтрокаКомпонентыЕП.ООСМС = СтрокаЕП.ООСМС;
				СтрокаКомпонентыЕП.ОПВР  = СтрокаЕП.ОПВР;
				
			КонецЕсли;
			
		КонецЦикла;
		
	Иначе
		
		КомпонентыЕП = Неопределено;
		
	КонецЕсли;
	
	Возврат Новый Структура("ЕП, КомпонентыЕП", ЕП, КомпонентыЕП);

КонецФункции

Процедура СоздатьВТИсключаемыеЛицаЕП(МенеджерВременныхТаблиц, ИмяТаблицы, МесяцНачисления) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("КонецМесяцаРасчета", КонецМесяца(МесяцНачисления)); 
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	// Исключаемые лица
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПериодыПоФизлицам.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|   ЕСТЬNULL(СтатусФизическихЛицКакНалогоплательщиков.ИмеетПравоНаПенсионноеОбеспечение, ИСТИНА) КАК ИмеетПравоНаПенсионноеОбеспечение,
		|   ЕСТЬNULL(СтатусФизическихЛицКакНалогоплательщиков.ПодлежитСоциальномуСтрахованию, ИСТИНА) КАК ПодлежитСоциальномуСтрахованию,
		|   ЕСТЬNULL(СтатусФизическихЛицКакНалогоплательщиков.ПодлежитСоциальномуМедицинскомуСтрахованию, ИСТИНА) КАК ПодлежитСоциальномуМедицинскомуСтрахованию,
		|   ЛОЖЬ КАК ПенсионерПоВозрасту,
		|   ЛОЖЬ КАК ПенсионерПоВыслугеЛет,
		// инвалид любой группы бессрочный или инвалид во время действия справки об инвалидности
		|   ЛОЖЬ КАК Инвалид,
		// инвалид первой и второй группы бессрочно
		|	ЛОЖЬ КАК Инвалид1_2Бессрочно,
		// исчислять ОПВ по заявлению
		|	ЛОЖЬ КАК ИсчислятьОПВ,
		|	ЛОЖЬ КАК УчастникВОВ,
		|	ФизическиеЛица.ДатаРождения КАК ДатаРождения
		|ПОМЕСТИТЬ ВТИсключаемыеФизическиеЛицаИсточники
		|ИЗ
        |	ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусФизическихЛицКакНалогоплательщиков.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СтатусФизическихЛицКакНалогоплательщиков
		|		ПО СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо = ПериодыПоФизлицам.ФизическоеЛицо
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизическиеЛица
		|			ПО ФизическиеЛица.Ссылка = ПериодыПоФизлицам.ФизическоеЛицо
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПериодыПоФизлицам.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода,
		|   ЛОЖЬ,
		|   ЛОЖЬ,
		|   ЛОЖЬ,
		|   ЕСТЬNULL(СведенияОПенсионномОбеспеченииФизическихЛиц.ПенсионерПоВозрасту, ЛОЖЬ),
		|   ЕСТЬNULL(СведенияОПенсионномОбеспеченииФизическихЛиц.ПенсионерПоВыслугеЛет, ЛОЖЬ),
		|   ЛОЖЬ,
		|   ЛОЖЬ,
		|	ЛОЖЬ,
		|	ЛОЖЬ,
		|	ДАТАВРЕМЯ(1, 1, 1)
		|ИЗ
        |	ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОПенсионномОбеспеченииФизическихЛиц.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОПенсионномОбеспеченииФизическихЛиц
		|		ПО СведенияОПенсионномОбеспеченииФизическихЛиц.ФизическоеЛицо = ПериодыПоФизлицам.ФизическоеЛицо
		|ГДЕ
		|	(СведенияОПенсионномОбеспеченииФизическихЛиц.ПенсионерПоВозрасту
		|			ИЛИ СведенияОПенсионномОбеспеченииФизическихЛиц.ПенсионерПоВыслугеЛет)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПериодыПоФизлицам.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода,
		|   ЛОЖЬ,
		|   ЛОЖЬ,
		|   ЛОЖЬ,
		|   ЛОЖЬ,
		|   ЛОЖЬ,
		|	ВЫБОР
		|		КОГДА СведенияОбИнвалидностиФизическихЛицСрезПоследних.ОтношениеКИнвалидности ЕСТЬ NULL
		|			ТОГДА ЛОЖЬ
		|		КОГДА СведенияОбИнвалидностиФизическихЛицСрезПоследних.ОтношениеКИнвалидности = ЗНАЧЕНИЕ(Перечисление.ОтношениеКИнвалидности.Инвалид)
		|				И (СведенияОбИнвалидностиФизическихЛицСрезПоследних.ДействуетДо = ДАТАВРЕМЯ(1, 1, 1)
		|					ИЛИ КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(СведенияОбИнвалидностиФизическихЛицСрезПоследних.ДействуетДо, ДЕНЬ, -1), МЕСЯЦ) >= КОНЕЦПЕРИОДА(ПериодыПоФизлицам.МесяцНалоговогоПериода, МЕСЯЦ))
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ,
		|	ВЫБОР
		|		КОГДА СведенияОбИнвалидностиФизическихЛицСрезПоследних.ОтношениеКИнвалидности ЕСТЬ NULL
		|			ТОГДА ЛОЖЬ
		|		КОГДА СведенияОбИнвалидностиФизическихЛицСрезПоследних.ОтношениеКИнвалидности = ЗНАЧЕНИЕ(Перечисление.ОтношениеКИнвалидности.Инвалид)
		|				И СведенияОбИнвалидностиФизическихЛицСрезПоследних.ГруппаИнвалидности В (ЗНАЧЕНИЕ(Перечисление.ГруппыИнвалидности.Первая), ЗНАЧЕНИЕ(Перечисление.ГруппыИнвалидности.Вторая))
		|				И СведенияОбИнвалидностиФизическихЛицСрезПоследних.ДействуетДо = ДАТАВРЕМЯ(1, 1, 1)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ,
		|	ЕСТЬNULL(СведенияОбИнвалидностиФизическихЛицСрезПоследних.ИсчислятьОПВ, ЛОЖЬ),
		|	ЛОЖЬ,
		|	ДАТАВРЕМЯ(1, 1, 1)
		|ИЗ
		|	ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОбИнвалидностиФизическихЛиц.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОбИнвалидностиФизическихЛицСрезПоследних
		|		ПО СведенияОбИнвалидностиФизическихЛицСрезПоследних.ФизическоеЛицо = ПериодыПоФизлицам.ФизическоеЛицо
		|ГДЕ
		|	СведенияОбИнвалидностиФизическихЛицСрезПоследних.ОтношениеКИнвалидности = ЗНАЧЕНИЕ(Перечисление.ОтношениеКИнвалидности.Инвалид)
		|	И (СведенияОбИнвалидностиФизическихЛицСрезПоследних.ДействуетДо = ДАТАВРЕМЯ(1,1,1) 
		// ЗУП РФ поведение СведенияОбИнвалидностиФизическихЛиц.МО.ПередЗаписью: Строка.ДействуетДо = КонецДня(Строка.СрокДействияСправки) + 1 
		|		ИЛИ КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(СведенияОбИнвалидностиФизическихЛицСрезПоследних.ДействуетДо, ДЕНЬ, -1), МЕСЯЦ) >= КОНЕЦПЕРИОДА(ПериодыПоФизлицам.МесяцНалоговогоПериода, МЕСЯЦ))
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ПериодыПоФизлицам.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода,
		|   ЛОЖЬ,
		|   ЛОЖЬ,
		|   ЛОЖЬ,
		|   ЛОЖЬ,
		|   ЛОЖЬ,
		|   ЛОЖЬ,
		|   ЛОЖЬ,
		|   ЛОЖЬ,
		|	ИСТИНА,
		|	ДАТАВРЕМЯ(1, 1, 1)
		|ИЗ
		|	ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОФизическихЛицахУчастникахВОВ.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОФизическихЛицахУчастникахВОВСрезПоследних
		|		ПО СведенияОФизическихЛицахУчастникахВОВСрезПоследних.ФизическоеЛицо = ПериодыПоФизлицам.ФизическоеЛицо
		|ГДЕ
		|	(СведенияОФизическихЛицахУчастникахВОВСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.КатегорииФизическихЛицУчастниковВОВ.УчастникВОВ)
		|			ИЛИ СведенияОФизическихЛицахУчастникахВОВСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.КатегорииФизическихЛицУчастниковВОВ.ИнвалидВОВ))
		|
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТИсключаемыеФизическиеЛицаИсточники.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсключаемыеФизическиеЛицаИсточники.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|   МАКСИМУМ(ВТИсключаемыеФизическиеЛицаИсточники.ИмеетПравоНаПенсионноеОбеспечение) КАК ИмеетПравоНаПенсионноеОбеспечение,
		|   МАКСИМУМ(ВТИсключаемыеФизическиеЛицаИсточники.ПодлежитСоциальномуСтрахованию) КАК ПодлежитСоциальномуСтрахованию,
		|   МАКСИМУМ(ВТИсключаемыеФизическиеЛицаИсточники.ПодлежитСоциальномуМедицинскомуСтрахованию) КАК ПодлежитСоциальномуМедицинскомуСтрахованию,
		|   МАКСИМУМ(ВТИсключаемыеФизическиеЛицаИсточники.ПенсионерПоВозрасту) КАК ПенсионерПоВозрасту,
		|   МАКСИМУМ(ВТИсключаемыеФизическиеЛицаИсточники.ПенсионерПоВыслугеЛет) КАК ПенсионерПоВыслугеЛет,
		|	МАКСИМУМ(ВТИсключаемыеФизическиеЛицаИсточники.Инвалид) КАК Инвалид,
		|   МАКСИМУМ(ВТИсключаемыеФизическиеЛицаИсточники.Инвалид1_2Бессрочно) КАК Инвалид1_2Бессрочно,
		|   МАКСИМУМ(ВТИсключаемыеФизическиеЛицаИсточники.ИсчислятьОПВ) КАК ИсчислятьОПВ,
		|	МАКСИМУМ(ВТИсключаемыеФизическиеЛицаИсточники.УчастникВОВ) КАК УчастникВОВ,
		|	МАКСИМУМ(ВТИсключаемыеФизическиеЛицаИсточники.ДатаРождения) КАК ДатаРождения
		|ПОМЕСТИТЬ ВТМаксимумыИсключаемыеФизическиеЛица
		|ИЗ
		|	ВТИсключаемыеФизическиеЛицаИсточники КАК ВТИсключаемыеФизическиеЛицаИсточники
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсключаемыеФизическиеЛицаИсточники.ФизическоеЛицо,
		|	ВТИсключаемыеФизическиеЛицаИсточники.МесяцНалоговогоПериода
		|
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		// Исключаемые лица по компонентам единого платежа
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	МаксимумыИсключаемыеФизическиеЛица.ФизическоеЛицо КАК ФизическоеЛицо,
		|	МаксимумыИсключаемыеФизическиеЛица.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВЫБОР
		|		КОГДА НЕ МаксимумыИсключаемыеФизическиеЛица.ИмеетПравоНаПенсионноеОбеспечение
		|				ИЛИ МаксимумыИсключаемыеФизическиеЛица.ПенсионерПоВозрасту
		|				ИЛИ МаксимумыИсключаемыеФизическиеЛица.ПенсионерПоВыслугеЛет
		|				ИЛИ (МаксимумыИсключаемыеФизическиеЛица.Инвалид1_2Бессрочно
		|				И НЕ МаксимумыИсключаемыеФизическиеЛица.ИсчислятьОПВ)
		|			ТОГДА 0
		|		ИНАЧЕ 1
		|	КОНЕЦ КАК ИсключатьОПВ,
		|	ВЫБОР
		|		КОГДА НЕ МаксимумыИсключаемыеФизическиеЛица.ПодлежитСоциальномуМедицинскомуСтрахованию
		|				ИЛИ МаксимумыИсключаемыеФизическиеЛица.ПенсионерПоВозрасту
		|				ИЛИ МаксимумыИсключаемыеФизическиеЛица.ПенсионерПоВыслугеЛет
		|				ИЛИ МаксимумыИсключаемыеФизическиеЛица.Инвалид
		|				ИЛИ МаксимумыИсключаемыеФизическиеЛица.УчастникВОВ
		|			ТОГДА 0
		|		ИНАЧЕ 1
		|	КОНЕЦ КАК ИсключатьОСМС,
		|	ВЫБОР
		|		КОГДА НЕ МаксимумыИсключаемыеФизическиеЛица.ПодлежитСоциальномуСтрахованию
		|				ИЛИ МаксимумыИсключаемыеФизическиеЛица.ПенсионерПоВозрасту
		|			ТОГДА 0
		|		ИНАЧЕ 1
		|	КОНЕЦ КАК ИсключатьСО,
		|	ВЫБОР
		|		КОГДА НЕ МаксимумыИсключаемыеФизическиеЛица.ИмеетПравоНаПенсионноеОбеспечение
		|				ИЛИ МаксимумыИсключаемыеФизическиеЛица.ПенсионерПоВозрасту
		|				ИЛИ МаксимумыИсключаемыеФизическиеЛица.ПенсионерПоВыслугеЛет
		|				ИЛИ МаксимумыИсключаемыеФизическиеЛица.Инвалид1_2Бессрочно
		|				ИЛИ МаксимумыИсключаемыеФизическиеЛица.ДатаРождения = ДАТАВРЕМЯ(1, 1, 1)
		|				ИЛИ МаксимумыИсключаемыеФизическиеЛица.ДатаРождения < ДАТАВРЕМЯ(1975, 1, 1)
		|			ТОГДА 0
		|		ИНАЧЕ 1
		|	КОНЕЦ КАК ИсключатьОПВР
		|ПОМЕСТИТЬ ВТИтогИсключаемыеНВОФизическиеЛица
		|ИЗ
		|	ВТМаксимумыИсключаемыеФизическиеЛица КАК МаксимумыИсключаемыеФизическиеЛица
		|
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		// Исключаемые лица по единому платежу
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПериодыПоФизлицам.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя) КАК ВидДохода,
		|	ЕСТЬNULL(СтатусыФизическихЛицКакНалогоплательщиков.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)) = ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент) КАК СтатусНеРезидента
		|ПОМЕСТИТЬ ВТИсключаемыеФизическиеЛицаПриРасчетеЕП
		|ИЗ ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтатусыФизическихЛицКакНалогоплательщиков КАК СтатусыФизическихЛицКакНалогоплательщиков
		|		ПО ПериодыПоФизлицам.МесяцНалоговогоПериода = СтатусыФизическихЛицКакНалогоплательщиков.МесяцНалоговогоПериода
		|			И ПериодыПоФизлицам.ФизическоеЛицо = СтатусыФизическихЛицКакНалогоплательщиков.ФизическоеЛицо
		|ГДЕ
		|	СтатусыФизическихЛицКакНалогоплательщиков.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Нерезидент)
		|";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВТИтогИсключаемыеНВОФизическиеЛица", ИмяТаблицы);	
	Запрос.Выполнить();

	УничтожитьВТ = Новый Массив;
	УничтожитьВТ.Добавить("ВТМаксимумыИсключаемыеФизическиеЛица");
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаИсточники");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);

КонецПроцедуры

Процедура СоздатьВТРанееИсчисленныеКомпонентыЕП(Организация, Регистратор, МенеджерВременныхТаблиц, ПоследнийМесяцНалоговогоПериода, ОкончательныйРасчет, ИсключатьДоходыРегистратора, ПредоставлятьВычетВМесяцеОтсутствияДохода = Ложь)
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ГоловнаяОрганизация", ЗарплатаКадрыПовтИсп.ГоловнаяОрганизация(Организация));
	Запрос.УстановитьПараметр("НачалоГодаПервогоМесяцаНалоговогоПериода", НачалоГода(ПоследнийМесяцНалоговогоПериода));
	Запрос.УстановитьПараметр("ПоследнийМесяцНалоговогоПериода", ПоследнийМесяцНалоговогоПериода);
	Запрос.УстановитьПараметр("ИсключаемыйРегистратор", ?(ИсключатьДоходыРегистратора, Регистратор, Неопределено));

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(СведенияОКомпонентахЕП.Период, МЕСЯЦ) КАК МесяцНалоговогоПериода,
		|	СведенияОКомпонентахЕП.Подразделение,
		|	СведенияОКомпонентахЕП.ФизическоеЛицо,
		|	СведенияОКомпонентахЕП.МесяцНалоговогоПериода,
		|	СведенияОКомпонентахЕП.РегистрацияВНалоговомОргане,
		|	СведенияОКомпонентахЕП.ВидПлатежа,
		|   СведенияОКомпонентахЕП.ОПВОборот КАК ОПВ,
		|   СведенияОКомпонентахЕП.ВОСМСОборот КАК ВОСМС,
		|   СведенияОКомпонентахЕП.ИПНОборот КАК ИПН,
		|   СведенияОКомпонентахЕП.ООСМСОборот КАК ООСМС,
		|   СведенияОКомпонентахЕП.СООборот КАК СО,
		|   СведенияОКомпонентахЕП.ОПВРОборот КАК ОПВР
		|ПОМЕСТИТЬ ВТИсчисленныеКомпонентыЕП
		|ИЗ
		|	РегистрНакопления.ЕПКомпоненты.Обороты(
		|			&НачалоГодаПервогоМесяцаНалоговогоПериода,
		|			&ПоследнийМесяцНалоговогоПериода,
		|			Регистратор,
		|			Организация = &Организация
		// данные документов-исправлений будущего периода не учитываем
		|				И МесяцНалоговогоПериода <= &ПоследнийМесяцНалоговогоПериода
		|				И ФизическоеЛицо В
		|					(ВЫБРАТЬ
		|						СписокСотрудников.ФизическоеЛицо
		|					ИЗ
		|						ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОКомпонентахЕП
		|
		|ГДЕ
		|	СведенияОКомпонентахЕП.Регистратор <> &ИсключаемыйРегистратор
		|
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода,
		|	ИсчисленныеКомпонентыЕП.Подразделение,
		|	ИсчисленныеКомпонентыЕП.ФизическоеЛицо,
		|	ИсчисленныеКомпонентыЕП.МесяцНалоговогоПериода,
		|	ИсчисленныеКомпонентыЕП.РегистрацияВНалоговомОргане,
		|	ИсчисленныеКомпонентыЕП.ВидПлатежа,
		|	СУММА(ВЫБОР
		|			КОГДА ПериодыПоФизлицам.МесяцНалоговогоПериода = ИсчисленныеКомпонентыЕП.МесяцНалоговогоПериода
		|				И &ОкончательныйРасчетНалоги
		|				ТОГДА ИсчисленныеКомпонентыЕП.ОПВ
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК ОПВ,
		|	СУММА(ВЫБОР
		|			КОГДА ПериодыПоФизлицам.МесяцНалоговогоПериода = ИсчисленныеКомпонентыЕП.МесяцНалоговогоПериода
		|				И &ОкончательныйРасчетНалоги
		|				ТОГДА ИсчисленныеКомпонентыЕП.ВОСМС
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК ВОСМС,
		|	СУММА(ВЫБОР
		|			КОГДА ПериодыПоФизлицам.МесяцНалоговогоПериода = ИсчисленныеКомпонентыЕП.МесяцНалоговогоПериода
		|				И &ОкончательныйРасчетНалоги
		|				ТОГДА ИсчисленныеКомпонентыЕП.ИПН
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК ИПН,
		|	СУММА(ВЫБОР
		|			КОГДА ПериодыПоФизлицам.МесяцНалоговогоПериода = ИсчисленныеКомпонентыЕП.МесяцНалоговогоПериода
		|				И &ОкончательныйРасчетНалоги
		|				ТОГДА ИсчисленныеКомпонентыЕП.ООСМС
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК ООСМС,
		|	СУММА(ВЫБОР
		|			КОГДА ПериодыПоФизлицам.МесяцНалоговогоПериода = ИсчисленныеКомпонентыЕП.МесяцНалоговогоПериода
		|				И &ОкончательныйРасчетНалоги
		|				ТОГДА ИсчисленныеКомпонентыЕП.СО
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК СО,
		|	СУММА(ВЫБОР
		|			КОГДА ПериодыПоФизлицам.МесяцНалоговогоПериода = ИсчисленныеКомпонентыЕП.МесяцНалоговогоПериода
		|				И &ОкончательныйРасчетНалоги
		|				ТОГДА ИсчисленныеКомпонентыЕП.ОПВР
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК ОПВР
		|ПОМЕСТИТЬ ВТРанееИсчисленныеКомпонентыЕП
		|ИЗ
		|	ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТИсчисленныеКомпонентыЕП КАК ИсчисленныеКомпонентыЕП
		|		ПО ПериодыПоФизлицам.МесяцНалоговогоПериода >= ИсчисленныеКомпонентыЕП.МесяцНалоговогоПериода
		|			И ПериодыПоФизлицам.ФизическоеЛицо = ИсчисленныеКомпонентыЕП.ФизическоеЛицо
		|ГДЕ
		// корректируем расчеты конфигурации, пени и самостоятельные корректировки не принимаем во внимание
		|	ИсчисленныеКомпонентыЕП.ВидПлатежа = ЗНАЧЕНИЕ(Перечисление.ВидыПлатежейВГосБюджет.Налог)
		|
		|СГРУППИРОВАТЬ ПО
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода,
		|	ИсчисленныеКомпонентыЕП.Подразделение,
		|	ИсчисленныеКомпонентыЕП.ФизическоеЛицо,
		|	ИсчисленныеКомпонентыЕП.МесяцНалоговогоПериода,
		|	ИсчисленныеКомпонентыЕП.РегистрацияВНалоговомОргане,
		|	ИсчисленныеКомпонентыЕП.ВидПлатежа
		|";
		
	Если ОкончательныйРасчет Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОкончательныйРасчетНалоги", "Истина");
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&ОкончательныйРасчетНалоги", "Ложь");
	КонецЕсли;
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеКомпонентыЕП");	
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
КонецПроцедуры

Функция ПолучитьБазуДляЕдиногоПлатежа(Организация, ПериодРегистрации, ФизическиеЛицаМассив, ВидДохода = Неопределено)
	
	Запрос = Новый Запрос;
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	СведенияОДоходах.Организация КАК Организация,
		|	СведенияОДоходах.ФизическоеЛицо КАК ФизическоеЛицо,
		|	СведенияОДоходах.Сотрудник КАК Сотрудник,
		|	СведенияОДоходах.Подразделение КАК Подразделение,
		|	СУММА(СведенияОДоходах.СуммаДохода) КАК Сумма,
		|	СведенияОДоходах.Период КАК МесяцНалоговогоПериода,
		|	СведенияОДоходах.ДатаНачала КАК ДатаНачала,
		|	СведенияОДоходах.Начисление КАК Начисление
		|ПОМЕСТИТЬ ВТСведенияОДоходах
		|ИЗ
		|	РегистрНакопления.СведенияОДоходахФизическихЛиц КАК СведенияОДоходах
		|ГДЕ
		|	СведенияОДоходах.Организация = &Организация
		|	И СведенияОДоходах.ПериодРегистрации = &ПериодРегистрации
		|	И СведенияОДоходах.ФизическоеЛицо В(&ФизическиеЛица)
		|	И СведенияОДоходах.Активность
		|
		|СГРУППИРОВАТЬ ПО
		|	СведенияОДоходах.Организация,
		|	СведенияОДоходах.ФизическоеЛицо,
		|	СведенияОДоходах.Сотрудник,
		|	СведенияОДоходах.Подразделение,
		|	СведенияОДоходах.Период,
		|	СведенияОДоходах.ДатаНачала,
		|	СведенияОДоходах.Начисление
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(НалогообложениеНачислений.Период) КАК Период,
		|	НалогообложениеНачислений.Начисление КАК Начисление,
		|	ВТСведенияОДоходах.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода
		|ПОМЕСТИТЬ ВТПериодыНалогообложения
		|ИЗ
		|	ВТСведенияОДоходах КАК ВТСведенияОДоходах
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НалогообложениеНачислений КАК НалогообложениеНачислений
		|		ПО ВТСведенияОДоходах.МесяцНалоговогоПериода >= НалогообложениеНачислений.Период
		|			И ВТСведенияОДоходах.Начисление = НалогообложениеНачислений.Начисление
		|
		|СГРУППИРОВАТЬ ПО
		|	НалогообложениеНачислений.Начисление,
		|	ВТСведенияОДоходах.МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТПериодыНалогообложения.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТПериодыНалогообложения.Начисление КАК Начисление,
		|	НалогообложениеНачислений.ВидДохода КАК ВидДохода,
		|	НалогообложениеНачислений.СпособОбложенияЕП КАК СпособОбложенияЕП
		|ПОМЕСТИТЬ ВТНалогообложениеНачислений
		|ИЗ
		|	ВТПериодыНалогообложения КАК ВТПериодыНалогообложения
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НалогообложениеНачислений КАК НалогообложениеНачислений
		|		ПО ВТПериодыНалогообложения.Период = НалогообложениеНачислений.Период
		|			И ВТПериодыНалогообложения.Начисление = НалогообложениеНачислений.Начисление
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТСведенияОДоходах.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТСведенияОДоходах.Сотрудник КАК Сотрудник,
		|	ВТСведенияОДоходах.Подразделение КАК Подразделение,
		|	ВТНалогообложениеНачислений.ВидДохода КАК ВидДохода,
		|	ВТСведенияОДоходах.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТСведенияОДоходах.ДатаНачала КАК ДатаНачала,
		|	СУММА(ВЫБОР
		|			КОГДА ЕСТЬNULL(ВТНалогообложениеНачислений.СпособОбложенияЕП, ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.ОблагаетсяЦеликом)) <> ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.НеОблагаетсяЦеликом)
		|				ТОГДА ВТСведенияОДоходах.Сумма
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК Сумма
		|ИЗ
		|	ВТСведенияОДоходах КАК ВТСведенияОДоходах
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНалогообложениеНачислений КАК ВТНалогообложениеНачислений
		|		ПО ВТСведенияОДоходах.МесяцНалоговогоПериода = ВТНалогообложениеНачислений.МесяцНалоговогоПериода
		|			И ВТСведенияОДоходах.Начисление = ВТНалогообложениеНачислений.Начисление
		|ГДЕ
		|	ВТНалогообложениеНачислений.ВидДохода ЕСТЬ NULL
		|	ИЛИ ВТНалогообложениеНачислений.ВидДохода = &ВидДохода
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТСведенияОДоходах.ФизическоеЛицо,
		|	ВТСведенияОДоходах.Сотрудник,
		|	ВТСведенияОДоходах.Подразделение,
		|	ВТНалогообложениеНачислений.ВидДохода,
		|	ВТСведенияОДоходах.МесяцНалоговогоПериода,
		|	ВТСведенияОДоходах.ДатаНачала
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТСведенияОДоходах.Организация КАК Организация,
		|	ВТСведенияОДоходах.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТСведенияОДоходах.Сотрудник КАК Сотрудник,
		|	ВТСведенияОДоходах.Подразделение КАК Подразделение,
		|	ВТСведенияОДоходах.Начисление КАК Начисление,
		|	ВТНалогообложениеНачислений.ВидДохода КАК ВидДохода,
		|	ВТСведенияОДоходах.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТСведенияОДоходах.ДатаНачала КАК ДатаНачала,
		|	СУММА(ВЫБОР
		|			КОГДА ЕСТЬNULL(ВТНалогообложениеНачислений.СпособОбложенияЕП, ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.ОблагаетсяЦеликом)) <> ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.НеОблагаетсяЦеликом)
		|				ТОГДА ВТСведенияОДоходах.Сумма
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК База
		|ИЗ
		|	ВТСведенияОДоходах КАК ВТСведенияОДоходах
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНалогообложениеНачислений КАК ВТНалогообложениеНачислений
		|		ПО ВТСведенияОДоходах.МесяцНалоговогоПериода = ВТНалогообложениеНачислений.МесяцНалоговогоПериода
		|			И ВТСведенияОДоходах.Начисление = ВТНалогообложениеНачислений.Начисление
		|ГДЕ
		|	ВТНалогообложениеНачислений.ВидДохода ЕСТЬ NULL
		|	ИЛИ ВТНалогообложениеНачислений.ВидДохода = &ВидДохода
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТСведенияОДоходах.Организация,
		|	ВТСведенияОДоходах.ФизическоеЛицо,
		|	ВТСведенияОДоходах.Сотрудник,
		|	ВТСведенияОДоходах.Начисление,
		|	ВТСведенияОДоходах.Подразделение,
		|	ВТНалогообложениеНачислений.ВидДохода,
		|	ВТСведенияОДоходах.МесяцНалоговогоПериода,
		|	ВТСведенияОДоходах.ДатаНачала
		|";
		
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ПериодРегистрации", ПериодРегистрации);
	Запрос.УстановитьПараметр("ФизическиеЛица", ФизическиеЛицаМассив);
	
	Если ВидДохода = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ИЛИ ВТНалогообложениеНачислений.ВидДохода = &ВидДохода", "ИЛИ ИСТИНА");
	Иначе
		Запрос.УстановитьПараметр("ВидДохода", ВидДохода);
	КонецЕсли;
	
	Результат = Запрос.ВыполнитьПакет();
	ВсегоРезультатов = Результат.Количество();

	БазаРасчетаЕПЗаСчетРаботника = Результат[ВсегоРезультатов-2].Выгрузить();
	БазаРасчетаЕПЗаСчетРаботодателя = Результат[ВсегоРезультатов-1].Выгрузить();
	
	Возврат Новый Структура("БазаРасчетаЕПЗаСчетРаботника, БазаРасчетаЕПЗаСчетРаботодателя", БазаРасчетаЕПЗаСчетРаботника, БазаРасчетаЕПЗаСчетРаботодателя);
	
КонецФункции

Процедура ЗарегистрироватьЕдиныйПлатеж(Движения, Отказ, РеквизитыДляПроведения, ДанныеДляПроведения, МенеджерВременныхТаблиц, ХарактерВыплаты = Неопределено, ЗаписыватьДвижения = Ложь, ИмяПоляМесяц = "Ссылка.МесяцНачисления") Экспорт
	
	Если ИмяПоляМесяц = "Ссылка.МесяцНачисления" Тогда
		ПериодРегистрацииИмя = "МесяцНачисления";
	Иначе
		ПериодРегистрацииИмя = "ПериодРегистрации";
	КонецЕсли;
	
	ПериодРегистрации = РеквизитыДляПроведения[ПериодРегистрацииИмя];
	
	ДатаКонтроля = '2023-01-01';
	Если ПериодРегистрации < ДатаКонтроля Тогда
		Возврат;
	КонецЕсли;

	Организация = РеквизитыДляПроведения.Организация;
	
	ДанныеМежрасчетногоПериода = ?(ХарактерВыплаты = Перечисления.ХарактерВыплатыЗарплаты.Зарплата Или
									ХарактерВыплаты = Неопределено, Ложь, Истина);
									
	МассивФизическихЛиц = ОбщегоНазначения.ВыгрузитьКолонку(ДанныеДляПроведения.НалогиВзносыОтчисления, "ФизическоеЛицо", Истина);
	БазаРасчета = ПолучитьБазуДляЕдиногоПлатежа(Организация, ПериодРегистрации, МассивФизическихЛиц, Справочники.ВидыДоходов.ДоходыОтРаботодателя);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ФизическиеЛица", МассивФизическихЛиц);
	Запрос.УстановитьПараметр("ПериодРегистрации", ПериодРегистрации);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("КонецМесяцаНачисления", КонецМесяца(ПериодРегистрации));

	ОписаниеСтатейРасходов = ЗарплатаКадры.СтатьиРасходовПоСпособамРасчетовСФизическимиЛицами();
	ОплатаТруда = ОписаниеСтатейРасходов[Перечисления.СпособыРасчетовСФизическимиЛицами.ОплатаТруда];

	Если ДанныеМежрасчетногоПериода Тогда
		
		СтруктураОтбора = Новый Структура("ВидНалогаВзносаОтчисления, ВидДохода");
		СтруктураОтбора.ВидДохода = Справочники.ВидыДоходов.ДоходыОтРаботодателя;
		
		// ЕП
		СтруктураОтбора.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ЕП;
		ТаблицаЕП = ДанныеДляПроведения.НалогиВзносыОтчисления.Скопировать(СтруктураОтбора);

		ТаблицаЕП.Колонки.Добавить("ТерриторияВыполненияРаботВОрганизации", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
		ТаблицаЕП.Колонки.Добавить("Сотрудник", Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
		ТаблицаЕП.Колонки.Добавить("СтатьиФинансированияЗарплата", Новый ОписаниеТипов("СправочникСсылка.СтатьиФинансированияЗарплата"));
		ТаблицаЕП.Колонки.Добавить("СтатьиРасходовЗарплата", Новый ОписаниеТипов("СправочникСсылка.СтатьиРасходовЗарплата"));
		ТаблицаЕП.Колонки.Добавить("ВидДоходаИсполнительногоПроизводства", Новый ОписаниеТипов("ПеречислениеСсылка.ВидыДоходовИсполнительногоПроизводства"));
		ТаблицаЕП.Колонки.Добавить("ГруппаНачисленияУдержанияВыплаты", Новый ОписаниеТипов("ПеречислениеСсылка.ГруппыНачисленияУдержанияВыплаты"));
		ТаблицаЕП.ЗаполнитьЗначения(Перечисления.ГруппыНачисленияУдержанияВыплаты.Удержано, "ГруппаНачисленияУдержанияВыплаты");
		
		// ЕП
		УдержанияПоРабочимМестамЕП = УчетНачисленнойЗарплатыРасширенный.РаспределениеПрочихУдержанийПоРабочимМестам(ТаблицаЕП, ПериодРегистрации, Организация, БазаРасчета.БазаРасчетаЕПЗаСчетРаботника, , Перечисления.ВидыОсобыхНачисленийИУдержаний.ЕП, , , Истина);
		УдержанияПоРабочимМестамЕП.ЗаполнитьЗначения(ДанныеМежрасчетногоПериода, "ДанныеМежрасчетногоПериода");
    	УдержанияПоРабочимМестамЕП.ЗаполнитьЗначения(Перечисления.ВидыДоходовИсполнительногоПроизводства.ДоходыБезОграниченияВзысканий, "ВидДоходаИсполнительногоПроизводства");
		УдержанияПоРабочимМестамЕП.ЗаполнитьЗначения(ОплатаТруда, "СтатьяРасходов");
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(УдержанияПоРабочимМестамЕП, Движения.НачисленияУдержанияПоСотрудникам);
		
	Иначе
		
		Регистратор = РеквизитыДляПроведения.Ссылка;
		
		Запрос.УстановитьПараметр("Регистратор", Регистратор);
		
		// за счет работника
		Запрос.Текст = "ВЫБРАТЬ
		|	НалогиВзносыОтчисления.ФизическоеЛицо,
		|	НалогиВзносыОтчисления.Подразделение,
		|	ЗНАЧЕНИЕ(Перечисление.ВидыПлатежейВГосБюджет.Налог) КАК ВидПлатежа,
		|	НалогиВзносыОтчисления.Ссылка.МесяцНачисления КАК ПериодРегистрации,
		|	НалогиВзносыОтчисления.МесяцНалоговогоПериода,
		|	СУММА(НалогиВзносыОтчисления.НалогВзнос) КАК СуммаПлатежа,
		|	СУММА(КомпонентыЕП.ОПВ + КомпонентыЕП.ВОСМС + КомпонентыЕП.ИПН + КомпонентыЕП.ООСМС + КомпонентыЕП.СО + КомпонентыЕП.ОПВР) КАК СуммаПлатежаЗаМесяц,
		|	СУММА(КомпонентыЕП.ОПВ) КАК ОПВ,
		|	СУММА(КомпонентыЕП.ВОСМС) КАК ВОСМС,
		|	СУММА(КомпонентыЕП.ИПН) КАК ИПН,
		|	СУММА(КомпонентыЕП.ООСМС) КАК ООСМС,
		|	СУММА(КомпонентыЕП.СО) КАК СО,
		|	СУММА(КомпонентыЕП.ОПВР) КАК ОПВР
		|ПОМЕСТИТЬ ВТСведенияОКомпонентахЕП
		|ИЗ
		|	#НалогиВзносыОтчисления КАК НалогиВзносыОтчисления
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ #КомпонентыЕП КАК КомпонентыЕП
		|		ПО НалогиВзносыОтчисления.ИдентификаторСтрокиНалогиВзносыОтчисления = КомпонентыЕП.ИдентификаторСтрокиНалогиВзносыОтчисления
		|			И НалогиВзносыОтчисления.Ссылка = КомпонентыЕП.Ссылка
		|ГДЕ
		|	НалогиВзносыОтчисления.Ссылка = &Регистратор
		|
		|СГРУППИРОВАТЬ ПО
		|	НалогиВзносыОтчисления.ФизическоеЛицо,
		|	НалогиВзносыОтчисления.Подразделение,
		|	НалогиВзносыОтчисления.Ссылка.МесяцНачисления,
		|	НалогиВзносыОтчисления.МесяцНалоговогоПериода
		|
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СведенияОКомпонентахЕП.ФизическоеЛицо,
		|	СведенияОКомпонентахЕП.Подразделение,
		|	СведенияОКомпонентахЕП.ВидПлатежа КАК ВидПлатежа,
		|	СведенияОКомпонентахЕП.ПериодРегистрации КАК ПериодРегистрации,
		|	СведенияОКомпонентахЕП.МесяцНалоговогоПериода,
		|	СведенияОКомпонентахЕП.СуммаПлатежа КАК СуммаПлатежа,
		|	СведенияОКомпонентахЕП.СуммаПлатежаЗаМесяц КАК СуммаПлатежаЗаМесяц,
		|	-(СведенияОКомпонентахЕП.СуммаПлатежаЗаМесяц - СведенияОКомпонентахЕП.СуммаПлатежа) КАК СуммаПлатежаРанееИсчисленная,
		|	СведенияОКомпонентахЕП.ОПВ КАК ОПВ,
		|	СведенияОКомпонентахЕП.ВОСМС КАК ВОСМС,
		|	СведенияОКомпонентахЕП.ИПН КАК ИПН,
		|	СведенияОКомпонентахЕП.СО КАК СО,
		|	СведенияОКомпонентахЕП.ОПВР КАК ОПВР,
		|	СведенияОКомпонентахЕП.ООСМС КАК ООСМС
		|ИЗ
		|	ВТСведенияОКомпонентахЕП КАК СведенияОКомпонентахЕП
		|";
		
	    Запрос.Текст = СтрЗаменить(Запрос.Текст, "Ссылка.МесяцНачисления",  ИмяПоляМесяц);
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "#НалогиВзносыОтчисления", Регистратор.Метаданные().ПолноеИмя() + ".НалогиВзносыОтчисления");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "#КомпонентыЕП",           Регистратор.Метаданные().ПолноеИмя() + ".КомпонентыЕП");
		
		РезультатыРасчетаЕдиныйПлатеж = Запрос.Выполнить().Выгрузить();

		// ЕП за счет работника
		РезультатыРасчетаЕдиныйПлатеж.Колонки.Добавить("ТерриторияВыполненияРаботВОрганизации", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
		РезультатыРасчетаЕдиныйПлатеж.Колонки.Добавить("Сотрудник", Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
		РезультатыРасчетаЕдиныйПлатеж.Колонки.Добавить("СтатьиФинансированияЗарплата", Новый ОписаниеТипов("СправочникСсылка.СтатьиФинансированияЗарплата"));
		РезультатыРасчетаЕдиныйПлатеж.Колонки.Добавить("СтатьиРасходовЗарплата", Новый ОписаниеТипов("СправочникСсылка.СтатьиРасходовЗарплата"));
		РезультатыРасчетаЕдиныйПлатеж.Колонки.Добавить("ВидДоходаИсполнительногоПроизводства", Новый ОписаниеТипов("ПеречислениеСсылка.ВидыДоходовИсполнительногоПроизводства"));
		РезультатыРасчетаЕдиныйПлатеж.Колонки.Добавить("ГруппаНачисленияУдержанияВыплаты", Новый ОписаниеТипов("ПеречислениеСсылка.ГруппыНачисленияУдержанияВыплаты"));
		РезультатыРасчетаЕдиныйПлатеж.ЗаполнитьЗначения(Перечисления.ГруппыНачисленияУдержанияВыплаты.Удержано, "ГруппаНачисленияУдержанияВыплаты");

		МассивНВО = Новый Массив;
		МассивНВО.Добавить("ОПВ");
		МассивНВО.Добавить("ВОСМС");
		МассивНВО.Добавить("ИПН");
		МассивНВО.Добавить("СуммаПлатежаРанееИсчисленная");
		
		УдержанияПоРабочимМестамЕП = Неопределено;
		
		Для Каждого ВидНВО Из МассивНВО Цикл
			
			РезультатыРасчетаЕдиныйПлатеж.Колонки[ВидНВО].Имя = "Сумма";
			
			// точность распределения 0
			УдержанияПоРабочимМестамЕПКомпоненты = УчетНачисленнойЗарплатыРасширенный.РаспределениеПрочихУдержанийПоРабочимМестам(РезультатыРасчетаЕдиныйПлатеж, ПериодРегистрации, Организация, БазаРасчета.БазаРасчетаЕПЗаСчетРаботника, , Перечисления.ВидыОсобыхНачисленийИУдержаний.ЕП, , , Истина);
			
			РезультатыРасчетаЕдиныйПлатеж.Колонки["Сумма"].Имя = ВидНВО;

			Если УдержанияПоРабочимМестамЕП = Неопределено Тогда
				УдержанияПоРабочимМестамЕП = УдержанияПоРабочимМестамЕПКомпоненты;
			Иначе
				ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(УдержанияПоРабочимМестамЕПКомпоненты, УдержанияПоРабочимМестамЕП);	
			КонецЕсли;
			
		КонецЦикла;
		
		УдержанияПоРабочимМестамЕП.ЗаполнитьЗначения(ОплатаТруда, "СтатьяРасходов");
     	УдержанияПоРабочимМестамЕП.ЗаполнитьЗначения(Перечисления.ВидыДоходовИсполнительногоПроизводства.ДоходыБезОграниченияВзысканий, "ВидДоходаИсполнительногоПроизводства");
		УдержанияПоРабочимМестамЕП.Свернуть("Период, Организация, ФизическоеЛицо, СтатьяФинансирования, СтатьяРасходов, Сотрудник, Подразделение, НачислениеУдержание, ГруппаНачисленияУдержанияВыплаты, ПериодДействия, ДокументОснование, Контрагент, ДатаНачала, ДатаОкончания, ДанныеМежрасчетногоПериода, ТерриторияВыполненияРаботВОрганизации, 
                                        |ВидДоходаИсполнительногоПроизводства, ДатаПолученияДохода, ЗачетАвансаНДФЛ, КатегорияДохода, МестоПолученияДохода, ПервичныйРегистратор, УчитыватьВРаспределенииНДФЛ,
										|ИдентификаторСтроки, РегистрацияВНалоговомОргане, Сторно, ОграничениеВзыскания", "Сумма, СуммаКорректировкиВыплаты");
		
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(УдержанияПоРабочимМестамЕП, Движения.НачисленияУдержанияПоСотрудникам);
		
	КонецЕсли;

	// Взаиморасчеты
	Если ЗначениеЗаполнено(ХарактерВыплаты)
		ИЛИ ХарактерВыплаты = Неопределено Тогда
		
		Если ХарактерВыплаты = Неопределено Тогда
			ХарактерВыплатыВзаиморасчеты = Перечисления.ХарактерВыплатыЗарплаты.Межрасчет;	
		Иначе	
			ХарактерВыплатыВзаиморасчеты = ХарактерВыплаты;	
		КонецЕсли;
		УдержанияДляВзаиморасчетов = ВзаиморасчетыССотрудниками.НоваяТаблицаНачисленнойЗарплаты();
		ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(УдержанияПоРабочимМестамЕП, УдержанияДляВзаиморасчетов);
		ВзаиморасчетыССотрудниками.ЗарегистрироватьНачисленнуюЗарплату(
			Движения, Отказ, 
			Организация, ПериодРегистрации, ХарактерВыплатыВзаиморасчеты,
			Неопределено, УдержанияДляВзаиморасчетов);
	КонецЕсли;
	
	Если ДанныеМежрасчетногоПериода Тогда
		Возврат;
	КонецЕсли;
	
	// ЕП за счет работника
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КомпонентыЕП.ФизическоеЛицо,
		|	КомпонентыЕП.Подразделение,
		|	КомпонентыЕП.ПериодРегистрации КАК МесяцНалоговогоПериода,
		|	КомпонентыЕП.ПериодРегистрации КАК Период,
		|	КомпонентыЕП.ВидПлатежа КАК ВидПлатежа,
		|	КомпонентыЕП.ОПВ КАК ОПВ,
		|	КомпонентыЕП.ВОСМС КАК ВОСМС,
		|	КомпонентыЕП.ИПН КАК ИПН,
		|	0 КАК ООСМС,
		|	0 КАК СО,
		|	0 КАК ОПВР,
		|	ИсторияРегистрацийВНалоговомОрганеСрезПоследних.РегистрацияВНалоговомОргане
		|ИЗ
		|	ВТСведенияОКомпонентахЕП КАК КомпонентыЕП
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИсторияРегистрацийВНалоговомОргане.СрезПоследних(
		|				&КонецМесяцаНачисления,
		|				СтруктурнаяЕдиница В
		|					(ВЫБРАТЬ
		|						СведенияОКомпонентахЕП.Подразделение
		|					ИЗ
		|						ВТСведенияОКомпонентахЕП КАК СведенияОКомпонентахЕП)) КАК ИсторияРегистрацийВНалоговомОрганеСрезПоследних
		|		ПО КомпонентыЕП.Подразделение = ИсторияРегистрацийВНалоговомОрганеСрезПоследних.СтруктурнаяЕдиница
		|ГДЕ
		|	(КомпонентыЕП.ОПВ <> 0
		|			ИЛИ КомпонентыЕП.ВОСМС <> 0
		|			ИЛИ КомпонентыЕП.ИПН <> 0)
		|";
		
	Выборка = Запрос.Выполнить().Выбрать();

	РегистрацияОрганизации = ЗарплатаКадры.РегистрацияВНалоговомОргане(Организация, КонецМесяца(ПериодРегистрации));
	
	Пока Выборка.Следующий() Цикл
		НоваяЗапись = Движения.ЕПКомпоненты.Добавить(); 
		ЗаполнитьЗначенияСвойств(НоваяЗапись, Выборка);
		НоваяЗапись.Организация = Организация;
		ПроставитьРегистрациюВНалоговомОрганеВСтроке(НоваяЗапись, Выборка.РегистрацияВНалоговомОргане, РегистрацияОрганизации);
	КонецЦикла;
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КомпонентыЕП.ФизическоеЛицо,
		|	КомпонентыЕП.Подразделение,
		|	КомпонентыЕП.ПериодРегистрации КАК МесяцНалоговогоПериода,
		|	КомпонентыЕП.ВидПлатежа КАК ВидПлатежа,
		|	ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ООСМС) КАК ВидНалогаВзносаОтчисления,
		|	КомпонентыЕП.ООСМС КАК Сумма
		|ИЗ
		|	ВТСведенияОКомпонентахЕП КАК КомпонентыЕП
		|ГДЕ
		|	КомпонентыЕП.ООСМС <> 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	КомпонентыЕП.ФизическоеЛицо,
		|	КомпонентыЕП.Подразделение,
		|	КомпонентыЕП.ПериодРегистрации КАК МесяцНалоговогоПериода,
		|	КомпонентыЕП.ВидПлатежа,
		|	ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.СО) КАК ВидНалогаВзносаОтчисления,
		|	КомпонентыЕП.СО КАК Сумма
		|ИЗ
		|	ВТСведенияОКомпонентахЕП КАК КомпонентыЕП
		|ГДЕ
		|	КомпонентыЕП.СО <> 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	КомпонентыЕП.ФизическоеЛицо,
		|	КомпонентыЕП.Подразделение,
		|	КомпонентыЕП.ПериодРегистрации КАК МесяцНалоговогоПериода,
		|	КомпонентыЕП.ВидПлатежа,
		|	ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ОПВР) КАК ВидНалогаВзносаОтчисления,
		|	КомпонентыЕП.ОПВР КАК Сумма
		|ИЗ
		|	ВТСведенияОКомпонентахЕП КАК КомпонентыЕП
		|ГДЕ
		|	КомпонентыЕП.ОПВР <> 0
		|";
		
	//Выборка = Запрос.Выполнить().Выбрать();
	ИсчисленныеНалогиВзносы = Запрос.Выполнить().Выгрузить();
	
	СтруктураОтбора = Новый Структура("ВидНалогаВзносаОтчисления");
	
	// СО
	СтруктураОтбора.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.СО;
	ТаблицаСО = ИсчисленныеНалогиВзносы.Скопировать(СтруктураОтбора);
	
	// ООСМС
	СтруктураОтбора.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ООСМС;
	ТаблицаООСМС = ИсчисленныеНалогиВзносы.Скопировать(СтруктураОтбора);
	
	// ОПВР
	СтруктураОтбора.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ОПВР;
	ТаблицаОПВР = ИсчисленныеНалогиВзносы.Скопировать(СтруктураОтбора);
	
	НоваяТаблицаРаспределения = Движения.ЕПКомпоненты.ВыгрузитьКолонки();

	// СО
	СОПоСотрудникам = НалогиВзносыОтчисленияПоСотрудникам(ТаблицаСО, БазаРасчета.БазаРасчетаЕПЗаСчетРаботодателя);
	СОПоСотрудникам.Колонки.Сумма.Имя = "СО";
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(СОПоСотрудникам, НоваяТаблицаРаспределения);
	
	// ООСМС
	ООСМСПоСотрудникам = НалогиВзносыОтчисленияПоСотрудникам(ТаблицаООСМС, БазаРасчета.БазаРасчетаЕПЗаСчетРаботодателя);
	ООСМСПоСотрудникам.Колонки.Сумма.Имя = "ООСМС";
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ООСМСПоСотрудникам, НоваяТаблицаРаспределения);
	
	// ОПВР
	ОПВРПоСотрудникам = НалогиВзносыОтчисленияПоСотрудникам(ТаблицаОПВР, БазаРасчета.БазаРасчетаЕПЗаСчетРаботодателя);
	ОПВРПоСотрудникам.Колонки.Сумма.Имя = "ОПВР";
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ОПВРПоСотрудникам, НоваяТаблицаРаспределения);
	
	НоваяТаблицаРаспределения.ЗаполнитьЗначения(Перечисления.ВидыПлатежейВГосБюджет.Налог, "ВидПлатежа");
	НоваяТаблицаРаспределения.ЗаполнитьЗначения(РеквизитыДляПроведения[ПериодРегистрацииИмя], "МесяцНалоговогоПериода");
	НоваяТаблицаРаспределения.ЗаполнитьЗначения(Организация, "Организация");
	
	НоваяТаблицаРаспределения.Свернуть("Период, Организация, ФизическоеЛицо, Сотрудник, Подразделение, Начисление, ВидПлатежа, МесяцНалоговогоПериода, ДатаНачала", "СО,ООСМС,ОПВР");
	
	КоличествоЗаписей = НоваяТаблицаРаспределения.Количество();
	
	Для Н = 1 По КоличествоЗаписей Цикл

		СтрокаТаблицы = НоваяТаблицаРаспределения[КоличествоЗаписей - Н];
		Если СтрокаТаблицы.СО = 0  
			И СтрокаТаблицы.ОПВР = 0
			И СтрокаТаблицы.ООСМС = 0 Тогда
			НоваяТаблицаРаспределения.Удалить(КоличествоЗаписей - Н);
		КонецЕсли;
				
	КонецЦикла;

	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(НоваяТаблицаРаспределения, Движения.ЕПКомпоненты);
	
	Движения.ЕПКомпоненты.Записывать = Истина;

КонецПроцедуры

Функция РассчитатьЕПДо2024(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	СоздатьВТИсключаемыеЛицаЕП(МенеджерВременныхТаблиц, "ВТИтогИсключаемыеНВОФизическиеЛица", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИтогИсключаемыеНВОФизическиеЛица");
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеЕП");
	
	ВидНалогаВзносаЕП = Перечисления.ВидыНалоговВзносовОтчислений.ЕП;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходыПосле2023(МенеджерВременныхТаблиц, ВидНалогаВзносаЕП, "ВТИсключаемыеФизическиеЛицаПриРасчетеЕП");
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ЕП
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаЕП);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	СоздатьВТРанееИсчисленныеКомпонентыЕП(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты, Истина);
	
	// Статусы доли единого платежа
	СоздатьВТДолиЕППоПериодам(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТДолиЕП");
	
	// - Исчисленные ЕП
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	0 КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 10 КАК МаксимальныйРазмерОрганиченияДоходаОСМС,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 7 КАК МаксимальныйРазмерОрганиченияДоходаСО,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 50 КАК МаксимальныйРазмерОрганиченияДоходаОПВ
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДоходаОСМС КАК МаксимальныйРазмерОрганиченияДоходаОСМС,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДоходаСО КАК МаксимальныйРазмерОрганиченияДоходаСО,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДоходаОПВ КАК МаксимальныйРазмерОрганиченияДоходаОПВ,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		ИНАЧЕ Доходы.ОблагаемыйДоход 
		|	КОНЕЦ КАК ОбъектИсчисленияЕП,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		ИНАЧЕ Доходы.ОблагаемыйДоход 
        |	КОНЕЦ * ЕСТЬNULL(СтавкаЕП.Ставка, 0) КАК ИсчисленныйЕП,
