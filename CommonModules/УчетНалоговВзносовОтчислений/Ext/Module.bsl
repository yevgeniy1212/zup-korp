	РезультатыРасчетов.Колонки.Удалить("СтавкаВОСМС");
	РезультатыРасчетов.Колонки.Удалить("СтавкаООСМС");
	РезультатыРасчетов.Колонки.Удалить("СтавкаИПН");
	РезультатыРасчетов.Колонки.Удалить("СтавкаОПВ");
	РезультатыРасчетов.Колонки.Удалить("СтавкаСО");
	РезультатыРасчетов.Колонки.Удалить("СтавкаОПВР");
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	ДанныеОкругления = ПолучитьСпособОкругленияСПериодом(МенеджерВременныхТаблиц, ВидНалогаВзносаЕП);
	СпособОкругления = ДанныеОкругления.СпособОкругления;
	ПериодОкругления = ДанныеОкругления.Период;
	
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	ТочностьОкругления = ОписаниеСпособаОкругления.Точность;
	ПравилоОкругления = ОписаниеСпособаОкругления.ПравилоОкругления;		

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругленияДляРаспределения = ТочностьОкругления - Цел(ТочностьОкругления);
	
	Если ТочностьОкругленияДляРаспределения = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругленияДляРаспределения <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		
		КорректировкаООСМС = 0;
		КорректировкаВОСМС = 0;
		КорректировкаОПВ   = 0;
		КорректировкаОПВР  = 0;
		КорректировкаСО    = 0;
		
		// сумма ЕП по полной ставке
		// если порядок округления не установлен, то используем округление до двух знаков
		Если ПериодОкругления = Дата('00010101') Тогда
			// округление до двух знаков необходимо, чтобы распределение совпало с Госкорпорацией, тк суммы будут передаваться с двумя знаками после запятой
			СтрокаРасчета.ИсчисленныйЕП = Окр(СтрокаРасчета.ИсчисленныйЕП, 2);
		Иначе
			СтрокаРасчета.ИсчисленныйЕП = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаРасчета.ИсчисленныйЕП, ТочностьОкругления, ПравилоОкругления);
		КонецЕсли;
	
		СуммаПолногоЕП = СтрокаРасчета.ИсчисленныйЕП;
		
		МаксимальныйРазмерОрганиченияДоходаООСМС = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОСМС;
		МаксимальныйРазмерОрганиченияДоходаВОСМС = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОСМС;
		МаксимальныйРазмерОрганиченияДоходаОПВ 	= СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОПВ;
		МаксимальныйРазмерОрганиченияДоходаОПВР = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОПВ;
		МаксимальныйРазмерОрганиченияДоходаСО 	= СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаСО;
		
		Если НЕ СтрокаРасчета.СтавкаСО = 0 Тогда
			КорректировкаСтавкиСО = 0.032 / СтрокаРасчета.СтавкаСО;	
			МаксимальныйРазмерОрганиченияДоходаСО = МаксимальныйРазмерОрганиченияДоходаСО * КорректировкаСтавкиСО;	
		КонецЕсли;
        // корректировки максимальной суммы выполняются в соответствии с расчетом Госкорпорации
		// законодательно для всех НВО, кроме СО контроль максимального предела должен происходить по объекту, а не сумме платежа
		// при этом при умножении ставки НВО в составе единого платежа максимальные суммы НВО не равны фактическим от обычной ставки НВО
        // при приведении расчетов Госкорпорации к законодательству влияние данных переменных в расчете необходимо устранить
		Если НЕ СтрокаРасчета.СтавкаОПВ = 0 Тогда
			КорректировкаСтавкиОПВ = 0.1 / СтрокаРасчета.СтавкаОПВ;	
			МаксимальныйРазмерОрганиченияДоходаОПВ = МаксимальныйРазмерОрганиченияДоходаОПВ * КорректировкаСтавкиОПВ;	
		КонецЕсли;
		Если НЕ СтрокаРасчета.СтавкаОПВР = 0 Тогда
			КорректировкаСтавкиОПВР = 0.015 / СтрокаРасчета.СтавкаОПВР;	
			МаксимальныйРазмерОрганиченияДоходаОПВР = МаксимальныйРазмерОрганиченияДоходаОПВР * КорректировкаСтавкиОПВР;	
		КонецЕсли;
		Если НЕ СтрокаРасчета.СтавкаВОСМС = 0 Тогда
			КорректировкаСтавкиВОСМС = 0.02 / СтрокаРасчета.СтавкаВОСМС;	
			МаксимальныйРазмерОрганиченияДоходаВОСМС = МаксимальныйРазмерОрганиченияДоходаВОСМС * КорректировкаСтавкиВОСМС;	
		КонецЕсли;
		Если НЕ СтрокаРасчета.СтавкаООСМС = 0 Тогда
			КорректировкаСтавкиООСМС = 0.03 / СтрокаРасчета.СтавкаООСМС;	
			МаксимальныйРазмерОрганиченияДоходаООСМС = МаксимальныйРазмерОрганиченияДоходаООСМС * КорректировкаСтавкиООСМС;	
		КонецЕсли;

		// скорректируем сумму ЕП на разницу между максимальным пределом и фактически начисленной долей НВО
		Если СтрокаРасчета.СтавкаВОСМС = 0 Тогда 
			
			// уменьшим на долю ООСМС без тысячных (тысячные всегда уходят на ИПН, даже если вид НВО входит в льготу)
			КорректировкаВОСМС = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляВОСМС * 100) / 100;
			
		ИначеЕсли СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаВОСМС Тогда
			
			// найдем суммы ОСМС
			КорректировкаВОСМС = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляВОСМС * 100) / 100;
			
			ТысячныеВОСМС = (КорректировкаВОСМС - Цел(КорректировкаВОСМС * 100) / 100);
			
			// найдем пределы
			МаксимальнаяСуммаВОСМС = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОСМС * 0.02;
			
			// уменьшим платеж на разницу, уберем согласно методике тысячные
			КорректировкаВОСМС = КорректировкаВОСМС - МаксимальнаяСуммаВОСМС - ТысячныеВОСМС;
			
		КонецЕсли;
		
		// скорректируем сумму ЕП на разницу между максимальным пределом и фактически начисленной долей НВО
		Если СтрокаРасчета.СтавкаООСМС = 0 Тогда 
			
			// уменьшим на долю ООСМС без тысячных (тысячные всегда уходят на ИПН, даже если вид НВО входит в льготу)
			КорректировкаООСМС = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляООСМС * 100) / 100;
			
		ИначеЕсли СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаООСМС Тогда
			
			// найдем суммы ОСМС
			КорректировкаООСМС = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляООСМС * 100) / 100;
			
			ТысячныеООСМС = (КорректировкаООСМС - Цел(КорректировкаООСМС * 100) / 100);
			
			// найдем пределы
			МаксимальнаяСуммаООСМС = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОСМС * 0.03;
			
			// уменьшим платеж на разницу, уберем согласно методике тысячные
			КорректировкаООСМС = КорректировкаООСМС - МаксимальнаяСуммаООСМС - ТысячныеООСМС;
			
		КонецЕсли;
		
		Если СтрокаРасчета.СтавкаОПВ = 0 Тогда
			
			// уменьшим на долю ОПВ без тысячных (тысячные всегда уходят на ИПН, даже если вид НВО входит в льготу)
			КорректировкаОПВ = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВ * 100) / 100;

		ИначеЕсли СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаОПВ Тогда
			
			// найдем суммы ОПВ
			КорректировкаОПВ = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВ * 100) / 100;
			
			ТысячныеОПВ = (КорректировкаОПВ - Цел(КорректировкаОПВ * 100) / 100);
			
			// найдем пределы
			МаксимальнаяСуммаОПВ = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОПВ * 0.1;
			
			// уменьшим платеж на разницу, уберем согласно методике тысячные
			КорректировкаОПВ = КорректировкаОПВ - МаксимальнаяСуммаОПВ - ТысячныеОПВ;
			
		КонецЕсли;
		
		Если СтрокаРасчета.СтавкаОПВР = 0 Тогда 
			
			КорректировкаОПВР = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВР * 100) / 100;
			
		ИначеЕсли СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаОПВР Тогда
			
			// найдем суммы ОПВР
			КорректировкаОПВР = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВР * 100) / 100;
			
			ТысячныеОПВР = (КорректировкаОПВР - Цел(КорректировкаОПВР * 100) / 100);
			
			// найдем пределы
			МаксимальнаяСуммаОПВР = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОПВ * 0.015;
			
			// уменьшим платеж на разницу, уберем согласно методике тысячные
			КорректировкаОПВР = КорректировкаОПВР - МаксимальнаяСуммаОПВР - ТысячныеОПВР;
			
		КонецЕсли;

		Если СтрокаРасчета.СтавкаСО = 0 Тогда 
			
			// уменьшим на долю СО без тысячных (тысячные всегда уходят на ИПН, даже если вид НВО входит в льготу)
			КорректировкаСО = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляСО * 100) / 100;
			
		ИначеЕсли СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаСО Тогда
			
			// найдем суммы СО
			КорректировкаСО = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляСО * 100) / 100;
			
			ТысячныеСО = (КорректировкаСО - Цел(КорректировкаСО * 100) / 100);
			
			// найдем пределы
			МаксимальнаяСуммаСО = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаСО * 0.032;
			
			// уменьшим платеж на разницу, уберем согласно методике тысячные
			КорректировкаСО = КорректировкаСО - МаксимальнаяСуммаСО - ТысячныеСО;
			
		КонецЕсли;
		
		Если НЕ ОкончательныйРасчетЗарплаты Тогда
			// в межрасчете всегда убираем долю за счет работодателя
			КорректировкаООСМС = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляООСМС * 100) / 100;
			КорректировкаСО    = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляСО * 100) / 100;
			КорректировкаОПВР  = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВР * 100) / 100;
		КонецЕсли;
		
		// округлим до двух знаков, в противном случае получится погрешность при округлении (объект 159090.9 при отсутствии сумм ВОСМС и ООСМС вернет 23863.635, без округления результат будет не корректен)
		СтрокаРасчета.ИсчисленныйЕП = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаРасчета.ИсчисленныйЕП - КорректировкаООСМС - КорректировкаВОСМС - КорректировкаОПВ - КорректировкаОПВР - КорректировкаСО, 0.01);
		
		// распределяем округленный до двух знаков ЕП, в случае распределения более двух знаков после запятой разойдемся с распределением Госкорпорации
		СтрокаРасчета.ИсчисленныйЕП = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаРасчета.ИсчисленныйЕП, 0.01);
		
		Если НЕ СтрокаРасчета.СтавкаОПВ = 0 Тогда
			
			Если СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаОПВ Тогда
				СтрокаРасчета.ОПВ = МаксимальнаяСуммаОПВ;
			Иначе
				СтрокаРасчета.ОПВ = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляОПВ * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.ОПВ = 0;
		КонецЕсли;
		
		Если НЕ СтрокаРасчета.СтавкаВОСМС = 0 Тогда
			
			Если СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаВОСМС Тогда
				СтрокаРасчета.ВОСМС = МаксимальнаяСуммаВОСМС;
			Иначе
				СтрокаРасчета.ВОСМС = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляВОСМС * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.ВОСМС = 0;
		КонецЕсли;
		
		Если НЕ СтрокаРасчета.СтавкаООСМС = 0 Тогда
			
			Если СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаООСМС Тогда
				СтрокаРасчета.ООСМС = МаксимальнаяСуммаООСМС;
			Иначе
				СтрокаРасчета.ООСМС = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляООСМС * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.ООСМС = 0;
		КонецЕсли;
		
		Если НЕ СтрокаРасчета.СтавкаСО = 0 Тогда
			
			Если СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаСО Тогда
				СтрокаРасчета.СО = МаксимальнаяСуммаСО;
			Иначе
				СтрокаРасчета.СО = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляСО * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.СО = 0;
		КонецЕсли;
		
		Если НЕ СтрокаРасчета.СтавкаОПВР = 0 Тогда
			
			Если СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаОПВР Тогда
				СтрокаРасчета.ОПВР = МаксимальнаяСуммаОПВР;
			Иначе
				СтрокаРасчета.ОПВР = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляОПВР * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.ОПВР = 0;
		КонецЕсли;
		
		// суммы корректировок компонент ЕП
		СуммаКорректировок = КорректировкаОПВ + КорректировкаВОСМС + КорректировкаООСМС + КорректировкаСО + КорректировкаОПВР;
	
		// на ИПН относим оставшуюся сумму
		СтрокаРасчета.ИПН = СуммаПолногоЕП - СтрокаРасчета.ВОСМС - СтрокаРасчета.ООСМС - СтрокаРасчета.ОПВ - СтрокаРасчета.СО - СтрокаРасчета.ОПВР - СуммаКорректировок;
		
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияЕП,ИсчисленныйЕП,ООСМС,ВОСМС,ИПН,ОПВ,ОПВР,СО", ТочностьРаспределения);
		
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныйЕППоПодразделениям, РезультатыРасчетов);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеКомпонентыЕППоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияЕПВЦеломЗаПериод,	ИсчисленныйЕПВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектЕПИсчисленныйРанее, 		 	РанееИсчисленныйЕП,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияЕП, 				ИсчисленныйЕП,
								|ООСМС,								ВОСМС,								ОПВ,								ОПВР,	
								|СО,								ИПН");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0
			И (СтрокаТЗ.ИсчисленныйЕП < 1 И СтрокаТЗ.ИсчисленныйЕП > 0
				ИЛИ СтрокаТЗ.ИсчисленныйЕП > -1 И СтрокаТЗ.ИсчисленныйЕП < 0) Тогда
				
			СтрокаТЗ.ИсчисленныйЕП = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			// не округляем, тк возникнут погрешности между суммой ЕП и суммой компонент ЕП
			СтрокаТЗ.ИсчисленныйЕП = СтрокаТЗ.ИсчисленныйЕП;
			
		КонецЕсли;
		
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат ДанныеОРезультатахРасчетаЕПДляДокумента(РезультатыРасчетов, ОкончательныйРасчетЗарплаты);
	
КонецФункции

Функция РассчитатьЕППосле2025(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	СоздатьВТИсключаемыеЛицаЕП(МенеджерВременныхТаблиц, "ВТИтогИсключаемыеНВОФизическиеЛица", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИтогИсключаемыеНВОФизическиеЛица");
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеЕП");
	
	ВидНалогаВзносаЕП = Перечисления.ВидыНалоговВзносовОтчислений.ЕП;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходыПосле2023(МенеджерВременныхТаблиц, ВидНалогаВзносаЕП, "ВТИсключаемыеФизическиеЛицаПриРасчетеЕП");
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ЕП
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаЕП);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	СоздатьВТРанееИсчисленныеКомпонентыЕП(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты, Истина);
	
	// Статусы доли единого платежа
	СоздатьВТДолиЕППоПериодам(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТДолиЕП");
	
	// - Исчисленные ЕП
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	0 КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 10 КАК МаксимальныйРазмерОрганиченияДоходаОСМС,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 7 КАК МаксимальныйРазмерОрганиченияДоходаСО,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 50 КАК МаксимальныйРазмерОрганиченияДоходаОПВ
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДоходаОСМС КАК МаксимальныйРазмерОрганиченияДоходаОСМС,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДоходаСО КАК МаксимальныйРазмерОрганиченияДоходаСО,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДоходаОПВ КАК МаксимальныйРазмерОрганиченияДоходаОПВ,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		ИНАЧЕ Доходы.ОблагаемыйДоход 
		|	КОНЕЦ КАК ОбъектИсчисленияЕП,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		ИНАЧЕ Доходы.ОблагаемыйДоход 
        |	КОНЕЦ * ЕСТЬNULL(СтавкаЕП.Ставка, 0) КАК ИсчисленныйЕП,
		|   ЕСТЬNULL(СтавкаЕП.Ставка, 0) * ЕСТЬNULL(ДолиЕП.ДоляОПВ, 0) КАК СтавкаОПВ,
		|   ЕСТЬNULL(СтавкаЕП.Ставка, 0) * ЕСТЬNULL(ДолиЕП.ДоляВОСМС, 0) КАК СтавкаВОСМС,
		|   ЕСТЬNULL(СтавкаЕП.Ставка, 0) * ЕСТЬNULL(ДолиЕП.ДоляИПН, 0) КАК СтавкаИПН,
		|   ЕСТЬNULL(СтавкаЕП.Ставка, 0) * ЕСТЬNULL(ДолиЕП.ДоляСО, 0) КАК СтавкаСО,
		|   ЕСТЬNULL(СтавкаЕП.Ставка, 0) * ЕСТЬNULL(ДолиЕП.ДоляООСМС, 0) КАК СтавкаООСМС,
		|   ЕСТЬNULL(СтавкаЕП.Ставка, 0) * ЕСТЬNULL(ДолиЕП.ДоляОПВР, 0) КАК СтавкаОПВР,
		|   ЕСТЬNULL(ДолиЕП.ДоляОПВ, 0) КАК ДоляОПВ,
		|   ЕСТЬNULL(ДолиЕП.ДоляВОСМС, 0) КАК ДоляВОСМС,
		|   ЕСТЬNULL(ДолиЕП.ДоляИПН, 0) КАК ДоляИПН,
		|   ЕСТЬNULL(ДолиЕП.ДоляСО, 0) КАК ДоляСО,
		|   ЕСТЬNULL(ДолиЕП.ДоляООСМС, 0) КАК ДоляООСМС,
		|   ЕСТЬNULL(ДолиЕП.ДоляОПВР, 0) КАК ДоляОПВР,
		|	ЕСТЬNULL(СтавкаЕП.Ставка, 0) КАК СтавкаЕП
		|ПОМЕСТИТЬ ВТИсчисленныйЕП
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкаЕП
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкаЕП.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкаЕП.ВидДохода
		|			И СтавкаЕП.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ЕП)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкаСО
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкаСО.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкаСО.ВидДохода
		|			И СтавкаСО.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.СО)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкаОПВ
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкаОПВ.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкаОПВ.ВидДохода
		|			И СтавкаОПВ.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ОПВ)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМС КАК СтавкиООСМС
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиООСМС.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиООСМС.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДолиЕП КАК ДолиЕП
		|		ПО Доходы.МесяцНалоговогоПериода = ДолиЕП.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|ГДЕ
		|	Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныйЕП.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныйЕП.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныйЕП.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныйЕП.ОбъектИсчисленияЕП КАК ОбъектИсчисленияЕП,
		|	ВТИсчисленныйЕП.ИсчисленныйЕП КАК ИсчисленныйЕП,
		|	ВТИсчисленныйЕП.СтавкаЕП КАК СтавкаЕП,
		|	ВТИсчисленныйЕП.СтавкаИПН КАК СтавкаИПН,
		|	ВТИсчисленныйЕП.СтавкаОПВ 	* ЕСТЬNULL(ИтогИсключаемыеНВОФизическиеЛица.ИсключатьОПВ, 1) КАК СтавкаОПВ,
		|	ВТИсчисленныйЕП.СтавкаВОСМС * ЕСТЬNULL(ИтогИсключаемыеНВОФизическиеЛица.ИсключатьОСМС, 1) КАК СтавкаВОСМС,
		|	ВТИсчисленныйЕП.СтавкаСО 	* ЕСТЬNULL(ИтогИсключаемыеНВОФизическиеЛица.ИсключатьСО, 1) КАК СтавкаСО,
		|	ВТИсчисленныйЕП.СтавкаООСМС * ЕСТЬNULL(ИтогИсключаемыеНВОФизическиеЛица.ИсключатьОСМС, 1) КАК СтавкаООСМС,
		|	ВТИсчисленныйЕП.СтавкаОПВР 	* ЕСТЬNULL(ИтогИсключаемыеНВОФизическиеЛица.ИсключатьОПВР, 1) КАК СтавкаОПВР,
		|   ВТИсчисленныйЕП.ДоляОПВ КАК ДоляОПВ,
		|   ВТИсчисленныйЕП.ДоляВОСМС КАК ДоляВОСМС,
		|   ВТИсчисленныйЕП.ДоляИПН КАК ДоляИПН,
		|   ВТИсчисленныйЕП.ДоляСО КАК ДоляСО,
		|   ВТИсчисленныйЕП.ДоляООСМС КАК ДоляООСМС,
		|   ВТИсчисленныйЕП.ДоляОПВР КАК ДоляОПВР,
		|	ВТИсчисленныйЕП.МаксимальныйРазмерОрганиченияДоходаОСМС КАК МаксимальныйРазмерОрганиченияДоходаОСМС,
		|	ВТИсчисленныйЕП.МаксимальныйРазмерОрганиченияДоходаСО КАК МаксимальныйРазмерОрганиченияДоходаСО,
		|	ВТИсчисленныйЕП.МаксимальныйРазмерОрганиченияДоходаОПВ КАК МаксимальныйРазмерОрганиченияДоходаОПВ
		|ИЗ
		|	ВТИсчисленныйЕП КАК ВТИсчисленныйЕП
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИтогИсключаемыеНВОФизическиеЛица КАК ИтогИсключаемыеНВОФизическиеЛица
		|		ПО ВТИсчисленныйЕП.МесяцНалоговогоПериода = ИтогИсключаемыеНВОФизическиеЛица.МесяцНалоговогоПериода
		|			И ВТИсчисленныйЕП.ФизическоеЛицо = ИтогИсключаемыеНВОФизическиеЛица.ФизическоеЛицо
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	СУММА(ДоходыПоПодразделениям.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	СУММА(ДоходыПоПодразделениям.НеоблагаемыйДоход) КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
        |
		|СГРУППИРОВАТЬ ПО
		|	ДоходыПоПодразделениям.Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныйЕППоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныйЕППоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныйЕППоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныйЕППоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныйЕППоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйЕППоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйЕППоПодразделениям.ОбъектИсчисления КАК ОбъектЕПИсчисленныйРанее,
		|	ИсчисленныйЕППоПодразделениям.НалогВзнос КАК РанееИсчисленныйЕП,
		|	-ИсчисленныйЕППоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныйЕППоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныйЕППоПодразделениям.НалогВзнос КАК ИсчисленныйЕП,
		|	-ИсчисленныйЕППоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияЕП
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныйЕППоПодразделениям
		|ГДЕ
		|	(ИсчисленныйЕППоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйЕППоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйЕППоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныйЕППоПодразделениям.НалогВзнос <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеКомпонентыЕППоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеКомпонентыЕППоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеКомпонентыЕППоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя) КАК ВидДохода,
		|	0 КАК ОблагаемыйДоходВЦеломЗаПериод, 	
		|	0 КАК НеоблагаемыйДоходВЦеломЗаПериод, 	
		|	0 КАК ОбъектИсчисленияЕПВЦеломЗаПериод,	
		|	0 КАК ИсчисленныйЕПВЦеломЗаПериод,
		|	0 КАК ОблагаемыйДоходИсчисленныйРанее,
		|	0 КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	0 КАК ОбъектЕПИсчисленныйРанее,
		|	0 КАК РанееИсчисленныйЕП,
		|	0 КАК ОблагаемыйДоход, 
		|	0 КАК НеоблагаемыйДоход,
		|	0 КАК ОбъектИсчисленияЕП,
		|	0 КАК ИсчисленныйЕП,
		|	-ИсчисленныеКомпонентыЕППоПодразделениям.ОПВ КАК ОПВ,
		|	-ИсчисленныеКомпонентыЕППоПодразделениям.ВОСМС КАК ВОСМС,
		|	-ИсчисленныеКомпонентыЕППоПодразделениям.ИПН КАК ИПН,
		|	-ИсчисленныеКомпонентыЕППоПодразделениям.СО КАК СО,
		|	-ИсчисленныеКомпонентыЕППоПодразделениям.ООСМС КАК ООСМС,
		|	-ИсчисленныеКомпонентыЕППоПодразделениям.ОПВР КАК ОПВР
		|ИЗ
		|	ВТРанееИсчисленныеКомпонентыЕП КАК ИсчисленныеКомпонентыЕППоПодразделениям
		|";
			
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТИсчисленныйЕП");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеКомпонентыЕППоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	ИсчисленныйЕППоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 3].Выгрузить();
	РезультатЗапроса = Результат[ВсегоРезультатов - 4].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса.Колонки.Добавить("ОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИПН", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("СО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ООСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ОПВР", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныйЕПВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияЕПВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	РезультатыРасчетов.Колонки.Добавить("ОПВВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ВОСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИПНВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("СОВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ООСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОПВРВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектЕПИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныйЕП", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	РезультатыРасчетов.Колонки.Удалить("ДоляВОСМС");
	РезультатыРасчетов.Колонки.Удалить("ДоляООСМС");
	РезультатыРасчетов.Колонки.Удалить("ДоляОПВ");
	РезультатыРасчетов.Колонки.Удалить("ДоляСО");
	РезультатыРасчетов.Колонки.Удалить("ДоляОПВР");
	РезультатыРасчетов.Колонки.Удалить("СтавкаВОСМС");
	РезультатыРасчетов.Колонки.Удалить("СтавкаООСМС");
	РезультатыРасчетов.Колонки.Удалить("СтавкаИПН");
	РезультатыРасчетов.Колонки.Удалить("СтавкаОПВ");
	РезультатыРасчетов.Колонки.Удалить("СтавкаСО");
	РезультатыРасчетов.Колонки.Удалить("СтавкаОПВР");
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	ДанныеОкругления = ПолучитьСпособОкругленияСПериодом(МенеджерВременныхТаблиц, ВидНалогаВзносаЕП);
	СпособОкругления = ДанныеОкругления.СпособОкругления;
	ПериодОкругления = ДанныеОкругления.Период;
	
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	ТочностьОкругления = ОписаниеСпособаОкругления.Точность;
	ПравилоОкругления = ОписаниеСпособаОкругления.ПравилоОкругления;		

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругленияДляРаспределения = ТочностьОкругления - Цел(ТочностьОкругления);
	
	Если ТочностьОкругленияДляРаспределения = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругленияДляРаспределения <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		
		КорректировкаООСМС = 0;
		КорректировкаВОСМС = 0;
		КорректировкаОПВ   = 0;
		КорректировкаОПВР  = 0;
		КорректировкаСО    = 0;
		
		// сумма ЕП по полной ставке
		// если порядок округления не установлен, то используем округление до двух знаков
		Если ПериодОкругления = Дата('00010101') Тогда
			// округление до двух знаков необходимо, чтобы распределение совпало с Госкорпорацией, тк суммы будут передаваться с двумя знаками после запятой
			СтрокаРасчета.ИсчисленныйЕП = Окр(СтрокаРасчета.ИсчисленныйЕП, 2);
		Иначе
			СтрокаРасчета.ИсчисленныйЕП = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаРасчета.ИсчисленныйЕП, ТочностьОкругления, ПравилоОкругления);
		КонецЕсли;
	
		СуммаПолногоЕП = СтрокаРасчета.ИсчисленныйЕП;
		
		МаксимальныйРазмерОрганиченияДоходаООСМС = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОСМС;
		МаксимальныйРазмерОрганиченияДоходаВОСМС = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОСМС;
		МаксимальныйРазмерОрганиченияДоходаОПВ 	= СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОПВ;
		МаксимальныйРазмерОрганиченияДоходаОПВР = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОПВ;
		МаксимальныйРазмерОрганиченияДоходаСО 	= СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаСО;
		
		// ставка социальных отчислений устанавливается в размере 4.5% от объекта исчисления для 2025 года
		Если НЕ СтрокаРасчета.СтавкаСО = 0 Тогда
			КорректировкаСтавкиСО = 0.045 / СтрокаРасчета.СтавкаСО;	
			МаксимальныйРазмерОрганиченияДоходаСО = МаксимальныйРазмерОрганиченияДоходаСО * КорректировкаСтавкиСО;	
		КонецЕсли;
        // корректировки максимальной суммы выполняются в соответствии с расчетом Госкорпорации
		// законодательно для всех НВО, кроме СО контроль максимального предела должен происходить по объекту, а не сумме платежа
		// при этом при умножении ставки НВО в составе единого платежа максимальные суммы НВО не равны фактическим от обычной ставки НВО
        // при приведении расчетов Госкорпорации к законодательству влияние данных переменных в расчете необходимо устранить
		Если НЕ СтрокаРасчета.СтавкаОПВ = 0 Тогда
			КорректировкаСтавкиОПВ = 0.1 / СтрокаРасчета.СтавкаОПВ;	
			МаксимальныйРазмерОрганиченияДоходаОПВ = МаксимальныйРазмерОрганиченияДоходаОПВ * КорректировкаСтавкиОПВ;	
		КонецЕсли;
		Если НЕ СтрокаРасчета.СтавкаОПВР = 0 Тогда
			КорректировкаСтавкиОПВР = 0.025 / СтрокаРасчета.СтавкаОПВР;	
			МаксимальныйРазмерОрганиченияДоходаОПВР = МаксимальныйРазмерОрганиченияДоходаОПВР * КорректировкаСтавкиОПВР;	
		КонецЕсли;
		Если НЕ СтрокаРасчета.СтавкаВОСМС = 0 Тогда
			КорректировкаСтавкиВОСМС = 0.02 / СтрокаРасчета.СтавкаВОСМС;	
			МаксимальныйРазмерОрганиченияДоходаВОСМС = МаксимальныйРазмерОрганиченияДоходаВОСМС * КорректировкаСтавкиВОСМС;	
		КонецЕсли;
		Если НЕ СтрокаРасчета.СтавкаООСМС = 0 Тогда
			КорректировкаСтавкиООСМС = 0.03 / СтрокаРасчета.СтавкаООСМС;	
			МаксимальныйРазмерОрганиченияДоходаООСМС = МаксимальныйРазмерОрганиченияДоходаООСМС * КорректировкаСтавкиООСМС;	
		КонецЕсли;

		// скорректируем сумму ЕП на разницу между максимальным пределом и фактически начисленной долей НВО
		Если СтрокаРасчета.СтавкаВОСМС = 0 Тогда 
			
			// уменьшим на долю ООСМС без тысячных (тысячные всегда уходят на ИПН, даже если вид НВО входит в льготу)
			КорректировкаВОСМС = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляВОСМС * 100) / 100;
			
		ИначеЕсли СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаВОСМС Тогда
			
			// найдем суммы ОСМС
			КорректировкаВОСМС = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляВОСМС * 100) / 100;
			
			ТысячныеВОСМС = (КорректировкаВОСМС - Цел(КорректировкаВОСМС * 100) / 100);
			
			// найдем пределы
			МаксимальнаяСуммаВОСМС = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОСМС * 0.02;
			
			// уменьшим платеж на разницу, уберем согласно методике тысячные
			КорректировкаВОСМС = КорректировкаВОСМС - МаксимальнаяСуммаВОСМС - ТысячныеВОСМС;
			
		КонецЕсли;
		
		// скорректируем сумму ЕП на разницу между максимальным пределом и фактически начисленной долей НВО
		Если СтрокаРасчета.СтавкаООСМС = 0 Тогда 
			
			// уменьшим на долю ООСМС без тысячных (тысячные всегда уходят на ИПН, даже если вид НВО входит в льготу)
			КорректировкаООСМС = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляООСМС * 100) / 100;
			
		ИначеЕсли СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаООСМС Тогда
			
			// найдем суммы ОСМС
			КорректировкаООСМС = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляООСМС * 100) / 100;
			
			ТысячныеООСМС = (КорректировкаООСМС - Цел(КорректировкаООСМС * 100) / 100);
			
			// найдем пределы
			МаксимальнаяСуммаООСМС = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОСМС * 0.03;
			
			// уменьшим платеж на разницу, уберем согласно методике тысячные
			КорректировкаООСМС = КорректировкаООСМС - МаксимальнаяСуммаООСМС - ТысячныеООСМС;
			
		КонецЕсли;
		
		Если СтрокаРасчета.СтавкаОПВ = 0 Тогда
			
			// уменьшим на долю ОПВ без тысячных (тысячные всегда уходят на ИПН, даже если вид НВО входит в льготу)
			КорректировкаОПВ = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВ * 100) / 100;

		ИначеЕсли СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаОПВ Тогда
			
			// найдем суммы ОПВ
			КорректировкаОПВ = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВ * 100) / 100;
			
			ТысячныеОПВ = (КорректировкаОПВ - Цел(КорректировкаОПВ * 100) / 100);
			
			// найдем пределы
			МаксимальнаяСуммаОПВ = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОПВ * 0.1;
			
			// уменьшим платеж на разницу, уберем согласно методике тысячные
			КорректировкаОПВ = КорректировкаОПВ - МаксимальнаяСуммаОПВ - ТысячныеОПВ;
			
		КонецЕсли;
		
		Если СтрокаРасчета.СтавкаОПВР = 0 Тогда 
			
			КорректировкаОПВР = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВР * 100) / 100;
			
		ИначеЕсли СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаОПВР Тогда
			
			// найдем суммы ОПВР
			КорректировкаОПВР = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВР * 100) / 100;
			
			ТысячныеОПВР = (КорректировкаОПВР - Цел(КорректировкаОПВР * 100) / 100);
			
			// найдем пределы
			МаксимальнаяСуммаОПВР = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОПВ * 0.025;
			
			// уменьшим платеж на разницу, уберем согласно методике тысячные
			КорректировкаОПВР = КорректировкаОПВР - МаксимальнаяСуммаОПВР - ТысячныеОПВР;
			
		КонецЕсли;

		Если СтрокаРасчета.СтавкаСО = 0 Тогда 
			
			// уменьшим на долю СО без тысячных (тысячные всегда уходят на ИПН, даже если вид НВО входит в льготу)
			КорректировкаСО = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляСО * 100) / 100;
			
		ИначеЕсли СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаСО Тогда
			
			// найдем суммы СО
			КорректировкаСО = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляСО * 100) / 100;
			
			ТысячныеСО = (КорректировкаСО - Цел(КорректировкаСО * 100) / 100);
			
			// найдем пределы
			МаксимальнаяСуммаСО = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаСО * 0.045;
			
			// уменьшим платеж на разницу, уберем согласно методике тысячные
			КорректировкаСО = КорректировкаСО - МаксимальнаяСуммаСО - ТысячныеСО;
			
		КонецЕсли;
		
		Если НЕ ОкончательныйРасчетЗарплаты Тогда
			// в межрасчете всегда убираем долю за счет работодателя
			КорректировкаООСМС = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляООСМС * 100) / 100;
			КорректировкаСО    = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляСО * 100) / 100;
			КорректировкаОПВР  = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВР * 100) / 100;
		КонецЕсли;
		
		// округлим до двух знаков, в противном случае получится погрешность при округлении (объект 159090.9 при отсутствии сумм ВОСМС и ООСМС вернет 23863.635, без округления результат будет не корректен)
		СтрокаРасчета.ИсчисленныйЕП = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаРасчета.ИсчисленныйЕП - КорректировкаООСМС - КорректировкаВОСМС - КорректировкаОПВ - КорректировкаОПВР - КорректировкаСО, 0.01);
		
		// распределяем округленный до двух знаков ЕП, в случае распределения более двух знаков после запятой разойдемся с распределением Госкорпорации
		СтрокаРасчета.ИсчисленныйЕП = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаРасчета.ИсчисленныйЕП, 0.01);
		
		Если НЕ СтрокаРасчета.СтавкаОПВ = 0 Тогда
			
			Если СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаОПВ Тогда
				СтрокаРасчета.ОПВ = МаксимальнаяСуммаОПВ;
			Иначе
				СтрокаРасчета.ОПВ = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляОПВ * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.ОПВ = 0;
		КонецЕсли;
		
		Если НЕ СтрокаРасчета.СтавкаВОСМС = 0 Тогда
			
			Если СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаВОСМС Тогда
				СтрокаРасчета.ВОСМС = МаксимальнаяСуммаВОСМС;
			Иначе
				СтрокаРасчета.ВОСМС = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляВОСМС * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.ВОСМС = 0;
		КонецЕсли;
		
		Если НЕ СтрокаРасчета.СтавкаООСМС = 0 Тогда
			
			Если СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаООСМС Тогда
				СтрокаРасчета.ООСМС = МаксимальнаяСуммаООСМС;
			Иначе
				СтрокаРасчета.ООСМС = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляООСМС * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.ООСМС = 0;
		КонецЕсли;
		
		Если НЕ СтрокаРасчета.СтавкаСО = 0 Тогда
			
			Если СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаСО Тогда
				СтрокаРасчета.СО = МаксимальнаяСуммаСО;
			Иначе
				СтрокаРасчета.СО = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляСО * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.СО = 0;
		КонецЕсли;
		
		Если НЕ СтрокаРасчета.СтавкаОПВР = 0 Тогда
			
			Если СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаОПВР Тогда
				СтрокаРасчета.ОПВР = МаксимальнаяСуммаОПВР;
			Иначе
				СтрокаРасчета.ОПВР = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляОПВР * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.ОПВР = 0;
		КонецЕсли;
		
		// суммы корректировок компонент ЕП
		СуммаКорректировок = КорректировкаОПВ + КорректировкаВОСМС + КорректировкаООСМС + КорректировкаСО + КорректировкаОПВР;
	
		// на ИПН относим оставшуюся сумму
		СтрокаРасчета.ИПН = СуммаПолногоЕП - СтрокаРасчета.ВОСМС - СтрокаРасчета.ООСМС - СтрокаРасчета.ОПВ - СтрокаРасчета.СО - СтрокаРасчета.ОПВР - СуммаКорректировок;
		
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияЕП,ИсчисленныйЕП,ООСМС,ВОСМС,ИПН,ОПВ,ОПВР,СО", ТочностьРаспределения);
		
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныйЕППоПодразделениям, РезультатыРасчетов);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеКомпонентыЕППоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияЕПВЦеломЗаПериод,	ИсчисленныйЕПВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектЕПИсчисленныйРанее, 		 	РанееИсчисленныйЕП,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияЕП, 				ИсчисленныйЕП,
								|ООСМС,								ВОСМС,								ОПВ,								ОПВР,	
								|СО,								ИПН");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0
			И (СтрокаТЗ.ИсчисленныйЕП < 1 И СтрокаТЗ.ИсчисленныйЕП > 0
				ИЛИ СтрокаТЗ.ИсчисленныйЕП > -1 И СтрокаТЗ.ИсчисленныйЕП < 0) Тогда
				
			СтрокаТЗ.ИсчисленныйЕП = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			// не округляем, тк возникнут погрешности между суммой ЕП и суммой компонент ЕП
			СтрокаТЗ.ИсчисленныйЕП = СтрокаТЗ.ИсчисленныйЕП;
			
		КонецЕсли;
		
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат ДанныеОРезультатахРасчетаЕПДляДокумента(РезультатыРасчетов, ОкончательныйРасчетЗарплаты);
	
КонецФункции

Функция РассчитатьЕППосле2026(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	СоздатьВТИсключаемыеЛицаЕП(МенеджерВременныхТаблиц, "ВТИтогИсключаемыеНВОФизическиеЛица", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИтогИсключаемыеНВОФизическиеЛица");
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеЕП");
	
	ВидНалогаВзносаЕП = Перечисления.ВидыНалоговВзносовОтчислений.ЕП;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
    ПараметрыПолученияДанных = Новый Структура("Организация, ВидНалогаВзносаОтчисления, МесяцНачисления", Организация, ВидНалогаВзносаЕП, МесяцНачисления);
	СоздатьВТДоходыПосле2026(МенеджерВременныхТаблиц, ПараметрыПолученияДанных, "ВТИсключаемыеФизическиеЛицаПриРасчетеЕП");
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ЕП
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаЕП);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	СоздатьВТРанееИсчисленныеКомпонентыЕП(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты, Истина);
	
	// Статусы доли единого платежа
	СоздатьВТДолиЕППоПериодам(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТДолиЕП");
	
	// - Исчисленные ЕП
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	0 КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 20 КАК МаксимальныйРазмерОрганиченияДоходаВОСМС,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 40 КАК МаксимальныйРазмерОрганиченияДоходаООСМС,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 7 КАК МаксимальныйРазмерОрганиченияДоходаСО,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 50 КАК МаксимальныйРазмерОрганиченияДоходаОПВ
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДоходаВОСМС КАК МаксимальныйРазмерОрганиченияДоходаВОСМС,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДоходаООСМС КАК МаксимальныйРазмерОрганиченияДоходаООСМС,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДоходаСО КАК МаксимальныйРазмерОрганиченияДоходаСО,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДоходаОПВ КАК МаксимальныйРазмерОрганиченияДоходаОПВ,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		ИНАЧЕ Доходы.ОблагаемыйДоход 
		|	КОНЕЦ КАК ОбъектИсчисленияЕП,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход <= 0
		|			ТОГДА 0
		|		ИНАЧЕ Доходы.ОблагаемыйДоход 
        |	КОНЕЦ * ЕСТЬNULL(СтавкаЕП.Ставка, 0) КАК ИсчисленныйЕП,
		|   ЕСТЬNULL(СтавкаЕП.Ставка, 0) * ЕСТЬNULL(ДолиЕП.ДоляОПВ, 0) КАК СтавкаОПВ,
		|   ЕСТЬNULL(СтавкаЕП.Ставка, 0) * ЕСТЬNULL(ДолиЕП.ДоляВОСМС, 0) КАК СтавкаВОСМС,
		|   ЕСТЬNULL(СтавкаЕП.Ставка, 0) * ЕСТЬNULL(ДолиЕП.ДоляИПН, 0) КАК СтавкаИПН,
		|   ЕСТЬNULL(СтавкаЕП.Ставка, 0) * ЕСТЬNULL(ДолиЕП.ДоляСО, 0) КАК СтавкаСО,
		|   ЕСТЬNULL(СтавкаЕП.Ставка, 0) * ЕСТЬNULL(ДолиЕП.ДоляООСМС, 0) КАК СтавкаООСМС,
		|   ЕСТЬNULL(СтавкаЕП.Ставка, 0) * ЕСТЬNULL(ДолиЕП.ДоляОПВР, 0) КАК СтавкаОПВР,
		|   ЕСТЬNULL(ДолиЕП.ДоляОПВ, 0) КАК ДоляОПВ,
		|   ЕСТЬNULL(ДолиЕП.ДоляВОСМС, 0) КАК ДоляВОСМС,
		|   ЕСТЬNULL(ДолиЕП.ДоляИПН, 0) КАК ДоляИПН,
		|   ЕСТЬNULL(ДолиЕП.ДоляСО, 0) КАК ДоляСО,
		|   ЕСТЬNULL(ДолиЕП.ДоляООСМС, 0) КАК ДоляООСМС,
		|   ЕСТЬNULL(ДолиЕП.ДоляОПВР, 0) КАК ДоляОПВР,
		|	ЕСТЬNULL(СтавкаЕП.Ставка, 0) КАК СтавкаЕП
		|ПОМЕСТИТЬ ВТИсчисленныйЕП
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкаЕП
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкаЕП.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкаЕП.ВидДохода
		|			И СтавкаЕП.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ЕП)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкаСО
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкаСО.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкаСО.ВидДохода
		|			И СтавкаСО.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.СО)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкаОПВ
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкаОПВ.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкаОПВ.ВидДохода
		|			И СтавкаОПВ.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ОПВ)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМС КАК СтавкиООСМС
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиООСМС.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиООСМС.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДолиЕП КАК ДолиЕП
		|		ПО Доходы.МесяцНалоговогоПериода = ДолиЕП.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|ГДЕ
		|	Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныйЕП.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныйЕП.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныйЕП.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныйЕП.ОбъектИсчисленияЕП КАК ОбъектИсчисленияЕП,
		|	ВТИсчисленныйЕП.ИсчисленныйЕП КАК ИсчисленныйЕП,
		|	ВТИсчисленныйЕП.СтавкаЕП КАК СтавкаЕП,
		|	ВТИсчисленныйЕП.СтавкаИПН КАК СтавкаИПН,
		|	ВТИсчисленныйЕП.СтавкаОПВ 	* ЕСТЬNULL(ИтогИсключаемыеНВОФизическиеЛица.ИсключатьОПВ, 1) КАК СтавкаОПВ,
		|	ВТИсчисленныйЕП.СтавкаВОСМС * ЕСТЬNULL(ИтогИсключаемыеНВОФизическиеЛица.ИсключатьОСМС, 1) КАК СтавкаВОСМС,
		|	ВТИсчисленныйЕП.СтавкаСО 	* ЕСТЬNULL(ИтогИсключаемыеНВОФизическиеЛица.ИсключатьСО, 1) КАК СтавкаСО,
		|	ВТИсчисленныйЕП.СтавкаООСМС * ЕСТЬNULL(ИтогИсключаемыеНВОФизическиеЛица.ИсключатьОСМС, 1) КАК СтавкаООСМС,
		|	ВТИсчисленныйЕП.СтавкаОПВР 	* ЕСТЬNULL(ИтогИсключаемыеНВОФизическиеЛица.ИсключатьОПВР, 1) КАК СтавкаОПВР,
		|   ВТИсчисленныйЕП.ДоляОПВ КАК ДоляОПВ,
		|   ВТИсчисленныйЕП.ДоляВОСМС КАК ДоляВОСМС,
		|   ВТИсчисленныйЕП.ДоляИПН КАК ДоляИПН,
		|   ВТИсчисленныйЕП.ДоляСО КАК ДоляСО,
		|   ВТИсчисленныйЕП.ДоляООСМС КАК ДоляООСМС,
		|   ВТИсчисленныйЕП.ДоляОПВР КАК ДоляОПВР,
		|	ВТИсчисленныйЕП.МаксимальныйРазмерОрганиченияДоходаООСМС КАК МаксимальныйРазмерОрганиченияДоходаООСМС,
		|	ВТИсчисленныйЕП.МаксимальныйРазмерОрганиченияДоходаВОСМС КАК МаксимальныйРазмерОрганиченияДоходаВОСМС,
		|	ВТИсчисленныйЕП.МаксимальныйРазмерОрганиченияДоходаСО КАК МаксимальныйРазмерОрганиченияДоходаСО,
		|	ВТИсчисленныйЕП.МаксимальныйРазмерОрганиченияДоходаОПВ КАК МаксимальныйРазмерОрганиченияДоходаОПВ
		|ИЗ
		|	ВТИсчисленныйЕП КАК ВТИсчисленныйЕП
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИтогИсключаемыеНВОФизическиеЛица КАК ИтогИсключаемыеНВОФизическиеЛица
		|		ПО ВТИсчисленныйЕП.МесяцНалоговогоПериода = ИтогИсключаемыеНВОФизическиеЛица.МесяцНалоговогоПериода
		|			И ВТИсчисленныйЕП.ФизическоеЛицо = ИтогИсключаемыеНВОФизическиеЛица.ФизическоеЛицо
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	СУММА(ДоходыПоПодразделениям.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	СУММА(ДоходыПоПодразделениям.НеоблагаемыйДоход) КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
        |
		|СГРУППИРОВАТЬ ПО
		|	ДоходыПоПодразделениям.Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныйЕППоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныйЕППоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныйЕППоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныйЕППоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныйЕППоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйЕППоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйЕППоПодразделениям.ОбъектИсчисления КАК ОбъектЕПИсчисленныйРанее,
		|	ИсчисленныйЕППоПодразделениям.НалогВзнос КАК РанееИсчисленныйЕП,
		|	-ИсчисленныйЕППоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныйЕППоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныйЕППоПодразделениям.НалогВзнос КАК ИсчисленныйЕП,
		|	-ИсчисленныйЕППоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияЕП
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныйЕППоПодразделениям
		|ГДЕ
		|	(ИсчисленныйЕППоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйЕППоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйЕППоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныйЕППоПодразделениям.НалогВзнос <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеКомпонентыЕППоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеКомпонентыЕППоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеКомпонентыЕППоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя) КАК ВидДохода,
		|	0 КАК ОблагаемыйДоходВЦеломЗаПериод, 	
		|	0 КАК НеоблагаемыйДоходВЦеломЗаПериод, 	
		|	0 КАК ОбъектИсчисленияЕПВЦеломЗаПериод,	
		|	0 КАК ИсчисленныйЕПВЦеломЗаПериод,
		|	0 КАК ОблагаемыйДоходИсчисленныйРанее,
		|	0 КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	0 КАК ОбъектЕПИсчисленныйРанее,
		|	0 КАК РанееИсчисленныйЕП,
		|	0 КАК ОблагаемыйДоход, 
		|	0 КАК НеоблагаемыйДоход,
		|	0 КАК ОбъектИсчисленияЕП,
		|	0 КАК ИсчисленныйЕП,
		|	-ИсчисленныеКомпонентыЕППоПодразделениям.ОПВ КАК ОПВ,
		|	-ИсчисленныеКомпонентыЕППоПодразделениям.ВОСМС КАК ВОСМС,
		|	-ИсчисленныеКомпонентыЕППоПодразделениям.ИПН КАК ИПН,
		|	-ИсчисленныеКомпонентыЕППоПодразделениям.СО КАК СО,
		|	-ИсчисленныеКомпонентыЕППоПодразделениям.ООСМС КАК ООСМС,
		|	-ИсчисленныеКомпонентыЕППоПодразделениям.ОПВР КАК ОПВР
		|ИЗ
		|	ВТРанееИсчисленныеКомпонентыЕП КАК ИсчисленныеКомпонентыЕППоПодразделениям
		|";
			
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТИсчисленныйЕП");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеКомпонентыЕППоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	ИсчисленныйЕППоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 3].Выгрузить();
	РезультатЗапроса = Результат[ВсегоРезультатов - 4].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса.Колонки.Добавить("ОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ВОСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИПН", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("СО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ООСМС", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ОПВР", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныйЕПВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияЕПВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	РезультатыРасчетов.Колонки.Добавить("ОПВВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ВОСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИПНВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("СОВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ООСМСВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОПВРВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектЕПИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныйЕП", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	РезультатыРасчетов.Колонки.Удалить("ДоляВОСМС");
	РезультатыРасчетов.Колонки.Удалить("ДоляООСМС");
	РезультатыРасчетов.Колонки.Удалить("ДоляОПВ");
	РезультатыРасчетов.Колонки.Удалить("ДоляСО");
	РезультатыРасчетов.Колонки.Удалить("ДоляОПВР");
	РезультатыРасчетов.Колонки.Удалить("СтавкаВОСМС");
	РезультатыРасчетов.Колонки.Удалить("СтавкаООСМС");
	РезультатыРасчетов.Колонки.Удалить("СтавкаИПН");
	РезультатыРасчетов.Колонки.Удалить("СтавкаОПВ");
	РезультатыРасчетов.Колонки.Удалить("СтавкаСО");
	РезультатыРасчетов.Колонки.Удалить("СтавкаОПВР");
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	ДанныеОкругления = ПолучитьСпособОкругленияСПериодом(МенеджерВременныхТаблиц, ВидНалогаВзносаЕП);
	СпособОкругления = ДанныеОкругления.СпособОкругления;
	ПериодОкругления = ДанныеОкругления.Период;
	
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	ТочностьОкругления = ОписаниеСпособаОкругления.Точность;
	ПравилоОкругления = ОписаниеСпособаОкругления.ПравилоОкругления;		

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругленияДляРаспределения = ТочностьОкругления - Цел(ТочностьОкругления);
	
	Если ТочностьОкругленияДляРаспределения = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругленияДляРаспределения <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		
		КорректировкаООСМС = 0;
		КорректировкаВОСМС = 0;
		КорректировкаОПВ   = 0;
		КорректировкаОПВР  = 0;
		КорректировкаСО    = 0;
		
		// сумма ЕП по полной ставке
		// если порядок округления не установлен, то используем округление до двух знаков
		Если ПериодОкругления = Дата('00010101') Тогда
			// округление до двух знаков необходимо, чтобы распределение совпало с Госкорпорацией, тк суммы будут передаваться с двумя знаками после запятой
			СтрокаРасчета.ИсчисленныйЕП = Окр(СтрокаРасчета.ИсчисленныйЕП, 2);
		Иначе
			СтрокаРасчета.ИсчисленныйЕП = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаРасчета.ИсчисленныйЕП, ТочностьОкругления, ПравилоОкругления);
		КонецЕсли;
	
		СуммаПолногоЕП = СтрокаРасчета.ИсчисленныйЕП;
		
		МаксимальныйРазмерОрганиченияДоходаООСМС = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаООСМС;
		МаксимальныйРазмерОрганиченияДоходаВОСМС = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаВОСМС;
		МаксимальныйРазмерОрганиченияДоходаОПВ 	= СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОПВ;
		МаксимальныйРазмерОрганиченияДоходаОПВР = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОПВ;
		МаксимальныйРазмерОрганиченияДоходаСО 	= СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаСО;
		
		// ставка социальных отчислений устанавливается в размере 4.5% от объекта исчисления для 2025 года
		Если НЕ СтрокаРасчета.СтавкаСО = 0 Тогда
			КорректировкаСтавкиСО = 0.045 / СтрокаРасчета.СтавкаСО;	
			МаксимальныйРазмерОрганиченияДоходаСО = МаксимальныйРазмерОрганиченияДоходаСО * КорректировкаСтавкиСО;	
		КонецЕсли;
        // корректировки максимальной суммы выполняются в соответствии с расчетом Госкорпорации
		// законодательно для всех НВО, кроме СО контроль максимального предела должен происходить по объекту, а не сумме платежа
		// при этом при умножении ставки НВО в составе единого платежа максимальные суммы НВО не равны фактическим от обычной ставки НВО
        // при приведении расчетов Госкорпорации к законодательству влияние данных переменных в расчете необходимо устранить
		Если НЕ СтрокаРасчета.СтавкаОПВ = 0 Тогда
			КорректировкаСтавкиОПВ = 0.1 / СтрокаРасчета.СтавкаОПВ;	
			МаксимальныйРазмерОрганиченияДоходаОПВ = МаксимальныйРазмерОрганиченияДоходаОПВ * КорректировкаСтавкиОПВ;	
		КонецЕсли;
		Если НЕ СтрокаРасчета.СтавкаОПВР = 0 Тогда
			КорректировкаСтавкиОПВР = 0.025 / СтрокаРасчета.СтавкаОПВР;	
			МаксимальныйРазмерОрганиченияДоходаОПВР = МаксимальныйРазмерОрганиченияДоходаОПВР * КорректировкаСтавкиОПВР;	
		КонецЕсли;
		Если НЕ СтрокаРасчета.СтавкаВОСМС = 0 Тогда
			КорректировкаСтавкиВОСМС = 0.02 / СтрокаРасчета.СтавкаВОСМС;	
			МаксимальныйРазмерОрганиченияДоходаВОСМС = МаксимальныйРазмерОрганиченияДоходаВОСМС * КорректировкаСтавкиВОСМС;	
		КонецЕсли;
		Если НЕ СтрокаРасчета.СтавкаООСМС = 0 Тогда
			КорректировкаСтавкиООСМС = 0.03 / СтрокаРасчета.СтавкаООСМС;	
			МаксимальныйРазмерОрганиченияДоходаООСМС = МаксимальныйРазмерОрганиченияДоходаООСМС * КорректировкаСтавкиООСМС;	
		КонецЕсли;

		// скорректируем сумму ЕП на разницу между максимальным пределом и фактически начисленной долей НВО
		Если СтрокаРасчета.СтавкаВОСМС = 0 Тогда 
			
			// уменьшим на долю ООСМС без тысячных (тысячные всегда уходят на ИПН, даже если вид НВО входит в льготу)
			КорректировкаВОСМС = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляВОСМС * 100) / 100;
			
		ИначеЕсли СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаВОСМС Тогда
			
			// найдем суммы ОСМС
			КорректировкаВОСМС = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляВОСМС * 100) / 100;
			
			ТысячныеВОСМС = (КорректировкаВОСМС - Цел(КорректировкаВОСМС * 100) / 100);
			
			// найдем пределы
			МаксимальнаяСуммаВОСМС = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаВОСМС * 0.02;
			
			// уменьшим платеж на разницу, уберем согласно методике тысячные
			КорректировкаВОСМС = КорректировкаВОСМС - МаксимальнаяСуммаВОСМС - ТысячныеВОСМС;
			
		КонецЕсли;
		
		// скорректируем сумму ЕП на разницу между максимальным пределом и фактически начисленной долей НВО
		Если СтрокаРасчета.СтавкаООСМС = 0 Тогда 
			
			// уменьшим на долю ООСМС без тысячных (тысячные всегда уходят на ИПН, даже если вид НВО входит в льготу)
			КорректировкаООСМС = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляООСМС * 100) / 100;
			
		ИначеЕсли СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаООСМС Тогда
			
			// найдем суммы ОСМС
			КорректировкаООСМС = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляООСМС * 100) / 100;
			
			ТысячныеООСМС = (КорректировкаООСМС - Цел(КорректировкаООСМС * 100) / 100);
			
			// найдем пределы
			МаксимальнаяСуммаООСМС = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаООСМС * 0.03;
			
			// уменьшим платеж на разницу, уберем согласно методике тысячные
			КорректировкаООСМС = КорректировкаООСМС - МаксимальнаяСуммаООСМС - ТысячныеООСМС;
			
		КонецЕсли;
		
		Если СтрокаРасчета.СтавкаОПВ = 0 Тогда
			
			// уменьшим на долю ОПВ без тысячных (тысячные всегда уходят на ИПН, даже если вид НВО входит в льготу)
			КорректировкаОПВ = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВ * 100) / 100;

		ИначеЕсли СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаОПВ Тогда
			
			// найдем суммы ОПВ
			КорректировкаОПВ = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВ * 100) / 100;
			
			ТысячныеОПВ = (КорректировкаОПВ - Цел(КорректировкаОПВ * 100) / 100);
			
			// найдем пределы
			МаксимальнаяСуммаОПВ = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОПВ * 0.1;
			
			// уменьшим платеж на разницу, уберем согласно методике тысячные
			КорректировкаОПВ = КорректировкаОПВ - МаксимальнаяСуммаОПВ - ТысячныеОПВ;
			
		КонецЕсли;
		
		Если СтрокаРасчета.СтавкаОПВР = 0 Тогда 
			
			КорректировкаОПВР = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВР * 100) / 100;
			
		ИначеЕсли СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаОПВР Тогда
			
			// найдем суммы ОПВР
			КорректировкаОПВР = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВР * 100) / 100;
			
			ТысячныеОПВР = (КорректировкаОПВР - Цел(КорректировкаОПВР * 100) / 100);
			
			// найдем пределы
			МаксимальнаяСуммаОПВР = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОПВ * 0.025;
			
			// уменьшим платеж на разницу, уберем согласно методике тысячные
			КорректировкаОПВР = КорректировкаОПВР - МаксимальнаяСуммаОПВР - ТысячныеОПВР;
			
		КонецЕсли;

		Если СтрокаРасчета.СтавкаСО = 0 Тогда 
			
			// уменьшим на долю СО без тысячных (тысячные всегда уходят на ИПН, даже если вид НВО входит в льготу)
			КорректировкаСО = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляСО * 100) / 100;
			
		ИначеЕсли СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаСО Тогда
			
			// найдем суммы СО
			КорректировкаСО = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляСО * 100) / 100;
			
			ТысячныеСО = (КорректировкаСО - Цел(КорректировкаСО * 100) / 100);
			
			// найдем пределы
			МаксимальнаяСуммаСО = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаСО * 0.045;
			
			// уменьшим платеж на разницу, уберем согласно методике тысячные
			КорректировкаСО = КорректировкаСО - МаксимальнаяСуммаСО - ТысячныеСО;
			
		КонецЕсли;
		
		Если НЕ ОкончательныйРасчетЗарплаты Тогда
			// в межрасчете всегда убираем долю за счет работодателя
			КорректировкаООСМС = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляООСМС * 100) / 100;
			КорректировкаСО    = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляСО * 100) / 100;
			КорректировкаОПВР  = Цел(СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВР * 100) / 100;
		КонецЕсли;
		
		// округлим до двух знаков, в противном случае получится погрешность при округлении (объект 159090.9 при отсутствии сумм ВОСМС и ООСМС вернет 23863.635, без округления результат будет не корректен)
		СтрокаРасчета.ИсчисленныйЕП = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаРасчета.ИсчисленныйЕП - КорректировкаООСМС - КорректировкаВОСМС - КорректировкаОПВ - КорректировкаОПВР - КорректировкаСО, 0.01);
		
		// распределяем округленный до двух знаков ЕП, в случае распределения более двух знаков после запятой разойдемся с распределением Госкорпорации
		СтрокаРасчета.ИсчисленныйЕП = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаРасчета.ИсчисленныйЕП, 0.01);
		
		Если НЕ СтрокаРасчета.СтавкаОПВ = 0 Тогда
			
			Если СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаОПВ Тогда
				СтрокаРасчета.ОПВ = МаксимальнаяСуммаОПВ;
			Иначе
				СтрокаРасчета.ОПВ = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляОПВ * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.ОПВ = 0;
		КонецЕсли;
		
		Если НЕ СтрокаРасчета.СтавкаВОСМС = 0 Тогда
			
			Если СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаВОСМС Тогда
				СтрокаРасчета.ВОСМС = МаксимальнаяСуммаВОСМС;
			Иначе
				СтрокаРасчета.ВОСМС = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляВОСМС * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.ВОСМС = 0;
		КонецЕсли;
		
		Если НЕ СтрокаРасчета.СтавкаООСМС = 0 Тогда
			
			Если СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаООСМС Тогда
				СтрокаРасчета.ООСМС = МаксимальнаяСуммаООСМС;
			Иначе
				СтрокаРасчета.ООСМС = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляООСМС * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.ООСМС = 0;
		КонецЕсли;
		
		Если НЕ СтрокаРасчета.СтавкаСО = 0 Тогда
			
			Если СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаСО Тогда
				СтрокаРасчета.СО = МаксимальнаяСуммаСО;
			Иначе
				СтрокаРасчета.СО = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляСО * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.СО = 0;
		КонецЕсли;
		
		Если НЕ СтрокаРасчета.СтавкаОПВР = 0 Тогда
			
			Если СтрокаРасчета.ОбъектИсчисленияЕП > МаксимальныйРазмерОрганиченияДоходаОПВР Тогда
				СтрокаРасчета.ОПВР = МаксимальнаяСуммаОПВР;
			Иначе
				СтрокаРасчета.ОПВР = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляОПВР * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.ОПВР = 0;
		КонецЕсли;
		
		// суммы корректировок компонент ЕП
		СуммаКорректировок = КорректировкаОПВ + КорректировкаВОСМС + КорректировкаООСМС + КорректировкаСО + КорректировкаОПВР;
	
		// на ИПН относим оставшуюся сумму
		СтрокаРасчета.ИПН = СуммаПолногоЕП - СтрокаРасчета.ВОСМС - СтрокаРасчета.ООСМС - СтрокаРасчета.ОПВ - СтрокаРасчета.СО - СтрокаРасчета.ОПВР - СуммаКорректировок;
		
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияЕП,ИсчисленныйЕП,ООСМС,ВОСМС,ИПН,ОПВ,ОПВР,СО", ТочностьРаспределения);
		
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныйЕППоПодразделениям, РезультатыРасчетов);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеКомпонентыЕППоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияЕПВЦеломЗаПериод,	ИсчисленныйЕПВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектЕПИсчисленныйРанее, 		 	РанееИсчисленныйЕП,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияЕП, 				ИсчисленныйЕП,
								|ООСМС,								ВОСМС,								ОПВ,								ОПВР,	
								|СО,								ИПН");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0
			И (СтрокаТЗ.ИсчисленныйЕП < 1 И СтрокаТЗ.ИсчисленныйЕП > 0
				ИЛИ СтрокаТЗ.ИсчисленныйЕП > -1 И СтрокаТЗ.ИсчисленныйЕП < 0) Тогда
				
			СтрокаТЗ.ИсчисленныйЕП = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			// не округляем, тк возникнут погрешности между суммой ЕП и суммой компонент ЕП
			СтрокаТЗ.ИсчисленныйЕП = СтрокаТЗ.ИсчисленныйЕП;
			
		КонецЕсли;
		
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат ДанныеОРезультатахРасчетаЕПДляДокумента(РезультатыРасчетов, ОкончательныйРасчетЗарплаты);
	
КонецФункции

#КонецОбласти