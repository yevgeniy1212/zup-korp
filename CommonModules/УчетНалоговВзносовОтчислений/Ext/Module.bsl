	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТПоФизическомуЛицуНаДатуПолученияДохода
	|";
	
	РезультатЗапроса = Запрос.Выполнить();
 	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.СледующийПоЗначениюПоля("ФизическоеЛицо") Цикл 
		
		Пока Выборка.СледующийПоЗначениюПоля("ВидНалогаВзносаОтчисления") Цикл 
			
			Пока Выборка.СледующийПоЗначениюПоля("ВидДохода") Цикл 
				Пока Выборка.СледующийПоЗначениюПоля("НалоговыйПериод") Цикл 
					Если Выборка.ОстатокЗаНалоговыйПериод >= 0 Тогда
						ОстатокКУдержанию = 0;
                        ПравилоОкругления = ?(Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС, 
                            ПредопределенноеЗначение("Перечисление.ПравилаОкругленияПриРасчетеЗарплаты.ВБольшуюСторону"), Выборка.ПравилоОкругления);  
						Пока Выборка.СледующийПоЗначениюПоля("НачалоМесяцаНалоговогоПериода") Цикл 
							СуммаКРаспределению = Выборка.ОстатокЗаНалоговыйПериод;
							ОстатокКУдержанию = ОстатокКУдержанию + Выборка.СуммаЗаМесяц;
							Если ОстатокКУдержанию > 0 И Выборка.СуммаЗаМесяц > 0 Тогда
								Пока Выборка.Следующий() И СуммаКРаспределению > 0 И ОстатокКУдержанию > 0 Цикл
									Если Выборка.СуммаОстаток > 0 Тогда
                                      
										СписываемаяСумма = Мин(Выборка.СуммаОстаток, ОстатокКУдержанию);
										СуммаКРаспределению = СуммаКРаспределению - СписываемаяСумма;
										ОстатокКУдержанию = ОстатокКУдержанию - СписываемаяСумма;
										
										СтрокаТаблицыРезультатов = РезультатыРасчетов.Добавить();
										ЗаполнитьЗначенияСвойств(СтрокаТаблицыРезультатов, Выборка);
                                        
                                        Если ПериодРегистрации >= Дата(2020,1,1) И Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС Тогда
                                            НалогВзнос = ЗарплатаКадрыКлиентСервер.Округлить(СписываемаяСумма, 1, ПравилоОкругления);
                                        Иначе
                                            НалогВзнос = ЗарплатаКадрыКлиентСервер.Округлить(СписываемаяСумма, Выборка.ТочностьОкругления, ПравилоОкругления);
                                        КонецЕсли;
                                        
                                        //проверяем остатки на текущий период, если есть остатки с дробью, не округляем значение, чтобы не увеличить сумму выплаченных налогов
                                        Если Выборка.НачисленоНалога - Выборка.УдержаноНалога <= НалогВзнос Тогда
                                            //проверяем правило округления, если в большую сторону и разница между округлением меньше 1, то округляем налог всегда 
                                            Если ПравилоОкругления = ПредопределенноеЗначение("Перечисление.ПравилаОкругленияПриРасчетеЗарплаты.ВБольшуюСторону")
                                                И НалогВзнос - СписываемаяСумма < 1 Тогда
                                                СтрокаТаблицыРезультатов.НалогВзнос = НалогВзнос;
                                            Иначе
                                                СтрокаТаблицыРезультатов.НалогВзнос = СписываемаяСумма;
                                            КонецЕсли;
                                        Иначе
                                            СтрокаТаблицыРезультатов.НалогВзнос = НалогВзнос;
                                        КонецЕсли; 
									
									КонецЕсли;
								КонецЦикла;
							КонецЕсли;
						КонецЦикла;
					Иначе
						СуммаКРаспределению = СуммаКРаспределению - Выборка.ОстатокЗаНалоговыйПериод;
						СтрокаТаблицыРезультатов = РезультатыРасчетов.Добавить();
						ЗаполнитьЗначенияСвойств(СтрокаТаблицыРезультатов, Выборка);
                        Если ПериодРегистрации >= Дата(2020,1,1) И Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС Тогда
                            НалогВзнос = ЗарплатаКадрыКлиентСервер.Округлить(Выборка.ОстатокЗаНалоговыйПериод, 1, ПравилоОкругления);
                        Иначе
                            НалогВзнос = ЗарплатаКадрыКлиентСервер.Округлить(Выборка.ОстатокЗаНалоговыйПериод, Выборка.ТочностьОкругления, ПравилоОкругления);
                        КонецЕсли;
                        
                        //проверяем остатки на текущий период, если есть остатки с дробью, не округляем значение, чтобы не увеличить сумму выплаченных налогов
                        Если Выборка.НачисленоНалога - Выборка.УдержаноНалога <= НалогВзнос Тогда
                            //проверяем правило округления, если в большую сторону и разница между округлением меньше 1, то округляем налог всегда 
                            Если ПравилоОкругления = ПредопределенноеЗначение("Перечисление.ПравилаОкругленияПриРасчетеЗарплаты.ВБольшуюСторону")
                                И НалогВзнос - Выборка.ОстатокЗаНалоговыйПериод < 1 Тогда
                                СтрокаТаблицыРезультатов.НалогВзнос = НалогВзнос;
                            Иначе
                                СтрокаТаблицыРезультатов.НалогВзнос = Выборка.ОстатокЗаНалоговыйПериод;
                            КонецЕсли;
                        Иначе
                            СтрокаТаблицыРезультатов.НалогВзнос = НалогВзнос;
                        КонецЕсли; 

						СтрокаТаблицыРезультатов.МесяцНалоговогоПериода = Выборка.ПоследнийМесяцНалоговогоПериода;
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция ПолучитьДатуНачалаДействияВычетаСО()

	Возврат Дата('20250101');
	
КонецФункции

// Расчеты с 2019 года

Процедура СоздатьВТДанныеПоКорректировкеДоходаИПН(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет, ИсключатьДоходыРегистратора, ПрименятьКорректировку = Истина) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("НачалоМесяцаРасчета", НачалоМесяца(МесяцНачисления));
	Запрос.УстановитьПараметр("КонецМесяцаРасчета", КонецМесяца(МесяцНачисления));
	Запрос.УстановитьПараметр("ОкончательныйРасчет", ОкончательныйРасчет);
	Запрос.УстановитьПараметр("ПрименятьКорректировку", ПрименятьКорректировку);
	Запрос.УстановитьПараметр("ИсключаемыйРегистратор", ?(ИсключатьДоходыРегистратора, Регистратор, Неопределено));
	
	// Накопленные данные по вычетам	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ПериодыПоФизлицам.ФизическоеЛицо КАК ФизическоеЛицо,
		|	СУММА(СведенияОбИсчисленииНалоговВзносовОтчислений.ПримененнаяЛьготаОборот) КАК ПримененнаяКорректировка
		|ПОМЕСТИТЬ ВТДанныеПоКорректировкеДоходаИПН
		|ИЗ
		|	ВТКадровыеДанныеСотрудниковПоПериодам КАК ПериодыПоФизлицам
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.СведенияОбИсчисленииНалоговВзносовОтчислений.Обороты(
		|				&НачалоМесяцаРасчета,
		|				&КонецМесяцаРасчета,
		|				Регистратор,
		|				Организация = &Организация
		|					И &ОкончательныйРасчет
		|					И &ПрименятьКорректировку
		|					И ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ИПН)
		|					И ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)) КАК СведенияОбИсчисленииНалоговВзносовОтчислений
		|		ПО ПериодыПоФизлицам.ФизическоеЛицо = СведенияОбИсчисленииНалоговВзносовОтчислений.ФизическоеЛицо
		|			И ПериодыПоФизлицам.МесяцНалоговогоПериода >= СведенияОбИсчисленииНалоговВзносовОтчислений.Период
		|			И (ПериодыПоФизлицам.НачалоГодаНалоговогоПериода = НАЧАЛОПЕРИОДА(СведенияОбИсчисленииНалоговВзносовОтчислений.Период, ГОД))
		|			И (НАЧАЛОПЕРИОДА(ПериодыПоФизлицам.ДатаПриема, МЕСЯЦ) <= НАЧАЛОПЕРИОДА(СведенияОбИсчисленииНалоговВзносовОтчислений.Период, МЕСЯЦ))
		|
		|ГДЕ
		|	СведенияОбИсчисленииНалоговВзносовОтчислений.Регистратор <> &ИсключаемыйРегистратор
		|	И СведенияОбИсчисленииНалоговВзносовОтчислений.ПериодРегистрации >= ДАТАВРЕМЯ(2019, 1, 1)
		|
		|СГРУППИРОВАТЬ ПО
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода,
		|	ПериодыПоФизлицам.ФизическоеЛицо
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	МесяцНалоговогоПериода,
		|	ФизическоеЛицо
		|";
		
	Запрос.Выполнить();
	
КонецПроцедуры

// Взносы и отчисления ОСМС

Процедура СоздатьВТИсключаемыеЛицаОСМС(МенеджерВременныхТаблиц, ИмяТаблицы, МесяцНачисления) Экспорт
	
	Если МесяцНачисления >= Дата(2023, 1, 1) Тогда
		СоздатьВТИсключаемыеЛицаОСМСПосле2023(МенеджерВременныхТаблиц, ИмяТаблицы, МесяцНачисления)
	Иначе
		СоздатьВТИсключаемыеЛицаОСМСДо2022(МенеджерВременныхТаблиц, ИмяТаблицы, МесяцНачисления)
	КонецЕсли;
	
КонецПроцедуры

Процедура СоздатьВТИсключаемыеЛицаОСМСПосле2023(МенеджерВременныхТаблиц, ИмяТаблицы, МесяцНачисления) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("КонецМесяцаРасчета", КонецМесяца(МесяцНачисления)); 
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	// Исключаемые лица
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СведенияОПенсионномОбеспеченииФизическихЛиц.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка) КАК ВидДохода
		|ПОМЕСТИТЬ ВТИсключаемыеФизическиеЛицаИсточники
		|ИЗ
		|	РегистрСведений.СведенияОПенсионномОбеспеченииФизическихЛиц.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОПенсионномОбеспеченииФизическихЛиц
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ПО СведенияОПенсионномОбеспеченииФизическихЛиц.ФизическоеЛицо = ПериодыПоФизлицам.ФизическоеЛицо
		|ГДЕ
		|	(СведенияОПенсионномОбеспеченииФизическихЛиц.ПенсионерПоВозрасту
		|			ИЛИ СведенияОПенсионномОбеспеченииФизическихЛиц.ПенсионерПоВыслугеЛет)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СведенияОбИнвалидностиФизическихЛицСрезПоследних.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка)
		|ИЗ
		|	РегистрСведений.СведенияОбИнвалидностиФизическихЛиц.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОбИнвалидностиФизическихЛицСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ПО СведенияОбИнвалидностиФизическихЛицСрезПоследних.ФизическоеЛицо = ПериодыПоФизлицам.ФизическоеЛицо
		|ГДЕ
		|	СведенияОбИнвалидностиФизическихЛицСрезПоследних.ОтношениеКИнвалидности = ЗНАЧЕНИЕ(Перечисление.ОтношениеКИнвалидности.Инвалид)
		|	И (СведенияОбИнвалидностиФизическихЛицСрезПоследних.ДействуетДо = ДАТАВРЕМЯ(1,1,1) 
		// ЗУП РФ поведение СведенияОбИнвалидностиФизическихЛиц.МО.ПередЗаписью: Строка.ДействуетДо = КонецДня(Строка.СрокДействияСправки) + 1 
		|		ИЛИ КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(СведенияОбИнвалидностиФизическихЛицСрезПоследних.ДействуетДо, ДЕНЬ, -1), МЕСЯЦ) >= КОНЕЦПЕРИОДА(ПериодыПоФизлицам.МесяцНалоговогоПериода, МЕСЯЦ))
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СведенияОФизическихЛицахУчастникахВОВСрезПоследних.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка)
		|ИЗ
		|	РегистрСведений.СведенияОФизическихЛицахУчастникахВОВ.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОФизическихЛицахУчастникахВОВСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ПО СведенияОФизическихЛицахУчастникахВОВСрезПоследних.ФизическоеЛицо = ПериодыПоФизлицам.ФизическоеЛицо
		|ГДЕ
		|	(СведенияОФизическихЛицахУчастникахВОВСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.КатегорииФизическихЛицУчастниковВОВ.УчастникВОВ)
		|			ИЛИ СведенияОФизическихЛицахУчастникахВОВСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.КатегорииФизическихЛицУчастниковВОВ.ИнвалидВОВ))
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка)
		|ИЗ
		|	РегистрСведений.СтатусФизическихЛицКакНалогоплательщиков.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СтатусФизическихЛицКакНалогоплательщиков
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ПО СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо = ПериодыПоФизлицам.ФизическоеЛицо
		|ГДЕ
		|	НЕ СтатусФизическихЛицКакНалогоплательщиков.ПодлежитСоциальномуМедицинскомуСтрахованию
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|ИЗ
		|	ВТСтатусыФизическихЛицКакНалогоплательщиков КАК СтатусФизическихЛицКакНалогоплательщиков
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ПО СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо = ПериодыПоФизлицам.ФизическоеЛицо
		|			И СтатусФизическихЛицКакНалогоплательщиков.МесяцНалоговогоПериода = ПериодыПоФизлицам.МесяцНалоговогоПериода
		|			И СтатусФизическихЛицКакНалогоплательщиков.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТУчетнаяПолитикаПоПериодам КАК УчетнаяПолитикаПоПериодам
		|		ПО УчетнаяПолитикаПоПериодам.МесяцНалоговогоПериода = ПериодыПоФизлицам.МесяцНалоговогоПериода
		|			И УчетнаяПолитикаПоПериодам.ПорядокОбложенияДоходовРаботников = ЗНАЧЕНИЕ(Перечисление.ПорядокОбложенияДоходовРаботников.ЕдиныйПлатеж)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТИсключаемыеФизическиеЛицаИсточники.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсключаемыеФизическиеЛицаИсточники.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсключаемыеФизическиеЛицаИсточники.ВидДохода КАК ВидДохода
		|ПОМЕСТИТЬ ВТИтогИсключаемыеФизическиеЛица
		|ИЗ
		|	ВТИсключаемыеФизическиеЛицаИсточники КАК ВТИсключаемыеФизическиеЛицаИсточники";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВТИтогИсключаемыеФизическиеЛица", ИмяТаблицы);	
	Запрос.Выполнить();

	УничтожитьВТ = Новый Массив;
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаИсточники");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);

КонецПроцедуры

Процедура СоздатьВТИсключаемыеЛицаОСМСДо2022(МенеджерВременныхТаблиц, ИмяТаблицы, МесяцНачисления) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("КонецМесяцаРасчета", КонецМесяца(МесяцНачисления)); 
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	// Исключаемые лица
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СведенияОПенсионномОбеспеченииФизическихЛиц.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода
		|ПОМЕСТИТЬ ВТИсключаемыеФизическиеЛицаИсточники
		|ИЗ
		|	РегистрСведений.СведенияОПенсионномОбеспеченииФизическихЛиц.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОПенсионномОбеспеченииФизическихЛиц
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ПО СведенияОПенсионномОбеспеченииФизическихЛиц.ФизическоеЛицо = ПериодыПоФизлицам.ФизическоеЛицо
		|ГДЕ
		|	(СведенияОПенсионномОбеспеченииФизическихЛиц.ПенсионерПоВозрасту
		|			ИЛИ СведенияОПенсионномОбеспеченииФизическихЛиц.ПенсионерПоВыслугеЛет)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СведенияОбИнвалидностиФизическихЛицСрезПоследних.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода
		|ИЗ
		|	РегистрСведений.СведенияОбИнвалидностиФизическихЛиц.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОбИнвалидностиФизическихЛицСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ПО СведенияОбИнвалидностиФизическихЛицСрезПоследних.ФизическоеЛицо = ПериодыПоФизлицам.ФизическоеЛицо
		|ГДЕ
		|	СведенияОбИнвалидностиФизическихЛицСрезПоследних.ОтношениеКИнвалидности = ЗНАЧЕНИЕ(Перечисление.ОтношениеКИнвалидности.Инвалид)
		|	И (СведенияОбИнвалидностиФизическихЛицСрезПоследних.ДействуетДо = ДАТАВРЕМЯ(1,1,1) 
		// ЗУП РФ поведение СведенияОбИнвалидностиФизическихЛиц.МО.ПередЗаписью: Строка.ДействуетДо = КонецДня(Строка.СрокДействияСправки) + 1 
		|		ИЛИ КОНЕЦПЕРИОДА(ДОБАВИТЬКДАТЕ(СведенияОбИнвалидностиФизическихЛицСрезПоследних.ДействуетДо, ДЕНЬ, -1), МЕСЯЦ) >= КОНЕЦПЕРИОДА(ПериодыПоФизлицам.МесяцНалоговогоПериода, МЕСЯЦ))
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СведенияОФизическихЛицахУчастникахВОВСрезПоследних.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода
		|ИЗ
		|	РегистрСведений.СведенияОФизическихЛицахУчастникахВОВ.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОФизическихЛицахУчастникахВОВСрезПоследних
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ПО СведенияОФизическихЛицахУчастникахВОВСрезПоследних.ФизическоеЛицо = ПериодыПоФизлицам.ФизическоеЛицо
		|ГДЕ
		|	(СведенияОФизическихЛицахУчастникахВОВСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.КатегорииФизическихЛицУчастниковВОВ.УчастникВОВ)
		|			ИЛИ СведенияОФизическихЛицахУчастникахВОВСрезПоследних.Статус = ЗНАЧЕНИЕ(Перечисление.КатегорииФизическихЛицУчастниковВОВ.ИнвалидВОВ))
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода
		|ИЗ
		|	РегистрСведений.СтатусФизическихЛицКакНалогоплательщиков.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СтатусФизическихЛицКакНалогоплательщиков
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ПО СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо = ПериодыПоФизлицам.ФизическоеЛицо
		|ГДЕ
		|	НЕ СтатусФизическихЛицКакНалогоплательщиков.ПодлежитСоциальномуМедицинскомуСтрахованию
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТИсключаемыеФизическиеЛицаИсточники.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсключаемыеФизическиеЛицаИсточники.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода
		|ПОМЕСТИТЬ ВТИтогИсключаемыеФизическиеЛица
		|ИЗ
		|	ВТИсключаемыеФизическиеЛицаИсточники КАК ВТИсключаемыеФизическиеЛицаИсточники";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ВТИтогИсключаемыеФизическиеЛица", ИмяТаблицы);	
	Запрос.Выполнить();

	УничтожитьВТ = Новый Массив;
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаИсточники");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);

КонецПроцедуры

Процедура СоздатьВТСтавкиОСМС(Организация, МенеджерВременныхТаблиц) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация",Организация);
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	// Ставки ОСМС
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	1 КАК Приоритет,
	|	МАКСИМУМ(ЕСТЬNULL(СведенияОСтавкахОСМС.Период, ДАТАВРЕМЯ(1, 1, 1))) КАК ПериодСтавки,
	|	ПериодыРасчета.Период КАК МесяцНалоговогоПериода,
	|	СведенияОСтавкахОСМС.Организация КАК Организация,
	|	СведенияОСтавкахОСМС.ВидДохода КАК ВидДохода
	|ПОМЕСТИТЬ ВТПериодыСтавокОСМС
	|ИЗ
	|	ВТДатыПоМесяцам КАК ПериодыРасчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОСтавкахОСМС КАК СведенияОСтавкахОСМС
	|		ПО ПериодыРасчета.Период >= СведенияОСтавкахОСМС.Период
	|ГДЕ
	|	СведенияОСтавкахОСМС.Организация = &Организация
	|
	|СГРУППИРОВАТЬ ПО
	|	ПериодыРасчета.Период,
	|	СведенияОСтавкахОСМС.Организация,
	|	СведенияОСтавкахОСМС.ВидДохода
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	2,
	|	МАКСИМУМ(ЕСТЬNULL(СведенияОСтавкахОСМС.Период, ДАТАВРЕМЯ(1, 1, 1))),
	|	ПериодыРасчета.Период,
	|	ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка),
	|	СведенияОСтавкахОСМС.ВидДохода
	|ИЗ
	|	ВТДатыПоМесяцам КАК ПериодыРасчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОСтавкахОСМС КАК СведенияОСтавкахОСМС
	|		ПО ПериодыРасчета.Период >= СведенияОСтавкахОСМС.Период
	|ГДЕ
	|	СведенияОСтавкахОСМС.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	ПериодыРасчета.Период,
	|	СведенияОСтавкахОСМС.ВидДохода
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ПериодСтавки,
	|	ВидДохода,
	|	Организация
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПериодыСтавокОСМС.Приоритет КАК Приоритет,
	|	ПериодыСтавокОСМС.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
	|	ПериодыСтавокОСМС.ПериодСтавки КАК ПериодСтавки,
	|	ПериодыСтавокОСМС.ВидДохода КАК ВидДохода,
	|	ЕСТЬNULL(СведенияОСтавкахОСМС.СтавкаВзносы, 0) / 100 КАК СтавкаВзносы,
	|	ЕСТЬNULL(СведенияОСтавкахОСМС.СтавкаОтчисления, 0) / 100 КАК СтавкаОтчисления
	|ПОМЕСТИТЬ ВТСтавкиОСМСПоПриоритетам
	|ИЗ
	|	ВТПериодыСтавокОСМС КАК ПериодыСтавокОСМС
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОСтавкахОСМС КАК СведенияОСтавкахОСМС
	|		ПО ПериодыСтавокОСМС.ПериодСтавки = СведенияОСтавкахОСМС.Период
	|			И ПериодыСтавокОСМС.Организация = СведенияОСтавкахОСМС.Организация
	|			И ПериодыСтавокОСМС.ВидДохода = СведенияОСтавкахОСМС.ВидДохода
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Приоритет,
	|	МесяцНалоговогоПериода,
	|	ПериодСтавки,
	|	ВидДохода
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТСтавкиПоПриоритетам.Приоритет КАК Приоритет,
	|	МаксимумСтавок.ПериодСтавки КАК ПериодСтавки,
	|	МаксимумСтавок.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
	|	МаксимумСтавок.ВидДохода КАК ВидДохода
	|ПОМЕСТИТЬ ВТ_МаксимумыСтавокПоПериоду
	|ИЗ
	|	(ВЫБРАТЬ
	|		МАКСИМУМ(ПриоритетСтавок.ПериодСтавки) КАК ПериодСтавки,
	|		ПриоритетСтавок.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
	|		ПриоритетСтавок.ВидДохода КАК ВидДохода
	|	ИЗ
	|		ВТСтавкиОСМСПоПриоритетам КАК ПриоритетСтавок
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ПриоритетСтавок.МесяцНалоговогоПериода,
	|		ПриоритетСтавок.ВидДохода) КАК МаксимумСтавок
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМСПоПриоритетам КАК ВТСтавкиПоПриоритетам
	|		ПО МаксимумСтавок.ПериодСтавки = ВТСтавкиПоПриоритетам.ПериодСтавки
	|			И МаксимумСтавок.МесяцНалоговогоПериода = ВТСтавкиПоПриоритетам.МесяцНалоговогоПериода
	|			И МаксимумСтавок.ВидДохода = ВТСтавкиПоПриоритетам.ВидДохода
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	МесяцНалоговогоПериода,
	|	ВидДохода
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПриоритетСтавок.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
	|	ПриоритетСтавок.ВидДохода КАК ВидДохода,
	|	ВТСтавкиПоПриоритетам.СтавкаВзносы КАК СтавкаВзносы,
	|	ВТСтавкиПоПриоритетам.СтавкаОтчисления КАК СтавкаОтчисления
	|ПОМЕСТИТЬ ВТСтавкиОСМС
	|ИЗ
	|	(ВЫБРАТЬ
	|		МИНИМУМ(ПриоритетСтавок.Приоритет) КАК Приоритет,
	|		ПриоритетСтавок.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
	|		ПриоритетСтавок.ВидДохода КАК ВидДохода
	|	ИЗ
	|		ВТ_МаксимумыСтавокПоПериоду КАК ПриоритетСтавок
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ПриоритетСтавок.МесяцНалоговогоПериода,
	|		ПриоритетСтавок.ВидДохода) КАК ПриоритетСтавок
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиОСМСПоПриоритетам КАК ВТСтавкиПоПриоритетам
	|		ПО ПриоритетСтавок.Приоритет = ВТСтавкиПоПриоритетам.Приоритет
	|			И ПриоритетСтавок.МесяцНалоговогоПериода = ВТСтавкиПоПриоритетам.МесяцНалоговогоПериода
	|			И ПриоритетСтавок.ВидДохода = ВТСтавкиПоПриоритетам.ВидДохода";
		
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТПериодыСтавокОСМС");
	УничтожитьВТ.Добавить("ВТСтавкиОСМСПоПриоритетам");
	УничтожитьВТ.Добавить("ВТ_МаксимумыСтавокПоПериоду");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
КонецПроцедуры


#Область ВычетыИПН

Функция ПолучитьСведенияОЛьготахИВычетахИПН(ФизическоеЛицо,Дата) Экспорт
	
	ДатаКонтроля = '2018-01-01';
	ВозвращаемыйМассив = Новый Массив;
	
	Если Дата >= ДатаКонтроля Тогда
		ТЗ =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ВычетыФизическихЛицИПНСрезПоследних.Регистратор КАК Регистратор
		|ПОМЕСТИТЬ ВТ_Регистратор
		|ИЗ
		|	РегистрСведений.ВычетыФизическихЛицИПН.СрезПоследних(&Дата, ФизическоеЛицо = &ФизическоеЛицо) КАК ВычетыФизическихЛицИПНСрезПоследних
		|ГДЕ
		|	ВычетыФизическихЛицИПНСрезПоследних.Период >= &ДатаОграниченияПолученияДанных
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВычетыФизическихЛицИПНСрезПоследних.Период УБЫВ
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Регистратор
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВТ_Регистратор.Регистратор КАК Регистратор,
		|	ВТ_Регистратор.Регистратор.Дата КАК Дата,
		|	ВТ_Регистратор.Регистратор.Номер КАК Номер,
		|	ВТ_Регистратор.Регистратор.Организация КАК Организация
		|ИЗ
		|	ВТ_Регистратор КАК ВТ_Регистратор
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВычетыФизическихЛицИПНСрезПоследних.ПредоставлятьВычет КАК ПредоставлятьВычет,
		|	ВычетыФизическихЛицИПНСрезПоследних.ВидВычета КАК ВидВычетаИПН,
		|	ВычетыФизическихЛицИПНСрезПоследних.Основание КАК ДокументПодтверждающийПравоНаВычет,
		|	ВЫБОР
		|		КОГДА ВычетыФизическихЛицИПНСрезПоследних.ВидВычета.ПредоставлениеВычета = ЗНАЧЕНИЕ(Перечисление.ВидыПредоставленияВычетов.ПоПериодическимПлатежам)
		|				И ВычетыФизическихЛицИПНСрезПоследних.ПредоставлятьВычет
		|			ТОГДА ""Подробнее""
		|		ИНАЧЕ """"
		|	КОНЕЦ КАК Расшифровка,
		|	ВычетыФизическихЛицИПНСрезПоследних.ДействуетПо КАК ДействуетПо
		|ИЗ
		|	РегистрСведений.ВычетыФизическихЛицИПН.СрезПоследних(&Дата, ФизическоеЛицо = &ФизическоеЛицо) КАК ВычетыФизическихЛицИПНСрезПоследних
		|ГДЕ
		|	ВычетыФизическихЛицИПНСрезПоследних.Период >= &ДатаОграниченияПолученияДанных
		|	И ВычетыФизическихЛицИПНСрезПоследних.Регистратор В
		|			(ВЫБРАТЬ
		|				Т.Регистратор
		|			ИЗ
		|				ВТ_Регистратор КАК Т)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ВычетыФизическихЛицИПНСрезПоследних.ВидВычета,
		|	ВычетыФизическихЛицИПНСрезПоследних.ДействуетПо";
		
		Запрос = Новый Запрос(ТЗ);
		Запрос.УстановитьПараметр("ФизическоеЛицо",                 ФизическоеЛицо);
		Запрос.УстановитьПараметр("Дата",                           Дата);
		Запрос.УстановитьПараметр("ДатаОграниченияПолученияДанных", ДатаКонтроля);
		
		МассивРезультатов = Запрос.ВыполнитьПакет();
		
		КлючиСтруктуры = "";
		
		Для Каждого Колонка Из МассивРезультатов[1].Колонки Цикл
			КлючиСтруктуры = КлючиСтруктуры + ?(ПустаяСтрока(КлючиСтруктуры), "", ",") + Колонка.Имя;
		КонецЦикла;
		
		ВыборкаРезультата = МассивРезультатов[1].Выбрать();
		
		Если ВыборкаРезультата.Следующий() Тогда
			
			СтруктураСтрокиВыборкаРезультата = Новый Структура(КлючиСтруктуры);
			ЗаполнитьЗначенияСвойств(СтруктураСтрокиВыборкаРезультата, ВыборкаРезультата);
		Иначе
			СтруктураСтрокиВыборкаРезультата = Неопределено;
		КонецЕсли;
		ВозвращаемыйМассив.Добавить(СтруктураСтрокиВыборкаРезультата);
		
		ВозвращаемыйМассив.Добавить(МассивРезультатов[2].Выгрузить());
		
	Иначе
		ТЗ =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ВычетыФизическихЛицИПН.Регистратор,
		|	ВычетыФизическихЛицИПН.Регистратор.Номер КАК Номер,
		|	ВычетыФизическихЛицИПН.Регистратор.Дата КАК Дата,
		|	ВычетыФизическихЛицИПН.Регистратор.Организация КАК Организация,
		|	ВычетыФизическихЛицИПН.Регистратор.Сотрудник КАК Сотрудник,
		|	ВычетыФизическихЛицИПН.ПредоставлятьВычет
		|ИЗ
		|	РегистрСведений.ВычетыФизическихЛицИПН.СрезПоследних(&Дата, ФизическоеЛицо = &ФизическоеЛицо) КАК ВычетыФизическихЛицИПН
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ПрочиеВычетыФизическихЛицИПН.Регистратор,
		|	ПрочиеВычетыФизическихЛицИПН.Регистратор.Номер КАК Номер,
		|	ПрочиеВычетыФизическихЛицИПН.Регистратор.Дата КАК Дата,
		|	ПрочиеВычетыФизическихЛицИПН.Регистратор.Организация КАК Организация,
		|	ПрочиеВычетыФизическихЛицИПН.Регистратор.Сотрудник КАК Сотрудник,
		|	ПрочиеВычетыФизическихЛицИПН.ВидВычета КАК ВидВычетаИПН,
		|	ПрочиеВычетыФизическихЛицИПН.Размер,
		|	ПрочиеВычетыФизическихЛицИПН.ДействуетПо,
		|	ПрочиеВычетыФизическихЛицИПН.Основание КАК ДокументПодтверждающийПравоНаВычет
		|ИЗ
		|	РегистрСведений.ПрочиеВычетыФизическихЛицИПН.СрезПоследних(&Дата, ФизическоеЛицо = &ФизическоеЛицо) КАК ПрочиеВычетыФизическихЛицИПН
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ ПЕРВЫЕ 1
		|	ЛьготыФизическихЛицИПН.Регистратор,
		|	ЛьготыФизическихЛицИПН.Регистратор.Номер КАК Номер,
		|	ЛьготыФизическихЛицИПН.Регистратор.Дата КАК Дата,
		|	ЛьготыФизическихЛицИПН.Регистратор.Организация КАК Организация,
		|	ЛьготыФизическихЛицИПН.Регистратор.Сотрудник КАК Сотрудник,
		|	ЛьготыФизическихЛицИПН.Основание КАК ДокументПодтверждающийПравоНаЛьготу,
		|	ЛьготыФизическихЛицИПН.ПредоставлятьЛьготу,
		|	ЛьготыФизическихЛицИПН.ДействуетДо,
		|	ЛьготыФизическихЛицИПН.КатегорияЛицаПолучателяЛьготы
		|ИЗ
		|	РегистрСведений.ЛьготыФизическихЛицИПН.СрезПоследних(&Дата, ФизическоеЛицо = &ФизическоеЛицо) КАК ЛьготыФизическихЛицИПН";
		
		Запрос = Новый Запрос(ТЗ);
		Запрос.УстановитьПараметр("ФизическоеЛицо",                 ФизическоеЛицо);
		Запрос.УстановитьПараметр("Дата",                           Дата);
		МассивРезультатов = Запрос.ВыполнитьПакет();
		
		Для ИндексРезультата = 0 По 2 Цикл
			
			КлючиСтруктуры = "";
			
			Для Каждого Колонка Из МассивРезультатов[ИндексРезультата].Колонки Цикл
				КлючиСтруктуры = КлючиСтруктуры + ?(ПустаяСтрока(КлючиСтруктуры), "", ",") + Колонка.Имя;
			КонецЦикла;
			
			МассивСтруктур = Новый Массив;
			
			ВыборкаРезультата = МассивРезультатов[ИндексРезультата].Выбрать();
			
			Пока ВыборкаРезультата.Следующий() Цикл
				
				СтруктураСтрокиВыборкаРезультата = Новый Структура(КлючиСтруктуры);
				ЗаполнитьЗначенияСвойств(СтруктураСтрокиВыборкаРезультата, ВыборкаРезультата);
				
				МассивСтруктур.Добавить(СтруктураСтрокиВыборкаРезультата);
				
			КонецЦикла;
			
			ВозвращаемыйМассив.Добавить(МассивСтруктур);
			
		КонецЦикла;
		
	КонецЕсли;

	Возврат ВозвращаемыйМассив;
	
КонецФункции

#КонецОбласти

Функция ВТСуществует(МенеджерВременныхТаблиц, ИмяВТ)
	
	Возврат ЗарплатаКадры.ВТСуществует(МенеджерВременныхТаблиц, ИмяВТ);
	
КонецФункции

