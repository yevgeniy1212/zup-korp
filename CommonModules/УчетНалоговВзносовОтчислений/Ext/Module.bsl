	ПериодОкругления = ДанныеОкругления.Период;
	
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
	ПравилоОкругления = ОписаниеСпособаОкругления.ПравилоОкругления;		

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругленияДляРаспределения = ТочностьОкругления - Цел(ТочностьОкругления);
	
	Если ТочностьОкругленияДляРаспределения = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругленияДляРаспределения <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		
		КорректировкаООСМС = 0;
		КорректировкаВОСМС = 0;
		КорректировкаОПВ   = 0;
		КорректировкаОПВР  = 0;
		КорректировкаСО    = 0;
		
		// сумма ЕП по полной ставке
		// округление до двух знаков необходимо, чтобы распределение совпало с Госкорпорацией, тк суммы будут передаваться с двумя знаками после запятой
		СтрокаРасчета.ИсчисленныйЕП = Окр(СтрокаРасчета.ИсчисленныйЕП, 2);
		СуммаПолногоЕП = СтрокаРасчета.ИсчисленныйЕП;
		
		// скорректируем сумму ЕП на разницу между максимальным пределом и фактически начисленной долей НВО
		Если СтрокаРасчета.СтавкаВОСМС = 0
			ИЛИ СтрокаРасчета.СтавкаООСМС = 0 Тогда 
			
			// уменьшим на долю ООСМС и ВОСМС
			КорректировкаООСМС = СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляООСМС;
			КорректировкаВОСМС = СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляВОСМС;
			
		ИначеЕсли СтрокаРасчета.ОбъектИсчисленияЕП > СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОСМС Тогда
			
			// найдем суммы ОСМС
			КорректировкаООСМС = СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляООСМС;
			КорректировкаВОСМС = СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляВОСМС;
			
			// найдем пределы
			МаксимальнаяСуммаООСМС = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОСМС * 0.03;
			МаксимальнаяСуммаВОСМС = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОСМС * 0.02;
			
			// уменьшим платеж на разницу
			КорректировкаООСМС = КорректировкаООСМС - МаксимальнаяСуммаООСМС;
			КорректировкаВОСМС = КорректировкаВОСМС - МаксимальнаяСуммаВОСМС;
			
		КонецЕсли;
		
		Если СтрокаРасчета.СтавкаОПВ = 0 Тогда
			
			// уменьшим на долю ОПВ
			КорректировкаОПВ = СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВ;

		ИначеЕсли СтрокаРасчета.ОбъектИсчисленияЕП > СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОПВ Тогда
			
			// найдем суммы ОПВ
			КорректировкаОПВ = СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВ;
			
			// найдем пределы
			МаксимальнаяСуммаОПВ = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОПВ * 0.1;
			
			// уменьшим платеж на разницу
			КорректировкаОПВ = КорректировкаОПВ - МаксимальнаяСуммаОПВ;
			
		КонецЕсли;
		
		Если СтрокаРасчета.СтавкаОПВР = 0 Тогда 
			
			КорректировкаОПВР = СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВР;
			
		ИначеЕсли СтрокаРасчета.ОбъектИсчисленияЕП > СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОПВ Тогда
			
			// найдем суммы ОПВР
			КорректировкаОПВР = СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВР;
			
			// найдем пределы
			МаксимальнаяСуммаОПВР = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОПВ * 0.015;
			
			// уменьшим платеж на разницу
			КорректировкаОПВР = КорректировкаОПВР - МаксимальнаяСуммаОПВР;
			
		КонецЕсли;

		Если СтрокаРасчета.СтавкаСО = 0 Тогда 
			
			// уменьшим на долю СО
			КорректировкаСО = СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляСО;
			
		ИначеЕсли СтрокаРасчета.ОбъектИсчисленияЕП > СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаСО Тогда
			
			// найдем суммы СО
			КорректировкаСО = СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляСО;
			
			// найдем пределы
			МаксимальнаяСуммаСО = СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаСО * 0.032;
			
			// уменьшим платеж на разницу
			КорректировкаСО = КорректировкаСО - МаксимальнаяСуммаСО;
			
		КонецЕсли;
		
		Если НЕ ОкончательныйРасчетЗарплаты Тогда
			// в межрасчете всегда убираем долю за счет работодателя
			КорректировкаООСМС = СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляООСМС;
			КорректировкаСО    = СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляСО;
			КорректировкаОПВР  = СтрокаРасчета.ИсчисленныйЕП * СтрокаРасчета.ДоляОПВР;
		КонецЕсли;
		
		// округлим до двух знаков, в противном случае получится погрешность при округлении (объект 159090.9 при отсутствии сумм ВОСМС и ООСМС вернет 23863.635, без округления результат будет не корректен)
		СтрокаРасчета.ИсчисленныйЕП = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаРасчета.ИсчисленныйЕП - КорректировкаООСМС - КорректировкаВОСМС - КорректировкаОПВ - КорректировкаОПВР - КорректировкаСО, ТочностьОкругления, ПравилоОкругления);
		
		// распределяем окрунленный до двух знаков ЕП, в случае распределения более двух знаков после запятой разойдемся с распределением Госкорпорации
		СтрокаРасчета.ИсчисленныйЕП = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаРасчета.ИсчисленныйЕП, ТочностьОкругления, ПравилоОкругления);
		
		Если НЕ СтрокаРасчета.СтавкаОПВ = 0 Тогда
			
			Если СтрокаРасчета.ОбъектИсчисленияЕП > СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОПВ Тогда
				СтрокаРасчета.ОПВ = МаксимальнаяСуммаОПВ;
			Иначе
				СтрокаРасчета.ОПВ = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляОПВ * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.ОПВ = 0;
		КонецЕсли;
		
		Если НЕ СтрокаРасчета.СтавкаВОСМС = 0 Тогда
			
			Если СтрокаРасчета.ОбъектИсчисленияЕП > СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОСМС Тогда
				СтрокаРасчета.ВОСМС = МаксимальнаяСуммаВОСМС;
			Иначе
				СтрокаРасчета.ВОСМС = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляВОСМС * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.ВОСМС = 0;
		КонецЕсли;
		
		Если НЕ СтрокаРасчета.СтавкаООСМС = 0 Тогда
			
			Если СтрокаРасчета.ОбъектИсчисленияЕП > СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОСМС Тогда
				СтрокаРасчета.ООСМС = МаксимальнаяСуммаООСМС;
			Иначе
				СтрокаРасчета.ООСМС = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляООСМС * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.ООСМС = 0;
		КонецЕсли;
		
		Если НЕ СтрокаРасчета.СтавкаСО = 0 Тогда
			
			Если СтрокаРасчета.ОбъектИсчисленияЕП > СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаСО Тогда
				СтрокаРасчета.СО = МаксимальнаяСуммаСО;
			Иначе
				СтрокаРасчета.СО = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляСО * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.СО = 0;
		КонецЕсли;
		
		Если НЕ СтрокаРасчета.СтавкаОПВР = 0 Тогда
			
			//СтрокаРасчета.ОПВР  = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляОПВР * 100) / 100;
			Если СтрокаРасчета.ОбъектИсчисленияЕП > СтрокаРасчета.МаксимальныйРазмерОрганиченияДоходаОПВ Тогда
				СтрокаРасчета.ОПВР = МаксимальнаяСуммаОПВР;
			Иначе
				СтрокаРасчета.ОПВР = Цел(СуммаПолногоЕП * СтрокаРасчета.ДоляОПВР * 100) / 100;
			КонецЕсли;
			
		Иначе
			СтрокаРасчета.ОПВР = 0;
		КонецЕсли;
		
		// суммы превышений пределов, на которые ранее была скорректирована сумма ЕП к перечислению
		СуммаКорректировок = КорректировкаОПВ + КорректировкаВОСМС + КорректировкаООСМС + КорректировкаСО + КорректировкаОПВР;
	
		// сумму ИПН не округляем для получения точного значения с учетом данных погрешностей далее
		СуммаИПН = СуммаПолногоЕП * СтрокаРасчета.ДоляИПН;
		
		// сумма начисленных компонент (с учетом ограничений до двух знаков МТ-102)
		СуммаКомпонентЕП = СтрокаРасчета.ОПВ + СтрокаРасчета.ВОСМС + СтрокаРасчета.ООСМС + СтрокаРасчета.СО + СтрокаРасчета.ОПВР + СуммаИПН;
		
		// сумма ИПН получим уменьшим сумму полного ЕП на размер корректировок и размер фактических компонент (компоненты с учетом пределов)
		СуммаПогрешности = СуммаПолногоЕП - СуммаКорректировок - СуммаКомпонентЕП;
		
		СтрокаРасчета.ИПН = СуммаИПН + СуммаПогрешности;
		
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияЕП,ИсчисленныйЕП,ООСМС,ВОСМС,ИПН,ОПВ,ОПВР,СО", ТочностьРаспределения);
		
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныйЕППоПодразделениям, РезультатыРасчетов);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеКомпонентыЕППоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияЕПВЦеломЗаПериод,	ИсчисленныйЕПВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектЕПИсчисленныйРанее, 		 	РанееИсчисленныйЕП,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияЕП, 				ИсчисленныйЕП,
								|ООСМС,								ВОСМС,								ОПВ,								ОПВР,	
								|СО,								ИПН");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0
			И (СтрокаТЗ.ИсчисленныйЕП < 1 И СтрокаТЗ.ИсчисленныйЕП > 0
				ИЛИ СтрокаТЗ.ИсчисленныйЕП > -1 И СтрокаТЗ.ИсчисленныйЕП < 0) Тогда
				
			СтрокаТЗ.ИсчисленныйЕП = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			// не округляем, тк возникнут погрешности между суммой ЕП и суммой компонент ЕП
			СтрокаТЗ.ИсчисленныйЕП = СтрокаТЗ.ИсчисленныйЕП;
			
		КонецЕсли;
		
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат ДанныеОРезультатахРасчетаЕПДляДокумента(РезультатыРасчетов, ОкончательныйРасчетЗарплаты);
	
КонецФункции

Функция РассчитатьЕППосле2024(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	СоздатьВТИсключаемыеЛицаЕП(МенеджерВременныхТаблиц, "ВТИтогИсключаемыеНВОФизическиеЛица", МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИтогИсключаемыеНВОФизическиеЛица");
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеЕП");
	
	ВидНалогаВзносаЕП = Перечисления.ВидыНалоговВзносовОтчислений.ЕП;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходыПосле2023(МенеджерВременныхТаблиц, ВидНалогаВзносаЕП, "ВТИсключаемыеФизическиеЛицаПриРасчетеЕП");
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ЕП
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаЕП);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	СоздатьВТРанееИсчисленныеКомпонентыЕП(Организация, ДокументСсылка, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчетЗарплаты, Истина);
	
	// Статусы доли единого платежа
	СоздатьВТДолиЕППоПериодам(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТДолиЕП");
	
	// - Исчисленные ЕП
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	0 КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 10 КАК МаксимальныйРазмерОрганиченияДоходаОСМС,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 7 КАК МаксимальныйРазмерОрганиченияДоходаСО,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 50 КАК МаксимальныйРазмерОрганиченияДоходаОПВ
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДоходаОСМС КАК МаксимальныйРазмерОрганиченияДоходаОСМС,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДоходаСО КАК МаксимальныйРазмерОрганиченияДоходаСО,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДоходаОПВ КАК МаксимальныйРазмерОрганиченияДоходаОПВ,
		|	ВЫБОР
