		|						И НакопленныеДанныеПоВычетам.ВидВычета.ПериодПредоставления = ЗНАЧЕНИЕ(Перечисление.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахКалендарногоГода))
		|						ИЛИ НакопленныеДанныеПоВычетам.ВидВычета = ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ВычетСО)
		|						ИЛИ НакопленныеДанныеПоВычетам.ВидВычета = ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ВычетОПВ)
		|						ИЛИ НакопленныеДанныеПоВычетам.ВидВычета = ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.Стандартный1МЗП)
		|						ИЛИ НакопленныеДанныеПоВычетам.ВидВычета = ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ВычетВОСМС))
        |			КОНЕЦ)
		|ГДЕ
		|	(ИсчисленныйИПНПоПодразделениям.ФизическоеЛицо ЕСТЬ NULL
		|			И (НакопленныеДанныеПоВычетам.РазрешенныйВычетВТекущемПериоде <> 0
		|			ИЛИ НакопленныеДанныеПоВычетам.ПримененныйВычетВТекущемПериоде <> 0))", "") + "
		|ИТОГИ
		|	МАКСИМУМ(ОблагаемыйДоходИсчисленныйРанее),
		|	МАКСИМУМ(НеоблагаемыйДоходИсчисленныйРанее),
		|	МАКСИМУМ(ОбъектИПНВИсчисленныйРанее),
		|	МАКСИМУМ(ИПНИсчисленныйРанее),
		|	МАКСИМУМ(ОблагаемыйДоход),
		|	МАКСИМУМ(НеоблагаемыйДоход),
		|	МАКСИМУМ(ИсчисленныйИПН),
		|	МАКСИМУМ(ОбъектИсчисленияИПН)
		|ПО
		|	ФизическоеЛицо,
		|	МесяцНалоговогоПериода,
		|	Подразделение,
		|	ВидДохода";
	
	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"ВТДоходы КАК Доходы", "ВТДоходыОбъединенная КАК Доходы");
	КонецЕсли;
	
	Результат = Запрос.ВыполнитьПакет();
	УничтожитьВТ.Добавить("ВТНакопленныеДанныеПоВычетам");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныйИПНВыборкаПоФизЛицам = Результат[ВсегоРезультатов - 1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ФизическоеЛицо");
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	ВыборкаПоФизЛицам = Результат[ВсегоРезультатов - 3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ФизическоеЛицо");
	
	НастройкиВидовВычетаПоВидамДохода = Результат[ВсегоРезультатов - 4].Выгрузить();
	НастройкиВидовВычетаПоВидамДохода.Индексы.Добавить("МесяцНалоговогоПериода");
	НастройкиВидовВычетаПоВидамДохода.Индексы.Добавить("ВидВычета");
	
	НастройкиОкругленияВычетов = Результат[ВсегоРезультатов - 5].Выгрузить(); 
	НастройкиОкругленияВычетов.Индексы.Добавить("МесяцНалоговогоПериода");
	НастройкиОкругленияВычетов.Индексы.Добавить("ВидВычета");
	
	СтруктураДанных = ПодготовитьСлужебныеДанныеДляРасчетаИПН();
	ВспомогательнаяТаблицаРасчета = СтруктураДанных.ВспомогательнаяТаблицаРасчета;
	РезультатыРасчетов = СтруктураДанных.РезультатыРасчетов;
	ИзмеренияРасчетаВычетов = СтруктураДанных.ИзмеренияРасчетаВычетов;
	РесурсыРасчетаВычетов = СтруктураДанных.РесурсыРасчетаВычетов;
	СтруктураВычетов = СтруктураДанных.СтруктураВычетов;
	СтрокаКолонокВычетов = Сред(ИзмеренияРасчетаВычетов, 2, СтрДлина(ИзмеренияРасчетаВычетов));
	
	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаИПН);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	ВычетыПримененныеВДанномРасчете = Новый Соответствие;
	ВычетыРазрешенныеВДанномРасчете = Новый Соответствие;
	Пока ВыборкаПоФизЛицам.Следующий() Цикл
		ВыборкаПоПериодам = ВыборкаПоФизЛицам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "МесяцНалоговогоПериода");
		Пока ВыборкаПоПериодам.Следующий() Цикл
			ВычетыПримененныеВДанномРасчете.Очистить();
			ВычетыРазрешенныеВДанномРасчете.Очистить();
			ВыборкаПоВидамДохода = ВыборкаПоПериодам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ВидДохода");
			Пока ВыборкаПоВидамДохода.Следующий() Цикл
				
				СтрокаРасчета = ВспомогательнаяТаблицаРасчета.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаРасчета, ВыборкаПоВидамДохода, "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода");
				ЗаполнитьЗначенияСвойств(СтрокаРасчета, СтруктураВычетов, СтрокаКолонокВычетов);
				
				ОбъектИсчисленияИПН = ВыборкаПоВидамДохода.ОблагаемыйДоходВЦеломЗаПериод;
				ВыборкаПоВидамВычетов = ВыборкаПоВидамДохода.Выбрать();
				РазрешенныйВычетВТекущемПериоде = 0;
				ПримененныйВычетВТекущемПериоде = 0;
				// ВычетОПВ, ВычетВОСМС применяем для каждого вида дохода в отдельности по исчисленной сумме в рамках вида дохода 
				Если НЕ ВычетыПримененныеВДанномРасчете.Получить(Справочники.ВидыВычетовИПН.ВычетОПВ) = Неопределено Тогда
					ВычетыПримененныеВДанномРасчете.Удалить(Справочники.ВидыВычетовИПН.ВычетОПВ);
				КонецЕсли;
				Если НЕ ВычетыПримененныеВДанномРасчете.Получить(Справочники.ВидыВычетовИПН.ВычетВОСМС) = Неопределено Тогда
					ВычетыПримененныеВДанномРасчете.Удалить(Справочники.ВидыВычетовИПН.ВычетВОСМС);
				КонецЕсли;
				Пока ВыборкаПоВидамВычетов.Следующий() Цикл
					
					Если НЕ ЗначениеЗаполнено(ВыборкаПоВидамВычетов.ВидВычета) Тогда
						// Незачем считать, если вычеты не найдены
						Продолжить;
					КонецЕсли;
					
					Если ВыборкаПоВидамВычетов.ИспользуетсяПоНесколькимВидамДохода Тогда
						
						СтруктураПоиска = Новый Структура("МесяцНалоговогоПериода, ВидВычета, ВидДохода");
						ЗаполнитьЗначенияСвойств(СтруктураПоиска, ВыборкаПоВидамВычетов);
						
						Если НастройкиВидовВычетаПоВидамДохода.НайтиСтроки(СтруктураПоиска).Количество() = 0 Тогда
							// Незачем считать, если вычеты не найдены
							Продолжить;
						КонецЕсли;
						
					КонецЕсли;
					
					// Соберем остатки за прошлые периоды в пределах года
					РазрешенныйВычетЗаПрошлыеМесяцы = ВыборкаПоВидамВычетов.РазрешенныйВычетСНачалаГода + ВыборкаПоВидамВычетов.РазрешенныйВычетСНачалаГодаПоДругимВидам;
					ПримененныйВычетЗаПрошлыеМесяцы = ВыборкаПоВидамВычетов.ПримененныйВычетСНачалаГода + ВыборкаПоВидамВычетов.ПримененныйВычетСНачалаГодаПоДругимВидам;
					ОстатокВычетаЗаПрошлыеМесяцы = РазрешенныйВычетЗаПрошлыеМесяцы - ПримененныйВычетЗаПрошлыеМесяцы;
					
					// Получим значения в текущем периоде
					Если ВыборкаПоВидамВычетов.ПредоставлениеВычета = Перечисления.ВидыПредоставленияВычетов.ПоИсчисленнойСуммеВзносов Тогда
						РазрешенныйВычетВТекущемПериоде = ВыборкаПоВидамВычетов.РазмерВычета;
					ИначеЕсли ВыборкаПоВидамВычетов.ПредоставлениеВычета = Перечисления.ВидыПредоставленияВычетов.Стандартный 
						ИЛИ ВыборкаПоВидамВычетов.ПредоставлениеВычета = Перечисления.ВидыПредоставленияВычетов.ПоПериодическимПлатежам Тогда
						Если ВыборкаПоВидамВычетов.ПределВычета > 0 Тогда
							Если ВыборкаПоВидамВычетов.ПериодПредоставления = Перечисления.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахМесяца Тогда
								РазрешенныйВычетВТекущемПериоде = Мин(ВыборкаПоВидамВычетов.СуммовойПределВычета, ВыборкаПоВидамВычетов.РазмерВычета);
							ИначеЕсли ВыборкаПоВидамВычетов.ПериодПредоставления = Перечисления.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахКалендарногоГода Тогда
								РазрешенныйВычетВТекущемПериоде = Мин(ВыборкаПоВидамВычетов.СуммовойПределВычета - РазрешенныйВычетЗаПрошлыеМесяцы, ВыборкаПоВидамВычетов.РазмерВычета);
							Иначе 
								РазрешенныйВычетВТекущемПериоде = 0;
							КонецЕсли;
						Иначе 
							РазрешенныйВычетВТекущемПериоде = ВыборкаПоВидамВычетов.РазмерВычета;
						КонецЕсли;
					Иначе
						РазрешенныйВычетВТекущемПериоде = 0;
					КонецЕсли;
					
					ПримененныйВычетВТекущемПериоде = Мин(ОбъектИсчисленияИПН, ОстатокВычетаЗаПрошлыеМесяцы + РазрешенныйВычетВТекущемПериоде 
										- ?(ВычетыПримененныеВДанномРасчете.Получить(ВыборкаПоВидамВычетов.ВидВычета) <> Неопределено, ВычетыПримененныеВДанномРасчете.Получить(ВыборкаПоВидамВычетов.ВидВычета), 0));

					// Скорректируем остаток облагаемого дохода
					ОбъектИсчисленияИПН = Макс(0, ОбъектИсчисленияИПН - ПримененныйВычетВТекущемПериоде);

					// Получим значения в текущем расчете
					РазрешенныйВычетВТекущемРасчете = РазрешенныйВычетВТекущемПериоде - ВыборкаПоВидамВычетов.РазрешенныйВычетВТекущемПериоде;
					ПримененныйВычетВТекущемРасчете = ПримененныйВычетВТекущемПериоде - ВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде;
					
					// Зафиксируем результаты по значению текущего физлица расчета
					Если ВычетыПримененныеВДанномРасчете.Получить(ВыборкаПоВидамВычетов.ВидВычета) = Неопределено Тогда
						ВычетыПримененныеВДанномРасчете.Вставить(ВыборкаПоВидамВычетов.ВидВычета, ПримененныйВычетВТекущемРасчете + ВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде);
					Иначе 
						ВычетыПримененныеВДанномРасчете[ВыборкаПоВидамВычетов.ВидВычета] = ВычетыПримененныеВДанномРасчете[ВыборкаПоВидамВычетов.ВидВычета] + ПримененныйВычетВТекущемРасчете + ВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде;
					КонецЕсли;
					
					СтрокаРасчета["ПримененныйВычет" + Строка(ВыборкаПоВидамВычетов.Приоритет)] = ПримененныйВычетВТекущемПериоде;
					СтрокаРасчета["РазрешенныйВычет" + Строка(ВыборкаПоВидамВычетов.Приоритет)] = РазрешенныйВычетВТекущемПериоде;

					СтрокаРасчета["ИспользуетсяПоНесколькимВидамДохода" + Строка(ВыборкаПоВидамВычетов.Приоритет)] = ВыборкаПоВидамВычетов.ИспользуетсяПоНесколькимВидамДохода;
					
					Если ВыборкаПоВидамВычетов.ИспользуетсяПоНесколькимВидамДохода Тогда
							
						// Зафиксируем результаты по значению текущего физлица расчета
						Если ВычетыРазрешенныеВДанномРасчете.Получить(ВыборкаПоВидамВычетов.ВидВычета) = Неопределено Тогда
							ВычетыРазрешенныеВДанномРасчете.Вставить(ВыборкаПоВидамВычетов.ВидВычета, РазрешенныйВычетВТекущемРасчете);
						Иначе 
							// добавим разрешенные вычеты других документов текущего периода с прочим видом дохода
							ВычетыРазрешенныеВДанномРасчете[ВыборкаПоВидамВычетов.ВидВычета] = ВычетыРазрешенныеВДанномРасчете[ВыборкаПоВидамВычетов.ВидВычета] + РазрешенныйВычетВТекущемРасчете;
						КонецЕсли;
					
					КонецЕсли;
					
				КонецЦикла;
				
				// применим корректировку на объект исчисления (Доходы - Вычеты), 
				// если сумма всех начислений (ВыборкаПоПериодам.ОблагаемыйДоходВЦеломЗаПериод + ВыборкаПоПериодам.НеоблагаемыйДоходВЦеломЗаПериод) не более 25 МРП
				Если ОкончательныйРасчет
					И ЗначениеЗаполнено(ВыборкаПоПериодам.МесяцНалоговогоПериода)
					И ВыборкаПоПериодам.МесяцНалоговогоПериода >= Дата(2019, 1, 1)
					И ВыборкаПоПериодам.СтатусНеРезидента = Перечисления.СтатусыФизическихЛицНалогоплательщиков.Резидент
					И (ВыборкаПоВидамДохода.ОблагаемыйДоходВЦеломЗаПериод + ВыборкаПоВидамДохода.НеоблагаемыйДоходВЦеломЗаПериод) <= ВыборкаПоПериодам.ОграничениеКорректировкиДохода25МРП
					И ВыборкаПоВидамДохода.ВидДохода = Справочники.ВидыДоходов.ДоходыОтРаботодателя
					И ОбъектИсчисленияИПН > 0 Тогда
					
					ПримененнаяКорректировка = Окр(ОбъектИсчисленияИПН * 0.9, 2, РежимОкругления.Окр15как20);
					ОбъектИсчисленияИПН = ОбъектИсчисленияИПН - ПримененнаяКорректировка;
					СтрокаРасчета.ПримененнаяЛьгота = ПримененнаяКорректировка;
					
				КонецЕсли;
				
				СтрокаРасчета.ОбъектИсчисленияИПН 	= ОбъектИсчисленияИПН;
				СтрокаРасчета.ИсчисленныйИПН 		= ОбъектИсчисленияИПН * ВыборкаПоВидамДохода.СтавкаИПН; 
		
				// сначала применим округление к сумме ИПН, после чего распределим ниже (ранее округление выполнялось после распределения, что приводило к погрешностям расчета)
				СтрокаРасчета.ИсчисленныйИПН = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаРасчета.ИсчисленныйИПН, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);

			КонецЦикла;
		КонецЦикла;
	КонецЦикла;

	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	ПоляПоискаВидаДохода = "ФизическоеЛицо, МесяцНалоговогоПериода";
	СтруктураПоискаВидаДохода = Новый Структура(ПоляПоискаВидаДохода);
	
	МесяцНалоговогоПериодаВЦикле = Неопределено;
	ПоляПоискаПоНастройкамВычетов = "МесяцНалоговогоПериода";
	СтруктураПоискаПоНастройкамВычетов = Новый Структура(ПоляПоискаПоНастройкамВычетов);

	ПоляПоискаПоНастройкамВычетов = "МесяцНалоговогоПериода";
	СтруктураПоискаПоОкруглениюВычетов = Новый Структура(ПоляПоискаПоНастройкамВычетов);

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
	
	Если ТочностьОкругления = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругления <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;
			
	Для Каждого СтрокаРасчета Из ВспомогательнаяТаблицаРасчета Цикл

		// ускорим работу цикла, если не меняется месяц начисления, нет необходимости искать по таблице НастройкиВидовВычетаПоВидамДоходаМесяца 
		Если МесяцНалоговогоПериодаВЦикле = Неопределено
			ИЛИ МесяцНалоговогоПериодаВЦикле <> СтрокаРасчета.МесяцНалоговогоПериода Тогда
			
			МесяцНалоговогоПериодаВЦикле = СтрокаРасчета.МесяцНалоговогоПериода;
			СтруктураПоискаПоНастройкамВычетов.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
			НастройкиВидовВычетаПоВидамДоходаМесяца = НастройкиВидовВычетаПоВидамДохода.Скопировать(СтруктураПоискаПоНастройкамВычетов, "ВидВычета, ВидДохода");

			НастройкиОкругленияВычетовМесяца = Новый Соответствие;
			
			СтруктураПоискаПоОкруглениюВычетов.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
			НастройкиПоОкруглениюНВОТекущегоМесяца = НастройкиОкругленияВычетов.НайтиСтроки(СтруктураПоискаПоОкруглениюВычетов);
			
			Для Каждого СтрокаВычета Из НастройкиПоОкруглениюНВОТекущегоМесяца Цикл
				
				НастройкиОкругленияВычетовМесяца.Вставить(СтрокаВычета.ВидВычета, СтрокаВычета.Точность);
				
			КонецЦикла;			
			
		КонецЕсли;

		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяцаПоПодразделениям = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		
		СтруктураПоискаВидаДохода.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоискаВидаДохода.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		ДоходыПоВидамДохода = РаспределениеДоходовПоПодразделениям.Скопировать(СтруктураПоискаВидаДохода, "ВидДохода, ОблагаемыйДоход");
		ДоходыПоВидамДохода.Свернуть("ВидДохода", "ОблагаемыйДоход");
		
		РаспределитьНалогиВзносыПоПодразделениямИВидуДохода(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяцаПоПодразделениям, ДоходыПоВидамДохода, "ОбъектИсчисленияИПН,ИсчисленныйИПН,ПримененнаяЛьгота" + РесурсыРасчетаВычетов, НастройкиВидовВычетаПоВидамДоходаМесяца, ТочностьРаспределения, НастройкиОкругленияВычетовМесяца);
		
	КонецЦикла;
	
	Пока ИсчисленныйИПНВыборкаПоФизЛицам.Следующий() Цикл
		ИсчисленныйИПНВыборкаПоПериодам = ИсчисленныйИПНВыборкаПоФизЛицам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "МесяцНалоговогоПериода");
		Пока ИсчисленныйИПНВыборкаПоПериодам.Следующий() Цикл
			ИсчисленныйИПНВыборкаПоПодразделениям = ИсчисленныйИПНВыборкаПоПериодам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Подразделение");
			Пока ИсчисленныйИПНВыборкаПоПодразделениям.Следующий() Цикл
				ИсчисленныйИПНВыборкаПоВидамДохода = ИсчисленныйИПНВыборкаПоПодразделениям.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ВидДохода");
				Пока ИсчисленныйИПНВыборкаПоВидамДохода.Следующий() Цикл
					НоваяСтрока = РезультатыРасчетов.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, ИсчисленныйИПНВыборкаПоВидамДохода);
					ЗаполнитьЗначенияСвойств(НоваяСтрока, СтруктураВычетов, СтрокаКолонокВычетов);
					ИсчисленныйИПНВыборкаПоВидамВычетов = ИсчисленныйИПНВыборкаПоВидамДохода.Выбрать();
					Пока ИсчисленныйИПНВыборкаПоВидамВычетов.Следующий() Цикл
						Если НЕ ЗначениеЗаполнено(ИсчисленныйИПНВыборкаПоВидамВычетов.ВидВычета) Тогда
							Продолжить;
						КонецЕсли;
						
						ЭтоИсправлениеСтандартногоВычета = Ложь;
						
						Если ИсчисленныйИПНВыборкаПоВидамДохода.МесяцНалоговогоПериода < МесяцНачисления
							И (ИсчисленныйИПНВыборкаПоВидамВычетов.ВидВычета = Справочники.ВидыВычетовИПН.Стандартный1МЗП
								ИЛИ ИсчисленныйИПНВыборкаПоВидамВычетов.ВидВычета = Справочники.ВидыВычетовИПН.Стандартный75МЗПИнвалиды
								ИЛИ ИсчисленныйИПНВыборкаПоВидамВычетов.ВидВычета = Справочники.ВидыВычетовИПН.Стандартный75МЗПРодители)
								И НЕ (ИсчисленныйИПНВыборкаПоВидамВычетов.ОблагаемыйДоход + ИсчисленныйИПНВыборкаПоВидамВычетов.ОблагаемыйДоходИсчисленныйРанее = 0) Тогда
							
							ЭтоИсправлениеСтандартногоВычета = Истина;
							
						КонецЕсли;	
						
						НоваяСтрока["ПримененныйВычет" + Строка(ИсчисленныйИПНВыборкаПоВидамВычетов.Приоритет)] = - ИсчисленныйИПНВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде;
						НоваяСтрока["РазрешенныйВычет" + Строка(ИсчисленныйИПНВыборкаПоВидамВычетов.Приоритет)] = ?(ЭтоИсправлениеСтандартногоВычета, 0, - ИсчисленныйИПНВыборкаПоВидамВычетов.РазрешенныйВычетВТекущемПериоде);
						
						НоваяСтрока["ПримененныйВычет" + Строка(ИсчисленныйИПНВыборкаПоВидамВычетов.Приоритет) + "ИсчисленныйРанее"] = ИсчисленныйИПНВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде;
						НоваяСтрока["РазрешенныйВычет" + Строка(ИсчисленныйИПНВыборкаПоВидамВычетов.Приоритет) + "ИсчисленныйРанее"] = ИсчисленныйИПНВыборкаПоВидамВычетов.РазрешенныйВычетВТекущемПериоде;
						
						НоваяСтрока["ПримененнаяЛьгота"] = ИсчисленныйИПНВыборкаПоВидамВычетов.ПримененнаяЛьгота;
						
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СотрудникиБезДохода.ФизическоеЛицо КАК ФизическоеЛицо,
		|	СотрудникиБезДохода.Подразделение КАК Подразделение
		|ИЗ
		|	ВТСотрудникиОрганизацииБезДохода КАК СотрудникиБезДохода";
		
		ТаблицаФизЛиц = Запрос.Выполнить().Выгрузить();
		Для каждого СтрокаТаблицы Из ТаблицаФизЛиц Цикл
			ПараметрыОтбора = Новый Структура("ФизическоеЛицо", СтрокаТаблицы.ФизическоеЛицо);
			МассивСтрок = ВспомогательнаяТаблицаРасчета.НайтиСтроки(ПараметрыОтбора);
			Для каждого Строка Из МассивСтрок Цикл
				НоваяСтрока = РезультатыРасчетов.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
				НоваяСтрока.Подразделение = СтрокаТаблицы.Подразделение;
			КонецЦикла;
		КонецЦикла;
		УничтожитьВТ.Добавить("ВТСотрудникиОрганизацииБезДохода");
		УничтожитьВТ.Добавить("ВТПериодыПоФизлицамОбъединенная");
		УничтожитьВТ.Добавить("ВТКадровыеДанныеСотрудниковПоПериодамОбъединенная");
		УничтожитьВТ.Добавить("ВТРанееИсчисленныеНалогиВзносыОбъедененная");
	КонецЕсли;
	
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0
			И НЕ ОписаниеСпособаОкругления.ПравилоОкругления = Перечисления.ПравилаОкругленияПриРасчетеЗарплаты.Авто
			И (СтрокаТЗ.ИсчисленныйИПН < 1 И СтрокаТЗ.ИсчисленныйИПН > 0
				ИЛИ СтрокаТЗ.ИсчисленныйИПН > -1 И СтрокаТЗ.ИсчисленныйИПН < 0) Тогда
				
			СтрокаТЗ.ИсчисленныйИПН = 0;
			
		КонецЕсли;

	КонецЦикла;

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода" + ИзмеренияРасчетаВычетов,
								"ОблагаемыйДоходВЦеломЗаПериод,   НеоблагаемыйДоходВЦеломЗаПериод, 	 ОбъектИсчисленияИПНВЦеломЗаПериод, ИсчисленныйИПНВЦеломЗаПериод, 
								|ОблагаемыйДоходИсчисленныйРанее, НеоблагаемыйДоходИсчисленныйРанее, ОбъектИПНИсчисленныйРанее, 		ИПНИсчисленныйРанее, 
								|ОблагаемыйДоход, 				  НеоблагаемыйДоход, 				 ОбъектИсчисленияИПН, 				ИсчисленныйИПН, 				ПримененнаяЛьгота" + РесурсыРасчетаВычетов);

	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
		СтрокаТЗ.НомерСтроки = НомерСтроки;

	КонецЦикла;

	Запрос.УстановитьПараметр("ИсчисленныеИПН", РезультатыРасчетов.Скопировать());
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаИПН.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ТаблицаИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ТаблицаИПН.ПримененнаяЛьгота КАК ПримененнаяКорректировка
		|ПОМЕСТИТЬ ВТИсчисленныйИПН
		|ИЗ
		|	&ИсчисленныеИПН КАК ТаблицаИПН";
	Запрос.Выполнить();
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьИПНПосле2026(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт

	УничтожитьВТ = Новый Массив;
	
	ВидНалогаВзносаИПН =  Перечисления.ВидыНалоговВзносовОтчислений.ИПН;
	
	// Получаем применение вычета в месяц отсутствия дохода
	ПредоставлятьВычетВМесяцеОтсутствияДохода = ЗарплатаКадрыРКПовтИсп.ПредоставлятьВычетВМесяцеОтсутствияДохода(Организация, МесяцНачисления);
	
	СоздатьВТИсключаемыеЛицаИПН(МенеджерВременныхТаблиц, МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеИПН");
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
    ПараметрыПолученияДанных = Новый Структура("Организация, ВидНалогаВзносаОтчисления, МесяцНачисления, Регистратор, ПредоставлятьВычетВМесяцеОтсутствияДохода", Организация, ВидНалогаВзносаИПН, МесяцНачисления, Регистратор, ПредоставлятьВычетВМесяцеОтсутствияДохода);
	СоздатьВТДоходыПосле2026(МенеджерВременныхТаблиц, ПараметрыПолученияДанных, "ВТИсключаемыеФизическиеЛицаПриРасчетеИПН");
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленного ИПН
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаИПН, ПредоставлятьВычетВМесяцеОтсутствияДохода);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// Таблица ВТДанныеДляРасчетаВычетовИПН
	СоздатьВТДанныеДляРасчетаВычетовИПН(МенеджерВременныхТаблиц, Организация, ПредоставлятьВычетВМесяцеОтсутствияДохода, МесяцНачисления);
	УничтожитьВТ.Добавить("ВТДанныеДляРасчетаВычетовИПН");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	
	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		Запрос.Текст ="ВЫБРАТЬ
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.НалогВзносСНачалаГода КАК НалогВзносСНачалаГода,
		|	ДоходыПоПодразделениям.ОбъектИсчисленияСНачалаГода КАК ОбъектИсчисленияСНачалаГода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ПОМЕСТИТЬ ВТДоходыОбъединенная
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТСотрудникиОрганизацииБезДохода.ФизическоеЛицо,
		|	ВТСотрудникиОрганизацииБезДохода.МесяцНалоговогоПериода,
		|	ВТСотрудникиОрганизацииБезДохода.Подразделение,
		|	ВТСотрудникиОрганизацииБезДохода.ВидДохода,
		|	0,
		|	0,
		|	ВТСотрудникиОрганизацииБезДохода.ОблагаемыйДоход,
		|	ВТСотрудникиОрганизацииБезДохода.НеоблагаемыйДоход
		|ИЗ
		|	ВТСотрудникиОрганизацииБезДохода КАК ВТСотрудникиОрганизацииБезДохода";
		Запрос.Выполнить();
		УничтожитьВТ.Добавить("ВТДоходыОбъединенная");
	КонецЕсли;
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.НеоблагаемыйДоход) КАК НеоблагаемыйДоход,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.НалогВзнос) КАК НалогВзнос,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.НалогВзносСПревышения) КАК НалогВзносСПревышения,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.ПримененнаяЛьгота) КАК ПримененнаяЛьгота,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.ОбъектИсчисления) КАК ОбъектИсчисления
		|ПОМЕСТИТЬ ВТИсчисленныеНалогиВзносы
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ВТИсчисленныеНалогиВзносыПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.ВидДохода";
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносы");
	
	// Ставки ИПН
	СоздатьВТСтавкиИПН(Организация, МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтавкиИПН");
	
	// Финальный запрос	
	Запрос.Текст = "ВЫБРАТЬ
		|	ВидыДоходов.Ссылка КАК ВидДохода,
		|	1 КАК ПриоритетВидаДохода
		|ПОМЕСТИТЬ ВТПорядокРасчетаВидовДохода
		|ИЗ
		|	Справочник.ВидыДоходов КАК ВидыДоходов
		|ГДЕ
		|	ВидыДоходов.Ссылка = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ВидыДоходов.Ссылка,
		|	2 КАК ПриоритетВидаДохода
		|ИЗ
		|	Справочник.ВидыДоходов КАК ВидыДоходов
		|ГДЕ
		|	НЕ ВидыДоходов.Ссылка = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|
		|////////////////////////////////////////////////////////////////////////////////
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НастройкиВычетовПоВидамДохода.МесяцНалоговогоПериода,
		|   НастройкиВычетовПоВидамДохода.ВидВычета,
		|   НастройкиВычетовПоВидамДохода.ВидДохода
		|ИЗ
		|	ВТНастройкиВычетовПоВидамДохода КАК НастройкиВычетовПоВидамДохода
		|
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(СтатусыФизическихЛицКакНалогоплательщиков.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)) = ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)
		|			ТОГДА ЕСТЬNULL(СтавкиИПН.СтавкаРезиденты, 0)
		|		ИНАЧЕ ЕСТЬNULL(СтавкиИПН.СтавкаНерезиденты, 0)
		|	КОНЕЦ КАК СтавкаИПН,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(СтатусыФизическихЛицКакНалогоплательщиков.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)) = ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)
		|			ТОГДА ЕСТЬNULL(СтавкиИПН.СтавкаПревышенияРезиденты, 0)
		|		ИНАЧЕ ЕСТЬNULL(СтавкиИПН.СтавкаПревышенияНерезиденты, 0)
		|	КОНЕЦ КАК СтавкаПревышениеИПН,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(СтатусыФизическихЛицКакНалогоплательщиков.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)) = ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)
		|			ТОГДА ЕСТЬNULL(СтавкиИПН.СуммаПределаСтавки, 0)
		|		ИНАЧЕ ЕСТЬNULL(СтавкиИПН.СуммаПределаСтавкиНерезидента, 0)
		|	КОНЕЦ КАК СуммаПределаСтавки,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.ОбъектИсчисленияСНачалаГода КАК ОбъектИсчисленияСНачалаГода,
		|	ДоходыПоПодразделениям.НалогВзносСНачалаГода КАК НалогВзносСНачалаГода,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиИПН КАК СтавкиИПН
		|		ПО ДоходыПоПодразделениям.МесяцНалоговогоПериода = СтавкиИПН.МесяцНалоговогоПериода
		|			И ДоходыПоПодразделениям.ВидДохода = СтавкиИПН.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтатусыФизическихЛицКакНалогоплательщиков КАК СтатусыФизическихЛицКакНалогоплательщиков
		|		ПО ДоходыПоПодразделениям.МесяцНалоговогоПериода = СтатусыФизическихЛицКакНалогоплательщиков.МесяцНалоговогоПериода
		|			И ДоходыПоПодразделениям.ФизическоеЛицо = СтатусыФизическихЛицКакНалогоплательщиков.ФизическоеЛицо
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТПорядокРасчетаВидовДохода КАК ПорядокРасчетаВидовДохода
		|		ПО ДоходыПоПодразделениям.ВидДохода = ПорядокРасчетаВидовДохода.ВидДохода
		|ГДЕ
		|	НЕ ДоходыПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ФизическоеЛицо,
		|	МесяцНалоговогоПериода,
		|	ПриоритетВидаДохода
		|ИТОГИ
		|	МАКСИМУМ(СтавкаИПН),
		|	МАКСИМУМ(СтавкаПревышениеИПН),
		|	МАКСИМУМ(СуммаПределаСтавки),
		|	СУММА(ОблагаемыйДоход),
		|	СУММА(НеоблагаемыйДоход),
		|	СУММА(ОбъектИсчисленияСНачалаГода)
		|ПО
		|	ФизическоеЛицо,
		|	МесяцНалоговогоПериода,
		|	ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДанныеДляРасчетаВычетовИПН.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДанныеДляРасчетаВычетовИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДанныеДляРасчетаВычетовИПН.Подразделение КАК Подразделение,
		|	ДанныеДляРасчетаВычетовИПН.ВидВычета КАК ВидВычета,
		|	ДанныеДляРасчетаВычетовИПН.ВидДохода КАК ВидДохода,
		|	ДанныеДляРасчетаВычетовИПН.Приоритет КАК Приоритет,
		|	ДанныеДляРасчетаВычетовИПН.ПредоставлениеВычета КАК ПредоставлениеВычета,
		|	ДанныеДляРасчетаВычетовИПН.ПериодПредоставления КАК ПериодПредоставления,
		|	ДанныеДляРасчетаВычетовИПН.РазмерВычета КАК РазмерВычета,
		|	СУММА(ДанныеДляРасчетаВычетовИПН.РВВТекущемПериоде) КАК РазрешенныйВычетВТекущемПериоде,
		|	СУММА(ДанныеДляРасчетаВычетовИПН.ПВВТекущемПериоде) КАК ПримененныйВычетВТекущемПериоде,
		|	СУММА(ДанныеДляРасчетаВычетовИПН.РВСНачалаГода) КАК РазрешенныйВычетСНачалаГода,
		|	СУММА(ДанныеДляРасчетаВычетовИПН.ПВСНачалаГода) КАК ПримененныйВычетСНачалаГода,
		|	СУММА(ДанныеДляРасчетаВычетовИПН.РВВТекущемПериодеПоДругимВидам) КАК РазрешенныйВычетВТекущемПериодеПоДругимВидам,
		|	СУММА(ДанныеДляРасчетаВычетовИПН.ПВВТекущемПериодеПоДругимВидам) КАК ПримененныйВычетВТекущемПериодеПоДругимВидам,
		|	СУММА(ДанныеДляРасчетаВычетовИПН.РВВТекущемПериодеПоДругимПодразделениям) КАК РазрешенныйВТекущемПоДругимПодразделениям,
		|	СУММА(ДанныеДляРасчетаВычетовИПН.ПВВТекущемПериодеПоДругимПодразделениям) КАК ПримененныйВТекущемПоДругимПодразделениям
		|ИЗ
		|	ВТДанныеДляРасчетаВычетовИПН КАК ДанныеДляРасчетаВычетовИПН
		|
		|СГРУППИРОВАТЬ ПО
		|	ДанныеДляРасчетаВычетовИПН.ФизическоеЛицо,
		|	ДанныеДляРасчетаВычетовИПН.МесяцНалоговогоПериода,
		|	ДанныеДляРасчетаВычетовИПН.ВидВычета,
		|	ДанныеДляРасчетаВычетовИПН.Подразделение,
		|	ДанныеДляРасчетаВычетовИПН.ВидДохода,
		|	ДанныеДляРасчетаВычетовИПН.РазмерВычета,
		|	ДанныеДляРасчетаВычетовИПН.Приоритет,
		|	ДанныеДляРасчетаВычетовИПН.ПредоставлениеВычета,
        |	ДанныеДляРасчетаВычетовИПН.ПериодПредоставления
		|
		|УПОРЯДОЧИТЬ ПО
		|	ФизическоеЛицо,
		|	МесяцНалоговогоПериода,
		|	Приоритет
		|ИТОГИ
		|ПО
		|	ФизическоеЛицо,
		|	МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныйИПНПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныйИПНПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныйИПНПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныйИПНПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныйИПНПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	-ИсчисленныйИПНПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныйИПНПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныйИПНПоПодразделениям.НалогВзнос КАК ИсчисленныйИПН,
		|	-ИсчисленныйИПНПоПодразделениям.НалогВзносСПревышения КАК ИсчисленныйИПНПревышение,
		|	-ИсчисленныйИПНПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияИПН,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетам.ВидВычета, ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ПустаяСсылка)) КАК ВидВычета,
		|	ЕСТЬNULL(ВидыВычетовИПН.ПредоставлениеВычета, ЗНАЧЕНИЕ(Перечисление.ВидыПредоставленияВычетов.ПустаяСсылка)) КАК ПредоставлениеВычета,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетам.ВидВычета.Приоритет, 0) КАК Приоритет,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетам.РазрешенныйВычетВТекущемПериоде, 0) КАК РазрешенныйВычетВТекущемПериоде,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетам.ПримененныйВычетВТекущемПериоде, 0) КАК ПримененныйВычетВТекущемПериоде
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныйИПНПоПодразделениям
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНакопленныеДанныеПоВычетам КАК НакопленныеДанныеПоВычетам
		|		ПО ИсчисленныйИПНПоПодразделениям.МесяцНалоговогоПериода = НакопленныеДанныеПоВычетам.МесяцНалоговогоПериода
		|			И ИсчисленныйИПНПоПодразделениям.ФизическоеЛицо = НакопленныеДанныеПоВычетам.ФизическоеЛицо
		|			И ИсчисленныйИПНПоПодразделениям.Подразделение = НакопленныеДанныеПоВычетам.Подразделение
		|			И ИсчисленныйИПНПоПодразделениям.ВидДохода = НакопленныеДанныеПоВычетам.ВидДохода
		|			И (ВЫБОР
		|				КОГДА ИсчисленныйИПНПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ИсчисленныйИПНПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтНалоговогоАгента)
		|						И (НакопленныеДанныеПоВычетам.ВидВычета.ПредоставлениеВычета = ЗНАЧЕНИЕ(Перечисление.ВидыПредоставленияВычетов.Стандартный)
		|							ИЛИ НакопленныеДанныеПоВычетам.ВидВычета.ПредоставлениеВычета = ЗНАЧЕНИЕ(Перечисление.ВидыПредоставленияВычетов.ПоИсчисленнойСуммеВзносов))
		|			КОНЕЦ)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыВычетовИПН КАК ВидыВычетовИПН
		|			ПО НакопленныеДанныеПоВычетам.ВидВычета = ВидыВычетовИПН.Ссылка
		|ГДЕ
		|	(ИсчисленныйИПНПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйИПНПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйИПНПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныйИПНПоПодразделениям.НалогВзнос <> 0
		|			ИЛИ НакопленныеДанныеПоВычетам.РазрешенныйВычетВТекущемПериоде <> 0
		|			ИЛИ НакопленныеДанныеПоВычетам.ПримененныйВычетВТекущемПериоде <> 0)
		|	И НЕ ИсчисленныйИПНПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|
		// учтем ситуации, когда у сотрудника не было в месяце начислений и сумма разрешенного вычета была предоставлена другим документом в месяце
		|" + ?(ПредоставлятьВычетВМесяцеОтсутствияДохода, "
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	НакопленныеДанныеПоВычетам.МесяцНалоговогоПериода,
		|	НакопленныеДанныеПоВычетам.Подразделение,
		|	НакопленныеДанныеПоВычетам.ФизическоеЛицо,
		|	НакопленныеДанныеПоВычетам.ВидДохода,
		|	0,
		|	0,
		|	0,
		|	0,
		|	0,
		|	0,
		|	НакопленныеДанныеПоВычетам.ВидВычета,
		|	ЕСТЬNULL(ВидыВычетовИПН.ПредоставлениеВычета, ЗНАЧЕНИЕ(Перечисление.ВидыПредоставленияВычетов.ПустаяСсылка)),
		|	НакопленныеДанныеПоВычетам.ВидВычета.Приоритет,
		|	НакопленныеДанныеПоВычетам.РазрешенныйВычетВТекущемПериоде,
		|	НакопленныеДанныеПоВычетам.ПримененныйВычетВТекущемПериоде
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям  КАК ИсчисленныйИПНПоПодразделениям
		|		ПРАВОЕ СОЕДИНЕНИЕ ВТНакопленныеДанныеПоВычетам КАК НакопленныеДанныеПоВычетам
		|		ПО ИсчисленныйИПНПоПодразделениям.МесяцНалоговогоПериода = НакопленныеДанныеПоВычетам.МесяцНалоговогоПериода
		|			И ИсчисленныйИПНПоПодразделениям.ФизическоеЛицо = НакопленныеДанныеПоВычетам.ФизическоеЛицо
		|			И ИсчисленныйИПНПоПодразделениям.Подразделение = НакопленныеДанныеПоВычетам.Подразделение
		|			И ИсчисленныйИПНПоПодразделениям.ВидДохода = НакопленныеДанныеПоВычетам.ВидДохода
		|			И (ВЫБОР
		|				КОГДА ИсчисленныйИПНПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ИсчисленныйИПНПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтНалоговогоАгента)
		|						И (НакопленныеДанныеПоВычетам.ВидВычета.ПредоставлениеВычета = ЗНАЧЕНИЕ(Перечисление.ВидыПредоставленияВычетов.Стандартный)
		|							ИЛИ НакопленныеДанныеПоВычетам.ВидВычета.ПредоставлениеВычета = ЗНАЧЕНИЕ(Перечисление.ВидыПредоставленияВычетов.ПоИсчисленнойСуммеВзносов))
        |			КОНЕЦ)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыВычетовИПН КАК ВидыВычетовИПН
		|			ПО НакопленныеДанныеПоВычетам.ВидВычета = ВидыВычетовИПН.Ссылка
		|ГДЕ
		|	(ИсчисленныйИПНПоПодразделениям.ФизическоеЛицо ЕСТЬ NULL
		|			И (НакопленныеДанныеПоВычетам.РазрешенныйВычетВТекущемПериоде <> 0
		|			ИЛИ НакопленныеДанныеПоВычетам.ПримененныйВычетВТекущемПериоде <> 0))", "") + "
		|ИТОГИ
		|	МАКСИМУМ(ОблагаемыйДоходИсчисленныйРанее),
		|	МАКСИМУМ(ОблагаемыйДоход),
		|	МАКСИМУМ(НеоблагаемыйДоход),
		|	МАКСИМУМ(ИсчисленныйИПН),
		|	МАКСИМУМ(ИсчисленныйИПНПревышение),
		|	МАКСИМУМ(ОбъектИсчисленияИПН)
		|ПО
		|	ФизическоеЛицо,
		|	МесяцНалоговогоПериода,
		|	Подразделение,
		|	ВидДохода
		|";
	
	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям", "ВТДоходыОбъединенная КАК ДоходыПоПодразделениям");
	КонецЕсли;
	
	Результат = Запрос.ВыполнитьПакет();
	УничтожитьВТ.Добавить("ВТНакопленныеДанныеПоВычетам");
    УничтожитьВТ.Добавить("ВТНастройкиВычетовПоВидамДохода");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныйИПНВыборкаПоФизЛицам = Результат[ВсегоРезультатов - 1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ФизическоеЛицо");
	ДанныхПериодаПоВычетам = Результат[ВсегоРезультатов - 2].Выгрузить();
	ВыборкаДанныхПериодаПоВычетам = Результат[ВсегоРезультатов - 2].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ФизическоеЛицо");
	ВыборкаПоФизЛицам = Результат[ВсегоРезультатов - 3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ФизическоеЛицо");
	
	НастройкиВидовВычетаПоВидамДохода = Результат[ВсегоРезультатов - 4].Выгрузить();
	НастройкиВидовВычетаПоВидамДохода.Индексы.Добавить("МесяцНалоговогоПериода");
	НастройкиВидовВычетаПоВидамДохода.Индексы.Добавить("ВидВычета");
	
	СтруктураДанных = ПодготовитьСлужебныеДанныеДляРасчетаИПН(МенеджерВременныхТаблиц, МесяцНачисления);
	РезультатыРасчетов = СтруктураДанных.РезультатыРасчетов;
	ИзмеренияРасчетаВычетов = СтруктураДанных.ИзмеренияРасчетаВычетов;
	РесурсыРасчетаВычетов = СтруктураДанных.РесурсыРасчетаВычетов;
	СтруктураВычетов = СтруктураДанных.СтруктураВычетов;
	СтрокаКолонокВычетов = Сред(ИзмеренияРасчетаВычетов, 2, СтрДлина(ИзмеренияРасчетаВычетов));
	
	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаИПН);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	ВычетыПримененныеВДанномРасчетеПоДругимВидам = Новый Соответствие;
	ВычетыРазрешенныеВДанномРасчетеПоДругимВидам = Новый Соответствие;
	
	ВычетыПримененныеВДанномРасчетеИсправляемыхПериодов = Новый Соответствие;
	
	СтруктураПоискаНастроекВычета = Новый Структура("МесяцНалоговогоПериода, ВидВычета");

	Пока ВыборкаПоФизЛицам.Следующий() Цикл
		
		ВыборкаПоПериодам = ВыборкаПоФизЛицам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "МесяцНалоговогоПериода");
		
		ВычетыПримененныеВДанномРасчетеИсправляемыхПериодов.Очистить();
		
		Пока ВыборкаПоПериодам.Следующий() Цикл
			
			ВыборкаПоВидамВычетов = Неопределено;
			ВычетыПримененныеВДанномРасчетеПоДругимВидам.Очистить();
			ВычетыРазрешенныеВДанномРасчетеПоДругимВидам.Очистить();
			
			ВыборкаДанныхПериодаПоВычетам.Сбросить();
			
			// получим данные вычетов по физическому лицу и периоду
			Если ВыборкаДанныхПериодаПоВычетам.НайтиСледующий(ВыборкаПоФизЛицам.ФизическоеЛицо, "ФизическоеЛицо") Тогда
				
				ВыборкаВычетовПоПериодам = ВыборкаДанныхПериодаПоВычетам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "МесяцНалоговогоПериода");	
				
				Если ВыборкаВычетовПоПериодам.НайтиСледующий(ВыборкаПоПериодам.МесяцНалоговогоПериода, "МесяцНалоговогоПериода") Тогда
					
					ВыборкаПоВидамВычетов = ВыборкаВычетовПоПериодам.Выбрать();
					
				КонецЕсли;
				
			КонецЕсли;
			
			ВыборкаПоВидамДохода = ВыборкаПоПериодам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ВидДохода");
			
			Пока ВыборкаПоВидамДохода.Следующий() Цикл
				
				ВыборкаПоПодразделениям = ВыборкаПоВидамДохода.Выбрать();
				
				Пока ВыборкаПоПодразделениям.Следующий() Цикл
					
					СтрокаРасчета = РезультатыРасчетов.Добавить();
					ЗаполнитьЗначенияСвойств(СтрокаРасчета, ВыборкаПоПодразделениям, "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода");
					ЗаполнитьЗначенияСвойств(СтрокаРасчета, СтруктураВычетов, СтрокаКолонокВычетов);
					
					// изначально примем весь облагаемый доход как объект исчисления 
					// далее в расчете объект будем уменьшать согласно расчету ИПН
					ОбъектИсчисленияИПН = ВыборкаПоПодразделениям.ОблагаемыйДоход;
									
					Если НЕ ВыборкаПоВидамВычетов = Неопределено Тогда
						
						ВыборкаПоВидамВычетов.Сбросить();
						
						Пока ВыборкаПоВидамВычетов.Следующий() Цикл
							
							Если (НЕ ВыборкаПоВидамВычетов.ВидДохода = ВыборкаПоПодразделениям.ВидДохода
								ИЛИ НЕ ВыборкаПоВидамВычетов.Подразделение = ВыборкаПоПодразделениям.Подразделение) Тогда
								Продолжить;
							КонецЕсли;

							// расчетные остатки сумм вычетов для разных ситуаций
							ОбщийОстатокВычетаЗаПрошлыеМесяцы = 0;
							ОбщийОстатокВычетаЗаТекущийПериод = 0;
							ОбщийОстатокВычетаНаМоментРасчета = 0;
							
							// переменная хранит сумму разрешеного вычета в текущем расчете (может отличаться от той суммы, которая в итоге отразится в учетном регистре через переменную СуммаРазрешенногоВычетаДляФиксацииВУчете
							РазрешенныйВычетВТекущемРасчете = 0;
							
							// переменная хранит размер суммы по рассчитываемому вычету
							РазмерВычета = 0;
							
							// переменнаые хранят суммы вычетов, которые отразятся в документе и отразятся в учетных регистрах
							СуммаРазрешенногоВычетаДляФиксацииВУчете = 0;
							СуммаПримененногоВычетаДляФиксацииВУчете = 0;
							
							ЗаполнитьЗначенияСвойств(СтруктураПоискаНастроекВычета, ВыборкаПоВидамВычетов);
							
							ИспользуетсяПоНесколькимВидамДохода = НастройкиВидовВычетаПоВидамДохода.НайтиСтроки(СтруктураПоискаНастроекВычета).Количество() > 1;
							
							// Соберем остатки за прошлые периоды в пределах года
							// ВыборкаПоВидамВычетов.РазрешенныйВычетСНачалаГода - уже включает в себя общую разрешенную сумму независимо от вида дохода
							// переменные используются для получения сумм вычетов, рассчитанных ранее в прошлых периодах
							РазрешенныйВычетЗаПрошлыеМесяцы = ВыборкаПоВидамВычетов.РазрешенныйВычетСНачалаГода;
							ПримененныйВычетЗаПрошлыеМесяцы = ВыборкаПоВидамВычетов.ПримененныйВычетСНачалаГода;
							
							// Соберем остатки за текущий период (с учетом документов межрасчета, исправления)
							// ВыборкаПоВидамВычетов.РазрешенныйВычетСНачалаГода - уже включает в себя общую разрешенную сумму независимо от вида дохода
							// переменные используются для получения сумм вычетов, рассчитанных ранее в текущем месяце
							РазрешенныйВычетВТекущемПериодеПоДругимВидам = ВыборкаПоВидамВычетов.РазрешенныйВычетВТекущемПериодеПоДругимВидам;
							ПримененныйВычетВТекущемПериодеПоДругимВидам = ВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериодеПоДругимВидам;
							РазрешенныйВТекущемПоДругимПодразделениям = ВыборкаПоВидамВычетов.РазрешенныйВТекущемПоДругимПодразделениям;
							ПримененныйВТекущемПоДругимПодразделениям = ВыборкаПоВидамВычетов.ПримененныйВТекущемПоДругимПодразделениям;
							РазрешенныйВычетВТекущемПериоде = ВыборкаПоВидамВычетов.РазрешенныйВычетВТекущемПериоде;
							ПримененныйВычетВТекущемПериоде = ВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде;
							
							// Соберем остатки текущего расчета
							// переменнаые хранят суммы вычетов ранее использованные в текущем расчете по другим видам дохода относительно рассчитываемого в данном расчете
							РазрешенныйВычетВДанномРасчетеПоДругимВидамИПодразделениям = ?(ВычетыРазрешенныеВДанномРасчетеПоДругимВидам.Получить(ВыборкаПоВидамВычетов.ВидВычета) <> Неопределено, ВычетыРазрешенныеВДанномРасчетеПоДругимВидам.Получить(ВыборкаПоВидамВычетов.ВидВычета), 0);
							ПримененныйВычетВДанномРасчетеПоДругимВидамИПодразделениям = ?(ВычетыПримененныеВДанномРасчетеПоДругимВидам.Получить(ВыборкаПоВидамВычетов.ВидВычета) <> Неопределено, ВычетыПримененныеВДанномРасчетеПоДругимВидам.Получить(ВыборкаПоВидамВычетов.ВидВычета), 0);
							
                            Если МесяцНачисления = ВыборкаВычетовПоПериодам.МесяцНалоговогоПериода Тогда
								ПримененныеВДанномРасчетеИсправляемыхПериодов = ?(ВычетыПримененныеВДанномРасчетеИсправляемыхПериодов.Получить(ВыборкаПоВидамВычетов.ВидВычета) <> Неопределено, ВычетыПримененныеВДанномРасчетеИсправляемыхПериодов.Получить(ВыборкаПоВидамВычетов.ВидВычета), 0);
							Иначе
								ПримененныеВДанномРасчетеИсправляемыхПериодов = 0;
							КонецЕсли;
							
							Если РазрешенныйВычетВТекущемПериодеПоДругимВидам = РазрешенныйВТекущемПоДругимПодразделениям Тогда
								РазрешенныйВТекущемПоДругимПодразделениям = 0;
							КонецЕсли;
							
							Если ПримененныйВычетВТекущемПериодеПоДругимВидам = ПримененныйВТекущемПоДругимПодразделениям
								ИЛИ (ПримененныйВычетВТекущемПериодеПоДругимВидам = РазрешенныйВычетВТекущемПериодеПоДругимВидам
									И ПримененныйВычетВТекущемПериодеПоДругимВидам = ВыборкаПоВидамВычетов.РазмерВычета) Тогда
								ПримененныйВТекущемПоДругимПодразделениям = 0;
							КонецЕсли;

							Если ВыборкаПоВидамВычетов.ПредоставлениеВычета = Перечисления.ВидыПредоставленияВычетов.ПоИсчисленнойСуммеВзносов
								ИЛИ НЕ ИспользуетсяПоНесколькимВидамДохода Тогда
								
								// интересует только сумма исчисленного вида дохода
								ОбщийОстатокВычетаЗаПрошлыеМесяцы = РазрешенныйВычетЗаПрошлыеМесяцы - ПримененныйВычетЗаПрошлыеМесяцы;
								ОбщийОстатокВычетаЗаТекущийПериод = РазрешенныйВычетВТекущемПериоде - ПримененныйВычетВТекущемПериоде;
								
							Иначе
								
								// маркер разрешения вычета в текущем расчете по анализу данных текущего периода
								СуммаРазрешенныхВТекущемПериодеВычетов = РазрешенныйВычетВТекущемПериоде + РазрешенныйВычетВТекущемПериодеПоДругимВидам + РазрешенныйВТекущемПоДругимПодразделениям + РазрешенныйВычетВДанномРасчетеПоДругимВидамИПодразделениям; 
								
								Если ВыборкаПоВидамВычетов.ПериодПредоставления = Перечисления.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахКалендарногоГода Тогда
									// если годовой вычет, то узнаем разрешался ли ранее
									СуммаРазрешенныхВТекущемПериодеВычетов = СуммаРазрешенныхВТекущемПериодеВычетов + РазрешенныйВычетЗаПрошлыеМесяцы;		
								КонецЕсли;
								
								// общая сумма вычета (разрешенная и примененная на разных видах дохода и подразделениях) за прошлые периоды
								ОбщийОстатокВычетаЗаПрошлыеМесяцы = РазрешенныйВычетЗаПрошлыеМесяцы - ПримененныйВычетЗаПрошлыеМесяцы - ПримененныеВДанномРасчетеИсправляемыхПериодов;
								
								// механизм исправлениения: отрицательные остатки в указанной ситуации возникают в связи с возникновением в межрасчете сумм превышающих размер вычета, которые далее сторнируются в документе окончательного расчета (
								// такие отрицательные остатки прошлого периода не должны влиять на текущий период документа
								Если НЕ ПримененныеВДанномРасчетеИсправляемыхПериодов = 0 
									И ОбщийОстатокВычетаЗаПрошлыеМесяцы < 0 Тогда
									
									ОбщийОстатокВычетаЗаПрошлыеМесяцы = 0;
									
								КонецЕсли;
								
								// интересует общая сумма вычета (разрешенная и примененная на разных видах дохода) за текущий период и текущий расчет
								ОбщийОстатокВычетаЗаТекущийПериод = РазрешенныйВычетВТекущемПериоде + РазрешенныйВычетВТекущемПериодеПоДругимВидам + РазрешенныйВТекущемПоДругимПодразделениям + РазрешенныйВычетВДанномРасчетеПоДругимВидамИПодразделениям 
																	- ПримененныйВычетВТекущемПериоде - ПримененныйВычетВТекущемПериодеПоДругимВидам - ПримененныйВТекущемПоДругимПодразделениям - ПримененныйВычетВДанномРасчетеПоДругимВидамИПодразделениям;
									
							КонецЕсли;
							
							ОбщийОстатокВычетаНаМоментРасчета = ОбщийОстатокВычетаЗаПрошлыеМесяцы + ОбщийОстатокВычетаЗаТекущийПериод; 
							
							РазмерВычета = ВыборкаПоВидамВычетов.РазмерВычета;
							
							Если ВыборкаПоВидамВычетов.ПредоставлениеВычета = Перечисления.ВидыПредоставленияВычетов.ПоИсчисленнойСуммеВзносов Тогда
								
								РазрешенныйВычетВТекущемРасчете = РазмерВычета + ОбщийОстатокВычетаЗаПрошлыеМесяцы + ОбщийОстатокВычетаЗаТекущийПериод;
								
							Иначе
								
								// из размера вычета уберем примененные по другим видам дохода суммы вычета, получившаяся сумма содержит возможную используемую сумму вычета для расчета в данном виде дохода (с учетом дельты: ранее примененная сумма + сумму остатка вычета)
								Если ВыборкаПоВидамВычетов.ПериодПредоставления = Перечисления.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахМесяца Тогда
									
									РазмерВычета = РазмерВычета + ОбщийОстатокВычетаЗаПрошлыеМесяцы;

									// ВПределахМесяца: учтем сумму переноса вычета прошлых периодов ОбщийОстатокВычетаЗаПрошлыеМесяцы
									// СуммаРазрешенныхВТекущемПериодеВычетов > 0, разрешается один раз на полную сумму, поэтому если в прошлых документах был разрешен, разрешаем на полную сумму
									РазрешенныйВычетВТекущемРасчете = ?(СуммаРазрешенныхВТекущемПериодеВычетов = 0, РазмерВычета - ПримененныйВычетВДанномРасчетеПоДругимВидамИПодразделениям, 
																		РазмерВычета - ПримененныйВычетВТекущемПериодеПоДругимВидам - ПримененныйВТекущемПоДругимПодразделениям - ПримененныйВычетВДанномРасчетеПоДругимВидамИПодразделениям);
										
								Иначе
									
									// ВПределахКалендарногоГода: для годового вычета сумма разрешается единоразово на всю сумму вычета и далее используется в течение календарного года, поэтому не используем ОбщийОстатокВычетаЗаПрошлыеМесяцы 
									РазрешенныйВычетВТекущемРасчете = ?(СуммаРазрешенныхВТекущемПериодеВычетов = 0, РазмерВычета - ПримененныйВычетВДанномРасчетеПоДругимВидамИПодразделениям, РазмерВычета - ПримененныеВДанномРасчетеИсправляемыхПериодов - ПримененныйВычетЗаПрошлыеМесяцы 
																																		- ПримененныйВычетВТекущемПериодеПоДругимВидам - ПримененныйВТекущемПоДругимПодразделениям - ПримененныйВычетВДанномРасчетеПоДругимВидамИПодразделениям);
									
								КонецЕсли;
								
							КонецЕсли;
																
							// если в текущем расчете только продолжаем применение вычета (ничего не разрешаем, то значение разрешенного вычета не фиксируем)
							Если РазрешенныйВычетВТекущемРасчете = 0 Тогда
								СуммаПримененногоВычетаДляФиксацииВУчете = 0
							Иначе
								СуммаПримененногоВычетаДляФиксацииВУчете = Мин(ОбъектИсчисленияИПН, РазрешенныйВычетВТекущемРасчете);
							КонецЕсли;
															
							// Скорректируем остаток облагаемого дохода
							ОбъектИсчисленияИПН = Макс(0, ОбъектИсчисленияИПН - СуммаПримененногоВычетаДляФиксацииВУчете);

							// фиксируем сумму разрешенного вычета по исчисленной сумме
							Если ВыборкаПоВидамВычетов.ПредоставлениеВычета = Перечисления.ВидыПредоставленияВычетов.ПоИсчисленнойСуммеВзносов Тогда
								
								СуммаРазрешенногоВычетаДляФиксацииВУчете = РазрешенныйВычетВТекущемРасчете;
								
							// фиксируем сумму разрешенного вычета один раз в налоговом периоде (далее исчерпываем, переносим)
							Иначе
								
	                            Если ВыборкаПоВидамВычетов.ПериодПредоставления = Перечисления.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахМесяца Тогда

									// если вычет был ранее в налоговом периоде разрешен на данном виде дохода, то устанавливаем ранее разрешенную (полную) сумму вычета, чтобы далее сумма свернулась
									Если НЕ РазрешенныйВычетВТекущемПериоде = 0 Тогда
										СуммаРазрешенногоВычетаДляФиксацииВУчете = РазрешенныйВычетВТекущемПериоде;
									// если вычет был ранее в налоговом периоде разрешен на другом виде дохода, то ранее разрешенная сумма была разрешена в полном размере и необходимости разрешать её на данном виде дохода нет
									ИначеЕсли НЕ РазрешенныйВычетВТекущемПериодеПоДругимВидам = 0
										ИЛИ НЕ РазрешенныйВТекущемПоДругимПодразделениям = 0 
										ИЛИ НЕ РазрешенныйВычетВДанномРасчетеПоДругимВидамИПодразделениям = 0 Тогда 
										СуммаРазрешенногоВычетаДляФиксацииВУчете = 0;
									// при межрасчетах в сведения о доходах могут быть другие виды дохода сотрудника с пустыми суммами, на таких видах доход не будем показывать разрешенную сумму
									// при окончательном расчете сумма может быть нулевая, например в ситуации с предоставлением вычета в месяце отсуствия дохода
									ИначеЕсли НЕ ОкончательныйРасчет И ВыборкаПоПодразделениям.ОблагаемыйДоход = 0 Тогда
									    СуммаРазрешенногоВычетаДляФиксацииВУчете = 0;
									Иначе
										// в переменной РазрешенныйВычетВТекущемРасчете в текущем месяце могуть быть включены остатки переноса вычета прошлых периодов, такие остатки не должны увеличивать разрешенный вычет текущего месяца
										СуммаРазрешенногоВычетаДляФиксацииВУчете = РазрешенныйВычетВТекущемРасчете - ОбщийОстатокВычетаЗаПрошлыеМесяцы;
									КонецЕсли;
									
								Иначе	
									
									// отдельно учтем ситуацию, когда сумму разрешенного вычета не нужно фиксировать в учете, если это годовой вычет и его сумма была разрешена в расчетах прошлых периодов
									// если вычет был ранее в налоговом периоде разрешен на данном виде дохода, то устанавливаем ранее разрешенную (полную) сумму вычета, чтобы далее сумма свернулась
									Если НЕ РазрешенныйВычетВТекущемПериоде = 0 Тогда
										СуммаРазрешенногоВычетаДляФиксацииВУчете = РазрешенныйВычетВТекущемПериоде;
									// РазрешенныйВычетЗаПрошлыеМесяцы = РазмерВычета если сумма будет отличаться, значит размер вычета изменился в середине года и нужно доначислить сумму разрешенного вычета
									// если вычет был ранее в прошлых месяцах разрешен, в том числе на другом виде дохода, то ранее разрешенная сумма была разрешена в полном размере и необходимости разрешать её на данном виде дохода нет
									ИначеЕсли РазрешенныйВычетЗаПрошлыеМесяцы = РазмерВычета Тогда 
										СуммаРазрешенногоВычетаДляФиксацииВУчете = 0;
									// если вычет был ранее в месяце разрешен на другом виде дохода, то ранее разрешенная сумма была разрешена в полном размере и необходимости разрешать её на данном виде дохода нет
								ИначеЕсли НЕ РазрешенныйВычетВТекущемПериодеПоДругимВидам = 0
										ИЛИ НЕ РазрешенныйВТекущемПоДругимПодразделениям = 0
										ИЛИ НЕ РазрешенныйВычетВДанномРасчетеПоДругимВидамИПодразделениям = 0
										Тогда 
										СуммаРазрешенногоВычетаДляФиксацииВУчете = 0;
									Иначе
										СуммаРазрешенногоВычетаДляФиксацииВУчете = РазрешенныйВычетВТекущемРасчете;
									КонецЕсли;
									
								КонецЕсли;
								
							КонецЕсли;
							
							СтрокаРасчета["ПримененныйВычет" + Строка(ВыборкаПоВидамВычетов.Приоритет)] = СуммаПримененногоВычетаДляФиксацииВУчете;
							СтрокаРасчета["РазрешенныйВычет" + Строка(ВыборкаПоВидамВычетов.Приоритет)] = СуммаРазрешенногоВычетаДляФиксацииВУчете;
							
							// Зафиксируем результаты по значению текущего физлица расчета, когда в одном документе рассчитываются сразу два вида дохода и вычет разрешается в этом документе
							Если ИспользуетсяПоНесколькимВидамДохода Тогда

								Если НЕ ВыборкаПоВидамВычетов.ПредоставлениеВычета = Перечисления.ВидыПредоставленияВычетов.ПоИсчисленнойСуммеВзносов Тогда

									// если расчет строки происходил ранее (например, в межрасчете), то необходимо исключить эту сумму
									// ВыборкаПоВидамВычетов.РазрешенныйВычетВТекущемПериоде > 0 если вычет был применен в межрасчете ранее не фиксируем сумму в текущем расчете (сумма содержится в переменных ВТДанныеДляРасчетаВычетовИПН)
									Если ВыборкаПоВидамВычетов.РазрешенныйВычетВТекущемПериоде > 0 Тогда
										Если ВыборкаПоВидамВычетов.РазрешенныйВычетВТекущемПериоде < СуммаРазрешенногоВычетаДляФиксацииВУчете Тогда
											// доначислим сумму
											РазницаРазрешенныйВычет = СуммаРазрешенногоВычетаДляФиксацииВУчете - ВыборкаПоВидамВычетов.РазрешенныйВычетВТекущемПериоде;
										Иначе	
											// исключим/уменьшим сумму
											РазницаРазрешенныйВычет = ВыборкаПоВидамВычетов.РазрешенныйВычетВТекущемПериоде - СуммаРазрешенногоВычетаДляФиксацииВУчете;
										КонецЕсли;
									Иначе
										РазницаРазрешенныйВычет = СуммаРазрешенногоВычетаДляФиксацииВУчете;
									КонецЕсли;
									Если ВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде > 0 Тогда
										Если ВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде < СуммаПримененногоВычетаДляФиксацииВУчете Тогда
											// доначислим сумму
											РазницаПримененныйВычет = СуммаПримененногоВычетаДляФиксацииВУчете - ВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде;
										Иначе
											// исключим/уменьшим сумму
											РазницаПримененныйВычет = ВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде - СуммаПримененногоВычетаДляФиксацииВУчете;
										КонецЕсли;
									Иначе
										РазницаПримененныйВычет = СуммаПримененногоВычетаДляФиксацииВУчете;
									КонецЕсли;
									// если вычет по расчету был впервые применен и зафиксирован в регистре (определяем по СтрокаРасчета["РазрешенныйВычет" + Строка(ВыборкаПоВидамВычетов.Приоритет)]), 
									// то документов ранее предоставивших вычет нет и будем учитывать сумму в расчете на других видах дохода
									// иначе противном случае (к примеру, Начисление по договорам -> Начисление зарплаты) сумма вычета окажется в переменной ПримененныйВычетВТекущемПериодеПоДругимВидам
									Если СуммаРазрешенногоВычетаДляФиксацииВУчете > 0 Тогда
										
										Если ВычетыПримененныеВДанномРасчетеПоДругимВидам[ВыборкаПоВидамВычетов.ВидВычета] = Неопределено Тогда
											ВычетыПримененныеВДанномРасчетеПоДругимВидам.Вставить(ВыборкаПоВидамВычетов.ВидВычета, РазницаПримененныйВычет);
										Иначе
											ВычетыПримененныеВДанномРасчетеПоДругимВидам[ВыборкаПоВидамВычетов.ВидВычета] = ВычетыПримененныеВДанномРасчетеПоДругимВидам[ВыборкаПоВидамВычетов.ВидВычета] + РазницаПримененныйВычет;
										КонецЕсли;
										
										Если МесяцНачисления > ВыборкаВычетовПоПериодам.МесяцНалоговогоПериода Тогда
										
											Если ВычетыПримененныеВДанномРасчетеИсправляемыхПериодов[ВыборкаПоВидамВычетов.ВидВычета] = Неопределено Тогда
												ВычетыПримененныеВДанномРасчетеИсправляемыхПериодов.Вставить(ВыборкаПоВидамВычетов.ВидВычета, РазницаПримененныйВычет);
											Иначе
												ВычетыПримененныеВДанномРасчетеИсправляемыхПериодов[ВыборкаПоВидамВычетов.ВидВычета] = ВычетыПримененныеВДанномРасчетеИсправляемыхПериодов[ВыборкаПоВидамВычетов.ВидВычета] + РазницаПримененныйВычет;
											КонецЕсли;
											
										КонецЕсли;
											
										Если ВычетыРазрешенныеВДанномРасчетеПоДругимВидам[ВыборкаПоВидамВычетов.ВидВычета] = Неопределено Тогда
											ВычетыРазрешенныеВДанномРасчетеПоДругимВидам.Вставить(ВыборкаПоВидамВычетов.ВидВычета, РазницаРазрешенныйВычет);
										Иначе
											ВычетыРазрешенныеВДанномРасчетеПоДругимВидам[ВыборкаПоВидамВычетов.ВидВычета] = ВычетыРазрешенныеВДанномРасчетеПоДругимВидам[ВыборкаПоВидамВычетов.ВидВычета] + РазницаРазрешенныйВычет;
										КонецЕсли;
									
									// если в данном расчете ранее разрешалась сумма вычета, значит её можно переносить по разным видам дохода	
									ИначеЕсли СуммаПримененногоВычетаДляФиксацииВУчете > 0 Тогда
										
										Если ВычетыПримененныеВДанномРасчетеПоДругимВидам[ВыборкаПоВидамВычетов.ВидВычета] = Неопределено Тогда
											ВычетыПримененныеВДанномРасчетеПоДругимВидам.Вставить(ВыборкаПоВидамВычетов.ВидВычета, РазницаПримененныйВычет)	
										Иначе
											ВычетыПримененныеВДанномРасчетеПоДругимВидам[ВыборкаПоВидамВычетов.ВидВычета] = ВычетыПримененныеВДанномРасчетеПоДругимВидам[ВыборкаПоВидамВычетов.ВидВычета] + РазницаПримененныйВычет;
										КонецЕсли;
										
										Если МесяцНачисления > ВыборкаВычетовПоПериодам.МесяцНалоговогоПериода Тогда
										
											Если ВычетыПримененныеВДанномРасчетеИсправляемыхПериодов[ВыборкаПоВидамВычетов.ВидВычета] = Неопределено Тогда
												ВычетыПримененныеВДанномРасчетеИсправляемыхПериодов.Вставить(ВыборкаПоВидамВычетов.ВидВычета, РазницаПримененныйВычет);
											Иначе
												ВычетыПримененныеВДанномРасчетеИсправляемыхПериодов[ВыборкаПоВидамВычетов.ВидВычета] = ВычетыПримененныеВДанномРасчетеИсправляемыхПериодов[ВыборкаПоВидамВычетов.ВидВычета] + РазницаПримененныйВычет;
											КонецЕсли;
											
										КонецЕсли;
											
									// если в данном расчете ранее разрешалась сумма вычета, значит её можно переносить по разным видам дохода	
									ИначеЕсли НЕ ВычетыПримененныеВДанномРасчетеПоДругимВидам.Получить(ВыборкаПоВидамВычетов.ВидВычета) = Неопределено Тогда
										
										ВычетыПримененныеВДанномРасчетеПоДругимВидам[ВыборкаПоВидамВычетов.ВидВычета] = ВычетыПримененныеВДанномРасчетеПоДругимВидам[ВыборкаПоВидамВычетов.ВидВычета] + РазницаПримененныйВычет;
										
										Если МесяцНачисления > ВыборкаВычетовПоПериодам.МесяцНалоговогоПериода Тогда
										
											Если ВычетыПримененныеВДанномРасчетеИсправляемыхПериодов[ВыборкаПоВидамВычетов.ВидВычета] = Неопределено Тогда
												ВычетыПримененныеВДанномРасчетеИсправляемыхПериодов.Вставить(ВыборкаПоВидамВычетов.ВидВычета, РазницаПримененныйВычет);
											Иначе
												ВычетыПримененныеВДанномРасчетеИсправляемыхПериодов[ВыборкаПоВидамВычетов.ВидВычета] = ВычетыПримененныеВДанномРасчетеИсправляемыхПериодов[ВыборкаПоВидамВычетов.ВидВычета] + РазницаПримененныйВычет;
											КонецЕсли;
											
										КонецЕсли;
											
										// разрешенный вычет не фиксируем, потому что суммы вычета разрашается целиком
										
									КонецЕсли;
									
								КонецЕсли;
								
							КонецЕсли;
							
						КонецЦикла;
						
					КонецЕсли;
					
					ОбщийОбъектИсчисления = ОбъектИсчисленияИПН + ВыборкаПоВидамДохода.ОбъектИсчисленияСНачалаГода;
					
					СтрокаРасчета.Подразделение	 				= ВыборкаПоПодразделениям.Подразделение;
					СтрокаРасчета.ОбъектИсчисленияИПН 			= ОбъектИсчисленияИПН;
					СтрокаРасчета.ОблагаемыйДоход 				= ВыборкаПоПодразделениям.ОблагаемыйДоход;
					СтрокаРасчета.НеоблагаемыйДоход 			= ВыборкаПоПодразделениям.НеоблагаемыйДоход;
					
					// только по ставке превышения
					Если ВыборкаПоВидамДохода.ОбъектИсчисленияСНачалаГода > ВыборкаПоПодразделениям.СуммаПределаСтавки Тогда
					
						СтрокаРасчета.ИсчисленныйИПНПревышение = ОбъектИсчисленияИПН * ВыборкаПоПодразделениям.СтавкаПревышениеИПН; 
						СтрокаРасчета.ИсчисленныйИПНПревышение = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаРасчета.ИсчисленныйИПНПревышение, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
						
					// превышение достигнуто в этом расчете	
					ИначеЕсли ОбщийОбъектИсчисления > ВыборкаПоПодразделениям.СуммаПределаСтавки
						// при отсутствии предела используем обычную ставку 
						И НЕ ВыборкаПоПодразделениям.СуммаПределаСтавки = 0 Тогда
						
						ОбъектИсчисленияИПНПоСтавкеИПН = Макс(ВыборкаПоПодразделениям.СуммаПределаСтавки - ВыборкаПоВидамДохода.ОбъектИсчисленияСНачалаГода, 0);
						ОбъектИсчисленияИПНПоСтавкеИПНПревышение = ОбъектИсчисленияИПН - ОбъектИсчисленияИПНПоСтавкеИПН;
						
						// учтем установленные настройки округления и если сумма ИПН после округления превышает 
						// максимальную сумму ИПН по первой ставке, уменьшим на погрешность округления
						МаксимальнаяСуммаИПНПоПервойСтавке = ВыборкаПоПодразделениям.СуммаПределаСтавки * ВыборкаПоПодразделениям.СтавкаИПН;
						
						ИсчисленныйИПН = ЗарплатаКадрыКлиентСервер.Округлить(ОбъектИсчисленияИПНПоСтавкеИПН * ВыборкаПоПодразделениям.СтавкаИПН, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
						
						СуммаИПНПоПервойСтавке = ВыборкаПоПодразделениям.НалогВзносСНачалаГода + ИсчисленныйИПН;
						
						// даже при установленных настройках округления сумма ИПН ограничена нормативными требованиями
						// поэтому при повторном расчёте она может получиться с сотыми долями
						Если СуммаИПНПоПервойСтавке > МаксимальнаяСуммаИПНПоПервойСтавке Тогда
							
							ИсчисленныйИПН = МаксимальнаяСуммаИПНПоПервойСтавке - ВыборкаПоПодразделениям.НалогВзносСНачалаГода;
							
						КонецЕсли;
						
						СтрокаРасчета.ИсчисленныйИПН 		   = ИсчисленныйИПН;
						СтрокаРасчета.ИсчисленныйИПНПревышение = ОбъектИсчисленияИПНПоСтавкеИПНПревышение * ВыборкаПоПодразделениям.СтавкаПревышениеИПН;
						
						// округляем только ИПН по ставке превышения, так как в ИПН без превышения достигнут предел, которые невозможно округлить
						СтрокаРасчета.ИсчисленныйИПНПревышение = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаРасчета.ИсчисленныйИПНПревышение, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
					
					// по обычной ставке, превышение не достигнуто	
					Иначе
						
						СтрокаРасчета.ИсчисленныйИПН 		= ОбъектИсчисленияИПН * ВыборкаПоПодразделениям.СтавкаИПН; 
						СтрокаРасчета.ИсчисленныйИПН 		= ЗарплатаКадрыКлиентСервер.Округлить(СтрокаРасчета.ИсчисленныйИПН, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
							
					КонецЕсли;
					
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;

    // корректируем суммы вычетов, ранее разрешенные и примененные в текущем месяце в прочих документах
	ИсчисленныйИПНВыборкаПоФизЛицам.Сбросить();

	Пока ИсчисленныйИПНВыборкаПоФизЛицам.Следующий() Цикл
		ИсчисленныйИПНВыборкаПоПериодам = ИсчисленныйИПНВыборкаПоФизЛицам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "МесяцНалоговогоПериода");
		Пока ИсчисленныйИПНВыборкаПоПериодам.Следующий() Цикл
			ИсчисленныйИПНВыборкаПоПодразделениям = ИсчисленныйИПНВыборкаПоПериодам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Подразделение");
			Пока ИсчисленныйИПНВыборкаПоПодразделениям.Следующий() Цикл
				ИсчисленныйИПНВыборкаПоВидамДохода = ИсчисленныйИПНВыборкаПоПодразделениям.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ВидДохода");
				Пока ИсчисленныйИПНВыборкаПоВидамДохода.Следующий() Цикл
					НоваяСтрока = РезультатыРасчетов.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, ИсчисленныйИПНВыборкаПоВидамДохода);
					ЗаполнитьЗначенияСвойств(НоваяСтрока, СтруктураВычетов, СтрокаКолонокВычетов);
					ИсчисленныйИПНВыборкаПоВидамВычетов = ИсчисленныйИПНВыборкаПоВидамДохода.Выбрать();
					Пока ИсчисленныйИПНВыборкаПоВидамВычетов.Следующий() Цикл
						Если НЕ ЗначениеЗаполнено(ИсчисленныйИПНВыборкаПоВидамВычетов.ВидВычета) Тогда
							Продолжить;
						КонецЕсли;
						
						//НоваяСтрока.ВидДохода = ИсчисленныйИПНВыборкаПоВидамВычетов.ВидДохода;
						
						НоваяСтрока["РазрешенныйВычет" + Строка(ИсчисленныйИПНВыборкаПоВидамВычетов.Приоритет)] = - ИсчисленныйИПНВыборкаПоВидамВычетов.РазрешенныйВычетВТекущемПериоде;
						НоваяСтрока["ПримененныйВычет" + Строка(ИсчисленныйИПНВыборкаПоВидамВычетов.Приоритет)] = - ИсчисленныйИПНВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде;
						
					КонецЦикла;
				
				КонецЦикла;
				
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;

	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		УничтожитьВТ.Добавить("ВТСотрудникиОрганизацииБезДохода");
		УничтожитьВТ.Добавить("ВТПериодыПоФизлицамОбъединенная");
		УничтожитьВТ.Добавить("ВТКадровыеДанныеСотрудниковПоПериодамОбъединенная");
		УничтожитьВТ.Добавить("ВТРанееИсчисленныеНалогиВзносыОбъедененная");
	КонецЕсли;
	
	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
	
	Если ТочностьОкругления = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругления <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;

	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0
			И НЕ ОписаниеСпособаОкругления.ПравилоОкругления = Перечисления.ПравилаОкругленияПриРасчетеЗарплаты.Авто
			И (СтрокаТЗ.ИсчисленныйИПН < 1 И СтрокаТЗ.ИсчисленныйИПН > 0
				ИЛИ СтрокаТЗ.ИсчисленныйИПН > -1 И СтрокаТЗ.ИсчисленныйИПН < 0) Тогда
				
			СтрокаТЗ.ИсчисленныйИПН = 0;
			
		КонецЕсли;
		
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0
			И НЕ ОписаниеСпособаОкругления.ПравилоОкругления = Перечисления.ПравилаОкругленияПриРасчетеЗарплаты.Авто
			И (СтрокаТЗ.ИсчисленныйИПНПревышение < 1 И СтрокаТЗ.ИсчисленныйИПНПревышение > 0
				ИЛИ СтрокаТЗ.ИсчисленныйИПНПревышение > -1 И СтрокаТЗ.ИсчисленныйИПНПревышение < 0) Тогда
				
			СтрокаТЗ.ИсчисленныйИПНПревышение = 0;
			
		КонецЕсли;

	КонецЦикла;
	
	РесурсыРасчета = "ОблагаемыйДоход, НеоблагаемыйДоход, ОбъектИсчисленияИПН, ИсчисленныйИПН, ИсчисленныйИПНПревышение" + РесурсыРасчетаВычетов;
	
	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода" + ИзмеренияРасчетаВычетов, РесурсыРасчета);
	
	МассивСтрок = Новый Массив;
	МассивРесурсов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(РесурсыРасчета, ",", Истина, Истина);

	Для Каждого СтрокаРезультата Из РезультатыРасчетов Цикл
		
		Если НЕ СтрокаРезультата["ОблагаемыйДоход"] = 0 Тогда
			
			Продолжить; 
			
		КонецЕсли;
		
		РесурсыЗаполнены = Ложь;
		
		Для Каждого Ресурс Из МассивРесурсов Цикл
			
			Если НЕ СтрокаРезультата[Ресурс] = 0 Тогда
				
				РесурсыЗаполнены = Истина;
				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
		Если НЕ РесурсыЗаполнены Тогда
			МассивСтрок.Добавить(СтрокаРезультата);	
		КонецЕсли;
		
	КонецЦикла;
		
	Для Каждого СтрокаРезультата Из МассивСтрок Цикл
	    РезультатыРасчетов.Удалить(СтрокаРезультата);
	КонецЦикла;	

	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
		СтрокаТЗ.НомерСтроки = НомерСтроки;

	КонецЦикла;

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьСОДо2019(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("КонецМесяцаРасчета",КонецМесяца(МесяцНачисления));
	
	// Исключаемые лица
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СведенияОПенсионномОбеспеченииФизическихЛиц.ФизическоеЛицо
		|ПОМЕСТИТЬ ВТИсключаемыеФизическиеЛицаПриРасчетеСО
		|ИЗ
		|	РегистрСведений.СведенияОПенсионномОбеспеченииФизическихЛиц.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОПенсионномОбеспеченииФизическихЛиц
		|ГДЕ
		|	СведенияОПенсионномОбеспеченииФизическихЛиц.ПенсионерПоВозрасту
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо
		|ИЗ
		|	РегистрСведений.СтатусФизическихЛицКакНалогоплательщиков.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СтатусФизическихЛицКакНалогоплательщиков
		|ГДЕ
		|	НЕ СтатусФизическихЛицКакНалогоплательщиков.ПодлежитСоциальномуСтрахованию";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеСО");
	
	ВидНалогаВзносаСО =  Перечисления.ВидыНалоговВзносовОтчислений.СО;
	
	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаСО);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаСО, "ВТИсключаемыеФизическиеЛицаПриРасчетеСО");
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных СО
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаСО);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// - Размер ограничения доходов, облагаемых СО, по периодам
	// - Исчисленные СО
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 10 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) КАК ИсчисленныеОПВ,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0)
		|	КОНЕЦ КАК ОбъектИсчисленияСО,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0)
		|	КОНЕЦ * ЕСТЬNULL(СтавкиСО.Ставка, 0) КАК ИсчисленныеСО
		|ПОМЕСТИТЬ ВТИсчисленныеСОВЦеломЗаПериод
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиСО
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиСО.МесяцНалоговогоПериода
		|			И (СтавкиСО.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.СО))
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеОПВ КАК ИсчисленныеОПВПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеОПВПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеОПВПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеОПВПоПериодам.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеСО.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеСО.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеСО.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеСО.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	ВТИсчисленныеСО.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ВТИсчисленныеСО.ИсчисленныеОПВ КАК ИсчисленныеОПВ,
		|	ВТИсчисленныеСО.ОбъектИсчисленияСО КАК ОбъектИсчисленияСО,
		|	ВТИсчисленныеСО.ИсчисленныеСО КАК ИсчисленныеСО
		|ИЗ
		|	ВТИсчисленныеСОВЦеломЗаПериод КАК ВТИсчисленныеСО
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеСОПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеСОПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеСОПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеСОПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеСОПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеСОПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеСОПоПодразделениям.ОбъектИсчисления КАК ОбъектСОИсчисленныйРанее,
		|	ИсчисленныеСОПоПодразделениям.НалогВзнос КАК РанееИсчисленныеСО,
		|	-ИсчисленныеСОПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеСОПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеСОПоПодразделениям.НалогВзнос КАК ИсчисленныеСО,
		|	-ИсчисленныеСОПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияСО
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеСОПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеСОПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеСОПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеСОПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеСОПоПодразделениям.НалогВзнос <> 0)";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТИсчисленныеСОВЦеломЗаПериод");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеСОПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	РезультатЗапроса.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатЗапроса.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатЗапроса.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатЗапроса.Колонки.Добавить("МинимальныйРазмерОрганиченияДохода", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("МаксимальныйРазмерОрганиченияДохода", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ОбъектИсчисленияСО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИсчисленныеСО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(Результат[ВсегоРезультатов - 3].Выгрузить(), РезультатЗапроса);
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеСОВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияСОВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектСОИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеСО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияСО,ИсчисленныеСО");
	КонецЦикла;
	
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		СтрокаТЗ.ИсчисленныеСО = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеСО, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
	КонецЦикла; 

	Запрос.УстановитьПараметр("ИсчисленныеСО", РезультатыРасчетов.Скопировать());	
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеСОПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияСОВЦеломЗаПериод, 	ИсчисленныеСОВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектСОИсчисленныйРанее, 			РанееИсчисленныеСО,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияСО, 				ИсчисленныеСО");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
	КонецЦикла; 

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаСО.МесяцНалоговогоПериода,
		|	ТаблицаСО.ФизическоеЛицо,
		|	ТаблицаСО.Подразделение,
		|	ТаблицаСО.ВидДохода,
		|	ТаблицаСО.ОбъектИсчисленияСО,
		|	ТаблицаСО.ИсчисленныеСО
		|ПОМЕСТИТЬ ВТИсчисленныеСОПоПодразделениям
		|ИЗ
		|	&ИсчисленныеСО КАК ТаблицаСО
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеСОПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеСОПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеСОПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеСОПоПодразделениям.ОбъектИсчисленияСО) КАК ОбъектИсчисленияСО,
		|	СУММА(ВТИсчисленныеСОПоПодразделениям.ИсчисленныеСО) КАК ИсчисленныеСО
		|ПОМЕСТИТЬ ВТИсчисленныеСО
		|ИЗ
		|	ВТИсчисленныеСОПоПодразделениям КАК ВТИсчисленныеСОПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеСОПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеСОПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеСОПоПодразделениям.ВидДохода";
		
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеСОПоПодразделениям");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьСОПосле2019(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("КонецМесяцаРасчета",КонецМесяца(МесяцНачисления));
	
	// Исключаемые лица
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СведенияОПенсионномОбеспеченииФизическихЛиц.ФизическоеЛицо
		|ПОМЕСТИТЬ ВТИсключаемыеФизическиеЛицаПриРасчетеСО
		|ИЗ
		|	РегистрСведений.СведенияОПенсионномОбеспеченииФизическихЛиц.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОПенсионномОбеспеченииФизическихЛиц
		|ГДЕ
		|	СведенияОПенсионномОбеспеченииФизическихЛиц.ПенсионерПоВозрасту
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо
		|ИЗ
		|	РегистрСведений.СтатусФизическихЛицКакНалогоплательщиков.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СтатусФизическихЛицКакНалогоплательщиков
		|ГДЕ
		|	НЕ СтатусФизическихЛицКакНалогоплательщиков.ПодлежитСоциальномуСтрахованию";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеСО");
	
	ВидНалогаВзносаСО =  Перечисления.ВидыНалоговВзносовОтчислений.СО;
	
	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаСО);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаСО, "ВТИсключаемыеФизическиеЛицаПриРасчетеСО");
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных СО
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаСО);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	// - Размер ограничения доходов, облагаемых СО, по периодам
	// - Исчисленные СО
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 7 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) КАК ИсчисленныеОПВ,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0)
		|	КОНЕЦ КАК ОбъектИсчисленияСО,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0)
		|	КОНЕЦ * ЕСТЬNULL(СтавкиСО.Ставка, 0) КАК ИсчисленныеСО
		|ПОМЕСТИТЬ ВТИсчисленныеСОВЦеломЗаПериод
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиСО
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиСО.МесяцНалоговогоПериода
		|			И (СтавкиСО.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.СО))
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеОПВ КАК ИсчисленныеОПВПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеОПВПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеОПВПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеОПВПоПериодам.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеСО.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеСО.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеСО.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеСО.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	ВТИсчисленныеСО.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ВТИсчисленныеСО.ИсчисленныеОПВ КАК ИсчисленныеОПВ,
		|	ВТИсчисленныеСО.ОбъектИсчисленияСО КАК ОбъектИсчисленияСО,
		|	ВТИсчисленныеСО.ИсчисленныеСО КАК ИсчисленныеСО
		|ИЗ
		|	ВТИсчисленныеСОВЦеломЗаПериод КАК ВТИсчисленныеСО
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеСОПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеСОПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеСОПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеСОПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеСОПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеСОПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеСОПоПодразделениям.ОбъектИсчисления КАК ОбъектСОИсчисленныйРанее,
		|	ИсчисленныеСОПоПодразделениям.НалогВзнос КАК РанееИсчисленныеСО,
		|	-ИсчисленныеСОПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеСОПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеСОПоПодразделениям.НалогВзнос КАК ИсчисленныеСО,
		|	-ИсчисленныеСОПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияСО
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеСОПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеСОПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеСОПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеСОПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеСОПоПодразделениям.НалогВзнос <> 0)";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТИсчисленныеСОВЦеломЗаПериод");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеСОПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	РезультатЗапроса.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатЗапроса.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатЗапроса.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатЗапроса.Колонки.Добавить("МинимальныйРазмерОрганиченияДохода", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("МаксимальныйРазмерОрганиченияДохода", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ОбъектИсчисленияСО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИсчисленныеСО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(Результат[ВсегоРезультатов - 3].Выгрузить(), РезультатЗапроса);
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеСОВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияСОВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектСОИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеСО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
	
	Если ТочностьОкругления = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругления <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;
			
	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияСО,ИсчисленныеСО", ТочностьРаспределения);
	КонецЦикла;
	
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		СтрокаТЗ.ИсчисленныеСО = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеСО, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
	КонецЦикла; 

	Запрос.УстановитьПараметр("ИсчисленныеСО", РезультатыРасчетов.Скопировать());	
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеСОПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияСОВЦеломЗаПериод, 	ИсчисленныеСОВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектСОИсчисленныйРанее, 			РанееИсчисленныеСО,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияСО, 				ИсчисленныеСО");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
	КонецЦикла; 

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаСО.МесяцНалоговогоПериода,
		|	ТаблицаСО.ФизическоеЛицо,
		|	ТаблицаСО.Подразделение,
		|	ТаблицаСО.ВидДохода,
		|	ТаблицаСО.ОбъектИсчисленияСО,
		|	ТаблицаСО.ИсчисленныеСО
		|ПОМЕСТИТЬ ВТИсчисленныеСОПоПодразделениям
		|ИЗ
		|	&ИсчисленныеСО КАК ТаблицаСО
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеСОПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеСОПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеСОПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеСОПоПодразделениям.ОбъектИсчисленияСО) КАК ОбъектИсчисленияСО,
		|	СУММА(ВТИсчисленныеСОПоПодразделениям.ИсчисленныеСО) КАК ИсчисленныеСО
		|ПОМЕСТИТЬ ВТИсчисленныеСО
		|ИЗ
		|	ВТИсчисленныеСОПоПодразделениям КАК ВТИсчисленныеСОПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеСОПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеСОПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеСОПоПодразделениям.ВидДохода";
		
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеСОПоПодразделениям");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьСОПосле2021(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("КонецМесяцаРасчета",КонецМесяца(МесяцНачисления));
	
	// Исключаемые лица
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СведенияОПенсионномОбеспеченииФизическихЛиц.ФизическоеЛицо
		|ПОМЕСТИТЬ ВТИсключаемыеФизическиеЛицаПриРасчетеСО
		|ИЗ
		|	РегистрСведений.СведенияОПенсионномОбеспеченииФизическихЛиц.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОПенсионномОбеспеченииФизическихЛиц
		|ГДЕ
		|	СведенияОПенсионномОбеспеченииФизическихЛиц.ПенсионерПоВозрасту
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо
		|ИЗ
		|	РегистрСведений.СтатусФизическихЛицКакНалогоплательщиков.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СтатусФизическихЛицКакНалогоплательщиков
		|ГДЕ
