    УничтожитьВТ.Добавить("ВТНастройкиИРазмерыВычетовПоПодразделениям");
    УничтожитьВТ.Добавить("ВТНакопленныеДанныеПоВычетамСНачалаГода");
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НастройкиИРегламентированнныеРазмерыВычетов.МесяцНалоговогоПериода,
		|	НастройкиИРегламентированнныеРазмерыВычетов.ФизическоеЛицо,
		|	НастройкиИРегламентированнныеРазмерыВычетов.ВидВычета,
		|	НастройкиИРегламентированнныеРазмерыВычетов.Приоритет,
		|	НастройкиИРегламентированнныеРазмерыВычетов.ПределВычета,
		|	НастройкиИРегламентированнныеРазмерыВычетов.СуммовойПределВычета КАК СуммовойПределВычета,
		|	НастройкиИРегламентированнныеРазмерыВычетов.ПредоставлениеВычета,
		|	НастройкиИРегламентированнныеРазмерыВычетов.ПериодПредоставления,
		|	НастройкиИРегламентированнныеРазмерыВычетов.ВидДоходаВычета КАК ВидДохода,
        |	НастройкиИРегламентированнныеРазмерыВычетов.Подразделение КАК Подразделение,
		|	ВЫБОР
		|		КОГДА РазмерыВзносовВТекущемРасчете.Подразделение ЕСТЬ NULL
		|			ТОГДА НастройкиИРегламентированнныеРазмерыВычетов.РазмерВычета
		|		ИНАЧЕ ВЫБОР
		|				КОГДА НастройкиИРегламентированнныеРазмерыВычетов.СтатусРезидентства = ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)
		|					ТОГДА ЕСТЬNULL(РазмерыВзносовВТекущемРасчете.СуммаВзносов, 0)
		|				ИНАЧЕ 0
		|			КОНЕЦ
		|	КОНЕЦ КАК РазмерВычета,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетамДругимиДокументами.РазрешенныйВычетВТекущемПериоде, 0) КАК РВВТекущемПериоде,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетамДругимиДокументами.ПримененныйВычетВТекущемПериоде, 0) КАК ПВВТекущемПериоде,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетамПоДругимВидамДохода.РазрешенныйВТекущемПоДругимВидам, 0) КАК РВВТекущемПериодеПоДругимВидам,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетамПоДругимВидамДохода.ПримененныйВТекущемПоДругимВидам, 0) КАК ПВВТекущемПериодеПоДругимВидам,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетамПоДругимПодразделениям.РазрешенныйВТекущемПоДругимПодразделениям, 0) КАК РВВТекущемПериодеПоДругимПодразделениям,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетамПоДругимПодразделениям.ПримененныйВТекущемПоДругимПодразделениям, 0) КАК ПВВТекущемПериодеПоДругимПодразделениям,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетамСНачалаГода.РазрешенныйВычетСНачалаГода, 0) КАК РВСНачалаГода,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетамСНачалаГода.ПримененныйВычетСНачалаГода, 0) + ЕСТЬNULL(ВычетыПримененныеУДругогоРаботодателя.ПримененныйВычетСНачалаГода, 0) КАК ПВСНачалаГода,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетамСНачалаГода.РазрешенныйВычетСНачалаГодаОтОбратного, 0) КАК РазрешенныйВычетСНачалаГодаОтОбратного,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетамСНачалаГода.ПримененныйВычетСНачалаГодаОтОбратного, 0) + ЕСТЬNULL(ВычетыПримененныеУДругогоРаботодателя.ПримененныйВычетСНачалаГода, 0) КАК ПримененныйВычетСНачалаГодаОтОбратного
		|ПОМЕСТИТЬ ВТДанныеДляРасчетаВычетовИПН
		|ИЗ
		|	ВТНастройкиИРазмерыВычетовПоВидамДоходаИПодразделениям КАК НастройкиИРегламентированнныеРазмерыВычетов
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыВзносовВТекущемРасчете КАК РазмерыВзносовВТекущемРасчете
		|		ПО НастройкиИРегламентированнныеРазмерыВычетов.МесяцНалоговогоПериода = РазмерыВзносовВТекущемРасчете.МесяцНалоговогоПериода
		|			И НастройкиИРегламентированнныеРазмерыВычетов.ФизическоеЛицо = РазмерыВзносовВТекущемРасчете.ФизическоеЛицо
		|			И НастройкиИРегламентированнныеРазмерыВычетов.ВидДоходаВычета = РазмерыВзносовВТекущемРасчете.ВидДохода
		|			И НастройкиИРегламентированнныеРазмерыВычетов.ВидВзносов = РазмерыВзносовВТекущемРасчете.ВидВзносов
		|			И НастройкиИРегламентированнныеРазмерыВычетов.Подразделение = РазмерыВзносовВТекущемРасчете.Подразделение
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНакопленныеДанныеПоВычетам КАК НакопленныеДанныеПоВычетамДругимиДокументами
		|		ПО НастройкиИРегламентированнныеРазмерыВычетов.МесяцНалоговогоПериода = НакопленныеДанныеПоВычетамДругимиДокументами.МесяцНалоговогоПериода
		|			И НастройкиИРегламентированнныеРазмерыВычетов.ФизическоеЛицо = НакопленныеДанныеПоВычетамДругимиДокументами.ФизическоеЛицо
		|			И НастройкиИРегламентированнныеРазмерыВычетов.ВидВычета = НакопленныеДанныеПоВычетамДругимиДокументами.ВидВычета
		|			И НастройкиИРегламентированнныеРазмерыВычетов.ВидДоходаВычета = НакопленныеДанныеПоВычетамДругимиДокументами.ВидДохода
		|			И НастройкиИРегламентированнныеРазмерыВычетов.Подразделение = НакопленныеДанныеПоВычетамДругимиДокументами.Подразделение
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНакопленныеДанныеПоВычетамПоДругимПодразделениям КАК НакопленныеДанныеПоВычетамПоДругимПодразделениям
		|		ПО НастройкиИРегламентированнныеРазмерыВычетов.МесяцНалоговогоПериода = НакопленныеДанныеПоВычетамПоДругимПодразделениям.МесяцНалоговогоПериода
		|			И НастройкиИРегламентированнныеРазмерыВычетов.ФизическоеЛицо = НакопленныеДанныеПоВычетамПоДругимПодразделениям.ФизическоеЛицо
		|			И НастройкиИРегламентированнныеРазмерыВычетов.ВидВычета = НакопленныеДанныеПоВычетамПоДругимПодразделениям.ВидВычета
		|			И НастройкиИРегламентированнныеРазмерыВычетов.Подразделение = НакопленныеДанныеПоВычетамПоДругимПодразделениям.Подразделение
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНакопленныеДанныеПоВычетамПоДругимВидамДохода КАК НакопленныеДанныеПоВычетамПоДругимВидамДохода
		|		ПО НастройкиИРегламентированнныеРазмерыВычетов.МесяцНалоговогоПериода = НакопленныеДанныеПоВычетамПоДругимВидамДохода.МесяцНалоговогоПериода
		|			И НастройкиИРегламентированнныеРазмерыВычетов.ФизическоеЛицо = НакопленныеДанныеПоВычетамПоДругимВидамДохода.ФизическоеЛицо
		|			И НастройкиИРегламентированнныеРазмерыВычетов.ВидВычета = НакопленныеДанныеПоВычетамПоДругимВидамДохода.ВидВычета
		|			И НастройкиИРегламентированнныеРазмерыВычетов.ВидДоходаВычета = НакопленныеДанныеПоВычетамПоДругимВидамДохода.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНакопленныеДанныеПоВычетамСНачалаГода КАК НакопленныеДанныеПоВычетамСНачалаГода
		|		ПО НастройкиИРегламентированнныеРазмерыВычетов.МесяцНалоговогоПериода = НакопленныеДанныеПоВычетамСНачалаГода.МесяцНалоговогоПериода
		|			И НастройкиИРегламентированнныеРазмерыВычетов.ФизическоеЛицо = НакопленныеДанныеПоВычетамСНачалаГода.ФизическоеЛицо
		|			И НастройкиИРегламентированнныеРазмерыВычетов.ВидВычета = НакопленныеДанныеПоВычетамСНачалаГода.ВидВычета
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТВычетыПримененныеУДругогоРаботодателя КАК ВычетыПримененныеУДругогоРаботодателя
		|		ПО НастройкиИРегламентированнныеРазмерыВычетов.МесяцНалоговогоПериода = ВычетыПримененныеУДругогоРаботодателя.МесяцНалоговогоПериода
		|			И НастройкиИРегламентированнныеРазмерыВычетов.ФизическоеЛицо = ВычетыПримененныеУДругогоРаботодателя.ФизическоеЛицо
		|			И НастройкиИРегламентированнныеРазмерыВычетов.ВидДоходаВычета = ВычетыПримененныеУДругогоРаботодателя.ВидВычета
		|
		|";
		
	Запрос.Выполнить();

	УничтожитьВТ.Добавить("ВТИсчисленныеОПВПоПодразделениям");
	УничтожитьВТ.Добавить("ВТИсчисленныеВОСМСПоПодразделениям");
	УничтожитьВТ.Добавить("ВТИсчисленныеСОПоПодразделениям");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);

КонецПроцедуры

Процедура СоздатьВТДанныеДляРасчетаВычетовИПНПосле2025(МенеджерВременныхТаблиц, Организация, ПредоставлятьВычетВМесяцеОтсутствияДохода = Ложь, МесяцНачисления) Экспорт
    
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("НачалоПериода", МесяцНачисления);
	Запрос.УстановитьПараметр("КонецПериода", КонецМесяца(МесяцНачисления));
	
	Если НЕ ВТСуществует(МенеджерВременныхТаблиц, "ВТИсчисленныеОПВ") Тогда
		Запрос.Текст =
			"ВЫБРАТЬ
			|	NULL КАК МесяцНалоговогоПериода,
			|	NULL КАК ФизическоеЛицо,
			|	NULL КАК ВидДохода,
			|	0 КАК ИсчисленныеОПВ
			|ПОМЕСТИТЬ ВТИсчисленныеОПВ";
		Запрос.Выполнить();
	КонецЕсли;
	
    Если НЕ ВТСуществует(МенеджерВременныхТаблиц, "ВТИсчисленныеВОСМС") Тогда
    	Запрос.Текст =
    		"ВЫБРАТЬ
    		|	NULL КАК МесяцНалоговогоПериода,
    		|	NULL КАК ФизическоеЛицо,
    		|	NULL КАК ВидДохода,
    		|	0 КАК ИсчисленныеВОСМС
    		|ПОМЕСТИТЬ ВТИсчисленныеВОСМС";
    	Запрос.Выполнить();
    КонецЕсли;

	Если НЕ ВТСуществует(МенеджерВременныхТаблиц, "ВТИсчисленныеСО") Тогда
        // в межрасчете (где СО не рассчитывается) при наличии в месяце данных сумм ГПХ необходимо получать сумму вычета СО по ГПХ для дельты расчета 
		Запрос.Текст =
			"ВЫБРАТЬ
			|	СведенияОбИсчисленииВычетовИПН.ПериодРегистрации КАК МесяцНалоговогоПериода,
			|	СведенияОбИсчисленииВычетовИПН.ФизическоеЛицо КАК ФизическоеЛицо,
			|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтНалоговогоАгента) КАК ВидДохода,
			|	СведенияОбИсчисленииВычетовИПН.ПримененныйВычетОборот КАК ИсчисленныеСО
			|ПОМЕСТИТЬ ВТИсчисленныеСО
			|ИЗ
			|	РегистрНакопления.СведенияОбИсчисленииВычетовИПН.Обороты(
			|			&НачалоПериода,
			|			&КонецПериода,
			|			,
			|			&Организация = &Организация
			|				И ВидВычета = ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ВычетСО)
			|				И ФизическоеЛицо В
			|					(ВЫБРАТЬ
			|						ВТФизическиеЛица.ФизическоеЛицо
			|					ИЗ
			|						ВТФизическиеЛица)) КАК СведенияОбИсчисленииВычетовИПН";
    	Запрос.Выполнить();
		// учтем вызов "от обратного" в документе окончательного расчета при наличии в месяце данных сумм ГПХ
		УничтожитьВТ.Добавить("ВТИсчисленныеСО");
	КонецЕсли;
	
	// Применение вычетов ИПН
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(ПрименениеВычетовИПН.Период) КАК Период,
		|	ПрименениеВычетовИПН.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода
		|ПОМЕСТИТЬ ВТПериодыПримененияВычетов
		|ИЗ
		|	ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПрименениеВычетовИПН КАК ПрименениеВычетовИПН
		|		ПО ПериодыПоФизлицам.МесяцНалоговогоПериода >= ПрименениеВычетовИПН.Период
		|			И ПериодыПоФизлицам.ФизическоеЛицо = ПрименениеВычетовИПН.ФизическоеЛицо
		|			И (ПрименениеВычетовИПН.Активность)
		|
		|СГРУППИРОВАТЬ ПО
		|	ПрименениеВычетовИПН.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТПериодыПримененияВычетов.ФизическоеЛицо,
		|	ВТПериодыПримененияВычетов.МесяцНалоговогоПериода,
		|	ПрименениеВычетовИПН.Организация
		|ПОМЕСТИТЬ ВТПрименениеВычетовИПН
		|ИЗ
		|	ВТПериодыПримененияВычетов КАК ВТПериодыПримененияВычетов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПрименениеВычетовИПН КАК ПрименениеВычетовИПН
		|		ПО ВТПериодыПримененияВычетов.Период = ПрименениеВычетовИПН.Период
		|			И ВТПериодыПримененияВычетов.ФизическоеЛицо = ПрименениеВычетовИПН.ФизическоеЛицо
		|			И (ПрименениеВычетовИПН.Активность)
		|ГДЕ
		|	ПрименениеВычетовИПН.Организация = &Организация";
	
	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"ВТПериодыПоФизлицам КАК ПериодыПоФизлицам","ВТПериодыПоФизлицамОбъединенная КАК ПериодыПоФизлицам");
	КонецЕсли;
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТПериодыПримененияВычетов");
	УничтожитьВТ.Добавить("ВТПрименениеВычетовИПН");
	
	// Назначенные вычеты ИПН
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(ВычетыФизическихЛицИПН.Период) КАК Период,
		|	ВычетыФизическихЛицИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВычетыФизическихЛицИПН.ВидВычета КАК ВидВычета,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода
		|ПОМЕСТИТЬ ВТПериодыВычетовИПН
		|ИЗ
		|	ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ВычетыФизическихЛицИПН КАК ВычетыФизическихЛицИПН
		|		ПО ПериодыПоФизлицам.МесяцНалоговогоПериода >= ВычетыФизическихЛицИПН.Период
		|			И ПериодыПоФизлицам.ФизическоеЛицо = ВычетыФизическихЛицИПН.ФизическоеЛицо
		|			И (ВычетыФизическихЛицИПН.Активность)
		|ГДЕ
		|	ВычетыФизическихЛицИПН.ВидВычета <> ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ВычетОПВ)
		|	И ВычетыФизическихЛицИПН.ВидВычета <> ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ВычетВОСМС)
		|	И ВычетыФизическихЛицИПН.ВидВычета <> ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ВычетСО)
		|
