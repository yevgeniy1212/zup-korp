		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОПенсионномОбеспеченииФизическихЛиц
		|ГДЕ
		|	(СведенияОПенсионномОбеспеченииФизическихЛиц.ПенсионерПоВозрасту
		|			ИЛИ СведенияОПенсионномОбеспеченииФизическихЛиц.ПенсионерПоВыслугеЛет)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СведенияОбИнвалидностиФизическихЛицСрезПоследних.ФизическоеЛицо,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка) КАК ВидДохода
		|ИЗ
		|	РегистрСведений.СведенияОбИнвалидностиФизическихЛиц.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОбИнвалидностиФизическихЛицСрезПоследних
		|ГДЕ
		|	СведенияОбИнвалидностиФизическихЛицСрезПоследних.ОтношениеКИнвалидности = ЗНАЧЕНИЕ(Перечисление.ОтношениеКИнвалидности.Инвалид)
		|	И СведенияОбИнвалидностиФизическихЛицСрезПоследних.ГруппаИнвалидности В (ЗНАЧЕНИЕ(Перечисление.ГруппыИнвалидности.Первая), ЗНАЧЕНИЕ(Перечисление.ГруппыИнвалидности.Вторая))
		|	И СведенияОбИнвалидностиФизическихЛицСрезПоследних.ДействуетДо = ДАТАВРЕМЯ(1, 1, 1)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка) КАК ВидДохода
		|ИЗ
		|	РегистрСведений.СтатусФизическихЛицКакНалогоплательщиков.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СтатусФизическихЛицКакНалогоплательщиков
		|ГДЕ
		|	НЕ СтатусФизическихЛицКакНалогоплательщиков.ИмеетПравоНаПенсионноеОбеспечение
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ФизическиеЛица.Ссылка,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка) КАК ВидДохода
		|ИЗ
		|	Справочник.ФизическиеЛица КАК ФизическиеЛица
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТФизическиеЛица КАК СписокСотрудников 
		|				ПО ФизическиеЛица.Ссылка = СписокСотрудников.ФизическоеЛицо
		|ГДЕ
		|	ФизическиеЛица.ДатаРождения < ДАТАВРЕМЯ(1975, 1, 1)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка) КАК ВидДохода
		|ИЗ
		|	ВТСтатусыФизическихЛицКакНалогоплательщиков КАК СтатусФизическихЛицКакНалогоплательщиков
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ПО СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо = ПериодыПоФизлицам.ФизическоеЛицо
		|			И СтатусФизическихЛицКакНалогоплательщиков.МесяцНалоговогоПериода = ПериодыПоФизлицам.МесяцНалоговогоПериода
		|			И СтатусФизическихЛицКакНалогоплательщиков.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТУчетнаяПолитикаПоПериодам КАК УчетнаяПолитикаПоПериодам
		|		ПО УчетнаяПолитикаПоПериодам.МесяцНалоговогоПериода = ПериодыПоФизлицам.МесяцНалоговогоПериода
		|			И УчетнаяПолитикаПоПериодам.ПорядокОбложенияДоходовРаботников = ЗНАЧЕНИЕ(Перечисление.ПорядокОбложенияДоходовРаботников.ЕдиныйПлатеж)";
		
	Запрос.Выполнить();

КонецПроцедуры


////////////////////////////////////////////////////////////////////////////////
// РАСЧЕТ НАЛОГОВ, ВЗНОСОВ И ОТЧИСЛЕНИЙ
////////////////////////////////////////////////////////////////////////////////

Функция РассчитатьОПВДо2019(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос();
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ИсключаемыйРегистратор", ?(ИсключатьДоходыРегистратора, Регистратор, Неопределено));
	
	// Исключаемые физические лица
	СоздатьВТИсключаемыеФизическиеЛицаПриРасчетеОПВ(МенеджерВременныхТаблиц, МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеОПВ");
	
	ВидНалогаВзносаОПВ =  Перечисления.ВидыНалоговВзносовОтчислений.ОПВ;
	
	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);

	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ, "ВТИсключаемыеФизическиеЛицаПриРасчетеОПВ");
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");   
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ОПВ
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");

	// - Размер органичения доходов, облагаемых ОПВ по периодам
	// - Исчисленные ОПВ
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 75 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход < 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА ЕСТЬNULL(Доходы.ОблагаемыйДоход, 0)
		|		ИНАЧЕ ЕСТЬNULL(РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода, 0)
		|	КОНЕЦ КАК ОбъектИсчисленияОПВ,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход < 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА ЕСТЬNULL(Доходы.ОблагаемыйДоход, 0)
		|		ИНАЧЕ ЕСТЬNULL(РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода, 0)
		|	КОНЕЦ * ЕСТЬNULL(СтавкиОПВ.Ставка, 0) КАК ИсчисленныеОПВ
		|ПОМЕСТИТЬ ВТИсчисленныеОПВВЦеломЗаПериод
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиОПВ
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОПВ.МесяцНалоговогоПериода
		|			И (СтавкиОПВ.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ОПВ))
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеОПВ.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВ.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеОПВ.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеОПВ.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ВТИсчисленныеОПВ.ОбъектИсчисленияОПВ КАК ОбъектИсчисленияОПВ,
		|	ВТИсчисленныеОПВ.ИсчисленныеОПВ КАК ИсчисленныеОПВ
		|ИЗ
		|	ВТИсчисленныеОПВВЦеломЗаПериод КАК ВТИсчисленныеОПВ
		|
		|УПОРЯДОЧИТЬ ПО
		|	ФизическоеЛицо,
		|	МесяцНалоговогоПериода,
		|	ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеОПВПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеОПВПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеОПВПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления КАК ОбъектОПВИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.НалогВзнос КАК РанееИсчисленныеОПВ,
		|	-ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеОПВПоПодразделениям.НалогВзнос КАК ИсчисленныеОПВ,
		|	-ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияОПВ
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеОПВПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.НалогВзнос <> 0)";
		
	Результат = Запрос.ВыполнитьПакет();
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТИсчисленныеОПВВЦеломЗаПериод");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеОПВПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	РезультатЗапроса.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатЗапроса.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатЗапроса.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатЗапроса.Колонки.Добавить("МаксимальныйРазмерОрганиченияДохода", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ОбъектИсчисленияОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИсчисленныеОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(Результат[ВсегоРезультатов - 3].Выгрузить(), РезультатЗапроса);
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеОПВВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияОПВВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектОПВИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияОПВ,ИсчисленныеОПВ");
	КонецЦикла;
	
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		СтрокаТЗ.ИсчисленныеОПВ = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеОПВ, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
	КонецЦикла;
	
	Запрос.УстановитьПараметр("ИсчисленныеОПВ", РезультатыРасчетов.Скопировать());

	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеОПВПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияОПВВЦеломЗаПериод, 	ИсчисленныеОПВВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектОПВИсчисленныйРанее, 			РанееИсчисленныеОПВ,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход, 					ОбъектИсчисленияОПВ, 				ИсчисленныеОПВ");
								
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
	КонецЦикла; 

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаОПВ.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ТаблицаОПВ.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ТаблицаОПВ.Подразделение КАК Подразделение,
		|	ТаблицаОПВ.ВидДохода КАК ВидДохода,
		|	ТаблицаОПВ.ОбъектИсчисленияОПВ КАК ОбъектИсчисленияОПВ,
		|	ТаблицаОПВ.ИсчисленныеОПВ КАК ИсчисленныеОПВ
		|ПОМЕСТИТЬ ВТИсчисленныеОПВПоПодразделениям
		|ИЗ
		|	&ИсчисленныеОПВ КАК ТаблицаОПВ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеОПВПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеОПВПоПодразделениям.ОбъектИсчисленияОПВ) КАК ОбъектИсчисленияОПВ,
		|	СУММА(ВТИсчисленныеОПВПоПодразделениям.ИсчисленныеОПВ) КАК ИсчисленныеОПВ
		|ПОМЕСТИТЬ ВТИсчисленныеОПВ
		|ИЗ
		|	ВТИсчисленныеОПВПоПодразделениям КАК ВТИсчисленныеОПВПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеОПВПоПодразделениям.ВидДохода";
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеОПВПоПодразделениям");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьОПВПосле2019(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос();
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ИсключаемыйРегистратор", ?(ИсключатьДоходыРегистратора, Регистратор, Неопределено));
	
	// Исключаемые физические лица
	СоздатьВТИсключаемыеФизическиеЛицаПриРасчетеОПВ(МенеджерВременныхТаблиц, МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеОПВ");
	
	ВидНалогаВзносаОПВ =  Перечисления.ВидыНалоговВзносовОтчислений.ОПВ;
	
	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);

	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ, "ВТИсключаемыеФизическиеЛицаПриРасчетеОПВ");
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");   
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ОПВ
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");

	// - Размер органичения доходов, облагаемых ОПВ по периодам
	// - Исчисленные ОПВ
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 50 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход < 0
		|			ТОГДА 0
		|		КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтНалоговогоАгента)
		|			И Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА ЕСТЬNULL(РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода, Доходы.ОблагаемыйДоход)
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА ЕСТЬNULL(Доходы.ОблагаемыйДоход, 0)
		|		ИНАЧЕ ЕСТЬNULL(РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода, 0)
		|	КОНЕЦ КАК ОбъектИсчисленияОПВ,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход < 0
		|			ТОГДА 0
		|		КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтНалоговогоАгента)
		|			И Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА ЕСТЬNULL(РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода, Доходы.ОблагаемыйДоход)
		|		КОГДА Доходы.ОблагаемыйДоход < РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА ЕСТЬNULL(Доходы.ОблагаемыйДоход, 0)
		|		ИНАЧЕ ЕСТЬNULL(РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода, 0)
		|	КОНЕЦ * ЕСТЬNULL(СтавкиОПВ.Ставка, 0) КАК ИсчисленныеОПВ
		|ПОМЕСТИТЬ ВТИсчисленныеОПВВЦеломЗаПериод
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиОПВ
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОПВ.МесяцНалоговогоПериода
		|			И (СтавкиОПВ.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ОПВ))
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеОПВ.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВ.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеОПВ.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеОПВ.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ВТИсчисленныеОПВ.ОбъектИсчисленияОПВ КАК ОбъектИсчисленияОПВ,
		|	ВТИсчисленныеОПВ.ИсчисленныеОПВ КАК ИсчисленныеОПВ
		|ИЗ
		|	ВТИсчисленныеОПВВЦеломЗаПериод КАК ВТИсчисленныеОПВ
		|
		|УПОРЯДОЧИТЬ ПО
		|	ФизическоеЛицо,
		|	МесяцНалоговогоПериода,
		|	ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеОПВПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеОПВПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеОПВПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления КАК ОбъектОПВИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.НалогВзнос КАК РанееИсчисленныеОПВ,
		|	-ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеОПВПоПодразделениям.НалогВзнос КАК ИсчисленныеОПВ,
		|	-ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияОПВ
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеОПВПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.НалогВзнос <> 0)";
		
	Результат = Запрос.ВыполнитьПакет();
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТИсчисленныеОПВВЦеломЗаПериод");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеОПВПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	РезультатЗапроса.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатЗапроса.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатЗапроса.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатЗапроса.Колонки.Добавить("МаксимальныйРазмерОрганиченияДохода", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ОбъектИсчисленияОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИсчисленныеОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(Результат[ВсегоРезультатов - 3].Выгрузить(), РезультатЗапроса);
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеОПВВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияОПВВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектОПВИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияОПВ,ИсчисленныеОПВ");
	КонецЦикла;
	
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		СтрокаТЗ.ИсчисленныеОПВ = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеОПВ, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
	КонецЦикла;
	
	Запрос.УстановитьПараметр("ИсчисленныеОПВ", РезультатыРасчетов.Скопировать());

	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеОПВПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияОПВВЦеломЗаПериод, 	ИсчисленныеОПВВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектОПВИсчисленныйРанее, 			РанееИсчисленныеОПВ,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход, 					ОбъектИсчисленияОПВ, 				ИсчисленныеОПВ");
								
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
	КонецЦикла; 

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаОПВ.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ТаблицаОПВ.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ТаблицаОПВ.Подразделение КАК Подразделение,
		|	ТаблицаОПВ.ВидДохода КАК ВидДохода,
		|	ТаблицаОПВ.ОбъектИсчисленияОПВ КАК ОбъектИсчисленияОПВ,
		|	ТаблицаОПВ.ИсчисленныеОПВ КАК ИсчисленныеОПВ
		|ПОМЕСТИТЬ ВТИсчисленныеОПВПоПодразделениям
		|ИЗ
		|	&ИсчисленныеОПВ КАК ТаблицаОПВ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеОПВПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеОПВПоПодразделениям.ОбъектИсчисленияОПВ) КАК ОбъектИсчисленияОПВ,
		|	СУММА(ВТИсчисленныеОПВПоПодразделениям.ИсчисленныеОПВ) КАК ИсчисленныеОПВ
		|ПОМЕСТИТЬ ВТИсчисленныеОПВ
		|ИЗ
		|	ВТИсчисленныеОПВПоПодразделениям КАК ВТИсчисленныеОПВПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеОПВПоПодразделениям.ВидДохода";
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеОПВПоПодразделениям");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьОПВПосле2020(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос();
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ИсключаемыйРегистратор", ?(ИсключатьДоходыРегистратора, Регистратор, Неопределено));
	
	// Исключаемые физические лица
	СоздатьВТИсключаемыеФизическиеЛицаПриРасчетеОПВ(МенеджерВременныхТаблиц, МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеОПВ");
	
	ВидНалогаВзносаОПВ =  Перечисления.ВидыНалоговВзносовОтчислений.ОПВ;
	
	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);

	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ, "ВТИсключаемыеФизическиеЛицаПриРасчетеОПВ");
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");   
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ОПВ
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");

	// - Размер органичения доходов, облагаемых ОПВ по периодам
	// - Исчисленные ОПВ
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 50 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	ЕСТЬNULL(СтавкиОПВ.Ставка, 0) КАК Ставка,
		|	МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода, 0)) КАК МаксимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(Доходы.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	МАКСИМУМ(ВЫБОР КОГДА ДругиеВидыДоходов.ВидДохода ЕСТЬ NULL ТОГДА ЛОЖЬ ИНАЧЕ ИСТИНА КОНЕЦ) КАК ЕстьНесколькоВидовДоходов,
		|	0 КАК ОбъектИсчисленияОПВ,
		|	0 КАК ИсчисленныеОПВ
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДоходы КАК ДругиеВидыДоходов
		|		ПО ДругиеВидыДоходов.МесяцНалоговогоПериода = Доходы.МесяцНалоговогоПериода
		|			И ДругиеВидыДоходов.ФизическоеЛицо = Доходы.ФизическоеЛицо
		|			И НЕ ДругиеВидыДоходов.ВидДохода = Доходы.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиОПВ
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОПВ.МесяцНалоговогоПериода
		|			И (СтавкиОПВ.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ОПВ))
		|			И Доходы.ВидДохода = СтавкиОПВ.ВидДохода
		|	
		|СГРУППИРОВАТЬ ПО
		|	Доходы.МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо,
		|	Доходы.ВидДохода,
		|	ЕСТЬNULL(СтавкиОПВ.Ставка, 0)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Доходы.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеОПВПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеОПВПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеОПВПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления КАК ОбъектОПВИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.НалогВзнос КАК РанееИсчисленныеОПВ,
		|	-ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеОПВПоПодразделениям.НалогВзнос КАК ИсчисленныеОПВ,
		|	-ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияОПВ
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеОПВПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.НалогВзнос <> 0)";
		
	Результат = Запрос.ВыполнитьПакет();
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеОПВПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	РезультатЗапроса.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатЗапроса.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатЗапроса.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатЗапроса.Колонки.Добавить("МаксимальныйРазмерОрганиченияДохода", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ОбъектИсчисленияОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИсчисленныеОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаДляОбработки = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам = Новый ТаблицаЗначений;
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ОбъектИсчисления", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Индексы.Добавить("ФизическоеЛицо, МесяцНалоговогоПериода");
	
	СтруктураПоискаПоФизЛицам = Новый Структура("ФизическоеЛицо, МесяцНалоговогоПериода");

	Для Каждого СтрокаТаблицы Из ТаблицаДляОбработки Цикл
		
		ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
		
		// корректируем максимальный доход только в окончательном расчете, если есть несколько видов дохода в месяце начисления
		НеобходимаКорректировкаМакисмальногоОграничения = ОкончательныйРасчет И СтрокаТаблицы.ЕстьНесколькоВидовДоходов;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			ЗаполнитьЗначенияСвойств(СтруктураПоискаПоФизЛицам, СтрокаТаблицы);

			// сумма взносов исчисленная
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			
			Если МассивВзносов.Количество() > 0 Тогда
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = МассивВзносов[0].ОбъектИсчисления;
			Иначе
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			КонецЕсли;
			
		Иначе
			
			ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			
		КонецЕсли;
		
		МаксимальныйРазмерОрганиченияДохода = СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода - ОбъектИсчисленияПоДругимВидамВДанномРасчете;
	
		Если СтрокаТаблицы.ОблагаемыйДоход < 0 Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияОПВ = 0;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход < МаксимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияОПВ = СтрокаТаблицы.ОблагаемыйДоход;
			
		Иначе
			
			СтрокаТаблицы.ОбъектИсчисленияОПВ = МаксимальныйРазмерОрганиченияДохода;
			
		КонецЕсли;
		
		СтрокаТаблицы.ИсчисленныеОПВ = СтрокаТаблицы.ОбъектИсчисленияОПВ * СтрокаТаблицы.Ставка;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			Если МассивВзносов.Количество() > 0 Тогда
				СтрокаВзносовТаблицаВзносовПоФизЛицам = МассивВзносов[0];
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления + СтрокаТаблицы.ОбъектИсчисленияОПВ;
			Иначе
				СтрокаВзносовТаблицаВзносовПоФизЛицам = ТаблицаВзносовПоФизЛицамПоДругимДоходам.Добавить();
				СтрокаВзносовТаблицаВзносовПоФизЛицам.МесяцНалоговогоПериода = СтрокаТаблицы.МесяцНалоговогоПериода;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ФизическоеЛицо = СтрокаТаблицы.ФизическоеЛицо;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаТаблицы.ОбъектИсчисленияОПВ;
			КонецЕсли;
			
		КонецЕсли;

	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаДляОбработки, РезультатЗапроса);
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеОПВВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияОПВВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектОПВИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
	
	Если ТочностьОкругления = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругления <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;
			
	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияОПВ,ИсчисленныеОПВ", ТочностьРаспределения);
	КонецЦикла;
	
	// для вычетов ИПН передаем общую таблицу округленных сумм
	ТаблицаДляВычетовИПН = РезультатыРасчетов.Скопировать();
	
	Для каждого СтрокаТЗ Из ТаблицаДляВычетовИПН Цикл
		СтрокаТЗ.ИсчисленныеОПВ = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеОПВ, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
	КонецЦикла; 
	
	Запрос.УстановитьПараметр("ИсчисленныеОПВ", ТаблицаДляВычетовИПН);

	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеОПВПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияОПВВЦеломЗаПериод, 	ИсчисленныеОПВВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектОПВИсчисленныйРанее, 			РанееИсчисленныеОПВ,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход, 					ОбъектИсчисленияОПВ, 				ИсчисленныеОПВ");
								
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0 
			И НЕ ОписаниеСпособаОкругления.ПравилоОкругления = Перечисления.ПравилаОкругленияПриРасчетеЗарплаты.Авто
			И (СтрокаТЗ.ИсчисленныеОПВ < 1 И СтрокаТЗ.ИсчисленныеОПВ > 0
				ИЛИ СтрокаТЗ.ИсчисленныеОПВ > -1 И СтрокаТЗ.ИсчисленныеОПВ < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеОПВ = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеОПВ = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеОПВ, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
			
		КонецЕсли;
		
	КонецЦикла; 

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаОПВ.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ТаблицаОПВ.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ТаблицаОПВ.Подразделение КАК Подразделение,
		|	ТаблицаОПВ.ВидДохода КАК ВидДохода,
		|	ТаблицаОПВ.ОбъектИсчисленияОПВ КАК ОбъектИсчисленияОПВ,
		|	ТаблицаОПВ.ИсчисленныеОПВ КАК ИсчисленныеОПВ
		|ПОМЕСТИТЬ ВТИсчисленныеОПВПоПодразделениям
		|ИЗ
		|	&ИсчисленныеОПВ КАК ТаблицаОПВ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеОПВПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеОПВПоПодразделениям.ОбъектИсчисленияОПВ) КАК ОбъектИсчисленияОПВ,
		|	СУММА(ВТИсчисленныеОПВПоПодразделениям.ИсчисленныеОПВ) КАК ИсчисленныеОПВ
		|ПОМЕСТИТЬ ВТИсчисленныеОПВ
		|ИЗ
		|	ВТИсчисленныеОПВПоПодразделениям КАК ВТИсчисленныеОПВПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеОПВПоПодразделениям.ВидДохода
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ВТИсчисленныеОПВПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВПоПодразделениям.ВидДохода";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеОПВПоПодразделениям");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьОПВПосле2021(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос();
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ИсключаемыйРегистратор", ?(ИсключатьДоходыРегистратора, Регистратор, Неопределено));
	
	// Исключаемые физические лица
	СоздатьВТИсключаемыеФизическиеЛицаПриРасчетеОПВ(МенеджерВременныхТаблиц, МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеОПВ");
	
	ВидНалогаВзносаОПВ =  Перечисления.ВидыНалоговВзносовОтчислений.ОПВ;
	
	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);

	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ, "ВТИсключаемыеФизическиеЛицаПриРасчетеОПВ");
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");   
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ОПВ
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");

	// - Размер органичения доходов, облагаемых ОПВ по периодам
	// - Исчисленные ОПВ
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 50 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	ЕСТЬNULL(СтавкиОПВ.Ставка, 0) КАК Ставка,
		|	ВЫБОР
		|		КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|			ТОГДА МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода, 0))
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК МинимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода, 0)) КАК МаксимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(Доходы.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	МАКСИМУМ(ВЫБОР КОГДА ДругиеВидыДоходов.ВидДохода ЕСТЬ NULL ТОГДА ЛОЖЬ ИНАЧЕ ИСТИНА КОНЕЦ) КАК ЕстьНесколькоВидовДоходов,
		|	0 КАК ОбъектИсчисленияОПВ,
		|	0 КАК ИсчисленныеОПВ
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДоходы КАК ДругиеВидыДоходов
		|		ПО ДругиеВидыДоходов.МесяцНалоговогоПериода = Доходы.МесяцНалоговогоПериода
		|			И ДругиеВидыДоходов.ФизическоеЛицо = Доходы.ФизическоеЛицо
		|			И НЕ ДругиеВидыДоходов.ВидДохода = Доходы.ВидДохода
		|			И НЕ ДругиеВидыДоходов.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиОПВ
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОПВ.МесяцНалоговогоПериода
		|			И (СтавкиОПВ.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ОПВ))
		|			И Доходы.ВидДохода = СтавкиОПВ.ВидДохода
		|	
		|СГРУППИРОВАТЬ ПО
		|	Доходы.МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо,
		|	Доходы.ВидДохода,
		|	ЕСТЬNULL(СтавкиОПВ.Ставка, 0)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Доходы.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеОПВПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеОПВПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеОПВПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления КАК ОбъектОПВИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.НалогВзнос КАК РанееИсчисленныеОПВ,
		|	-ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеОПВПоПодразделениям.НалогВзнос КАК ИсчисленныеОПВ,
		|	-ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияОПВ
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеОПВПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.НалогВзнос <> 0)
		|	И НЕ ИсчисленныеОПВПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)";
		
	Результат = Запрос.ВыполнитьПакет();
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеОПВПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	РезультатЗапроса.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатЗапроса.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатЗапроса.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатЗапроса.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатЗапроса.Колонки.Добавить("МаксимальныйРазмерОрганиченияДохода", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ОбъектИсчисленияОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИсчисленныеОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаДляОбработки = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам = Новый ТаблицаЗначений;
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ОбъектИсчисления", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Индексы.Добавить("ФизическоеЛицо, МесяцНалоговогоПериода");
	
	СтруктураПоискаПоФизЛицам = Новый Структура("ФизическоеЛицо, МесяцНалоговогоПериода");

	Для Каждого СтрокаТаблицы Из ТаблицаДляОбработки Цикл
		
		ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
		
		// корректируем максимальный доход только в окончательном расчете, если есть несколько видов дохода в месяце начисления
		НеобходимаКорректировкаМакисмальногоОграничения = ОкончательныйРасчет И СтрокаТаблицы.ЕстьНесколькоВидовДоходов;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			ЗаполнитьЗначенияСвойств(СтруктураПоискаПоФизЛицам, СтрокаТаблицы);

			// сумма взносов исчисленная
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			
			Если МассивВзносов.Количество() > 0 Тогда
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = МассивВзносов[0].ОбъектИсчисления;
			Иначе
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			КонецЕсли;
			
		Иначе
			
			ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			
		КонецЕсли;
		
		МаксимальныйРазмерОрганиченияДохода = СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода - ОбъектИсчисленияПоДругимВидамВДанномРасчете;
		МинимальныйРазмерОрганиченияДохода = СтрокаТаблицы.МинимальныйРазмерОрганиченияДохода;
	
		Если СтрокаТаблицы.ОблагаемыйДоход < 0 Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияОПВ = 0;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход < МинимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияОПВ = МинимальныйРазмерОрганиченияДохода;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход < МаксимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияОПВ = СтрокаТаблицы.ОблагаемыйДоход;
			
		Иначе
			
			СтрокаТаблицы.ОбъектИсчисленияОПВ = МаксимальныйРазмерОрганиченияДохода;
			
		КонецЕсли;
		
		СтрокаТаблицы.ИсчисленныеОПВ = СтрокаТаблицы.ОбъектИсчисленияОПВ * СтрокаТаблицы.Ставка;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			Если МассивВзносов.Количество() > 0 Тогда
				СтрокаВзносовТаблицаВзносовПоФизЛицам = МассивВзносов[0];
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления + СтрокаТаблицы.ОбъектИсчисленияОПВ;
			Иначе
				СтрокаВзносовТаблицаВзносовПоФизЛицам = ТаблицаВзносовПоФизЛицамПоДругимДоходам.Добавить();
				СтрокаВзносовТаблицаВзносовПоФизЛицам.МесяцНалоговогоПериода = СтрокаТаблицы.МесяцНалоговогоПериода;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ФизическоеЛицо = СтрокаТаблицы.ФизическоеЛицо;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаТаблицы.ОбъектИсчисленияОПВ;
			КонецЕсли;
			
		КонецЕсли;

	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаДляОбработки, РезультатЗапроса);
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеОПВВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияОПВВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектОПВИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
	
	Если ТочностьОкругления = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругления <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;
			
	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияОПВ,ИсчисленныеОПВ", ТочностьРаспределения);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеОПВПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияОПВВЦеломЗаПериод, 	ИсчисленныеОПВВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектОПВИсчисленныйРанее, 			РанееИсчисленныеОПВ,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход, 					ОбъектИсчисленияОПВ, 				ИсчисленныеОПВ");
								
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0 
			И (СтрокаТЗ.ИсчисленныеОПВ < 1 И СтрокаТЗ.ИсчисленныеОПВ > 0
				ИЛИ СтрокаТЗ.ИсчисленныеОПВ > -1 И СтрокаТЗ.ИсчисленныеОПВ < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеОПВ = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеОПВ = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеОПВ, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
			
		КонецЕсли;
		
	КонецЦикла; 
	
	// для вычетов ИПН передаем общую таблицу округленных сумм
	ТаблицаДляВычетовИПН = РезультатЗапроса.Скопировать();
	
	Для каждого СтрокаТЗ Из ТаблицаДляВычетовИПН Цикл
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0 
			И (СтрокаТЗ.ИсчисленныеОПВ < 1 И СтрокаТЗ.ИсчисленныеОПВ > 0
				ИЛИ СтрокаТЗ.ИсчисленныеОПВ > -1 И СтрокаТЗ.ИсчисленныеОПВ < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеОПВ = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеОПВ = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеОПВ, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
			
		КонецЕсли;
	КонецЦикла; 
	
	Запрос.УстановитьПараметр("ИсчисленныеОПВ", ТаблицаДляВычетовИПН);


	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаОПВ.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ТаблицаОПВ.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ТаблицаОПВ.Подразделение КАК Подразделение,
		|	ТаблицаОПВ.ВидДохода КАК ВидДохода,
		|	ТаблицаОПВ.ОбъектИсчисленияОПВ КАК ОбъектИсчисленияОПВ,
		|	ТаблицаОПВ.ИсчисленныеОПВ КАК ИсчисленныеОПВ
		|ПОМЕСТИТЬ ВТИсчисленныеОПВПоПодразделениям
		|ИЗ
		|	&ИсчисленныеОПВ КАК ТаблицаОПВ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеОПВПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеОПВПоПодразделениям.ОбъектИсчисленияОПВ) КАК ОбъектИсчисленияОПВ,
		|	СУММА(ВТИсчисленныеОПВПоПодразделениям.ИсчисленныеОПВ) КАК ИсчисленныеОПВ
		|ПОМЕСТИТЬ ВТИсчисленныеОПВ
		|ИЗ
		|	ВТИсчисленныеОПВПоПодразделениям КАК ВТИсчисленныеОПВПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеОПВПоПодразделениям.ВидДохода
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ВТИсчисленныеОПВПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВПоПодразделениям.ВидДохода";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеОПВПоПодразделениям");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьОПВПосле2023(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос();
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ИсключаемыйРегистратор", ?(ИсключатьДоходыРегистратора, Регистратор, Неопределено));
	
	// Исключаемые физические лица
	СоздатьВТИсключаемыеФизическиеЛицаПриРасчетеОПВ(МенеджерВременныхТаблиц, МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеОПВ");
	
	ВидНалогаВзносаОПВ =  Перечисления.ВидыНалоговВзносовОтчислений.ОПВ;
	
	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);

	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходыПосле2023(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ, "ВТИсключаемыеФизическиеЛицаПриРасчетеОПВ");
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");   
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ОПВ
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");

	// - Размер органичения доходов, облагаемых ОПВ по периодам
	// - Исчисленные ОПВ
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 50 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	ЕСТЬNULL(СтавкиОПВ.Ставка, 0) КАК Ставка,
		|	ВЫБОР
		|		КОГДА Доходы.МесяцНалоговогоПериода < ДАТАВРЕМЯ(2023, 7, 1)
		|			ТОГДА ВЫБОР
		|					КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|						ТОГДА МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода, 0))
		|					ИНАЧЕ 0
		|				КОНЕЦ
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК МинимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода, 0)) КАК МаксимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(Доходы.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	МАКСИМУМ(ВЫБОР КОГДА ДругиеВидыДоходов.ВидДохода ЕСТЬ NULL ТОГДА ЛОЖЬ ИНАЧЕ ИСТИНА КОНЕЦ) КАК ЕстьНесколькоВидовДоходов,
		|	0 КАК ОбъектИсчисленияОПВ,
		|	0 КАК ИсчисленныеОПВ
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДоходы КАК ДругиеВидыДоходов
		|		ПО ДругиеВидыДоходов.МесяцНалоговогоПериода = Доходы.МесяцНалоговогоПериода
		|			И ДругиеВидыДоходов.ФизическоеЛицо = Доходы.ФизическоеЛицо
		|			И НЕ ДругиеВидыДоходов.ВидДохода = Доходы.ВидДохода
		|			И НЕ ДругиеВидыДоходов.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиОПВ
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОПВ.МесяцНалоговогоПериода
		|			И (СтавкиОПВ.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ОПВ))
		|			И Доходы.ВидДохода = СтавкиОПВ.ВидДохода
		|	
		|СГРУППИРОВАТЬ ПО
		|	Доходы.МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо,
		|	Доходы.ВидДохода,
		|	ЕСТЬNULL(СтавкиОПВ.Ставка, 0)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Доходы.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеОПВПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеОПВПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеОПВПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления КАК ОбъектОПВИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.НалогВзнос КАК РанееИсчисленныеОПВ,
		|	-ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеОПВПоПодразделениям.НалогВзнос КАК ИсчисленныеОПВ,
		|	-ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияОПВ
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеОПВПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.НалогВзнос <> 0)
		|	И НЕ ИсчисленныеОПВПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)";
		
	Результат = Запрос.ВыполнитьПакет();
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеОПВПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	РезультатЗапроса.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатЗапроса.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатЗапроса.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатЗапроса.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатЗапроса.Колонки.Добавить("МаксимальныйРазмерОрганиченияДохода", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ОбъектИсчисленияОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИсчисленныеОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаДляОбработки = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам = Новый ТаблицаЗначений;
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ОбъектИсчисления", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Индексы.Добавить("ФизическоеЛицо, МесяцНалоговогоПериода");
	
	СтруктураПоискаПоФизЛицам = Новый Структура("ФизическоеЛицо, МесяцНалоговогоПериода");

	Для Каждого СтрокаТаблицы Из ТаблицаДляОбработки Цикл
		
		ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
		
		// корректируем максимальный доход только в окончательном расчете, если есть несколько видов дохода в месяце начисления
		НеобходимаКорректировкаМакисмальногоОграничения = ОкончательныйРасчет И СтрокаТаблицы.ЕстьНесколькоВидовДоходов;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			ЗаполнитьЗначенияСвойств(СтруктураПоискаПоФизЛицам, СтрокаТаблицы);

			// сумма взносов исчисленная
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			
			Если МассивВзносов.Количество() > 0 Тогда
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = МассивВзносов[0].ОбъектИсчисления;
			Иначе
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			КонецЕсли;
			
		Иначе
			
			ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			
		КонецЕсли;
		
		МаксимальныйРазмерОрганиченияДохода = СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода - ОбъектИсчисленияПоДругимВидамВДанномРасчете;
		МинимальныйРазмерОрганиченияДохода = СтрокаТаблицы.МинимальныйРазмерОрганиченияДохода;
	
		Если СтрокаТаблицы.ОблагаемыйДоход < 0 Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияОПВ = 0;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход < МинимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияОПВ = МинимальныйРазмерОрганиченияДохода;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход < МаксимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияОПВ = СтрокаТаблицы.ОблагаемыйДоход;
			
		Иначе
			
			СтрокаТаблицы.ОбъектИсчисленияОПВ = МаксимальныйРазмерОрганиченияДохода;
			
		КонецЕсли;
		
		СтрокаТаблицы.ИсчисленныеОПВ = СтрокаТаблицы.ОбъектИсчисленияОПВ * СтрокаТаблицы.Ставка;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			Если МассивВзносов.Количество() > 0 Тогда
				СтрокаВзносовТаблицаВзносовПоФизЛицам = МассивВзносов[0];
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления + СтрокаТаблицы.ОбъектИсчисленияОПВ;
			Иначе
				СтрокаВзносовТаблицаВзносовПоФизЛицам = ТаблицаВзносовПоФизЛицамПоДругимДоходам.Добавить();
				СтрокаВзносовТаблицаВзносовПоФизЛицам.МесяцНалоговогоПериода = СтрокаТаблицы.МесяцНалоговогоПериода;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ФизическоеЛицо = СтрокаТаблицы.ФизическоеЛицо;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаТаблицы.ОбъектИсчисленияОПВ;
			КонецЕсли;
			
		КонецЕсли;

	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаДляОбработки, РезультатЗапроса);
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеОПВВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияОПВВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектОПВИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
	
	Если ТочностьОкругления = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругления <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;
			
	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияОПВ,ИсчисленныеОПВ", ТочностьРаспределения);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеОПВПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияОПВВЦеломЗаПериод, 	ИсчисленныеОПВВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектОПВИсчисленныйРанее, 			РанееИсчисленныеОПВ,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход, 					ОбъектИсчисленияОПВ, 				ИсчисленныеОПВ");
								
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0 
			И (СтрокаТЗ.ИсчисленныеОПВ < 1 И СтрокаТЗ.ИсчисленныеОПВ > 0
				ИЛИ СтрокаТЗ.ИсчисленныеОПВ > -1 И СтрокаТЗ.ИсчисленныеОПВ < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеОПВ = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеОПВ = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеОПВ, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
			
		КонецЕсли;
		
	КонецЦикла; 
	
	// для вычетов ИПН передаем общую таблицу округленных сумм
	ТаблицаДляВычетовИПН = РезультатЗапроса.Скопировать();
	
	Для каждого СтрокаТЗ Из ТаблицаДляВычетовИПН Цикл
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0 
			И (СтрокаТЗ.ИсчисленныеОПВ < 1 И СтрокаТЗ.ИсчисленныеОПВ > 0
				ИЛИ СтрокаТЗ.ИсчисленныеОПВ > -1 И СтрокаТЗ.ИсчисленныеОПВ < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеОПВ = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеОПВ = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеОПВ, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
			
		КонецЕсли;
	КонецЦикла; 
	
	Запрос.УстановитьПараметр("ИсчисленныеОПВ", ТаблицаДляВычетовИПН);


	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаОПВ.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ТаблицаОПВ.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ТаблицаОПВ.Подразделение КАК Подразделение,
		|	ТаблицаОПВ.ВидДохода КАК ВидДохода,
		|	ТаблицаОПВ.ОбъектИсчисленияОПВ КАК ОбъектИсчисленияОПВ,
		|	ТаблицаОПВ.ИсчисленныеОПВ КАК ИсчисленныеОПВ
		|ПОМЕСТИТЬ ВТИсчисленныеОПВПоПодразделениям
		|ИЗ
		|	&ИсчисленныеОПВ КАК ТаблицаОПВ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеОПВПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеОПВПоПодразделениям.ОбъектИсчисленияОПВ) КАК ОбъектИсчисленияОПВ,
		|	СУММА(ВТИсчисленныеОПВПоПодразделениям.ИсчисленныеОПВ) КАК ИсчисленныеОПВ
		|ПОМЕСТИТЬ ВТИсчисленныеОПВ
		|ИЗ
		|	ВТИсчисленныеОПВПоПодразделениям КАК ВТИсчисленныеОПВПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеОПВПоПодразделениям.ВидДохода
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ВТИсчисленныеОПВПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВПоПодразделениям.ВидДохода";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеОПВПоПодразделениям");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьОПВПосле2025(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос();
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ИсключаемыйРегистратор", ?(ИсключатьДоходыРегистратора, Регистратор, Неопределено));
	
	// Исключаемые физические лица
	СоздатьВТИсключаемыеФизическиеЛицаПриРасчетеОПВ(МенеджерВременныхТаблиц, МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеОПВ");
	
	ВидНалогаВзносаОПВ =  Перечисления.ВидыНалоговВзносовОтчислений.ОПВ;
	
	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);

	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходыПосле2023(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ, "ВТИсключаемыеФизическиеЛицаПриРасчетеОПВ");
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");   
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ОПВ
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");

	// - Размер органичения доходов, облагаемых ОПВ по периодам
	// - Исчисленные ОПВ
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 50 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	ЕСТЬNULL(СтавкиОПВ.Ставка, 0) КАК Ставка,
		|	ВЫБОР
		|		КОГДА Доходы.МесяцНалоговогоПериода < ДАТАВРЕМЯ(2023, 7, 1)
		|			ТОГДА ВЫБОР
		|					КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|						ТОГДА МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода, 0))
		|					ИНАЧЕ 0
		|				КОНЕЦ
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК МинимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода, 0)) КАК МаксимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(Доходы.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	МАКСИМУМ(ВЫБОР КОГДА ДругиеВидыДоходов.ВидДохода ЕСТЬ NULL ТОГДА ЛОЖЬ ИНАЧЕ ИСТИНА КОНЕЦ) КАК ЕстьНесколькоВидовДоходов,
		|	0 КАК ОбъектИсчисленияОПВ,
		|	0 КАК ИсчисленныеОПВ
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДоходы КАК ДругиеВидыДоходов
		|		ПО ДругиеВидыДоходов.МесяцНалоговогоПериода = Доходы.МесяцНалоговогоПериода
		|			И ДругиеВидыДоходов.ФизическоеЛицо = Доходы.ФизическоеЛицо
		|			И НЕ ДругиеВидыДоходов.ВидДохода = Доходы.ВидДохода
		|			И НЕ ДругиеВидыДоходов.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиОПВ
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОПВ.МесяцНалоговогоПериода
		|			И (СтавкиОПВ.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ОПВ))
		|			И Доходы.ВидДохода = СтавкиОПВ.ВидДохода
		|	
		|СГРУППИРОВАТЬ ПО
		|	Доходы.МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо,
		|	Доходы.ВидДохода,
		|	ЕСТЬNULL(СтавкиОПВ.Ставка, 0)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Доходы.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеОПВПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеОПВПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеОПВПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления КАК ОбъектОПВИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.НалогВзнос КАК РанееИсчисленныеОПВ,
		|	-ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеОПВПоПодразделениям.НалогВзнос КАК ИсчисленныеОПВ,
		|	-ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияОПВ
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеОПВПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.НалогВзнос <> 0)
		|	И НЕ ИсчисленныеОПВПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)";
		
	Результат = Запрос.ВыполнитьПакет();
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеОПВПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	РезультатЗапроса.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатЗапроса.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатЗапроса.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатЗапроса.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатЗапроса.Колонки.Добавить("МаксимальныйРазмерОрганиченияДохода", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ОбъектИсчисленияОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИсчисленныеОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаДляОбработки = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам = Новый ТаблицаЗначений;
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ОбъектИсчисления", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Индексы.Добавить("ФизическоеЛицо, МесяцНалоговогоПериода");
	
	СтруктураПоискаПоФизЛицам = Новый Структура("ФизическоеЛицо, МесяцНалоговогоПериода");

	Для Каждого СтрокаТаблицы Из ТаблицаДляОбработки Цикл
		
		ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
		
		// корректируем максимальный доход только в окончательном расчете, если есть несколько видов дохода в месяце начисления
		НеобходимаКорректировкаМакисмальногоОграничения = ОкончательныйРасчет И СтрокаТаблицы.ЕстьНесколькоВидовДоходов;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			ЗаполнитьЗначенияСвойств(СтруктураПоискаПоФизЛицам, СтрокаТаблицы);

			// сумма взносов исчисленная
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			
			Если МассивВзносов.Количество() > 0 Тогда
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = МассивВзносов[0].ОбъектИсчисления;
			Иначе
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			КонецЕсли;
			
		Иначе
			
			ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			
		КонецЕсли;
		
		МаксимальныйРазмерОрганиченияДохода = СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода - ОбъектИсчисленияПоДругимВидамВДанномРасчете;
		МинимальныйРазмерОрганиченияДохода = СтрокаТаблицы.МинимальныйРазмерОрганиченияДохода;
	
		Если СтрокаТаблицы.ОблагаемыйДоход < 0 Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияОПВ = 0;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход < МинимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияОПВ = МинимальныйРазмерОрганиченияДохода;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход < МаксимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияОПВ = СтрокаТаблицы.ОблагаемыйДоход;
			
		Иначе
			
			СтрокаТаблицы.ОбъектИсчисленияОПВ = МаксимальныйРазмерОрганиченияДохода;
			
		КонецЕсли;
		
		СтрокаТаблицы.ИсчисленныеОПВ = СтрокаТаблицы.ОбъектИсчисленияОПВ * СтрокаТаблицы.Ставка;

        // сначала применим округление к сумме ИПН, после чего распределим ниже (ранее округление выполнялось после распределения, что приводило к погрешностям расчета)
		СтрокаТаблицы.ИсчисленныеОПВ = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТаблицы.ИсчисленныеОПВ, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			Если МассивВзносов.Количество() > 0 Тогда
				СтрокаВзносовТаблицаВзносовПоФизЛицам = МассивВзносов[0];
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления + СтрокаТаблицы.ОбъектИсчисленияОПВ;
			Иначе
				СтрокаВзносовТаблицаВзносовПоФизЛицам = ТаблицаВзносовПоФизЛицамПоДругимДоходам.Добавить();
				СтрокаВзносовТаблицаВзносовПоФизЛицам.МесяцНалоговогоПериода = СтрокаТаблицы.МесяцНалоговогоПериода;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ФизическоеЛицо = СтрокаТаблицы.ФизическоеЛицо;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаТаблицы.ОбъектИсчисленияОПВ;
			КонецЕсли;
			
		КонецЕсли;

	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаДляОбработки, РезультатЗапроса);
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеОПВВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияОПВВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектОПВИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
	
	Если ТочностьОкругления = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругления <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;
			
	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияОПВ,ИсчисленныеОПВ", ТочностьРаспределения);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеОПВПоПодразделениям, РезультатыРасчетов);

	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0 
			И (СтрокаТЗ.ИсчисленныеОПВ < 1 И СтрокаТЗ.ИсчисленныеОПВ > 0
				ИЛИ СтрокаТЗ.ИсчисленныеОПВ > -1 И СтрокаТЗ.ИсчисленныеОПВ < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеОПВ = 0;
			
		КонецЕсли;
		
	КонецЦикла; 

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияОПВВЦеломЗаПериод, 	ИсчисленныеОПВВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектОПВИсчисленныйРанее, 			РанееИсчисленныеОПВ,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход, 					ОбъектИсчисленияОПВ, 				ИсчисленныеОПВ");
								
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	
	НомерСтроки = 0;
	
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
	КонецЦикла; 
	
	// для вычетов ИПН передаем общую таблицу округленных сумм
	ТаблицаДляВычетовИПН = РезультатЗапроса.Скопировать();
	
	Для каждого СтрокаТЗ Из ТаблицаДляВычетовИПН Цикл
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0 
			И (СтрокаТЗ.ИсчисленныеОПВ < 1 И СтрокаТЗ.ИсчисленныеОПВ > 0
				ИЛИ СтрокаТЗ.ИсчисленныеОПВ > -1 И СтрокаТЗ.ИсчисленныеОПВ < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеОПВ = 0;
			
		КонецЕсли;
	КонецЦикла; 
	
	Запрос.УстановитьПараметр("ИсчисленныеОПВ", ТаблицаДляВычетовИПН);


	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаОПВ.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ТаблицаОПВ.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ТаблицаОПВ.Подразделение КАК Подразделение,
		|	ТаблицаОПВ.ВидДохода КАК ВидДохода,
		|	ТаблицаОПВ.ОбъектИсчисленияОПВ КАК ОбъектИсчисленияОПВ,
		|	ТаблицаОПВ.ИсчисленныеОПВ КАК ИсчисленныеОПВ
		|ПОМЕСТИТЬ ВТИсчисленныеОПВПоПодразделениям
		|ИЗ
		|	&ИсчисленныеОПВ КАК ТаблицаОПВ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеОПВПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеОПВПоПодразделениям.ОбъектИсчисленияОПВ) КАК ОбъектИсчисленияОПВ,
		|	СУММА(ВТИсчисленныеОПВПоПодразделениям.ИсчисленныеОПВ) КАК ИсчисленныеОПВ
		|ПОМЕСТИТЬ ВТИсчисленныеОПВ
		|ИЗ
		|	ВТИсчисленныеОПВПоПодразделениям КАК ВТИсчисленныеОПВПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеОПВПоПодразделениям.ВидДохода
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ВТИсчисленныеОПВПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВПоПодразделениям.ВидДохода";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеОПВПоПодразделениям");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьОПВПосле2026(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос();
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ИсключаемыйРегистратор", ?(ИсключатьДоходыРегистратора, Регистратор, Неопределено));
	
	// Исключаемые физические лица
	СоздатьВТИсключаемыеФизическиеЛицаПриРасчетеОПВ(МенеджерВременныхТаблиц, МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеОПВ");
	
	ВидНалогаВзносаОПВ =  Перечисления.ВидыНалоговВзносовОтчислений.ОПВ;
	
	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);

	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходыПосле2023(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ, "ВТИсключаемыеФизическиеЛицаПриРасчетеОПВ");
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");   
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ОПВ
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаОПВ);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");

	// - Размер органичения доходов, облагаемых ОПВ по периодам
	// - Исчисленные ОПВ
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 50 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	ЕСТЬNULL(СтавкиОПВ.Ставка, 0) КАК Ставка,
		|	ВЫБОР
		|		КОГДА Доходы.МесяцНалоговогоПериода < ДАТАВРЕМЯ(2023, 7, 1)
		|			ТОГДА ВЫБОР
		|					КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|						ТОГДА МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода, 0))
		|					ИНАЧЕ 0
		|				КОНЕЦ
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК МинимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(ЕСТЬNULL(РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода, 0)) КАК МаксимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(Доходы.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	МАКСИМУМ(ВЫБОР КОГДА ДругиеВидыДоходов.ВидДохода ЕСТЬ NULL ТОГДА ЛОЖЬ ИНАЧЕ ИСТИНА КОНЕЦ) КАК ЕстьНесколькоВидовДоходов,
		|	0 КАК ОбъектИсчисленияОПВ,
		|	0 КАК ИсчисленныеОПВ
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДоходы КАК ДругиеВидыДоходов
		|		ПО ДругиеВидыДоходов.МесяцНалоговогоПериода = Доходы.МесяцНалоговогоПериода
		|			И ДругиеВидыДоходов.ФизическоеЛицо = Доходы.ФизическоеЛицо
		|			И НЕ ДругиеВидыДоходов.ВидДохода = Доходы.ВидДохода
		|			И НЕ ДругиеВидыДоходов.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиОПВ
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОПВ.МесяцНалоговогоПериода
		|			И (СтавкиОПВ.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ОПВ))
		|			И Доходы.ВидДохода = СтавкиОПВ.ВидДохода
		|	
		|СГРУППИРОВАТЬ ПО
		|	Доходы.МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо,
		|	Доходы.ВидДохода,
		|	ЕСТЬNULL(СтавкиОПВ.Ставка, 0)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Доходы.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеОПВПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеОПВПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеОПВПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления КАК ОбъектОПВИсчисленныйРанее,
		|	ИсчисленныеОПВПоПодразделениям.НалогВзнос КАК РанееИсчисленныеОПВ,
		|	-ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеОПВПоПодразделениям.НалогВзнос КАК ИсчисленныеОПВ,
		|	-ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияОПВ
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеОПВПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеОПВПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеОПВПоПодразделениям.НалогВзнос <> 0)
		|	И НЕ ИсчисленныеОПВПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)";
		
	Результат = Запрос.ВыполнитьПакет();
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеОПВПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	РезультатЗапроса.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатЗапроса.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатЗапроса.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатЗапроса.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатЗапроса.Колонки.Добавить("МаксимальныйРазмерОрганиченияДохода", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ОбъектИсчисленияОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИсчисленныеОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаДляОбработки = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам = Новый ТаблицаЗначений;
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ОбъектИсчисления", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Индексы.Добавить("ФизическоеЛицо, МесяцНалоговогоПериода");
	
	СтруктураПоискаПоФизЛицам = Новый Структура("ФизическоеЛицо, МесяцНалоговогоПериода");

	Для Каждого СтрокаТаблицы Из ТаблицаДляОбработки Цикл
		
		ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
		
		// корректируем максимальный доход только в окончательном расчете, если есть несколько видов дохода в месяце начисления
		НеобходимаКорректировкаМакисмальногоОграничения = ОкончательныйРасчет И СтрокаТаблицы.ЕстьНесколькоВидовДоходов;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			ЗаполнитьЗначенияСвойств(СтруктураПоискаПоФизЛицам, СтрокаТаблицы);

			// сумма взносов исчисленная
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			
			Если МассивВзносов.Количество() > 0 Тогда
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = МассивВзносов[0].ОбъектИсчисления;
			Иначе
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			КонецЕсли;
			
		Иначе
			
			ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			
		КонецЕсли;
		
		МаксимальныйРазмерОрганиченияДохода = СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода - ОбъектИсчисленияПоДругимВидамВДанномРасчете;
		МинимальныйРазмерОрганиченияДохода = СтрокаТаблицы.МинимальныйРазмерОрганиченияДохода;
	
		Если СтрокаТаблицы.ОблагаемыйДоход < 0 Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияОПВ = 0;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход < МинимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияОПВ = МинимальныйРазмерОрганиченияДохода;
			
		ИначеЕсли СтрокаТаблицы.ОблагаемыйДоход < МаксимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияОПВ = СтрокаТаблицы.ОблагаемыйДоход;
			
		Иначе
			
			СтрокаТаблицы.ОбъектИсчисленияОПВ = МаксимальныйРазмерОрганиченияДохода;
			
		КонецЕсли;
		
		СтрокаТаблицы.ИсчисленныеОПВ = СтрокаТаблицы.ОбъектИсчисленияОПВ * СтрокаТаблицы.Ставка;

        // сначала применим округление к сумме ИПН, после чего распределим ниже (ранее округление выполнялось после распределения, что приводило к погрешностям расчета)
		СтрокаТаблицы.ИсчисленныеОПВ = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТаблицы.ИсчисленныеОПВ, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			Если МассивВзносов.Количество() > 0 Тогда
				СтрокаВзносовТаблицаВзносовПоФизЛицам = МассивВзносов[0];
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления + СтрокаТаблицы.ОбъектИсчисленияОПВ;
			Иначе
				СтрокаВзносовТаблицаВзносовПоФизЛицам = ТаблицаВзносовПоФизЛицамПоДругимДоходам.Добавить();
				СтрокаВзносовТаблицаВзносовПоФизЛицам.МесяцНалоговогоПериода = СтрокаТаблицы.МесяцНалоговогоПериода;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ФизическоеЛицо = СтрокаТаблицы.ФизическоеЛицо;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаТаблицы.ОбъектИсчисленияОПВ;
			КонецЕсли;
			
		КонецЕсли;

	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаДляОбработки, РезультатЗапроса);
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеОПВВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияОПВВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектОПВИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеОПВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
	
	Если ТочностьОкругления = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругления <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;
			
	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияОПВ,ИсчисленныеОПВ", ТочностьРаспределения);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеОПВПоПодразделениям, РезультатыРасчетов);

	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0 
			И (СтрокаТЗ.ИсчисленныеОПВ < 1 И СтрокаТЗ.ИсчисленныеОПВ > 0
				ИЛИ СтрокаТЗ.ИсчисленныеОПВ > -1 И СтрокаТЗ.ИсчисленныеОПВ < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеОПВ = 0;
			
		КонецЕсли;
		
	КонецЦикла; 

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияОПВВЦеломЗаПериод, 	ИсчисленныеОПВВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектОПВИсчисленныйРанее, 			РанееИсчисленныеОПВ,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход, 					ОбъектИсчисленияОПВ, 				ИсчисленныеОПВ");
								
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	
	НомерСтроки = 0;
	
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
	КонецЦикла; 
	
	// для вычетов ИПН передаем общую таблицу округленных сумм
	ТаблицаДляВычетовИПН = РезультатыРасчетов.Скопировать(, "МесяцНалоговогоПериода, ФизическоеЛицо, Подразделение, ВидДохода, ОблагаемыйДоход, ИсчисленныеОПВВЦеломЗаПериод");
	
	Для каждого СтрокаТЗ Из ТаблицаДляВычетовИПН Цикл
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0 
			И (СтрокаТЗ.ИсчисленныеОПВВЦеломЗаПериод < 1 И СтрокаТЗ.ИсчисленныеОПВВЦеломЗаПериод > 0
				ИЛИ СтрокаТЗ.ИсчисленныеОПВВЦеломЗаПериод > -1 И СтрокаТЗ.ИсчисленныеОПВВЦеломЗаПериод < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеОПВВЦеломЗаПериод = 0;
			
		КонецЕсли;
	КонецЦикла; 
	
	Запрос.УстановитьПараметр("ИсчисленныеОПВ", ТаблицаДляВычетовИПН);


	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаОПВ.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ТаблицаОПВ.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ТаблицаОПВ.Подразделение КАК Подразделение,
		|	ТаблицаОПВ.ВидДохода КАК ВидДохода,
		|	ТаблицаОПВ.ИсчисленныеОПВВЦеломЗаПериод КАК ИсчисленныеОПВ
		|ПОМЕСТИТЬ ВТИсчисленныеОПВПоПодразделениям
		|ИЗ
		|	&ИсчисленныеОПВ КАК ТаблицаОПВ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеОПВПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеОПВПоПодразделениям.ИсчисленныеОПВ) КАК ИсчисленныеОПВ
		|ПОМЕСТИТЬ ВТИсчисленныеОПВ
		|ИЗ
		|	ВТИсчисленныеОПВПоПодразделениям КАК ВТИсчисленныеОПВПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеОПВПоПодразделениям.ВидДохода
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ВТИсчисленныеОПВПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеОПВПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеОПВПоПодразделениям.ВидДохода";
	
	Запрос.Выполнить();
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьИПН(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт

	Если МесяцНачисления >= Дата(2026,1,1) Тогда
		РезультатыРасчетов = РассчитатьИПНПосле2026(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет, ИсключатьДоходыРегистратора);
	ИначеЕсли МесяцНачисления >= Дата(2025,1,1) Тогда
		РезультатыРасчетов = РассчитатьИПНПосле2025(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет, ИсключатьДоходыРегистратора);
	ИначеЕсли МесяцНачисления >= Дата(2023,1,1) Тогда
		РезультатыРасчетов = РассчитатьИПНПосле2023(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет, ИсключатьДоходыРегистратора);
	ИначеЕсли МесяцНачисления >= Дата(2021,1,1) Тогда
		РезультатыРасчетов = РассчитатьИПНПосле2021(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет, ИсключатьДоходыРегистратора);
	ИначеЕсли МесяцНачисления >= Дата(2020,1,1) Тогда
		РезультатыРасчетов = РассчитатьИПНПосле2020(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет, ИсключатьДоходыРегистратора);
	ИначеЕсли МесяцНачисления >= Дата(2019,1,1) Тогда
		РезультатыРасчетов = РассчитатьИПНПосле2019(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет, ИсключатьДоходыРегистратора);
	ИначеЕсли МесяцНачисления >= Дата(2018,1,1) Тогда
		РезультатыРасчетов = РассчитатьИПНПосле2018(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет, ИсключатьДоходыРегистратора);
	Иначе
		РезультатыРасчетов = РассчитатьИПНДо2018(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет, ИсключатьДоходыРегистратора);
	КонецЕсли;
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьИПНДо2018(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	ВидНалогаВзносаИПН =  Перечисления.ВидыНалоговВзносовОтчислений.ИПН;
	ПрименятьКорректировкуПрочихНалоговВзносовОтчислений = ЗарплатаКадрыРКПовтИсп.ПрименятьКорректировкуПрочихНалоговВзносовОтчислений(ЗарплатаКадрыПовтИсп.ГоловнаяОрганизация(Организация), МесяцНачисления);
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаИПН);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");   
	
	// Таблица ВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленного ИПН
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаИПН);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");   

	// Таблица ВТЛьготыФизическихЛиц
	СоздатьВТЛьготыФизическихЛиц(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТЛьготыФизическихЛиц");   
	
	// Таблица ВТПредоставлениеВычетовФизическимЛицам ВТПрименениеВычетов
	СоздатьВТПредоставлениеВычетовФизическимЛицам(МенеджерВременныхТаблиц, Организация);
	УничтожитьВТ.Добавить("ВТПредоставлениеВычетовФизическимЛицам");   
	УничтожитьВТ.Добавить("ВТПрименениеВычетов");   
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.НеоблагаемыйДоход) КАК НеоблагаемыйДоход,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.НалогВзнос) КАК НалогВзнос,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.ОбъектИсчисления) КАК ОбъектИсчисления,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.ПримененныйВычет) КАК ПримененныйВычет,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.РазрешенныйВычет) КАК РазрешенныйВычет,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.ПримененнаяЛьгота) КАК ПримененнаяЛьгота,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.ПрочиеВычеты) КАК ПрочиеВычеты,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.ПримененныйВычетСНачалаГода) КАК ПримененныйВычетСНачалаГода,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.РазрешенныйВычетСНачалаГода) КАК РазрешенныйВычетСНачалаГода,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.ПримененнаяЛьготаСНачалаГода) КАК ПримененнаяЛьготаСНачалаГода
		|ПОМЕСТИТЬ ВТИсчисленныеНалогиВзносы
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ВТИсчисленныеНалогиВзносыПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.ВидДохода";
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносы");   
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	// Ставки ИПН
	СоздатьВТСтавкиИПН(Организация, МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтавкиИПН");   

	// Прочие вычеты физических лиц
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Периоды.МесяцНалоговогоПериода,
		|	МАКСИМУМ(ПрочиеВычетыФизическихЛицИПН.Период) КАК Период,
		|	ПрочиеВычетыФизическихЛицИПН.ФизическоеЛицо,
		|	ПрочиеВычетыФизическихЛицИПН.ВидВычета
		|ПОМЕСТИТЬ ВТПериодыПрочихВычетов
		|ИЗ
		|	ВТПериодыПоФизлицам КАК Периоды
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПрочиеВычетыФизическихЛицИПН КАК ПрочиеВычетыФизическихЛицИПН
		|		ПО Периоды.МесяцНалоговогоПериода >= ПрочиеВычетыФизическихЛицИПН.Период
		|			И Периоды.ФизическоеЛицо = ПрочиеВычетыФизическихЛицИПН.ФизическоеЛицо
		|
		|СГРУППИРОВАТЬ ПО
		|	Периоды.МесяцНалоговогоПериода,
		|	ПрочиеВычетыФизическихЛицИПН.ФизическоеЛицо,
		|	ПрочиеВычетыФизическихЛицИПН.ВидВычета
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПериодыПрочихВычетов.МесяцНалоговогоПериода,
		|	ПериодыПрочихВычетов.ФизическоеЛицо,
		|	СУММА(ПрочиеВычетыФизическихЛицИПН.Размер) КАК Размер
		|ПОМЕСТИТЬ ВТПрочиеВычетыФизическихЛиц
		|ИЗ
		|	ВТПериодыПрочихВычетов КАК ПериодыПрочихВычетов
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПрочиеВычетыФизическихЛицИПН КАК ПрочиеВычетыФизическихЛицИПН
		|		ПО ПериодыПрочихВычетов.Период = ПрочиеВычетыФизическихЛицИПН.Период
		|			И ПериодыПрочихВычетов.ФизическоеЛицо = ПрочиеВычетыФизическихЛицИПН.ФизическоеЛицо
		|			И ПериодыПрочихВычетов.ВидВычета = ПрочиеВычетыФизическихЛицИПН.ВидВычета
		|			И ПрочиеВычетыФизическихЛицИПН.Активность
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПрименениеВычетов КАК ПрименениеВычетов
		|		ПО ПериодыПрочихВычетов.МесяцНалоговогоПериода = ПрименениеВычетов.МесяцНалоговогоПериода
		|			И ПериодыПрочихВычетов.ФизическоеЛицо = ПрименениеВычетов.ФизическоеЛицо
		|ГДЕ
		|	ПрочиеВычетыФизическихЛицИПН.ДействуетПо >= ПериодыПрочихВычетов.МесяцНалоговогоПериода
		|
		|СГРУППИРОВАТЬ ПО
		|	ПериодыПрочихВычетов.МесяцНалоговогоПериода,
		|	ПериодыПрочихВычетов.ФизическоеЛицо";
		
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТПериодыПрочихВычетов");   
	УничтожитьВТ.Добавить("ВТПрочиеВычетыФизическихЛиц");   
	
	Если НЕ ВТСуществует(МенеджерВременныхТаблиц,"ВТИсчисленныеОПВ") Тогда
		Запрос.Текст =
			"ВЫБРАТЬ
			|	NULL КАК МесяцНалоговогоПериода,
			|	NULL КАК ФизическоеЛицо,
			|	NULL КАК ВидДохода,
			|	0 КАК ОбъектИсчисленияОПВ,
			|	0 КАК ИсчисленныеОПВ
			|ПОМЕСТИТЬ ВТИсчисленныеОПВ";
		Запрос.Выполнить();
	КонецЕсли;
	
	Если НЕ ВТСуществует(МенеджерВременныхТаблиц,"ВТИсчисленныеВОСМС") 
		И НЕ ПрименятьКорректировкуПрочихНалоговВзносовОтчислений Тогда
		Запрос.Текст =
			"ВЫБРАТЬ
			|	NULL КАК МесяцНалоговогоПериода,
			|	NULL КАК ФизическоеЛицо,
			|	NULL КАК ВидДохода,
			|	0 КАК ИсчисленныеВОСМС
			|ПОМЕСТИТЬ ВТИсчисленныеВОСМС";
		Запрос.Выполнить();
	КонецЕсли;
	
	// Финальный запрос	
	Запрос.Текст = 	
		"ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(СтатусыФизическихЛицКакНалогоплательщиков.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)) = ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)
		|			ТОГДА ЕСТЬNULL(СтавкиИПН.СтавкаРезиденты, 0)
		|		ИНАЧЕ ЕСТЬNULL(СтавкиИПН.СтавкаНерезиденты, 0)
		|	КОНЕЦ КАК СтавкаИПН,
		|	Доходы.ОблагаемыйДоход КАК ОблагаемыйДоходВЦеломЗаПериод,
		|	Доходы.НеоблагаемыйДоход КАК НеоблагаемыйДоходВЦеломЗаПериод,
		|	// Корректировка облагаемого дохода
		|	ЕСТЬNULL(ПредоставлениеВычетовФизическимЛицам.РазмерСтандартногоВычета, 0) КАК РазмерСтандартногоВычета,
		|	ЕСТЬNULL(ПредоставлениеВычетовФизическимЛицам.ЕстьЗаявлениеНаВычет, ЛОЖЬ) КАК ЕстьЗаявлениеНаВычет,
		|	ЕСТЬNULL(ПредоставлениеВычетовФизическимЛицам.ПредоставлятьВычет, ЛОЖЬ) КАК ПредоставлятьВычет,
		|	ЕСТЬNULL(ПредоставлениеВычетовФизическимЛицам.КалендарныхДнейРаботы, 0) КАК КалендарныхДнейРаботы,
		|	ЕСТЬNULL(ЛьготыФизическихЛиц.РазмерЛьготы, 0) КАК РазмерЛьготы,
		|	ЕСТЬNULL(ЛьготыФизическихЛиц.КатегорияЛицаПолучателяЛьготы, ЗНАЧЕНИЕ(Справочник.КатегорииЛицПолучателейЛьготИПН.ПустаяСсылка)) КАК КатегорияЛицаПолучателяЛьготы,
		|	ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) КАК ИсчисленныеОПВ,
		|	" + ?(ПрименятьКорректировкуПрочихНалоговВзносовОтчислений, "0", "ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0)") + " КАК ИсчисленныеВОСМС,
		|	ЕСТЬNULL(ПрочиеВычетыФизическихЛиц.Размер, 0) КАК ПрочиеВычетыВЦеломЗаПериод,
		|	// Исчисленные ранее показатели
		|	ЕСТЬNULL(ИсчисленныйИПНРанее.ПримененныйВычет, 0) КАК ПримененныйВычетИсчисленныйРанее,
		|	ЕСТЬNULL(ИсчисленныйИПНРанее.РазрешенныйВычет, 0) КАК РазрешенныйВычетИсчисленныйРанее,
		|	ЕСТЬNULL(ИсчисленныйИПНРанее.ПримененнаяЛьгота, 0) КАК ПримененнаяЛьготаИсчисленнаяРанее,
		|	ЕСТЬNULL(ИсчисленныйИПНРанее.ПрочиеВычеты, 0) КАК ПрочиеВычетыИсчисленныеРанее,
		|	ЕСТЬNULL(ИсчисленныйИПНРанее.ПримененныйВычетСНачалаГода, 0) КАК ПримененныйВычетСНачалаГода,
		|	ЕСТЬNULL(ИсчисленныйИПНРанее.РазрешенныйВычетСНачалаГода, 0) КАК РазрешенныйВычетСНачалаГода,
		|	ЕСТЬNULL(ИсчисленныйИПНРанее.ПримененнаяЛьготаСНачалаГода, 0) КАК ПримененнаяЛьготаСНачалаГода
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиИПН КАК СтавкиИПН
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиИПН.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиИПН.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтатусыФизическихЛицКакНалогоплательщиков КАК СтатусыФизическихЛицКакНалогоплательщиков
		|		ПО Доходы.МесяцНалоговогоПериода = СтатусыФизическихЛицКакНалогоплательщиков.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = СтатусыФизическихЛицКакНалогоплательщиков.ФизическоеЛицо
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеОПВ КАК ИсчисленныеОПВПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеОПВПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеОПВПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеОПВПоПериодам.ВидДохода
		|" + ?(ПрименятьКорректировкуПрочихНалоговВзносовОтчислений, "", "
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеВОСМС КАК ИсчисленныеВОСМСПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеВОСМСПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеВОСМСПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеВОСМСПоПериодам.ВидДохода") + "
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТПредоставлениеВычетовФизическимЛицам КАК ПредоставлениеВычетовФизическимЛицам
		|		ПО Доходы.МесяцНалоговогоПериода = ПредоставлениеВычетовФизическимЛицам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ПредоставлениеВычетовФизическимЛицам.ФизическоеЛицо
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТЛьготыФизическихЛиц КАК ЛьготыФизическихЛиц
		|		ПО Доходы.МесяцНалоговогоПериода = ЛьготыФизическихЛиц.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ЛьготыФизическихЛиц.ФизическоеЛицо
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТПрочиеВычетыФизическихЛиц КАК ПрочиеВычетыФизическихЛиц
		|		ПО Доходы.МесяцНалоговогоПериода = ПрочиеВычетыФизическихЛиц.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ПрочиеВычетыФизическихЛиц.ФизическоеЛицо
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеНалогиВзносы КАК ИсчисленныйИПНРанее
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныйИПНРанее.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныйИПНРанее.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныйИПНРанее.ВидДохода
		|
		|УПОРЯДОЧИТЬ ПО
		|	ФизическоеЛицо,
		|	МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныйИПНПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныйИПНПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныйИПНПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныйИПНПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныйИПНПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйИПНПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйИПНПоПодразделениям.ОбъектИсчисления КАК ОбъектИПНВИсчисленныйРанее,
		|	ИсчисленныйИПНПоПодразделениям.НалогВзнос КАК ИПНИсчисленныйРанее,
		|	ИсчисленныйИПНПоПодразделениям.ПримененныйВычет КАК ПримененныйВычетИсчисленныйРанее,
		|	ИсчисленныйИПНПоПодразделениям.РазрешенныйВычет КАК РазрешенныйВычетИсчисленныйРанее,
		|	ИсчисленныйИПНПоПодразделениям.ПримененнаяЛьгота КАК ПримененнаяЛьготаИсчисленнаяРанее,
		|	ИсчисленныйИПНПоПодразделениям.ПрочиеВычеты КАК ПрочиеВычетыИсчисленныеРанее,
		|	-ИсчисленныйИПНПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныйИПНПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныйИПНПоПодразделениям.НалогВзнос КАК ИсчисленныйИПН,
		|	-ИсчисленныйИПНПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияИПН,
		|	-ИсчисленныйИПНПоПодразделениям.ПримененныйВычет КАК ПримененныйВычет,
		|	-ИсчисленныйИПНПоПодразделениям.РазрешенныйВычет КАК РазрешенныйВычет,
		|	-ИсчисленныйИПНПоПодразделениям.ПримененнаяЛьгота КАК ПримененнаяЛьгота,
		|	-ИсчисленныйИПНПоПодразделениям.ПрочиеВычеты КАК ПрочиеВычеты
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныйИПНПоПодразделениям";
		
	Результат = Запрос.ВыполнитьПакет();
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныйИПНПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	Выборка = Результат[ВсегоРезультатов - 3].Выбрать();

	КвалификаторЧисла = Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15,2));
	ВспомогательнаяТаблицаРасчета = Новый ТаблицаЗначений;
	ВспомогательнаяТаблицаРасчета.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	ВспомогательнаяТаблицаРасчета.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	ВспомогательнаяТаблицаРасчета.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	ВспомогательнаяТаблицаРасчета.Колонки.Добавить("ОбъектИсчисленияИПН", КвалификаторЧисла);
	ВспомогательнаяТаблицаРасчета.Колонки.Добавить("ИсчисленныйИПН", КвалификаторЧисла);
	ВспомогательнаяТаблицаРасчета.Колонки.Добавить("ПримененныйВычет", КвалификаторЧисла);
	ВспомогательнаяТаблицаРасчета.Колонки.Добавить("РазрешенныйВычет", КвалификаторЧисла);
	ВспомогательнаяТаблицаРасчета.Колонки.Добавить("ПримененнаяЛьгота", КвалификаторЧисла);
	ВспомогательнаяТаблицаРасчета.Колонки.Добавить("ПрочиеВычеты", КвалификаторЧисла);
	
	РезультатыРасчетов = ВспомогательнаяТаблицаРасчета.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", КвалификаторЧисла);
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", КвалификаторЧисла);      
	
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", КвалификаторЧисла);
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", КвалификаторЧисла);
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияИПНВЦеломЗаПериод", КвалификаторЧисла);
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныйИПНВЦеломЗаПериод", КвалификаторЧисла);
	РезультатыРасчетов.Колонки.Добавить("ПримененныйВычетВЦеломЗаПериод", КвалификаторЧисла);
	РезультатыРасчетов.Колонки.Добавить("РазрешенныйВычетВЦеломЗаПериод", КвалификаторЧисла);
	РезультатыРасчетов.Колонки.Добавить("ПримененнаяЛьготаВЦеломЗаПериод", КвалификаторЧисла);   
	РезультатыРасчетов.Колонки.Добавить("ПрочиеВычетыВЦеломЗаПериод", КвалификаторЧисла);
	
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", КвалификаторЧисла);
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", КвалификаторЧисла);
	РезультатыРасчетов.Колонки.Добавить("ОбъектИПНИсчисленныйРанее", КвалификаторЧисла);
	РезультатыРасчетов.Колонки.Добавить("ИПНИсчисленныйРанее", КвалификаторЧисла);
	РезультатыРасчетов.Колонки.Добавить("ПримененныйВычетИсчисленныйРанее", КвалификаторЧисла);
	РезультатыРасчетов.Колонки.Добавить("РазрешенныйВычетИсчисленныйРанее", КвалификаторЧисла);
	РезультатыРасчетов.Колонки.Добавить("ПримененнаяЛьготаИсчисленнаяРанее", КвалификаторЧисла);
	РезультатыРасчетов.Колонки.Добавить("ПрочиеВычетыИсчисленныеРанее", КвалификаторЧисла);

	ТекущееФизическоеЛицо = Неопределено;
	ПримененнаяЛьготаВТекущемРасчете = 0;
	ПримененныйВычетВТекущемРасчете = 0;
	РазрешенныйВычетВТекущемРасчете = 0;
	
	Пока Выборка.Следующий() Цикл
		
		Если ТекущееФизическоеЛицо <> Выборка.ФизическоеЛицо Тогда
			ТекущееФизическоеЛицо = Выборка.ФизическоеЛицо;
			ПримененнаяЛьготаВТекущемРасчете = 0;
			ПримененныйВычетВТекущемРасчете = 0;
			РазрешенныйВычетВТекущемРасчете = 0;
		КонецЕсли;
		
		СтрокаРасчета = ВспомогательнаяТаблицаРасчета.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаРасчета, Выборка, "ФизическоеЛицо, ВидДохода, МесяцНалоговогоПериода");
		// Льгота
		ОстатокЛьготы 					 = Выборка.РазмерЛьготы - Выборка.ПримененнаяЛьготаСНачалаГода + Выборка.ПримененнаяЛьготаИсчисленнаяРанее - ПримененнаяЛьготаВТекущемРасчете;
		Если ОстатокЛьготы > 0 И Выборка.ОблагаемыйДоходВЦеломЗаПериод > 0 Тогда
			СтрокаРасчета.ПримененнаяЛьгота	 = Мин(ОстатокЛьготы, Выборка.ОблагаемыйДоходВЦеломЗаПериод);
		Иначе
			СтрокаРасчета.ПримененнаяЛьгота = 0;
		КонецЕсли;
		
		ПримененнаяЛьготаВТекущемРасчете = ПримененнаяЛьготаВТекущемРасчете + СтрокаРасчета.ПримененнаяЛьгота - Выборка.ПримененнаяЛьготаИсчисленнаяРанее;
		
		Если Выборка.ВидДохода = Справочники.ВидыДоходов.ДоходыОтРаботодателя Тогда 
			// Стандартный вычет
			СтрокаРасчета.РазрешенныйВычет				 	= Выборка.РазмерСтандартногоВычета;
			ОстатокВычета 									= (Выборка.РазрешенныйВычетСНачалаГода - Выборка.РазрешенныйВычетИсчисленныйРанее) 
															- (Выборка.ПримененныйВычетСНачалаГода - Выборка.ПримененныйВычетИсчисленныйРанее) 
															+ (РазрешенныйВычетВТекущемРасчете + Выборка.РазмерСтандартногоВычета - ПримененныйВычетВТекущемРасчете);
			ОблагаемыйДоход 								= Макс(Выборка.ОблагаемыйДоходВЦеломЗаПериод - СтрокаРасчета.ПримененнаяЛьгота - Выборка.ИсчисленныеОПВ, 0);
			СтрокаРасчета.ПримененныйВычет				 	= Мин(ОстатокВычета, ОблагаемыйДоход);
			РазрешенныйВычетВТекущемРасчете					= РазрешенныйВычетВТекущемРасчете + СтрокаРасчета.РазрешенныйВычет;
			ПримененныйВычетВТекущемРасчете 				= ПримененныйВычетВТекущемРасчете + СтрокаРасчета.ПримененныйВычет;
			
			// Прочие вычеты                                
			СтрокаРасчета.ПрочиеВычеты						= Выборка.ПрочиеВычетыВЦеломЗаПериод;
			
			// ОбъектИсчисления
			СтрокаРасчета.ОбъектИсчисленияИПН				= Макс(Выборка.ОблагаемыйДоходВЦеломЗаПериод 
															- СтрокаРасчета.ПримененнаяЛьгота 
															- Выборка.ИсчисленныеОПВ 
															- СтрокаРасчета.ПримененныйВычет 
															- СтрокаРасчета.ПрочиеВычеты, 0);
		Иначе
			// ОбъектИсчисления
			СтрокаРасчета.ОбъектИсчисленияИПН				= Макс(Выборка.ОблагаемыйДоходВЦеломЗаПериод - СтрокаРасчета.ПримененнаяЛьгота, 0);
		КонецЕсли;
		// Корректировку на сумму взносов ОСМС выполняем последней
		СтрокаРасчета.ОбъектИсчисленияИПН					= Макс(СтрокаРасчета.ОбъектИсчисленияИПН - Выборка.ИсчисленныеВОСМС, 0);	
		
		// ИПН
		СтрокаРасчета.ИсчисленныйИПН			 			= СтрокаРасчета.ОбъектИсчисленияИПН * Выборка.СтавкаИПН;
		
	КонецЦикла;
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из ВспомогательнаяТаблицаРасчета Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияИПН,ИсчисленныйИПН,ПримененнаяЛьгота,РазрешенныйВычет,ПримененныйВычет,ПрочиеВычеты");
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныйИПНПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод,   НеоблагаемыйДоходВЦеломЗаПериод, 	 ОбъектИсчисленияИПНВЦеломЗаПериод, ИсчисленныйИПНВЦеломЗаПериод, ПримененнаяЛьготаВЦеломЗаПериод,   РазрешенныйВычетВЦеломЗаПериод,   ПримененныйВычетВЦеломЗаПериод,   ПрочиеВычетыВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, НеоблагаемыйДоходИсчисленныйРанее, ОбъектИПНИсчисленныйРанее, 		ИПНИсчисленныйРанее, 		  ПримененнаяЛьготаИсчисленнаяРанее, РазрешенныйВычетИсчисленныйРанее, ПримененныйВычетИсчисленныйРанее, ПрочиеВычетыИсчисленныеРанее,
								|ОблагаемыйДоход, 				  НеоблагаемыйДоход, 				 ОбъектИсчисленияИПН, 				ИсчисленныйИПН, 			  ПримененнаяЛьгота, 			     РазрешенныйВычет, 		   ПримененныйВычет, 		     ПрочиеВычеты");

								
								
	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаИПН);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);

	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		НомерСтроки = НомерСтроки + 1;
		СтрокаТЗ.НомерСтроки = НомерСтроки;
		СтрокаТЗ.ИсчисленныйИПН = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныйИПН, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
	КонецЦикла;
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьИПНПосле2018(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт

	УдалитьВТ = Новый Массив;
	
	ВидНалогаВзносаИПН =  Перечисления.ВидыНалоговВзносовОтчислений.ИПН;
	
	// Получаем применение вычета в месяц отсутствия дохода
	УчетнаяПолитикаНУ = РегистрыСведений.УчетнаяПолитикаПоНалоговомуУчету.СрезПоследних(МесяцНачисления, Новый Структура("Организация", Организация));
	ПредоставлятьВычетВМесяцеОтсутствияДохода = Ложь;
	Если УчетнаяПолитикаНУ.Количество() > 0 Тогда
		ПредоставлятьВычетВМесяцеОтсутствияДохода = УчетнаяПолитикаНУ[0].ПредоставлятьВычетВМесяцеОтсутствияДохода;
		//И ТипЗнч(Регистратор) = Тип("ДокументСсылка.НачислениеЗарплаты");
	КонецЕсли;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаИПН);
	УдалитьВТ.Добавить("ВТДоходы");
	УдалитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленного ИПН
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаИПН, ПредоставлятьВычетВМесяцеОтсутствияДохода);
	УдалитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// Таблица ВТДанныеДляРасчетаВычетовИПН
	СоздатьВТДанныеДляРасчетаВычетовИПН(МенеджерВременныхТаблиц, Организация, ПредоставлятьВычетВМесяцеОтсутствияДохода, МесяцНачисления);
	УдалитьВТ.Добавить("ВТДанныеДляРасчетаВычетовИПН");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	
	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		Запрос.Текст ="ВЫБРАТЬ
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	Доходы.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	Доходы.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ПОМЕСТИТЬ ВТДоходыОбъединенная
		|ИЗ
		|	ВТДоходы КАК Доходы
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТСотрудникиОрганизацииБезДохода.ФизическоеЛицо,
		|	ВТСотрудникиОрганизацииБезДохода.МесяцНалоговогоПериода,
		|	ВТСотрудникиОрганизацииБезДохода.ВидДохода,
		|	ВТСотрудникиОрганизацииБезДохода.ОблагаемыйДоход,
		|	ВТСотрудникиОрганизацииБезДохода.НеоблагаемыйДоход
		|ИЗ
		|	ВТСотрудникиОрганизацииБезДохода КАК ВТСотрудникиОрганизацииБезДохода";
		Запрос.Выполнить();
		УдалитьВТ.Добавить("ВТДоходыОбъединенная");
	КонецЕсли;
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.НеоблагаемыйДоход) КАК НеоблагаемыйДоход,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.НалогВзнос) КАК НалогВзнос,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.ОбъектИсчисления) КАК ОбъектИсчисления
		|ПОМЕСТИТЬ ВТИсчисленныеНалогиВзносы
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ВТИсчисленныеНалогиВзносыПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.ВидДохода";
	Запрос.Выполнить();
	УдалитьВТ.Добавить("ВТИсчисленныеНалогиВзносы");
	
	// Статусы физических лиц как налогоплательщиков по периодам
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(СтатусФизическихЛицКакНалогоплательщиков.Период) КАК ПериодСтатуса,
		|	СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо,
		|	ПериодыРасчета.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода
		|ПОМЕСТИТЬ ВТПериодыСтатусов
		|ИЗ
		|	ВТПериодыПоФизлицам КАК ПериодыРасчета
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусФизическихЛицКакНалогоплательщиков КАК СтатусФизическихЛицКакНалогоплательщиков
		|		ПО ПериодыРасчета.МесяцНалоговогоПериода >= СтатусФизическихЛицКакНалогоплательщиков.Период
		|			И ПериодыРасчета.ФизическоеЛицо = СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо
		|
		|СГРУППИРОВАТЬ ПО
		|	СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо,
		|	ПериодыРасчета.МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПериодыСтатусов.МесяцНалоговогоПериода,
		|	ПериодыСтатусов.ФизическоеЛицо,
		|	СтатусФизическихЛицКакНалогоплательщиков.Статус
		|ПОМЕСТИТЬ ВТСтатусыФизическихЛицКакНалогоплательщиков
		|ИЗ
		|	ВТПериодыСтатусов КАК ПериодыСтатусов
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусФизическихЛицКакНалогоплательщиков КАК СтатусФизическихЛицКакНалогоплательщиков
		|		ПО ПериодыСтатусов.ПериодСтатуса = СтатусФизическихЛицКакНалогоплательщиков.Период
		|			И ПериодыСтатусов.ФизическоеЛицо = СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо";
	
	Запрос.Выполнить();
	УдалитьВТ.Добавить("ВТПериодыСтатусов");
	УдалитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	// Ставки ИПН
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	1 КАК Приоритет,
		|	МАКСИМУМ(ЕСТЬNULL(СведенияОСтавкахИПН.Период, ДАТАВРЕМЯ(1, 1, 1))) КАК ПериодСтавки,
		|	ПериодыРасчета.Период КАК МесяцНалоговогоПериода,
		|	СведенияОСтавкахИПН.Организация КАК Организация,
		|	СведенияОСтавкахИПН.ВидДохода
		|ПОМЕСТИТЬ ВТПериодыСтавокИПН
		|ИЗ
		|	ВТДатыПоМесяцам КАК ПериодыРасчета
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОСтавкахИПН КАК СведенияОСтавкахИПН
		|		ПО ПериодыРасчета.Период >= СведенияОСтавкахИПН.Период
		|ГДЕ
		|	СведенияОСтавкахИПН.Организация = &Организация
		|
		|СГРУППИРОВАТЬ ПО
		|	ПериодыРасчета.Период,
		|	СведенияОСтавкахИПН.Организация,
		|	СведенияОСтавкахИПН.ВидДохода
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	2,
		|	МАКСИМУМ(ЕСТЬNULL(СведенияОСтавкахИПН.Период, ДАТАВРЕМЯ(1, 1, 1))),
		|	ПериодыРасчета.Период,
		|	ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка),
		|	СведенияОСтавкахИПН.ВидДохода
		|ИЗ
		|	ВТДатыПоМесяцам КАК ПериодыРасчета
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОСтавкахИПН КАК СведенияОСтавкахИПН
		|		ПО ПериодыРасчета.Период >= СведенияОСтавкахИПН.Период
		|ГДЕ
		|	СведенияОСтавкахИПН.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)
		|
		|СГРУППИРОВАТЬ ПО
		|	ПериодыРасчета.Период,
		|	СведенияОСтавкахИПН.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПериодыСтавокИПН.Приоритет,
		|	ПериодыСтавокИПН.МесяцНалоговогоПериода,
		|	ПериодыСтавокИПН.ВидДохода,
		|	ЕСТЬNULL(СведенияОСтавкахИПН.Ставка, 0) / 100 КАК СтавкаРезиденты,
		|	ЕСТЬNULL(СведенияОСтавкахИПН.СтавкаНерезиденты, 0) / 100 КАК СтавкаНерезиденты
		|ПОМЕСТИТЬ ВТСтавкиИПНПоПриоритетам
		|ИЗ
		|	ВТПериодыСтавокИПН КАК ПериодыСтавокИПН
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОСтавкахИПН КАК СведенияОСтавкахИПН
		|		ПО ПериодыСтавокИПН.ПериодСтавки = СведенияОСтавкахИПН.Период
		|			И ПериодыСтавокИПН.Организация = СведенияОСтавкахИПН.Организация
		|			И ПериодыСтавокИПН.ВидДохода = СведенияОСтавкахИПН.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПриоритетСтавок.МесяцНалоговогоПериода,
		|	ПриоритетСтавок.ВидДохода,
		|	ВТСтавкиПоПриоритетам.СтавкаРезиденты,
		|	ВТСтавкиПоПриоритетам.СтавкаНерезиденты
		|ПОМЕСТИТЬ ВТСтавкиИПН
		|ИЗ
		|	(ВЫБРАТЬ
		|		МИНИМУМ(ПриоритетСтавок.Приоритет) КАК Приоритет,
		|		ПриоритетСтавок.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|		ПриоритетСтавок.ВидДохода КАК ВидДохода
		|	ИЗ
		|		ВТСтавкиИПНПоПриоритетам КАК ПриоритетСтавок
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ПриоритетСтавок.МесяцНалоговогоПериода,
		|		ПриоритетСтавок.ВидДохода) КАК ПриоритетСтавок
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиИПНПоПриоритетам КАК ВТСтавкиПоПриоритетам
		|		ПО ПриоритетСтавок.Приоритет = ВТСтавкиПоПриоритетам.Приоритет
		|			И ПриоритетСтавок.МесяцНалоговогоПериода = ВТСтавкиПоПриоритетам.МесяцНалоговогоПериода
		|			И ПриоритетСтавок.ВидДохода = ВТСтавкиПоПриоритетам.ВидДохода";
		
	Запрос.Выполнить();
	УдалитьВТ.Добавить("ВТПериодыСтавокИПН");
	УдалитьВТ.Добавить("ВТСтавкиИПНПоПриоритетам");
	УдалитьВТ.Добавить("ВТСтавкиИПН");
	
	// Финальный запрос	
	Запрос.Текст = 	
		"ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(СтатусыФизическихЛицКакНалогоплательщиков.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)) = ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)
		|			ТОГДА ЕСТЬNULL(СтавкиИПН.СтавкаРезиденты, 0)
		|		ИНАЧЕ ЕСТЬNULL(СтавкиИПН.СтавкаНерезиденты, 0)
		|	КОНЕЦ КАК СтавкаИПН,
		|	Доходы.ОблагаемыйДоход КАК ОблагаемыйДоходВЦеломЗаПериод,
		|	Доходы.НеоблагаемыйДоход КАК НеоблагаемыйДоходВЦеломЗаПериод,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.ВидВычета, ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ПустаяСсылка)) КАК ВидВычета,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.Приоритет, 0) КАК Приоритет,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.ПредоставлениеВычета, ЗНАЧЕНИЕ(Перечисление.ВидыПредоставленияВычетов.ПустаяСсылка)) КАК ПредоставлениеВычета,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.ВидВзносов, ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ПустаяСсылка)) КАК ВидВзносов,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.ПределВычета, 0) КАК ПределВычета,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.ПериодПредоставления, ЗНАЧЕНИЕ(Перечисление.ПериодыРасчетаВычетовИКорректировокДоходов.ПустаяСсылка)) КАК ПериодПредоставления,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.РазмерВычета, 0) КАК РазмерВычета,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.СуммовойПределВычета, 0) КАК СуммовойПределВычета,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.РазрешенныйВычетВТекущемПериоде, 0) КАК РазрешенныйВычетВТекущемПериоде,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.ПримененныйВычетВТекущемПериоде, 0) КАК ПримененныйВычетВТекущемПериоде,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.РазрешенныйВычетСНачалаГода, 0) КАК РазрешенныйВычетСНачалаГода,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.ПримененныйВычетСНачалаГода, 0) КАК ПримененныйВычетСНачалаГода
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиИПН КАК СтавкиИПН
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиИПН.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиИПН.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтатусыФизическихЛицКакНалогоплательщиков КАК СтатусыФизическихЛицКакНалогоплательщиков
		|		ПО Доходы.МесяцНалоговогоПериода = СтатусыФизическихЛицКакНалогоплательщиков.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = СтатусыФизическихЛицКакНалогоплательщиков.ФизическоеЛицо
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДанныеДляРасчетаВычетовИПН КАК ДанныеДляРасчетаВычетовИПН
		|		ПО Доходы.МесяцНалоговогоПериода = ДанныеДляРасчетаВычетовИПН.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ДанныеДляРасчетаВычетовИПН.ФизическоеЛицо
		|			И (ВЫБОР
		|				КОГДА ДанныеДляРасчетаВычетовИПН.ПредоставлениеВычета = ЗНАЧЕНИЕ(Перечисление.ВидыПредоставленияВычетов.ПоИсчисленнойСуммеВзносов)
		|					ТОГДА Доходы.ВидДохода = ДанныеДляРасчетаВычетовИПН.ВидДоходаВзносов
		|				ИНАЧЕ ИСТИНА
		|			КОНЕЦ)
		|			И (ВЫБОР
		|				КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ ДанныеДляРасчетаВычетовИПН.ПредоставлениеВычета = ЗНАЧЕНИЕ(Перечисление.ВидыПредоставленияВычетов.Стандартный)
		|						И ДанныеДляРасчетаВычетовИПН.ПериодПредоставления = ЗНАЧЕНИЕ(Перечисление.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахКалендарногоГода)
		|			КОНЕЦ)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ФизическоеЛицо,
		|	МесяцНалоговогоПериода,
		|	Приоритет
		|ИТОГИ
		|	МАКСИМУМ(СтавкаИПН),
		|	МАКСИМУМ(ОблагаемыйДоходВЦеломЗаПериод),
		|	МАКСИМУМ(НеоблагаемыйДоходВЦеломЗаПериод)
		|ПО
		|	ФизическоеЛицо,
		|	МесяцНалоговогоПериода,
		|	ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныйИПНПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныйИПНПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныйИПНПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныйИПНПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныйИПНПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйИПНПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйИПНПоПодразделениям.ОбъектИсчисления КАК ОбъектИПНВИсчисленныйРанее,
		|	ИсчисленныйИПНПоПодразделениям.НалогВзнос КАК ИПНИсчисленныйРанее,
		|	-ИсчисленныйИПНПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныйИПНПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныйИПНПоПодразделениям.НалогВзнос КАК ИсчисленныйИПН,
		|	-ИсчисленныйИПНПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияИПН,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетам.ВидВычета, ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ПустаяСсылка)) КАК ВидВычета,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетам.ВидВычета.Приоритет, 0) КАК Приоритет,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетам.РазрешенныйВычетВТекущемПериоде, 0) КАК РазрешенныйВычетВТекущемПериоде,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетам.ПримененныйВычетВТекущемПериоде, 0) КАК ПримененныйВычетВТекущемПериоде
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныйИПНПоПодразделениям
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНакопленныеДанныеПоВычетам КАК НакопленныеДанныеПоВычетам
		|		ПО ИсчисленныйИПНПоПодразделениям.МесяцНалоговогоПериода = НакопленныеДанныеПоВычетам.МесяцНалоговогоПериода
		|			И ИсчисленныйИПНПоПодразделениям.ФизическоеЛицо = НакопленныеДанныеПоВычетам.ФизическоеЛицо
		|			И ИсчисленныйИПНПоПодразделениям.Подразделение = НакопленныеДанныеПоВычетам.Подразделение
		|			И ИсчисленныйИПНПоПодразделениям.ВидДохода = НакопленныеДанныеПоВычетам.ВидДохода
		|			И (ВЫБОР
		|				КОГДА ИсчисленныйИПНПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|					ТОГДА ИСТИНА
		|				ИНАЧЕ НакопленныеДанныеПоВычетам.ВидВычета.ПредоставлениеВычета = ЗНАЧЕНИЕ(Перечисление.ВидыПредоставленияВычетов.Стандартный)
		|						И НакопленныеДанныеПоВычетам.ВидВычета.ПериодПредоставления = ЗНАЧЕНИЕ(Перечисление.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахКалендарногоГода)
		|			КОНЕЦ)
		|ГДЕ
		|	(ИсчисленныйИПНПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйИПНПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйИПНПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныйИПНПоПодразделениям.НалогВзнос <> 0
		|			ИЛИ НакопленныеДанныеПоВычетам.РазрешенныйВычетВТекущемПериоде <> 0
		|			ИЛИ НакопленныеДанныеПоВычетам.ПримененныйВычетВТекущемПериоде <> 0)
		|ИТОГИ
		|	МАКСИМУМ(ОблагаемыйДоходИсчисленныйРанее),
		|	МАКСИМУМ(НеоблагаемыйДоходИсчисленныйРанее),
		|	МАКСИМУМ(ОбъектИПНВИсчисленныйРанее),
		|	МАКСИМУМ(ИПНИсчисленныйРанее),
		|	МАКСИМУМ(ОблагаемыйДоход),
		|	МАКСИМУМ(НеоблагаемыйДоход),
		|	МАКСИМУМ(ИсчисленныйИПН),
		|	МАКСИМУМ(ОбъектИсчисленияИПН)
		|ПО
		|	ФизическоеЛицо,
		|	МесяцНалоговогоПериода,
		|	Подразделение,
		|	ВидДохода";
	
	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"ВТДоходы КАК Доходы", "ВТДоходыОбъединенная КАК Доходы");
	КонецЕсли;
	
	Результат = Запрос.ВыполнитьПакет();
	УдалитьВТ.Добавить("ВТНакопленныеДанныеПоВычетам");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныйИПНВыборкаПоФизЛицам = Результат[ВсегоРезультатов - 1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ФизическоеЛицо");
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	ВыборкаПоФизЛицам = Результат[ВсегоРезультатов - 3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ФизическоеЛицо");

	СтруктураДанных = ПодготовитьСлужебныеДанныеДляРасчетаИПН();
	ВспомогательнаяТаблицаРасчета = СтруктураДанных.ВспомогательнаяТаблицаРасчета;
	РезультатыРасчетов = СтруктураДанных.РезультатыРасчетов;
	ИзмеренияРасчетаВычетов = СтруктураДанных.ИзмеренияРасчетаВычетов;
	РесурсыРасчетаВычетов = СтруктураДанных.РесурсыРасчетаВычетов;
	
	ВычетыПримененныеВДанномРасчете = Новый Соответствие;
	
	Пока ВыборкаПоФизЛицам.Следующий() Цикл
		ВычетыПримененныеВДанномРасчете.Очистить();
		ВыборкаПоПериодам = ВыборкаПоФизЛицам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "МесяцНалоговогоПериода");
		Пока ВыборкаПоПериодам.Следующий() Цикл
			ВыборкаПоВидамДохода = ВыборкаПоПериодам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ВидДохода");
			Пока ВыборкаПоВидамДохода.Следующий() Цикл
				
				СтрокаРасчета = ВспомогательнаяТаблицаРасчета.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаРасчета, ВыборкаПоВидамДохода, "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода");
				
				ОбъектИсчисленияИПН = ВыборкаПоВидамДохода.ОблагаемыйДоходВЦеломЗаПериод;
				ВыборкаПоВидамВычетов = ВыборкаПоВидамДохода.Выбрать();
				РазрешенныйВычетВТекущемПериоде = 0;
				ПримененныйВычетВТекущемПериоде = 0;
				Пока ВыборкаПоВидамВычетов.Следующий() Цикл
					
					Если НЕ ЗначениеЗаполнено(ВыборкаПоВидамВычетов.ВидВычета) Тогда
						// Незачем считать, если вычеты не найдены
						Продолжить;
					КонецЕсли;
					
					// Соберем остатки за прошлые периоды в пределах года
					РазрешенныйВычетЗаПрошлыеМесяцы = ВыборкаПоВидамВычетов.РазрешенныйВычетСНачалаГода - ВыборкаПоВидамВычетов.РазрешенныйВычетВТекущемПериоде;
					ПримененныйВычетЗаПрошлыеМесяцы = ВыборкаПоВидамВычетов.ПримененныйВычетСНачалаГода - ВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде;
					ОстатокВычетаЗаПрошлыеМесяцы = РазрешенныйВычетЗаПрошлыеМесяцы - ПримененныйВычетЗаПрошлыеМесяцы;

					// Получим значения в текущем периоде
					Если ВыборкаПоВидамВычетов.ПредоставлениеВычета = Перечисления.ВидыПредоставленияВычетов.ПоИсчисленнойСуммеВзносов Тогда
						РазрешенныйВычетВТекущемПериоде = ВыборкаПоВидамВычетов.РазмерВычета;
					ИначеЕсли ВыборкаПоВидамВычетов.ПредоставлениеВычета = Перечисления.ВидыПредоставленияВычетов.Стандартный 
						ИЛИ ВыборкаПоВидамВычетов.ПредоставлениеВычета = Перечисления.ВидыПредоставленияВычетов.ПоПериодическимПлатежам Тогда
						Если ВыборкаПоВидамВычетов.ПределВычета > 0 Тогда
							Если ВыборкаПоВидамВычетов.ПериодПредоставления = Перечисления.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахМесяца Тогда
								РазрешенныйВычетВТекущемПериоде = Мин(ВыборкаПоВидамВычетов.СуммовойПределВычета, ВыборкаПоВидамВычетов.РазмерВычета);
							ИначеЕсли ВыборкаПоВидамВычетов.ПериодПредоставления = Перечисления.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахКалендарногоГода Тогда
								РазрешенныйВычетВТекущемПериоде = Мин(ВыборкаПоВидамВычетов.СуммовойПределВычета - РазрешенныйВычетЗаПрошлыеМесяцы, ВыборкаПоВидамВычетов.РазмерВычета);
							Иначе 
								РазрешенныйВычетВТекущемПериоде = 0;
							КонецЕсли;
						Иначе 
							РазрешенныйВычетВТекущемПериоде = ВыборкаПоВидамВычетов.РазмерВычета;
						КонецЕсли;
					Иначе
						РазрешенныйВычетВТекущемПериоде = 0;
					КонецЕсли;
					
					ПримененныйВычетВТекущемПериоде = Мин(ОбъектИсчисленияИПН, ОстатокВычетаЗаПрошлыеМесяцы + РазрешенныйВычетВТекущемПериоде 
										- ?(ВычетыПримененныеВДанномРасчете.Получить(ВыборкаПоВидамВычетов.ВидВычета) <> Неопределено, ВычетыПримененныеВДанномРасчете.Получить(ВыборкаПоВидамВычетов.ВидВычета), 0));

					// Скорректируем остаток облагаемого дохода
					ОбъектИсчисленияИПН = Макс(0, ОбъектИсчисленияИПН - ПримененныйВычетВТекущемПериоде);

					// Получим значения в текущем расчете
					РазрешенныйВычетВТекущемРасчете = РазрешенныйВычетВТекущемПериоде - ВыборкаПоВидамВычетов.РазрешенныйВычетВТекущемПериоде;
					ПримененныйВычетВТекущемРасчете = ПримененныйВычетВТекущемПериоде - ВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде;
					
					// Зафиксируем результаты по значению текущего физлица расчета
					Если ВычетыПримененныеВДанномРасчете.Получить(ВыборкаПоВидамВычетов.ВидВычета) = Неопределено Тогда
						ВычетыПримененныеВДанномРасчете.Вставить(ВыборкаПоВидамВычетов.ВидВычета, ПримененныйВычетВТекущемРасчете + ВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде);
					Иначе 
						ВычетыПримененныеВДанномРасчете[ВыборкаПоВидамВычетов.ВидВычета] = ВычетыПримененныеВДанномРасчете[ВыборкаПоВидамВычетов.ВидВычета] + ПримененныйВычетВТекущемРасчете + ВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде;
					КонецЕсли;
					
					СтрокаРасчета["ВидВычета" + Строка(ВыборкаПоВидамВычетов.Приоритет)] = ВыборкаПоВидамВычетов.ВидВычета;
					СтрокаРасчета["ПримененныйВычет" + Строка(ВыборкаПоВидамВычетов.Приоритет)] = ПримененныйВычетВТекущемПериоде;
					СтрокаРасчета["РазрешенныйВычет" + Строка(ВыборкаПоВидамВычетов.Приоритет)] = РазрешенныйВычетВТекущемПериоде;
					
				КонецЦикла;
				
				СтрокаРасчета.ОбъектИсчисленияИПН 	= ОбъектИсчисленияИПН;
				СтрокаРасчета.ИсчисленныйИПН 		= ОбъектИсчисленияИПН * ВыборкаПоВидамДохода.СтавкаИПН; 

			КонецЦикла;
		КонецЦикла;
	КонецЦикла;

	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из ВспомогательнаяТаблицаРасчета Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияИПН,ИсчисленныйИПН" + РесурсыРасчетаВычетов);
	КонецЦикла;
	
	Пока ИсчисленныйИПНВыборкаПоФизЛицам.Следующий() Цикл
		ИсчисленныйИПНВыборкаПоПериодам = ИсчисленныйИПНВыборкаПоФизЛицам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "МесяцНалоговогоПериода");
		Пока ИсчисленныйИПНВыборкаПоПериодам.Следующий() Цикл
			ИсчисленныйИПНВыборкаПоПодразделениям = ИсчисленныйИПНВыборкаПоПериодам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Подразделение");
			Пока ИсчисленныйИПНВыборкаПоПодразделениям.Следующий() Цикл
				ИсчисленныйИПНВыборкаПоВидамДохода = ИсчисленныйИПНВыборкаПоПодразделениям.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ВидДохода");
				Пока ИсчисленныйИПНВыборкаПоВидамДохода.Следующий() Цикл
					НоваяСтрока = РезультатыРасчетов.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, ИсчисленныйИПНВыборкаПоВидамДохода);
					ИсчисленныйИПНВыборкаПоВидамВычетов = ИсчисленныйИПНВыборкаПоВидамДохода.Выбрать();
					Пока ИсчисленныйИПНВыборкаПоВидамВычетов.Следующий() Цикл
						Если НЕ ЗначениеЗаполнено(ИсчисленныйИПНВыборкаПоВидамВычетов.ВидВычета) Тогда
							Продолжить;
						КонецЕсли;
						
						НоваяСтрока["ВидВычета" + Строка(ИсчисленныйИПНВыборкаПоВидамВычетов.Приоритет)] = ИсчисленныйИПНВыборкаПоВидамВычетов.ВидВычета;
						
						НоваяСтрока["ПримененныйВычет" + Строка(ИсчисленныйИПНВыборкаПоВидамВычетов.Приоритет)] = - ИсчисленныйИПНВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде;
						НоваяСтрока["РазрешенныйВычет" + Строка(ИсчисленныйИПНВыборкаПоВидамВычетов.Приоритет)] = - ИсчисленныйИПНВыборкаПоВидамВычетов.РазрешенныйВычетВТекущемПериоде;
						
						НоваяСтрока["ПримененныйВычет" + Строка(ИсчисленныйИПНВыборкаПоВидамВычетов.Приоритет) + "ИсчисленныйРанее"] = ИсчисленныйИПНВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде;
						НоваяСтрока["РазрешенныйВычет" + Строка(ИсчисленныйИПНВыборкаПоВидамВычетов.Приоритет) + "ИсчисленныйРанее"] = ИсчисленныйИПНВыборкаПоВидамВычетов.РазрешенныйВычетВТекущемПериоде;
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СотрудникиБезДохода.ФизическоеЛицо КАК ФизическоеЛицо,
		|	СотрудникиБезДохода.Подразделение КАК Подразделение
		|ИЗ
		|	ВТСотрудникиОрганизацииБезДохода КАК СотрудникиБезДохода";
		
		ТаблицаФизЛиц = Запрос.Выполнить().Выгрузить();
		Для каждого СтрокаТаблицы Из ТаблицаФизЛиц Цикл
			ПараметрыОтбора = Новый Структура("ФизическоеЛицо", СтрокаТаблицы.ФизическоеЛицо);
			МассивСтрок = ВспомогательнаяТаблицаРасчета.НайтиСтроки(ПараметрыОтбора);
			Для каждого Строка Из МассивСтрок Цикл
				НоваяСтрока = РезультатыРасчетов.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
				НоваяСтрока.Подразделение = СтрокаТаблицы.Подразделение;
			КонецЦикла;
		КонецЦикла;
		УдалитьВТ.Добавить("ВТСотрудникиОрганизацииБезДохода");
		УдалитьВТ.Добавить("ВТПериодыПоФизлицамОбъединенная");
		УдалитьВТ.Добавить("ВТКадровыеДанныеСотрудниковПоПериодамОбъединенная");
		УдалитьВТ.Добавить("ВТРанееИсчисленныеНалогиВзносыОбъедененная");
	КонецЕсли;
	
	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода" + ИзмеренияРасчетаВычетов,
								"ОблагаемыйДоходВЦеломЗаПериод,   НеоблагаемыйДоходВЦеломЗаПериод, 	 ОбъектИсчисленияИПНВЦеломЗаПериод, ИсчисленныйИПНВЦеломЗаПериод, 
								|ОблагаемыйДоходИсчисленныйРанее, НеоблагаемыйДоходИсчисленныйРанее, ОбъектИПНИсчисленныйРанее, 		ИПНИсчисленныйРанее, 
								|ОблагаемыйДоход, 				  НеоблагаемыйДоход, 				 ОбъектИсчисленияИПН, 				ИсчисленныйИПН" 				+ РесурсыРасчетаВычетов);

	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаИПН);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);

	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		НомерСтроки = НомерСтроки + 1;
		СтрокаТЗ.НомерСтроки = НомерСтроки;
		СтрокаТЗ.ИсчисленныйИПН = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныйИПН, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
	КонецЦикла;
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УдалитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьИПНПосле2019(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт

	УничтожитьВТ = Новый Массив;
	
	ВидНалогаВзносаИПН =  Перечисления.ВидыНалоговВзносовОтчислений.ИПН;
	
	// Получаем применение вычета в месяц отсутствия дохода
	УчетнаяПолитикаНУ = РегистрыСведений.УчетнаяПолитикаПоНалоговомуУчету.СрезПоследних(МесяцНачисления, Новый Структура("Организация", Организация));
	ПредоставлятьВычетВМесяцеОтсутствияДохода = Ложь;
	ПрименятьВычетОПВДляГПХ = Ложь;
	Если УчетнаяПолитикаНУ.Количество() > 0 Тогда
		ПредоставлятьВычетВМесяцеОтсутствияДохода = УчетнаяПолитикаНУ[0].ПредоставлятьВычетВМесяцеОтсутствияДохода;
		ПрименятьВычетОПВДляГПХ = УчетнаяПолитикаНУ[0].ПрименятьВычетВОСМСДляФизическихЛицИГПХ;
		//И ТипЗнч(Регистратор) = Тип("ДокументСсылка.НачислениеЗарплаты");
	КонецЕсли;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаИПН);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленного ИПН
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаИПН, ПредоставлятьВычетВМесяцеОтсутствияДохода);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	// Таблица ВТДанныеДляРасчетаВычетовИПН
	СоздатьВТДанныеДляРасчетаВычетовИПН(МенеджерВременныхТаблиц, Организация, ПредоставлятьВычетВМесяцеОтсутствияДохода, МесяцНачисления);
	УничтожитьВТ.Добавить("ВТДанныеДляРасчетаВычетовИПН");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	
	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		Запрос.Текст ="ВЫБРАТЬ
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	Доходы.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	Доходы.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ПОМЕСТИТЬ ВТДоходыОбъединенная
		|ИЗ
		|	ВТДоходы КАК Доходы
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТСотрудникиОрганизацииБезДохода.ФизическоеЛицо,
		|	ВТСотрудникиОрганизацииБезДохода.МесяцНалоговогоПериода,
		|	ВТСотрудникиОрганизацииБезДохода.ВидДохода,
		|	ВТСотрудникиОрганизацииБезДохода.ОблагаемыйДоход,
		|	ВТСотрудникиОрганизацииБезДохода.НеоблагаемыйДоход
		|ИЗ
		|	ВТСотрудникиОрганизацииБезДохода КАК ВТСотрудникиОрганизацииБезДохода";
		Запрос.Выполнить();
		УничтожитьВТ.Добавить("ВТДоходыОбъединенная");
	КонецЕсли;
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.НеоблагаемыйДоход) КАК НеоблагаемыйДоход,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.НалогВзнос) КАК НалогВзнос,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.ПримененнаяЛьгота) КАК ПримененнаяЛьгота,
		|	СУММА(ВТИсчисленныеНалогиВзносыПоПодразделениям.ОбъектИсчисления) КАК ОбъектИсчисления
		|ПОМЕСТИТЬ ВТИсчисленныеНалогиВзносы
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ВТИсчисленныеНалогиВзносыПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям.ВидДохода";
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносы");
	
	// Ставки ИПН
	СоздатьВТСтавкиИПН(Организация, МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтавкиИПН");
	
	// Финальный запрос	
	Запрос.Текст = 	
		"ВЫБРАТЬ
		|	НастройкиВычетовПоВидамДохода.МесяцНалоговогоПериода,
		|   НастройкиВычетовПоВидамДохода.ВидВычета,
		|   НастройкиВычетовПоВидамДохода.ВидДохода
		|ИЗ
		|	ВТНастройкиВычетовПоВидамДохода КАК НастройкиВычетовПоВидамДохода
		|
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	ВЫБОР
		|		КОГДА ЕСТЬNULL(СтатусыФизическихЛицКакНалогоплательщиков.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)) = ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)
		|			ТОГДА ЕСТЬNULL(СтавкиИПН.СтавкаРезиденты, 0)
		|		ИНАЧЕ ЕСТЬNULL(СтавкиИПН.СтавкаНерезиденты, 0)
		|	КОНЕЦ КАК СтавкаИПН,
		|	ЕСТЬNULL(СтатусыФизическихЛицКакНалогоплательщиков.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)) КАК СтатусНерезидента,
		|	ЕСТЬNULL(РазмерыМРП.РазмерМРПНаНачалоГода, 0) * 25 КАК ОграничениеКорректировкиДохода25МРП,
		|	Доходы.ОблагаемыйДоход КАК ОблагаемыйДоходВЦеломЗаПериод,
		|	Доходы.НеоблагаемыйДоход КАК НеоблагаемыйДоходВЦеломЗаПериод,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.ВидВычета, ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ПустаяСсылка)) КАК ВидВычета,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.Приоритет, 0) КАК Приоритет,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.ПредоставлениеВычета, ЗНАЧЕНИЕ(Перечисление.ВидыПредоставленияВычетов.ПустаяСсылка)) КАК ПредоставлениеВычета,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.ВидВзносов, ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ПустаяСсылка)) КАК ВидВзносов,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.ИспользуетсяПоНесколькимВидамДохода, ЛОЖЬ) КАК ИспользуетсяПоНесколькимВидамДохода,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.ПределВычета, 0) КАК ПределВычета,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.ПериодПредоставления, ЗНАЧЕНИЕ(Перечисление.ПериодыРасчетаВычетовИКорректировокДоходов.ПустаяСсылка)) КАК ПериодПредоставления,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.РазмерВычета, 0) КАК РазмерВычета,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.СуммовойПределВычета, 0) КАК СуммовойПределВычета,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.РазрешенныйВычетВТекущемПериоде, 0) КАК РазрешенныйВычетВТекущемПериоде,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.ПримененныйВычетВТекущемПериоде, 0) КАК ПримененныйВычетВТекущемПериоде,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.РазрешенныйВычетСНачалаГода, 0) КАК РазрешенныйВычетСНачалаГода,
		|	ЕСТЬNULL(ДанныеДляРасчетаВычетовИПН.ПримененныйВычетСНачалаГода, 0) КАК ПримененныйВычетСНачалаГода
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиИПН КАК СтавкиИПН
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиИПН.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиИПН.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыМРППоПериодам КАК РазмерыМРП
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыМРП.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтатусыФизическихЛицКакНалогоплательщиков КАК СтатусыФизическихЛицКакНалогоплательщиков
		|		ПО Доходы.МесяцНалоговогоПериода = СтатусыФизическихЛицКакНалогоплательщиков.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = СтатусыФизическихЛицКакНалогоплательщиков.ФизическоеЛицо
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДанныеДляРасчетаВычетовИПН КАК ДанныеДляРасчетаВычетовИПН
		|		ПО Доходы.МесяцНалоговогоПериода = ДанныеДляРасчетаВычетовИПН.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ДанныеДляРасчетаВычетовИПН.ФизическоеЛицо
		|			И (ВЫБОР
		|				КОГДА ДанныеДляРасчетаВычетовИПН.ПредоставлениеВычета = ЗНАЧЕНИЕ(Перечисление.ВидыПредоставленияВычетов.ПоИсчисленнойСуммеВзносов)
		|					ТОГДА Доходы.ВидДохода = ДанныеДляРасчетаВычетовИПН.ВидДоходаВзносов
		|				КОГДА НЕ ДанныеДляРасчетаВычетовИПН.ВидДоходаВычета ЕСТЬ NULL
		|					ТОГДА Доходы.ВидДохода = ДанныеДляРасчетаВычетовИПН.ВидДоходаВычета
		|				ИНАЧЕ ИСТИНА
		|			КОНЕЦ)
		|			И (ВЫБОР
		|				КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|					ТОГДА ИСТИНА" + ?(ПрименятьВычетОПВДляГПХ, "
		|				ИНАЧЕ Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтНалоговогоАгента)
		|						И ((ДанныеДляРасчетаВычетовИПН.ПредоставлениеВычета = ЗНАЧЕНИЕ(Перечисление.ВидыПредоставленияВычетов.Стандартный)
		|						И ДанныеДляРасчетаВычетовИПН.ПериодПредоставления = ЗНАЧЕНИЕ(Перечисление.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахКалендарногоГода))
		|						ИЛИ ДанныеДляРасчетаВычетовИПН.ВидВычета = ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ВычетОПВ))", "
		|				ИНАЧЕ ДанныеДляРасчетаВычетовИПН.ПредоставлениеВычета = ЗНАЧЕНИЕ(Перечисление.ВидыПредоставленияВычетов.Стандартный)
		|						И ДанныеДляРасчетаВычетовИПН.ПериодПредоставления = ЗНАЧЕНИЕ(Перечисление.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахКалендарногоГода)") + "
		|			КОНЕЦ)
		|
		|УПОРЯДОЧИТЬ ПО
		|	ФизическоеЛицо,
		|	МесяцНалоговогоПериода,
		|	Приоритет
		|ИТОГИ
		|	МАКСИМУМ(СтавкаИПН),
		|	МАКСИМУМ(ОблагаемыйДоходВЦеломЗаПериод),
		|	МАКСИМУМ(НеоблагаемыйДоходВЦеломЗаПериод),
		|	МАКСИМУМ(ОграничениеКорректировкиДохода25МРП),
		|	МАКСИМУМ(СтатусНерезидента)
		|ПО
		|	ФизическоеЛицо,
		|	МесяцНалоговогоПериода,
		|	ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныйИПНПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныйИПНПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныйИПНПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныйИПНПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныйИПНПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйИПНПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйИПНПоПодразделениям.ОбъектИсчисления КАК ОбъектИПНВИсчисленныйРанее,
		|	ИсчисленныйИПНПоПодразделениям.НалогВзнос КАК ИПНИсчисленныйРанее,
		|	ИсчисленныйИПНПоПодразделениям.ПримененнаяЛьгота КАК ПримененнаяЛьготаИсчислннаяРанее,
		|	-ИсчисленныйИПНПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныйИПНПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныйИПНПоПодразделениям.НалогВзнос КАК ИсчисленныйИПН,
		|	-ИсчисленныйИПНПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияИПН,
		|	-ИсчисленныйИПНПоПодразделениям.ПримененнаяЛьгота КАК ПримененнаяЛьгота,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетам.ВидВычета, ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ПустаяСсылка)) КАК ВидВычета,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетам.ВидВычета.Приоритет, 0) КАК Приоритет,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетам.РазрешенныйВычетВТекущемПериоде, 0) КАК РазрешенныйВычетВТекущемПериоде,
		|	ЕСТЬNULL(НакопленныеДанныеПоВычетам.ПримененныйВычетВТекущемПериоде, 0) КАК ПримененныйВычетВТекущемПериоде
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныйИПНПоПодразделениям
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНакопленныеДанныеПоВычетам КАК НакопленныеДанныеПоВычетам
		|		ПО ИсчисленныйИПНПоПодразделениям.МесяцНалоговогоПериода = НакопленныеДанныеПоВычетам.МесяцНалоговогоПериода
		|			И ИсчисленныйИПНПоПодразделениям.ФизическоеЛицо = НакопленныеДанныеПоВычетам.ФизическоеЛицо
		|			И ИсчисленныйИПНПоПодразделениям.Подразделение = НакопленныеДанныеПоВычетам.Подразделение
		|			И ИсчисленныйИПНПоПодразделениям.ВидДохода = НакопленныеДанныеПоВычетам.ВидДохода
		|			И (ВЫБОР
		|				КОГДА ИсчисленныйИПНПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|					ТОГДА ИСТИНА
		|" + ?(ПрименятьВычетОПВДляГПХ, "
		|				ИНАЧЕ ИсчисленныйИПНПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтНалоговогоАгента)
		|						И ((НакопленныеДанныеПоВычетам.ВидВычета.ПредоставлениеВычета = ЗНАЧЕНИЕ(Перечисление.ВидыПредоставленияВычетов.Стандартный)
		|						И НакопленныеДанныеПоВычетам.ВидВычета.ПериодПредоставления = ЗНАЧЕНИЕ(Перечисление.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахКалендарногоГода))
		|						ИЛИ НакопленныеДанныеПоВычетам.ВидВычета = ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ВычетОПВ))", "
		|				ИНАЧЕ НакопленныеДанныеПоВычетам.ВидВычета.ПредоставлениеВычета = ЗНАЧЕНИЕ(Перечисление.ВидыПредоставленияВычетов.Стандартный)
		|						И НакопленныеДанныеПоВычетам.ВидВычета.ПериодПредоставления = ЗНАЧЕНИЕ(Перечисление.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахКалендарногоГода)") + "
		|			КОНЕЦ)
		|ГДЕ
		|	(ИсчисленныйИПНПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйИПНПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйИПНПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныйИПНПоПодразделениям.НалогВзнос <> 0
		|			ИЛИ НакопленныеДанныеПоВычетам.РазрешенныйВычетВТекущемПериоде <> 0
		|			ИЛИ НакопленныеДанныеПоВычетам.ПримененныйВычетВТекущемПериоде <> 0)
		|ИТОГИ
		|	МАКСИМУМ(ОблагаемыйДоходИсчисленныйРанее),
		|	МАКСИМУМ(НеоблагаемыйДоходИсчисленныйРанее),
		|	МАКСИМУМ(ОбъектИПНВИсчисленныйРанее),
		|	МАКСИМУМ(ИПНИсчисленныйРанее),
		|	МАКСИМУМ(ОблагаемыйДоход),
		|	МАКСИМУМ(НеоблагаемыйДоход),
		|	МАКСИМУМ(ИсчисленныйИПН),
		|	МАКСИМУМ(ОбъектИсчисленияИПН)
		|ПО
		|	ФизическоеЛицо,
		|	МесяцНалоговогоПериода,
		|	Подразделение,
		|	ВидДохода";
	
	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"ВТДоходы КАК Доходы", "ВТДоходыОбъединенная КАК Доходы");
	КонецЕсли;
	
	Результат = Запрос.ВыполнитьПакет();
	УничтожитьВТ.Добавить("ВТНакопленныеДанныеПоВычетам");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныйИПНВыборкаПоФизЛицам = Результат[ВсегоРезультатов - 1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ФизическоеЛицо");
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	ВыборкаПоФизЛицам = Результат[ВсегоРезультатов - 3].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ФизическоеЛицо");
	НастройкиВидовВычетаПоВидамДохода = Результат[ВсегоРезультатов - 4].Выгрузить();
	НастройкиВидовВычетаПоВидамДохода.Индексы.Добавить("МесяцНалоговогоПериода");
	НастройкиВидовВычетаПоВидамДохода.Индексы.Добавить("ВидВычета");

	СтруктураДанных = ПодготовитьСлужебныеДанныеДляРасчетаИПН();
	ВспомогательнаяТаблицаРасчета = СтруктураДанных.ВспомогательнаяТаблицаРасчета;
	РезультатыРасчетов = СтруктураДанных.РезультатыРасчетов;
	ИзмеренияРасчетаВычетов = СтруктураДанных.ИзмеренияРасчетаВычетов;
	РесурсыРасчетаВычетов = СтруктураДанных.РесурсыРасчетаВычетов;
	
	ВычетыПримененныеВДанномРасчете = Новый Соответствие;
	ВычетыРазрешенныеВДанномРасчете = Новый Соответствие;
	Пока ВыборкаПоФизЛицам.Следующий() Цикл
		ВыборкаПоПериодам = ВыборкаПоФизЛицам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "МесяцНалоговогоПериода");
		Пока ВыборкаПоПериодам.Следующий() Цикл
			ВычетыПримененныеВДанномРасчете.Очистить();
			ВычетыРазрешенныеВДанномРасчете.Очистить();
			ВыборкаПоВидамДохода = ВыборкаПоПериодам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ВидДохода");
			Пока ВыборкаПоВидамДохода.Следующий() Цикл
				
				СтрокаРасчета = ВспомогательнаяТаблицаРасчета.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаРасчета, ВыборкаПоВидамДохода, "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода");
				
				ОбъектИсчисленияИПН = ВыборкаПоВидамДохода.ОблагаемыйДоходВЦеломЗаПериод;
				ВыборкаПоВидамВычетов = ВыборкаПоВидамДохода.Выбрать();
				РазрешенныйВычетВТекущемПериоде = 0;
				ПримененныйВычетВТекущемПериоде = 0;
				// ВычетОПВ применяем для каждого вида дохода в отдельности по исчисленной сумме в рамках вида дохода 
				Если НЕ ВычетыПримененныеВДанномРасчете.Получить(Справочники.ВидыВычетовИПН.ВычетОПВ) = Неопределено Тогда
					ВычетыПримененныеВДанномРасчете.Удалить(Справочники.ВидыВычетовИПН.ВычетОПВ);
				КонецЕсли;
				Пока ВыборкаПоВидамВычетов.Следующий() Цикл
					
					Если НЕ ЗначениеЗаполнено(ВыборкаПоВидамВычетов.ВидВычета) Тогда
						// Незачем считать, если вычеты не найдены
						Продолжить;
					КонецЕсли;
					
					Если ВыборкаПоВидамВычетов.ИспользуетсяПоНесколькимВидамДохода Тогда
						
						СтруктураПоиска = Новый Структура("МесяцНалоговогоПериода, ВидВычета, ВидДохода");
						ЗаполнитьЗначенияСвойств(СтруктураПоиска, ВыборкаПоВидамВычетов);
						
						Если НастройкиВидовВычетаПоВидамДохода.НайтиСтроки(СтруктураПоиска).Количество() = 0 Тогда
							// Незачем считать, если вычеты не найдены
							Продолжить;
						КонецЕсли;
						
					КонецЕсли;
					
					// если вид вычета используется по нескольким видам дохода, найдем какие суммы были использованы по другим видам дохода у данного вычета
					Если ВыборкаПоВидамВычетов.ИспользуетсяПоНесколькимВидамДохода Тогда
						
						РазрешенныйВычетПрочихВидовДоходаТекущегоРасчета = ?(ВычетыРазрешенныеВДанномРасчете.Получить(ВыборкаПоВидамВычетов.ВидВычета) <> Неопределено, ВычетыРазрешенныеВДанномРасчете.Получить(ВыборкаПоВидамВычетов.ВидВычета), 0);
						
					Иначе
						
						РазрешенныйВычетПрочихВидовДоходаТекущегоРасчета = 0;
						
					КонецЕсли;

					// Соберем остатки за прошлые периоды в пределах года
					РазрешенныйВычетЗаПрошлыеМесяцы = ВыборкаПоВидамВычетов.РазрешенныйВычетСНачалаГода - ВыборкаПоВидамВычетов.РазрешенныйВычетВТекущемПериоде;
					ПримененныйВычетЗаПрошлыеМесяцы = ВыборкаПоВидамВычетов.ПримененныйВычетСНачалаГода - ВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде;
					ОстатокВычетаЗаПрошлыеМесяцы = РазрешенныйВычетЗаПрошлыеМесяцы - ПримененныйВычетЗаПрошлыеМесяцы;

					// Получим значения в текущем периоде
					Если ВыборкаПоВидамВычетов.ПредоставлениеВычета = Перечисления.ВидыПредоставленияВычетов.ПоИсчисленнойСуммеВзносов Тогда
						РазрешенныйВычетВТекущемПериоде = ВыборкаПоВидамВычетов.РазмерВычета;
					ИначеЕсли ВыборкаПоВидамВычетов.ПредоставлениеВычета = Перечисления.ВидыПредоставленияВычетов.Стандартный 
						ИЛИ ВыборкаПоВидамВычетов.ПредоставлениеВычета = Перечисления.ВидыПредоставленияВычетов.ПоПериодическимПлатежам Тогда
						Если ВыборкаПоВидамВычетов.ПределВычета > 0 Тогда
							Если ВыборкаПоВидамВычетов.ПериодПредоставления = Перечисления.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахМесяца Тогда
								РазрешенныйВычетВТекущемПериоде = Мин(ВыборкаПоВидамВычетов.СуммовойПределВычета, ВыборкаПоВидамВычетов.РазмерВычета);
							ИначеЕсли ВыборкаПоВидамВычетов.ПериодПредоставления = Перечисления.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахКалендарногоГода Тогда
								РазрешенныйВычетВТекущемПериоде = Мин(ВыборкаПоВидамВычетов.СуммовойПределВычета - РазрешенныйВычетЗаПрошлыеМесяцы, ВыборкаПоВидамВычетов.РазмерВычета);
							Иначе 
								РазрешенныйВычетВТекущемПериоде = 0;
							КонецЕсли;
						Иначе 
							РазрешенныйВычетВТекущемПериоде = ВыборкаПоВидамВычетов.РазмерВычета;
						КонецЕсли;
					Иначе
						РазрешенныйВычетВТекущемПериоде = 0;
					КонецЕсли;
					
					ПримененныйВычетВТекущемПериоде = Мин(ОбъектИсчисленияИПН, ОстатокВычетаЗаПрошлыеМесяцы + РазрешенныйВычетВТекущемПериоде 
										- ?(ВычетыПримененныеВДанномРасчете.Получить(ВыборкаПоВидамВычетов.ВидВычета) <> Неопределено, ВычетыПримененныеВДанномРасчете.Получить(ВыборкаПоВидамВычетов.ВидВычета), 0));

					// Скорректируем остаток облагаемого дохода
					ОбъектИсчисленияИПН = Макс(0, ОбъектИсчисленияИПН - ПримененныйВычетВТекущемПериоде);

					// Получим значения в текущем расчете
					РазрешенныйВычетВТекущемРасчете = РазрешенныйВычетВТекущемПериоде - ВыборкаПоВидамВычетов.РазрешенныйВычетВТекущемПериоде;
					ПримененныйВычетВТекущемРасчете = ПримененныйВычетВТекущемПериоде - ВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде;
					
					// Зафиксируем результаты по значению текущего физлица расчета
					Если ВычетыПримененныеВДанномРасчете.Получить(ВыборкаПоВидамВычетов.ВидВычета) = Неопределено Тогда
						ВычетыПримененныеВДанномРасчете.Вставить(ВыборкаПоВидамВычетов.ВидВычета, ПримененныйВычетВТекущемРасчете + ВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде);
					Иначе 
						ВычетыПримененныеВДанномРасчете[ВыборкаПоВидамВычетов.ВидВычета] = ВычетыПримененныеВДанномРасчете[ВыборкаПоВидамВычетов.ВидВычета] + ПримененныйВычетВТекущемРасчете + ВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде;
					КонецЕсли;
					
					СтрокаРасчета["ВидВычета" + Строка(ВыборкаПоВидамВычетов.Приоритет)] = ВыборкаПоВидамВычетов.ВидВычета;
					СтрокаРасчета["ПримененныйВычет" + Строка(ВыборкаПоВидамВычетов.Приоритет)] = ПримененныйВычетВТекущемПериоде;
					СтрокаРасчета["РазрешенныйВычет" + Строка(ВыборкаПоВидамВычетов.Приоритет)] = РазрешенныйВычетВТекущемПериоде;

					СтрокаРасчета["ИспользуетсяПоНесколькимВидамДохода" + Строка(ВыборкаПоВидамВычетов.Приоритет)] = ВыборкаПоВидамВычетов.ИспользуетсяПоНесколькимВидамДохода;
					
					Если ВыборкаПоВидамВычетов.ИспользуетсяПоНесколькимВидамДохода Тогда
							
						// Зафиксируем результаты по значению текущего физлица расчета
						Если ВычетыРазрешенныеВДанномРасчете.Получить(ВыборкаПоВидамВычетов.ВидВычета) = Неопределено Тогда
							ВычетыРазрешенныеВДанномРасчете.Вставить(ВыборкаПоВидамВычетов.ВидВычета, РазрешенныйВычетВТекущемРасчете);
						Иначе 
							// добавим разрешенные вычеты других документов текущего периода с прочим видом дохода
							ВычетыРазрешенныеВДанномРасчете[ВыборкаПоВидамВычетов.ВидВычета] = ВычетыРазрешенныеВДанномРасчете[ВыборкаПоВидамВычетов.ВидВычета] + РазрешенныйВычетВТекущемРасчете;
						КонецЕсли;
					
					КонецЕсли;
					
				КонецЦикла;
				
				// применим корректировку на объект исчисления (Доходы - Вычеты), 
				// если сумма всех начислений (ВыборкаПоПериодам.ОблагаемыйДоходВЦеломЗаПериод + ВыборкаПоПериодам.НеоблагаемыйДоходВЦеломЗаПериод) не более 25 МРП
				Если ОкончательныйРасчет
					И ЗначениеЗаполнено(ВыборкаПоПериодам.МесяцНалоговогоПериода)
					И ВыборкаПоПериодам.МесяцНалоговогоПериода >= Дата(2019, 1, 1)
					И ВыборкаПоПериодам.СтатусНеРезидента = Перечисления.СтатусыФизическихЛицНалогоплательщиков.Резидент
					И (ВыборкаПоВидамДохода.ОблагаемыйДоходВЦеломЗаПериод + ВыборкаПоВидамДохода.НеоблагаемыйДоходВЦеломЗаПериод) <= ВыборкаПоПериодам.ОграничениеКорректировкиДохода25МРП
					И ВыборкаПоВидамДохода.ВидДохода = Справочники.ВидыДоходов.ДоходыОтРаботодателя
					И ОбъектИсчисленияИПН > 0 Тогда
					
					ПримененнаяКорректировка = Окр(ОбъектИсчисленияИПН * 0.9, 2, РежимОкругления.Окр15как20);
					ОбъектИсчисленияИПН = ОбъектИсчисленияИПН - ПримененнаяКорректировка;
					СтрокаРасчета.ПримененнаяЛьгота = ПримененнаяКорректировка;
					
				КонецЕсли;
				
				СтрокаРасчета.ОбъектИсчисленияИПН 	= ОбъектИсчисленияИПН;
				СтрокаРасчета.ИсчисленныйИПН 		= ОбъектИсчисленияИПН * ВыборкаПоВидамДохода.СтавкаИПН; 

			КонецЦикла;
		КонецЦикла;
	КонецЦикла;

	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	ПоляПоискаВидаДохода = "ФизическоеЛицо, МесяцНалоговогоПериода";
	СтруктураПоискаВидаДохода = Новый Структура(ПоляПоискаВидаДохода);
	
	МесяцНалоговогоПериодаВЦикле = Неопределено;
	ПоляПоискаПоНастройкамВычетов = "МесяцНалоговогоПериода";
	СтруктураПоискаПоНастройкамВычетов = Новый Структура(ПоляПоискаПоНастройкамВычетов);
	
	Для Каждого СтрокаРасчета Из ВспомогательнаяТаблицаРасчета Цикл

		// ускорим работу цикла, если не меняется месяц начисления, нет необходимости искать по таблице НастройкиВидовВычетаПоВидамДоходаМесяца 
		Если МесяцНалоговогоПериодаВЦикле = Неопределено
			ИЛИ МесяцНалоговогоПериодаВЦикле <> СтрокаРасчета.МесяцНалоговогоПериода Тогда
			
			МесяцНалоговогоПериодаВЦикле = СтрокаРасчета.МесяцНалоговогоПериода;
			СтруктураПоискаПоНастройкамВычетов.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
			НастройкиВидовВычетаПоВидамДоходаМесяца = НастройкиВидовВычетаПоВидамДохода.Скопировать(СтруктураПоискаПоНастройкамВычетов, "ВидВычета, ВидДохода");
			
		КонецЕсли;
			
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяцаПоПодразделениям = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		
		СтруктураПоискаВидаДохода.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоискаВидаДохода.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		ДоходыПоВидамДохода = РаспределениеДоходовПоПодразделениям.Скопировать(СтруктураПоискаВидаДохода, "ВидДохода, ОблагаемыйДоход");
		ДоходыПоВидамДохода.Свернуть("ВидДохода", "ОблагаемыйДоход");
		
		РаспределитьНалогиВзносыПоПодразделениямИВидуДохода(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяцаПоПодразделениям, ДоходыПоВидамДохода, "ОбъектИсчисленияИПН,ИсчисленныйИПН,ПримененнаяЛьгота" + РесурсыРасчетаВычетов, НастройкиВидовВычетаПоВидамДоходаМесяца);
		
	КонецЦикла;
	
	Пока ИсчисленныйИПНВыборкаПоФизЛицам.Следующий() Цикл
		ИсчисленныйИПНВыборкаПоПериодам = ИсчисленныйИПНВыборкаПоФизЛицам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "МесяцНалоговогоПериода");
		Пока ИсчисленныйИПНВыборкаПоПериодам.Следующий() Цикл
			ИсчисленныйИПНВыборкаПоПодразделениям = ИсчисленныйИПНВыборкаПоПериодам.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "Подразделение");
			Пока ИсчисленныйИПНВыборкаПоПодразделениям.Следующий() Цикл
				ИсчисленныйИПНВыборкаПоВидамДохода = ИсчисленныйИПНВыборкаПоПодразделениям.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам, "ВидДохода");
				Пока ИсчисленныйИПНВыборкаПоВидамДохода.Следующий() Цикл
					НоваяСтрока = РезультатыРасчетов.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, ИсчисленныйИПНВыборкаПоВидамДохода);
					ИсчисленныйИПНВыборкаПоВидамВычетов = ИсчисленныйИПНВыборкаПоВидамДохода.Выбрать();
					Пока ИсчисленныйИПНВыборкаПоВидамВычетов.Следующий() Цикл
						Если НЕ ЗначениеЗаполнено(ИсчисленныйИПНВыборкаПоВидамВычетов.ВидВычета) Тогда
							Продолжить;
						КонецЕсли;
						
						НоваяСтрока["ВидВычета" + Строка(ИсчисленныйИПНВыборкаПоВидамВычетов.Приоритет)] = ИсчисленныйИПНВыборкаПоВидамВычетов.ВидВычета;
						
						НоваяСтрока["ПримененныйВычет" + Строка(ИсчисленныйИПНВыборкаПоВидамВычетов.Приоритет)] = - ИсчисленныйИПНВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде;
						НоваяСтрока["РазрешенныйВычет" + Строка(ИсчисленныйИПНВыборкаПоВидамВычетов.Приоритет)] = - ИсчисленныйИПНВыборкаПоВидамВычетов.РазрешенныйВычетВТекущемПериоде;
						
						НоваяСтрока["ПримененныйВычет" + Строка(ИсчисленныйИПНВыборкаПоВидамВычетов.Приоритет) + "ИсчисленныйРанее"] = ИсчисленныйИПНВыборкаПоВидамВычетов.ПримененныйВычетВТекущемПериоде;
						НоваяСтрока["РазрешенныйВычет" + Строка(ИсчисленныйИПНВыборкаПоВидамВычетов.Приоритет) + "ИсчисленныйРанее"] = ИсчисленныйИПНВыборкаПоВидамВычетов.РазрешенныйВычетВТекущемПериоде;
						
						НоваяСтрока["ПримененнаяЛьгота"] = ИсчисленныйИПНВыборкаПоВидамВычетов.ПримененнаяЛьгота;
						
					КонецЦикла;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СотрудникиБезДохода.ФизическоеЛицо КАК ФизическоеЛицо,
		|	СотрудникиБезДохода.Подразделение КАК Подразделение
		|ИЗ
		|	ВТСотрудникиОрганизацииБезДохода КАК СотрудникиБезДохода";
		
		ТаблицаФизЛиц = Запрос.Выполнить().Выгрузить();
		Для каждого СтрокаТаблицы Из ТаблицаФизЛиц Цикл
			ПараметрыОтбора = Новый Структура("ФизическоеЛицо", СтрокаТаблицы.ФизическоеЛицо);
			МассивСтрок = ВспомогательнаяТаблицаРасчета.НайтиСтроки(ПараметрыОтбора);
			Для каждого Строка Из МассивСтрок Цикл
				НоваяСтрока = РезультатыРасчетов.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
				НоваяСтрока.Подразделение = СтрокаТаблицы.Подразделение;
			КонецЦикла;
		КонецЦикла;
		УничтожитьВТ.Добавить("ВТСотрудникиОрганизацииБезДохода");
		УничтожитьВТ.Добавить("ВТПериодыПоФизлицамОбъединенная");
		УничтожитьВТ.Добавить("ВТКадровыеДанныеСотрудниковПоПериодамОбъединенная");
		УничтожитьВТ.Добавить("ВТРанееИсчисленныеНалогиВзносыОбъедененная");
	КонецЕсли;
	
	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода" + ИзмеренияРасчетаВычетов,
								"ОблагаемыйДоходВЦеломЗаПериод,   НеоблагаемыйДоходВЦеломЗаПериод, 	 ОбъектИсчисленияИПНВЦеломЗаПериод, ИсчисленныйИПНВЦеломЗаПериод, 
								|ОблагаемыйДоходИсчисленныйРанее, НеоблагаемыйДоходИсчисленныйРанее, ОбъектИПНИсчисленныйРанее, 		ИПНИсчисленныйРанее, 
								|ОблагаемыйДоход, 				  НеоблагаемыйДоход, 				 ОбъектИсчисленияИПН, 				ИсчисленныйИПН, 				ПримененнаяЛьгота" + РесурсыРасчетаВычетов);

	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаИПН);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);

	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		НомерСтроки = НомерСтроки + 1;
		СтрокаТЗ.НомерСтроки = НомерСтроки;
		СтрокаТЗ.ИсчисленныйИПН = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныйИПН, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
	КонецЦикла;
	
	Запрос.УстановитьПараметр("ИсчисленныеИПН", РезультатыРасчетов.Скопировать());
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаИПН.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ТаблицаИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ТаблицаИПН.ПримененнаяЛьгота КАК ПримененнаяКорректировка
		|ПОМЕСТИТЬ ВТИсчисленныйИПН
		|ИЗ
		|	&ИсчисленныеИПН КАК ТаблицаИПН";
	Запрос.Выполнить();
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьИПНПосле2020(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт

	УничтожитьВТ = Новый Массив;
	
	ВидНалогаВзносаИПН =  Перечисления.ВидыНалоговВзносовОтчислений.ИПН;
	
	// Получаем применение вычета в месяц отсутствия дохода
	УчетнаяПолитикаНУ = РегистрыСведений.УчетнаяПолитикаПоНалоговомуУчету.СрезПоследних(МесяцНачисления, Новый Структура("Организация", Организация));
	ПредоставлятьВычетВМесяцеОтсутствияДохода = Ложь;
	ПрименятьВычетОПВиВОСМСГПХ = Ложь;
	Если УчетнаяПолитикаНУ.Количество() > 0 Тогда
		ПредоставлятьВычетВМесяцеОтсутствияДохода = УчетнаяПолитикаНУ[0].ПредоставлятьВычетВМесяцеОтсутствияДохода;
		ПрименятьВычетОПВиВОСМСГПХ = УчетнаяПолитикаНУ[0].ПрименятьВычетОПВиВОСМСДляГПХ;
		//И ТипЗнч(Регистратор) = Тип("ДокументСсылка.НачислениеЗарплаты");
	КонецЕсли;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаИПН);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленного ИПН
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаИПН, ПредоставлятьВычетВМесяцеОтсутствияДохода);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
    
