		"ВЫБРАТЬ
		|	ТаблицаСО.МесяцНалоговогоПериода,
		|	ТаблицаСО.ФизическоеЛицо,
		|	ТаблицаСО.Подразделение,
		|	ТаблицаСО.ВидДохода,
		|	ТаблицаСО.ОбъектИсчисленияСО,
		|	ТаблицаСО.ИсчисленныеСО
		|ПОМЕСТИТЬ ВТИсчисленныеСОПоПодразделениям
		|ИЗ
		|	&ИсчисленныеСО КАК ТаблицаСО
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеСОПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеСОПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеСОПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеСОПоПодразделениям.ОбъектИсчисленияСО) КАК ОбъектИсчисленияСО,
		|	СУММА(ВТИсчисленныеСОПоПодразделениям.ИсчисленныеСО) КАК ИсчисленныеСО
		|ПОМЕСТИТЬ ВТИсчисленныеСО
		|ИЗ
		|	ВТИсчисленныеСОПоПодразделениям КАК ВТИсчисленныеСОПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеСОПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеСОПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеСОПоПодразделениям.ВидДохода";
		
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеСОПоПодразделениям");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьСОПосле2022(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("КонецМесяцаРасчета", КонецМесяца(МесяцНачисления));
	Запрос.УстановитьПараметр("ОкончательныйРасчет", ОкончательныйРасчет);
	
	// Исключаемые лица
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СведенияОПенсионномОбеспеченииФизическихЛиц.ФизическоеЛицо
		|ПОМЕСТИТЬ ВТИсключаемыеФизическиеЛицаПриРасчетеСО
		|ИЗ
		|	РегистрСведений.СведенияОПенсионномОбеспеченииФизическихЛиц.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОПенсионномОбеспеченииФизическихЛиц
		|ГДЕ
		|	СведенияОПенсионномОбеспеченииФизическихЛиц.ПенсионерПоВозрасту
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо
		|ИЗ
		|	РегистрСведений.СтатусФизическихЛицКакНалогоплательщиков.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СтатусФизическихЛицКакНалогоплательщиков
		|ГДЕ
		|	НЕ СтатусФизическихЛицКакНалогоплательщиков.ПодлежитСоциальномуСтрахованию";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеСО");
	
	ВидНалогаВзносаСО =  Перечисления.ВидыНалоговВзносовОтчислений.СО;
	
	ДанныеОкругления = ПолучитьСпособОкругленияСПериодом(МенеджерВременныхТаблиц, ВидНалогаВзносаСО);
	СпособОкругления = ДанныеОкругления.СпособОкругления;
	ПериодОкругления = ДанныеОкругления.Период;
	
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	Если ПериодОкругления >= '20220101' Тогда
		// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
		ТочностьОкругления = ОписаниеСпособаОкругления.Точность;
		ПравилоОкругления = ОписаниеСпособаОкругления.ПравилоОкругления;		
	Иначе
		ТочностьОкругления = 1;
		ПравилоОкругления = Перечисления.ПравилаОкругленияПриРасчетеЗарплаты.ВБольшуюСторону;		
	КонецЕсли;

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругленияДляРаспределения = ТочностьОкругления - Цел(ТочностьОкругления);
	
	Если ТочностьОкругленияДляРаспределения = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругленияДляРаспределения <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаСО, "ВТИсключаемыеФизическиеЛицаПриРасчетеСО");
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных СО
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаСО);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	// - Размер ограничения доходов, облагаемых СО, по периодам
	// - Исчисленные СО
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 7 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) КАК ИсчисленныеОПВ,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0)
		|	КОНЕЦ КАК ОбъектИсчисленияСО,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0)
		|	КОНЕЦ * ЕСТЬNULL(СтавкиСО.Ставка, 0) КАК ИсчисленныеСО
		|ПОМЕСТИТЬ ВТИсчисленныеСОВЦеломЗаПериод
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиСО
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиСО.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиСО.ВидДохода
		|			И (СтавкиСО.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.СО))
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеОПВ КАК ИсчисленныеОПВПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеОПВПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеОПВПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеОПВПоПериодам.ВидДохода
		|			И НЕ Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|ГДЕ
		|	&ОкончательныйРасчет
		|	ИЛИ НЕ Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеСО.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеСО.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеСО.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеСО.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	ВТИсчисленныеСО.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ВТИсчисленныеСО.ИсчисленныеОПВ КАК ИсчисленныеОПВ,
		|	ВТИсчисленныеСО.ОбъектИсчисленияСО КАК ОбъектИсчисленияСО,
		|	ВТИсчисленныеСО.ИсчисленныеСО КАК ИсчисленныеСО
		|ИЗ
		|	ВТИсчисленныеСОВЦеломЗаПериод КАК ВТИсчисленныеСО
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеСОПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеСОПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеСОПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеСОПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеСОПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеСОПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеСОПоПодразделениям.ОбъектИсчисления КАК ОбъектСОИсчисленныйРанее,
		|	ИсчисленныеСОПоПодразделениям.НалогВзнос КАК РанееИсчисленныеСО,
		|	-ИсчисленныеСОПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеСОПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеСОПоПодразделениям.НалогВзнос КАК ИсчисленныеСО,
		|	-ИсчисленныеСОПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияСО
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеСОПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеСОПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеСОПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеСОПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеСОПоПодразделениям.НалогВзнос <> 0)
		|	И НЕ ИсчисленныеСОПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТИсчисленныеСОВЦеломЗаПериод");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеСОПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	РезультатЗапроса.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатЗапроса.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатЗапроса.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатЗапроса.Колонки.Добавить("МинимальныйРазмерОрганиченияДохода", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("МаксимальныйРазмерОрганиченияДохода", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ОбъектИсчисленияСО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИсчисленныеСО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(Результат[ВсегоРезультатов - 3].Выгрузить(), РезультатЗапроса);
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеСОВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияСОВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектСОИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеСО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияСО,ИсчисленныеСО", ТочностьРаспределения);
	КонецЦикла;
	
	ТаблицаДляСН = РезультатыРасчетов.Скопировать();
	
	Для каждого СтрокаТЗ Из ТаблицаДляСН Цикл
		СтрокаТЗ.ИсчисленныеСО = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеСО, ТочностьОкругления, ПравилоОкругления);
	КонецЦикла; 
	
	Запрос.УстановитьПараметр("ИсчисленныеСО", ТаблицаДляСН.Скопировать());	
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеСОПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияСОВЦеломЗаПериод, 	ИсчисленныеСОВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектСОИсчисленныйРанее, 			РанееИсчисленныеСО,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияСО, 				ИсчисленныеСО");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0 
			И (СтрокаТЗ.ИсчисленныеСО < 1 И СтрокаТЗ.ИсчисленныеСО > 0
				ИЛИ СтрокаТЗ.ИсчисленныеСО > -1 И СтрокаТЗ.ИсчисленныеСО < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеСО = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеСО = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеСО, ТочностьОкругления, ПравилоОкругления);
			
		КонецЕсли;
	КонецЦикла; 

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаСО.МесяцНалоговогоПериода,
		|	ТаблицаСО.ФизическоеЛицо,
		|	ТаблицаСО.Подразделение,
		|	ТаблицаСО.ВидДохода,
		|	ТаблицаСО.ОбъектИсчисленияСО,
		|	ТаблицаСО.ИсчисленныеСО
		|ПОМЕСТИТЬ ВТИсчисленныеСОПоПодразделениям
		|ИЗ
		|	&ИсчисленныеСО КАК ТаблицаСО
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеСОПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеСОПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеСОПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеСОПоПодразделениям.ОбъектИсчисленияСО) КАК ОбъектИсчисленияСО,
		|	СУММА(ВТИсчисленныеСОПоПодразделениям.ИсчисленныеСО) КАК ИсчисленныеСО
		|ПОМЕСТИТЬ ВТИсчисленныеСО
		|ИЗ
		|	ВТИсчисленныеСОПоПодразделениям КАК ВТИсчисленныеСОПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеСОПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеСОПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеСОПоПодразделениям.ВидДохода";
		
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеСОПоПодразделениям");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьСОПосле2023(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("КонецМесяцаРасчета", КонецМесяца(МесяцНачисления));
	Запрос.УстановитьПараметр("ОкончательныйРасчет", ОкончательныйРасчет);
	
	СоздатьВТИсключаемыеЛицаСО(МенеджерВременныхТаблиц, МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеСО");
	
	ВидНалогаВзносаСО =  Перечисления.ВидыНалоговВзносовОтчислений.СО;
	
	ДанныеОкругления = ПолучитьСпособОкругленияСПериодом(МенеджерВременныхТаблиц, ВидНалогаВзносаСО);
	СпособОкругления = ДанныеОкругления.СпособОкругления;
	ПериодОкругления = ДанныеОкругления.Период;
	
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	Если ПериодОкругления >= '20220101' Тогда
		// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
		ТочностьОкругления = ОписаниеСпособаОкругления.Точность;
		ПравилоОкругления = ОписаниеСпособаОкругления.ПравилоОкругления;		
	Иначе
		ТочностьОкругления = 1;
		ПравилоОкругления = Перечисления.ПравилаОкругленияПриРасчетеЗарплаты.ВБольшуюСторону;		
	КонецЕсли;

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругленияДляРаспределения = ТочностьОкругления - Цел(ТочностьОкругления);
	
	Если ТочностьОкругленияДляРаспределения = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругленияДляРаспределения <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходыПосле2023(МенеджерВременныхТаблиц, ВидНалогаВзносаСО, "ВТИсключаемыеФизическиеЛицаПриРасчетеСО");
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных СО
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаСО);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// - Размер ограничения доходов, облагаемых СО, по периодам
	// - Исчисленные СО
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 7 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) КАК ИсчисленныеОПВ,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0)
		|	КОНЕЦ КАК ОбъектИсчисленияСО,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) >= РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0)
		|	КОНЕЦ * ЕСТЬNULL(СтавкиСО.Ставка, 0) КАК ИсчисленныеСО
		|ПОМЕСТИТЬ ВТИсчисленныеСОВЦеломЗаПериод
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиСО
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиСО.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиСО.ВидДохода
		|			И (СтавкиСО.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.СО))
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеОПВ КАК ИсчисленныеОПВПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеОПВПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеОПВПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеОПВПоПериодам.ВидДохода
		|ГДЕ
		|	&ОкончательныйРасчет
		|	ИЛИ НЕ Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеСО.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеСО.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеСО.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеСО.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	ВТИсчисленныеСО.МаксимальныйРазмерОрганиченияДохода КАК МаксимальныйРазмерОрганиченияДохода,
		|	ВТИсчисленныеСО.ИсчисленныеОПВ КАК ИсчисленныеОПВ,
		|	ВТИсчисленныеСО.ОбъектИсчисленияСО КАК ОбъектИсчисленияСО,
		|	ВТИсчисленныеСО.ИсчисленныеСО КАК ИсчисленныеСО
		|ИЗ
		|	ВТИсчисленныеСОВЦеломЗаПериод КАК ВТИсчисленныеСО
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеСОПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеСОПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеСОПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеСОПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеСОПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеСОПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеСОПоПодразделениям.ОбъектИсчисления КАК ОбъектСОИсчисленныйРанее,
		|	ИсчисленныеСОПоПодразделениям.НалогВзнос КАК РанееИсчисленныеСО,
		|	-ИсчисленныеСОПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеСОПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеСОПоПодразделениям.НалогВзнос КАК ИсчисленныеСО,
		|	-ИсчисленныеСОПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияСО
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеСОПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеСОПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеСОПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеСОПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеСОПоПодразделениям.НалогВзнос <> 0)
		|	И НЕ ИсчисленныеСОПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТИсчисленныеСОВЦеломЗаПериод");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеСОПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	РезультатЗапроса.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатЗапроса.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатЗапроса.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатЗапроса.Колонки.Добавить("МинимальныйРазмерОрганиченияДохода", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("МаксимальныйРазмерОрганиченияДохода", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ОбъектИсчисленияСО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИсчисленныеСО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(Результат[ВсегоРезультатов - 3].Выгрузить(), РезультатЗапроса);
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеСОВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияСОВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектСОИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеСО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияСО,ИсчисленныеСО", ТочностьРаспределения);
	КонецЦикла;
	
	ТаблицаДляСН = РезультатыРасчетов.Скопировать();
	
	Для каждого СтрокаТЗ Из ТаблицаДляСН Цикл
		СтрокаТЗ.ИсчисленныеСО = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеСО, ТочностьОкругления, ПравилоОкругления);
	КонецЦикла; 
	
	Запрос.УстановитьПараметр("ИсчисленныеСО", ТаблицаДляСН.Скопировать());	
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеСОПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияСОВЦеломЗаПериод, 	ИсчисленныеСОВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектСОИсчисленныйРанее, 			РанееИсчисленныеСО,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияСО, 				ИсчисленныеСО");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0 
			И (СтрокаТЗ.ИсчисленныеСО < 1 И СтрокаТЗ.ИсчисленныеСО > 0
				ИЛИ СтрокаТЗ.ИсчисленныеСО > -1 И СтрокаТЗ.ИсчисленныеСО < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеСО = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеСО = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеСО, ТочностьОкругления, ПравилоОкругления);
			
		КонецЕсли;
	КонецЦикла; 

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаСО.МесяцНалоговогоПериода,
		|	ТаблицаСО.ФизическоеЛицо,
		|	ТаблицаСО.Подразделение,
		|	ТаблицаСО.ВидДохода,
		|	ТаблицаСО.ОбъектИсчисленияСО,
		|	ТаблицаСО.ИсчисленныеСО
		|ПОМЕСТИТЬ ВТИсчисленныеСОПоПодразделениям
		|ИЗ
		|	&ИсчисленныеСО КАК ТаблицаСО
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеСОПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеСОПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеСОПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеСОПоПодразделениям.ОбъектИсчисленияСО) КАК ОбъектИсчисленияСО,
		|	СУММА(ВТИсчисленныеСОПоПодразделениям.ИсчисленныеСО) КАК ИсчисленныеСО
		|ПОМЕСТИТЬ ВТИсчисленныеСО
		|ИЗ
		|	ВТИсчисленныеСОПоПодразделениям КАК ВТИсчисленныеСОПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеСОПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеСОПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеСОПоПодразделениям.ВидДохода";
		
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеСОПоПодразделениям");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьСОПосле2025(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("КонецМесяцаРасчета", КонецМесяца(МесяцНачисления));
	Запрос.УстановитьПараметр("ОкончательныйРасчет", ОкончательныйРасчет);
	
	СоздатьВТИсключаемыеЛицаСО(МенеджерВременныхТаблиц, МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеСО");
	
	ВидНалогаВзносаСО =  Перечисления.ВидыНалоговВзносовОтчислений.СО;
	
	ДанныеОкругления = ПолучитьСпособОкругленияСПериодом(МенеджерВременныхТаблиц, ВидНалогаВзносаСО);
	СпособОкругления = ДанныеОкругления.СпособОкругления;
	ПериодОкругления = ДанныеОкругления.Период;
	
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	Если ПериодОкругления >= '20220101' Тогда
		// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
		ТочностьОкругления = ОписаниеСпособаОкругления.Точность;
		ПравилоОкругления = ОписаниеСпособаОкругления.ПравилоОкругления;		
	Иначе
		ТочностьОкругления = 1;
		ПравилоОкругления = Перечисления.ПравилаОкругленияПриРасчетеЗарплаты.ВБольшуюСторону;		
	КонецЕсли;

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругленияДляРаспределения = ТочностьОкругления - Цел(ТочностьОкругления);
	
	Если ТочностьОкругленияДляРаспределения = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругленияДляРаспределения <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходыПосле2023(МенеджерВременныхТаблиц, ВидНалогаВзносаСО, "ВТИсключаемыеФизическиеЛицаПриРасчетеСО");
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных СО
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаСО);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// - Размер ограничения доходов, облагаемых СО, по периодам
	// - Исчисленные СО
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 7 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	МАКСИМУМ(Доходы.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	ЕСТЬNULL(СтавкиСО.Ставка, 0) КАК Ставка,
		|	МАКСИМУМ(РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода) КАК МинимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода) КАК МаксимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0)) КАК ИсчисленныеОПВ,
		|	МАКСИМУМ(ВЫБОР КОГДА ДругиеВидыДоходов.ВидДохода ЕСТЬ NULL ТОГДА ЛОЖЬ ИНАЧЕ ИСТИНА КОНЕЦ) КАК ЕстьНесколькоВидовДоходов,
		|	0 КАК ОбъектИсчисленияСО,
		|	0 КАК ИсчисленныеСО
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиСО
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиСО.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиСО.ВидДохода
		|			И (СтавкиСО.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.СО))
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДоходы КАК ДругиеВидыДоходов
		|		ПО ДругиеВидыДоходов.МесяцНалоговогоПериода = Доходы.МесяцНалоговогоПериода
		|			И ДругиеВидыДоходов.ФизическоеЛицо = Доходы.ФизическоеЛицо
		|			И НЕ ДругиеВидыДоходов.ВидДохода = Доходы.ВидДохода
		|			И НЕ ДругиеВидыДоходов.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеОПВ КАК ИсчисленныеОПВПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеОПВПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеОПВПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеОПВПоПериодам.ВидДохода
		|ГДЕ
		|	&ОкончательныйРасчет
		|	ИЛИ НЕ Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|	
		|СГРУППИРОВАТЬ ПО
		|	Доходы.МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо,
		|	Доходы.ВидДохода,
		|	ЕСТЬNULL(СтавкиСО.Ставка, 0)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Доходы.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеСОПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеСОПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеСОПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеСОПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеСОПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеСОПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеСОПоПодразделениям.ОбъектИсчисления КАК ОбъектСОИсчисленныйРанее,
		|	ИсчисленныеСОПоПодразделениям.НалогВзнос КАК РанееИсчисленныеСО,
		|	-ИсчисленныеСОПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеСОПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеСОПоПодразделениям.НалогВзнос КАК ИсчисленныеСО,
		|	-ИсчисленныеСОПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияСО
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеСОПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеСОПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеСОПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеСОПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеСОПоПодразделениям.НалогВзнос <> 0)
		|	И НЕ ИсчисленныеСОПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеСОПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	РезультатЗапроса.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатЗапроса.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатЗапроса.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатЗапроса.Колонки.Добавить("МинимальныйРазмерОрганиченияДохода", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("МаксимальныйРазмерОрганиченияДохода", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ОбъектИсчисленияСО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИсчисленныеСО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаДляОбработки = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам = Новый ТаблицаЗначений;
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ОбъектИсчисления", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Индексы.Добавить("ФизическоеЛицо, МесяцНалоговогоПериода");
	
	СтруктураПоискаПоФизЛицам = Новый Структура("ФизическоеЛицо, МесяцНалоговогоПериода");

	Для Каждого СтрокаТаблицы Из ТаблицаДляОбработки Цикл
		
		ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
		
		// применение максимального предела отключено до получения точных разъяснений
		// корректируем максимальный доход только в окончательном расчете, если есть несколько видов дохода в месяце начисления
		НеобходимаКорректировкаМакисмальногоОграничения = Ложь; //ОкончательныйРасчет И СтрокаТаблицы.ЕстьНесколькоВидовДоходов;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			ЗаполнитьЗначенияСвойств(СтруктураПоискаПоФизЛицам, СтрокаТаблицы);

			// сумма взносов исчисленная
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			
			Если МассивВзносов.Количество() > 0 Тогда
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = МассивВзносов[0].ОбъектИсчисления;
			Иначе
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			КонецЕсли;
			
		Иначе
			
			ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			
		КонецЕсли;
		
		МаксимальныйРазмерОрганиченияДохода = СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода - ОбъектИсчисленияПоДругимВидамВДанномРасчете;
		МинимальныйРазмерОрганиченияДохода = СтрокаТаблицы.МинимальныйРазмерОрганиченияДохода;
        ОблагаемыйДоходСУчетомОПВ = СтрокаТаблицы.ОблагаемыйДоход - СтрокаТаблицы.ИсчисленныеОПВ;
		
		Если ОблагаемыйДоходСУчетомОПВ <= 0 Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияСО = 0;
			
		ИначеЕсли ОблагаемыйДоходСУчетомОПВ < МинимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияСО = МинимальныйРазмерОрганиченияДохода;
			
		ИначеЕсли ОблагаемыйДоходСУчетомОПВ >= МаксимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияСО = МаксимальныйРазмерОрганиченияДохода;
			
		Иначе
			
			СтрокаТаблицы.ОбъектИсчисленияСО = ОблагаемыйДоходСУчетомОПВ;
			
		КонецЕсли;
		
		СтрокаТаблицы.ИсчисленныеСО = СтрокаТаблицы.ОбъектИсчисленияСО * СтрокаТаблицы.Ставка;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			Если МассивВзносов.Количество() > 0 Тогда
				СтрокаВзносовТаблицаВзносовПоФизЛицам = МассивВзносов[0];
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления + СтрокаТаблицы.ОбъектИсчисленияСО;
			Иначе
				СтрокаВзносовТаблицаВзносовПоФизЛицам = ТаблицаВзносовПоФизЛицамПоДругимДоходам.Добавить();
				СтрокаВзносовТаблицаВзносовПоФизЛицам.МесяцНалоговогоПериода = СтрокаТаблицы.МесяцНалоговогоПериода;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ФизическоеЛицо = СтрокаТаблицы.ФизическоеЛицо;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаТаблицы.ОбъектИсчисленияСО;
			КонецЕсли;
			
		КонецЕсли;

	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаДляОбработки, РезультатЗапроса);
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеСОВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияСОВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектСОИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеСО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияСО,ИсчисленныеСО", ТочностьРаспределения);
	КонецЦикла;
	
	ТаблицаДляСН = РезультатыРасчетов.Скопировать();
	
	Для каждого СтрокаТЗ Из ТаблицаДляСН Цикл
		СтрокаТЗ.ИсчисленныеСО = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеСО, ТочностьОкругления, ПравилоОкругления);
	КонецЦикла; 
	
	Запрос.УстановитьПараметр("ИсчисленныеСО", ТаблицаДляСН.Скопировать());	
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеСОПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияСОВЦеломЗаПериод, 	ИсчисленныеСОВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектСОИсчисленныйРанее, 			РанееИсчисленныеСО,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияСО, 				ИсчисленныеСО");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0 
			И (СтрокаТЗ.ИсчисленныеСО < 1 И СтрокаТЗ.ИсчисленныеСО > 0
				ИЛИ СтрокаТЗ.ИсчисленныеСО > -1 И СтрокаТЗ.ИсчисленныеСО < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеСО = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеСО = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеСО, ТочностьОкругления, ПравилоОкругления);
			
		КонецЕсли;
	КонецЦикла; 

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаСО.МесяцНалоговогоПериода,
		|	ТаблицаСО.ФизическоеЛицо,
		|	ТаблицаСО.Подразделение,
		|	ТаблицаСО.ВидДохода,
		|	ТаблицаСО.ОбъектИсчисленияСО,
		|	ТаблицаСО.ИсчисленныеСО
		|ПОМЕСТИТЬ ВТИсчисленныеСОПоПодразделениям
		|ИЗ
		|	&ИсчисленныеСО КАК ТаблицаСО
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеСОПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеСОПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеСОПоПодразделениям.ВидДохода,
		|	СУММА(ВТИсчисленныеСОПоПодразделениям.ОбъектИсчисленияСО) КАК ОбъектИсчисленияСО,
		|	СУММА(ВТИсчисленныеСОПоПодразделениям.ИсчисленныеСО) КАК ИсчисленныеСО
		|ПОМЕСТИТЬ ВТИсчисленныеСО
		|ИЗ
		|	ВТИсчисленныеСОПоПодразделениям КАК ВТИсчисленныеСОПоПодразделениям
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТИсчисленныеСОПоПодразделениям.МесяцНалоговогоПериода,
		|	ВТИсчисленныеСОПоПодразделениям.ФизическоеЛицо,
		|	ВТИсчисленныеСОПоПодразделениям.ВидДохода";
		
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсчисленныеСОПоПодразделениям");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьСОПосле2026(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("КонецМесяцаРасчета", КонецМесяца(МесяцНачисления));
	Запрос.УстановитьПараметр("ОкончательныйРасчет", ОкончательныйРасчет);
	
	СоздатьВТИсключаемыеЛицаСО(МенеджерВременныхТаблиц, МесяцНачисления);
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеСО");
	
	ВидНалогаВзносаСО =  Перечисления.ВидыНалоговВзносовОтчислений.СО;
	
	ДанныеОкругления = ПолучитьСпособОкругленияСПериодом(МенеджерВременныхТаблиц, ВидНалогаВзносаСО);
	СпособОкругления = ДанныеОкругления.СпособОкругления;
	ПериодОкругления = ДанныеОкругления.Период;
	
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	Если ПериодОкругления >= '20220101' Тогда
		// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
		ТочностьОкругления = ОписаниеСпособаОкругления.Точность;
		ПравилоОкругления = ОписаниеСпособаОкругления.ПравилоОкругления;		
	Иначе
		ТочностьОкругления = 1;
		ПравилоОкругления = Перечисления.ПравилаОкругленияПриРасчетеЗарплаты.ВБольшуюСторону;		
	КонецЕсли;

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругленияДляРаспределения = ТочностьОкругления - Цел(ТочностьОкругления);
	
	Если ТочностьОкругленияДляРаспределения = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругленияДляРаспределения <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
    ПараметрыПолученияДанных = Новый Структура("Организация, ВидНалогаВзносаОтчисления, МесяцНачисления", Организация, ВидНалогаВзносаСО, МесяцНачисления);
	СоздатьВТДоходыПосле2026(МенеджерВременныхТаблиц, ПараметрыПолученияДанных, "ВТИсключаемыеФизическиеЛицаПриРасчетеСО");
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных СО
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаСО);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// - Размер ограничения доходов, облагаемых СО, по периодам
	// - Исчисленные СО
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода,
		|	РазмерыМЗППоПериодам.РазмерМЗП * 7 КАК МаксимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	МАКСИМУМ(Доходы.ОблагаемыйДоход) КАК ОблагаемыйДоход,
		|	ЕСТЬNULL(СтавкиСО.Ставка, 0) КАК Ставка,
		|	МАКСИМУМ(ВЫБОР
		|		КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтНалоговогоАгента)
		|			ТОГДА 0
		|		ИНАЧЕ РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|	КОНЕЦ) КАК МинимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(РазмерыОграниченийПоДоходам.МаксимальныйРазмерОрганиченияДохода) КАК МаксимальныйРазмерОрганиченияДохода,
		|	МАКСИМУМ(ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0)) КАК ИсчисленныеОПВ,
		|	МАКСИМУМ(ВЫБОР КОГДА ДругиеВидыДоходов.ВидДохода ЕСТЬ NULL ТОГДА ЛОЖЬ ИНАЧЕ ИСТИНА КОНЕЦ) КАК ЕстьНесколькоВидовДоходов,
		|	0 КАК ОбъектИсчисленияСО,
		|	0 КАК ИсчисленныеСО
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиСО
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиСО.МесяцНалоговогоПериода
		|			И Доходы.ВидДохода = СтавкиСО.ВидДохода
		|			И (СтавкиСО.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.СО))
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДоходы КАК ДругиеВидыДоходов
		|		ПО ДругиеВидыДоходов.МесяцНалоговогоПериода = Доходы.МесяцНалоговогоПериода
		|			И ДругиеВидыДоходов.ФизическоеЛицо = Доходы.ФизическоеЛицо
		|			И НЕ ДругиеВидыДоходов.ВидДохода = Доходы.ВидДохода
		|			И НЕ ДругиеВидыДоходов.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеОПВ КАК ИсчисленныеОПВПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеОПВПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеОПВПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеОПВПоПериодам.ВидДохода
		|ГДЕ
		|	&ОкончательныйРасчет
		|	ИЛИ НЕ Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|	
		|СГРУППИРОВАТЬ ПО
		|	Доходы.МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо,
		|	Доходы.ВидДохода,
		|	ЕСТЬNULL(СтавкиСО.Ставка, 0)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Доходы.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеСОПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеСОПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеСОПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеСОПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеСОПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеСОПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеСОПоПодразделениям.ОбъектИсчисления КАК ОбъектСОИсчисленныйРанее,
		|	ИсчисленныеСОПоПодразделениям.НалогВзнос КАК РанееИсчисленныеСО,
		|	-ИсчисленныеСОПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеСОПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеСОПоПодразделениям.НалогВзнос КАК ИсчисленныеСО,
		|	-ИсчисленныеСОПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияСО
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеСОПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеСОПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеСОПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеСОПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеСОПоПодразделениям.НалогВзнос <> 0)
		|	И НЕ ИсчисленныеСОПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеСОПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	
	РезультатЗапроса = Новый ТаблицаЗначений;
	РезультатЗапроса.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатЗапроса.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатЗапроса.Колонки.Добавить("ВидДохода", Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатЗапроса.Колонки.Добавить("МинимальныйРазмерОрганиченияДохода", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("МаксимальныйРазмерОрганиченияДохода", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ОбъектИсчисленияСО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатЗапроса.Колонки.Добавить("ИсчисленныеСО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаДляОбработки = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам = Новый ТаблицаЗначений;
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("МесяцНалоговогоПериода", Новый ОписаниеТипов("Дата", Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Колонки.Добавить("ОбъектИсчисления", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ТаблицаВзносовПоФизЛицамПоДругимДоходам.Индексы.Добавить("ФизическоеЛицо, МесяцНалоговогоПериода");
	
	СтруктураПоискаПоФизЛицам = Новый Структура("ФизическоеЛицо, МесяцНалоговогоПериода");

	Для Каждого СтрокаТаблицы Из ТаблицаДляОбработки Цикл
		
		ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
		
		// применение максимального предела отключено до получения точных разъяснений
		// корректируем максимальный доход только в окончательном расчете, если есть несколько видов дохода в месяце начисления
		НеобходимаКорректировкаМакисмальногоОграничения = Ложь; //ОкончательныйРасчет И СтрокаТаблицы.ЕстьНесколькоВидовДоходов;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			ЗаполнитьЗначенияСвойств(СтруктураПоискаПоФизЛицам, СтрокаТаблицы);

			// сумма взносов исчисленная
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			
			Если МассивВзносов.Количество() > 0 Тогда
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = МассивВзносов[0].ОбъектИсчисления;
			Иначе
				ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			КонецЕсли;
			
		Иначе
			
			ОбъектИсчисленияПоДругимВидамВДанномРасчете = 0;
			
		КонецЕсли;
		
		МаксимальныйРазмерОрганиченияДохода = СтрокаТаблицы.МаксимальныйРазмерОрганиченияДохода - ОбъектИсчисленияПоДругимВидамВДанномРасчете;
		МинимальныйРазмерОрганиченияДохода = СтрокаТаблицы.МинимальныйРазмерОрганиченияДохода;
        ОблагаемыйДоходСУчетомОПВ = СтрокаТаблицы.ОблагаемыйДоход - СтрокаТаблицы.ИсчисленныеОПВ;
		
		Если ОблагаемыйДоходСУчетомОПВ <= 0 Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияСО = 0;
			
		ИначеЕсли ОблагаемыйДоходСУчетомОПВ < МинимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияСО = МинимальныйРазмерОрганиченияДохода;
			
		ИначеЕсли ОблагаемыйДоходСУчетомОПВ >= МаксимальныйРазмерОрганиченияДохода Тогда
			
			СтрокаТаблицы.ОбъектИсчисленияСО = МаксимальныйРазмерОрганиченияДохода;
			
		Иначе
			
			СтрокаТаблицы.ОбъектИсчисленияСО = ОблагаемыйДоходСУчетомОПВ;
			
		КонецЕсли;
		
		СтрокаТаблицы.ИсчисленныеСО = СтрокаТаблицы.ОбъектИсчисленияСО * СтрокаТаблицы.Ставка;
		
		Если НеобходимаКорректировкаМакисмальногоОграничения Тогда
			
			МассивВзносов = ТаблицаВзносовПоФизЛицамПоДругимДоходам.НайтиСтроки(СтруктураПоискаПоФизЛицам);
			Если МассивВзносов.Количество() > 0 Тогда
				СтрокаВзносовТаблицаВзносовПоФизЛицам = МассивВзносов[0];
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления + СтрокаТаблицы.ОбъектИсчисленияСО;
			Иначе
				СтрокаВзносовТаблицаВзносовПоФизЛицам = ТаблицаВзносовПоФизЛицамПоДругимДоходам.Добавить();
				СтрокаВзносовТаблицаВзносовПоФизЛицам.МесяцНалоговогоПериода = СтрокаТаблицы.МесяцНалоговогоПериода;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ФизическоеЛицо = СтрокаТаблицы.ФизическоеЛицо;
				СтрокаВзносовТаблицаВзносовПоФизЛицам.ОбъектИсчисления = СтрокаТаблицы.ОбъектИсчисленияСО;
			КонецЕсли;
			
		КонецЕсли;

	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаДляОбработки, РезультатЗапроса);
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеСОВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияСОВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектСОИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеСО", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияСО,ИсчисленныеСО", ТочностьРаспределения);
	КонецЦикла;
	
	ТаблицаДляВычетовИПН = РезультатыРасчетов.Скопировать(, "МесяцНалоговогоПериода, ФизическоеЛицо, Подразделение, ВидДохода, ИсчисленныеСОВЦеломЗаПериод");
	
	Для каждого СтрокаТЗ Из ТаблицаДляВычетовИПН Цикл
		СтрокаТЗ.ИсчисленныеСОВЦеломЗаПериод = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеСОВЦеломЗаПериод, ТочностьОкругления, ПравилоОкругления);
	КонецЦикла; 
	
	Запрос.УстановитьПараметр("ИсчисленныеСО", ТаблицаДляВычетовИПН);	
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеСОПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияСОВЦеломЗаПериод, 	ИсчисленныеСОВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектСОИсчисленныйРанее, 			РанееИсчисленныеСО,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияСО, 				ИсчисленныеСО");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при межрасчете или исправлении или перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0 
			И (СтрокаТЗ.ИсчисленныеСО < 1 И СтрокаТЗ.ИсчисленныеСО > 0
				ИЛИ СтрокаТЗ.ИсчисленныеСО > -1 И СтрокаТЗ.ИсчисленныеСО < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеСО = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеСО = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеСО, ТочностьОкругления, ПравилоОкругления);
			
		КонецЕсли;
	КонецЦикла; 

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаСО.МесяцНалоговогоПериода,
		|	ТаблицаСО.ФизическоеЛицо,
		|	ТаблицаСО.Подразделение,
		|	ТаблицаСО.ВидДохода,
		|	ТаблицаСО.ИсчисленныеСОВЦеломЗаПериод КАК ИсчисленныеСО
		|ПОМЕСТИТЬ ВТИсчисленныеСОПоПодразделениям
		|ИЗ
		|	&ИсчисленныеСО КАК ТаблицаСО";
		
	Запрос.Выполнить();
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьСНДо2019(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт

	УничтожитьВТ = Новый Массив;
	
	ВидНалогаВзносаСН =  Перечисления.ВидыНалоговВзносовОтчислений.СН;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаСН);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленного СН
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаСН);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) КАК ИсчисленныеОПВ,
		|	ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0) КАК ИсчисленныеСО,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0)
		|	КОНЕЦ КАК ОбъектИсчисленияСН,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|				И РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода * ЕСТЬNULL(СтавкиСН.Ставка, 0) >= ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода * ЕСТЬNULL(СтавкиСН.Ставка, 0) - ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|		КОГДА (Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0)) * ЕСТЬNULL(СтавкиСН.Ставка, 0) >= ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|			ТОГДА (Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0)) * ЕСТЬNULL(СтавкиСН.Ставка, 0) - ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК ИсчисленныйСН
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиСН
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиСН.МесяцНалоговогоПериода
		|			И (СтавкиСН.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.СН))
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеОПВ КАК ИсчисленныеОПВПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеОПВПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеОПВПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеОПВПоПериодам.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеСО КАК ИсчисленныеСОПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеСОПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеСОПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеСОПоПериодам.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныйСНПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныйСНПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныйСНПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныйСНПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныйСНПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйСНПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйСНПоПодразделениям.ОбъектИсчисления КАК ОбъектСНИсчисленныйРанее,
		|	ИсчисленныйСНПоПодразделениям.НалогВзнос КАК РанееИсчисленныйСН,
		|	-ИсчисленныйСНПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныйСНПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныйСНПоПодразделениям.НалогВзнос КАК ИсчисленныйСН,
		|	-ИсчисленныйСНПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияСН
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныйСНПоПодразделениям
		|ГДЕ
		|	(ИсчисленныйСНПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйСНПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйСНПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныйСНПоПодразделениям.НалогВзнос <> 0)";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеСНПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	РезультатЗапроса = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныйСНВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияСНВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектСНИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныйСН", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияСН,ИсчисленныйСН");
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеСНПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияСНВЦеломЗаПериод, 	ИсчисленныйСНВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектСНИсчисленныйРанее, 			РанееИсчисленныйСН,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияСН, 				ИсчисленныйСН");
	
	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаСН);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		СтрокаТЗ.ИсчисленныйСН = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныйСН, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьСНПосле2019(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт

	УничтожитьВТ = Новый Массив;
	
	ВидНалогаВзносаСН =  Перечисления.ВидыНалоговВзносовОтчислений.СН;
	ПрименятьКорректировкуПрочихНалоговВзносовОтчислений = ЗарплатаКадрыРКПовтИсп.ПрименятьКорректировкуПрочихНалоговВзносовОтчислений(ЗарплатаКадрыПовтИсп.ГоловнаяОрганизация(Организация), МесяцНачисления);	
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаСН);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленного СН
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаСН);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	СоздатьВТДанныеПоКорректировкеДоходаИПН(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет, ИсключатьДоходыРегистратора, ПрименятьКорректировкуПрочихНалоговВзносовОтчислений);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ПрименятьКорректировкуПрочихНалоговВзносовОтчислений", ПрименятьКорректировкуПрочихНалоговВзносовОтчислений);
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДанныеИПН.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДанныеИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|	СУММА(ДанныеИПН.СуммаКорректировки) КАК СуммаКорректировки
		|ПОМЕСТИТЬ ВТСуммыКорректировки
		|ИЗ
		|	(ВЫБРАТЬ
		|		ИсчисленныйИПН.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|		ИсчисленныйИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|		ЕСТЬNULL(ИсчисленныйИПН.ПримененнаяКорректировка, 0) КАК СуммаКорректировки
		|	ИЗ
		|		ВТИсчисленныйИПН КАК ИсчисленныйИПН
		|	ГДЕ	
		|		&ПрименятьКорректировкуПрочихНалоговВзносовОтчислений
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		Доходы.МесяцНалоговогоПериода,
		|		Доходы.ФизическоеЛицо,
		|		ЕСТЬNULL(ДанныеПоКорректировкеДоходаИПН.ПримененнаяКорректировка, 0)
		|	ИЗ
		|		ВТДоходы КАК Доходы
		|			ЛЕВОЕ СОЕДИНЕНИЕ ВТДанныеПоКорректировкеДоходаИПН КАК ДанныеПоКорректировкеДоходаИПН
		|			ПО Доходы.МесяцНалоговогоПериода = ДанныеПоКорректировкеДоходаИПН.МесяцНалоговогоПериода
		|				И Доходы.ФизическоеЛицо = ДанныеПоКорректировкеДоходаИПН.ФизическоеЛицо) КАК ДанныеИПН
		|
		|СГРУППИРОВАТЬ ПО
		|	ДанныеИПН.МесяцНалоговогоПериода,
		|	ДанныеИПН.ФизическоеЛицо
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) КАК ИсчисленныеОПВ,
		|	ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0) КАК ИсчисленныеСО,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0) <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0)
		|	КОНЕЦ КАК ОбъектИсчисленияСН,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0) <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|				И РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода * ЕСТЬNULL(СтавкиСН.Ставка, 0) >= ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода * ЕСТЬNULL(СтавкиСН.Ставка, 0) - ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|		КОГДА (Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0)) * ЕСТЬNULL(СтавкиСН.Ставка, 0) >= ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|			ТОГДА (Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0)) * ЕСТЬNULL(СтавкиСН.Ставка, 0) - ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК ИсчисленныйСН
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиСН
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиСН.МесяцНалоговогоПериода
		|			И (СтавкиСН.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.СН))
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеОПВ КАК ИсчисленныеОПВПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеОПВПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеОПВПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеОПВПоПериодам.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеСО КАК ИсчисленныеСОПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеСОПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеСОПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеСОПоПериодам.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСуммыКорректировки КАК СуммыКорректировки
		|		ПО Доходы.МесяцНалоговогоПериода = СуммыКорректировки.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = СуммыКорректировки.ФизическоеЛицо
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныйСНПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныйСНПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныйСНПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныйСНПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныйСНПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйСНПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйСНПоПодразделениям.ОбъектИсчисления КАК ОбъектСНИсчисленныйРанее,
		|	ИсчисленныйСНПоПодразделениям.НалогВзнос КАК РанееИсчисленныйСН,
		|	-ИсчисленныйСНПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныйСНПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныйСНПоПодразделениям.НалогВзнос КАК ИсчисленныйСН,
		|	-ИсчисленныйСНПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияСН
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныйСНПоПодразделениям
		|ГДЕ
		|	(ИсчисленныйСНПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйСНПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйСНПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныйСНПоПодразделениям.НалогВзнос <> 0)";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТДанныеПоКорректировкеДоходаИПН");
	УничтожитьВТ.Добавить("ВТСуммыКорректировки");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеСНПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	РезультатЗапроса = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныйСНВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияСНВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектСНИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныйСН", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияСН,ИсчисленныйСН");
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеСНПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияСНВЦеломЗаПериод, 	ИсчисленныйСНВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектСНИсчисленныйРанее, 			РанееИсчисленныйСН,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияСН, 				ИсчисленныйСН");
	
	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаСН);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		СтрокаТЗ.ИсчисленныйСН = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныйСН, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьСНПосле2020(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт

	УничтожитьВТ = Новый Массив;
	
	ВидНалогаВзносаСН =  Перечисления.ВидыНалоговВзносовОтчислений.СН;
	ПрименятьКорректировкуПрочихНалоговВзносовОтчислений = ЗарплатаКадрыРКПовтИсп.ПрименятьКорректировкуПрочихНалоговВзносовОтчислений(ЗарплатаКадрыПовтИсп.ГоловнаяОрганизация(Организация), МесяцНачисления);	
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаСН);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленного СН
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаСН);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	СоздатьВТДанныеПоКорректировкеДоходаИПН(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет, ИсключатьДоходыРегистратора, ПрименятьКорректировкуПрочихНалоговВзносовОтчислений);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ПрименятьКорректировкуПрочихНалоговВзносовОтчислений", ПрименятьКорректировкуПрочихНалоговВзносовОтчислений);
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДанныеИПН.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДанныеИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|	СУММА(ДанныеИПН.СуммаКорректировки) КАК СуммаКорректировки
		|ПОМЕСТИТЬ ВТСуммыКорректировки
		|ИЗ
		|	(ВЫБРАТЬ
		|		ИсчисленныйИПН.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|		ИсчисленныйИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|		ЕСТЬNULL(ИсчисленныйИПН.ПримененнаяКорректировка, 0) КАК СуммаКорректировки
		|	ИЗ
		|		ВТИсчисленныйИПН КАК ИсчисленныйИПН
		|	ГДЕ	
		|		&ПрименятьКорректировкуПрочихНалоговВзносовОтчислений
		|	
		|	ОБЪЕДИНИТЬ ВСЕ
		|	
		|	ВЫБРАТЬ
		|		Доходы.МесяцНалоговогоПериода,
		|		Доходы.ФизическоеЛицо,
		|		ЕСТЬNULL(ДанныеПоКорректировкеДоходаИПН.ПримененнаяКорректировка, 0)
		|	ИЗ
		|		ВТДоходы КАК Доходы
		|			ЛЕВОЕ СОЕДИНЕНИЕ ВТДанныеПоКорректировкеДоходаИПН КАК ДанныеПоКорректировкеДоходаИПН
		|			ПО Доходы.МесяцНалоговогоПериода = ДанныеПоКорректировкеДоходаИПН.МесяцНалоговогоПериода
		|				И Доходы.ФизическоеЛицо = ДанныеПоКорректировкеДоходаИПН.ФизическоеЛицо) КАК ДанныеИПН
		|
		|СГРУППИРОВАТЬ ПО
		|	ДанныеИПН.МесяцНалоговогоПериода,
		|	ДанныеИПН.ФизическоеЛицо
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) КАК ИсчисленныеОПВ,
		|	ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0) КАК ИсчисленныеСО,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0) <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0)
		|	КОНЕЦ КАК ОбъектИсчисленияСН,
		|	ВЫБОР
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0) <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|				И РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода * ЕСТЬNULL(СтавкиСН.Ставка, 0) >= ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода * ЕСТЬNULL(СтавкиСН.Ставка, 0) - ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|		КОГДА (Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0)) * ЕСТЬNULL(СтавкиСН.Ставка, 0) >= ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|			ТОГДА (Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(СуммыКорректировки.СуммаКорректировки, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0)) * ЕСТЬNULL(СтавкиСН.Ставка, 0) - ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК ИсчисленныйСН
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиСН
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиСН.МесяцНалоговогоПериода
		|			И (СтавкиСН.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.СН))
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеОПВ КАК ИсчисленныеОПВПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеОПВПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеОПВПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеОПВПоПериодам.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеСО КАК ИсчисленныеСОПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеСОПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеСОПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеСОПоПериодам.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСуммыКорректировки КАК СуммыКорректировки
		|		ПО Доходы.МесяцНалоговогоПериода = СуммыКорректировки.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = СуммыКорректировки.ФизическоеЛицо
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеВОСМС КАК ИсчисленныеВОСМСПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеВОСМСПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеВОСМСПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеВОСМСПоПериодам.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныйСНПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныйСНПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныйСНПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныйСНПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныйСНПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйСНПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйСНПоПодразделениям.ОбъектИсчисления КАК ОбъектСНИсчисленныйРанее,
		|	ИсчисленныйСНПоПодразделениям.НалогВзнос КАК РанееИсчисленныйСН,
		|	-ИсчисленныйСНПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныйСНПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныйСНПоПодразделениям.НалогВзнос КАК ИсчисленныйСН,
		|	-ИсчисленныйСНПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияСН
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныйСНПоПодразделениям
		|ГДЕ
		|	(ИсчисленныйСНПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйСНПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйСНПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныйСНПоПодразделениям.НалогВзнос <> 0)";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	УничтожитьВТ.Добавить("ВТДанныеПоКорректировкеДоходаИПН");
	УничтожитьВТ.Добавить("ВТСуммыКорректировки");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеСНПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	РезультатЗапроса = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныйСНВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияСНВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектСНИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныйСН", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаСН);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
	
	Если ТочностьОкругления = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругления <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;
			
	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияСН,ИсчисленныйСН", ТочностьРаспределения);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеСНПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияСНВЦеломЗаПериод, 	ИсчисленныйСНВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектСНИсчисленныйРанее, 			РанееИсчисленныйСН,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияСН, 				ИсчисленныйСН");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0
			И НЕ ОписаниеСпособаОкругления.ПравилоОкругления = Перечисления.ПравилаОкругленияПриРасчетеЗарплаты.Авто
			И (СтрокаТЗ.ИсчисленныйСН < 1 И СтрокаТЗ.ИсчисленныйСН > 0
				ИЛИ СтрокаТЗ.ИсчисленныйСН > -1 И СтрокаТЗ.ИсчисленныйСН < 0) Тогда
				
			СтрокаТЗ.ИсчисленныйСН = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныйСН = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныйСН, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
			
		КонецЕсли;
		
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьСНПосле2021(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт

	УничтожитьВТ = Новый Массив;
	
	ВидНалогаВзносаСН =  Перечисления.ВидыНалоговВзносовОтчислений.СН;
	
	// Получаем применение вычета в месяц отсутствия дохода
	УчетнаяПолитикаНУ = РегистрыСведений.УчетнаяПолитикаПоНалоговомуУчету.СрезПоследних(МесяцНачисления, Новый Структура("Организация", Организация));
	ДанныеОрганизации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Организация, "ЮридическоеФизическоеЛицо, ИндивидуальныйПредприниматель");
	ОрганизацияЯвляетсяИП = (ДанныеОрганизации.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо);
	ФизическоеЛицоИП = ДанныеОрганизации.ИндивидуальныйПредприниматель;
	
	РежимНалогообложения = Перечисления.СистемыНалогообложения.Общая;
	КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя = 0;
	КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника = 0;
	
	// в расчете учитываем все три возможные положения 
	// РежимНалогообложения = ПустаяСсылка
	// для ИП и юр лица считаем как раньше
	//
	// РежимНалогообложения = Общая
	// для ИП считаем СН с учетом Коэффициентов
	// для юр лица считаем как раньше
	//
	// РежимНалогообложения = Упрощенная
	// для ИП и юр лица не считаем СН
	Если УчетнаяПолитикаНУ.Количество() > 0 Тогда
		
		РежимНалогообложения = УчетнаяПолитикаНУ[0].СистемаНалогообложения;
		
		Если ОрганизацияЯвляетсяИП Тогда
			
			КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя = УчетнаяПолитикаНУ[0].КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя;
			КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника = УчетнаяПолитикаНУ[0].КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника;
			
		КонецЕсли;
		
		// не плательщик СН, независимо что в регистре
		Если РежимНалогообложения = Перечисления.СистемыНалогообложения.Упрощенная Тогда
			КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя = 0;
			КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника 			   = 0;
		КонецЕсли;
		
	КонецЕсли;
	
	// поддержим расчеты, существовавшие до реализации расчетов за ИП
	// РежимНалогообложения = СпециальныйНалоговыйРежимНаОсновеУпрощеннойДекларации
	// для ИП и юр лица не считаем СН с обнуленными коэффициентами
	РасчетСНПоКоэффициентуМРП = (ОрганизацияЯвляетсяИП И НЕ РежимНалогообложения = Перечисления.СистемыНалогообложения.ПустаяСсылка())
								ИЛИ (НЕ ОрганизацияЯвляетсяИП И РежимНалогообложения = Перечисления.СистемыНалогообложения.Упрощенная);
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаСН);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленного СН
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаСН);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ФизическоеЛицоИП", ФизическоеЛицоИП);
	Запрос.УстановитьПараметр("МесяцНалоговогоПериода", МесяцНачисления);
	Запрос.УстановитьПараметр("РасчетСНПоКоэффициентуМРП", РасчетСНПоКоэффициентуМРП);
	Запрос.УстановитьПараметр("КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя", КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя);
	Запрос.УстановитьПараметр("КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника", КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ИсключаемыйРегистратор", ?(ИсключатьДоходыРегистратора, Регистратор, Неопределено));
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РазмерыМЗППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	РазмерыМЗППоПериодам.РазмерМЗП КАК МинимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМЗППоПериодам КАК РазмерыМЗППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) КАК ИсчисленныеОПВ,
		|	ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0) КАК ИсчисленныеСО,
		|	ВЫБОР
		|		КОГДА &РасчетСНПоКоэффициентуМРП
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0) <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0)
		|	КОНЕЦ КАК ОбъектИсчисленияСН,
		|	ВЫБОР
		|		КОГДА &РасчетСНПоКоэффициентуМРП
		|			ТОГДА ВЫБОР
		|					КОГДА ВЫБОР
		|							КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|								И Доходы.ФизическоеЛицо = &ФизическоеЛицоИП
		|								ТОГДА РазмерыМРППоПериодам.РазмерМРП * &КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя
		|							КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|								ТОГДА РазмерыМРППоПериодам.РазмерМРП * &КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника
		|							ИНАЧЕ 0
		|						КОНЕЦ > ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|						ТОГДА ВЫБОР
		|								КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|									И Доходы.ФизическоеЛицо = &ФизическоеЛицоИП
		|									ТОГДА РазмерыМРППоПериодам.РазмерМРП * &КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя
		|								КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|									ТОГДА РазмерыМРППоПериодам.РазмерМРП * &КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника
		|								ИНАЧЕ 0
		|							КОНЕЦ - ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|					ИНАЧЕ 0
		|				КОНЕЦ
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0) <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|				И РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода * ЕСТЬNULL(СтавкиСН.Ставка, 0) >= ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода * ЕСТЬNULL(СтавкиСН.Ставка, 0) - ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|		КОГДА (Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0)) * ЕСТЬNULL(СтавкиСН.Ставка, 0) >= ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|			ТОГДА (Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0)) * ЕСТЬNULL(СтавкиСН.Ставка, 0) - ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК ИсчисленныйСН
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыМРППоПериодам КАК РазмерыМРППоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыМРППоПериодам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиСН
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиСН.МесяцНалоговогоПериода
		|			И (СтавкиСН.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.СН))
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеОПВ КАК ИсчисленныеОПВПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеОПВПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеОПВПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеОПВПоПериодам.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеСО КАК ИсчисленныеСОПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеСОПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеСОПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеСОПоПериодам.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеВОСМС КАК ИсчисленныеВОСМСПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеВОСМСПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеВОСМСПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеВОСМСПоПериодам.ВидДохода
		|ГДЕ
		|	НЕ Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства) 
		|	ИЛИ &РасчетСНПоКоэффициентуМРП
		|
		// добавим сотрудников без дохода в месяце начисления для ИП
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	&МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	КадровыеДанныеСотрудников.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя) КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	0 КАК ИсчисленныеОПВ,
		|	0 КАК ИсчисленныеСО,
		|	0 КАК ОбъектИсчисленияСН,
		|	РазмерыМРППоПериодам.РазмерМРП * &КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника КАК ИсчисленныйСН
		|ИЗ
		|	ВТКадровыеДанныеСотрудников КАК КадровыеДанныеСотрудников
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДоходы КАК Доходы
		|		ПО Доходы.ФизическоеЛицо = КадровыеДанныеСотрудников.ФизическоеЛицо
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО &МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыМРППоПериодам КАК РазмерыМРППоПериодам
		|		ПО &МесяцНалоговогоПериода = РазмерыМРППоПериодам.МесяцНалоговогоПериода
		|ГДЕ
		|	&РасчетСНПоКоэффициентуМРП
		|   И Доходы.ФизическоеЛицо ЕСТЬ NULL
		|   И (&МесяцНалоговогоПериода МЕЖДУ КадровыеДанныеСотрудников.ДатаПриема И КадровыеДанныеСотрудников.ДатаУвольнения
		|		ИЛИ (КадровыеДанныеСотрудников.ДатаПриема >= &МесяцНалоговогоПериода И КадровыеДанныеСотрудников.ДатаУвольнения = ДАТАВРЕМЯ(1, 1, 1)))
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ВЫБОР КОГДА &РасчетСНПоКоэффициентуМРП ТОГДА 0 ИНАЧЕ ДоходыПоПодразделениям.ОблагаемыйДоход КОНЕЦ КАК ОблагаемыйДоход,
		|	ВЫБОР КОГДА &РасчетСНПоКоэффициентуМРП ТОГДА 0 ИНАЧЕ ДоходыПоПодразделениям.НеоблагаемыйДоход КОНЕЦ КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|	И НЕ ДоходыПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства) 
		|	ИЛИ &РасчетСНПоКоэффициентуМРП
		|
		// добавим сотрудников без дохода в месяце начисления для ИП
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	КадровыеДанныеСотрудников.ТекущееПодразделение,
		|	&МесяцНалоговогоПериода,
		|	КадровыеДанныеСотрудников.ФизическоеЛицо,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя),
		|	0,
		|	0
		|ИЗ
		|	ВТКадровыеДанныеСотрудников КАК КадровыеДанныеСотрудников
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДоходы КАК Доходы
		|		ПО Доходы.ФизическоеЛицо = КадровыеДанныеСотрудников.ФизическоеЛицо
		|ГДЕ
		|	&РасчетСНПоКоэффициентуМРП
		|   И Доходы.ФизическоеЛицо ЕСТЬ NULL
		|   И (&МесяцНалоговогоПериода МЕЖДУ КадровыеДанныеСотрудников.ДатаПриема И КадровыеДанныеСотрудников.ДатаУвольнения
		|		ИЛИ (КадровыеДанныеСотрудников.ДатаПриема >= &МесяцНалоговогоПериода И КадровыеДанныеСотрудников.ДатаУвольнения = ДАТАВРЕМЯ(1, 1, 1)))
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныйСНПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныйСНПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныйСНПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныйСНПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныйСНПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйСНПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйСНПоПодразделениям.ОбъектИсчисления КАК ОбъектСНИсчисленныйРанее,
		|	ИсчисленныйСНПоПодразделениям.НалогВзнос КАК РанееИсчисленныйСН,
		|	-ИсчисленныйСНПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныйСНПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныйСНПоПодразделениям.НалогВзнос КАК ИсчисленныйСН,
		|	-ИсчисленныйСНПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияСН
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныйСНПоПодразделениям
		|ГДЕ
		|	(ИсчисленныйСНПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйСНПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйСНПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныйСНПоПодразделениям.НалогВзнос <> 0)
		|	И НЕ ИсчисленныйСНПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|	ИЛИ &РасчетСНПоКоэффициентуМРП
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(СведенияОбИсчисленииНалоговВзносовОтчислений.Период, МЕСЯЦ) КАК МесяцНалоговогоПериода,
		|	СведенияОбИсчисленииНалоговВзносовОтчислений.Подразделение,
		|	СведенияОбИсчисленииНалоговВзносовОтчислений.ФизическоеЛицо,
		|	СведенияОбИсчисленииНалоговВзносовОтчислений.ВидДохода,
		|	0,
		|	0,
		|	0,
		|	0,
		|	-СУММА(СведенияОбИсчисленииНалоговВзносовОтчислений.ОблагаемыйДоходОборот),
		|	-СУММА(СведенияОбИсчисленииНалоговВзносовОтчислений.НеоблагаемыйДоходОборот),
		|	-СУММА(СведенияОбИсчисленииНалоговВзносовОтчислений.НалогВзносОборот),
		|	-СУММА(СведенияОбИсчисленииНалоговВзносовОтчислений.ОбъектИсчисленияОборот)
		|ИЗ
		|	РегистрНакопления.СведенияОбИсчисленииНалоговВзносовОтчислений.Обороты(
		|			&МесяцНалоговогоПериода,
		|			КОНЕЦПЕРИОДА(&МесяцНалоговогоПериода, МЕСЯЦ),
		|			Регистратор,
		|			Организация = &Организация
		|				И ФизическоеЛицо В
		|					(ВЫБРАТЬ
		|						КадровыеДанныеСотрудников.ФизическоеЛицо КАК ФизическоеЛицо
		|					ИЗ
		|						ВТКадровыеДанныеСотрудников КАК КадровыеДанныеСотрудников
		|							ЛЕВОЕ СОЕДИНЕНИЕ ВТДоходы КАК Доходы
		|							ПО Доходы.ФизическоеЛицо = КадровыеДанныеСотрудников.ФизическоеЛицо
		|					ГДЕ
		|						&РасчетСНПоКоэффициентуМРП
		|   					И Доходы.ФизическоеЛицо ЕСТЬ NULL)) КАК СведенияОбИсчисленииНалоговВзносовОтчислений
		|ГДЕ
		|	&РасчетСНПоКоэффициентуМРП
		|	И СведенияОбИсчисленииНалоговВзносовОтчислений.Регистратор <> &ИсключаемыйРегистратор
		|	И СведенияОбИсчисленииНалоговВзносовОтчислений.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.СН)
		|
		|СГРУППИРОВАТЬ ПО
		|	СведенияОбИсчисленииНалоговВзносовОтчислений.ФизическоеЛицо,
		|	СведенияОбИсчисленииНалоговВзносовОтчислений.ВидНалогаВзносаОтчисления,
		|	НАЧАЛОПЕРИОДА(СведенияОбИсчисленииНалоговВзносовОтчислений.Период, МЕСЯЦ),
		|	СведенияОбИсчисленииНалоговВзносовОтчислений.ВидДохода,
		|	СведенияОбИсчисленииНалоговВзносовОтчислений.Подразделение";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеСНПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	РезультатЗапроса = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныйСНВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияСНВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектСНИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныйСН", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаСН);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
	
	Если ТочностьОкругления = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругления <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;
			
	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияСН,ИсчисленныйСН", ТочностьРаспределения);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеСНПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияСНВЦеломЗаПериод, 	ИсчисленныйСНВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектСНИсчисленныйРанее, 			РанееИсчисленныйСН,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияСН, 				ИсчисленныйСН");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0
			И НЕ ОписаниеСпособаОкругления.ПравилоОкругления = Перечисления.ПравилаОкругленияПриРасчетеЗарплаты.Авто
			И (СтрокаТЗ.ИсчисленныйСН < 1 И СтрокаТЗ.ИсчисленныйСН > 0
				ИЛИ СтрокаТЗ.ИсчисленныйСН > -1 И СтрокаТЗ.ИсчисленныйСН < 0) Тогда
				
			СтрокаТЗ.ИсчисленныйСН = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныйСН = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныйСН, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
			
		КонецЕсли;
		
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьСНПосле2022(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт

	УничтожитьВТ = Новый Массив;
	
	ВидНалогаВзносаСН =  Перечисления.ВидыНалоговВзносовОтчислений.СН;
	
	// Получаем применение вычета в месяц отсутствия дохода
	УчетнаяПолитикаНУ = РегистрыСведений.УчетнаяПолитикаПоНалоговомуУчету.СрезПоследних(МесяцНачисления, Новый Структура("Организация", Организация));
	ДанныеОрганизации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Организация, "ЮридическоеФизическоеЛицо, ИндивидуальныйПредприниматель");
	ОрганизацияЯвляетсяИП = (ДанныеОрганизации.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо);
	ФизическоеЛицоИП = ДанныеОрганизации.ИндивидуальныйПредприниматель;
	
	РежимНалогообложения = Перечисления.СистемыНалогообложения.Общая;
	КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя = 0;
	КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника = 0;
	
	// в расчете учитываем все три возможные положения 
	// РежимНалогообложения = ПустаяСсылка
	// для ИП и юр лица считаем как раньше
	//
	// РежимНалогообложения = Общая
	// для ИП считаем СН с учетом Коэффициентов
	// для юр лица считаем как раньше
	//
	// РежимНалогообложения = Упрощенная
	// для ИП и юр лица не считаем СН
	Если УчетнаяПолитикаНУ.Количество() > 0 Тогда
		
		РежимНалогообложения = УчетнаяПолитикаНУ[0].СистемаНалогообложения;
		
		Если ОрганизацияЯвляетсяИП Тогда
			
			КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя = УчетнаяПолитикаНУ[0].КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя;
			КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника = УчетнаяПолитикаНУ[0].КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника;
			
		КонецЕсли;
		
		// не плательщик СН, независимо что в регистре
		Если РежимНалогообложения = Перечисления.СистемыНалогообложения.Упрощенная Тогда
			КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя = 0;
			КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника 			   = 0;
		КонецЕсли;
		
	КонецЕсли;
	
	// поддержим расчеты, существовавшие до реализации расчетов за ИП
	// РежимНалогообложения = СпециальныйНалоговыйРежимНаОсновеУпрощеннойДекларации
	// для ИП и юр лица не считаем СН с обнуленными коэффициентами
	РасчетСНПоКоэффициентуМРП = (ОрганизацияЯвляетсяИП И НЕ РежимНалогообложения = Перечисления.СистемыНалогообложения.ПустаяСсылка())
								ИЛИ (НЕ ОрганизацияЯвляетсяИП И РежимНалогообложения = Перечисления.СистемыНалогообложения.Упрощенная);
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаСН);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленного СН
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаСН);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// Статусы физических лиц как налогоплательщиков по периодам
	СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	УничтожитьВТ.Добавить("ВТСтатусыФизическихЛицКакНалогоплательщиков");
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ФизическоеЛицоИП", ФизическоеЛицоИП);
	Запрос.УстановитьПараметр("МесяцНалоговогоПериода", МесяцНачисления);
	Запрос.УстановитьПараметр("РасчетСНПоКоэффициентуМРП", РасчетСНПоКоэффициентуМРП);
	Запрос.УстановитьПараметр("КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя", КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя);
	Запрос.УстановитьПараметр("КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника", КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника);
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ИсключаемыйРегистратор", ?(ИсключатьДоходыРегистратора, Регистратор, Неопределено));
	Запрос.УстановитьПараметр("ОкончательныйРасчет", ОкончательныйРасчет);
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВТРазмерыМРППоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТРазмерыМРППоПериодам.РазмерМРП * 14 КАК МинимальныйРазмерОрганиченияДохода
		|ПОМЕСТИТЬ ВТРазмерыОграниченийПоДоходам
		|ИЗ
		|	ВТРазмерыМРППоПериодам КАК ВТРазмерыМРППоПериодам
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) КАК ИсчисленныеОПВ,
		|	ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0) КАК ИсчисленныеСО,
		|	ВЫБОР
		|		КОГДА &РасчетСНПоКоэффициентуМРП
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0) <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|		ИНАЧЕ Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0)
		|	КОНЕЦ КАК ОбъектИсчисленияСН,
		|	ВЫБОР
		|		КОГДА &РасчетСНПоКоэффициентуМРП
		|			ТОГДА ВЫБОР
		|					КОГДА ВЫБОР
		|							КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|								И Доходы.ФизическоеЛицо = &ФизическоеЛицоИП
		|								ТОГДА РазмерыМРППоПериодам.РазмерМРП * &КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя
		|							КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|								ТОГДА РазмерыМРППоПериодам.РазмерМРП * &КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника
		|							ИНАЧЕ 0
		|						КОНЕЦ > ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|						ТОГДА ВЫБОР
		|								КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|									И Доходы.ФизическоеЛицо = &ФизическоеЛицоИП
		|									ТОГДА РазмерыМРППоПериодам.РазмерМРП * &КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя
		|								КОГДА Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|									ТОГДА РазмерыМРППоПериодам.РазмерМРП * &КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника
		|								ИНАЧЕ 0
		|							КОНЕЦ - ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|					ИНАЧЕ 0
		|				КОНЕЦ
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0) <= 0
		|			ТОГДА 0
		|		КОГДА Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0) < РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода
		|				И РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода * ЕСТЬNULL(СтавкиСН.Ставка, 0) >= ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|			ТОГДА РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода * ЕСТЬNULL(СтавкиСН.Ставка, 0) - ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|		КОГДА (Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0)) * ЕСТЬNULL(СтавкиСН.Ставка, 0) >= ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|			ТОГДА (Доходы.ОблагаемыйДоход - ЕСТЬNULL(ИсчисленныеОПВПоПериодам.ИсчисленныеОПВ, 0) - ЕСТЬNULL(ИсчисленныеВОСМСПоПериодам.ИсчисленныеВОСМС, 0)) * ЕСТЬNULL(СтавкиСН.Ставка, 0) - ЕСТЬNULL(ИсчисленныеСОПоПериодам.ИсчисленныеСО, 0)
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК ИсчисленныйСН
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыМРППоПериодам КАК РазмерыМРППоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = РазмерыМРППоПериодам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиСН
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиСН.МесяцНалоговогоПериода
		|			И (СтавкиСН.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.СН))
		|			И Доходы.ВидДохода = СтавкиСН.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеОПВ КАК ИсчисленныеОПВПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеОПВПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеОПВПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеОПВПоПериодам.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеСО КАК ИсчисленныеСОПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеСОПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеСОПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеСОПоПериодам.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИсчисленныеВОСМС КАК ИсчисленныеВОСМСПоПериодам
		|		ПО Доходы.МесяцНалоговогоПериода = ИсчисленныеВОСМСПоПериодам.МесяцНалоговогоПериода
		|			И Доходы.ФизическоеЛицо = ИсчисленныеВОСМСПоПериодам.ФизическоеЛицо
		|			И Доходы.ВидДохода = ИсчисленныеВОСМСПоПериодам.ВидДохода
		|ГДЕ
		|	((НЕ Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|				ИЛИ &РасчетСНПоКоэффициентуМРП)
		|				И &ОкончательныйРасчет
		|					ИЛИ НЕ Доходы.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя))
		
		|
		// добавим сотрудников без дохода в месяце начисления для ИП
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	&МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	КадровыеДанныеСотрудников.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя) КАК ВидДохода,
		|	РазмерыОграниченийПоДоходам.МинимальныйРазмерОрганиченияДохода КАК МинимальныйРазмерОрганиченияДохода,
		|	0 КАК ИсчисленныеОПВ,
		|	0 КАК ИсчисленныеСО,
		|	0 КАК ОбъектИсчисленияСН,
		|	РазмерыМРППоПериодам.РазмерМРП * &КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника КАК ИсчисленныйСН
		|ИЗ
		|	ВТКадровыеДанныеСотрудников КАК КадровыеДанныеСотрудников
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДоходы КАК Доходы
		|		ПО Доходы.ФизическоеЛицо = КадровыеДанныеСотрудников.ФизическоеЛицо
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыОграниченийПоДоходам КАК РазмерыОграниченийПоДоходам
		|		ПО &МесяцНалоговогоПериода = РазмерыОграниченийПоДоходам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТРазмерыМРППоПериодам КАК РазмерыМРППоПериодам
		|		ПО &МесяцНалоговогоПериода = РазмерыМРППоПериодам.МесяцНалоговогоПериода
		|ГДЕ
		|	&РасчетСНПоКоэффициентуМРП
		|   И Доходы.ФизическоеЛицо ЕСТЬ NULL
		|   И (&МесяцНалоговогоПериода МЕЖДУ КадровыеДанныеСотрудников.ДатаПриема И КадровыеДанныеСотрудников.ДатаУвольнения
		|		ИЛИ (КадровыеДанныеСотрудников.ДатаПриема <= &МесяцНалоговогоПериода И КадровыеДанныеСотрудников.ДатаУвольнения = ДАТАВРЕМЯ(1, 1, 1)))
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ВЫБОР КОГДА &РасчетСНПоКоэффициентуМРП ТОГДА 0 ИНАЧЕ ДоходыПоПодразделениям.ОблагаемыйДоход КОНЕЦ КАК ОблагаемыйДоход,
		|	ВЫБОР КОГДА &РасчетСНПоКоэффициентуМРП ТОГДА 0 ИНАЧЕ ДоходыПоПодразделениям.НеоблагаемыйДоход КОНЕЦ КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|	И НЕ ДоходыПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства) 
		|	ИЛИ &РасчетСНПоКоэффициентуМРП
		|
		// добавим сотрудников без дохода в месяце начисления для ИП
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	КадровыеДанныеСотрудников.ТекущееПодразделение,
		|	&МесяцНалоговогоПериода,
		|	КадровыеДанныеСотрудников.ФизическоеЛицо,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя),
		|	0,
		|	0
		|ИЗ
		|	ВТКадровыеДанныеСотрудников КАК КадровыеДанныеСотрудников
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДоходы КАК Доходы
		|		ПО Доходы.ФизическоеЛицо = КадровыеДанныеСотрудников.ФизическоеЛицо
		|ГДЕ
		|	&РасчетСНПоКоэффициентуМРП
		|   И Доходы.ФизическоеЛицо ЕСТЬ NULL
		|   И (&МесяцНалоговогоПериода МЕЖДУ КадровыеДанныеСотрудников.ДатаПриема И КадровыеДанныеСотрудников.ДатаУвольнения
		|		ИЛИ (КадровыеДанныеСотрудников.ДатаПриема >= &МесяцНалоговогоПериода И КадровыеДанныеСотрудников.ДатаУвольнения = ДАТАВРЕМЯ(1, 1, 1)))
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныйСНПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныйСНПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныйСНПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныйСНПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныйСНПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйСНПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныйСНПоПодразделениям.ОбъектИсчисления КАК ОбъектСНИсчисленныйРанее,
		|	ИсчисленныйСНПоПодразделениям.НалогВзнос КАК РанееИсчисленныйСН,
		|	-ИсчисленныйСНПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныйСНПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныйСНПоПодразделениям.НалогВзнос КАК ИсчисленныйСН,
		|	-ИсчисленныйСНПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияСН
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныйСНПоПодразделениям
		|ГДЕ
		|	(ИсчисленныйСНПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйСНПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныйСНПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныйСНПоПодразделениям.НалогВзнос <> 0)
		|	И НЕ ИсчисленныйСНПоПодразделениям.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходСубъектаПредпринимательства)
		|	ИЛИ &РасчетСНПоКоэффициентуМРП
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(СведенияОбИсчисленииНалоговВзносовОтчислений.Период, МЕСЯЦ) КАК МесяцНалоговогоПериода,
		|	СведенияОбИсчисленииНалоговВзносовОтчислений.Подразделение,
		|	СведенияОбИсчисленииНалоговВзносовОтчислений.ФизическоеЛицо,
		|	СведенияОбИсчисленииНалоговВзносовОтчислений.ВидДохода,
		|	0,
		|	0,
		|	0,
		|	0,
		|	-СУММА(СведенияОбИсчисленииНалоговВзносовОтчислений.ОблагаемыйДоходОборот),
		|	-СУММА(СведенияОбИсчисленииНалоговВзносовОтчислений.НеоблагаемыйДоходОборот),
		|	-СУММА(СведенияОбИсчисленииНалоговВзносовОтчислений.НалогВзносОборот),
		|	-СУММА(СведенияОбИсчисленииНалоговВзносовОтчислений.ОбъектИсчисленияОборот)
		|ИЗ
		|	РегистрНакопления.СведенияОбИсчисленииНалоговВзносовОтчислений.Обороты(
		|			&МесяцНалоговогоПериода,
		|			КОНЕЦПЕРИОДА(&МесяцНалоговогоПериода, МЕСЯЦ),
		|			Регистратор,
		|			Организация = &Организация
		|				И ФизическоеЛицо В
		|					(ВЫБРАТЬ
		|						КадровыеДанныеСотрудников.ФизическоеЛицо КАК ФизическоеЛицо
		|					ИЗ
		|						ВТКадровыеДанныеСотрудников КАК КадровыеДанныеСотрудников
		|							ЛЕВОЕ СОЕДИНЕНИЕ ВТДоходы КАК Доходы
		|							ПО Доходы.ФизическоеЛицо = КадровыеДанныеСотрудников.ФизическоеЛицо
		|					ГДЕ
		|						&РасчетСНПоКоэффициентуМРП
		|   					И Доходы.ФизическоеЛицо ЕСТЬ NULL)) КАК СведенияОбИсчисленииНалоговВзносовОтчислений
		|ГДЕ
		|	&РасчетСНПоКоэффициентуМРП
		|	И СведенияОбИсчисленииНалоговВзносовОтчислений.Регистратор <> &ИсключаемыйРегистратор
		|	И СведенияОбИсчисленииНалоговВзносовОтчислений.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.СН)
		|
		|СГРУППИРОВАТЬ ПО
		|	СведенияОбИсчисленииНалоговВзносовОтчислений.ФизическоеЛицо,
		|	СведенияОбИсчисленииНалоговВзносовОтчислений.ВидНалогаВзносаОтчисления,
		|	НАЧАЛОПЕРИОДА(СведенияОбИсчисленииНалоговВзносовОтчислений.Период, МЕСЯЦ),
		|	СведенияОбИсчисленииНалоговВзносовОтчислений.ВидДохода,
		|	СведенияОбИсчисленииНалоговВзносовОтчислений.Подразделение";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТРазмерыОграниченийПоДоходам");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеСНПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	РезультатЗапроса = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныйСНВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияСНВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектСНИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныйСН", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаСН);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
	
	Если ТочностьОкругления = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругления <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;
			
	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияСН,ИсчисленныйСН", ТочностьРаспределения);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеСНПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияСНВЦеломЗаПериод, 	ИсчисленныйСНВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектСНИсчисленныйРанее, 			РанееИсчисленныйСН,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияСН, 				ИсчисленныйСН");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для Каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0
			И (СтрокаТЗ.ИсчисленныйСН < 1 И СтрокаТЗ.ИсчисленныйСН > 0
				ИЛИ СтрокаТЗ.ИсчисленныйСН > -1 И СтрокаТЗ.ИсчисленныйСН < 0) Тогда
				
			СтрокаТЗ.ИсчисленныйСН = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныйСН = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныйСН, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
			
		КонецЕсли;
		
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьСНПосле2023(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт

	УничтожитьВТ = Новый Массив;
	
	ВидНалогаВзносаСН =  Перечисления.ВидыНалоговВзносовОтчислений.СН;
	
	// Получаем применение вычета в месяц отсутствия дохода
	УчетнаяПолитикаНУ = РегистрыСведений.УчетнаяПолитикаПоНалоговомуУчету.СрезПоследних(МесяцНачисления, Новый Структура("Организация", Организация));
	ДанныеОрганизации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Организация, "ЮридическоеФизическоеЛицо, ИндивидуальныйПредприниматель");
	ОрганизацияЯвляетсяИП = (ДанныеОрганизации.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо);
	ФизическоеЛицоИП = ДанныеОрганизации.ИндивидуальныйПредприниматель;
	
	РежимНалогообложения = Перечисления.СистемыНалогообложения.Общая;
	КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя = 0;
	КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника = 0;
	
	// в расчете учитываем все три возможные положения 
	// РежимНалогообложения = ПустаяСсылка
	// для ИП и юр лица считаем как раньше
	//
	// РежимНалогообложения = Общая
	// для ИП считаем СН с учетом Коэффициентов
	// для юр лица считаем как раньше
	//
	// РежимНалогообложения = Упрощенная
	// для ИП и юр лица не считаем СН
	Если УчетнаяПолитикаНУ.Количество() > 0 Тогда
		
		РежимНалогообложения = УчетнаяПолитикаНУ[0].СистемаНалогообложения;
		
		Если ОрганизацияЯвляетсяИП Тогда
			
			КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя = УчетнаяПолитикаНУ[0].КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя;
			КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника = УчетнаяПолитикаНУ[0].КоэффициентМРПДляРасчетаСНЗаНаемногоРаботника;
			
		КонецЕсли;
		
		// не плательщик СН, независимо что в регистре
		Если РежимНалогообложения = Перечисления.СистемыНалогообложения.Упрощенная Тогда
			КоэффициентМРПДляРасчетаСНЗаИндивидуальногоПредпринимателя = 0;
