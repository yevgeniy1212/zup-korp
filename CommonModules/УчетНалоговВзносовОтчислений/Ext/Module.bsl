		|	-НалогиВзносыОтчисленияПоСотрудникам.СО КАК СО,
		|	-НалогиВзносыОтчисленияПоСотрудникам.СН КАК СН,
		|	-НалогиВзносыОтчисленияПоСотрудникам.ОППВ КАК ОППВ,
		|	-НалогиВзносыОтчисленияПоСотрудникам.ООСМС КАК ООСМС,
		|	-НалогиВзносыОтчисленияПоСотрудникам.ОПВР КАК ОПВР
		|ИЗ
		|	ВТ_НалогиВзносыОтчисленияПоСотрудникам КАК НалогиВзносыОтчисленияПоСотрудникам
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.НачислениеЗарплаты КАК НачислениеЗарплаты
		|		ПО НалогиВзносыОтчисленияПоСотрудникам.Регистратор = НачислениеЗарплаты.Ссылка
		|			И НачислениеЗарплаты.МесяцНачисления = НАЧАЛОПЕРИОДА(&ПериодРегистрации, МЕСЯЦ)
		|ГДЕ
		|	НалогиВзносыОтчисленияПоСотрудникам.Период < НАЧАЛОПЕРИОДА(&ПериодРегистрации, МЕСЯЦ)
		|	И (НалогиВзносыОтчисленияПоСотрудникам.СО < 0
		|			ИЛИ НалогиВзносыОтчисленияПоСотрудникам.СН < 0
		|			ИЛИ НалогиВзносыОтчисленияПоСотрудникам.ОППВ < 0
		|			ИЛИ НалогиВзносыОтчисленияПоСотрудникам.ООСМС < 0
		|			ИЛИ НалогиВзносыОтчисленияПоСотрудникам.ОПВР < 0)
		|";
		
	Запрос.Текст = ТекстКорректировкаРаспределения;
	РанееИсчисленныеНалогиВзносыОтчисления = Запрос.Выполнить().Выгрузить();
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(РанееИсчисленныеНалогиВзносыОтчисления, НоваяТаблицаРаспределения);
	НоваяТаблицаРаспределения.Свернуть("Период, Организация, ФизическоеЛицо, Сотрудник, ВидДохода, Подразделение, Начисление, Сторно, ДатаНачала, ДанныеМежрасчетногоПериода", "СО, СН, ОППВ, ООСМС, ОПВР");
	
	КоличествоЗаписей = НоваяТаблицаРаспределения.Количество();
	
	Для Н = 1 По КоличествоЗаписей Цикл

		СтрокаТаблицы = НоваяТаблицаРаспределения[КоличествоЗаписей - Н];
		Если СтрокаТаблицы.СО = 0  
			И СтрокаТаблицы.СН = 0
			И СтрокаТаблицы.ОППВ = 0
			И СтрокаТаблицы.ООСМС = 0
			И СтрокаТаблицы.ОПВР = 0 Тогда
			НоваяТаблицаРаспределения.Удалить(КоличествоЗаписей - Н);
		КонецЕсли;
				
	КонецЦикла;
	
	Движения.НалогиВзносыОтчисленияПоСотрудникам.Загрузить(НоваяТаблицаРаспределения);

	Движения.НалогиВзносыОтчисленияПоСотрудникам.Записывать = Истина;
	Если ЗаписыватьДвижения Тогда
		Движения.НалогиВзносыОтчисленияПоСотрудникам.Записать();
		Движения.НалогиВзносыОтчисленияПоСотрудникам.Записывать = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Процедура СформироватьНалогиВзносыОтчисленияПоДоходуСубъектаПредпринимательства(Движения, Отказ, Организация, ПериодРегистрации, Начисление, НалогиВзносыОтчисленияИсчисленные, ЗаписыватьДвижения = Ложь) Экспорт

	Если НалогиВзносыОтчисленияИсчисленные.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
		
	Регистратор = Движения.НалогиВзносыОтчисленияПоСотрудникам.Отбор.Регистратор.Значение;
	
	МассивФизическихЛиц = ОбщегоНазначения.ВыгрузитьКолонку(НалогиВзносыОтчисленияИсчисленные, "ФизическоеЛицо", Истина);
	
	СтруктураОтбора = Новый Структура("ВидНалогаВзносаОтчисления");
	// СН
	СтруктураОтбора.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.СН;
	ТаблицаСН = НалогиВзносыОтчисленияИсчисленные.Скопировать(СтруктураОтбора);
	// СО
	СтруктураОтбора.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.СО;
	ТаблицаСО = НалогиВзносыОтчисленияИсчисленные.Скопировать(СтруктураОтбора);
	// ОПВР
	СтруктураОтбора.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ОПВР;
	ТаблицаОПВР = НалогиВзносыОтчисленияИсчисленные.Скопировать(СтруктураОтбора);
	
	НоваяТаблицаРаспределения = Движения.НалогиВзносыОтчисленияПоСотрудникам.ВыгрузитьКолонки();
	// СН
	ТаблицаСН.Колонки.Сумма.Имя = "СН";
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаСН, НоваяТаблицаРаспределения);
	// СО
	ТаблицаСО.Колонки.Сумма.Имя = "СО";
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаСО, НоваяТаблицаРаспределения);
	// ОПВР
	ТаблицаОПВР.Колонки.Сумма.Имя = "ОПВР";
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаОПВР, НоваяТаблицаРаспределения);

	НоваяТаблицаРаспределения.ЗаполнитьЗначения(ПериодРегистрации, "Период");
	НоваяТаблицаРаспределения.ЗаполнитьЗначения(Организация, "Организация");
	НоваяТаблицаРаспределения.ЗаполнитьЗначения(Начисление, "Начисление");
	НоваяТаблицаРаспределения.Свернуть("Период, Организация, ФизическоеЛицо, Сотрудник, ВидДохода, Подразделение, Начисление, ДанныеМежрасчетногоПериода", "СО, СН, ОППВ, ООСМС, ОПВР");
	
	КоличествоЗаписей = НоваяТаблицаРаспределения.Количество();
	
	Для Н = 1 По КоличествоЗаписей Цикл

		СтрокаТаблицы = НоваяТаблицаРаспределения[КоличествоЗаписей - Н];
		Если СтрокаТаблицы.СО = 0  
			И СтрокаТаблицы.ОПВР = 0
			И СтрокаТаблицы.СН = 0 Тогда
			НоваяТаблицаРаспределения.Удалить(КоличествоЗаписей - Н);
		КонецЕсли;
				
	КонецЦикла;
		
	Движения.НалогиВзносыОтчисленияПоСотрудникам.Загрузить(НоваяТаблицаРаспределения);

	Движения.НалогиВзносыОтчисленияПоСотрудникам.Записывать = Истина;
	Если ЗаписыватьДвижения Тогда
		Движения.НалогиВзносыОтчисленияПоСотрудникам.Записать();
		Движения.НалогиВзносыОтчисленияПоСотрудникам.Записывать = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗарегистрироватьНалогиВзносыОтчисленияАвансом(Движения, Отказ, Организация, ПериодРегистрации, РезультатыРасчетаНалоговВзносовОтчислений, МенеджерВременныхТаблиц, ХарактерВыплаты = Неопределено, ЗаписыватьДвижения = Ложь) Экспорт
	
	ДанныеМежрасчетногоПериода = ?(	ХарактерВыплаты = Перечисления.ХарактерВыплатыЗарплаты.Зарплата Или
									ХарактерВыплаты = Неопределено, Ложь, Истина);
									
	ДоходОтРаботодателя = Справочники.ВидыДоходов.ДоходыОтРаботодателя;

	ОписаниеСтатейРасходов = ЗарплатаКадры.СтатьиРасходовПоСпособамРасчетовСФизическимиЛицами();
	ОплатаТруда = ОписаниеСтатейРасходов[Перечисления.СпособыРасчетовСФизическимиЛицами.ОплатаТруда];

	СтруктураОтбора = Новый Структура("ВидНалогаВзносаОтчисления, ВидДохода");
	СтруктураОтбора.ВидДохода = ДоходОтРаботодателя;
	
	// ИПН
	СтруктураОтбора.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ИПН;
	ТаблицаИПН = РезультатыРасчетаНалоговВзносовОтчислений.Скопировать(СтруктураОтбора);
	// ОПВ
	СтруктураОтбора.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ОПВ;
	ТаблицаОПВ = РезультатыРасчетаНалоговВзносовОтчислений.Скопировать(СтруктураОтбора);
	// ВОСМС
	СтруктураОтбора.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС;
	ТаблицаВОСМС = РезультатыРасчетаНалоговВзносовОтчислений.Скопировать(СтруктураОтбора);
	// ЕП
	СтруктураОтбора.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ЕП;
	ТаблицаЕП = РезультатыРасчетаНалоговВзносовОтчислений.Скопировать(СтруктураОтбора);

	ТаблицаИПН.Колонки.Добавить("ТерриторияВыполненияРаботВОрганизации", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	ТаблицаИПН.Колонки.Добавить("Сотрудник", Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
	ТаблицаИПН.Колонки.Добавить("СтатьиФинансированияЗарплата", Новый ОписаниеТипов("СправочникСсылка.СтатьиФинансированияЗарплата"));
	ТаблицаИПН.Колонки.Добавить("СтатьиРасходовЗарплата", Новый ОписаниеТипов("СправочникСсылка.СтатьиРасходовЗарплата"));
	ТаблицаИПН.Колонки.Добавить("ГруппаНачисленияУдержанияВыплаты", Новый ОписаниеТипов("ПеречислениеСсылка.ГруппыНачисленияУдержанияВыплаты"));
	ТаблицаИПН.ЗаполнитьЗначения(Перечисления.ГруппыНачисленияУдержанияВыплаты.Удержано, "ГруппаНачисленияУдержанияВыплаты");

	ТаблицаОПВ.Колонки.Добавить("ТерриторияВыполненияРаботВОрганизации", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	ТаблицаОПВ.Колонки.Добавить("Сотрудник", Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
	ТаблицаОПВ.Колонки.Добавить("СтатьиФинансированияЗарплата", Новый ОписаниеТипов("СправочникСсылка.СтатьиФинансированияЗарплата"));
	ТаблицаОПВ.Колонки.Добавить("СтатьиРасходовЗарплата", Новый ОписаниеТипов("СправочникСсылка.СтатьиРасходовЗарплата"));
	ТаблицаОПВ.Колонки.Добавить("ГруппаНачисленияУдержанияВыплаты", Новый ОписаниеТипов("ПеречислениеСсылка.ГруппыНачисленияУдержанияВыплаты"));
	ТаблицаОПВ.ЗаполнитьЗначения(Перечисления.ГруппыНачисленияУдержанияВыплаты.Удержано, "ГруппаНачисленияУдержанияВыплаты");

	ТаблицаВОСМС.Колонки.Добавить("ТерриторияВыполненияРаботВОрганизации", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	ТаблицаВОСМС.Колонки.Добавить("Сотрудник", Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
	ТаблицаВОСМС.Колонки.Добавить("СтатьиФинансированияЗарплата", Новый ОписаниеТипов("СправочникСсылка.СтатьиФинансированияЗарплата"));
	ТаблицаВОСМС.Колонки.Добавить("СтатьиРасходовЗарплата", Новый ОписаниеТипов("СправочникСсылка.СтатьиРасходовЗарплата"));
	ТаблицаВОСМС.Колонки.Добавить("ГруппаНачисленияУдержанияВыплаты", Новый ОписаниеТипов("ПеречислениеСсылка.ГруппыНачисленияУдержанияВыплаты"));
	ТаблицаВОСМС.ЗаполнитьЗначения(Перечисления.ГруппыНачисленияУдержанияВыплаты.Удержано, "ГруппаНачисленияУдержанияВыплаты");

	ТаблицаЕП.Колонки.Добавить("ТерриторияВыполненияРаботВОрганизации", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	ТаблицаЕП.Колонки.Добавить("Сотрудник", Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
	ТаблицаЕП.Колонки.Добавить("СтатьиФинансированияЗарплата", Новый ОписаниеТипов("СправочникСсылка.СтатьиФинансированияЗарплата"));
	ТаблицаЕП.Колонки.Добавить("СтатьиРасходовЗарплата", Новый ОписаниеТипов("СправочникСсылка.СтатьиРасходовЗарплата"));
	ТаблицаЕП.Колонки.Добавить("ГруппаНачисленияУдержанияВыплаты", Новый ОписаниеТипов("ПеречислениеСсылка.ГруппыНачисленияУдержанияВыплаты"));
	ТаблицаЕП.ЗаполнитьЗначения(Перечисления.ГруппыНачисленияУдержанияВыплаты.Удержано, "ГруппаНачисленияУдержанияВыплаты");

	// Нужно выполнить распределение по сотрудникам.
	ФизическиеЛицаМассив = ОбщегоНазначения.ВыгрузитьКолонку(ТаблицаИПН, "ФизическоеЛицо", Истина);

	БазыРасчета = ПолучитьБазуДляРасчетаНалоговВзносов(Организация, ПериодРегистрации, ФизическиеЛицаМассив, ДоходОтРаботодателя);
	
	// ИПН
	УдержанияПоРабочимМестамИПН = УчетНачисленнойЗарплатыРасширенный.РаспределениеПрочихУдержанийПоРабочимМестам(ТаблицаИПН, ПериодРегистрации, Организация, БазыРасчета.БазаРасчетаИПН, , Перечисления.ВидыОсобыхНачисленийИУдержаний.ИПН, , , Истина);
    УдержанияПоРабочимМестамИПН.ЗаполнитьЗначения(ОплатаТруда, "СтатьяРасходов");
    УдержанияПоРабочимМестамИПН.ЗаполнитьЗначения(Перечисления.ВидыДоходовИсполнительногоПроизводства.ДоходыБезОграниченияВзысканий, "ВидДоходаИсполнительногоПроизводства");
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(УдержанияПоРабочимМестамИПН, Движения.НачисленияУдержанияПоСотрудникамАвансом);
	// ОПВ
	УдержанияПоРабочимМестамОПВ = УчетНачисленнойЗарплатыРасширенный.РаспределениеПрочихУдержанийПоРабочимМестам(ТаблицаОПВ, ПериодРегистрации, Организация, БазыРасчета.БазаРасчетаОПВ, , Перечисления.ВидыОсобыхНачисленийИУдержаний.ОПВ, 0, , Истина);
    УдержанияПоРабочимМестамОПВ.ЗаполнитьЗначения(ОплатаТруда, "СтатьяРасходов");
    УдержанияПоРабочимМестамОПВ.ЗаполнитьЗначения(Перечисления.ВидыДоходовИсполнительногоПроизводства.ДоходыБезОграниченияВзысканий, "ВидДоходаИсполнительногоПроизводства");
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(УдержанияПоРабочимМестамОПВ, Движения.НачисленияУдержанияПоСотрудникамАвансом);
	// ВОСМС
	УдержанияПоРабочимМестамВОСМС = УчетНачисленнойЗарплатыРасширенный.РаспределениеПрочихУдержанийПоРабочимМестам(ТаблицаВОСМС, ПериодРегистрации, Организация, БазыРасчета.БазаРасчетаВОСМС, , Перечисления.ВидыОсобыхНачисленийИУдержаний.ВОСМС, 0, , Истина);
    УдержанияПоРабочимМестамВОСМС.ЗаполнитьЗначения(ОплатаТруда, "СтатьяРасходов");
    УдержанияПоРабочимМестамВОСМС.ЗаполнитьЗначения(Перечисления.ВидыДоходовИсполнительногоПроизводства.ДоходыБезОграниченияВзысканий, "ВидДоходаИсполнительногоПроизводства");
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(УдержанияПоРабочимМестамВОСМС, Движения.НачисленияУдержанияПоСотрудникамАвансом);
	// ЕП
	УдержанияПоРабочимМестамЕП = УчетНачисленнойЗарплатыРасширенный.РаспределениеПрочихУдержанийПоРабочимМестам(ТаблицаЕП, ПериодРегистрации, Организация, , , Перечисления.ВидыОсобыхНачисленийИУдержаний.ЕП, 0, , Истина);
    УдержанияПоРабочимМестамЕП.ЗаполнитьЗначения(ОплатаТруда, "СтатьяРасходов");
    УдержанияПоРабочимМестамЕП.ЗаполнитьЗначения(Перечисления.ВидыДоходовИсполнительногоПроизводства.ДоходыБезОграниченияВзысканий, "ВидДоходаИсполнительногоПроизводства");
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(УдержанияПоРабочимМестамЕП, Движения.НачисленияУдержанияПоСотрудникамАвансом);

	Движения.НачисленияУдержанияПоСотрудникамАвансом.Записывать = Истина;
	
	Если ЗаписыватьДвижения Тогда
		Движения.НачисленияУдержанияПоСотрудникамАвансом.Записать();
		Движения.НачисленияУдержанияПоСотрудникамАвансом.Записывать = Ложь;
	КонецЕсли;
	
	// Взаиморасчеты
	УдержанияДляВзаиморасчетов = ВзаиморасчетыССотрудниками.НоваяТаблицаНачисленнойЗарплаты();
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(УдержанияПоРабочимМестамИПН, УдержанияДляВзаиморасчетов);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(УдержанияПоРабочимМестамОПВ, УдержанияДляВзаиморасчетов);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(УдержанияПоРабочимМестамВОСМС, УдержанияДляВзаиморасчетов);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(УдержанияПоРабочимМестамЕП, УдержанияДляВзаиморасчетов);
	ВзаиморасчетыССотрудникамиРасширенный.ЗарегистрироватьНачисленныйАванс(
		Движения, Отказ, 
		Организация, ПериодРегистрации,
		Неопределено, УдержанияДляВзаиморасчетов);
	
КонецПроцедуры

Процедура СформироватьПениПоВзносамИОтчислениям(Движения, Отказ, Организация, ПериодРегистрации, РезультатыРасчетаПени, Записывать = Ложь) Экспорт
	
	Для Каждого СтрокаПени Из РезультатыРасчетаПени Цикл
		НоваяСтрока =  Движения.ПениПоВзносамИОтчислениям.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаПени);
		НоваяСтрока.Организация = Организация;	
		НоваяСтрока.Период = ПериодРегистрации;
	КонецЦикла;
	
	
	Если Записывать Тогда
		// Записываем сразу и не выставляем признак Записывать этому набору записей движений документа.
		Движения.ПениПоВзносамИОтчислениям.Записать();
		Движения.ПениПоВзносамИОтчислениям.Записывать = Ложь;
	Иначе
		Движения.ПениПоВзносамИОтчислениям.Записывать = Истина;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьДанныеДляПроведенияСведенияОбИсчисленииВычетовИПН(ДанныеДляПроведения, ДокументСсылка, ИмяПоляМесяц = "Ссылка.МесяцНачисления") Экспорт
	
	ДатаКонтроля = '2018-01-01';
	ИмяРеквизита = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(ИмяПоляМесяц,".")[1];
	
	Если ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДокументСсылка,ИмяРеквизита) < ДатаКонтроля Тогда
		Возврат;
	КонецЕсли;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	НалогиВзносыОтчисления.ФизическоеЛицо,
	|	НалогиВзносыОтчисления.Подразделение,
	|	НалогиВзносыОтчисления.Ссылка.МесяцНачисления КАК ПериодРегистрации,
	|	НалогиВзносыОтчисления.МесяцНалоговогоПериода,
	|	НалогиВзносыОтчисления.ВидДохода,
	|	ВычетыИПН.ВидВычетаИПН,
	|	СУММА(ВычетыИПН.РазрешенныйВычет) КАК РазрешенныйВычет,
	|	СУММА(ВычетыИПН.ПримененныйВычет) КАК ПримененныйВычет
	|ПОМЕСТИТЬ ВТСведенияОбИсчисленииВычетовИПН
	|ИЗ
	|	#НалогиВзносыОтчисления КАК НалогиВзносыОтчисления
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ #ВычетыИПН КАК ВычетыИПН
	|		ПО НалогиВзносыОтчисления.ИдентификаторСтрокиНалогиВзносыОтчисления = ВычетыИПН.ИдентификаторСтрокиНалогиВзносыОтчисления
	|			И НалогиВзносыОтчисления.Ссылка = ВычетыИПН.Ссылка
	|ГДЕ
	|	НалогиВзносыОтчисления.Ссылка = &ДокументСсылка
	|
	|СГРУППИРОВАТЬ ПО
	|	НалогиВзносыОтчисления.ФизическоеЛицо,
	|	НалогиВзносыОтчисления.Подразделение,
	|	НалогиВзносыОтчисления.Ссылка.МесяцНачисления,
	|	НалогиВзносыОтчисления.МесяцНалоговогоПериода,
	|	НалогиВзносыОтчисления.ВидДохода,
	|	ВычетыИПН.ВидВычетаИПН";
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "Ссылка.МесяцНачисления",  ИмяПоляМесяц);
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "#НалогиВзносыОтчисления", ДокументСсылка.Метаданные().ПолноеИмя() + ".НалогиВзносыОтчисления");
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "#ВычетыИПН",              ДокументСсылка.Метаданные().ПолноеИмя() + ".ВычетыИПН");
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.МенеджерВременныхТаблиц = ДанныеДляПроведения.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	
	Запрос.Выполнить();
	
КонецПроцедуры

Процедура СформироватьСведенияОбИсчисленииВычетовИПН(ДанныеДляПроведения, Движения, Отказ, Организация, МесяцНачисления,ОкончательныйРасчет = Истина)Экспорт
	
	ДатаКонтроля = '2018-01-01';
	Если МесяцНачисления < ДатаКонтроля Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = ДанныеДляПроведения.МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("КонецМесяцаНачисления", КонецМесяца(МесяцНачисления));
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СведенияОбИсчисленииВычетовИПН.ФизическоеЛицо,
		|	СведенияОбИсчисленииВычетовИПН.Подразделение,
		|	СведенияОбИсчисленииВычетовИПН.ПериодРегистрации,
		|	СведенияОбИсчисленииВычетовИПН.МесяцНалоговогоПериода КАК Период,
		|	СведенияОбИсчисленииВычетовИПН.ВидДохода КАК ВидДохода,
		|	СведенияОбИсчисленииВычетовИПН.ВидВычетаИПН КАК ВидВычета,
		|	СведенияОбИсчисленииВычетовИПН.РазрешенныйВычет,
		|	СведенияОбИсчисленииВычетовИПН.ПримененныйВычет,
		|	ИсторияРегистрацийВНалоговомОрганеСрезПоследних.РегистрацияВНалоговомОргане
		|ИЗ
		|	ВТСведенияОбИсчисленииВычетовИПН КАК СведенияОбИсчисленииВычетовИПН
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ИсторияРегистрацийВНалоговомОргане.СрезПоследних(
		|				&КонецМесяцаНачисления,
		|				СтруктурнаяЕдиница В
		|					(ВЫБРАТЬ
		|						СведенияОбИсчисленииВычетовИПН.Подразделение
		|					ИЗ
		|						ВТСведенияОбИсчисленииВычетовИПН КАК СведенияОбИсчисленииВычетовИПН)) КАК ИсторияРегистрацийВНалоговомОрганеСрезПоследних
		|		ПО СведенияОбИсчисленииВычетовИПН.Подразделение = ИсторияРегистрацийВНалоговомОрганеСрезПоследних.СтруктурнаяЕдиница
		|ГДЕ
		|	(СведенияОбИсчисленииВычетовИПН.РазрешенныйВычет <> 0
		|			ИЛИ СведенияОбИсчисленииВычетовИПН.ПримененныйВычет <> 0)";
		
	Выборка = Запрос.Выполнить().Выбрать();

	РегистрацияОрганизации = ЗарплатаКадры.РегистрацияВНалоговомОргане(Организация, КонецМесяца(МесяцНачисления));
	
	Пока Выборка.Следующий() Цикл
		НоваяЗапись = Движения.СведенияОбИсчисленииВычетовИПН.Добавить(); 
		ЗаполнитьЗначенияСвойств(НоваяЗапись, Выборка);
		НоваяЗапись.Организация = Организация;
		НоваяЗапись.ДанныеМежрасчетногоПериода = НЕ ОкончательныйРасчет;
		ПроставитьРегистрациюВНалоговомОрганеВСтроке(НоваяЗапись, Выборка.РегистрацияВНалоговомОргане, РегистрацияОрганизации);
	КонецЦикла;
	
	Движения.СведенияОбИсчисленииВычетовИПН.Записывать = Истина;
	
КонецПроцедуры

Процедура СформироватьПрекращениеВычетов(Движения, ФизическиеЛица, Организация, МесяцРегистрации, Отказ, ИсключаемыеРегистраторы) Экспорт
	
	Если ТипЗнч(ФизическиеЛица) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
		СписокФизическихЛиц = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ФизическиеЛица);
	Иначе
		СписокФизическихЛиц = ФизическиеЛица;
	КонецЕсли;
	
	ТаблицаВычеты = Новый ТаблицаЗначений;
	ТаблицаВычеты.Колонки.Добавить("ФизическоеЛицо");
	ТаблицаВычеты.Колонки.Добавить("МесяцРегистрации");
	ТаблицаВычеты.Колонки.Добавить("ВидВычета");
	ТаблицаВычеты.Колонки.Добавить("ПредоставлятьВычет");
	
	ТаблицаПрочиеВычеты = Новый ТаблицаЗначений;
	ТаблицаПрочиеВычеты.Колонки.Добавить("ФизическоеЛицо");
	ТаблицаПрочиеВычеты.Колонки.Добавить("МесяцРегистрации");
	ТаблицаПрочиеВычеты.Колонки.Добавить("ВидВычета");
	ТаблицаПрочиеВычеты.Колонки.Добавить("Размер");
	ТаблицаПрочиеВычеты.Колонки.Добавить("ДействуетС");
		
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Месяц",					МесяцРегистрации);
	Запрос.УстановитьПараметр("ПустаяДата",				Дата(1,1,1));
	Запрос.УстановитьПараметр("ДатаКонтроля",			Дата(2018,1,1));
	Запрос.УстановитьПараметр("ФизическиеЛица",			СписокФизическихЛиц);
	Запрос.УстановитьПараметр("ГоловнаяОрганизация",	Организация);
	Запрос.УстановитьПараметр("ИсключаемыеРегистраторы",ИсключаемыеРегистраторы);
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ПрименениеВычетовИПНСрезПоследних.ФизическоеЛицо КАК ФизическоеЛицо,
	|	ПрименениеВычетовИПНСрезПоследних.Организация КАК Организация
	|ПОМЕСТИТЬ ВТ_МестоПримененияВычетов
	|ИЗ
	|	РегистрСведений.ПрименениеВычетовИПН.СрезПоследних(
	|			&Месяц,
	|			ФизическоеЛицо В (&ФизическиеЛица)
	|				И НЕ Регистратор В (&ИсключаемыеРегистраторы)) КАК ПрименениеВычетовИПНСрезПоследних
	|ГДЕ
	|	ПрименениеВычетовИПНСрезПоследних.Организация = &ГоловнаяОрганизация";
	
	Запрос.Выполнить();
	
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ВычетыФизическихЛицИПН.ФизическоеЛицо КАК ФизическоеЛицо,
	|	ВычетыФизическихЛицИПН.ВидВычета КАК ВидВычетаИПН
	|ИЗ
	|	РегистрСведений.ВычетыФизическихЛицИПН.СрезПоследних(
	|			&Месяц,
	|			ФизическоеЛицо В (&ФизическиеЛица)
	|				И НЕ Регистратор В (&ИсключаемыеРегистраторы)) КАК ВычетыФизическихЛицИПН
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_МестоПримененияВычетов КАК МестоПримененияВычетов
	|		ПО МестоПримененияВычетов.ФизическоеЛицо = ВычетыФизическихЛицИПН.ФизическоеЛицо
	|ГДЕ
	|	ВЫБОР
	|			КОГДА ВычетыФизическихЛицИПН.ДействуетПо = &ПустаяДата
	|				ТОГДА ВычетыФизическихЛицИПН.ПредоставлятьВычет
	|			ИНАЧЕ ВычетыФизическихЛицИПН.ДействуетПо >= &Месяц
	|		КОНЕЦ";
	
	СтандартныеВычетыВыборка = Запрос.Выполнить().Выбрать();
	
	Если МесяцРегистрации < '2018-01-01' Тогда
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ПрочиеВычетыФизическихЛицИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|	МАКСИМУМ(ПрочиеВычетыФизическихЛицИПН.Период) КАК Период
		|ПОМЕСТИТЬ ВТ_МаксимумПрочиеВычеты
		|ИЗ
		|	РегистрСведений.ПрочиеВычетыФизическихЛицИПН КАК ПрочиеВычетыФизическихЛицИПН
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_МестоПримененияВычетов КАК МестоПримененияВычетов
		|		ПО МестоПримененияВычетов.ФизическоеЛицо = ПрочиеВычетыФизическихЛицИПН.ФизическоеЛицо
		|ГДЕ
		|	ПрочиеВычетыФизическихЛицИПН.Период < &Месяц
		|
		|СГРУППИРОВАТЬ ПО
		|   ПрочиеВычетыФизическихЛицИПН.ФизическоеЛицо
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Период
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПрочиеВычетыФизическихЛицИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ПрочиеВычетыФизическихЛицИПН.ВидВычета КАК ВидВычетаИПН,
		|	ПрочиеВычетыФизическихЛицИПН.ДействуетС
		|ИЗ
		|	РегистрСведений.ПрочиеВычетыФизическихЛицИПН КАК ПрочиеВычетыФизическихЛицИПН
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_МаксимумПрочиеВычеты КАК МаксимумПрочиеВычеты
		|		ПО ПрочиеВычетыФизическихЛицИПН.Период = МаксимумПрочиеВычеты.Период
		|			И ПрочиеВычетыФизическихЛицИПН.ФизическоеЛицо = МаксимумПрочиеВычеты.ФизическоеЛицо
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПрочиеВычетыФизическихЛицИПН.ФизическоеЛицо,
		|	ПрочиеВычетыФизическихЛицИПН.ВидВычета,
		|	ПрочиеВычетыФизическихЛицИПН.ДействуетС";
		
	Иначе
		
		Запрос.Текст =
		"ВЫБРАТЬ
		|	ПрочиеВычетыФизическихЛицИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ПрочиеВычетыФизическихЛицИПН.ВидВычета КАК ВидВычетаИПН,
		|	ПрочиеВычетыФизическихЛицИПН.ДействуетС КАК ДействуетС
		|ИЗ
		|	РегистрСведений.ПрочиеВычетыФизическихЛицИПН.СрезПоследних(
		|			&Месяц,
		|			ФизическоеЛицо В (&ФизическиеЛица)
		|				И НЕ Регистратор В (&ИсключаемыеРегистраторы)) КАК ПрочиеВычетыФизическихЛицИПН
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_МестоПримененияВычетов КАК МестоПримененияВычетов
		|		ПО МестоПримененияВычетов.ФизическоеЛицо = ПрочиеВычетыФизическихЛицИПН.ФизическоеЛицо
		|ГДЕ
		|	ПрочиеВычетыФизическихЛицИПН.Период >= &ДатаКонтроля
		|	И ВЫБОР
		|			КОГДА ПрочиеВычетыФизическихЛицИПН.ДействуетПо = &ПустаяДата
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ПрочиеВычетыФизическихЛицИПН.ДействуетПо >= &Месяц
		|		КОНЕЦ
		|	И ПрочиеВычетыФизическихЛицИПН.Размер <> 0
		|
		|УПОРЯДОЧИТЬ ПО
		|	ПрочиеВычетыФизическихЛицИПН.ФизическоеЛицо,
		|	ПрочиеВычетыФизическихЛицИПН.ВидВычета,
		|	ДействуетС";
		
	КонецЕсли;
	
	ПрочиеВычетыВыборка = Запрос.Выполнить().Выбрать();
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ЛьготыФизическихЛицИПН.ФизическоеЛицо КАК ФизическоеЛицо,
		|	МАКСИМУМ(ЛьготыФизическихЛицИПН.Период) КАК Период
		|ПОМЕСТИТЬ ВТ_МаксимумЛьготыФизическихЛицИПН
		|ИЗ
		|	РегистрСведений.ЛьготыФизическихЛицИПН КАК ЛьготыФизическихЛицИПН
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_МестоПримененияВычетов КАК МестоПримененияВычетов
		|		ПО МестоПримененияВычетов.ФизическоеЛицо = ЛьготыФизическихЛицИПН.ФизическоеЛицо
		|ГДЕ
		|	ЛьготыФизическихЛицИПН.Период < &Месяц
		|	И ВЫБОР
		|			КОГДА ЛьготыФизическихЛицИПН.ДействуетДо = &ПустаяДата
		|				ТОГДА ЛьготыФизическихЛицИПН.ПредоставлятьЛьготу
		|			ИНАЧЕ ЛьготыФизическихЛицИПН.ДействуетДо >= &Месяц
		|		КОНЕЦ
		|
		|СГРУППИРОВАТЬ ПО
		|   ЛьготыФизическихЛицИПН.ФизическоеЛицо
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Период
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЛьготыФизическихЛицИПН.ФизическоеЛицо,
		|	ЛьготыФизическихЛицИПН.ПредоставлятьЛьготу
		|ИЗ
		|	РегистрСведений.ЛьготыФизическихЛицИПН КАК ЛьготыФизическихЛицИПН
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_МаксимумЛьготыФизическихЛицИПН КАК МаксимумЛьготыФизическихЛицИПН
		|		ПО ЛьготыФизическихЛицИПН.Период = МаксимумЛьготыФизическихЛицИПН.Период
		|			И ЛьготыФизическихЛицИПН.ФизическоеЛицо = МаксимумЛьготыФизическихЛицИПН.ФизическоеЛицо
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_МестоПримененияВычетов КАК МестоПримененияВычетов
		|		ПО МестоПримененияВычетов.ФизическоеЛицо = ЛьготыФизическихЛицИПН.ФизическоеЛицо
		|
		|УПОРЯДОЧИТЬ ПО
		|	ЛьготыФизическихЛицИПН.ФизическоеЛицо";
	
	ЛьготыВыборка = Запрос.Выполнить().Выбрать();
	
	Если ЛьготыВыборка.Следующий() Тогда
		ИзменитьЛьготу = Истина;
	Иначе
		ИзменитьЛьготу = Ложь;
	КонецЕсли;

	Для каждого ФизическоеЛицо Из СписокФизическихЛиц Цикл
		
		ДанныеОВычетах = Новый Структура(
			"МесяцРегистрации,ФизическоеЛицо,Организация,
			|ИзменитьСтандартныйВычет, 
			|ИзменитьЛьготу,
			|ИзменитьПрочиеВычеты,ПрочиеВычеты");
		
		// Общие сведения для прекращения вычетов
		ДанныеОВычетах.МесяцРегистрации = МесяцРегистрации;
		ДанныеОВычетах.ФизическоеЛицо = ФизическоеЛицо;
		ДанныеОВычетах.Организация = Организация;
		
		СтруктураПоиска = Новый Структура("ФизическоеЛицо", ФизическоеЛицо);
		
		СтандартныеВычетыВыборка.Сбросить();
		Если СтандартныеВычетыВыборка.НайтиСледующий(СтруктураПоиска) Тогда
			ДанныеОВычетах.ИзменитьСтандартныйВычет = Истина;
		Иначе
			ДанныеОВычетах.ИзменитьСтандартныйВычет = Ложь;
		КонецЕсли;
		
		Если МесяцРегистрации >= '2018-01-01' Тогда
			
			ДанныеОВычетах.Вставить("Вычеты", ТаблицаВычеты);
			
			СтандартныеВычетыВыборка.Сбросить();
			Пока СтандартныеВычетыВыборка.НайтиСледующий(СтруктураПоиска) Цикл
			
				ЗаписьОВычетах = ТаблицаВычеты.Добавить();
				
				ЗаписьОВычетах.ФизическоеЛицо		= ФизическоеЛицо;
				ЗаписьОВычетах.МесяцРегистрации		= МесяцРегистрации;
				ЗаписьОВычетах.ВидВычета			= СтандартныеВычетыВыборка.ВидВычетаИПН;
				ЗаписьОВычетах.ПредоставлятьВычет	= Ложь;
			
			КонецЦикла;
			
		КонецЕсли;
		
		ПрочиеВычетыВыборка.Сбросить();
		Если ПрочиеВычетыВыборка.НайтиСледующий(СтруктураПоиска) Тогда
			ДанныеОВычетах.ИзменитьПрочиеВычеты = Истина;
		Иначе
			ДанныеОВычетах.ИзменитьПрочиеВычеты = Ложь;
		КонецЕсли;
		
		ПрочиеВычетыВыборка.Сбросить();
		Пока ПрочиеВычетыВыборка.НайтиСледующий(СтруктураПоиска) Цикл
					
			ЗаписьОПрочихВычетах = ТаблицаПрочиеВычеты.Добавить();
			
			ЗаписьОПрочихВычетах.ФизическоеЛицо		= ФизическоеЛицо;
			ЗаписьОПрочихВычетах.МесяцРегистрации	= МесяцРегистрации;
			ЗаписьОПрочихВычетах.ВидВычета			= ПрочиеВычетыВыборка.ВидВычетаИПН;
			ЗаписьОПрочихВычетах.Размер				= 0;
			ЗаписьОПрочихВычетах.ДействуетС			= ПрочиеВычетыВыборка.ДействуетС;
			
		КонецЦикла;
		
		ЛьготыВыборка.Сбросить();
		Если ЛьготыВыборка.НайтиСледующий(СтруктураПоиска) Тогда
			ДанныеОВычетах.ИзменитьЛьготу = Истина;
		Иначе
			ДанныеОВычетах.ИзменитьЛьготу = Ложь;
		КонецЕсли;
		
		ДанныеОВычетах.Вставить("ПрочиеВычеты", ТаблицаПрочиеВычеты);
		
		// Формирование движений
		Если ДанныеОВычетах.ИзменитьСтандартныйВычет
			ИЛИ ДанныеОВычетах.ИзменитьПрочиеВычеты
			ИЛИ ДанныеОВычетах.ИзменитьЛьготу Тогда
			
			СформироватьПрименениеСтандартныхВычетов(Движения, Отказ, ДанныеОВычетах, , Ложь);
			
			Если СписокФизическихЛиц.Количество() > 1 Тогда
				
				ТаблицаВычеты.Очистить();
				ТаблицаПрочиеВычеты.Очистить();
								
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// РАСЧЕТ НАЛОГОВ, ВЗНОСОВ И ОТЧИСЛЕНИЙ
////////////////////////////////////////////////////////////////////////////////

Процедура ПодготовитьДанныеДляРасчетаНалоговВзносов(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, Знач ПервыйМесяцНалоговогоПериода = Неопределено, Знач ПоследнийМесяцНалоговогоПериода = Неопределено, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	
	ЗарплатаКадры.СоздатьПустуюВТ(МенеджерВременныхТаблиц, "РегистрНакопления.СведенияОДоходахФизическихЛиц");

	ЭтоРасчетПоДоходамТекущегоМесяца = ПервыйМесяцНалоговогоПериода = Неопределено Или ПоследнийМесяцНалоговогоПериода = Неопределено;
	
	Если ЭтоРасчетПоДоходамТекущегоМесяца Тогда

		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
		Запрос.УстановитьПараметр("Организация", Организация);
		Запрос.УстановитьПараметр("ПериодРегистрации",МесяцНачисления);
		Запрос.УстановитьПараметр("НачалоМесяцаРасчета",НачалоМесяца(МесяцНачисления));
		Запрос.УстановитьПараметр("КонецМесяцаРасчета",КонецМесяца(МесяцНачисления));
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	МАКСИМУМ(СведенияОДоходах.ПоследнийМесяцНалоговогоПериода) КАК ПоследнийМесяцНалоговогоПериода,
			|	МИНИМУМ(СведенияОДоходах.ПервыйМесяцНалоговогоПериода) КАК ПервыйМесяцНалоговогоПериода
			|ИЗ
			|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
			|		МАКСИМУМ(СведенияОДоходахФизическихЛицОбороты.Период) КАК ПоследнийМесяцНалоговогоПериода,
			|		МИНИМУМ(СведенияОДоходахФизическихЛицОбороты.Период) КАК ПервыйМесяцНалоговогоПериода
			|	ИЗ
			|		РегистрНакопления.СведенияОДоходахФизическихЛиц.Обороты(
			|				,
			|				,
			|				Месяц,
			|				Организация = &Организация
			|					И ПериодРегистрации = &ПериодРегистрации
			|					И ФизическоеЛицо В
			|						(ВЫБРАТЬ
			|							СписокСотрудников.ФизическоеЛицо
			|						ИЗ
			|							ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОДоходахФизическихЛицОбороты
			|	
			|	ОБЪЕДИНИТЬ
			|	
			|	ВЫБРАТЬ
			|		МАКСИМУМ(СведенияОДоходах.Период),
			|		МИНИМУМ(СведенияОДоходах.Период)
			|	ИЗ
			|		ВТРегистрНакопления_СведенияОДоходахФизическихЛиц КАК СведенияОДоходах
			|	ГДЕ
			|		СведенияОДоходах.ПериодРегистрации МЕЖДУ &НачалоМесяцаРасчета И &КонецМесяцаРасчета
			|		И СведенияОДоходах.Организация = &Организация
			|		И СведенияОДоходах.ФизическоеЛицо В
			|				(ВЫБРАТЬ
			|					СписокСотрудников.ФизическоеЛицо
			|				ИЗ
			|					ВТФизическиеЛица КАК СписокСотрудников)
			|		И СведенияОДоходах.Активность) КАК СведенияОДоходах";		
		Выборка = Запрос.Выполнить().Выбрать();

		Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.ПоследнийМесяцНалоговогоПериода) Тогда
			ПоследнийМесяцНалоговогоПериода = КонецМесяца(Выборка.ПоследнийМесяцНалоговогоПериода);
			ПервыйМесяцНалоговогоПериода = НачалоМесяца(Выборка.ПервыйМесяцНалоговогоПериода);
		Иначе
			ПоследнийМесяцНалоговогоПериода = КонецМесяца(МесяцНачисления);
			ПервыйМесяцНалоговогоПериода = НачалоМесяца(МесяцНачисления);
		КонецЕсли;
		
	КонецЕсли;

	// Таблица ВТДатыПоМесяцам: список налоговых периодов, в которых выполняется расчет.
	ЗарплатаКадрыОбщиеНаборыДанных.СоздатьВТПериоды(МенеджерВременныхТаблиц, НачалоГода(ПервыйМесяцНалоговогоПериода), НачалоМесяца(ПоследнийМесяцНалоговогоПериода),,,"ВТДатыПоМесяцам");
	
	// Таблица ВТПериодыПоГодам: список налоговых периодов (в виде даты начала года), в которых выполняется расчет.
	ЗарплатаКадрыОбщиеНаборыДанных.СоздатьВТПериоды(МенеджерВременныхТаблиц, НачалоГода(ПервыйМесяцНалоговогоПериода), НачалоГода(ПоследнийМесяцНалоговогоПериода), "ГОД", "НачалоНалоговогоПериода","ВТПериодыПоГодам");
	
	// Таблица ВТПериодыПоФизлицам
	СоздатьВТПериодыПоФизлицам(Организация, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет);
	
	//Таблица  ВТСтавкиНалоговВзносов:
	СоздатьВТСтавкиНалоговВзносовПоПериодам(Организация, МенеджерВременныхТаблиц);
	
	//Таблица  ВТСтавкиОСМС:
	СоздатьВТСтавкиОСМС(Организация, МенеджерВременныхТаблиц);

	// Таблица ВТСведенияОДоходах
	СоздатьВТСведенияОДоходах(Организация, Регистратор, МенеджерВременныхТаблиц, ПервыйМесяцНалоговогоПериода, ПоследнийМесяцНалоговогоПериода, ОкончательныйРасчет, ИсключатьДоходыРегистратора);
	
	// Таблица ВТРанееИсчисленныеНалогиВзносы
	СоздатьВТРанееИсчисленныеНалогиВзносы(Организация, Регистратор, МенеджерВременныхТаблиц, ПервыйМесяцНалоговогоПериода, ПоследнийМесяцНалоговогоПериода, ОкончательныйРасчет, ИсключатьДоходыРегистратора);
	
	// Таблица ВТРазмерыМЗППоПериодам
	СоздатьВТРазмерыМЗППоПериодам(МенеджерВременныхТаблиц);

	// Таблица ВТРазмерыМРППоПериодам
	СоздатьВТРазмерыМРППоПериодам(МенеджерВременныхТаблиц);

	// Таблица ВТНалогообложениеНачислений
	СоздатьВТНалогообложениеНачисленийПоПериодам(МенеджерВременныхТаблиц);
	
	// Таблица ВТСпособыОкругления
	СоздатьВТСпособыОкругления(Организация, МесяцНачисления, МенеджерВременныхТаблиц);
	
	// Таблица ВТУчетнаяПолитикаПоПериодам
	СоздатьВТУчетнаяПолитика(Организация, МенеджерВременныхТаблиц);
	
	Если МесяцНачисления >= Дата(2023, 1, 1) Тогда
		// Таблица ВТСтатусыФизическихЛицКакНалогоплательщиков
		СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц);
	КонецЕсли;
	
	// Получение кадровых данных физических лиц
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Если ВТСуществует(МенеджерВременныхТаблиц,"ВТВсеСотрудникиОрганизации") Тогда
		УничтожитьВТ = Новый Массив;
		УничтожитьВТ.Добавить("ВТСотрудникиОрганизации");
		ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	КонецЕсли;
	
	// ЗУПК в некоторых ситуациях таблица ВТОсновныеСотрудникиФизическихЛиц может быть создана раннее
	// в МенеджерРасчетаЗарплаты.ЗаполнитьОсновногоСотрудникаВТУдержаний с отличными периодами
	// удалим таблицу, если она существует и создадим новую с необходимым периодом 
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, "ВТОсновныеСотрудникиФизическихЛиц", Истина);
	Запрос.Текст = "ВЫБРАТЬ ФизическоеЛицо ИЗ ВТФизическиеЛица КАК ФизическиеЛица";
	Физлица = ОбщегоНазначения.ВыгрузитьКолонку(Запрос.Выполнить().Выгрузить(), "ФизическоеЛицо", Истина);
	КадровыйУчет.СоздатьВТОсновныеСотрудникиФизическихЛиц(МенеджерВременныхТаблиц, Истина, Физлица, Организация, НачалоМесяца(ПервыйМесяцНалоговогоПериода), КонецМесяца(ПоследнийМесяцНалоговогоПериода));
	ОписательТаблиц = КадровыйУчет.ОписаниеВременнойТаблицыОтборовСотрудников("ВТОсновныеСотрудникиФизическихЛиц");
	ЗапросКадровыеДанные = КадровыйУчет.ЗапросВТПостоянныеКадровыеДанныеСотрудников(Истина,	ОписательТаблиц, "ТекущееПодразделение,ДатаПриема,ДатаУвольнения",, "ВТКадровыеДанныеСотрудников");
	ЗапросКадровыеДанные.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	ЗапросКадровыеДанные.Выполнить();

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода,
		|	ПериодыПоФизлицам.НачалоГодаНалоговогоПериода,
		|	ПериодыПоФизлицам.ФизическоеЛицо,
		|	КадровыеДанныеСотрудников.Сотрудник,
		|	ЕСТЬNULL(КадровыеДанныеСотрудников.ДатаПриема, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаПриема,
		|	ЕСТЬNULL(КадровыеДанныеСотрудников.ДатаУвольнения, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаУвольнения
		|ПОМЕСТИТЬ ВТКадровыеДанныеСотрудниковПоПериодам
		|ИЗ
		|	ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТКадровыеДанныеСотрудников КАК КадровыеДанныеСотрудников
		|		ПО ПериодыПоФизлицам.ФизическоеЛицо = КадровыеДанныеСотрудников.ФизическоеЛицо
		|			И (НАЧАЛОПЕРИОДА(ПериодыПоФизлицам.МесяцНалоговогоПериода, МЕСЯЦ) >= НАЧАЛОПЕРИОДА(КадровыеДанныеСотрудников.ДатаПриема, МЕСЯЦ))
		|			И (ВЫБОР
		|				КОГДА КадровыеДанныеСотрудников.ДатаУвольнения <> ДАТАВРЕМЯ(1, 1, 1)
		|					ТОГДА НАЧАЛОПЕРИОДА(ПериодыПоФизлицам.МесяцНалоговогоПериода, МЕСЯЦ) <= НАЧАЛОПЕРИОДА(КадровыеДанныеСотрудников.ДатаУвольнения, МЕСЯЦ)
		|				ИНАЧЕ ИСТИНА
		|			КОНЕЦ)";
	
	Запрос.Выполнить();
	
	// Получаем применение вычета в месяц отсутствия дохода
	УчетнаяПолитикаНУ = РегистрыСведений.УчетнаяПолитикаПоНалоговомуУчету.СрезПоследних(МесяцНачисления, Новый Структура("Организация", Организация));
	ПредоставлятьВычетВМесяцеОтсутствияДохода = Ложь;
	Если УчетнаяПолитикаНУ.Количество() > 0 Тогда
		ПредоставлятьВычетВМесяцеОтсутствияДохода = УчетнаяПолитикаНУ[0].ПредоставлятьВычетВМесяцеОтсутствияДохода;
		//И ТипЗнч(Регистратор) = Тип("ДокументСсылка.НачислениеЗарплаты");
	КонецЕсли;
	
	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		ПараметрыПолученияСотрудниковОрганизаций = КадровыйУчет.ПараметрыПолученияСотрудниковОрганизацийПоСпискуФизическихЛиц();
		ПараметрыПолученияСотрудниковОрганизаций.Организация = Организация;
		ПараметрыПолученияСотрудниковОрганизаций.НачалоПериода = НачалоМесяца(МесяцНачисления);
		ПараметрыПолученияСотрудниковОрганизаций.ОкончаниеПериода = КонецМесяца(МесяцНачисления);
		ПараметрыПолученияСотрудниковОрганизаций.КадровыеДанные = "Подразделение";
		КадровыйУчет.СоздатьВТСотрудникиОрганизации(МенеджерВременныхТаблиц, Истина, ПараметрыПолученияСотрудниковОрганизаций, "ВТСотрудникиОрганизацииОбъединенная");
		
		Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СотрудникиОрганизации.ФизическоеЛицо КАК ФизическоеЛицо,
		|	КадровыеДанныеСотрудников.Сотрудник КАК Сотрудник,
		|	СотрудникиОрганизации.Подразделение КАК Подразделение,
		|	НАЧАЛОПЕРИОДА(&МесяцНалоговогоПериода, МЕСЯЦ) КАК МесяцНалоговогоПериода,
		|	НАЧАЛОПЕРИОДА(&МесяцНалоговогоПериода, ГОД) КАК НачалоГодаНалоговогоПериода,
		|	ЕСТЬNULL(КадровыеДанныеСотрудников.ДатаПриема, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаПриема,
		|	ЕСТЬNULL(КадровыеДанныеСотрудников.ДатаУвольнения, ДАТАВРЕМЯ(1, 1, 1)) КАК ДатаУвольнения,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя) КАК ВидДохода,
		|	0 КАК ОблагаемыйДоход,
		|	0 КАК НеоблагаемыйДоход
		|ПОМЕСТИТЬ ВТСотрудникиОрганизацииБезДохода
		|ИЗ
		|	ВТСотрудникиОрганизацииОбъединенная КАК СотрудникиОрганизации
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТКадровыеДанныеСотрудников КАК КадровыеДанныеСотрудников
		|		ПО СотрудникиОрганизации.ФизическоеЛицо = КадровыеДанныеСотрудников.ФизическоеЛицо
		|			И (НАЧАЛОПЕРИОДА(&МесяцНалоговогоПериода, МЕСЯЦ) >= НАЧАЛОПЕРИОДА(КадровыеДанныеСотрудников.ДатаПриема, МЕСЯЦ))
		|			И (ВЫБОР
		|				КОГДА КадровыеДанныеСотрудников.ДатаУвольнения <> ДАТАВРЕМЯ(1, 1, 1)
		|					ТОГДА НАЧАЛОПЕРИОДА(&МесяцНалоговогоПериода, МЕСЯЦ) <= НАЧАЛОПЕРИОДА(КадровыеДанныеСотрудников.ДатаУвольнения, МЕСЯЦ)
		|				ИНАЧЕ ИСТИНА
		|			КОНЕЦ)
		|ГДЕ
		|	СотрудникиОрганизации.ФизическоеЛицо В
		|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
		|				Т1.ФизическоеЛицо
		|			ИЗ
		|				ВТФизическиеЛица КАК Т1
		|					ЛЕВОЕ СОЕДИНЕНИЕ ВТПериодыПоФизлицам КАК Т2
		|					ПО
		|						Т1.ФизическоеЛицо = Т2.ФизическоеЛицо
		|			ГДЕ
		|				Т2.ФизическоеЛицо ЕСТЬ NULL)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ПериодыПоФизлицам.НачалоГодаНалоговогоПериода КАК НачалоГодаНалоговогоПериода,
		|	ПериодыПоФизлицам.ФизическоеЛицо КАК ФизическоеЛицо
		|ПОМЕСТИТЬ ВТПериодыПоФизлицамОбъединенная
		|ИЗ
		|	ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТСотрудникиОрганизацииБезДохода.МесяцНалоговогоПериода,
		|	ВТСотрудникиОрганизацииБезДохода.НачалоГодаНалоговогоПериода,
		|	ВТСотрудникиОрганизацииБезДохода.ФизическоеЛицо
		|ИЗ
		|	ВТСотрудникиОрганизацииБезДохода КАК ВТСотрудникиОрганизацииБезДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	КадровыеДанныеСотрудниковПоПериодам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	КадровыеДанныеСотрудниковПоПериодам.НачалоГодаНалоговогоПериода КАК НачалоГодаНалоговогоПериода,
		|	КадровыеДанныеСотрудниковПоПериодам.ФизическоеЛицо КАК ФизическоеЛицо,
		|	КадровыеДанныеСотрудниковПоПериодам.Сотрудник КАК Сотрудник,
		|	КадровыеДанныеСотрудниковПоПериодам.ДатаПриема КАК ДатаПриема,
		|	КадровыеДанныеСотрудниковПоПериодам.ДатаУвольнения КАК ДатаУвольнения
		|ПОМЕСТИТЬ ВТКадровыеДанныеСотрудниковПоПериодамОбъединенная
		|ИЗ
		|	ВТКадровыеДанныеСотрудниковПоПериодам КАК КадровыеДанныеСотрудниковПоПериодам
		|
		|ОБЪЕДИНИТЬ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТСотрудникиОрганизацииБезДохода.МесяцНалоговогоПериода,
		|	ВТСотрудникиОрганизацииБезДохода.НачалоГодаНалоговогоПериода,
		|	ВТСотрудникиОрганизацииБезДохода.ФизическоеЛицо,
		|	ВТСотрудникиОрганизацииБезДохода.Сотрудник,
		|	ВТСотрудникиОрганизацииБезДохода.ДатаПриема,
		|	ВТСотрудникиОрганизацииБезДохода.ДатаУвольнения
		|ИЗ
		|	ВТСотрудникиОрганизацииБезДохода КАК ВТСотрудникиОрганизацииБезДохода";
		
		Запрос.УстановитьПараметр("МесяцНалоговогоПериода", МесяцНачисления);
		Запрос.УстановитьПараметр("Организация", Организация);
		Запрос.Выполнить();
		
		// Таблица ВТРанееИсчисленныеНалогиВзносыОбъедененная
		СоздатьВТРанееИсчисленныеНалогиВзносы(Организация, Регистратор, МенеджерВременныхТаблиц, ПервыйМесяцНалоговогоПериода, ПоследнийМесяцНалоговогоПериода, ОкончательныйРасчет, ИсключатьДоходыРегистратора, Истина);
		
	КонецЕсли;
	
	// Таблица ВТНакопленныеДанныеПоВычетам
	СоздатьВТНакопленныеДанныеПоВычетам(Организация, Регистратор, МенеджерВременныхТаблиц, ПервыйМесяцНалоговогоПериода, ПоследнийМесяцНалоговогоПериода, ОкончательныйРасчет, ИсключатьДоходыРегистратора, ПредоставлятьВычетВМесяцеОтсутствияДохода); 
	
КонецПроцедуры

