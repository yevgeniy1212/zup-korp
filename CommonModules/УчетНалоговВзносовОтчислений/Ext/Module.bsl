// Уточняет значение поля РегистрацияВНалоговомОргане в строке регистра.
// Параметры:
//		СтрокаДанных - срока набора записей учетного регистра, содержит поле РегистрацияВНалоговомОргане.
//      РегистрацияПодразделенияВНалоговомОргане - регистрация в НО, указанная в подразделении (возможно пустая).
//      РегистрацияОрганизацииВНалоговомОргане - регистрация в НО, указанная в организации.
//
Процедура ПроставитьРегистрациюВНалоговомОрганеВСтроке(СтрокаДанных, РегистрацияПодразделенияВНалоговомОргане, РегистрацияОрганизацииВНалоговомОргане) Экспорт
	СтрокаДанных.РегистрацияВНалоговомОргане = ?(ЗначениеЗаполнено(РегистрацияПодразделенияВНалоговомОргане), РегистрацияПодразделенияВНалоговомОргане, РегистрацияОрганизацииВНалоговомОргане);
КонецПроцедуры	

// Формирует строку движения по регистру СведенияОДоходахФизическихЛиц.
//
// Параметры:
//		СведенияОДоходахФизическихЛиц - набор записей регистра накопления СведенияОДоходахФизическихЛиц.
//		Организация
//		ДанныеДокумента - некоторая структура (строка таблицы значений, выборки из результата запроса и т.п.) 
//				с полями, соответствующими полям регистра (в структуре могут отсутствовать необязательные поля):
//					ФизическоеЛицо, с непустым значением
//					ПериодРегистрации, с непустым значением
//					МесяцНалоговогоПериода, с непустым значением
//					РегистрацияВНалоговомОргане
//					СуммаДохода
//					Начисление, с непустым значением
//					Подразделение, с непустым значением
//					Сотрудник
//
Функция СтрокаСведенийОДоходах(СведенияОДоходахФизическихЛиц, Организация, МесяцНачисления, ДанныеДокумента, ОкончательныйРасчет = Истина)
	
	НоваяСтрока = СведенияОДоходахФизическихЛиц.Добавить();
	ЗаполнитьЗначенияСвойств(НоваяСтрока, ДанныеДокумента);
	НоваяСтрока.Организация = Организация;
	НоваяСтрока.Период = ДанныеДокумента.МесяцНалоговогоПериода;
	НоваяСтрока.ДанныеМежрасчетногоПериода = Не ОкончательныйРасчет;
	
	Возврат НоваяСтрока
	
КонецФункции

Функция ПолучитьБазуДляРасчетаНалоговВзносов(Организация, ПериодРегистрации, ФизическиеЛицаМассив, ВидДохода = Неопределено)
	
	Запрос = Новый Запрос;
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	СведенияОДоходах.ФизическоеЛицо КАК ФизическоеЛицо,
		|	СведенияОДоходах.Сотрудник КАК Сотрудник,
		|	СведенияОДоходах.Подразделение КАК Подразделение,
		|	СУММА(СведенияОДоходах.СуммаДохода) КАК Сумма,
		|	СведенияОДоходах.Период КАК МесяцНалоговогоПериода,
		|	СведенияОДоходах.Начисление КАК Начисление
		|ПОМЕСТИТЬ ВТСведенияОДоходах
		|ИЗ
		|	РегистрНакопления.СведенияОДоходахФизическихЛиц КАК СведенияОДоходах
		|ГДЕ
		|	СведенияОДоходах.Организация = &Организация
		|	И СведенияОДоходах.ПериодРегистрации = &ПериодРегистрации
		|	И СведенияОДоходах.ФизическоеЛицо В(&ФизическиеЛица)
		|	И СведенияОДоходах.Активность
		|
		|СГРУППИРОВАТЬ ПО
		|	СведенияОДоходах.ФизическоеЛицо,
		|	СведенияОДоходах.Сотрудник,
		|	СведенияОДоходах.Подразделение,
		|	СведенияОДоходах.Период,
		|	СведенияОДоходах.Начисление
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(НалогообложениеНачислений.Период) КАК Период,
		|	НалогообложениеНачислений.Начисление КАК Начисление,
		|	ВТСведенияОДоходах.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода
		|ПОМЕСТИТЬ ВТПериодыНалогообложения
		|ИЗ
		|	ВТСведенияОДоходах КАК ВТСведенияОДоходах
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НалогообложениеНачислений КАК НалогообложениеНачислений
		|		ПО ВТСведенияОДоходах.МесяцНалоговогоПериода >= НалогообложениеНачислений.Период
		|			И ВТСведенияОДоходах.Начисление = НалогообложениеНачислений.Начисление
		|
		|СГРУППИРОВАТЬ ПО
		|	НалогообложениеНачислений.Начисление,
		|	ВТСведенияОДоходах.МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТПериодыНалогообложения.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТПериодыНалогообложения.Начисление КАК Начисление,
		|	НалогообложениеНачислений.ВидДохода КАК ВидДохода,
		|	НалогообложениеНачислений.СпособОбложенияИПН КАК СпособОбложенияИПН,
		|	НалогообложениеНачислений.СпособОбложенияОПВ КАК СпособОбложенияОПВ,
		|	НалогообложениеНачислений.СпособОбложенияВОСМС КАК СпособОбложенияВОСМС
		|ПОМЕСТИТЬ ВТНалогообложениеНачислений
		|ИЗ
		|	ВТПериодыНалогообложения КАК ВТПериодыНалогообложения
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НалогообложениеНачислений КАК НалогообложениеНачислений
		|		ПО ВТПериодыНалогообложения.Период = НалогообложениеНачислений.Период
		|			И ВТПериодыНалогообложения.Начисление = НалогообложениеНачислений.Начисление
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТСведенияОДоходах.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТСведенияОДоходах.Сотрудник КАК Сотрудник,
		|	ВТСведенияОДоходах.Подразделение КАК Подразделение,
		|	ВТНалогообложениеНачислений.ВидДохода КАК ВидДохода,
		|	СУММА(ВЫБОР
		|			КОГДА ЕСТЬNULL(ВТНалогообложениеНачислений.СпособОбложенияИПН, ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.ОблагаетсяЦеликом)) <> ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.НеОблагаетсяЦеликом)
		|				ТОГДА ВТСведенияОДоходах.Сумма
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК Сумма
		|ИЗ
		|	ВТСведенияОДоходах КАК ВТСведенияОДоходах
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНалогообложениеНачислений КАК ВТНалогообложениеНачислений
		|		ПО ВТСведенияОДоходах.МесяцНалоговогоПериода = ВТНалогообложениеНачислений.МесяцНалоговогоПериода
		|			И ВТСведенияОДоходах.Начисление = ВТНалогообложениеНачислений.Начисление
		|ГДЕ
		|	ВТНалогообложениеНачислений.ВидДохода ЕСТЬ NULL
		|	ИЛИ ВТНалогообложениеНачислений.ВидДохода = &ВидДохода
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТСведенияОДоходах.ФизическоеЛицо,
		|	ВТСведенияОДоходах.Сотрудник,
		|	ВТСведенияОДоходах.Подразделение,
		|	ВТНалогообложениеНачислений.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТСведенияОДоходах.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТСведенияОДоходах.Сотрудник КАК Сотрудник,
		|	ВТСведенияОДоходах.Подразделение КАК Подразделение,
		|	СУММА(ВЫБОР
		|			КОГДА ЕСТЬNULL(ВТНалогообложениеНачислений.СпособОбложенияОПВ, ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.ОблагаетсяЦеликом)) <> ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.НеОблагаетсяЦеликом)
		|				ТОГДА ВТСведенияОДоходах.Сумма
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК Сумма,
		|	ВТНалогообложениеНачислений.ВидДохода КАК ВидДохода
		|ИЗ
		|	ВТСведенияОДоходах КАК ВТСведенияОДоходах
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНалогообложениеНачислений КАК ВТНалогообложениеНачислений
		|		ПО ВТСведенияОДоходах.МесяцНалоговогоПериода = ВТНалогообложениеНачислений.МесяцНалоговогоПериода
		|			И ВТСведенияОДоходах.Начисление = ВТНалогообложениеНачислений.Начисление
		|ГДЕ
		|	ВТНалогообложениеНачислений.ВидДохода ЕСТЬ NULL
		|	ИЛИ ВТНалогообложениеНачислений.ВидДохода = &ВидДохода
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТСведенияОДоходах.ФизическоеЛицо,
		|	ВТСведенияОДоходах.Сотрудник,
		|	ВТСведенияОДоходах.Подразделение,
		|	ВТНалогообложениеНачислений.ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТСведенияОДоходах.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТСведенияОДоходах.Сотрудник КАК Сотрудник,
		|	ВТСведенияОДоходах.Подразделение КАК Подразделение,
		|	ВТНалогообложениеНачислений.ВидДохода КАК ВидДохода,
		|	СУММА(ВЫБОР
		|			КОГДА ЕСТЬNULL(ВТНалогообложениеНачислений.СпособОбложенияВОСМС, ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.ОблагаетсяЦеликом)) <> ЗНАЧЕНИЕ(Перечисление.СпособыНалогообложенияДоходов.НеОблагаетсяЦеликом)
		|				ТОГДА ВТСведенияОДоходах.Сумма
		|			ИНАЧЕ 0
		|		КОНЕЦ) КАК Сумма
		|ИЗ
		|	ВТСведенияОДоходах КАК ВТСведенияОДоходах
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНалогообложениеНачислений КАК ВТНалогообложениеНачислений
		|		ПО ВТСведенияОДоходах.МесяцНалоговогоПериода = ВТНалогообложениеНачислений.МесяцНалоговогоПериода
		|			И ВТСведенияОДоходах.Начисление = ВТНалогообложениеНачислений.Начисление
		|ГДЕ
		|	ВТНалогообложениеНачислений.ВидДохода ЕСТЬ NULL
		|	ИЛИ ВТНалогообложениеНачислений.ВидДохода = &ВидДохода
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТСведенияОДоходах.ФизическоеЛицо,
		|	ВТСведенияОДоходах.Сотрудник,
		|	ВТСведенияОДоходах.Подразделение,
		|	ВТНалогообложениеНачислений.ВидДохода";
		
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ПериодРегистрации", ПериодРегистрации);
	Запрос.УстановитьПараметр("ФизическиеЛица", ФизическиеЛицаМассив);
	
	Если ВидДохода = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ИЛИ ВТНалогообложениеНачислений.ВидДохода = &ВидДохода", "ИЛИ ИСТИНА");
	Иначе
		Запрос.УстановитьПараметр("ВидДохода", ВидДохода);
	КонецЕсли;
	
	Результат = Запрос.ВыполнитьПакет();
	ВсегоРезультатов = Результат.Количество();

	БазаРасчетаИПН = Результат[ВсегоРезультатов-3].Выгрузить();
	БазаРасчетаОПВ = Результат[ВсегоРезультатов-2].Выгрузить();
	БазаРасчетаВОСМС = Результат[ВсегоРезультатов-1].Выгрузить();
	
	Возврат Новый Структура("БазаРасчетаИПН, БазаРасчетаОПВ, БазаРасчетаВОСМС", БазаРасчетаИПН, БазаРасчетаОПВ, БазаРасчетаВОСМС);
	
КонецФункции

Функция НалогиВзносыОтчисленияПоСотрудникам(ИсходныеДанные, БазаРаспределения, Точность = 2)
	
	НалогиВзносыОтчисленияПоСотрудникам = Новый ТаблицаЗначений;
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("Период");
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("Организация");
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("ФизическоеЛицо");
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("Сотрудник");
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("ВидДохода");
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("Подразделение");
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("Начисление");
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("Сумма");
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("Сторно");
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("ДатаНачала");
	
	ИсходныеДанные.Сортировать("МесяцНалоговогоПериода, ФизическоеЛицо, Подразделение");
	
	СтруктураПоиска = Новый Структура("МесяцНалоговогоПериода, ФизическоеЛицо, Подразделение"); 
	Для Каждого СтрокаДанных Из ИсходныеДанные Цикл
		
		Если СтрокаДанных.Сумма = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		СтруктураПоиска.ФизическоеЛицо = СтрокаДанных.ФизическоеЛицо;
		СтруктураПоиска.Подразделение = СтрокаДанных.Подразделение;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаДанных.МесяцНалоговогоПериода;
		НайденныеСтроки = БазаРаспределения.НайтиСтроки(СтруктураПоиска);
		КоэффициентыРаспределения = ОбщегоНазначения.ВыгрузитьКолонку(НайденныеСтроки, "База");
			
			
		РезультатРаспределения = ОбщегоНазначения.РаспределитьСуммуПропорциональноКоэффициентам(СтрокаДанных.Сумма, КоэффициентыРаспределения, Точность);
		Если РезультатРаспределения = Неопределено Тогда
			НоваяСтрока = НалогиВзносыОтчисленияПоСотрудникам.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДанных);
			НоваяСтрока.Период = СтрокаДанных.МесяцНалоговогоПериода;
		Иначе
			Индекс = 0;
			Для Каждого СтрокаБазы Из НайденныеСтроки Цикл
				НоваяСтрока = НалогиВзносыОтчисленияПоСотрудникам.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаБазы);
				НоваяСтрока.Период = СтрокаБазы.МесяцНалоговогоПериода;
				НоваяСтрока.Сумма = РезультатРаспределения[Индекс];
				Индекс = Индекс + 1;
			КонецЦикла;
		КонецЕсли;

	КонецЦикла;
	
	Возврат НалогиВзносыОтчисленияПоСотрудникам;
	
КонецФункции

Функция НалогиВзносыОтчисленияПоСотрудникамИВидуДохода(ИсходныеДанные, БазаРаспределения, Точность = 2)
	
	НалогиВзносыОтчисленияПоСотрудникам = Новый ТаблицаЗначений;
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("Период");
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("Организация");
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("ФизическоеЛицо");
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("Сотрудник");
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("ВидДохода");
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("Подразделение");
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("Начисление");
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("Сумма");
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("Сторно");
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("ДатаНачала");
	НалогиВзносыОтчисленияПоСотрудникам.Колонки.Добавить("ДанныеМежрасчетногоПериода");
	
	//ИсходныеДанные.Сортировать("МесяцНалоговогоПериода, ФизическоеЛицо, Подразделение");
	ПоляПоиска = "МесяцНалоговогоПериода, ВидДохода, ФизическоеЛицо, Подразделение";
	
	ИсходныеДанные.Индексы.Добавить(ПоляПоиска);
	
	СтруктураПоискаВидаДохода = Новый Структура(ПоляПоиска);

	Для Каждого СтрокаДанных Из ИсходныеДанные Цикл
		
		Если СтрокаДанных.Сумма = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(СтруктураПоискаВидаДохода, СтрокаДанных);
		НайденныеСтроки = БазаРаспределения.НайтиСтроки(СтруктураПоискаВидаДохода);
		КоэффициентыРаспределения = ОбщегоНазначения.ВыгрузитьКолонку(НайденныеСтроки, "База");
			
		РезультатРаспределения = ОбщегоНазначения.РаспределитьСуммуПропорциональноКоэффициентам(СтрокаДанных.Сумма, КоэффициентыРаспределения, Точность);
		Если РезультатРаспределения = Неопределено Тогда
			НоваяСтрока = НалогиВзносыОтчисленияПоСотрудникам.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаДанных);
			НоваяСтрока.Период = СтрокаДанных.МесяцНалоговогоПериода;
		Иначе
			Индекс = 0;
			Для Каждого СтрокаБазы Из НайденныеСтроки Цикл
				НоваяСтрока = НалогиВзносыОтчисленияПоСотрудникам.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаБазы);
				НоваяСтрока.Период = СтрокаБазы.МесяцНалоговогоПериода;
				НоваяСтрока.Сумма = РезультатРаспределения[Индекс];
				Индекс = Индекс + 1;
			КонецЦикла;
		КонецЕсли;

	КонецЦикла;
	
	Возврат НалогиВзносыОтчисленияПоСотрудникам;
	
КонецФункции

Функция ДанныеОРезультатахРасчетаОПВДляДокумента(ОПВ) Экспорт

	ВидНалогаВзноса = Перечисления.ВидыНалоговВзносовОтчислений.ОПВ;
	
	// Приводим таблицу к структуре, соответствующей документам расчета.
	ОПВ.Колонки.Добавить("НалогВзнос", Новый ОписаниеТипов("Число"));
	ОПВ.Колонки.Добавить("ОбъектИсчисления", Новый ОписаниеТипов("Число"));
	ОПВ.Колонки.Добавить("ВидНалогаВзносаОтчисления", Новый ОписаниеТипов("ПеречислениеСсылка.ВидыНалоговВзносовОтчислений"));
	
	Для Каждого СтрокаОПВ Из ОПВ Цикл
		СтрокаОПВ.НалогВзнос = СтрокаОПВ.ИсчисленныеОПВ;
		СтрокаОПВ.ОбъектИсчисления = СтрокаОПВ.ОбъектИсчисленияОПВ;
		СтрокаОПВ.ВидНалогаВзносаОтчисления = ВидНалогаВзноса;
	КонецЦикла;
	
	Возврат Новый Структура("ОПВ", ОПВ);

КонецФункции

Функция ДанныеОРезультатахРасчетаИПНДляДокумента(МесяцНачисления, ИПН) Экспорт

	Если МесяцНачисления >= Дата(2026,1,1) Тогда
		ДанныеОРезультатах = ДанныеОРезультатахРасчетаИПНДляДокументаПосле2026(ИПН);
	ИначеЕсли МесяцНачисления >= Дата(2018,1,1) Тогда
		ДанныеОРезультатах = ДанныеОРезультатахРасчетаИПНДляДокументаПосле2018(ИПН);
	Иначе 
		ДанныеОРезультатах = ДанныеОРезультатахРасчетаИПНДляДокументаДо2018(ИПН);
	КонецЕсли;

	Возврат ДанныеОРезультатах;

КонецФункции

Функция ДанныеОРезультатахРасчетаИПНДляДокументаДо2018(ИПН) 

	ВидНалогаВзноса = Перечисления.ВидыНалоговВзносовОтчислений.ИПН;
	
	// Приводим таблицу к структуре, соответствующей документам расчета.
	ИПН.Колонки.Добавить("ИдентификаторСтрокиНалогиВзносыОтчисления", Новый ОписаниеТипов("Число"));
	ИПН.Колонки.Добавить("НалогВзнос", Новый ОписаниеТипов("Число"));
	ИПН.Колонки.Добавить("ОбъектИсчисления", Новый ОписаниеТипов("Число"));
