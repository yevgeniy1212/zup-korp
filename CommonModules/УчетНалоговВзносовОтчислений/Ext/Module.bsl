    |	МАКСИМУМ(СпособыОкругленияОрганизации.ПравилоОкругления) КАК ПравилоОкругления,
    |	МАКСИМУМ(СпособыОкругленияОрганизации.Точность) КАК ТочностьОкругления,
    |	СпособыОкругленияОрганизации.Период КАК Период,
    |	СпособыОкругленияОрганизации.ВидРасчета КАК ВидРасчета
    |ПОМЕСТИТЬ ВТ_СпособыОкругления
    |ИЗ
    |	ВТ_СпособыОкругленияОрганизации КАК СпособыОкругленияОрганизации
    |
    |СГРУППИРОВАТЬ ПО
    |	СпособыОкругленияОрганизации.Период,
    |	СпособыОкругленияОрганизации.ВидРасчета
    |;
    |
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СуммыНалоговВзносовПоСотрудникам.ФизическоеЛицо КАК ФизическоеЛицо,
	|	СуммыНалоговВзносовПоСотрудникам.ВидНалогаВзносаОтчисления КАК ВидНалогаВзносаОтчисления,
	|	СуммыНалоговВзносовПоСотрудникам.ВидДохода КАК ВидДохода,
	|	ВсегоПоФизическомуЛицу.НалоговыйПериод КАК НалоговыйПериод,
	|	ВсегоПоФизическомуЛицу.СуммаОстаток КАК ОстатокЗаНалоговыйПериод,
	|	НАЧАЛОПЕРИОДА(СуммыНалоговВзносовПоСотрудникам.МесяцНалоговогоПериода, МЕСЯЦ) КАК НачалоМесяцаНалоговогоПериода,
	|	СуммыНалоговВзносовПоСотрудникам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
	|	СуммыНалоговВзносовПоСотрудникам.РегистрацияВНалоговомОргане КАК РегистрацияВНалоговомОргане,
	|	СуммыНалоговВзносовПоСотрудникам.СуммаОстаток КАК СуммаОстаток,
	|	СуммыНалоговВзносовПоСотрудникам.НачисленоНалога КАК НачисленоНалога,
	|	СуммыНалоговВзносовПоСотрудникам.Организация КАК Организация,
	|	СуммыНалоговВзносовПоСотрудникам.СуммаВыплаты КАК СуммаВыплаты,
    |	ПоФизическомуЛицуЗаМесяц.СуммаОстаток КАК СуммаЗаМесяц,
    |	ПоФизическомуЛицуЗаМесяц.УдержаноНалога КАК УдержаноНалога,
	|	ЕСТЬNULL(СпособыОкругления.ПравилоОкругления, ЗНАЧЕНИЕ(Перечисление.ПравилаОкругленияПриРасчетеЗарплаты.Авто)) КАК ПравилоОкругления,
	|	ЕСТЬNULL(СпособыОкругления.ТочностьОкругления, 0.01) КАК ТочностьОкругления
	|ИЗ
	|	ВТПодробно КАК СуммыНалоговВзносовПоСотрудникам
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТВсегоПоФизическомуЛицу КАК ВсегоПоФизическомуЛицу
	|		ПО СуммыНалоговВзносовПоСотрудникам.ФизическоеЛицо = ВсегоПоФизическомуЛицу.ФизическоеЛицо
	|			И СуммыНалоговВзносовПоСотрудникам.ВидНалогаВзносаОтчисления = ВсегоПоФизическомуЛицу.ВидНалогаВзносаОтчисления
	|			И СуммыНалоговВзносовПоСотрудникам.ВидДохода = ВсегоПоФизическомуЛицу.ВидДохода
	|			И (ГОД(СуммыНалоговВзносовПоСотрудникам.МесяцНалоговогоПериода) = ВсегоПоФизическомуЛицу.НалоговыйПериод)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТПоФизическомуЛицуЗаМесяц КАК ПоФизическомуЛицуЗаМесяц
	|		ПО СуммыНалоговВзносовПоСотрудникам.ФизическоеЛицо = ПоФизическомуЛицуЗаМесяц.ФизическоеЛицо
	|			И СуммыНалоговВзносовПоСотрудникам.ВидНалогаВзносаОтчисления = ПоФизическомуЛицуЗаМесяц.ВидНалогаВзносаОтчисления
	|			И СуммыНалоговВзносовПоСотрудникам.ВидДохода = ПоФизическомуЛицуЗаМесяц.ВидДохода
	|			И (НАЧАЛОПЕРИОДА(СуммыНалоговВзносовПоСотрудникам.МесяцНалоговогоПериода, МЕСЯЦ) = ПоФизическомуЛицуЗаМесяц.МесяцНалоговогоПериода)
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТПоФизическомуЛицуНаДатуПолученияДохода КАК ПоФизическомуЛицуНаДатуПолученияДохода
	|		ПО СуммыНалоговВзносовПоСотрудникам.ФизическоеЛицо = ПоФизическомуЛицуНаДатуПолученияДохода.ФизическоеЛицо
	|			И СуммыНалоговВзносовПоСотрудникам.ВидНалогаВзносаОтчисления = ПоФизическомуЛицуНаДатуПолученияДохода.ВидНалогаВзносаОтчисления
	|			И СуммыНалоговВзносовПоСотрудникам.ВидДохода = ПоФизическомуЛицуНаДатуПолученияДохода.ВидДохода
	|			И СуммыНалоговВзносовПоСотрудникам.МесяцНалоговогоПериода = ПоФизическомуЛицуНаДатуПолученияДохода.ДатаПолученияДохода
    |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СпособыОкругления КАК СпособыОкругления
    |		ПО СуммыНалоговВзносовПоСотрудникам.ВидНалогаВзносаОтчисления = СпособыОкругления.ВидРасчета
    |ГДЕ
	|	ВсегоПоФизическомуЛицу.СуммаОстаток > 0
	|	И ПоФизическомуЛицуНаДатуПолученияДохода.СуммаОстаток <> 0
	|
	|УПОРЯДОЧИТЬ ПО
	|	ФизическоеЛицо,
	|	ВидНалогаВзносаОтчисления,
	|	ВидДохода,
	|	НалоговыйПериод,
	|	НачалоМесяцаНалоговогоПериода,
	|	МесяцНалоговогоПериода,
	|	СуммыНалоговВзносовПоСотрудникам.ДатаНачисления,
	|	РегистрацияВНалоговомОргане";
	
	МассивРез = Запрос.ВыполнитьПакет();
	Выборка = МассивРез[3].Выбрать();
	
	ТаблицыКУдалению.Добавить("ВТВсегоПоФизическомуЛицу");
	
	Пока Выборка.СледующийПоЗначениюПоля("ФизическоеЛицо") Цикл 
		
		Пока Выборка.СледующийПоЗначениюПоля("ВидНалогаВзносаОтчисления") Цикл 
			
			Пока Выборка.СледующийПоЗначениюПоля("ВидДохода") Цикл 
				Пока Выборка.СледующийПоЗначениюПоля("НалоговыйПериод") Цикл 
                    ПравилоОкругления = ?(Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС, 
                        ПредопределенноеЗначение("Перечисление.ПравилаОкругленияПриРасчетеЗарплаты.ВБольшуюСторону"), Выборка.ПравилоОкругления);  
					Если Выборка.ОстатокЗаНалоговыйПериод >= 0 Тогда
						ОстатокКУдержанию = 0;
						Пока Выборка.СледующийПоЗначениюПоля("НачалоМесяцаНалоговогоПериода") Цикл 
							СуммаКРаспределению = Выборка.ОстатокЗаНалоговыйПериод;
							ОстатокКУдержанию = ОстатокКУдержанию + Выборка.СуммаЗаМесяц;
							Если ОстатокКУдержанию > 0 И Выборка.СуммаЗаМесяц > 0 Тогда
								Пока Выборка.Следующий() И СуммаКРаспределению > 0 И ОстатокКУдержанию > 0 Цикл
									Если Выборка.СуммаОстаток > 0 Тогда

                                        СписываемаяСумма = Мин(Выборка.СуммаОстаток, ОстатокКУдержанию);
										СуммаКРаспределению = СуммаКРаспределению - СписываемаяСумма;
										ОстатокКУдержанию = ОстатокКУдержанию - СписываемаяСумма;
										
										СтрокаТаблицыРезультатов = РезультатыРасчетов.Добавить();
										ЗаполнитьЗначенияСвойств(СтрокаТаблицыРезультатов, Выборка);
                                        
                                        Если ПериодРегистрации >= Дата(2020,1,1) И Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС Тогда
                                            НалогВзнос = ЗарплатаКадрыКлиентСервер.Округлить(СписываемаяСумма, 1, ПравилоОкругления);
                                        Иначе
                                            НалогВзнос = ЗарплатаКадрыКлиентСервер.Округлить(СписываемаяСумма, Выборка.ТочностьОкругления, ПравилоОкругления);
                                        КонецЕсли;
                                        
                                        //проверяем остатки на текущий период, если есть остатки с дробью, не округляем значение, чтобы не увеличить сумму выплаченных налогов
                                        Если Выборка.НачисленоНалога - Выборка.УдержаноНалога <= НалогВзнос Тогда
                                            //проверяем правило округления, если в большую сторону и разница между округлением меньше 1, то округляем налог всегда 
                                            Если ПравилоОкругления = ПредопределенноеЗначение("Перечисление.ПравилаОкругленияПриРасчетеЗарплаты.ВБольшуюСторону")
                                                И НалогВзнос - СписываемаяСумма < 1 Тогда
                                                СтрокаТаблицыРезультатов.НалогВзнос = НалогВзнос;
                                            Иначе
                                                СтрокаТаблицыРезультатов.НалогВзнос = СписываемаяСумма;
                                            КонецЕсли;
                                        Иначе
                                            СтрокаТаблицыРезультатов.НалогВзнос = НалогВзнос;
                                        КонецЕсли; 
										
									КонецЕсли;
								КонецЦикла;
							КонецЕсли;
						КонецЦикла;
					Иначе
						СуммаКРаспределению = СуммаКРаспределению - Выборка.ОстатокЗаНалоговыйПериод;
						СтрокаТаблицыРезультатов = РезультатыРасчетов.Добавить();
						ЗаполнитьЗначенияСвойств(СтрокаТаблицыРезультатов, Выборка);
                        Если ПериодРегистрации >= Дата(2020,1,1) И Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС Тогда
                            НалогВзнос = ЗарплатаКадрыКлиентСервер.Округлить(Выборка.ОстатокЗаНалоговыйПериод, 1, ПравилоОкругления);
                        Иначе
                            НалогВзнос = ЗарплатаКадрыКлиентСервер.Округлить(Выборка.ОстатокЗаНалоговыйПериод, ПравилоОкругления);
                        КонецЕсли;
                        
                        //проверяем остатки на текущий период, если есть остатки с дробью, не округляем значение, чтобы не увеличить сумму выплаченных налогов
                        Если Выборка.НачисленоНалога - Выборка.УдержаноНалога <= НалогВзнос Тогда
                            //проверяем правило округления, если в большую сторону и разница между округлением меньше 1, то округляем налог всегда 
                            Если ПравилоОкругления = ПредопределенноеЗначение("Перечисление.ПравилаОкругленияПриРасчетеЗарплаты.ВБольшуюСторону")
                                И НалогВзнос - Выборка.ОстатокЗаНалоговыйПериод < 1 Тогда
                                СтрокаТаблицыРезультатов.НалогВзнос = НалогВзнос;
                            Иначе
                                СтрокаТаблицыРезультатов.НалогВзнос = Выборка.ОстатокЗаНалоговыйПериод;
                            КонецЕсли;
                        Иначе
                            СтрокаТаблицыРезультатов.НалогВзнос = НалогВзнос;
                        КонецЕсли;
						СтрокаТаблицыРезультатов.МесяцНалоговогоПериода = Выборка.ПоследнийМесяцНалоговогоПериода;
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
		КонецЦикла;
		
	КонецЦикла;
	
	ЗарплатаКадры.УничтожитьВТ(Запрос.МенеджерВременныхТаблиц, ТаблицыКУдалению);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьУдержаниеНалоговВзносовПоНУПрочиеДоходы(Ссылка, Организация, ДатаОперации, ПериодРегистрации = Неопределено) Экспорт
	
	РезультатыРасчетов = Новый ТаблицаЗначений;
	РезультатыРасчетов.Колонки.Добавить("ФизическоеЛицо",Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"));
	РезультатыРасчетов.Колонки.Добавить("МесяцНалоговогоПериода",Новый ОписаниеТипов("Дата",,,Новый КвалификаторыДаты(ЧастиДаты.Дата)));
	РезультатыРасчетов.Колонки.Добавить("РегистрацияВНалоговомОргане",Новый ОписаниеТипов("СправочникСсылка.РегистрацииВНалоговомОргане"));
	РезультатыРасчетов.Колонки.Добавить("ВидНалогаВзносаОтчисления",Новый ОписаниеТипов("ПеречислениеСсылка.ВидыНалоговВзносовОтчислений"));
	РезультатыРасчетов.Колонки.Добавить("ВидДохода",Новый ОписаниеТипов("СправочникСсылка.ВидыДоходов"));
	РезультатыРасчетов.Колонки.Добавить("НалогВзнос",Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(15,2)));
	РезультатыРасчетов.Колонки.Добавить("НачисленоНалога",Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(15,2)));
	
	// УПК
	ИспользоватьВедомостиДляВыплатыПрочихДоходов = Ложь;
	
	Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.Дивиденды") Тогда
		ДивидендыИмяДокумента = "ДивидендыФизическимЛицам";
		ИспользоватьВедомостиДляВыплатыПрочихДоходов = ПолучитьФункциональнуюОпцию("ИспользоватьВедомостиДляВыплатыПрочихДоходов");	
		ТекстСоединенияДивиденды = "";
	Иначе
		ДивидендыИмяДокумента = "НачислениеДивидендов";
		// в УПК ведомости прочих доходов используются всегда вне зависимости от ФО ИспользоватьВедомостиДляВыплатыПрочихДоходов
		ИспользоватьВедомостиДляВыплатыПрочихДоходов = Истина;	
		ТекстСоединенияДивиденды = "И ЛОЖЬ";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ПериодРегистрации",ПериодРегистрации);
	Запрос.УстановитьПараметр("ПериодВзаиморасчетов",КонецМесяца(ПериодРегистрации));
	Запрос.УстановитьПараметр("Организация",Организация);
	Запрос.УстановитьПараметр("Регистратор", Ссылка);
	Запрос.УстановитьПараметр("КонецМесяца", КонецМесяца(ПериодРегистрации));
	
	Если ИспользоватьВедомостиДляВыплатыПрочихДоходов Тогда
		
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВзаиморасчетыСКонтрагентамиОстатки.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВЫБОР
		|		КОГДА НЕ НачислениеЗарплаты.Ссылка ЕСТЬ NULL
		|			ТОГДА НачислениеЗарплаты.МесяцНачисления
		|		КОГДА НЕ НачислениеПоДоговорам.Ссылка ЕСТЬ NULL
		|			ТОГДА НачислениеПоДоговорам.МесяцНачисления
		|		КОГДА НЕ РегистрацияПрочихДоходов.Ссылка ЕСТЬ NULL
		|			ТОГДА РегистрацияПрочихДоходов.ПериодРегистрации
		|		КОГДА НЕ ДивидендыФизическимЛицам.Ссылка ЕСТЬ NULL
		|			ТОГДА НАЧАЛОПЕРИОДА(ДивидендыФизическимЛицам.ДатаВыплаты, МЕСЯЦ)
		|		КОГДА НЕ ВыплатаБывшимСотрудникам.Ссылка ЕСТЬ NULL
		|			ТОГДА ВыплатаБывшимСотрудникам.ПериодРегистрации
		|		ИНАЧЕ &ПериодРегистрации
		|	КОНЕЦ КАК ПериодВзаиморасчетов,
		|	ВзаиморасчетыСКонтрагентамиОстатки.СтатьяФинансирования КАК СтатьяФинансирования,
		|	ВзаиморасчетыСКонтрагентамиОстатки.СтатьяРасходов КАК СтатьяРасходов,
		|	ВзаиморасчетыСКонтрагентамиОстатки.ДокументОснование КАК ДокументОснование,
		|	СУММА(ВзаиморасчетыСКонтрагентамиОстатки.СуммаВзаиморасчетовОстаток) КАК СуммаКВыплате
		|ПОМЕСТИТЬ ВТВзаиморасчетыСКонтрагентамиОстатки
		|ИЗ
		|	РегистрНакопления.ВзаиморасчетыСКонтрагентамиАкционерами.Остатки(&ПериодВзаиморасчетов, Организация = &Организация) КАК ВзаиморасчетыСКонтрагентамиОстатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.НачислениеЗарплаты КАК НачислениеЗарплаты 
		|		ПО НачислениеЗарплаты.Ссылка = ВзаиморасчетыСКонтрагентамиОстатки.ДокументОснование
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.НачислениеПоДоговорам КАК НачислениеПоДоговорам 
		|		ПО НачислениеПоДоговорам.Ссылка = ВзаиморасчетыСКонтрагентамиОстатки.ДокументОснование
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РегистрацияПрочихДоходов КАК РегистрацияПрочихДоходов 
