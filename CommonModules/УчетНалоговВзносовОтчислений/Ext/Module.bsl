		|		ПО НастройкиИРазмерыВычетов.МесяцНалоговогоПериода = НакопленныеДанныеПоВычетамПоДругимВидамДохода.МесяцНалоговогоПериода
		|			И НастройкиИРазмерыВычетов.ФизическоеЛицо = НакопленныеДанныеПоВычетамПоДругимВидамДохода.ФизическоеЛицо
		|			И НастройкиИРазмерыВычетов.ВидВычета = НакопленныеДанныеПоВычетамПоДругимВидамДохода.ВидВычета
		|			И НастройкиИРазмерыВычетов.МесяцНалоговогоПериода = НакопленныеДанныеПоВычетамПоДругимВидамДохода.МесяцНалоговогоПериода
		|			И НЕ НастройкиИРазмерыВычетов.ВидДоходаВычета = НакопленныеДанныеПоВычетамПоДругимВидамДохода.ВидДохода
		|
		|СГРУППИРОВАТЬ ПО
		|	НастройкиИРазмерыВычетов.МесяцНалоговогоПериода,
		|	НастройкиИРазмерыВычетов.ФизическоеЛицо,
		|	НастройкиИРазмерыВычетов.ВидВычета,
		|   НастройкиИРазмерыВычетов.ВидДоходаВычета
		|";
	
	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"ВТПериодыПоФизлицам КАК ПериодыПоФизлицам","ВТПериодыПоФизлицамОбъединенная КАК ПериодыПоФизлицам");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ДатаНачалаДействияВычетаСО", ПолучитьДатуНачалаДействияВычетаСО());
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТНастойкиВычетов");
	УничтожитьВТ.Добавить("ВТНастройкиИРазмерыВычетов");
	УничтожитьВТ.Добавить("ВТРазмерыПределовПосле2018");
	УничтожитьВТ.Добавить("ВТНастройкиВычетовПоВидамДоходаКоличество");
    УничтожитьВТ.Добавить("ВТНакопленныеДанныеПоВычетамБезПодразделения");
    УничтожитьВТ.Добавить("ВТНакопленныеДанныеПоВычетамПоДругимВидамДохода");
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НастройкиИРазмерыВычетов.МесяцНалоговогоПериода,
		|	НастройкиИРазмерыВычетов.ФизическоеЛицо,
		|	НастройкиИРазмерыВычетов.ВидВычета,
		|	НастройкиИРазмерыВычетов.Приоритет,
		|	НастройкиИРазмерыВычетов.ПредоставлениеВычета,
		|	НастройкиИРазмерыВычетов.ВидВзносов,
		|	НастройкиИРазмерыВычетов.ПределВычета,
		|	НастройкиИРазмерыВычетов.ПериодПредоставления,
		|	ЕСТЬNULL(НастройкиИРазмерыВычетов.ВидДоходаВзносов, ВЫБОР
		|		КОГДА НастройкиИРазмерыВычетов.ИспользуетсяПоНесколькимВидамДохода
		|			ТОГДА NULL
		|		ИНАЧЕ НакопленныеДанныеПоВычетам.ВидДохода
		|	КОНЕЦ) КАК ВидДоходаВзносов,
		|	ЕСТЬNULL(НастройкиИРазмерыВычетов.ВидДоходаВычета, НакопленныеДанныеПоВычетам.ВидДохода) КАК ВидДоходаВычета,
		|	НастройкиИРазмерыВычетов.ИспользуетсяПоНесколькимВидамДохода,
		|	НастройкиИРазмерыВычетов.РазмерВычета,
		|	НастройкиИРазмерыВычетов.СуммовойПределВычета,
		|	СУММА(ЕСТЬNULL(НакопленныеДанныеПоВычетамПоДругимВидамДохода.РазрешенныйВычетСНачалаГода, 0)) КАК РазрешенныйВычетСНачалаГодаПоДругимВидам,
		|	СУММА(ЕСТЬNULL(НакопленныеДанныеПоВычетамПоДругимВидамДохода.ПримененныйВычетСНачалаГода, 0)) КАК ПримененныйВычетСНачалаГодаПоДругимВидам,
		|	СУММА(ЕСТЬNULL(НакопленныеДанныеПоВычетам.РазрешенныйВычетВТекущемПериоде, 0)) КАК РазрешенныйВычетВТекущемПериоде,
		|	СУММА(ЕСТЬNULL(НакопленныеДанныеПоВычетам.ПримененныйВычетВТекущемПериоде, 0)) КАК ПримененныйВычетВТекущемПериоде,
		|	СУММА(ЕСТЬNULL(НакопленныеДанныеПоВычетам.РазрешенныйВычетСНачалаГода, 0)) КАК РазрешенныйВычетСНачалаГода,
		|	СУММА(ЕСТЬNULL(НакопленныеДанныеПоВычетам.ПримененныйВычетСНачалаГода, 0) + ЕСТЬNULL(ВычетыПримененныеУДругогоРаботодателя.ПримененныйВычетСНачалаГода, 0)) КАК ПримененныйВычетСНачалаГода,
		|	СУММА(ЕСТЬNULL(НакопленныеДанныеПоВычетам.РазрешенныйВычетСНачалаГодаОтОбратного, 0)) КАК РазрешенныйВычетСНачалаГодаОтОбратного,
		|	СУММА(ЕСТЬNULL(НакопленныеДанныеПоВычетам.ПримененныйВычетСНачалаГодаОтОбратного, 0) + ЕСТЬNULL(ВычетыПримененныеУДругогоРаботодателя.ПримененныйВычетСНачалаГода, 0)) КАК ПримененныйВычетСНачалаГодаОтОбратного
		|ПОМЕСТИТЬ ВТДанныеДляРасчетаВычетовИПН
		|ИЗ
		|	ВТНастройкиИРазмерыВычетов КАК НастройкиИРазмерыВычетов
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНакопленныеДанныеПоВычетамБезПодразделения КАК НакопленныеДанныеПоВычетам
		|		ПО НастройкиИРазмерыВычетов.МесяцНалоговогоПериода = НакопленныеДанныеПоВычетам.МесяцНалоговогоПериода
		|			И НастройкиИРазмерыВычетов.ФизическоеЛицо = НакопленныеДанныеПоВычетам.ФизическоеЛицо
		|			И НастройкиИРазмерыВычетов.ВидВычета = НакопленныеДанныеПоВычетам.ВидВычета
		|			И НастройкиИРазмерыВычетов.ВидДоходаВычета = НакопленныеДанныеПоВычетам.ВидДохода
		|			И НастройкиИРазмерыВычетов.МесяцНалоговогоПериода = НакопленныеДанныеПоВычетам.МесяцНалоговогоПериода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТНакопленныеДанныеПоВычетамПоДругимВидамДохода КАК НакопленныеДанныеПоВычетамПоДругимВидамДохода
		|		ПО НастройкиИРазмерыВычетов.МесяцНалоговогоПериода = НакопленныеДанныеПоВычетамПоДругимВидамДохода.МесяцНалоговогоПериода
		|			И НастройкиИРазмерыВычетов.ФизическоеЛицо = НакопленныеДанныеПоВычетамПоДругимВидамДохода.ФизическоеЛицо
		|			И НастройкиИРазмерыВычетов.ВидВычета = НакопленныеДанныеПоВычетамПоДругимВидамДохода.ВидВычета
		|			И НастройкиИРазмерыВычетов.МесяцНалоговогоПериода = НакопленныеДанныеПоВычетамПоДругимВидамДохода.МесяцНалоговогоПериода
		|			И НастройкиИРазмерыВычетов.ВидДоходаВычета = НакопленныеДанныеПоВычетамПоДругимВидамДохода.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТВычетыПримененныеУДругогоРаботодателя КАК ВычетыПримененныеУДругогоРаботодателя
		|		ПО НастройкиИРазмерыВычетов.МесяцНалоговогоПериода = ВычетыПримененныеУДругогоРаботодателя.МесяцНалоговогоПериода
		|			И НастройкиИРазмерыВычетов.ФизическоеЛицо = ВычетыПримененныеУДругогоРаботодателя.ФизическоеЛицо
		|			И НастройкиИРазмерыВычетов.ВидВычета = ВычетыПримененныеУДругогоРаботодателя.ВидВычета
		|
		|СГРУППИРОВАТЬ ПО
		|	НастройкиИРазмерыВычетов.МесяцНалоговогоПериода,
		|	НастройкиИРазмерыВычетов.ФизическоеЛицо,
		|	НастройкиИРазмерыВычетов.ВидВычета,
		|	НастройкиИРазмерыВычетов.Приоритет,
		|	НастройкиИРазмерыВычетов.ПредоставлениеВычета,
		|	НастройкиИРазмерыВычетов.ВидВзносов,
		|	НастройкиИРазмерыВычетов.ПределВычета,
		|	НастройкиИРазмерыВычетов.ПериодПредоставления,
		|	ЕСТЬNULL(НастройкиИРазмерыВычетов.ВидДоходаВзносов, ВЫБОР
		|		КОГДА НастройкиИРазмерыВычетов.ИспользуетсяПоНесколькимВидамДохода
		|			ТОГДА NULL
		|		ИНАЧЕ НакопленныеДанныеПоВычетам.ВидДохода
		|	КОНЕЦ),
		|	ЕСТЬNULL(НастройкиИРазмерыВычетов.ВидДоходаВычета, НакопленныеДанныеПоВычетам.ВидДохода),
		|	НастройкиИРазмерыВычетов.ИспользуетсяПоНесколькимВидамДохода,
		|	НастройкиИРазмерыВычетов.РазмерВычета,
		|	НастройкиИРазмерыВычетов.СуммовойПределВычета
		|";
		
	Запрос.Выполнить();

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);

КонецПроцедуры

Процедура СоздатьВТДанныеДляРасчетаВычетовИПНПосле2021(МенеджерВременныхТаблиц, Организация, ПредоставлятьВычетВМесяцеОтсутствияДохода = Ложь, МесяцНачисления) Экспорт
    
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	
	Если НЕ ВТСуществует(МенеджерВременныхТаблиц, "ВТИсчисленныеОПВ") Тогда
		Запрос.Текст =
			"ВЫБРАТЬ
			|	NULL КАК МесяцНалоговогоПериода,
			|	NULL КАК ФизическоеЛицо,
			|	NULL КАК ВидДохода,
			|	0 КАК ИсчисленныеОПВ
			|ПОМЕСТИТЬ ВТИсчисленныеОПВ";
		Запрос.Выполнить();
	КонецЕсли;
	
    Если НЕ ВТСуществует(МенеджерВременныхТаблиц, "ВТИсчисленныеВОСМС") Тогда
    	Запрос.Текст =
    		"ВЫБРАТЬ
    		|	NULL КАК МесяцНалоговогоПериода,
    		|	NULL КАК ФизическоеЛицо,
    		|	NULL КАК ВидДохода,
    		|	0 КАК ИсчисленныеВОСМС
    		|ПОМЕСТИТЬ ВТИсчисленныеВОСМС";
    	Запрос.Выполнить();
    КонецЕсли;
	
	// Применение вычетов ИПН
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(ПрименениеВычетовИПН.Период) КАК Период,
		|	ПрименениеВычетовИПН.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода
		|ПОМЕСТИТЬ ВТПериодыПримененияВычетов
		|ИЗ
		|	ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПрименениеВычетовИПН КАК ПрименениеВычетовИПН
		|		ПО ПериодыПоФизлицам.МесяцНалоговогоПериода >= ПрименениеВычетовИПН.Период
		|			И ПериодыПоФизлицам.ФизическоеЛицо = ПрименениеВычетовИПН.ФизическоеЛицо
		|			И (ПрименениеВычетовИПН.Активность)
		|
		|СГРУППИРОВАТЬ ПО
		|	ПрименениеВычетовИПН.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТПериодыПримененияВычетов.ФизическоеЛицо,
		|	ВТПериодыПримененияВычетов.МесяцНалоговогоПериода,
		|	ПрименениеВычетовИПН.Организация
		|ПОМЕСТИТЬ ВТПрименениеВычетовИПН
		|ИЗ
		|	ВТПериодыПримененияВычетов КАК ВТПериодыПримененияВычетов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПрименениеВычетовИПН КАК ПрименениеВычетовИПН
		|		ПО ВТПериодыПримененияВычетов.Период = ПрименениеВычетовИПН.Период
		|			И ВТПериодыПримененияВычетов.ФизическоеЛицо = ПрименениеВычетовИПН.ФизическоеЛицо
		|			И (ПрименениеВычетовИПН.Активность)
		|ГДЕ
		|	ПрименениеВычетовИПН.Организация = &Организация";
	
	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"ВТПериодыПоФизлицам КАК ПериодыПоФизлицам","ВТПериодыПоФизлицамОбъединенная КАК ПериодыПоФизлицам");
	КонецЕсли;
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТПериодыПримененияВычетов");
	УничтожитьВТ.Добавить("ВТПрименениеВычетовИПН");
	
	// Назначенные вычеты ИПН
	Запрос.Текст = 
		"ВЫБРАТЬ
