		|	ОсуществлениеОППВ.ФизическоеЛицо ЕСТЬ NULL ";
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеОППВ");
	
	ВидНалогаВзносаОППВ =  Перечисления.ВидыНалоговВзносовОтчислений.ОППВ;
	
	// Таблица ВТДоходы: облагаемые и необлагаемые суммы доходов
	СоздатьВТДоходы(МенеджерВременныхТаблиц, ВидНалогаВзносаОППВ, "ВТИсключаемыеФизическиеЛицаПриРасчетеОППВ", Ложь);
	УничтожитьВТ.Добавить("ВТДоходы");
	УничтожитьВТ.Добавить("ВТДоходыПоПодразделениям");
	
	// Таблица ВТВТИсчисленныеНалогиВзносыПоПодразделениям: сведения о ранее исчисленных ОППВ
	СоздатьВТИсчисленныеНалогиВзносыПоПодразделениям(МенеджерВременныхТаблиц, ВидНалогаВзносаОППВ);
	УничтожитьВТ.Добавить("ВТИсчисленныеНалогиВзносыПоПодразделениям");
	
	// - Исчисленные ОППВ
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Доходы.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	Доходы.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Доходы.ВидДохода КАК ВидДохода,
		|	Доходы.ОблагаемыйДоход КАК ОбъектИсчисленияОППВ,
		|	Доходы.ОблагаемыйДоход * ЕСТЬNULL(СтавкиОППВ.Ставка, 0) КАК ИсчисленныеОППВ
		|ПОМЕСТИТЬ ВТИсчисленныеОППВ
		|ИЗ
		|	ВТДоходы КАК Доходы
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавки КАК СтавкиОППВ
		|		ПО Доходы.МесяцНалоговогоПериода = СтавкиОППВ.МесяцНалоговогоПериода
		|			И (СтавкиОППВ.ВидНалогаВзносаОтчисления = ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ОППВ))
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИсчисленныеОППВ.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ВТИсчисленныеОППВ.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсчисленныеОППВ.ВидДохода КАК ВидДохода,
		|	ВТИсчисленныеОППВ.ОбъектИсчисленияОППВ КАК ОбъектИсчисленияОППВ,
		|	ВТИсчисленныеОППВ.ИсчисленныеОППВ КАК ИсчисленныеОППВ
		|ИЗ
		|	ВТИсчисленныеОППВ КАК ВТИсчисленныеОППВ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДоходыПоПодразделениям.Подразделение КАК Подразделение,
		|	ДоходыПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ДоходыПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ДоходыПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ДоходыПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	ДоходыПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход
		|ИЗ
		|	ВТДоходыПоПодразделениям КАК ДоходыПоПодразделениям
		|ГДЕ
		|	(ДоходыПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ДоходыПоПодразделениям.НеоблагаемыйДоход <> 0)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсчисленныеОППВПоПодразделениям.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ИсчисленныеОППВПоПодразделениям.Подразделение КАК Подразделение,
		|	ИсчисленныеОППВПоПодразделениям.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсчисленныеОППВПоПодразделениям.ВидДохода КАК ВидДохода,
		|	ИсчисленныеОППВПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеОППВПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоходИсчисленныйРанее,
		|	ИсчисленныеОППВПоПодразделениям.ОбъектИсчисления КАК ОбъектОППВИсчисленныйРанее,
		|	ИсчисленныеОППВПоПодразделениям.НалогВзнос КАК РанееИсчисленныеОППВ,
		|	-ИсчисленныеОППВПоПодразделениям.ОблагаемыйДоход КАК ОблагаемыйДоход,
		|	-ИсчисленныеОППВПоПодразделениям.НеоблагаемыйДоход КАК НеоблагаемыйДоход,
		|	-ИсчисленныеОППВПоПодразделениям.НалогВзнос КАК ИсчисленныеОППВ,
		|	-ИсчисленныеОППВПоПодразделениям.ОбъектИсчисления КАК ОбъектИсчисленияОППВ
		|ИЗ
		|	ВТИсчисленныеНалогиВзносыПоПодразделениям КАК ИсчисленныеОППВПоПодразделениям
		|ГДЕ
		|	(ИсчисленныеОППВПоПодразделениям.ОблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеОППВПоПодразделениям.НеоблагаемыйДоход <> 0
		|			ИЛИ ИсчисленныеОППВПоПодразделениям.ОбъектИсчисления <> 0
		|			ИЛИ ИсчисленныеОППВПоПодразделениям.НалогВзнос <> 0)";
	
	Результат = Запрос.ВыполнитьПакет();	
	УничтожитьВТ.Добавить("ВТИсчисленныеОППВ");
	
	ВсегоРезультатов = Результат.Количество();
	ИсчисленныеОППВПоПодразделениям = Результат[ВсегоРезультатов - 1].Выгрузить();
	РаспределениеДоходовПоПодразделениям = Результат[ВсегоРезультатов - 2].Выгрузить();
	РезультатЗапроса = Результат[ВсегоРезультатов - 3].Выгрузить();
	
	РезультатыРасчетов = РезультатЗапроса.СкопироватьКолонки();
	КвалификаторЧисла = Новый КвалификаторыЧисла(13,5);
	РезультатыРасчетов.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ИсчисленныеОППВВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектИсчисленияОППВВЦеломЗаПериод", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоходИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОбъектОППВИсчисленныйРанее", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("РанееИсчисленныеОППВ", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("ОблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	РезультатыРасчетов.Колонки.Добавить("НеоблагаемыйДоход", Новый ОписаниеТипов("Число", КвалификаторЧисла));
	
	ПоляПоиска = "ФизическоеЛицо, МесяцНалоговогоПериода, ВидДохода";
	СтруктураПоиска = Новый Структура(ПоляПоиска);
	РаспределениеДоходовПоПодразделениям.Индексы.Добавить(ПоляПоиска);

	СпособОкругления = ПолучитьСпособОкругления(МенеджерВременныхТаблиц, ВидНалогаВзносаОППВ);
	ОписаниеСпособаОкругления = ЗарплатаКадрыРасширенныйПовтИсп.ОписаниеСпособаОкругления(СпособОкругления);

	// для корректного округления после распределения при достижении суммы максимального предела необходима точность 0
	ТочностьОкругления = ОписаниеСпособаОкругления.Точность - Цел(ОписаниеСпособаОкругления.Точность);
	
	Если ТочностьОкругления = 0 Тогда
		ТочностьРаспределения = 0;
	ИначеЕсли ТочностьОкругления <= 0.1 Тогда
		ТочностьРаспределения = 2;
	Иначе
		ТочностьРаспределения = 1;
	КонецЕсли;
			
	Для Каждого СтрокаРасчета Из РезультатЗапроса Цикл
		СтруктураПоиска.ФизическоеЛицо = СтрокаРасчета.ФизическоеЛицо;
		СтруктураПоиска.МесяцНалоговогоПериода = СтрокаРасчета.МесяцНалоговогоПериода;
		СтруктураПоиска.ВидДохода = СтрокаРасчета.ВидДохода;
		ДоходыМесяца = РаспределениеДоходовПоПодразделениям.НайтиСтроки(СтруктураПоиска);
		РаспределитьНалогиВзносыПоПодразделениям(РезультатыРасчетов, СтрокаРасчета, ДоходыМесяца, "ОбъектИсчисленияОППВ,ИсчисленныеОППВ", ТочностьРаспределения);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ИсчисленныеОППВПоПодразделениям, РезультатыРасчетов);

	РезультатыРасчетов.Свернуть("ФизическоеЛицо, Подразделение, МесяцНалоговогоПериода, ВидДохода",
								"ОблагаемыйДоходВЦеломЗаПериод, 	НеоблагаемыйДоходВЦеломЗаПериод, 	ОбъектИсчисленияОППВВЦеломЗаПериод, ИсчисленныеОППВВЦеломЗаПериод,
								|ОблагаемыйДоходИсчисленныйРанее, 	НеоблагаемыйДоходИсчисленныйРанее, 	ОбъектОППВИсчисленныйРанее, 		РанееИсчисленныеОППВ,
								|ОблагаемыйДоход, 					НеоблагаемыйДоход,					ОбъектИсчисленияОППВ, 				ИсчисленныеОППВ");
	
	РезультатыРасчетов.Колонки.Добавить("НомерСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(13,0)));
	НомерСтроки = 0;
	
	Для каждого СтрокаТЗ Из РезультатыРасчетов Цикл
		
		НомерСтроки = НомерСтроки + 1;
	    СтрокаТЗ.НомерСтроки = НомерСтроки;
		
		// спишем возникшую погрешность округления при перераспределении сумм по подразделениям
		Если СтрокаТЗ.ОблагаемыйДоход = 0
			И (СтрокаТЗ.ИсчисленныеОППВ < 1 И СтрокаТЗ.ИсчисленныеОППВ > 0
				ИЛИ СтрокаТЗ.ИсчисленныеОППВ > -1 И СтрокаТЗ.ИсчисленныеОППВ < 0) Тогда
				
			СтрокаТЗ.ИсчисленныеОППВ = 0;
			
		// исчисление взносов производятся в тенге с учетом округления тиын
		Иначе
			
			СтрокаТЗ.ИсчисленныеОППВ = ЗарплатаКадрыКлиентСервер.Округлить(СтрокаТЗ.ИсчисленныеОППВ, ОписаниеСпособаОкругления.Точность, ОписаниеСпособаОкругления.ПравилоОкругления);
			
		КонецЕсли;
		
	КонецЦикла; 

	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	Возврат РезультатыРасчетов;
	
КонецФункции

Функция РассчитатьОППВПосле2023(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет = Истина, ИсключатьДоходыРегистратора = Истина) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	// Получение сведений по коэффициенту отработанного времени во вредных условиях
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ИспользоватьШтатноеРасписание", ПолучитьФункциональнуюОпцию("ИспользоватьШтатноеРасписание"));
	Запрос.УстановитьПараметр("Командировка", ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыИспользованияРабочегоВремени.Командировка"));
	
	// Сведения о необходимости исчисления ОППВ
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПериодыУсловийТруда.МесяцНалоговогоПериода,
		|	ПериодыУсловийТруда.Должность,
		|	КлассыУсловийТрудаПоДолжностям.ОсуществляютсяОППВ
		|ПОМЕСТИТЬ ВТОсобенностиИсчисленияОППВ
		|ИЗ
		|	(ВЫБРАТЬ
		|		ПериодыРасчета.Период КАК МесяцНалоговогоПериода,
		|		КлассыУсловийТрудаПоДолжностям.Должность КАК Должность,
		|		МАКСИМУМ(КлассыУсловийТрудаПоДолжностям.Период) КАК Период
		|	ИЗ
		|		ВТДатыПоМесяцам КАК ПериодыРасчета
		|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КлассыУсловийТрудаПоДолжностям КАК КлассыУсловийТрудаПоДолжностям
		|			ПО ПериодыРасчета.Период >= КлассыУсловийТрудаПоДолжностям.Период
		|	
		|	СГРУППИРОВАТЬ ПО
		|		КлассыУсловийТрудаПоДолжностям.Должность,
		|		ПериодыРасчета.Период) КАК ПериодыУсловийТруда
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КлассыУсловийТрудаПоДолжностям КАК КлассыУсловийТрудаПоДолжностям
		|		ПО ПериодыУсловийТруда.Период = КлассыУсловийТрудаПоДолжностям.Период
		|			И ПериодыУсловийТруда.Должность = КлассыУсловийТрудаПоДолжностям.Должность";
		
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТОсобенностиИсчисленияОППВ");
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МИНИМУМ(НАЧАЛОПЕРИОДА(ПериодыПоСотрудникам.МесяцНалоговогоПериода, МЕСЯЦ)) КАК НачалоПериода,
		|	МАКСИМУМ(КОНЕЦПЕРИОДА(ПериодыПоСотрудникам.МесяцНалоговогоПериода, МЕСЯЦ)) КАК КонецПериода,
		|	ПериодыПоСотрудникам.Сотрудник,
		|	ПериодыПоСотрудникам.ФизическоеЛицо
		|ПОМЕСТИТЬ ВТПериодыКадровыхДанныхСотрудников
		|ИЗ
		|	ВТКадровыеДанныеСотрудниковПоПериодам КАК ПериодыПоСотрудникам
		|
		|СГРУППИРОВАТЬ ПО
		|	ПериодыПоСотрудникам.Сотрудник,
		|	ПериодыПоСотрудникам.ФизическоеЛицо
		|";
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТПериодыКадровыхДанныхСотрудников");
	
	// Получим кадровые данные
	ОписаниеФильтра = ЗарплатаКадрыОбщиеНаборыДанных.ОписаниеФильтраДляСоздатьВТИмяРегистра(
		"ВТПериодыКадровыхДанныхСотрудников", 
		"Сотрудник");
		
	ОписаниеФильтра.СоответствиеИзмеренийРегистраИзмерениямФильтра.Вставить("ДатаНачала", "НачалоПериода");
	ОписаниеФильтра.СоответствиеИзмеренийРегистраИзмерениямФильтра.Вставить("ДатаОкончания", "КонецПериода");
	
	// не используем параметр ВключатьЗаписиНаНачалоПериода, тк он не используется в построении запроса для интервального регистра в СоздатьВТИмяРегистраПериоды
	//ПараметрыПостроения.ВключатьЗаписиНаНачалоПериода = Истина;
	ЗарплатаКадрыПериодическиеРегистры.СоздатьВТИмяРегистраПериоды(
		"КадроваяИсторияСотрудников",
		МенеджерВременныхТаблиц,
		Истина,
		ОписаниеФильтра,
		,
		"ВТКадровыеДанныеДляДолжностей");

	Запрос.Текст = "
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	НАЧАЛОПЕРИОДА(КадроваяИсторияСотрудников.НачалоПериода, ДЕНЬ) КАК КадровыйПериод,
		|	КадроваяИсторияСотрудников.Сотрудник,
		|	КадроваяИсторияСотрудников.ДолжностьПоШтатномуРасписанию,
		|	КадроваяИсторияСотрудников.Должность
		|ПОМЕСТИТЬ ВТДанныеЗанимаемыхДолжностей
		|ИЗ
		|	ВТКадровыеДанныеДляДолжностей КАК КадроваяИсторияСотрудников";

	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТДанныеЗанимаемыхДолжностей");
	
	Если ПолучитьФункциональнуюОпцию("ВестиУчетРабочегоВремениПоУсловиямТруда", Новый Структура("Организация", Организация)) Тогда
		
		// Расчет по данным Табеля	
		ТекстЗапроса = 	
