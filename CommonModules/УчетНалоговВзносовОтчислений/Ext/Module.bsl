Функция НоваяТаблицаНалогиВзносыОтчисления() Экспорт
	
	МассивТипов = Новый Массив;
	МассивТипов.Добавить(Тип("ПеречислениеСсылка.ВидыОсобыхНачисленийИУдержаний"));
	МассивТипов.Добавить(Тип("ПланВидовРасчетаСсылка.Начисления"));
	ОтражениеЗарплатыВУчетеВнутренний.ДополнитьМассивТиповНачисления(МассивТипов);
	
	Таблица = Новый ТаблицаЗначений;
	Таблица.Колонки.Добавить("Организация", Новый ОписаниеТипов("СправочникСсылка.Организации"));
	Таблица.Колонки.Добавить("Сотрудник",  Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
	Таблица.Колонки.Добавить("ФизическоеЛицо", Новый ОписаниеТипов("СправочникСсылка.ФизическиеЛица"), НСтр("ru = 'Сотрудник'"));
	Таблица.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	Таблица.Колонки.Добавить("ВидОперации", Новый ОписаниеТипов("ПеречислениеСсылка.ВидыОперацийПоЗарплате"));
	Таблица.Колонки.Добавить("Начисление", Новый ОписаниеТипов(МассивТипов));
	Таблица.Колонки.Добавить("ДатаНачала", Новый ОписаниеТипов("Дата"));
	Таблица.Колонки.Добавить("ОблагаетсяЕНВД", Новый ОписаниеТипов("Булево"));
	Таблица.Колонки.Добавить("Сумма", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)));
	Таблица.Колонки.Добавить("ИдентификаторСтроки", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(7, 0)));
	
	Возврат Таблица;
	
КонецФункции

Функция ДанныеДляОтражениеВУчетеВзносовПоТаблице(НалогиВзносыОтчисления) Экспорт
	
	Если НалогиВзносыОтчисления.Количество() = 0 Тогда
		Возврат НоваяТаблицаНалогиВзносыОтчисления();
	Иначе
		
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
		Запрос.УстановитьПараметр("НалогиВзносыОтчисления", НалогиВзносыОтчисления);
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	НалогиВзносыОтчисления.Организация,
		|	НалогиВзносыОтчисления.ФизическоеЛицо,
		|	НалогиВзносыОтчисления.Сотрудник,
		|	НалогиВзносыОтчисления.Подразделение,
		|	НалогиВзносыОтчисления.Начисление,
		|	НалогиВзносыОтчисления.СО,
		|	НалогиВзносыОтчисления.СН,
		|	НалогиВзносыОтчисления.ОППВ,
		|	НалогиВзносыОтчисления.ООСМС,
		|	ЛОЖЬ КАК ОблагаетсяЕНВД,
		|	НАЧАЛОПЕРИОДА(НалогиВзносыОтчисления.Период, МЕСЯЦ) КАК ДатаНачала
		|ПОМЕСТИТЬ ВТНалогиВзносыОтчисления
		|ИЗ
		|	&НалогиВзносыОтчисления КАК НалогиВзносыОтчисления";
		Запрос.Выполнить();
		
		Возврат ТаблицаВзносовДляОтражениеВУчете(Запрос.МенеджерВременныхТаблиц);
		
	КонецЕсли;
	
КонецФункции

Функция ТаблицаВзносовДляОтражениеВУчете(МенеджерВременныхТаблиц)
	
	ТаблицаВзносов = НоваяТаблицаНалогиВзносыОтчисления();
	
	ВидыОпераций = Новый Массив;
	ВидыОпераций.Добавить(Перечисления.ВидыОперацийПоЗарплате.СН);
	ВидыОпераций.Добавить(Перечисления.ВидыОперацийПоЗарплате.СО);
	ВидыОпераций.Добавить(Перечисления.ВидыОперацийПоЗарплате.ОППВ);
	ВидыОпераций.Добавить(Перечисления.ВидыОперацийПоЗарплате.ООСМС);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ВидыОпераций", ВидыОпераций);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НалогиВзносыОтчисления.Организация,
	|	НалогиВзносыОтчисления.ФизическоеЛицо,
	|	НалогиВзносыОтчисления.Сотрудник,
	|	НалогиВзносыОтчисления.Подразделение,
	|	НалогиВзносыОтчисления.Начисление,
	|	НалогиВзносыОтчисления.ОблагаетсяЕНВД,
	|	НалогиВзносыОтчисления.ДатаНачала,
	|	ВидыОперацийПоЗарплате.Ссылка КАК ВидОперации,
	|	СУММА(ВЫБОР
	|			КОГДА ВидыОперацийПоЗарплате.Ссылка = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПоЗарплате.СН)
	|				ТОГДА НалогиВзносыОтчисления.СН
	|			КОГДА ВидыОперацийПоЗарплате.Ссылка = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПоЗарплате.СО)
	|				ТОГДА НалогиВзносыОтчисления.СО
	|			КОГДА ВидыОперацийПоЗарплате.Ссылка = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПоЗарплате.ОППВ)
	|				ТОГДА НалогиВзносыОтчисления.ОППВ
	|			КОГДА ВидыОперацийПоЗарплате.Ссылка = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПоЗарплате.ООСМС)
	|				ТОГДА НалогиВзносыОтчисления.ООСМС
	|			ИНАЧЕ 0
	|		КОНЕЦ) КАК Сумма
	|ИЗ
	|	ВТНалогиВзносыОтчисления КАК НалогиВзносыОтчисления
	|		ЛЕВОЕ СОЕДИНЕНИЕ Перечисление.ВидыОперацийПоЗарплате КАК ВидыОперацийПоЗарплате
	|		ПО (ВидыОперацийПоЗарплате.Ссылка В (&ВидыОпераций))
	|
	|СГРУППИРОВАТЬ ПО
	|	НалогиВзносыОтчисления.Организация,
	|	НалогиВзносыОтчисления.ФизическоеЛицо,
	|	НалогиВзносыОтчисления.Сотрудник,
	|	НалогиВзносыОтчисления.Подразделение,
	|	НалогиВзносыОтчисления.Начисление,
	|	НалогиВзносыОтчисления.ОблагаетсяЕНВД,
	|	НалогиВзносыОтчисления.ДатаНачала,
	|	ВидыОперацийПоЗарплате.Ссылка
	|
	|ИМЕЮЩИЕ
	|	СУММА(ВЫБОР
	|			КОГДА ВидыОперацийПоЗарплате.Ссылка = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПоЗарплате.СН)
	|				ТОГДА НалогиВзносыОтчисления.СН
	|			КОГДА ВидыОперацийПоЗарплате.Ссылка = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПоЗарплате.СО)
	|				ТОГДА НалогиВзносыОтчисления.СО
	|			КОГДА ВидыОперацийПоЗарплате.Ссылка = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПоЗарплате.ОППВ)
	|				ТОГДА НалогиВзносыОтчисления.ОППВ
	|			КОГДА ВидыОперацийПоЗарплате.Ссылка = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПоЗарплате.ООСМС)
	|				ТОГДА НалогиВзносыОтчисления.ООСМС
	|			ИНАЧЕ 0
	|		КОНЕЦ) <> 0";
	
	Результат = Запрос.Выполнить().Выгрузить();
	ОтражениеЗарплатыВУчете.ДобавитьКолонкуИдентификаторСтроки(Результат);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(Результат, ТаблицаВзносов);
	
	Возврат ТаблицаВзносов;
	
КонецФункции

Процедура ДополнитьТаблицуНачисленныеОтпуска(НачисленныеОтпуска) Экспорт
	
	Если ТипЗнч(НачисленныеОтпуска) <> Тип("ТаблицаЗначений") Тогда
		Возврат;
	КонецЕсли;
	
	НачисленныеОтпуска.Колонки.Добавить("СН", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)));
	НачисленныеОтпуска.Колонки.Добавить("СО", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)));
	НачисленныеОтпуска.Колонки.Добавить("ОППВ", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)));
	НачисленныеОтпуска.Колонки.Добавить("ООСМС", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)));
	НачисленныеОтпуска.Колонки.Добавить("ЕП", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)));
	НачисленныеОтпуска.Колонки.Добавить("ОПВР", Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(15, 2)));
	
КонецПроцедуры

#КонецОбласти

// Расчет ОПВ

Процедура СоздатьВТИсключаемыеФизическиеЛицаПриРасчетеОПВ(МенеджерВременныхТаблиц, МесяцНачисления) Экспорт
	
	Если МесяцНачисления >= Дата(2023, 1, 1) Тогда
		СоздатьВТИсключаемыеЛицаОПВПосле2023(МенеджерВременныхТаблиц, МесяцНачисления)
	Иначе
		СоздатьВТИсключаемыеФизическиеЛицаПриРасчетеОПВДо2022(МенеджерВременныхТаблиц, МесяцНачисления)
	КонецЕсли;
	
КонецПроцедуры

Процедура СоздатьВТИсключаемыеЛицаОПВПосле2023(МенеджерВременныхТаблиц, МесяцНачисления)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("КонецМесяцаРасчета", КонецМесяца(МесяцНачисления));
	
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СведенияОПенсионномОбеспеченииФизическихЛиц.ФизическоеЛицо,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка) КАК ВидДохода
		|ПОМЕСТИТЬ ВТИсключаемыеФизическиеЛицаИсточники
		|ИЗ
		|	РегистрСведений.СведенияОПенсионномОбеспеченииФизическихЛиц.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОПенсионномОбеспеченииФизическихЛиц
		|ГДЕ
		|	(СведенияОПенсионномОбеспеченииФизическихЛиц.ПенсионерПоВозрасту
		|			ИЛИ СведенияОПенсионномОбеспеченииФизическихЛиц.ПенсионерПоВыслугеЛет)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СведенияОбИнвалидностиФизическихЛицСрезПоследних.ФизическоеЛицо,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка)
		|ИЗ
		|	РегистрСведений.СведенияОбИнвалидностиФизическихЛиц.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОбИнвалидностиФизическихЛицСрезПоследних
		|ГДЕ
		|	СведенияОбИнвалидностиФизическихЛицСрезПоследних.ОтношениеКИнвалидности = ЗНАЧЕНИЕ(Перечисление.ОтношениеКИнвалидности.Инвалид)
		|	И СведенияОбИнвалидностиФизическихЛицСрезПоследних.ГруппаИнвалидности В (ЗНАЧЕНИЕ(Перечисление.ГруппыИнвалидности.Первая), ЗНАЧЕНИЕ(Перечисление.ГруппыИнвалидности.Вторая))
		|	И СведенияОбИнвалидностиФизическихЛицСрезПоследних.ДействуетДо = ДАТАВРЕМЯ(1, 1, 1)
		|	И НЕ СведенияОбИнвалидностиФизическихЛицСрезПоследних.ИсчислятьОПВ
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка)
		|ИЗ
		|	РегистрСведений.СтатусФизическихЛицКакНалогоплательщиков.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СтатусФизическихЛицКакНалогоплательщиков
		|ГДЕ
		|	НЕ СтатусФизическихЛицКакНалогоплательщиков.ИмеетПравоНаПенсионноеОбеспечение
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо,
		|	ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
		|ИЗ
		|	ВТСтатусыФизическихЛицКакНалогоплательщиков КАК СтатусФизическихЛицКакНалогоплательщиков
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ПО СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо = ПериодыПоФизлицам.ФизическоеЛицо
		|			И СтатусФизическихЛицКакНалогоплательщиков.МесяцНалоговогоПериода = ПериодыПоФизлицам.МесяцНалоговогоПериода
		|			И СтатусФизическихЛицКакНалогоплательщиков.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)		
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТУчетнаяПолитикаПоПериодам КАК УчетнаяПолитикаПоПериодам
		|		ПО УчетнаяПолитикаПоПериодам.МесяцНалоговогоПериода = ПериодыПоФизлицам.МесяцНалоговогоПериода
		|			И УчетнаяПолитикаПоПериодам.ПорядокОбложенияДоходовРаботников = ЗНАЧЕНИЕ(Перечисление.ПорядокОбложенияДоходовРаботников.ЕдиныйПлатеж)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТИсключаемыеФизическиеЛицаИсточники.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВТИсключаемыеФизическиеЛицаИсточники.ВидДохода КАК ВидДохода
		|ПОМЕСТИТЬ ВТИсключаемыеФизическиеЛицаПриРасчетеОПВ
		|ИЗ
		|	ВТИсключаемыеФизическиеЛицаИсточники КАК ВТИсключаемыеФизическиеЛицаИсточники";
		
	Запрос.Выполнить();

	УничтожитьВТ = Новый Массив;
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаИсточники");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);

КонецПроцедуры

Процедура СоздатьВТИсключаемыеФизическиеЛицаПриРасчетеОПВДо2022(МенеджерВременныхТаблиц, МесяцНачисления) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("КонецМесяцаРасчета", КонецМесяца(МесяцНачисления));
	
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СведенияОПенсионномОбеспеченииФизическихЛиц.ФизическоеЛицо
		|ПОМЕСТИТЬ ВТИсключаемыеФизическиеЛицаИсточники
		|ИЗ
		|	РегистрСведений.СведенияОПенсионномОбеспеченииФизическихЛиц.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОПенсионномОбеспеченииФизическихЛиц
		|ГДЕ
		|	(СведенияОПенсионномОбеспеченииФизическихЛиц.ПенсионерПоВозрасту
		|			ИЛИ СведенияОПенсионномОбеспеченииФизическихЛиц.ПенсионерПоВыслугеЛет)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СведенияОбИнвалидностиФизическихЛицСрезПоследних.ФизическоеЛицо
		|ИЗ
		|	РегистрСведений.СведенияОбИнвалидностиФизическихЛиц.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СведенияОбИнвалидностиФизическихЛицСрезПоследних
		|ГДЕ
		|	СведенияОбИнвалидностиФизическихЛицСрезПоследних.ОтношениеКИнвалидности = ЗНАЧЕНИЕ(Перечисление.ОтношениеКИнвалидности.Инвалид)
		|	И СведенияОбИнвалидностиФизическихЛицСрезПоследних.ГруппаИнвалидности В (ЗНАЧЕНИЕ(Перечисление.ГруппыИнвалидности.Первая), ЗНАЧЕНИЕ(Перечисление.ГруппыИнвалидности.Вторая))
		|	И СведенияОбИнвалидностиФизическихЛицСрезПоследних.ДействуетДо = ДАТАВРЕМЯ(1, 1, 1)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо
		|ИЗ
		|	РегистрСведений.СтатусФизическихЛицКакНалогоплательщиков.СрезПоследних(
		|			&КонецМесяцаРасчета,
		|			ФизическоеЛицо В
		|				(ВЫБРАТЬ
		|					СписокСотрудников.ФизическоеЛицо
		|				ИЗ
		|					ВТФизическиеЛица КАК СписокСотрудников)) КАК СтатусФизическихЛицКакНалогоплательщиков
		|ГДЕ
		|	НЕ СтатусФизическихЛицКакНалогоплательщиков.ИмеетПравоНаПенсионноеОбеспечение
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТИсключаемыеФизическиеЛицаИсточники.ФизическоеЛицо КАК ФизическоеЛицо
		|ПОМЕСТИТЬ ВТИсключаемыеФизическиеЛицаПриРасчетеОПВ
		|ИЗ
		|	ВТИсключаемыеФизическиеЛицаИсточники КАК ВТИсключаемыеФизическиеЛицаИсточники";
		
	Запрос.Выполнить();

	УничтожитьВТ = Новый Массив;
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаИсточники");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);

КонецПроцедуры

Процедура СоздатьВТСтавкиИПН(Организация, МенеджерВременныхТаблиц) Экспорт
	
	УничтожитьВТ = Новый Массив;

	ТаблицаПределовДляНалоговыхБаз = ТаблицаПределовДляНалоговыхБаз();
	 
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ТаблицаПределовДляНалоговыхБаз", ТаблицаПределовДляНалоговыхБаз);

	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаПределовДляНалоговыхБаз.НалоговыйПериод КАК НалоговыйПериод,
		|	ТаблицаПределовДляНалоговыхБаз.ВидДохода КАК ВидДохода,
		|	ТаблицаПределовДляНалоговыхБаз.Предел КАК Предел,
        |	ТаблицаПределовДляНалоговыхБаз.ПределНерезидента КАК ПределНерезидента
		|ПОМЕСТИТЬ ВТТаблицаПределовДляНалоговыхБазВрем
		|ИЗ
		|	&ТаблицаПределовДляНалоговыхБаз КАК ТаблицаПределовДляНалоговыхБаз 
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ТаблицаПределовДляНалоговыхБаз.НалоговыйПериод) КАК НалоговыйПериод
		|ПОМЕСТИТЬ ВТТаблицаПределовДляНалоговыхБазМаксимумы
		|ИЗ
		|	ВТТаблицаПределовДляНалоговыхБазВрем КАК ТаблицаПределовДляНалоговыхБаз
        |		ЛЕВОЕ СОЕДИНЕНИЕ ВТПериодыПоГодам КАК ПериодыПоГодам 
		|		ПО ТаблицаПределовДляНалоговыхБаз.НалоговыйПериод <= ПериодыПоГодам.НачалоНалоговогоПериода 
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТаблицаПределовДляНалоговыхБаз.ВидДохода КАК ВидДохода,
		|	ТаблицаПределовДляНалоговыхБаз.Предел * РазмерыМРППоПериодам.РазмерМРПНаНачалоГода КАК СуммаПределаСтавки,
		|	ТаблицаПределовДляНалоговыхБаз.ПределНерезидента * РазмерыМРППоПериодам.РазмерМРПНаНачалоГода КАК СуммаПределаСтавкиНерезидента
		|ПОМЕСТИТЬ ВТТаблицаПределовДляНалоговыхБаз
		|ИЗ
		|	ВТТаблицаПределовДляНалоговыхБазВрем КАК ТаблицаПределовДляНалоговыхБаз
        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТТаблицаПределовДляНалоговыхБазМаксимумы КАК ТаблицаПределовДляНалоговыхБазМаксимумы 
		|		ПО ТаблицаПределовДляНалоговыхБаз.НалоговыйПериод = ТаблицаПределовДляНалоговыхБазМаксимумы.НалоговыйПериод
        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыПоГодам КАК ПериодыПоГодам 
		|		ПО ИСТИНА
        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТРазмерыМРППоПериодам КАК РазмерыМРППоПериодам 
		|		ПО РазмерыМРППоПериодам.МесяцНалоговогоПериода = ПериодыПоГодам.НачалоНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	1 КАК Приоритет,
		|	МАКСИМУМ(ЕСТЬNULL(СведенияОСтавкахИПН.Период, ДАТАВРЕМЯ(1, 1, 1))) КАК ПериодСтавки,
		|	ПериодыРасчета.Период КАК МесяцНалоговогоПериода,
		|	СведенияОСтавкахИПН.Организация КАК Организация,
		|	СведенияОСтавкахИПН.ВидДохода КАК ВидДохода
		|ПОМЕСТИТЬ ВТПериодыСтавокИПН
		|ИЗ
		|	ВТДатыПоМесяцам КАК ПериодыРасчета
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОСтавкахИПН КАК СведенияОСтавкахИПН
		|		ПО ПериодыРасчета.Период >= СведенияОСтавкахИПН.Период
		|ГДЕ
		|	СведенияОСтавкахИПН.Организация = &Организация
		|
		|СГРУППИРОВАТЬ ПО
		|	ПериодыРасчета.Период,
		|	СведенияОСтавкахИПН.Организация,
		|	СведенияОСтавкахИПН.ВидДохода
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	2,
		|	МАКСИМУМ(ЕСТЬNULL(СведенияОСтавкахИПН.Период, ДАТАВРЕМЯ(1, 1, 1))),
		|	ПериодыРасчета.Период,
		|	ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка),
		|	СведенияОСтавкахИПН.ВидДохода
		|ИЗ
		|	ВТДатыПоМесяцам КАК ПериодыРасчета
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОСтавкахИПН КАК СведенияОСтавкахИПН
		|		ПО ПериодыРасчета.Период >= СведенияОСтавкахИПН.Период
		|ГДЕ
		|	СведенияОСтавкахИПН.Организация = ЗНАЧЕНИЕ(Справочник.Организации.ПустаяСсылка)
		|
		|СГРУППИРОВАТЬ ПО
		|	ПериодыРасчета.Период,
		|	СведенияОСтавкахИПН.ВидДохода
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ПериодСтавки,
		|	Организация,
		|	ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПериодыСтавокИПН.Приоритет КАК Приоритет,
		|	ПериодыСтавокИПН.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ПериодыСтавокИПН.ПериодСтавки КАК ПериодСтавки,
		|	ПериодыСтавокИПН.ВидДохода КАК ВидДохода,
		|	ЕСТЬNULL(СведенияОСтавкахИПН.Ставка, 0) / 100 КАК СтавкаРезиденты,
		|	ЕСТЬNULL(СведенияОСтавкахИПН.СтавкаНерезиденты, 0) / 100 КАК СтавкаНерезиденты,
		|	ЕСТЬNULL(СведенияОСтавкахИПН.СтавкаПревышения, 0) / 100 КАК СтавкаПревышенияРезиденты,
		|	ЕСТЬNULL(СведенияОСтавкахИПН.СтавкаПревышенияНерезиденты, 0) / 100 КАК СтавкаПревышенияНерезиденты
		|ПОМЕСТИТЬ ВТСтавкиИПНПоПриоритетам
		|ИЗ
		|	ВТПериодыСтавокИПН КАК ПериодыСтавокИПН
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СведенияОСтавкахИПН КАК СведенияОСтавкахИПН
		|		ПО ПериодыСтавокИПН.ПериодСтавки = СведенияОСтавкахИПН.Период
		|			И ПериодыСтавокИПН.Организация = СведенияОСтавкахИПН.Организация
		|			И ПериодыСтавокИПН.ВидДохода = СведенияОСтавкахИПН.ВидДохода
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	ПериодСтавки,
		|	ВидДохода,
		|	МесяцНалоговогоПериода,
		|	Приоритет
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТСтавкиПоПриоритетам.Приоритет КАК Приоритет,
		|	МаксимумСтавок.ПериодСтавки КАК ПериодСтавки,
		|	МаксимумСтавок.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	МаксимумСтавок.ВидДохода КАК ВидДохода
		|ПОМЕСТИТЬ ВТ_МаксимумыСтавокПоПериоду
		|ИЗ
		|	(ВЫБРАТЬ
		|		МАКСИМУМ(ПриоритетСтавок.ПериодСтавки) КАК ПериодСтавки,
		|		ПриоритетСтавок.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|		ПриоритетСтавок.ВидДохода КАК ВидДохода
		|	ИЗ
		|		ВТСтавкиИПНПоПриоритетам КАК ПриоритетСтавок
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ПриоритетСтавок.МесяцНалоговогоПериода,
		|		ПриоритетСтавок.ВидДохода) КАК МаксимумСтавок
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиИПНПоПриоритетам КАК ВТСтавкиПоПриоритетам
		|		ПО МаксимумСтавок.ПериодСтавки = ВТСтавкиПоПриоритетам.ПериодСтавки
		|			И МаксимумСтавок.МесяцНалоговогоПериода = ВТСтавкиПоПриоритетам.МесяцНалоговогоПериода
		|			И МаксимумСтавок.ВидДохода = ВТСтавкиПоПриоритетам.ВидДохода
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	МесяцНалоговогоПериода,
		|	ВидДохода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПриоритетСтавок.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ПриоритетСтавок.ВидДохода КАК ВидДохода,
		|	ВТСтавкиПоПриоритетам.СтавкаРезиденты КАК СтавкаРезиденты,
		|	ВТСтавкиПоПриоритетам.СтавкаНерезиденты КАК СтавкаНерезиденты,
		|	ВТСтавкиПоПриоритетам.СтавкаПревышенияРезиденты КАК СтавкаПревышенияРезиденты,
		|	ВТСтавкиПоПриоритетам.СтавкаПревышенияНерезиденты КАК СтавкаПревышенияНерезиденты,
        |	ЕСТЬNULL(ТаблицаПределовДляНалоговыхБаз.СуммаПределаСтавки, 0) КАК СуммаПределаСтавки,
        |	ЕСТЬNULL(ТаблицаПределовДляНалоговыхБаз.СуммаПределаСтавкиНерезидента, 0) КАК СуммаПределаСтавкиНерезидента
		|ПОМЕСТИТЬ ВТСтавкиИПН
		|ИЗ
		|	(ВЫБРАТЬ
		|		МИНИМУМ(ПриоритетСтавок.Приоритет) КАК Приоритет,
		|		ПриоритетСтавок.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|		ПриоритетСтавок.ВидДохода КАК ВидДохода
		|	ИЗ
		|		ВТ_МаксимумыСтавокПоПериоду КАК ПриоритетСтавок
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ПриоритетСтавок.МесяцНалоговогоПериода,
		|		ПриоритетСтавок.ВидДохода) КАК ПриоритетСтавок
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТСтавкиИПНПоПриоритетам КАК ВТСтавкиПоПриоритетам
		|		ПО ПриоритетСтавок.Приоритет = ВТСтавкиПоПриоритетам.Приоритет
		|			И ПриоритетСтавок.МесяцНалоговогоПериода = ВТСтавкиПоПриоритетам.МесяцНалоговогоПериода
		|			И ПриоритетСтавок.ВидДохода = ВТСтавкиПоПриоритетам.ВидДохода
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТТаблицаПределовДляНалоговыхБаз КАК ТаблицаПределовДляНалоговыхБаз
		|		ПО ПриоритетСтавок.ВидДохода = ТаблицаПределовДляНалоговыхБаз.ВидДохода";
		
	Запрос.Выполнить();
	
	УничтожитьВТ.Добавить("ВТПериодыСтавокИПН");
	УничтожитьВТ.Добавить("ВТСтавкиИПНПоПриоритетам");
	УничтожитьВТ.Добавить("ВТ_МаксимумыСтавокПоПериоду");
    УничтожитьВТ.Добавить("ВТТаблицаПределовДляНалоговыхБазВрем");
    УничтожитьВТ.Добавить("ВТТаблицаПределовДляНалоговыхБазМаксимумы");
	УничтожитьВТ.Добавить("ВТТаблицаПределовДляНалоговыхБаз");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);

КонецПроцедуры

Процедура СоздатьВТСтатусыФизическихЛицКакНалогоплательщиков(МенеджерВременныхТаблиц, ЭтоПрочиеДоходы = Ложь) Экспорт
	
	Если МенеджерВременныхТаблиц.Таблицы.Найти("ВТСтатусыФизическихЛицКакНалогоплательщиков") = Неопределено Тогда
		
		УничтожитьВТ = Новый Массив;
		
		Запрос = Новый Запрос;
		Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
		
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	МАКСИМУМ(СтатусФизическихЛицКакНалогоплательщиков.Период) КАК ПериодСтатуса,
			|	СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо,
			|	ПериодыРасчета.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода
			|ПОМЕСТИТЬ ВТПериодыСтатусов
			|ИЗ
			|	ВТПериодыПоФизлицам КАК ПериодыРасчета
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусФизическихЛицКакНалогоплательщиков КАК СтатусФизическихЛицКакНалогоплательщиков
			|		ПО ПериодыРасчета.МесяцНалоговогоПериода >= СтатусФизическихЛицКакНалогоплательщиков.Период
			|			И ПериодыРасчета.ФизическоеЛицо = СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо
			|
			|СГРУППИРОВАТЬ ПО
			|	СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо,
			|	ПериодыРасчета.МесяцНалоговогоПериода
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	ПериодыСтатусов.МесяцНалоговогоПериода,
			|	ПериодыСтатусов.ФизическоеЛицо,
			|	СтатусФизическихЛицКакНалогоплательщиков.Статус
			|ПОМЕСТИТЬ ВТСтатусыФизическихЛицКакНалогоплательщиков
			|ИЗ
			|	ВТПериодыСтатусов КАК ПериодыСтатусов
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусФизическихЛицКакНалогоплательщиков КАК СтатусФизическихЛицКакНалогоплательщиков
			|		ПО ПериодыСтатусов.ПериодСтатуса = СтатусФизическихЛицКакНалогоплательщиков.Период
			|			И ПериодыСтатусов.ФизическоеЛицо = СтатусФизическихЛицКакНалогоплательщиков.ФизическоеЛицо
			|
			|ИНДЕКСИРОВАТЬ ПО
			|	ПериодыСтатусов.ФизическоеЛицо,
			|	ПериодыСтатусов.МесяцНалоговогоПериода
			|";
		
		Если ЭтоПрочиеДоходы Тогда
			Запрос.Текст = СтрЗаменить(Запрос.Текст,"ВТПериодыПоФизлицам", "ВТРегистрНакопления_СведенияОДоходахФизическихЛиц");
			Запрос.Текст = СтрЗаменить(Запрос.Текст,"ПериодыРасчета.МесяцНалоговогоПериода", "ПериодыРасчета.ПериодРегистрации");
		КонецЕсли;
		
		Запрос.Выполнить();
		
		УничтожитьВТ.Добавить("ВТПериодыСтатусов");
		ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);
	
	КонецЕсли;

КонецПроцедуры

