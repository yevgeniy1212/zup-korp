Функция РассчитатьНеоблагаемыеДоходы(Организация, Регистратор, МенеджерВременныхТаблиц, МесяцНачисления, ОкончательныйРасчет) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ПериодРегистрации", НачалоМесяца(МесяцНачисления));
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ИсключаемыйРегистратор", Регистратор);
	Запрос.УстановитьПараметр("ОкончательныйРасчет", ОкончательныйРасчет);
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;

	Если МесяцНачисления > Дата('20230101') Тогда
		СоздатьВТИсключаемыеЛицаНеоблагаемыеДоходы(МенеджерВременныхТаблиц, МесяцНачисления);
	Иначе
		Запрос.Текст = "ВЫБРАТЬ
		               |	NULL КАК ФизическоеЛицо,
		               |	NULL КАК МесяцНалоговогоПериода,
		               |	NULL КАК ВидДохода
		               |ПОМЕСТИТЬ ВТИсключаемыеФизическиеЛицаПриРасчетеНО";
		Запрос.Выполнить();
	КонецЕсли;
	УничтожитьВТ.Добавить("ВТИсключаемыеФизическиеЛицаПриРасчетеНО");
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(СведенияОНеоблагаемыхДоходах.Период, МЕСЯЦ) КАК МесяцНалоговогоПериода,
		|	СведенияОНеоблагаемыхДоходах.ПериодРегистрации,
		|	СведенияОНеоблагаемыхДоходах.Подразделение,
		|	СведенияОНеоблагаемыхДоходах.ФизическоеЛицо,
		|	СведенияОНеоблагаемыхДоходах.Начисление,
		|	СведенияОНеоблагаемыхДоходах.ВидНалогаВзносаОтчисления,
