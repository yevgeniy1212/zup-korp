		|	НастройкиИРазмерыВычетов.СуммовойПределВычета";
		
	Запрос.Выполнить();
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УничтожитьВТ);

КонецПроцедуры

Процедура СоздатьВТДанныеДляРасчетаВычетовИПНДо2018(МенеджерВременныхТаблиц, Организация, ПредоставлятьВычетВМесяцеОтсутствияДохода = Ложь, МесяцНачисления) Экспорт
	
	УничтожитьВТ = Новый Массив;
	
	// если применяется корректировка прочих доходов, то расчет ВОСМС происходит позже расчета ИПН
	ПрименятьКорректировкуПрочихНалоговВзносовОтчислений = ЗарплатаКадрыРКПовтИсп.ПрименятьКорректировкуПрочихНалоговВзносовОтчислений(ЗарплатаКадрыПовтИсп.ГоловнаяОрганизация(Организация), МесяцНачисления);
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("Организация", Организация);
	
	ПрименятьВычетВОСМСДляФизическихЛиц = ЗарплатаКадрыРКПовтИсп.ПрименятьВычетВОСМСДляФизическихЛицИГПХ(Организация, МесяцНачисления);
	ПрименятьВычетОПВиВОСМСГПХ = ЗарплатаКадрыРКПовтИсп.ПрименятьВычетВОСМСДляФизическихЛицИГПХ(Организация, МесяцНачисления);
	
	Если НЕ ВТСуществует(МенеджерВременныхТаблиц, "ВТИсчисленныеОПВ") Тогда
		Запрос.Текст =
			"ВЫБРАТЬ
			|	NULL КАК МесяцНалоговогоПериода,
			|	NULL КАК ФизическоеЛицо,
			|	NULL КАК ВидДохода,
			|	0 КАК ИсчисленныеОПВ
			|ПОМЕСТИТЬ ВТИсчисленныеОПВ";
		Запрос.Выполнить();
	КонецЕсли;
	
	Если НЕ ВТСуществует(МенеджерВременныхТаблиц, "ВТИсчисленныеВОСМС")
		И НЕ ПрименятьКорректировкуПрочихНалоговВзносовОтчислений Тогда
		Запрос.Текст =
			"ВЫБРАТЬ
			|	NULL КАК МесяцНалоговогоПериода,
			|	NULL КАК ФизическоеЛицо,
			|	NULL КАК ВидДохода,
			|	0 КАК ИсчисленныеВОСМС
			|ПОМЕСТИТЬ ВТИсчисленныеВОСМС";
		Запрос.Выполнить();
	КонецЕсли;
	
	// Применение вычетов ИПН
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(ПрименениеВычетовИПН.Период) КАК Период,
		|	ПрименениеВычетовИПН.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода
		|ПОМЕСТИТЬ ВТПериодыПримененияВычетов
		|ИЗ
		|	ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПрименениеВычетовИПН КАК ПрименениеВычетовИПН
		|		ПО ПериодыПоФизлицам.МесяцНалоговогоПериода >= ПрименениеВычетовИПН.Период
		|			И ПериодыПоФизлицам.ФизическоеЛицо = ПрименениеВычетовИПН.ФизическоеЛицо
		|			И (ПрименениеВычетовИПН.Активность)
		|
		|СГРУППИРОВАТЬ ПО
		|	ПрименениеВычетовИПН.ФизическоеЛицо,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТПериодыПримененияВычетов.ФизическоеЛицо,
		|	ВТПериодыПримененияВычетов.МесяцНалоговогоПериода,
		|	ПрименениеВычетовИПН.Организация
		|ПОМЕСТИТЬ ВТПрименениеВычетовИПН
		|ИЗ
		|	ВТПериодыПримененияВычетов КАК ВТПериодыПримененияВычетов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПрименениеВычетовИПН КАК ПрименениеВычетовИПН
		|		ПО ВТПериодыПримененияВычетов.Период = ПрименениеВычетовИПН.Период
		|			И ВТПериодыПримененияВычетов.ФизическоеЛицо = ПрименениеВычетовИПН.ФизическоеЛицо
		|			И (ПрименениеВычетовИПН.Активность)
		|ГДЕ
		|	ПрименениеВычетовИПН.Организация = &Организация";
	
	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"ВТПериодыПоФизлицам КАК ПериодыПоФизлицам","ВТПериодыПоФизлицамОбъединенная КАК ПериодыПоФизлицам");
	КонецЕсли;
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТПериодыПримененияВычетов");
	УничтожитьВТ.Добавить("ВТПрименениеВычетовИПН");
	
	// Назначенные вычеты ИПН
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(ВычетыФизическихЛицИПН.Период) КАК Период,
		|	ВычетыФизическихЛицИПН.ФизическоеЛицо,
		|	ВычетыФизическихЛицИПН.ВидВычета,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода
		|ПОМЕСТИТЬ ВТПериодыВычетовИПН
		|ИЗ
		|	ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ВычетыФизическихЛицИПН КАК ВычетыФизическихЛицИПН
		|		ПО ПериодыПоФизлицам.МесяцНалоговогоПериода >= ВычетыФизическихЛицИПН.Период
		|			И ПериодыПоФизлицам.ФизическоеЛицо = ВычетыФизическихЛицИПН.ФизическоеЛицо
		|			И (ВычетыФизическихЛицИПН.Активность)
		|ГДЕ
		|	ВычетыФизическихЛицИПН.ВидВычета <> ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ВычетОПВ)
		|	И ВычетыФизическихЛицИПН.ВидВычета <> ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ВычетВОСМС)
		|
		|СГРУППИРОВАТЬ ПО
		|	ВычетыФизическихЛицИПН.ФизическоеЛицо,
		|	ВычетыФизическихЛицИПН.ВидВычета,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТПериодыВычетовИПН.МесяцНалоговогоПериода,
		|	ВТПериодыВычетовИПН.ФизическоеЛицо,
		|	ВТПериодыВычетовИПН.ВидВычета,
		|	ВычетыФизическихЛицИПН.ПредоставлятьВычет,
		|	ВычетыФизическихЛицИПН.ДействуетПо
		|ПОМЕСТИТЬ ВТВычетыФизическихЛицИПН
		|ИЗ
		|	ВТПериодыВычетовИПН КАК ВТПериодыВычетовИПН
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ВычетыФизическихЛицИПН КАК ВычетыФизическихЛицИПН
		|		ПО ВТПериодыВычетовИПН.Период = ВычетыФизическихЛицИПН.Период
		|			И ВТПериодыВычетовИПН.ФизическоеЛицо = ВычетыФизическихЛицИПН.ФизическоеЛицо
		|			И ВТПериодыВычетовИПН.ВидВычета = ВычетыФизическихЛицИПН.ВидВычета
		|			И (ВычетыФизическихЛицИПН.Активность)
		|ГДЕ
		|	ВычетыФизическихЛицИПН.ПредоставлятьВычет
		|	И ВЫБОР
		|			КОГДА ВычетыФизическихЛицИПН.ДействуетПо = ДАТАВРЕМЯ(1, 1, 1)
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ НАЧАЛОПЕРИОДА(ВТПериодыВычетовИПН.МесяцНалоговогоПериода, МЕСЯЦ) <= НАЧАЛОПЕРИОДА(ВычетыФизическихЛицИПН.ДействуетПо, МЕСЯЦ)
		|		КОНЕЦ";
	
	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"ВТПериодыПоФизлицам КАК ПериодыПоФизлицам","ВТПериодыПоФизлицамОбъединенная КАК ПериодыПоФизлицам");
	КонецЕсли;
	
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТПериодыВычетовИПН");
	УничтожитьВТ.Добавить("ВТВычетыФизическихЛицИПН");
	
	// Прочие вычеты физических лиц
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(ПрочиеВычетыФизическихЛицИПН.Период) КАК Период,
		|	ПрочиеВычетыФизическихЛицИПН.ФизическоеЛицо,
		|	ПрочиеВычетыФизическихЛицИПН.ВидВычета,
		|	ПрочиеВычетыФизическихЛицИПН.ДействуетС,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода
		|ПОМЕСТИТЬ ВТПериодыПрочихВычетовИПН
		|ИЗ
		|	ВТПериодыПоФизлицам КАК ПериодыПоФизлицам
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПрочиеВычетыФизическихЛицИПН КАК ПрочиеВычетыФизическихЛицИПН
		|		ПО ПериодыПоФизлицам.МесяцНалоговогоПериода >= ПрочиеВычетыФизическихЛицИПН.Период
		|			И ПериодыПоФизлицам.ФизическоеЛицо = ПрочиеВычетыФизическихЛицИПН.ФизическоеЛицо
		|			И (ПрочиеВычетыФизическихЛицИПН.Активность)
		|
		|СГРУППИРОВАТЬ ПО
		|	ПрочиеВычетыФизическихЛицИПН.ФизическоеЛицо,
		|	ПрочиеВычетыФизическихЛицИПН.ВидВычета,
		|	ПрочиеВычетыФизическихЛицИПН.ДействуетС,
		|	ПериодыПоФизлицам.МесяцНалоговогоПериода
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТПериодыПрочихВычетовИПН.МесяцНалоговогоПериода,
		|	ВТПериодыПрочихВычетовИПН.ФизическоеЛицо,
		|	ВТПериодыПрочихВычетовИПН.ВидВычета,
		|	ВТПериодыПрочихВычетовИПН.ДействуетС,
		|	ПрочиеВычетыФизическихЛицИПН.Размер,
		|	ПрочиеВычетыФизическихЛицИПН.ДействуетПо
		|ПОМЕСТИТЬ ВТПрочиеВычетыФизическихЛицИПН
		|ИЗ
		|	ВТПериодыПрочихВычетовИПН КАК ВТПериодыПрочихВычетовИПН
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПрочиеВычетыФизическихЛицИПН КАК ПрочиеВычетыФизическихЛицИПН
		|		ПО ВТПериодыПрочихВычетовИПН.Период = ПрочиеВычетыФизическихЛицИПН.Период
		|			И ВТПериодыПрочихВычетовИПН.ФизическоеЛицо = ПрочиеВычетыФизическихЛицИПН.ФизическоеЛицо
		|			И ВТПериодыПрочихВычетовИПН.ВидВычета = ПрочиеВычетыФизическихЛицИПН.ВидВычета
		|			И ВТПериодыПрочихВычетовИПН.ДействуетС = ПрочиеВычетыФизическихЛицИПН.ДействуетС
		|			И (ПрочиеВычетыФизическихЛицИПН.Активность)
		|ГДЕ
		|	ВТПериодыПрочихВычетовИПН.МесяцНалоговогоПериода МЕЖДУ ПрочиеВычетыФизическихЛицИПН.ДействуетС И ПрочиеВычетыФизическихЛицИПН.ДействуетПо
		|	И ПрочиеВычетыФизическихЛицИПН.Размер <> 0";
	
	Если ПредоставлятьВычетВМесяцеОтсутствияДохода Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст,"ВТПериодыПоФизлицам КАК ПериодыПоФизлицам","ВТПериодыПоФизлицамОбъединенная КАК ПериодыПоФизлицам");
	КонецЕсли;
	
	Запрос.Выполнить();	
	УничтожитьВТ.Добавить("ВТПериодыПрочихВычетовИПН");
	УничтожитьВТ.Добавить("ВТПрочиеВычетыФизическихЛицИПН");
	
	// Размеры взносов
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДанныеОПВ.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ОПВ) КАК ВидВзносов,
		|	ДанныеОПВ.ФизическоеЛицо,
		|	ДанныеОПВ.ВидДохода,
		|	ДанныеОПВ.ИсчисленныеОПВ КАК СуммаВзносов
		|ПОМЕСТИТЬ ВТРазмерыВзносов
		|ИЗ
		|	ВТИсчисленныеОПВ КАК ДанныеОПВ
		|" + ?(НЕ ПрименятьКорректировкуПрочихНалоговВзносовОтчислений, "
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ДанныеВОСМС.МесяцНалоговогоПериода,
		|	ЗНАЧЕНИЕ(Перечисление.ВидыНалоговВзносовОтчислений.ВОСМС),
		|	ДанныеВОСМС.ФизическоеЛицо,
		|	ДанныеВОСМС.ВидДохода,
		|	ДанныеВОСМС.ИсчисленныеВОСМС
		|ИЗ
		|	ВТИсчисленныеВОСМС КАК ДанныеВОСМС", "");
		
	Запрос.Выполнить();
	УничтожитьВТ.Добавить("ВТРазмерыВзносов");
	
	// Размеры пределов
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПериодыПределов.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ПериодыПределов.ВидВычета КАК ВидВычета,
		|	РазмерыВычетовИПН.ВидПределаВычета КАК ВидПределаВычета,
		|	РазмерыВычетовИПН.Размер КАК Размер
		|ПОМЕСТИТЬ ВТРазмерыПределовПосле2018
		|ИЗ
		|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
		|		ПериодыВычетовИПН.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|		ПериодыВычетовИПН.ВидВычета КАК ВидВычета,
		|		МАКСИМУМ(РазмерыВычетовИПН.Период) КАК Период
		|	ИЗ
		|		ВТПериодыВычетовИПН КАК ПериодыВычетовИПН
		|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РазмерыВычетовИПН КАК РазмерыВычетовИПН
		|			ПО (РазмерыВычетовИПН.ВидВычетаИПН = ПериодыВычетовИПН.ВидВычета)
		|				И (РазмерыВычетовИПН.Период <= НАЧАЛОПЕРИОДА(ПериодыВычетовИПН.МесяцНалоговогоПериода, ГОД))
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ПериодыВычетовИПН.МесяцНалоговогоПериода,
		|		ПериодыВычетовИПН.ВидВычета) КАК ПериодыПределов
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РазмерыВычетовИПН КАК РазмерыВычетовИПН
		|		ПО ПериодыПределов.Период = РазмерыВычетовИПН.Период
		|			И ПериодыПределов.ВидВычета = РазмерыВычетовИПН.ВидВычетаИПН";
		
	Запрос.Выполнить();
	
	// Настройки вычетов по видам дохода
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПериодыПределов.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
		|	ПериодыПределов.ВидВычета КАК ВидВычета,
		|	ПрименениеВычетовПоВидамДохода.ВидДохода КАК ВидДохода
		|ПОМЕСТИТЬ ВТНастройкиВычетовПоВидамДохода
		|ИЗ
		|	(ВЫБРАТЬ РАЗЛИЧНЫЕ
		|		ДатыПоМесяцам.Период КАК МесяцНалоговогоПериода,
		|		ПрименениеВычетовПоВидамДохода.ВидВычетаИПН КАК ВидВычета,
		|		МАКСИМУМ(ПрименениеВычетовПоВидамДохода.Период) КАК Период
		|	ИЗ
		|		ВТДатыПоМесяцам КАК ДатыПоМесяцам
		|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПрименениеВычетовПоВидамДохода КАК ПрименениеВычетовПоВидамДохода
