Процедура ЗаполнитьПериодВзаиморасчетовВедомостейПрочихДоходовНаВыплатуЗарплаты(МетаданныеВедомости, ПараметрыОбновления) 
	
 	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Ложь);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ 
    |	ВедомостьВыплаты.Ссылка КАК Ссылка
    |ПОМЕСТИТЬ ВТ_Ведомости
    |ИЗ
    |	#ВедомостьВыплаты КАК ВедомостьВыплаты 
    |ГДЕ
    |   ВедомостьВыплаты.ПериодВзаиморасчетов = ДАТАВРЕМЯ(1, 1, 1)
    |СГРУППИРОВАТЬ ПО
    |	ВедомостьВыплаты.Ссылка
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ РАЗЛИЧНЫЕ 
    |	ВедомостьВыплаты.Ссылка КАК Ссылка,
    |	ВедомостьВыплаты.ДокументОснование КАК ДокументОснование
    |ПОМЕСТИТЬ ВТ_ДокументыОснованияВедомости
    |ИЗ
    |	#ВедомостьВыплаты КАК ВедомостьВыплаты
    |   ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Ведомости КАК ВТ_Ведомости
    |       ПО ВТ_Ведомости.Ссылка = ВедомостьВыплаты.Ссылка
    |СГРУППИРОВАТЬ ПО   
    |	ВедомостьВыплаты.Ссылка,
    |	ВедомостьВыплаты.ДокументОснование
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |УНИЧТОЖИТЬ ВТ_Ведомости
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ РАЗЛИЧНЫЕ
    |	ВТ_ДокументыОснованияВедомости.ДокументОснование КАК ДокументОснование,
    |	ВыплатаБывшимСотрудникам.ПериодРегистрации КАК ПериодВзаиморасчетов
    |ПОМЕСТИТЬ ВТ_ПериодыВзаиморасчетов
    |ИЗ
    |	ВТ_ДокументыОснованияВедомости КАК ВТ_ДокументыОснованияВедомости
    |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВыплатаБывшимСотрудникам КАК ВыплатаБывшимСотрудникам
    |		ПО (ВыплатаБывшимСотрудникам.Ссылка = ВТ_ДокументыОснованияВедомости.ДокументОснование)
    |
    |ОБЪЕДИНИТЬ ВСЕ
    |
    |ВЫБРАТЬ РАЗЛИЧНЫЕ
    |	ВТ_ДокументыОснованияВедомости.ДокументОснование,
    |	РегистрацияПрочихДоходов.ПериодРегистрации
    |ИЗ
    |	ВТ_ДокументыОснованияВедомости КАК ВТ_ДокументыОснованияВедомости
    |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РегистрацияПрочихДоходов КАК РегистрацияПрочихДоходов
    |		ПО (РегистрацияПрочихДоходов.Ссылка = ВТ_ДокументыОснованияВедомости.ДокументОснование)
    |
    |ОБЪЕДИНИТЬ ВСЕ
    |
    |ВЫБРАТЬ РАЗЛИЧНЫЕ
    |	ВТ_ДокументыОснованияВедомости.ДокументОснование,
    |	НачислениеЗарплаты.МесяцНачисления
    |ИЗ
    |	ВТ_ДокументыОснованияВедомости КАК ВТ_ДокументыОснованияВедомости
    |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.НачислениеЗарплаты КАК НачислениеЗарплаты
    |		ПО (НачислениеЗарплаты.Ссылка = ВТ_ДокументыОснованияВедомости.ДокументОснование)
    |
    |ОБЪЕДИНИТЬ ВСЕ
    |
    |ВЫБРАТЬ РАЗЛИЧНЫЕ
    |	ВТ_ДокументыОснованияВедомости.ДокументОснование,
    |	НачислениеПоДоговорам.МесяцНачисления
    |ИЗ
    |	ВТ_ДокументыОснованияВедомости КАК ВТ_ДокументыОснованияВедомости
    |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.НачислениеПоДоговорам КАК НачислениеПоДоговорам
    |		ПО (НачислениеПоДоговорам.Ссылка = ВТ_ДокументыОснованияВедомости.ДокументОснование)
    |
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ РАЗЛИЧНЫЕ
    |	ВедомостьВыплаты.Ссылка КАК Ссылка,
    |	ВедомостьВыплаты.ДокументОснование КАК ДокументОснование,
    |	ЕСТЬNULL(ВТ_ПериодыВзаиморасчетов.ПериодВзаиморасчетов, ВедомостьВыплаты.Ссылка.ПериодРегистрации) КАК ПериодВзаиморасчетов
    |ИЗ
    |	ВТ_ДокументыОснованияВедомости КАК ВТ_ДокументыОснованияВедомости
    |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ #ВедомостьВыплаты КАК ВедомостьВыплаты
    |		ПО (ВедомостьВыплаты.Ссылка = ВТ_ДокументыОснованияВедомости.Ссылка)
    |			И (ВедомостьВыплаты.ДокументОснование = ВТ_ДокументыОснованияВедомости.ДокументОснование)
    |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПериодыВзаиморасчетов КАК ВТ_ПериодыВзаиморасчетов
    |		ПО (ВедомостьВыплаты.ДокументОснование = ВТ_ПериодыВзаиморасчетов.ДокументОснование)
    |ИТОГИ ПО
    |	Ссылка"; 
    
	Если ЗарплатаКадрыРКПовтИсп.ЭтоКонфигурацияЗарплатногоУчета() Тогда
		
		ТекстЗапросаДивиденды = "    
        |		ПО (НачислениеПоДоговорам.Ссылка = ВТ_ДокументыОснованияВедомости.ДокументОснование)
        |
        |ОБЪЕДИНИТЬ ВСЕ
        |
        |ВЫБРАТЬ РАЗЛИЧНЫЕ
        |	ВТ_ДокументыОснованияВедомости.ДокументОснование,
        |	ДивидендыФизическимЛицам.ПериодРегистрации
        |ИЗ
        |	ВТ_ДокументыОснованияВедомости КАК ВТ_ДокументыОснованияВедомости
        |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ #Дивиденды КАК ДивидендыФизическимЛицам
        |		ПО (ДивидендыФизическимЛицам.Ссылка = ВТ_ДокументыОснованияВедомости.ДокументОснование)
        |";	
        ТекстЗапросаДивиденды = СтрЗаменить(ТекстЗапросаДивиденды, "#Дивиденды",	"Документ.ДивидендыФизическимЛицам"); 
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПО (НачислениеПоДоговорам.Ссылка = ВТ_ДокументыОснованияВедомости.ДокументОснование)",	ТекстЗапросаДивиденды); 
		
	КонецЕсли;
    
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "#ВедомостьВыплаты",	МетаданныеВедомости.ПолноеИмя() + ".Выплаты"); 

	Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока Выборка.Следующий() Цикл
		
		Если Не ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ПодготовитьОбновлениеДанных(ПараметрыОбновления, МетаданныеВедомости.ПолноеИмя(), "Ссылка", Выборка.Ссылка) Тогда
			Продолжить;
		КонецЕсли;
		
        Ведомость = Выборка.Ссылка.ПолучитьОбъект();
        
        СоответствиеПериодов = Новый Соответствие;
        ПериодВзаиморасчетов = Дата('00010101');
        ВыборкаПоВыплатам = Выборка.Выбрать();
        Пока ВыборкаПоВыплатам.Следующий() Цикл
            Если ЗначениеЗаполнено(ВыборкаПоВыплатам.ДокументОснование) Тогда
                СоответствиеПериодов.Вставить(ВыборкаПоВыплатам.ДокументОснование, ВыборкаПоВыплатам.ПериодВзаиморасчетов);
            Иначе
                ПериодВзаиморасчетов = ВыборкаПоВыплатам.ПериодВзаиморасчетов;
            КонецЕсли;
        КонецЦикла;
        
        // Обход строк табличной части документа
        Для Каждого СтрокаТЧ Из Ведомость.Выплаты Цикл
            Если Не ЗначениеЗаполнено(СтрокаТЧ.ПериодВзаиморасчетов) Тогда
                Если СоответствиеПериодов.Получить(СтрокаТЧ.ДокументОснование) <> Неопределено Тогда
                    СтрокаТЧ.ПериодВзаиморасчетов = СоответствиеПериодов[СтрокаТЧ.ДокументОснование];
                Иначе
                    СтрокаТЧ.ПериодВзаиморасчетов = ПериодВзаиморасчетов;
                КонецЕсли;
            КонецЕсли;
        КонецЦикла;

        ОбновлениеИнформационнойБазы.ЗаписатьОбъект(Ведомость,,, РежимЗаписиДокумента.Запись);
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
		
	КонецЦикла;
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
    
КонецПроцедуры	

Процедура УдалитьЗаписиНеиспользуемыхКлассификаторов(ПараметрыОбновления = Неопределено) Экспорт

	НачатьТранзакцию();
	
