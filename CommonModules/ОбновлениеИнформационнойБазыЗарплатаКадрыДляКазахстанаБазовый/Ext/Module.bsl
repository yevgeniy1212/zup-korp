			НСтр("ru = 'Не удалось обновить ""Регистр сведений  ""Расчет среднего заработка организаций"""".'"), 
			УровеньЖурналаРегистрации.Ошибка, , , Комментарий);					
			
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьДанныеИсполнительныхЛистовПрожиточныеМинимумы(ПараметрыОбновления = Неопределено) Экспорт

	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Ложь);
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ИсполнительныйЛист.Ссылка КАК Регистратор,
		|	ИсполнительныйЛист.Ссылка КАК ИсполнительныйДокумент,
		|	&ПрожиточныйМинимум КАК ПрожиточныйМинимум,
		|	1 КАК КоличествоПрожиточныхМинимумов,
		|	ИсполнительныйЛист.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ИсполнительныйЛист.Организация КАК Организация,
		|	ИсполнительныйЛист.ДатаДействия КАК Период,
		|	ИсполнительныйЛист.Проведен КАК Проведен,
		|	""Документ.ИсполнительныйЛист"" КАК ИмяТаблицы
		|ИЗ
		|	Документ.ИсполнительныйЛист КАК ИсполнительныйЛист
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ИсполнительныйЛист.СохраняемыйЗаработок КАК ИсполнительныйЛистСохраняемыйЗаработок
		|		ПО (ИсполнительныйЛистСохраняемыйЗаработок.Ссылка = ИсполнительныйЛист.Ссылка)
		|ГДЕ
		|	НЕ ИсполнительныйЛист.ОчередностьВзыскания = &ОчередностьБезУчетаПрожиточного
		|
		|СГРУППИРОВАТЬ ПО
		|	ИсполнительныйЛист.Ссылка,
		|	ИсполнительныйЛист.ФизическоеЛицо,
		|	ИсполнительныйЛист.Организация,
		|	ИсполнительныйЛист.Ссылка,
		|	ИсполнительныйЛист.ДатаДействия
		|
		|ИМЕЮЩИЕ
		|	КОЛИЧЕСТВО(ИсполнительныйЛистСохраняемыйЗаработок.Ссылка) = 0
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ИзменениеУсловийИсполнительногоЛиста.Ссылка,
		|	ИсполнительныйЛистДокумент.Ссылка,
		|	&ПрожиточныйМинимум КАК ПрожиточныйМинимум,
		|	1 КАК КоличествоПрожиточныхМинимумов,
		|	ИсполнительныйЛистДокумент.ФизическоеЛицо,
		|	ИзменениеУсловийИсполнительногоЛиста.Организация,
		|	ИзменениеУсловийИсполнительногоЛиста.ДатаИзменения,
		|	ИзменениеУсловийИсполнительногоЛиста.Проведен,
		|	""Документ.ИзменениеУсловийИсполнительногоЛиста""
		|ИЗ
		|	Документ.ИзменениеУсловийИсполнительногоЛиста КАК ИзменениеУсловийИсполнительногоЛиста
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ИсполнительныйЛист КАК ИсполнительныйЛистДокумент
		|		ПО ИзменениеУсловийИсполнительногоЛиста.ИсполнительныйЛист = ИсполнительныйЛистДокумент.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ИзменениеУсловийИсполнительногоЛиста.СохраняемыйЗаработок КАК ИзменениеУсловийИсполнительногоЛистаСохраняемыйЗаработок
		|		ПО (ИзменениеУсловийИсполнительногоЛистаСохраняемыйЗаработок.Ссылка = ИзменениеУсловийИсполнительногоЛиста.Ссылка)
		|ГДЕ
		|	НЕ ИсполнительныйЛистДокумент.ОчередностьВзыскания = &ОчередностьБезУчетаПрожиточного
		|
		|СГРУППИРОВАТЬ ПО
		|	ИзменениеУсловийИсполнительногоЛиста.Ссылка,
		|	ИсполнительныйЛистДокумент.Ссылка,
		|	ИсполнительныйЛистДокумент.ФизическоеЛицо,
		|	ИзменениеУсловийИсполнительногоЛиста.Организация,
		|	ИзменениеУсловийИсполнительногоЛиста.ДатаИзменения
		|
		|ИМЕЮЩИЕ
		|	КОЛИЧЕСТВО(ИзменениеУсловийИсполнительногоЛистаСохраняемыйЗаработок.Ссылка) = 0";
	
	Запрос.УстановитьПараметр("ОчередностьБезУчетаПрожиточного", Перечисления.ОчередностьВзысканияУдержаний.ПерваяОчередьПроцент70);
	Запрос.УстановитьПараметр("ПрожиточныйМинимум", Справочники.ПрожиточныеМинимумы.ПрожиточныйМинимум);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.Проведен Тогда
		
			Если Не ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ПодготовитьОбновлениеДанных(ПараметрыОбновления, "РегистрСведений.СохраняемыйЗаработокПриВзысканиях.НаборЗаписей", "Регистратор", Выборка.Регистратор) Тогда
				Продолжить;
			КонецЕсли;
			
			НаборЗаписей = РегистрыСведений.СохраняемыйЗаработокПриВзысканиях.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Регистратор.Установить(Выборка.Регистратор);
			СтрокаНабораЗаписей = НаборЗаписей.Добавить();
			
			ЗаполнитьЗначенияСвойств(СтрокаНабораЗаписей, Выборка);

			ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
			ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
			
		КонецЕсли;
		
		Если Не ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ПодготовитьОбновлениеДанных(ПараметрыОбновления, Выборка.ИмяТаблицы, "Ссылка", Выборка.Регистратор) Тогда
			Продолжить;
		КонецЕсли;

		ДокументОбъект = Выборка.Регистратор.ПолучитьОбъект();
		
		ДокументОбъект.СохранятьЗаработокСУчетомПрожиточногоМинимума = Истина;
		
		СтрокаПрожиточногоМинимума = ДокументОбъект.СохраняемыйЗаработок.Добавить();
		СтрокаПрожиточногоМинимума.ПрожиточныйМинимум = Справочники.ПрожиточныеМинимумы.ПрожиточныйМинимум;
		СтрокаПрожиточногоМинимума.КоличествоПрожиточныхМинимумов = 1;
		
		ОбновлениеИнформационнойБазы.ЗаписатьДанные(ДокументОбъект);
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ЗавершитьОбновлениеДанных(ПараметрыОбновления);

	КонецЦикла;
	
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ИсполнительныйЛист.Ссылка КАК Ссылка,
		|	""Документ.ИсполнительныйЛист"" КАК ИмяТаблицы
		|ИЗ
		|	Документ.ИсполнительныйЛист КАК ИсполнительныйЛист
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ИсполнительныйЛист.СохраняемыйЗаработок КАК ИсполнительныйЛистСохраняемыйЗаработок
		|		ПО (ИсполнительныйЛистСохраняемыйЗаработок.Ссылка = ИсполнительныйЛист.Ссылка)
		|ГДЕ
		|	ИсполнительныйЛист.ОчередностьВзыскания = &ОчередностьБезУчетаПрожиточного
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ИзменениеУсловийИсполнительногоЛиста.Ссылка,
		|	""Документ.ИзменениеУсловийИсполнительногоЛиста""
		|ИЗ
		|	Документ.ИзменениеУсловийИсполнительногоЛиста КАК ИзменениеУсловийИсполнительногоЛиста
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ИсполнительныйЛист КАК ИсполнительныйЛистДокумент
		|		ПО ИзменениеУсловийИсполнительногоЛиста.ИсполнительныйЛист = ИсполнительныйЛистДокумент.Ссылка
		|ГДЕ
		|	ИсполнительныйЛистДокумент.ОчередностьВзыскания = &ОчередностьБезУчетаПрожиточного";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если Не ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ПодготовитьОбновлениеДанных(ПараметрыОбновления, Выборка.ИмяТаблицы, "Ссылка", Выборка.Ссылка) Тогда
			Продолжить;
		КонецЕсли;
		
		ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();

		ДокументОбъект.ОчередностьВзыскания = Перечисления.ОчередностьВзысканияУдержаний.ПерваяОчередьПроцент50;
		
		ОбновлениеИнформационнойБазы.ЗаписатьДанные(ДокументОбъект);
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
		
	КонецЦикла;
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
	
КонецПроцедуры

