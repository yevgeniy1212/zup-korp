		УровеньЖурналаРегистрации.Ошибка, , , Комментарий);					

    КонецПопытки;
	
КонецПроцедуры

Процедура ЗаполнениеРегистраНалогиВзносыОтчисленияПоСотрудникамДанныеМежрасчетногоПериода(ПараметрыОбновления = Неопределено) Экспорт
	
    ТекстЗапроса = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 50
	|	НалогиВзносыОтчисленияПоСотрудникам.Регистратор КАК Регистратор
	|ПОМЕСТИТЬ ВТ_Регистраторы
	|ИЗ
	|	РегистрНакопления.НалогиВзносыОтчисленияПоСотрудникам КАК НалогиВзносыОтчисленияПоСотрудникам
	|ГДЕ
	|	ТИПЗНАЧЕНИЯ(НалогиВзносыОтчисленияПоСотрудникам.Регистратор) В (ТИП(Документ.НачислениеПоДоговорам),
	|			ТИП(Документ.ВыплатаБывшимСотрудникам),
	|			ТИП(Документ.РегистрацияПрочихДоходов))
	|	И НалогиВзносыОтчисленияПоСотрудникам.ДанныеМежрасчетногоПериода = ЛОЖЬ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Регистратор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НалогиВзносыОтчисленияПоСотрудникам.Период КАК Период,
	|	НалогиВзносыОтчисленияПоСотрудникам.Регистратор КАК Регистратор,
	|	НалогиВзносыОтчисленияПоСотрудникам.Начисление КАК Начисление
	|ПОМЕСТИТЬ ВТ_ДанныеМежрасчетногоПериода
	|ИЗ
	|	РегистрНакопления.НалогиВзносыОтчисленияПоСотрудникам КАК НалогиВзносыОтчисленияПоСотрудникам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Регистраторы КАК Регистраторы
	|		ПО НалогиВзносыОтчисленияПоСотрудникам.Регистратор = Регистраторы.Регистратор
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Период,
	|	Регистратор,
	|	Начисление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НалогиВзносыОтчисленияПоСотрудникам.Период КАК Период,
	|	НалогиВзносыОтчисленияПоСотрудникам.Регистратор КАК Регистратор,
	|	НалогиВзносыОтчисленияПоСотрудникам.НомерСтроки КАК НомерСтроки,
	|	НалогиВзносыОтчисленияПоСотрудникам.Активность КАК Активность,
	|	НалогиВзносыОтчисленияПоСотрудникам.Организация КАК Организация,
	|	НалогиВзносыОтчисленияПоСотрудникам.ФизическоеЛицо КАК ФизическоеЛицо,
	|	НалогиВзносыОтчисленияПоСотрудникам.Сотрудник КАК Сотрудник,
	|	НалогиВзносыОтчисленияПоСотрудникам.Подразделение КАК Подразделение,
	|	НалогиВзносыОтчисленияПоСотрудникам.Начисление КАК Начисление,
	|	НалогиВзносыОтчисленияПоСотрудникам.ВидДохода КАК ВидДохода,
	|	НалогиВзносыОтчисленияПоСотрудникам.СО КАК СО,
	|	НалогиВзносыОтчисленияПоСотрудникам.СН КАК СН,
	|	НалогиВзносыОтчисленияПоСотрудникам.ОППВ КАК ОППВ,
	|	НалогиВзносыОтчисленияПоСотрудникам.ООСМС КАК ООСМС,
	|	НалогиВзносыОтчисленияПоСотрудникам.ОПВР КАК ОПВР,
	|	НалогиВзносыОтчисленияПоСотрудникам.Сторно КАК Сторно,
	|	ИСТИНА КАК ДанныеМежрасчетногоПериода
	|ИЗ
	|	ВТ_ДанныеМежрасчетногоПериода КАК ВТ_ДанныеМежрасчетногоПериода
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.НалогиВзносыОтчисленияПоСотрудникам КАК НалогиВзносыОтчисленияПоСотрудникам
	|		ПО ВТ_ДанныеМежрасчетногоПериода.Период = НалогиВзносыОтчисленияПоСотрудникам.Период
	|			И ВТ_ДанныеМежрасчетногоПериода.Регистратор = НалогиВзносыОтчисленияПоСотрудникам.Регистратор
	|			И ВТ_ДанныеМежрасчетногоПериода.Начисление = НалогиВзносыОтчисленияПоСотрудникам.Начисление
	|
	|УПОРЯДОЧИТЬ ПО
	|	Регистратор,
	|	НомерСтроки";
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ОбработатьНаборыЗаписейРегистраНакопления("НалогиВзносыОтчисленияПоСотрудникам", ТекстЗапроса, , , ПараметрыОбновления);
	
КонецПроцедуры

Процедура ПеренестиПризнакВестиУчетРабочегоВремениПоУсловиямТруда() Экспорт
	
	НаборЗаписей = РегистрыСведений.НастройкиЗарплатаКадрыРасширенная.СоздатьНаборЗаписей();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	НастройкиЗарплатаКадрыРасширенная.Организация КАК Организация
		|ИЗ
		|	РегистрСведений.НастройкиЗарплатаКадрыРасширенная КАК НастройкиЗарплатаКадрыРасширенная
		|ГДЕ
		|	НастройкиЗарплатаКадрыРасширенная.ВестиУчетРабочегоВремениПоУсловиямТруда = ИСТИНА
		|	И НастройкиЗарплатаКадрыРасширенная.ИспользоватьОсобыеУсловияТруда = ЛОЖЬ";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		НаборЗаписей.Отбор.Организация.Установить(ВыборкаДетальныеЗаписи.Организация);
		НаборЗаписей.Прочитать();
		
		Если НаборЗаписей.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ЗаписьНабора = НаборЗаписей[0];
		ЗаписьНабора.ИспользоватьОсобыеУсловияТруда = Истина;
		
		Попытка
			
			НаборЗаписей.ОбменДанными.Загрузка = Истина;
			НаборЗаписей.Записать();
			
		Исключение
			
			ТекстСообщения = НСтр(
			"ru = 'при записи набора данных ""Настройки зарплата кадры (расширенный)"" произошла ошибка: 
			|%1");
			
			ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, ПодробноеПредставлениеОшибки);
			
			ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Не удалось обновить ""Регистр сведений  ""Настройки зарплата кадры (расширенный)"""".'"), 
			УровеньЖурналаРегистрации.Ошибка, , , Комментарий);
			
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура УдалитьВидыВремениПремийИНадбавкиЗаВредность(ПараметрыОбновления = Неопределено) Экспорт
	
	ВидВремениВыходныеРабочиеДни = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ВидыИспользованияРабочегоВремени.ВыходныеРабочиеДни");
	ВидВремениВыходныеРабочиеДниБезПовышеннойОплаты = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ВидыИспользованияРабочегоВремени.ВыходныеРабочиеДниБезПовышеннойОплаты");
	ВидВремениПраздники = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ВидыИспользованияРабочегоВремени.Праздники");
	ВидВремениПраздникиБезПовышеннойОплаты = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ВидыИспользованияРабочегоВремени.ПраздникиБезПовышеннойОплаты");
	ВидыВремени = Новый Массив;
	ВидыВремени.Добавить(ВидВремениВыходныеРабочиеДни);
	ВидыВремени.Добавить(ВидВремениВыходныеРабочиеДниБезПовышеннойОплаты);
	ВидыВремени.Добавить(ВидВремениПраздники);
	ВидыВремени.Добавить(ВидВремениПраздникиБезПовышеннойОплаты);
	
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Начисления.Ссылка КАК Ссылка
	|ИЗ
	|	ПланВидовРасчета.Начисления КАК Начисления
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПланВидовРасчета.Начисления.ВидыВремени КАК НачисленияВидыВремени
	|		ПО НачисленияВидыВремени.Ссылка = Начисления.Ссылка
	|			И НачисленияВидыВремени.ВидВремени В (&ВидыВремени)
	|ГДЕ
	|	(Начисления.КатегорияНачисленияИлиНеоплаченногоВремени = ЗНАЧЕНИЕ(Перечисление.КатегорииНачисленийИНеоплаченногоВремени.Премия)
	|		ИЛИ Начисления.КатегорияНачисленияИлиНеоплаченногоВремени = ЗНАЧЕНИЕ(Перечисление.КатегорииНачисленийИНеоплаченногоВремени.КвартальнаяПремия)
	|		ИЛИ Начисления.КатегорияНачисленияИлиНеоплаченногоВремени = ЗНАЧЕНИЕ(Перечисление.КатегорииНачисленийИНеоплаченногоВремени.НадбавкаЗаВредность))
	|	И НЕ НачисленияВидыВремени.Ссылка ЕСТЬ NULL";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("ВидыВремени", ВидыВремени);
	РезультатЗапроса = Запрос.Выполнить();
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Ложь);
	Если РезультатЗапроса.Пустой() Тогда
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
		Возврат;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если Не ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ПодготовитьОбновлениеДанных(ПараметрыОбновления, "ПланВидовРасчета.Начисления", "Ссылка", Выборка.Ссылка) Тогда
			Продолжить;
		КонецЕсли;
		
		НачислениеОбъект = Выборка.Ссылка.ПолучитьОбъект();
		Для Каждого ВидВремени Из ВидыВремени Цикл
			СтрокаВидаВремени = НачислениеОбъект.ВидыВремени.Найти(ВидВремени);
			Если НЕ СтрокаВидаВремени = Неопределено Тогда
				НачислениеОбъект.ВидыВремени.Удалить(СтрокаВидаВремени);
			КонецЕсли;
			
		КонецЦикла;
		
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(НачислениеОбъект);
		
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
		
	КонецЦикла;
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);

КонецПроцедуры

Процедура ЗаполнениеРегистраНалогиВзносыОтчисленияПоСотрудникамВидДоходаСДаннымиМежрасчета(ПараметрыОбновления = Неопределено) Экспорт
	
    ТекстЗапроса = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 50
	|	НалогиВзносыОтчисленияПоСотрудникам.Регистратор КАК Регистратор
	|ПОМЕСТИТЬ ВТ_Регистраторы
	|ИЗ
	|	РегистрНакопления.НалогиВзносыОтчисленияПоСотрудникам КАК НалогиВзносыОтчисленияПоСотрудникам
	|ГДЕ
	|	НалогиВзносыОтчисленияПоСотрудникам.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка)
	|	И НалогиВзносыОтчисленияПоСотрудникам.ДанныеМежрасчетногоПериода
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Регистратор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НалогиВзносыОтчисленияПоСотрудникам.Период КАК Период,
	|	НалогиВзносыОтчисленияПоСотрудникам.Регистратор КАК Регистратор,
	|	НалогиВзносыОтчисленияПоСотрудникам.Начисление КАК Начисление
	|ПОМЕСТИТЬ ВТ_Начисления
	|ИЗ
	|	РегистрНакопления.НалогиВзносыОтчисленияПоСотрудникам КАК НалогиВзносыОтчисленияПоСотрудникам
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Регистраторы КАК Регистраторы
	|	ПО НалогиВзносыОтчисленияПоСотрудникам.Регистратор = Регистраторы.Регистратор
	|ГДЕ
	|	НалогиВзносыОтчисленияПоСотрудникам.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Период,
	|	Начисление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Начисления.Период КАК Период,
	|	ВТ_Начисления.Регистратор КАК Регистратор,
	|	ВТ_Начисления.Начисление КАК Начисление,
	|	МАКСИМУМ(НалогообложениеНачислений.Период) КАК ПериодНалогообложение
	|ПОМЕСТИТЬ ВТ_ПериодыНалогообложения
	|ИЗ
	|	ВТ_Начисления КАК ВТ_Начисления
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НалогообложениеНачислений КАК НалогообложениеНачислений
	|		ПО ВТ_Начисления.Начисление = НалогообложениеНачислений.Начисление
	|			И ВТ_Начисления.Период >= НалогообложениеНачислений.Период
	// если учет вели некорректно вид дохода может быть пустым, что приведет к зацикливанию
	|			И НЕ НалогообложениеНачислений.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Начисления.Период,
	|	ВТ_Начисления.Начисление,
	|	ВТ_Начисления.Регистратор
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ПериодНалогообложение,
	|	Период,
	|	Начисление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Начисления.Период КАК Период,
	|	ВТ_Начисления.Регистратор КАК Регистратор,
	|	ВТ_Начисления.Начисление КАК Начисление,
	|	ЕСТЬNULL(НалогообложениеНачислений.ВидДохода, ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)) КАК ВидДохода
	|ПОМЕСТИТЬ ВТ_ДанныеВидовДохода
	|ИЗ
	|	ВТ_Начисления КАК ВТ_Начисления
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПериодыНалогообложения КАК ВТ_ПериодыНалогообложения
	|		ПО ВТ_Начисления.Период = ВТ_ПериодыНалогообложения.Период
	|			И ВТ_Начисления.Регистратор = ВТ_ПериодыНалогообложения.Регистратор
	|			И ВТ_Начисления.Начисление = ВТ_ПериодыНалогообложения.Начисление
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НалогообложениеНачислений КАК НалогообложениеНачислений
	|		ПО (НалогообложениеНачислений.Период = ВТ_ПериодыНалогообложения.ПериодНалогообложение)
	|			И (НалогообложениеНачислений.Начисление = ВТ_ПериодыНалогообложения.Начисление)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Период,
	|	Регистратор,
	|	Начисление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_Начисления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_ПериодыНалогообложения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	// выберем различные, без номера строки с целью удаления замножения 3.1.2.17
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НалогиВзносыОтчисленияПоСотрудникам.Период КАК Период,
	|	НалогиВзносыОтчисленияПоСотрудникам.Регистратор КАК Регистратор,
	|	НалогиВзносыОтчисленияПоСотрудникам.Активность КАК Активность,
	|	НалогиВзносыОтчисленияПоСотрудникам.Организация КАК Организация,
	|	НалогиВзносыОтчисленияПоСотрудникам.ФизическоеЛицо КАК ФизическоеЛицо,
	|	НалогиВзносыОтчисленияПоСотрудникам.Сотрудник КАК Сотрудник,
	|	НалогиВзносыОтчисленияПоСотрудникам.Подразделение КАК Подразделение,
	|	НалогиВзносыОтчисленияПоСотрудникам.Начисление КАК Начисление,
	|	НалогиВзносыОтчисленияПоСотрудникам.ДанныеМежрасчетногоПериода КАК ДанныеМежрасчетногоПериода,
	|	НалогиВзносыОтчисленияПоСотрудникам.СО КАК СО,
	|	НалогиВзносыОтчисленияПоСотрудникам.СН КАК СН,
	|	НалогиВзносыОтчисленияПоСотрудникам.ОППВ КАК ОППВ,
	|	НалогиВзносыОтчисленияПоСотрудникам.ООСМС КАК ООСМС,
	|	НалогиВзносыОтчисленияПоСотрудникам.ОПВР КАК ОПВР,
	|	НалогиВзносыОтчисленияПоСотрудникам.Сторно КАК Сторно,
	|	НалогиВзносыОтчисленияПоСотрудникам.ДатаНачала КАК ДатаНачала,
	|	ВТ_ДанныеВидовДохода.ВидДохода КАК ВидДохода
	|ИЗ
	|	ВТ_ДанныеВидовДохода КАК ВТ_ДанныеВидовДохода
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.НалогиВзносыОтчисленияПоСотрудникам КАК НалогиВзносыОтчисленияПоСотрудникам
	|		ПО ВТ_ДанныеВидовДохода.Период = НалогиВзносыОтчисленияПоСотрудникам.Период
	|			И ВТ_ДанныеВидовДохода.Регистратор = НалогиВзносыОтчисленияПоСотрудникам.Регистратор
	|			И ВТ_ДанныеВидовДохода.Начисление = НалогиВзносыОтчисленияПоСотрудникам.Начисление
	|
	|УПОРЯДОЧИТЬ ПО
	|	Регистратор";
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ОбработатьНаборыЗаписейРегистраНакопления("НалогиВзносыОтчисленияПоСотрудникам", ТекстЗапроса, , , ПараметрыОбновления);
	
КонецПроцедуры

Процедура ЗаполнитьПоказателиУдержанийДляСО(ПараметрыОбновления = Неопределено) Экспорт 
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Ложь);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Удержания.Ссылка КАК Ссылка,
		|	Удержания.ВычитатьИзРасчетнойБазыНалогиВзносы КАК ВычитатьИзРасчетнойБазыНалогиВзносы
		|ИЗ
		|	ПланВидовРасчета.Удержания КАК Удержания
		|ГДЕ
		|	(Удержания.КатегорияУдержания = ЗНАЧЕНИЕ(Перечисление.КатегорииУдержаний.ИсполнительныйЛист)
		|			И Удержания.ВидОперацииПоЗарплате = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПоЗарплате.АлиментыПрочиеИсполнительныеЛистыКонтрагенты))";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Если Не ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ПодготовитьОбновлениеДанных(ПараметрыОбновления, "ПланВидовРасчета.Удержания", "Ссылка", Выборка.Ссылка) Тогда
			Продолжить;
		КонецЕсли;
		
		УдержаниеОбъект = Выборка.Ссылка.ПолучитьОбъект();
		
		РасчетЗарплатыРасширенный.ЗаполнитьТаблицуПоказателейВидаРасчета(УдержаниеОбъект, Неопределено);
		РасчетЗарплатыРасширенный.ЗаполнитьИнформациюОПоказателяхВидаРасчета(УдержаниеОбъект);
		
		ОбновлениеИнформационнойБазы.ЗаписатьДанные(УдержаниеОбъект);
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
	КонецЦикла;
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
	
КонецПроцедуры

Процедура ЗаполнениеРегистраВзаиморасчетыСКонтрагентамиАкционерами(ПараметрыОбновления = Неопределено) Экспорт
	
    ТекстЗапроса = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 50
    |   ВзаиморасчетыСКонтрагентамиАкционерами.Регистратор КАК Регистратор
    |ПОМЕСТИТЬ ВТ_РегистраторыВзаиморасчеты
    |ИЗ
    |   РегистрНакопления.ВзаиморасчетыСКонтрагентамиАкционерами КАК ВзаиморасчетыСКонтрагентамиАкционерами
    |ГДЕ
    |   ВзаиморасчетыСКонтрагентамиАкционерами.ПериодВзаиморасчетов = ДАТАВРЕМЯ(1, 1, 1)
    |
    |ИНДЕКСИРОВАТЬ ПО
    |   Регистратор
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ РАЗЛИЧНЫЕ
    |   ВзаиморасчетыСКонтрагентамиАкционерами.Регистратор КАК Регистратор,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.ДокументОснование КАК ДокументОснование,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.Организация КАК Организация,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.ФизическоеЛицо КАК ФизическоеЛицо,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.СпособРасчетов КАК СпособРасчетов,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.СтатьяРасходов КАК СтатьяРасходов,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.Подразделение КАК Подразделение,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.ПериодВзаиморасчетов КАК ПериодВзаиморасчетов
    |ПОМЕСТИТЬ ВТ_ДокументыОснованияВзаиморасчеты
    |ИЗ
    |   РегистрНакопления.ВзаиморасчетыСКонтрагентамиАкционерами КАК ВзаиморасчетыСКонтрагентамиАкционерами
    |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_РегистраторыВзаиморасчеты КАК ВТ_РегистраторыВзаиморасчеты
    |       ПО ВзаиморасчетыСКонтрагентамиАкционерами.Регистратор = ВТ_РегистраторыВзаиморасчеты.Регистратор
    |
    |ИНДЕКСИРОВАТЬ ПО
    |   Регистратор,
    |   ДокументОснование
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |УНИЧТОЖИТЬ ВТ_РегистраторыВзаиморасчеты
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ РАЗЛИЧНЫЕ
    |   ВТ_ДокументыОснованияВзаиморасчеты.ДокументОснование КАК ДокументОснование,
    |   ВыплатаБывшимСотрудникам.ПериодРегистрации КАК ПериодВзаиморасчетов
    |ПОМЕСТИТЬ ВТ_ПериодыВзаиморасчетов
    |ИЗ
    |   ВТ_ДокументыОснованияВзаиморасчеты КАК ВТ_ДокументыОснованияВзаиморасчеты
    |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВыплатаБывшимСотрудникам КАК ВыплатаБывшимСотрудникам
    |       ПО (ВыплатаБывшимСотрудникам.Ссылка = ВТ_ДокументыОснованияВзаиморасчеты.ДокументОснование)
    |
    |ОБЪЕДИНИТЬ ВСЕ
    |
    |ВЫБРАТЬ РАЗЛИЧНЫЕ
    |   ВТ_ДокументыОснованияВзаиморасчеты.ДокументОснование,
    |   РегистрацияПрочихДоходов.ПериодРегистрации
    |ИЗ
