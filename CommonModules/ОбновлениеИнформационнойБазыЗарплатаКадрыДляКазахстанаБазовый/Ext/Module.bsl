        |       ЛЕВОЕ СОЕДИНЕНИЕ ВТРасчетСреднегоЗаработкаГоловнойОрганизации КАК ВТРасчетСреднегоЗаработкаГоловнойОрганизации
        |       ПО ВТФилиалы.ГоловнаяОрганизация = ВТРасчетСреднегоЗаработкаГоловнойОрганизации.Организация";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
    Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
        
        НаборЗаписей.Отбор.Организация.Установить(ВыборкаДетальныеЗаписи.Организация);
        НаборЗаписей.Отбор.Период.Установить(ВыборкаДетальныеЗаписи.Период);
        НаборЗаписей.Прочитать(); 
        
        Если НаборЗаписей.Количество() > 0 Тогда
            Продолжить;
        КонецЕсли;
        
		ЗаписНабора = НаборЗаписей.Добавить();
		
		ЗаполнитьЗначенияСвойств(ЗаписНабора, ВыборкаДетальныеЗаписи);
		
		Попытка
			
			НаборЗаписей.ОбменДанными.Загрузка = Истина;
			НаборЗаписей.Записать();

		Исключение
			
			ТекстСообщения = НСтр(
			"ru = 'при записи набора данных ""Расчет среднего заработка организаций"" произошла ошибка: 
			|%1");
			
			ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, ПодробноеПредставлениеОшибки);
			
			ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Не удалось обновить ""Регистр сведений  ""Расчет среднего заработка организаций"""".'"), 
			УровеньЖурналаРегистрации.Ошибка, , , Комментарий);					
			
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбновитьДокументыУдержаниеНалоговВзносовПоНУ(ПараметрыОбновления = Неопределено) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДокументыКОбработке.Ссылка КАК Ссылка,
	|	ДокументыКОбработке.Дата КАК Дата,
	|	ДокументыКОбработке.НалогиВзносы.(
	|		ФизическоеЛицо КАК Ссылка
	|	) КАК ФизическиеЛица
	|ИЗ
	|	Документ.УдержаниеНалоговВзносовПоНУ КАК ДокументыКОбработке
	|ГДЕ
	|	ДокументыКОбработке.КраткийСоставДокумента = """"
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДокументыКОбработке.ПериодРегистрации УБЫВ";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Ложь);
	Если РезультатЗапроса.Пустой() Тогда
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
		Возврат;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Если Не ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ПодготовитьОбновлениеДанных(ПараметрыОбновления, "Документ.УдержаниеНалоговВзносовПоНУ", "Ссылка", Выборка.Ссылка) Тогда
			Продолжить;
		КонецЕсли;
		
		ДокументОбъект = Выборка.Ссылка.ПолучитьОбъект();
		
		ФизическиеЛицаТаблица = Выборка.ФизическиеЛица.Выгрузить();
		ФизическиеЛица = Новый Массив;
		Для Каждого СтрокаФизлица Из ФизическиеЛицаТаблица Цикл
			ФизическиеЛица.Добавить(СтрокаФизлица.Ссылка);
		КонецЦикла;
		
		ДокументОбъект.КраткийСоставДокумента = ЗарплатаКадры.КраткийСоставСотрудниковПоСпискуФизическихЛиц(ФизическиеЛица, Выборка.Дата);
		
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ДокументОбъект);
		
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
		
	КонецЦикла;
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
	
КонецПроцедуры

Процедура ЗаполнениеРегистраНалогиВзносыОтчисленияПоСотрудникамВидДохода(ПараметрыОбновления = Неопределено) Экспорт
	
    ТекстЗапроса = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ ПЕРВЫЕ 50
	|	НалогиВзносыОтчисленияПоСотрудникам.Регистратор КАК Регистратор
	|ПОМЕСТИТЬ ВТ_Регистраторы
	|ИЗ
	|	РегистрНакопления.НалогиВзносыОтчисленияПоСотрудникам КАК НалогиВзносыОтчисленияПоСотрудникам
	|ГДЕ
	|	НалогиВзносыОтчисленияПоСотрудникам.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Регистратор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НалогиВзносыОтчисленияПоСотрудникам.Период КАК Период,
	|	НалогиВзносыОтчисленияПоСотрудникам.Регистратор КАК Регистратор,
	|	НалогиВзносыОтчисленияПоСотрудникам.Начисление КАК Начисление
	|ПОМЕСТИТЬ ВТ_Начисления
	|ИЗ
	|	РегистрНакопления.НалогиВзносыОтчисленияПоСотрудникам КАК НалогиВзносыОтчисленияПоСотрудникам
	|	ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Регистраторы КАК Регистраторы
	|	ПО НалогиВзносыОтчисленияПоСотрудникам.Регистратор = Регистраторы.Регистратор
	|ГДЕ
	|	НалогиВзносыОтчисленияПоСотрудникам.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Период,
	|	Начисление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Начисления.Период КАК Период,
	|	ВТ_Начисления.Регистратор КАК Регистратор,
	|	ВТ_Начисления.Начисление КАК Начисление,
	|	МАКСИМУМ(НалогообложениеНачислений.Период) КАК ПериодНалогообложение
	|ПОМЕСТИТЬ ВТ_ПериодыНалогообложения
	|ИЗ
	|	ВТ_Начисления КАК ВТ_Начисления
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НалогообложениеНачислений КАК НалогообложениеНачислений
	|		ПО ВТ_Начисления.Начисление = НалогообложениеНачислений.Начисление
	|			И ВТ_Начисления.Период >= НалогообложениеНачислений.Период
	// если учет вели некорректно вид дохода может быть пустым, что приведет к зацикливанию
	|			И НЕ НалогообложениеНачислений.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_Начисления.Период,
	|	ВТ_Начисления.Начисление,
	|	ВТ_Начисления.Регистратор
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ПериодНалогообложение,
	|	Период,
	|	Начисление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_Начисления.Период КАК Период,
	|	ВТ_Начисления.Регистратор КАК Регистратор,
	|	ВТ_Начисления.Начисление КАК Начисление,
	|	ЕСТЬNULL(НалогообложениеНачислений.ВидДохода, ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)) КАК ВидДохода
	|ПОМЕСТИТЬ ВТ_ДанныеВидовДохода
	|ИЗ
	|	ВТ_Начисления КАК ВТ_Начисления
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПериодыНалогообложения КАК ВТ_ПериодыНалогообложения
	|		ПО ВТ_Начисления.Период = ВТ_ПериодыНалогообложения.Период
	|			И ВТ_Начисления.Регистратор = ВТ_ПериодыНалогообложения.Регистратор
	|			И ВТ_Начисления.Начисление = ВТ_ПериодыНалогообложения.Начисление
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НалогообложениеНачислений КАК НалогообложениеНачислений
	|		ПО (НалогообложениеНачислений.Период = ВТ_ПериодыНалогообложения.ПериодНалогообложение)
	|			И (НалогообложениеНачислений.Начисление = ВТ_ПериодыНалогообложения.Начисление)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Период,
	|	Регистратор,
	|	Начисление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_Начисления
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_ПериодыНалогообложения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НалогиВзносыОтчисленияПоСотрудникам.Период КАК Период,
	|	НалогиВзносыОтчисленияПоСотрудникам.Регистратор КАК Регистратор,
	|	НалогиВзносыОтчисленияПоСотрудникам.НомерСтроки КАК НомерСтроки,
	|	НалогиВзносыОтчисленияПоСотрудникам.Активность КАК Активность,
	|	НалогиВзносыОтчисленияПоСотрудникам.Организация КАК Организация,
	|	НалогиВзносыОтчисленияПоСотрудникам.ФизическоеЛицо КАК ФизическоеЛицо,
	|	НалогиВзносыОтчисленияПоСотрудникам.Сотрудник КАК Сотрудник,
	|	НалогиВзносыОтчисленияПоСотрудникам.Подразделение КАК Подразделение,
	|	НалогиВзносыОтчисленияПоСотрудникам.Начисление КАК Начисление,
	|	НалогиВзносыОтчисленияПоСотрудникам.СО КАК СО,
	|	НалогиВзносыОтчисленияПоСотрудникам.СН КАК СН,
	|	НалогиВзносыОтчисленияПоСотрудникам.ОППВ КАК ОППВ,
	|	НалогиВзносыОтчисленияПоСотрудникам.ООСМС КАК ООСМС,
	|	НалогиВзносыОтчисленияПоСотрудникам.ОПВР КАК ОПВР,
	|	НалогиВзносыОтчисленияПоСотрудникам.Сторно КАК Сторно,
	|	ВТ_ДанныеВидовДохода.ВидДохода КАК ВидДохода
	|ИЗ
	|	ВТ_ДанныеВидовДохода КАК ВТ_ДанныеВидовДохода
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.НалогиВзносыОтчисленияПоСотрудникам КАК НалогиВзносыОтчисленияПоСотрудникам
	|		ПО ВТ_ДанныеВидовДохода.Период = НалогиВзносыОтчисленияПоСотрудникам.Период
	|			И ВТ_ДанныеВидовДохода.Регистратор = НалогиВзносыОтчисленияПоСотрудникам.Регистратор
	|			И ВТ_ДанныеВидовДохода.Начисление = НалогиВзносыОтчисленияПоСотрудникам.Начисление
	|
	|УПОРЯДОЧИТЬ ПО
	|	Регистратор,
	|	НомерСтроки";
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ОбработатьНаборыЗаписейРегистраНакопления("НалогиВзносыОтчисленияПоСотрудникам", ТекстЗапроса, , , ПараметрыОбновления);
	
КонецПроцедуры

Процедура ДополнитьВидыВремениПремий(ПараметрыОбновления = Неопределено) Экспорт
	
	ВидВремениКомандировка = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ВидыИспользованияРабочегоВремени.Командировка");
	
	ТекстЗапроса = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Начисления.Ссылка КАК Ссылка
	|ИЗ
	|	ПланВидовРасчета.Начисления КАК Начисления
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПланВидовРасчета.Начисления.ВидыВремени КАК НачисленияВидыВремени
	|		ПО НачисленияВидыВремени.Ссылка = Начисления.Ссылка
	|			И НачисленияВидыВремени.ВидВремени = &Командировка
	|ГДЕ
	|	(Начисления.КатегорияНачисленияИлиНеоплаченногоВремени = ЗНАЧЕНИЕ(Перечисление.КатегорииНачисленийИНеоплаченногоВремени.Премия)
	|		ИЛИ Начисления.КатегорияНачисленияИлиНеоплаченногоВремени = ЗНАЧЕНИЕ(Перечисление.КатегорииНачисленийИНеоплаченногоВремени.КвартальнаяПремия))
	|	И НачисленияВидыВремени.Ссылка ЕСТЬ NULL";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Командировка", ВидВремениКомандировка);
	РезультатЗапроса = Запрос.Выполнить();
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Ложь);
	Если РезультатЗапроса.Пустой() Тогда
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
		Возврат;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если Не ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ПодготовитьОбновлениеДанных(ПараметрыОбновления, "ПланВидовРасчета.Начисления", "Ссылка", Выборка.Ссылка) Тогда
			Продолжить;
		КонецЕсли;
		
		НачислениеОбъект = Выборка.Ссылка.ПолучитьОбъект();
		СтрокаВремени = НачислениеОбъект.ВидыВремени.Добавить();
		СтрокаВремени.ВидВремени = ВидВремениКомандировка;
		
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(НачислениеОбъект);
		
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
		
	КонецЦикла;
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);

КонецПроцедуры

Процедура ОбновитьМакетОтчетаТ8Т8а() Экспорт
	
	МетаданныеОтчетаТ8 = Метаданные.Отчеты.ПечатнаяФормаТ8;
	МетаданныеОтчетаТ8а = Метаданные.Отчеты.ПечатнаяФормаТ8а;
	
	ЗарплатаКадрыОтчеты.ОчиститьМакетОтчета(МетаданныеОтчетаТ8);
	ЗарплатаКадрыОтчеты.ОчиститьМакетОтчета(МетаданныеОтчетаТ8а);
	
КонецПроцедуры

Процедура УстановитьИспользованиеПрочихВзаиморасчетов() Экспорт

	ИспользоватьРегистрациюПрочихДоходов = ПолучитьФункциональнуюОпцию("ИспользоватьРегистрациюПрочихДоходов");
	ИспользоватьНачисленияПоДоговорам = ПолучитьФункциональнуюОпцию("ИспользоватьНачисленияПоДоговорам");
	ИспользоватьВыплатыБывшимСотрудникам = ПолучитьФункциональнуюОпцию("ИспользоватьВыплатыБывшимСотрудникам");
	
	Если НЕ ИспользоватьНачисленияПоДоговорам
		И НЕ ИспользоватьРегистрациюПрочихДоходов
		И НЕ ИспользоватьВыплатыБывшимСотрудникам Тогда
		Возврат;
	КонецЕсли;
	
	НаборЗаписей = РегистрыСведений.НастройкиВзаиморасчетовПоПрочимДоходам.СоздатьНаборЗаписей();
	НаборЗаписей.Прочитать();
	
	Если НаборЗаписей.Количество() > 0 Тогда
		НаборЗаписей[0].ИспользоватьВзаиморасчетыПоПрочимДоходам = Истина;		
		НаборЗаписей[0].ИспользоватьВедомостиДляВыплатыПрочихДоходов = Истина;		
	Иначе 
		ЗаписьНабора = НаборЗаписей.Добавить();
		ЗаписьНабора.ИспользоватьВзаиморасчетыПоПрочимДоходам = Истина;		
		ЗаписьНабора.ИспользоватьВедомостиДляВыплатыПрочихДоходов = Истина;		
	КонецЕсли;	
	
	Попытка
		
		НаборЗаписей.ОбменДанными.Загрузка = Истина;
		НаборЗаписей.Записать();

	Исключение
		
		ТекстСообщения = НСтр(
		"ru = 'при записи набора данных ""Настройки взаиморасчетов по прочим доходам"" произошла ошибка: 
		|%1");
		
		ПодробноеПредставлениеОшибки = ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, ПодробноеПредставлениеОшибки);
		
		ЗаписьЖурналаРегистрации(
		НСтр("ru = 'Не удалось обновить ""Регистр сведений  ""Настройки взаиморасчетов по прочим доходам"""".'"), 
		УровеньЖурналаРегистрации.Ошибка, , , Комментарий);					
		
	КонецПопытки;
	
КонецПроцедуры

Процедура ДобавитьБольничныйЗаСчетРаботодателяСОкруглением(ПараметрыОбновления = Неопределено) Экспорт
	
	Начисления = ПланыВидовРасчета.Начисления;
	КоллекторНачислений = Новый Соответствие;
	КоллекторУдержаний = Новый Соответствие;
	СвойстваНачислений = Новый ФиксированноеСоответствие(Начисления.СвойстваНачисленийПоКатегориям());
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	УдержанияБазовыеВидыРасчета.Ссылка КАК ВидРасчета
	|ИЗ
	|	ПланВидовРасчета.Удержания.БазовыеВидыРасчета КАК УдержанияБазовыеВидыРасчета
	|		ЛЕВОЕ СОЕДИНЕНИЕ ПланВидовРасчета.Начисления КАК Начисления
	|		ПО УдержанияБазовыеВидыРасчета.ВидРасчета = Начисления.Ссылка
	|ГДЕ
	|	Начисления.КатегорияНачисленияИлиНеоплаченногоВремени = ЗНАЧЕНИЕ(Перечисление.КатегорииНачисленийИНеоплаченногоВремени.ОплатаБольничногоЛистаЗаСчетРаботодателя)";
	
	Результат = Запрос.Выполнить();
	
	Если Не Результат.Пустой() Тогда
		
		СвойстваУдержаний = ПланыВидовРасчета.Удержания.СвойстваУдержанийПоКатегориям();
		Выборка = Результат.Выбрать();
		Пока Выборка.Следующий() Цикл
			
			ВРОбъект = Выборка.ВидРасчета.ПолучитьОбъект();
			КоллекторУдержаний.Вставить(Выборка.ВидРасчета, ВРОбъект);
			
		КонецЦикла;
		
	КонецЕсли;
	
	СвойстваПоКатегории = Начисления.СвойстваНачисленияПоКатегорииПоУмолчанию();
	СвойстваПоКатегории.СпособВыполненияНачисления = Перечисления.СпособыВыполненияНачислений.ПоОтдельномуДокументуДоОкончательногоРасчета;
	СвойстваПоКатегории.ВидДокументаНачисления = Перечисления.ВидыДокументовНачисления.БольничныйЛист;
	СвойстваПоКатегории.СпособРасчета = Перечисления.СпособыРасчетаНачислений.ПроизвольнаяФормула;
	СвойстваПоКатегории.ФормулаРасчета = "СреднийЗаработокОбщий * ВремяВДняхЧасах * КоэффициентИндексацииСреднегоЗаработка";
	СвойстваПоКатегории.СреднийЗаработокОбщий = Перечисления.УчетНачисленийВСреднемЗаработкеОбщий.ОбщийЗаработок;
	СвойстваПоКатегории.ВидВремени = Перечисления.ВидыРабочегоВремениСотрудников.ЦелодневноеНеотработанное;
	СвойстваПоКатегории.ОбозначениеВТабелеУчетаРабочегоВремени = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыИспользованияРабочегоВремени.Болезнь");
	СвойстваПоКатегории.ВидПособияСоциальногоСтрахования = Неопределено;
	СвойстваПоКатегории.КодДоходаНДФЛ = Справочники.ВидыДоходовНДФЛ.НайтиПоКоду("2300");
	СвойстваПоКатегории.КатегорияДохода = УчетНДФЛПовтИсп.КатегорияДоходаПоЕгоКоду(СвойстваПоКатегории.КодДоходаНДФЛ);
	СвойстваПоКатегории.КодДоходаСтраховыеВзносы = Справочники.ВидыДоходовПоСтраховымВзносам.НеОблагаетсяЦеликом;
	СвойстваПоКатегории.КодДоходаСтраховыеВзносы2017 = Справочники.ВидыДоходовПоСтраховымВзносам.НеОблагаетсяЦеликом;
	СвойстваПоКатегории.КатегорияСтатистическогоНаблюдения = Неопределено;
	СвойстваПоКатегории.КатегорияСтатистическогоНаблюдения2019 = Неопределено;
	СвойстваПоКатегории.ПорядокОпределенияРасчетногоПериодаСреднегоЗаработка = Перечисления.ПорядокОпределенияРасчетногоПериодаСреднегоЗаработка.ПоТрудовомуЗаконодательству;
	СвойстваПоКатегории.ВидОперацииПоЗарплате = Перечисления.ВидыОперацийПоЗарплате.РасходыПоСтрахованиюРаботодатель;
	СвойстваПоКатегории.ВидСтажаСЗВ = Перечисления.ВидыСтажаСЗВ.ВременнаяНетрудоспособность;
	СвойстваПоКатегории.ВидСтажаПФР2014 = Перечисления.ВидыСтажаПФР2014.ВременнаяНетрудоспособность;
	СвойстваПоКатегории.ВидНачисленияДляНУ	= Перечисления.ВидыНачисленийОплатыТрудаДляНУ.пп48ст266;
	СвойстваПоКатегории.НедоступныеСвойства.Добавить("ВидВремени");
	
	Описание = Начисления.ОписаниеНачисления();
	Описание.КатегорияНачисленияИлиНеоплаченногоВремени = Перечисления.КатегорииНачисленийИНеоплаченногоВремени.ОплатаБольничногоЛистаЗаСчетРаботодателя;
	Описание.СвойстваПоКатегории 	= СвойстваПоКатегории;
	Описание.Код					= НСтр("ru = 'БЛНФ'");
	Описание.Наименование			= НСтр("ru = 'Больничный за счет работодателя'");
	Описание.КлючевыеСвойства		= "Ссылка";
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Ложь);
	Начисления.СоздатьИзменитьНачисленияПоОписанию(КоллекторНачислений, Описание);
	
	Начисление = Новый Массив;
	НачислениеСсылка = Неопределено;
	Для Каждого СозданноеНачисление Из КоллекторНачислений Цикл
		Начисление.Добавить(СозданноеНачисление.Ключ);
		НачислениеСсылка = СозданноеНачисление.Ключ;
	КонецЦикла;
	
	// Записываем новое начисление, добавляем в приоритет начислений
	Начисления.ЗаписатьВидыРасчетаКоллектора(КоллекторНачислений, СвойстваНачислений);
	
	// Добавляем новое начисление в зависимые удержания
	Для Каждого Удержание Из КоллекторУдержаний Цикл
		УдержаниеОбъект = Удержание.Значение;
		Если УдержаниеОбъект.БазовыеВидыРасчета.Найти(НачислениеСсылка, "ВидРасчета") = Неопределено Тогда
			УдержаниеОбъект.БазовыеВидыРасчета.Добавить().ВидРасчета = НачислениеСсылка;
			УдержаниеОбъект.ОбменДанными.Загрузка = Истина;
			УдержаниеОбъект.Записать();
		КонецЕсли;
	КонецЦикла;
	
	// Создаем настройки налогообложения нового начисления
	РегистрыСведений.НалогообложениеНачислений.СоздатьНалогообложениеНачисленийПоНастройкам(Начисление);
	
	// Пометка прочих начислений с той же категорией начисления как "больше не используется"
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Начисления.Ссылка КАК Ссылка
		|ИЗ
		|	ПланВидовРасчета.Начисления КАК Начисления
		|ГДЕ
		|	Начисления.КатегорияНачисленияИлиНеоплаченногоВремени = ЗНАЧЕНИЕ(Перечисление.КатегорииНачисленийИНеоплаченногоВремени.ОплатаБольничногоЛистаЗаСчетРаботодателя)
		|	И Начисления.СпособРасчета = ЗНАЧЕНИЕ(Перечисление.СпособыРасчетаНачислений.ОплатаБольничного)
		|	И НЕ Начисления.ВАрхиве";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
		Возврат;
	КонецЕсли;
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Если Не ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ПодготовитьОбновлениеДанных(ПараметрыОбновления, "ПланВидовРасчета.Начисления", "Ссылка", ВыборкаДетальныеЗаписи.Ссылка) Тогда
			Продолжить;
		КонецЕсли;
		
		НачислениеОбъект = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
		НачислениеОбъект.ВАрхиве = Истина;
		
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(НачислениеОбъект);
		
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
		
	КонецЦикла;
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
	
КонецПроцедуры

Процедура ЗаполнитьДатуКорректировкиВеденияУчетаПоДаннымНВО() Экспорт

    Попытка
    
    	Константы.ДатаКорректировкиВеденияУчетаПоДаннымНВО.Установить(НачалоМесяца(ТекущаяДатаСеанса()));
    
    Исключение  
        
		ТекстСообщения = НСтр(
