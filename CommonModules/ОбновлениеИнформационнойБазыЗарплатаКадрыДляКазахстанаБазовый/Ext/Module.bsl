    |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.НачислениеЗарплаты КАК НачислениеЗарплаты
    |       ПО (НачислениеЗарплаты.Ссылка = ВТ_ДокументыОснованияВзаиморасчеты.ДокументОснование)
    |
    |ОБЪЕДИНИТЬ ВСЕ
    |
    |ВЫБРАТЬ РАЗЛИЧНЫЕ
    |   ВТ_ДокументыОснованияВзаиморасчеты.ДокументОснование,
    |   НачислениеПоДоговорам.МесяцНачисления
    |ИЗ
    |   ВТ_ДокументыОснованияВзаиморасчеты КАК ВТ_ДокументыОснованияВзаиморасчеты
    |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.НачислениеПоДоговорам КАК НачислениеПоДоговорам
    |       ПО (НачислениеПоДоговорам.Ссылка = ВТ_ДокументыОснованияВзаиморасчеты.ДокументОснование)
    |;
    |
    |////////////////////////////////////////////////////////////////////////////////
    |ВЫБРАТЬ РАЗЛИЧНЫЕ
    |   ВзаиморасчетыСКонтрагентамиАкционерами.Период КАК Период,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.Регистратор КАК Регистратор,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.НомерСтроки КАК НомерСтроки,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.Активность КАК Активность,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.ВидДвижения КАК ВидДвижения,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.Организация КАК Организация,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.ФизическоеЛицо КАК ФизическоеЛицо,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.СпособРасчетов КАК СпособРасчетов,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.СтатьяФинансирования КАК СтатьяФинансирования,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.СтатьяРасходов КАК СтатьяРасходов,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.ДокументОснование КАК ДокументОснование,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.ВидДоходаИсполнительногоПроизводства КАК ВидДоходаИсполнительногоПроизводства,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.Подразделение КАК Подразделение,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.СуммаВзаиморасчетов КАК СуммаВзаиморасчетов,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.ГруппаНачисленияУдержанияВыплаты КАК ГруппаНачисленияУдержанияВыплаты,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.Сотрудник КАК Сотрудник,
    |   ВзаиморасчетыСКонтрагентамиАкционерами.МоментВремени КАК МоментВремени,
    |   ЕСТЬNULL(ВТ_ПериодыВзаиморасчетов.ПериодВзаиморасчетов, ВзаиморасчетыСКонтрагентамиАкционерами.Период) КАК ПериодВзаиморасчетов
    |ИЗ
    |   ВТ_ДокументыОснованияВзаиморасчеты КАК ВТ_ДокументыОснованияВзаиморасчеты
    |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ВзаиморасчетыСКонтрагентамиАкционерами КАК ВзаиморасчетыСКонтрагентамиАкционерами
    |       ПО ВТ_ДокументыОснованияВзаиморасчеты.Регистратор = ВзаиморасчетыСКонтрагентамиАкционерами.Регистратор
    |           И ВТ_ДокументыОснованияВзаиморасчеты.Организация = ВзаиморасчетыСКонтрагентамиАкционерами.Организация
    |           И ВТ_ДокументыОснованияВзаиморасчеты.ФизическоеЛицо = ВзаиморасчетыСКонтрагентамиАкционерами.ФизическоеЛицо
    |           И ВТ_ДокументыОснованияВзаиморасчеты.СпособРасчетов = ВзаиморасчетыСКонтрагентамиАкционерами.СпособРасчетов
    |           И ВТ_ДокументыОснованияВзаиморасчеты.СтатьяРасходов = ВзаиморасчетыСКонтрагентамиАкционерами.СтатьяРасходов
    |           И ВТ_ДокументыОснованияВзаиморасчеты.Подразделение = ВзаиморасчетыСКонтрагентамиАкционерами.Подразделение
    |           И ВТ_ДокументыОснованияВзаиморасчеты.ПериодВзаиморасчетов = ВзаиморасчетыСКонтрагентамиАкционерами.ПериодВзаиморасчетов
    |       ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ПериодыВзаиморасчетов КАК ВТ_ПериодыВзаиморасчетов
    |       ПО (ВТ_ПериодыВзаиморасчетов.ДокументОснование = ВзаиморасчетыСКонтрагентамиАкционерами.ДокументОснование)";
    
	Если ЗарплатаКадрыРКПовтИсп.ЭтоКонфигурацияЗарплатногоУчета() Тогда
		
		ТекстЗапросаДивиденды = "    
        |       ПО (НачислениеПоДоговорам.Ссылка = ВТ_ДокументыОснованияВзаиморасчеты.ДокументОснование)
        |
        |ОБЪЕДИНИТЬ ВСЕ
        |
        |ВЫБРАТЬ РАЗЛИЧНЫЕ
        |   ВТ_ДокументыОснованияВзаиморасчеты.ДокументОснование,
        |   ДивидендыФизическимЛицам.ПериодРегистрации
        |ИЗ
        |   ВТ_ДокументыОснованияВзаиморасчеты КАК ВТ_ДокументыОснованияВзаиморасчеты,
        |       ВНУТРЕННЕЕ СОЕДИНЕНИЕ #Дивиденды КАК ДивидендыФизическимЛицам
        |       ПО (ДивидендыФизическимЛицам.Ссылка = ВТ_ДокументыОснованияВзаиморасчеты.ДокументОснование)
        |";

		ТекстЗапросаДивиденды = СтрЗаменить(ТекстЗапросаДивиденды, "#Дивиденды",	"Документ.ДивидендыФизическимЛицам"); 
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ПО (НачислениеПоДоговорам.Ссылка = ВТ_ДокументыОснованияВзаиморасчеты.ДокументОснование)",	ТекстЗапросаДивиденды); 
		
	КонецЕсли;
    
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ОбработатьНаборыЗаписейРегистраНакопления("ВзаиморасчетыСКонтрагентамиАкционерами", ТекстЗапроса, , , ПараметрыОбновления);
	
КонецПроцедуры

