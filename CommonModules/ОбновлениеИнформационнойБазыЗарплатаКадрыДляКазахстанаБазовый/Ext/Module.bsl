Процедура ЗаполнитьПоказателиУдержанийДляЕдиногоПлатежа(ПараметрыОбновления = Неопределено) Экспорт 
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Ложь);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Удержания.Ссылка КАК Ссылка,
		|	Удержания.ВычитатьИзРасчетнойБазыНалогиВзносы КАК ВычитатьИзРасчетнойБазыНалогиВзносы
		|ИЗ
		|	ПланВидовРасчета.Удержания КАК Удержания
		|ГДЕ
		|	(Удержания.ВычитатьИзРасчетнойБазыНалогиВзносы
		|			ИЛИ Удержания.КатегорияУдержания = ЗНАЧЕНИЕ(Перечисление.КатегорииУдержаний.ИсполнительныйЛист)
		|				И Удержания.ВидОперацииПоЗарплате = ЗНАЧЕНИЕ(Перечисление.ВидыОперацийПоЗарплате.АлиментыПрочиеИсполнительныеЛисты))";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Если Не ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ПодготовитьОбновлениеДанных(ПараметрыОбновления, "ПланВидовРасчета.Удержания", "Ссылка", Выборка.Ссылка) Тогда
			Продолжить;
		КонецЕсли;
		
		УдержаниеОбъект = Выборка.Ссылка.ПолучитьОбъект();
		
		РасчетЗарплатыРасширенный.ЗаполнитьТаблицуПоказателейВидаРасчета(УдержаниеОбъект, Неопределено);
		Если Выборка.ВычитатьИзРасчетнойБазыНалогиВзносы Тогда
			УчетПрочихУдержаний.ПередЗаписьюНачисления(УдержаниеОбъект);
		КонецЕсли;
		РасчетЗарплатыРасширенный.ЗаполнитьИнформациюОПоказателяхВидаРасчета(УдержаниеОбъект);
		
		ОбновлениеИнформационнойБазы.ЗаписатьДанные(УдержаниеОбъект);
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.ЗавершитьОбновлениеДанных(ПараметрыОбновления);
	КонецЦикла;
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
	
КонецПроцедуры

Процедура ЗаполнитьРегистрыРасчетаСреднегоЗаработка2024(ПараметрыОбновления = Неопределено) Экспорт
	
    НаборЗаписей = РегистрыСведений.РасчетСреднегоЗаработкаПодразделений.СоздатьНаборЗаписей();
    
    ДатаИзмененияЕдиныхПравил = НачалоМесяца(УчетСреднегоЗаработкаРК.ДатаИзмененияЕдиныхПравил2024());
    
    Запрос = Новый Запрос;
   	Запрос.УстановитьПараметр("ДатаИзмененияЕдиныхПравил", ДатаИзмененияЕдиныхПравил);
   	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДатаСеанса());
    Запрос.Текст = 
    "ВЫБРАТЬ
    |   &ДатаИзмененияЕдиныхПравил КАК Период,
    |   РасчетСреднегоЗаработкаПодразделений.Подразделение КАК Подразделение,
    |   РасчетСреднегоЗаработкаПодразделений.УчетРабочегоВремени КАК УчетРабочегоВремени,
    |   ЕСТЬNULL(РасчетСреднегоЗаработкаОрганизаций.УчетРабочегоВремениДляСуммированногоУчета, ЗНАЧЕНИЕ(Перечисление.УчетРабочегоВремениПриРасчетеСреднегоЗаработка.ПустаяСсылка)) КАК УчетРабочегоВремениДляСуммированногоУчета
    |ИЗ
    |   РегистрСведений.РасчетСреднегоЗаработкаПодразделений.СрезПоследних(&ДатаИзмененияЕдиныхПравил, ) КАК РасчетСреднегоЗаработкаПодразделений
    |       ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РасчетСреднегоЗаработкаОрганизаций.СрезПоследних(&ДатаИзмененияЕдиныхПравил, ) КАК РасчетСреднегоЗаработкаОрганизаций
    |       ПО (ВЫРАЗИТЬ(РасчетСреднегоЗаработкаПодразделений.Подразделение КАК Справочник.ПодразделенияОрганизаций).Владелец = РасчетСреднегоЗаработкаОрганизаций.Организация)
    |
    |ОБЪЕДИНИТЬ
    |
    |ВЫБРАТЬ
    |   РасчетСреднегоЗаработкаПодразделений.Период,
    |   РасчетСреднегоЗаработкаПодразделений.Подразделение,
    |   РасчетСреднегоЗаработкаПодразделений.УчетРабочегоВремени,
    |   ЕСТЬNULL(РасчетСреднегоЗаработкаОрганизаций.УчетРабочегоВремениДляСуммированногоУчета, ЗНАЧЕНИЕ(Перечисление.УчетРабочегоВремениПриРасчетеСреднегоЗаработка.ПустаяСсылка))
    |ИЗ
    |   РегистрСведений.РасчетСреднегоЗаработкаПодразделений КАК РасчетСреднегоЗаработкаПодразделений
    |       ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РасчетСреднегоЗаработкаОрганизаций.СрезПоследних(&ТекущаяДата, ) КАК РасчетСреднегоЗаработкаОрганизаций
    |       ПО (ВЫРАЗИТЬ(РасчетСреднегоЗаработкаПодразделений.Подразделение КАК Справочник.ПодразделенияОрганизаций).Владелец = РасчетСреднегоЗаработкаОрганизаций.Организация)
    |ГДЕ
    |   РасчетСреднегоЗаработкаПодразделений.Период МЕЖДУ &ДатаИзмененияЕдиныхПравил И &ТекущаяДата";
    
    РезультатЗапроса = Запрос.Выполнить();
    
    ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
    
    Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
        
        НаборЗаписей.Отбор.Подразделение.Установить(ВыборкаДетальныеЗаписи.Подразделение);
        НаборЗаписей.Отбор.Период.Установить(ВыборкаДетальныеЗаписи.Период);
        НаборЗаписей.Прочитать();
        Если НаборЗаписей.Количество() <> 0 Тогда
            НаборЗаписей.Очистить();
        КонецЕсли;
        
        ЗаписьНабора = НаборЗаписей.Добавить();     
        ЗаполнитьЗначенияСвойств(ЗаписьНабора, ВыборкаДетальныеЗаписи);  
        
        Попытка
            
