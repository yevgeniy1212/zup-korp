            УровеньЖурналаРегистрации.Ошибка, , , Комментарий);					
            
        КонецПопытки;
        
    КонецЦикла;
    
    НаборЗаписей = РегистрыСведений.РасчетСреднегоЗаработкаСотрудников.СоздатьНаборЗаписей();
		
	Запрос = Новый Запрос;
