Функция ПолучитьМассивПоКодуЗанятия(КодЗанятия, Период)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СтатистическийУчетСрезПоследних.КодЗанятия
	|ИЗ
	|	РегистрСведений.СтатистическийУчет.СрезПоследних(&Период, КодЗанятия ПОДОБНО ""%"" + &КодЗанятия + ""%"") КАК СтатистическийУчетСрезПоследних";
	
	МассивКодыЗанятий = Новый Массив;
	
	Запрос.УстановитьПараметр("Период", Период);	
	Запрос.УстановитьПараметр("КодЗанятия", КодЗанятия);
	
	Результат = Запрос.Выполнить();
	
	Выборка = Результат.Выбрать();
	Пока Выборка.Следующий() Цикл
		МассивКодыЗанятий.Добавить(Выборка.КодЗанятия);
	КонецЦикла;

	Возврат МассивКодыЗанятий;

КонецФункции

Процедура ЗначенияПоказателей_СтатистикаФорма2ТПРОФ_2017Кв3(ПараметрыОтчета, Контейнер) Экспорт

	// Сведения для отчета берутся за последний квартал.
	ПараметрыОтчетаДляЗаполнения = ОбщегоНазначенияКлиентСервер.СкопироватьСтруктуру(ПараметрыОтчета);
	
	Год = Формат(ПараметрыОтчета.мДатаНачалаПериодаОтчета, "ДФ=гггг");
	Контейнер.Форма2ТСтраница1.Год1 = Сред(Год, 1, 1);
	Контейнер.Форма2ТСтраница1.Год2 = Сред(Год, 2, 1);
	Контейнер.Форма2ТСтраница1.Год3 = Сред(Год, 3, 1);
	Контейнер.Форма2ТСтраница1.Год4 = Сред(Год, 4, 1);
	
	СтрокаСведений = "ИННЮЛ, НаимЮЛПол, ФИОРук, ФИОБух, ОКВЭД, ОКАТО, АдрЮР, ПолныйАдрЮР, АдрФакт, ТелОрганизации, АдресЭлектроннойПочтыОрганизации, ОснВидДеят";
	СведенияОбОрганизации = РегламентированнаяОтчетностьВызовСервера.ПолучитьСведенияОбОрганизации(ПараметрыОтчета.Организация,,СтрокаСведений);
	
	Контейнер.Форма2ТСтраница7.НаимЮЛПол 	 = СведенияОбОрганизации.НаимЮЛПол;
	Контейнер.Форма2ТСтраница7.ФИОРук	 	 = СведенияОбОрганизации.ФИОРук;
	Контейнер.Форма2ТСтраница7.ФИОБух	 	 = СведенияОбОрганизации.ФИОБух;
	Контейнер.Форма2ТСтраница7.Исполнитель 	 = Пользователи.ТекущийПользователь();
	
	Если НЕ  ПараметрыОтчета.Организация.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо Тогда
		Контейнер.Форма2ТСтраница7.АдрЮР			= СведенияОбОрганизации.ПолныйАдрЮР;
		Контейнер.Форма2ТСтраница7.ТелОрганизации	= СведенияОбОрганизации.ТелОрганизации;
		Контейнер.Форма2ТСтраница7.ЭлПочта			= СведенияОбОрганизации.АдресЭлектроннойПочтыОрганизации;
	     // Код БИН
		ДлинаИИН = СтрДлина(СведенияОбОрганизации.ИННЮЛ);
		Если ДлинаИИН <= 12 Тогда
			Для Шаг = 1 По ДлинаИИН Цикл
				Контейнер.Форма2ТСтраница1["БИН" + Шаг] = СРЕД(СведенияОбОрганизации.ИННЮЛ, Шаг, 1);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;

	ИсключаемыеСостояния = Новый СписокЗначений;
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускПоБеременностиИРодам);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускПоУходуЗаРебенком);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускНеоплачиваемыйПоЗаконодательству);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускНеоплачиваемыйПоРазрешениюРаботодателя);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ДополнительныйОтпускНеоплачиваемый);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускУчебныйНеоплачиваемый);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускУчебныйОплачиваемый);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускОсновной);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ДополнительныйОтпуск);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.БолезньБезОплаты);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.Болезнь);

	// Получение зарплатных данных отчета
	ДанныеОтчета = Новый ДеревоЗначений;
	ПараметрыОтчетаДляЗаполнения.Вставить("ИсключаемыеСостояния", ИсключаемыеСостояния);
	ПараметрыОтчетаДляЗаполнения.Вставить("ПРОФ", Истина);	
	ПараметрыОтчетаДляЗаполнения.Вставить("КодОКВЭД", СведенияОбОрганизации.ОКВЭД);
	ПараметрыОтчетаДляЗаполнения.Вставить("ДатаНачалаПериодаВыборки", НачалоМесяца(ПараметрыОтчета.мДатаКонцаПериодаОтчета));
	ДанныеДляЗаполненияРегламентированнойОтчетностиЗарплатаКадры("РегламентированныйОтчетСтатистикаФорма2ТПРОФ", ПараметрыОтчетаДляЗаполнения, ДанныеОтчета);
		
	Если ДанныеОтчета <> Неопределено Тогда
		
		СоответствияПолейНомерамПользовательскихКолонок = ПараметрыОтчетаДляЗаполнения.СоответствияПолейНомерамПользовательскихКолонок;
		
		ДолжностиПоСтрокам = "";
		Для НомерСтроки = 1 По 15 Цикл
			
			Если НомерСтроки = 1 Тогда
				ДолжностиПоСтрокам = ДолжностиПоСтрокам + СоответствияПолейНомерамПользовательскихКолонок.Получить("СТР" + НомерСтроки);
			Иначе
				ДолжностиПоСтрокам = ДолжностиПоСтрокам + "," + СоответствияПолейНомерамПользовательскихКолонок.Получить("СТР" + НомерСтроки);
			КонецЕсли; 
			
		КонецЦикла;

		СоответствияПолейГруппировкиНомерамРазделов = Новый Соответствие;
		СоответствияПолейГруппировкиНомерамРазделов.Вставить(1, ДолжностиПоСтрокам);
		СоответствияПолейГруппировкиНомерамРазделов.Вставить(2, "НаименованиеПрофессии");
		СоответствияПолейГруппировкиНомерамРазделов.Вставить(3, "НаименованиеЗанятия, КодЗанятия");
		
		КолонкиСуммирования = "ФактическаяЧисленностьРК, НачисленияДля1ТЗП, НачисленияЖенщинамДля1ТЗП, ФактическаяЧисленностьЖенщинРК";
		
		Для Каждого СтрокаПериод Из ДанныеОтчета.Строки Цикл
			
			ДанныеОтчетаТЗ = ПреобразоватьСтрокиДереваЗначенийВТаблицуЗначений(СтрокаПериод.Строки, ДанныеОтчета.Колонки);
			СотрудникиСПолнымРабочимМесяцем = ДанныеОтчетаТЗ.Скопировать(Новый Структура ("ФактическаяЧисленностьРК", 1));
			
			Для НомерРаздела = 1 По 3 Цикл
				ИмяПользовательскогоПоляНомерТаблицы = СоответствияПолейНомерамПользовательскихКолонок.Получить("Раздел" + НомерРаздела);
				Отбор = Новый Структура(ИмяПользовательскогоПоляНомерТаблицы, Истина);
				Таблица = СотрудникиСПолнымРабочимМесяцем.Скопировать(Отбор);
				Таблица.Свернуть(СоответствияПолейГруппировкиНомерамРазделов.Получить(НомерРаздела), КолонкиСуммирования);
				
				Если НомерРаздела = 1 Тогда  // раздел ...
					Для Каждого СтрокаТаблицы Из Таблица  Цикл
						Для НомерСтроки = 1 По 4 Цикл
							ИмяПользовательскогоПоляНомерСтроки = СоответствияПолейНомерамПользовательскихКолонок.Получить("СТР" + НомерСтроки);
							Если СтрокаТаблицы[ИмяПользовательскогоПоляНомерСтроки]= Строка(НомерСтроки) + "СТР" Тогда
								Контейнер.Форма2ТСтраница2["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "001"] = Контейнер.Форма2ТСтраница2["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "001"] + СтрокаТаблицы.ФактическаяЧисленностьРК;
								Контейнер.Форма2ТСтраница2["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "004"] = Контейнер.Форма2ТСтраница2["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "004"] + СтрокаТаблицы.ФактическаяЧисленностьЖенщинРК;
								
								Контейнер.Форма2ТСтраница2["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "002"] = Контейнер.Форма2ТСтраница2["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "002"] + СтрокаТаблицы.НачисленияДля1ТЗП/1000;
								Контейнер.Форма2ТСтраница2["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "005"] = Контейнер.Форма2ТСтраница2["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "005"] + СтрокаТаблицы.НачисленияЖенщинамДля1ТЗП/1000;
								
								Контейнер.Форма2ТСтраница2["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "003"] = ?(Контейнер.Форма2ТСтраница2["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "001"] <> 0, Контейнер.Форма2ТСтраница2["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "002"]*1000/Контейнер.Форма2ТСтраница2["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "001"], 0);
								Контейнер.Форма2ТСтраница2["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "006"] = ?(Контейнер.Форма2ТСтраница2["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "004"] <> 0, Контейнер.Форма2ТСтраница2["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "005"]*1000/Контейнер.Форма2ТСтраница2["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "004"], 0);								
							КонецЕсли;
						КонецЦикла;
						Для НомерСтроки = 5 По 12 Цикл
							ИмяПользовательскогоПоляНомерСтроки = СоответствияПолейНомерамПользовательскихКолонок.Получить("СТР" + НомерСтроки);
							Если СтрокаТаблицы[ИмяПользовательскогоПоляНомерСтроки]= Строка(НомерСтроки) + "СТР" Тогда
								Контейнер.Форма2ТСтраница3["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "001"] = Контейнер.Форма2ТСтраница3["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "001"] + СтрокаТаблицы.ФактическаяЧисленностьРК;
								Контейнер.Форма2ТСтраница3["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "004"] = Контейнер.Форма2ТСтраница3["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "004"] + СтрокаТаблицы.ФактическаяЧисленностьЖенщинРК;
								
								Контейнер.Форма2ТСтраница3["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "002"] = Контейнер.Форма2ТСтраница3["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "002"] + СтрокаТаблицы.НачисленияДля1ТЗП/1000;
								Контейнер.Форма2ТСтраница3["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "005"] = Контейнер.Форма2ТСтраница3["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "005"] + СтрокаТаблицы.НачисленияЖенщинамДля1ТЗП/1000;
								
								Контейнер.Форма2ТСтраница3["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "003"] = ?(Контейнер.Форма2ТСтраница3["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "001"] <> 0, Контейнер.Форма2ТСтраница3["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "002"]*1000/Контейнер.Форма2ТСтраница3["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "001"], 0);
								Контейнер.Форма2ТСтраница3["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "006"] = ?(Контейнер.Форма2ТСтраница3["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "004"] <> 0, Контейнер.Форма2ТСтраница3["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "005"]*1000/Контейнер.Форма2ТСтраница3["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "004"], 0);
								
							КонецЕсли;
						КонецЦикла;
						Для НомерСтроки = 13 По 15 Цикл
							ИмяПользовательскогоПоляНомерСтроки = СоответствияПолейНомерамПользовательскихКолонок.Получить("СТР" + НомерСтроки);
							Если СтрокаТаблицы[ИмяПользовательскогоПоляНомерСтроки]= Строка(НомерСтроки) + "СТР" Тогда
								Контейнер.Форма2ТСтраница4["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "001"] = Контейнер.Форма2ТСтраница4["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "001"] + СтрокаТаблицы.ФактическаяЧисленностьРК;
								Контейнер.Форма2ТСтраница4["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "004"] = Контейнер.Форма2ТСтраница4["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "004"] + СтрокаТаблицы.ФактическаяЧисленностьЖенщинРК;
								
								Контейнер.Форма2ТСтраница4["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "002"] = Контейнер.Форма2ТСтраница4["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "002"] + СтрокаТаблицы.НачисленияДля1ТЗП/1000;
								Контейнер.Форма2ТСтраница4["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "005"] = Контейнер.Форма2ТСтраница4["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "005"] + СтрокаТаблицы.НачисленияЖенщинамДля1ТЗП/1000;
								
								Контейнер.Форма2ТСтраница4["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "003"] = ?(Контейнер.Форма2ТСтраница4["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "001"] <> 0, Контейнер.Форма2ТСтраница4["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "002"]*1000/Контейнер.Форма2ТСтраница4["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "001"], 0);
								Контейнер.Форма2ТСтраница4["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "006"] = ?(Контейнер.Форма2ТСтраница4["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "004"] <> 0, Контейнер.Форма2ТСтраница4["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "005"]*1000/Контейнер.Форма2ТСтраница4["П000001" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "004"], 0);
								
							КонецЕсли;
						КонецЦикла;
					КонецЦикла;
				ИначеЕсли НомерРаздела = 2 Тогда
					
					НомерСтроки = 1;
					Для Каждого СтрокаТаблицы Из Таблица  Цикл
						НоваяСтрокаСтр5 = Контейнер.Форма2ТСтраница5_ДанныеДопСтрок.Добавить();
						
						НоваяСтрокаСтр5.П000000200101 = НомерСтроки;
						НоваяСтрокаСтр5.П000000200102 = СтрокаТаблицы.НаименованиеПрофессии;
						
						НоваяСтрокаСтр5.П000000200103  = СтрокаТаблицы.ФактическаяЧисленностьРК;
						НоваяСтрокаСтр5.П000000200104  = СтрокаТаблицы.НачисленияДля1ТЗП/1000;
						НоваяСтрокаСтр5.П000000200105  = ?(СтрокаТаблицы.ФактическаяЧисленностьРК <> 0, СтрокаТаблицы.НачисленияДля1ТЗП/СтрокаТаблицы.ФактическаяЧисленностьРК, 0);
						
						НоваяСтрокаСтр5.П000000200106  = СтрокаТаблицы.ФактическаяЧисленностьЖенщинРК;
						НоваяСтрокаСтр5.П000000200107  = СтрокаТаблицы.НачисленияЖенщинамДля1ТЗП/1000;
						НоваяСтрокаСтр5.П000000200108  = ?(СтрокаТаблицы.ФактическаяЧисленностьЖенщинРК <> 0, СтрокаТаблицы.НачисленияЖенщинамДля1ТЗП/СтрокаТаблицы.ФактическаяЧисленностьЖенщинРК, 0);
						
						НомерСтроки = НомерСтроки + 1
					КонецЦикла;
					
				Иначе
					
					НомерСтроки = 1;
					Для Каждого СтрокаТаблицы Из Таблица  Цикл
						НоваяСтрокаСтр6 = Контейнер.Форма2ТСтраница6_ДанныеДопСтрок.Добавить();
						
						НоваяСтрокаСтр6.П000000300101 = НомерСтроки;
						НоваяСтрокаСтр6.П000000300102 = СтрокаТаблицы.НаименованиеЗанятия;
						НоваяСтрокаСтр6.П000000300103 = СтрокаТаблицы.КодЗанятия;
						
						НоваяСтрокаСтр6.П000000300104  = СтрокаТаблицы.ФактическаяЧисленностьРК;
						НоваяСтрокаСтр6.П000000300105  = СтрокаТаблицы.НачисленияДля1ТЗП/1000;
						НоваяСтрокаСтр6.П000000300106  = ?(СтрокаТаблицы.ФактическаяЧисленностьРК <> 0, СтрокаТаблицы.НачисленияДля1ТЗП/СтрокаТаблицы.ФактическаяЧисленностьРК, 0);
						
						НоваяСтрокаСтр6.П000000300107  = СтрокаТаблицы.ФактическаяЧисленностьЖенщинРК;
						НоваяСтрокаСтр6.П000000300108  = СтрокаТаблицы.НачисленияЖенщинамДля1ТЗП/1000;
						НоваяСтрокаСтр6.П000000300109  = ?(СтрокаТаблицы.ФактическаяЧисленностьЖенщинРК <> 0, СтрокаТаблицы.НачисленияЖенщинамДля1ТЗП/СтрокаТаблицы.ФактическаяЧисленностьЖенщинРК, 0);
						НомерСтроки = НомерСтроки + 1
					КонецЦикла;
					
				КонецЕсли;
			КонецЦикла;
		КонецЦикла; 
	КонецЕсли; 
		
КонецПроцедуры

Процедура ЗначенияПоказателей_СтатистикаФорма2ТПРОФ_2018Кв3(ПараметрыОтчета, Контейнер) Экспорт

	// Сведения для отчета берутся за последний квартал.
	ПараметрыОтчетаДляЗаполнения = ОбщегоНазначенияКлиентСервер.СкопироватьСтруктуру(ПараметрыОтчета);
	
	Год = Формат(ПараметрыОтчета.мДатаНачалаПериодаОтчета, "ДФ=гггг");
	Контейнер.Форма2ТСтраница1.Год1 = Сред(Год, 1, 1);
	Контейнер.Форма2ТСтраница1.Год2 = Сред(Год, 2, 1);
	Контейнер.Форма2ТСтраница1.Год3 = Сред(Год, 3, 1);
	Контейнер.Форма2ТСтраница1.Год4 = Сред(Год, 4, 1);
	
	СтрокаСведений = "ИННЮЛ, НаимЮЛПол, ФИОРук, ФИОБух, ОКВЭД, ОКАТО, АдрЮР, ПолныйАдрЮР, АдрФакт, ТелОрганизации, АдресЭлектроннойПочтыОрганизации, ОснВидДеят";
	СведенияОбОрганизации = РегламентированнаяОтчетностьВызовСервера.ПолучитьСведенияОбОрганизации(ПараметрыОтчета.Организация,,СтрокаСведений);
	
	Контейнер.Форма2ТСтраница7.НаимЮЛПол 	 = СведенияОбОрганизации.НаимЮЛПол;
	Контейнер.Форма2ТСтраница7.ФИОРук	 	 = СведенияОбОрганизации.ФИОРук;
	Контейнер.Форма2ТСтраница7.ФИОБух	 	 = СведенияОбОрганизации.ФИОБух;
	Контейнер.Форма2ТСтраница7.Исполнитель 	 = Пользователи.ТекущийПользователь();
	
	Если НЕ  ПараметрыОтчета.Организация.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо Тогда
		Контейнер.Форма2ТСтраница2.ОснВидДеят = СведенияОбОрганизации.ОснВидДеят;
		Контейнер.Форма2ТСтраница2.ОКВЭД1 = Сред(СведенияОбОрганизации.ОКВЭД, 1, 1);
		Контейнер.Форма2ТСтраница2.ОКВЭД2 = Сред(СведенияОбОрганизации.ОКВЭД, 2, 1);
		Контейнер.Форма2ТСтраница2.ОКВЭД3 = Сред(СведенияОбОрганизации.ОКВЭД, 3, 1);
		Контейнер.Форма2ТСтраница2.ОКВЭД4 = Сред(СведенияОбОрганизации.ОКВЭД, 4, 1);
		Контейнер.Форма2ТСтраница2.ОКВЭД5 = Сред(СведенияОбОрганизации.ОКВЭД, 5, 1);
		
		Контейнер.Форма2ТСтраница2.АдрФакт = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(ПараметрыОтчета.Организация, Справочники.ВидыКонтактнойИнформации.ФактАдресОрганизации, ПараметрыОтчета.мДатаКонцаПериодаОтчета);
		
		Контейнер.Форма2ТСтраница7.АдрЮР			= СведенияОбОрганизации.ПолныйАдрЮР;
		Контейнер.Форма2ТСтраница7.ТелОрганизации	= СведенияОбОрганизации.ТелОрганизации;
		Контейнер.Форма2ТСтраница7.ЭлПочта			= СведенияОбОрганизации.АдресЭлектроннойПочтыОрганизации;
	     // Код БИН
		ДлинаИИН = СтрДлина(СведенияОбОрганизации.ИННЮЛ);
		Если ДлинаИИН <= 12 Тогда
			Для Шаг = 1 По ДлинаИИН Цикл
				Контейнер.Форма2ТСтраница1["БИН" + Шаг] = СРЕД(СведенияОбОрганизации.ИННЮЛ, Шаг, 1);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;

	ИсключаемыеСостояния = Новый СписокЗначений;
