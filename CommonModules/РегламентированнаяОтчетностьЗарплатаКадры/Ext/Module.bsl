										ТекстСообщения = НСтр("ru = 'При заполнении приложения 200.02 для <%1> не задан код строки Декларации!'");								
										ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, Выборка.КодСтроки);			
										ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, Выборка.КодСтроки);

										НомерСтатьиНК = "";
										
									КонецЕсли;
									
									Если НЕ ПерваяСтрокаНеоблагаемыхДоходовЗаполнена Тогда
										
