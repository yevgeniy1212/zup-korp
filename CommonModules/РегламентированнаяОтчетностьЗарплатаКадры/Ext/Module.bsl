                        ПользовательскиеПоляПоле2 = СтрокаДетЗап.ПользовательскиеПоляПоле2;
                        ГодРождения = ?(СтрокаДетЗап.СотрудникФизическоеЛицоДатаРожденияЧастиДатГод = 1, "", СтрокаДетЗап.СотрудникФизическоеЛицоДатаРожденияЧастиДатГод);
                        ДатаПриемаНаРаботуЧастиДатМесяц = СтрокаДетЗап.ДатаПриемаНаРаботуЧастиДатМесяц;
                        ДатаПриемаНаРаботуЧастиДатГод = СтрокаДетЗап.ДатаПриемаНаРаботуЧастиДатГод;
                        КодЗанятия = СтрокаДетЗап.КодЗанятия;
                        НаименованиеЗанятия = СтрокаДетЗап.НаименованиеЗанятия;
                        ВидОбразования = СтрокаДетЗап.ВидОбразования;
                    КонецЦикла;
                    
                    НоваяСтрока.П000001004002 = СотрудникКод;
                    НоваяСтрока.П000001004003 = ПользовательскиеПоляПоле2;
                    НоваяСтрока.П000001004004 = ГодРождения;
                    НоваяСтрока.П000001004005 = ДатаПриемаНаРаботуЧастиДатМесяц;
                    НоваяСтрока.П000001004006 = ДатаПриемаНаРаботуЧастиДатГод;
                    НоваяСтрока.П000001004007 = КодЗанятия;
                    НоваяСтрока.П000001004008 = НаименованиеЗанятия;
                    НоваяСтрока.П000001004009 = ВидОбразования;
                    
                    СуммаОплаты = СтрокаФизЛицо.НачисленоВнешнимСовместителям2ТОплатаТруда + СтрокаФизЛицо.НачисленоВнутреннимСовместителям2ТОплатаТруда + СтрокаФизЛицо.Начисления2ТОплатаТрудаИтог;
                    НоваяСтрока.П000001004010 = СуммаОплаты;
                    НоваяСтрока.П000001004011 = ?(СтрокаФизЛицо.ГрафикРаботыНеполноеРабочееВремя = Истина, 2, 1);
                    НоваяСтрока.П000001004012 = СтрокаФизЛицо.ОтработаноЧасов;
                    // согласно правилам заполнения выводим сумму округленно
                    НоваяСтрока.П000001004013 = Окр(СуммаОплаты, -2);
                    
                КонецЦикла;                   
            КонецЕсли;
        КонецЦикла;
		
		Контейнер.Форма2ТСтраница3_ДанныеДопСтрок.Сортировать("П000001004002"); // табельный номер
		Для Каждого НумеруемаяСтрока Из Контейнер.Форма2ТСтраница3_ДанныеДопСтрок Цикл
			НумеруемаяСтрока.П000001004001 = НомерСтроки;
			НомерСтроки = НомерСтроки + 1;
		КонецЦикла;
		
		ФактическаяЧисленностьВсего 			 = (ФактическаяЧисленность + ОтработаноЧасовПоСокращенномуГрафику + ОтработаноЧасовСовместители);
		ФактическаяЧисленностьЖенщиныВсего 		 = (ФактическаяЧисленностьЖенщины  + ОтработаноЧасовПоСокращенномуГрафикуЖенщиныВт + ОтработаноЧасовСовместителиЖенщиныВт);
		
		Контейнер.Форма2ТСтраница2.ФактЧислРаб = ФактическаяЧисленностьВсего;
		Контейнер.Форма2ТСтраница2.ФактЧислРабЖен = ФактическаяЧисленностьЖенщиныВсего;
				
	КонецЕсли;
	
