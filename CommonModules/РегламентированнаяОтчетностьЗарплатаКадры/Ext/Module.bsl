		НоваяСтрокаСтр7.П000170000204 = НоваяСтрокаСтр4.П000140000203 - НоваяСтрокаСтр7.П000170000203 - НоваяСтрокаСтр4.П000140000205;
		
		НомерСтроки = НомерСтроки + 1;
		
