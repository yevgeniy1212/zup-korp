				Иначе
					Для Каждого СтрокаПериод Из СтрокаКодОКВЭД.Строки Цикл					
						ФОТСНачалаГодаВт = ФОТСНачалаГодаВт + СтрокаПериод.Начисления1ТГод;
						
						ФОТСНачалаГодаЖенщиныВт = ФОТСНачалаГодаЖенщиныВт + СтрокаПериод.НачисленияЖенщинам1ТГод;
						
						СреднесписочнаяСНачалаГодаВт 							 = СреднесписочнаяСНачалаГодаВт + СтрокаПериод.СреднесписочнаяЧисленностьРК;
						СреднесписочнаяСНачалаГодаЖенщиныВт						 = СреднесписочнаяСНачалаГодаЖенщиныВт + СтрокаПериод.СреднесписочнаяЧисленностьЖенщинРК;
						ФактическаяСНачалаГодаВт 								 = ФактическаяСНачалаГодаВт + СтрокаПериод.ФактическаяЧисленностьРК;
						ФактическаяСНачалаГодаЖенщиныВт							 = ФактическаяСНачалаГодаЖенщиныВт + СтрокаПериод.ФактическаяЧисленностьЖенщинРК;
						
						ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаВт 		 = ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаВт + СтрокаПериод.ОтработаноЧасовПоСокращенномуГрафику;
						ОтработаноЧасовСовместителиСНачалаГодаВт 		 		 = ОтработаноЧасовСовместителиСНачалаГодаВт + СтрокаПериод.ОтработаноЧасовСовместители;
						ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаЖенщиныВт = ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаЖенщиныВт + СтрокаПериод.ОтработаноЧасовПоСокращенномуГрафикуЖенщины;
						ОтработаноЧасовСовместителиСНачалаГодаЖенщиныВт		  	 = ОтработаноЧасовСовместителиСНачалаГодаЖенщиныВт + СтрокаПериод.ОтработаноЧасовСовместителиЖенщины;	
					КонецЦикла;	
					
					НаименованиеОКВЭДВт = СтрокаКодОКВЭД.НаименованиеОКВЭД;
					КодОКВЭДВт = СтрокаКодОКВЭД.КодОКВЭД;

					СреднесписочнаяСНачалаГодаВт		= СреднесписочнаяСНачалаГодаВт/НомерМесяцаКонцаПериода;
					СреднесписочнаяСНачалаГодаЖенщиныВт = СреднесписочнаяСНачалаГодаЖенщиныВт/НомерМесяцаКонцаПериода;
					
					ФактическаяСНачалаГодаВт 			= (ФактическаяСНачалаГодаВт + ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаВт + ОтработаноЧасовСовместителиСНачалаГодаВт)/НомерМесяцаКонцаПериода;
					ФактическаяСНачалаГодаЖенщиныВт 	= (ФактическаяСНачалаГодаЖенщиныВт + ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаЖенщиныВт + ОтработаноЧасовСовместителиСНачалаГодаЖенщиныВт)/НомерМесяцаКонцаПериода;
					
					СреднесписочнаяВсегоВт = СреднесписочнаяВсегоВт + СреднесписочнаяСНачалаГодаВт;
					ФактическаяВсегоВт = ФактическаяВсегоВт + ФактическаяСНачалаГодаВт;
					
				КонецЕсли;
				
				НоваяСтрока = Контейнер.Форма1ТСтраница3_ДанныеДопСтрок.Добавить();
				НомерСтрокиРаздела2 = НомерСтрокиРаздела2 + 0.1;
				НоваяСтрока.П000001004001 = НомерСтрокиРаздела2;
				НоваяСтрока.П000001004002 = НаименованиеОКВЭДВт;
				НоваяСтрока.П000001004003 = КодОКВЭДВт;
				НоваяСтрока.П000001004004 = ?(СреднесписочнаяСНачалаГодаВт > 0 И СреднесписочнаяСНачалаГодаВт < 1, 1, СреднесписочнаяСНачалаГодаВт);
				НоваяСтрока.П000001004005 = ?(СреднесписочнаяСНачалаГодаЖенщиныВт > 0 И СреднесписочнаяСНачалаГодаЖенщиныВт < 1, 1, СреднесписочнаяСНачалаГодаЖенщиныВт);
				НоваяСтрока.П000001004006 = ФактическаяСНачалаГодаВт;
				НоваяСтрока.П000001004007 = ФактическаяСНачалаГодаЖенщиныВт;
				НоваяСтрока.П000001004008 = Окр(ФОТСНачалаГодаВт/ 1000, 1);
				НоваяСтрока.П000001004009 = Окр(ФОТСНачалаГодаЖенщиныВт/ 1000, 1);
				НоваяСтрока.П000001004010 = ?(Окр(ФактическаяСНачалаГодаВт) = 0, 0, Окр(НоваяСтрока.П000001004008*1000/Окр(ФактическаяСНачалаГодаВт)/НомерМесяцаКонцаПериода));
				НоваяСтрока.П000001004011 = ?(Окр(ФактическаяСНачалаГодаЖенщиныВт) = 0, 0, Окр(НоваяСтрока.П000001004009*1000/Окр(ФактическаяСНачалаГодаЖенщиныВт)/НомерМесяцаКонцаПериода));	
				
					
				Для Каждого СтрокаПериод Из СтрокаКодОКВЭД.Строки Цикл
					
					ФОТСНачалаГода = ФОТСНачалаГода + СтрокаПериод.Начисления1ТГод;			
					ФОТСНачалаГодаЖенщины = ФОТСНачалаГодаЖенщины + СтрокаПериод.НачисленияЖенщинам1ТГод;

					ДанныеОтчетаТЗ = ПреобразоватьСтрокиДереваЗначенийВТаблицуЗначений(СтрокаПериод.Строки, ДанныеОтчета.Колонки);
						
					Для НомерРаздела = 2 По 4 Цикл
					
						Если НомерРаздела = 4 Тогда
							НомерРаздела = 7;
						КонецЕсли;
					    ИмяПользовательскогоПоляНомерТаблицы = СоответствияПолейНомерамПользовательскихКолонок.Получить("Раздел" + НомерРаздела);
						Отбор = Новый Структура(ИмяПользовательскогоПоляНомерТаблицы, Истина);
						Таблица = ДанныеОтчетаТЗ.Скопировать(Отбор);
						Таблица.Свернуть(СоответствияПолейГруппировкиНомерамРазделов.Получить(НомерРаздела), КолонкиСуммирования);
						
						Если НомерРаздела = 2 Тогда
						//Раздел 2.1
							Для Каждого СтрокаТаблицы Из Таблица Цикл
								ФОТСНачалаГодаАУП = ФОТСНачалаГодаАУП + СтрокаТаблицы.Начисления1ТГод;
								
								ФОТСНачалаГодаЖенщиныАУП = ФОТСНачалаГодаЖенщиныАУП + СтрокаТаблицы.НачисленияЖенщинам1ТГод;
								
								СреднесписочнаяСНачалаГодаАУП 						= СреднесписочнаяСНачалаГодаАУП + СтрокаТаблицы.СреднесписочнаяЧисленностьРК;
								СреднесписочнаяСНачалаГодаЖенщиныАУП 				= СреднесписочнаяСНачалаГодаЖенщиныАУП + СтрокаТаблицы.СреднесписочнаяЧисленностьЖенщинРК;
								ФактическаяСНачалаГодаАУП							= ФактическаяСНачалаГодаАУП + СтрокаТаблицы.ФактическаяЧисленностьРК;
								ФактическаяСНачалаГодаЖенщиныАУП					= ФактическаяСНачалаГодаЖенщиныАУП + СтрокаТаблицы.ФактическаяЧисленностьЖенщинРК;
								
								ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаАУП 	   		= ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаАУП + СтрокаТаблицы.ОтработаноЧасовПоСокращенномуГрафику;
								ОтработаноЧасовСовместителиСНачалаГодаАУП 		 		   	= ОтработаноЧасовСовместителиСНачалаГодаАУП + СтрокаТаблицы.ОтработаноЧасовСовместители;
								ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаЖенщиныАУП 	= ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаЖенщиныАУП + СтрокаТаблицы.ОтработаноЧасовПоСокращенномуГрафикуЖенщины;
								ОтработаноЧасовСовместителиСНачалаГодаЖенщиныАУП 		   	= ОтработаноЧасовСовместителиСНачалаГодаЖенщиныАУП + СтрокаТаблицы.ОтработаноЧасовСовместителиЖенщины;
								
							КонецЦикла;
														
							СреднесписочнаяСНачалаГода 					  = СреднесписочнаяСНачалаГода + СтрокаПериод.СреднесписочнаяЧисленностьРК;
							СреднесписочнаяСНачалаГодаЖенщины			  = СреднесписочнаяСНачалаГодаЖенщины + СтрокаПериод.СреднесписочнаяЧисленностьЖенщинРК;
							ФактическаяСНачалаГода						  = ФактическаяСНачалаГода + СтрокаПериод.ФактическаяЧисленностьРК;
							ФактическаяСНачалаГодаЖенщины				  = ФактическаяСНачалаГодаЖенщины + СтрокаПериод.ФактическаяЧисленностьЖенщинРК;
							
							ОтработаноЧасовПоСокращенномуГрафикуСНачалаГода 	   = ОтработаноЧасовПоСокращенномуГрафикуСНачалаГода + СтрокаПериод.ОтработаноЧасовПоСокращенномуГрафику;
							ОтработаноЧасовСовместителиСНачалаГода 		 		   = ОтработаноЧасовСовместителиСНачалаГода + СтрокаПериод.ОтработаноЧасовСовместители;
							ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаЖенщины = ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаЖенщины + СтрокаПериод.ОтработаноЧасовПоСокращенномуГрафикуЖенщины;
							ОтработаноЧасовСовместителиСНачалаГодаЖенщины		   = ОтработаноЧасовСовместителиСНачалаГодаЖенщины + СтрокаПериод.ОтработаноЧасовСовместителиЖенщины;
							
						ИначеЕсли НомерРаздела = 3 Тогда
							Для Каждого СтрокаТаблицы Из Таблица Цикл
								Для НомерСтроки = 2 По 7 Цикл
									ИмяПользовательскогоПоляНомерСтроки = СоответствияПолейНомерамПользовательскихКолонок.Получить("СТР" + (НомерСтроки-1));
									Если СтрокаТаблицы[ИмяПользовательскогоПоляНомерСтроки]= Строка(НомерСтроки-1) + "СТР" Тогда
										Контейнер.Форма1ТСтраница4["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "001"] = Контейнер.Форма1ТСтраница4["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "001"] + СтрокаТаблицы.СреднесписочнаяЧисленностьРК;
										Контейнер.Форма1ТСтраница4["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "002"] = Контейнер.Форма1ТСтраница4["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "002"] + СтрокаТаблицы.СреднесписочнаяЧисленностьЖенщинРК;
										
										Контейнер.Форма1ТСтраница4["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "003"] = Контейнер.Форма1ТСтраница4["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "003"] + СтрокаТаблицы.ФактическаяЧисленностьРК 
																															+ СтрокаТаблицы.ОтработаноЧасовПоСокращенномуГрафику + СтрокаТаблицы.ОтработаноЧасовСовместители;
										Контейнер.Форма1ТСтраница4["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "004"] = Контейнер.Форма1ТСтраница4["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "004"] + СтрокаТаблицы.ФактическаяЧисленностьЖенщинРК 
																															+ СтрокаТаблицы.ОтработаноЧасовПоСокращенномуГрафикуЖенщины + СтрокаТаблицы.ОтработаноЧасовСовместителиЖенщины;
										Контейнер.Форма1ТСтраница4["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "005"] = Контейнер.Форма1ТСтраница4["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "005"] + СтрокаТаблицы.Начисления1ТГод;
										Контейнер.Форма1ТСтраница4["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "006"] = Контейнер.Форма1ТСтраница4["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "006"] + СтрокаТаблицы.НачисленияЖенщинам1ТГод;		
									КонецЕсли;
								КонецЦикла;
								Для НомерСтроки = 8 По 11 Цикл
									ИмяПользовательскогоПоляНомерСтроки = СоответствияПолейНомерамПользовательскихКолонок.Получить("СТР" + (НомерСтроки-1));
									Если СтрокаТаблицы[ИмяПользовательскогоПоляНомерСтроки]= Строка(НомерСтроки-1) + "СТР" Тогда
										Контейнер.Форма1ТСтраница5["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "001"] = Контейнер.Форма1ТСтраница5["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "001"] + СтрокаТаблицы.СреднесписочнаяЧисленностьРК;
										Контейнер.Форма1ТСтраница5["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "002"] = Контейнер.Форма1ТСтраница5["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "002"] + СтрокаТаблицы.СреднесписочнаяЧисленностьЖенщинРК;
										
										Контейнер.Форма1ТСтраница5["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "003"] = Контейнер.Форма1ТСтраница5["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "003"] + СтрокаТаблицы.ФактическаяЧисленностьРК 
																																																			+ СтрокаТаблицы.ОтработаноЧасовПоСокращенномуГрафику 
																																																			+ СтрокаТаблицы.ОтработаноЧасовСовместители;
										Контейнер.Форма1ТСтраница5["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "004"] = Контейнер.Форма1ТСтраница5["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "004"] + СтрокаТаблицы.ФактическаяЧисленностьЖенщинРК 
																																																			+ СтрокаТаблицы.ОтработаноЧасовПоСокращенномуГрафикуЖенщины 
																																																			+ СтрокаТаблицы.ОтработаноЧасовСовместителиЖенщины;
										Контейнер.Форма1ТСтраница5["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "005"] = Контейнер.Форма1ТСтраница5["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "005"] + СтрокаТаблицы.Начисления1ТГод;
										Контейнер.Форма1ТСтраница5["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "006"] = Контейнер.Форма1ТСтраница5["П000003" + Формат(НомерСтроки,"ЧЦ=3; ЧВН=") + "006"] + СтрокаТаблицы.НачисленияЖенщинам1ТГод; 
										
									КонецЕсли;
								КонецЦикла;
							КонецЦикла;
							
						ИначеЕсли НомерРаздела = 7 Тогда
							Для Каждого СтрокаТаблицы Из Таблица Цикл
								Для НомерСтолбца = 1 По 3 Цикл
									ИмяПользовательскогоПоляНомерСтроки = СоответствияПолейНомерамПользовательскихКолонок.Получить("Образование" + НомерСтолбца);
									Если СтрокаТаблицы[ИмяПользовательскогоПоляНомерСтроки] = Строка(НомерСтолбца) + "Образование" Тогда
										Контейнер.Форма1ТСтраница7["П000007002" + Формат(НомерСтолбца+1,"ЧЦ=3; ЧВН=")] = Контейнер.Форма1ТСтраница7["П000007002" + Формат(НомерСтолбца+1,"ЧЦ=3; ЧВН=")] + СтрокаТаблицы.ПринятВПериоде;
										Контейнер.Форма1ТСтраница8["П000007007" + Формат(НомерСтолбца+1,"ЧЦ=3; ЧВН=")] = Контейнер.Форма1ТСтраница8["П000007007" + Формат(НомерСтолбца+1,"ЧЦ=3; ЧВН=")] + СтрокаТаблицы.ВыбылоЛиквидацияПредприятия
																																																		+ СтрокаТаблицы.ВыбылоНарушениеТрудовойДисциплины
																																																		+ СтрокаТаблицы.ВыбылоНесоответствиеДолжности
																																																		+ СтрокаТаблицы.ВыбылоОбстоятельстваНезависящиеОтВолиСторон
																																																		+ СтрокаТаблицы.ВыбылоПоДругимПричинам
																																																		+ СтрокаТаблицы.ВыбылоПосокращениюЧисленности
