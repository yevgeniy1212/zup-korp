							НоваяСтрокаСтр1.П000210000105 = ?(Выборка.СтатусНалогплательщика = Перечисления.СтатусыФизическихЛицНалогоплательщиков.Резидент, "1", "2");
							НоваяСтрокаСтр1.П000210000106 = ?(Выборка.СтатусНалогплательщика = Перечисления.СтатусыФизическихЛицНалогоплательщиков.Резидент, "KZ", Выборка.КодСтраны);
