#Область ПрограммныйИнтерфейс

#Область ПроцедурыИФункцииМеханизмаАтозаполнения

// Процедура заполняет переданную в виде контейнера структуру данных отчета.
//
// Пример:
//	Если ИДОтчета = "РегламентированныйОтчет210Форма" Тогда
//		Если ИДРедакцииОтчета = "ФормаОтчета2102016Кв1" Тогда
//			ЗаполнитьФорма2102016Кв1(ПараметрыОтчета, Контейнер);
//		КонецЕсли;
//	КонецЕсли;
//
Процедура ЗаполнитьОтчетЗарплатаКадры(ИДОтчета, ИДРедакцииОтчета, ПараметрыОтчета, Контейнер) Экспорт
	
	Если ИДОтчета = "РегламентированныйОтчет200Форма" Тогда
		
		Если ИДРедакцииОтчета = "ФормаОтчета2002016Кв1" Тогда
			
			ЗаполнитьФорма2002016Кв1(ПараметрыОтчета, Контейнер);
			
		ИначеЕсли ИДРедакцииОтчета = "ФормаОтчета2002017Кв1" Тогда
			
			ЗаполнитьФорма2002017Кв1(ПараметрыОтчета, Контейнер);
			
		ИначеЕсли ИДРедакцииОтчета = "ФормаОтчета2002018Кв1" Тогда
			
			ЗаполнитьФорма2002018Кв1(ПараметрыОтчета, Контейнер);
			
		ИначеЕсли ИДРедакцииОтчета = "ФормаОтчета2002019Кв1" Тогда
			
			ЗаполнитьФорма2002019Кв1(ПараметрыОтчета, Контейнер);
					
		ИначеЕсли ИДРедакцииОтчета = "ФормаОтчета2002019Кв4" Тогда
			
			ЗаполнитьФорма2002019Кв4(ПараметрыОтчета, Контейнер);
			
		ИначеЕсли ИДРедакцииОтчета = "ФормаОтчета2002020Кв1" Тогда
			
			Если ПараметрыОтчета.мДатаНачалаПериодаОтчета >= '20200701' Тогда 
				ЗаполнитьФорма2002020Кв3(ПараметрыОтчета, Контейнер);
			Иначе
				ЗаполнитьФорма2002020Кв1(ПараметрыОтчета, Контейнер);
			КонецЕсли;
					
		ИначеЕсли ИДРедакцииОтчета = "ФормаОтчета2002021Кв1" 
			ИЛИ ИДРедакцииОтчета = "ФормаОтчета2002022Кв3" Тогда
			
			ЗаполнитьФорма2002021Кв1(ПараметрыОтчета, Контейнер);
			
		ИначеЕсли ИДРедакцииОтчета = "ФормаОтчета2002023Кв1" Тогда
			
			Если ПараметрыОтчета.мДатаНачалаПериодаОтчета >= '20250101' Тогда
				ЗаполнитьФорма2002025Кв1(ПараметрыОтчета, Контейнер);
			Иначе
				ЗаполнитьФорма2002023Кв1(ПараметрыОтчета, Контейнер);
			КонецЕсли;
            
        КонецЕсли;
		
	ИначеЕсли ИДОтчета = "РегламентированныйОтчет210Форма" Тогда
		
		Если ИДРедакцииОтчета = "ФормаОтчета2102016Кв1" Тогда
			
			ЗаполнитьФорма2102016Кв1(ПараметрыОтчета, Контейнер);
			
		КонецЕсли;
		
	ИначеЕсли ИДОтчета = "РегламентированныйОтчетСтатистика1ТКвартальная" Тогда
		
		Если ИДРедакцииОтчета = "ФормаОтчета1Т2017Кв1" Тогда
			
			ЗначенияПоказателей_СтатистикаФорма1ТКвартальная_2017Кв1(ПараметрыОтчета, Контейнер);
			
		ИначеЕсли ИДРедакцииОтчета = "ФормаОтчета1Т2018Кв1" Тогда
			
			ЗначенияПоказателей_СтатистикаФорма1ТКвартальная_2018Кв1(ПараметрыОтчета, Контейнер);
			
		ИначеЕсли ИДРедакцииОтчета = "ФормаОтчета1Т2019Кв1" Тогда
			
			ЗначенияПоказателей_СтатистикаФорма1ТКвартальная_2019Кв1(ПараметрыОтчета, Контейнер);
			
		ИначеЕсли ИДРедакцииОтчета = "ФормаОтчета1Т2020Кв1" 
			ИЛИ ИДРедакцииОтчета = "ФормаОтчета1Т2020Кв3" Тогда
			
			ЗначенияПоказателей_СтатистикаФорма1ТКвартальная_2020Кв1(ПараметрыОтчета, Контейнер);
			
		ИначеЕсли ИДРедакцииОтчета = "ФормаОтчета1Т2021Кв4" Тогда
			
			ЗначенияПоказателей_СтатистикаФорма1ТКвартальная_2021Кв4(ПараметрыОтчета, Контейнер);
			
		КонецЕсли;
		
	ИначеЕсли ИДОтчета = "РегламентированныйОтчетСтатистика1ТЗП" Тогда
		
		Если ИДРедакцииОтчета = "ФормаОтчета1Т2017Кв1" Тогда
			
			ЗначенияПоказателей_СтатистикаФорма1ТЗП_2017Кв1(ПараметрыОтчета, Контейнер);
			
		КонецЕсли;
		
	ИначеЕсли ИДОтчета = "РегламентированныйОтчетСтатистика2ТПРОФ" Тогда
		
		Если ИДРедакцииОтчета = "ФормаОтчета2ТПРОФ2017Кв3" Тогда
			
			ЗначенияПоказателей_СтатистикаФорма2ТПРОФ_2017Кв3(ПараметрыОтчета, Контейнер);
			
		ИначеЕсли ИДРедакцииОтчета = "ФормаОтчета2ТПРОФ2018Кв3" Тогда
			
			ЗначенияПоказателей_СтатистикаФорма2ТПРОФ_2018Кв3(ПараметрыОтчета, Контейнер);
			
		КонецЕсли;
		
	ИначеЕсли ИДОтчета = "РегламентированныйОтчетСтатистика1ТГодовая" Тогда
		
		Если ИДРедакцииОтчета = "ФормаОтчета1Т2019Кв1" Тогда
			
			ЗначенияПоказателей_СтатистикаФорма1ТГодовая_2019Кв1(ПараметрыОтчета, Контейнер);
			
		ИначеЕсли ИДРедакцииОтчета = "ФормаОтчета1Т2020Кв1"
			ИЛИ ИДРедакцииОтчета = "ФормаОтчета1Т2020Кв3" Тогда
			
			ЗначенияПоказателей_СтатистикаФорма1ТГодовая_2020Кв1(ПараметрыОтчета, Контейнер);
			
		ИначеЕсли ИДРедакцииОтчета = "ФормаОтчета1Т2021Кв4" Тогда
			
			ЗначенияПоказателей_СтатистикаФорма1ТГодовая_2021Кв4(ПараметрыОтчета, Контейнер);
			
		ИначеЕсли ИДРедакцииОтчета = "ФормаОтчета1Т2022Кв4" Тогда
			
            ЗначенияПоказателей_СтатистикаФорма1ТГодовая_2022Кв4(ПараметрыОтчета, Контейнер);    
        
		ИначеЕсли ИДРедакцииОтчета = "ФормаОтчета1Т2025Кв1" Тогда
			
			ЗначенияПоказателей_СтатистикаФорма1ТГодовая_2025Кв1(ПараметрыОтчета, Контейнер);
			
        КонецЕсли;   	
        
    ИначеЕсли ИДОтчета = "РегламентированныйОтчетСтатистика2ТОплатаТруда" Тогда
		
		Если ИДРедакцииОтчета = "ФормаОтчета2Т2022Кв1" Тогда
			
			ЗначенияПоказателей_СтатистикаФорма2ТОплатаТруда_2022Кв1(ПараметрыОтчета, Контейнер);
			
		ИначеЕсли ИДРедакцииОтчета = "ФормаОтчета2Т2025Кв1" Тогда
			
			ЗначенияПоказателей_СтатистикаФорма2ТОплатаТруда_2025Кв1(ПараметрыОтчета, Контейнер);
            
        КонецЕсли;
        
	КонецЕсли;
	
КонецПроцедуры

#Область Форма200

Процедура ЗаполнитьФорма2002016Кв1(ПараметрыОтчета, Контейнер) Экспорт
	
	Начало1Мес = НачалоМесяца(ПараметрыОтчета.мДатаНачалаПериодаОтчета);
	Начало2Мес = ДобавитьМесяц(Начало1Мес, 1);
	Начало3Мес = ДобавитьМесяц(Начало2Мес, 1);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("парамПериодС", 				              НачалоМесяца(ПараметрыОтчета.мДатаНачалаПериодаОтчета));
	Запрос.УстановитьПараметр("парамПериодПо", 				              КонецМесяца(ПараметрыОтчета.мДатаКонцаПериодаОтчета));
	Запрос.УстановитьПараметр("парамПослеПериодПо", 		              КонецМесяца(ПараметрыОтчета.мДатаКонцаПериодаОтчета) + 1);
	Запрос.УстановитьПараметр("парамОрганизация",	 		              ПараметрыОтчета.Организация);
	Запрос.УстановитьПараметр("парамСписокСтруктурныхЕдиниц",             ПараметрыОтчета.СписокСтруктурныхединиц);
	Запрос.УстановитьПараметр("парамНалоговыйКомитетГоловнойОрганизации", ПараметрыОтчета.Организация.РегистрацияВНалоговомОргане);
	
	ВидыОсобыхНачисленийУдержаний = Новый Массив;
	ВидыОсобыхНачисленийУдержаний.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.КомпенсацияЗаЗадержкуЗарплаты);
	ВидыОсобыхНачисленийУдержаний.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ПогашениеЗаймаИзЗарплаты);
	ВидыОсобыхНачисленийУдержаний.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ПроцентыПоЗайму);
	ВидыОсобыхНачисленийУдержаний.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.МатериальнаяВыгодаПоЗаймам);
	Запрос.УстановитьПараметр("ВидыОсобыхНачисленийУдержаний",             ВидыОсобыхНачисленийУдержаний);
	
	ВидыОперацийИПН = Новый Массив;
	ВидыОперацийИПН.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ИПН);
	ВидыОперацийИПН.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ИПНДоходыКонтрагентов);
	ВидыОперацийИПН.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ИПНРасчетыСБывшимиСотрудниками);
	Запрос.УстановитьПараметр("ВидыОперацийИПН", ВидыОперацийИПН);

	РегистрацияГоловнойОрганизации = РегламентированнаяОтчетностьРК.РегистрацияВНалоговомОргане(ПараметрыОтчета.Организация,КонецМесяца(ПараметрыОтчета.мДатаКонцаПериодаОтчета));
	
	Запрос.УстановитьПараметр("парамРегистрацияГоловнойОрганизации", РегистрацияГоловнойОрганизации);
	
	// Если налогоплательщик - ИП, то исключим данные самого индивидуального предпринимателя.
	Если РегламентированнаяОтчетностьРК.ИндивидуальныйПредприниматель(ПараметрыОтчета.Организация) Тогда
		Запрос.УстановитьПараметр("парамИндивидуальныйПредприниматель", ПараметрыОтчета.Организация.ИндивидуальныйПредприниматель);
	Иначе
		Запрос.УстановитьПараметр("парамИндивидуальныйПредприниматель", Неопределено);
	КонецЕсли;
	
	СтрокаСведений = "ИННЮЛ, НаимЮЛПол, ФИОРук";
	СведенияОбОрганизации = РегламентированнаяОтчетностьВызовСервера.ПолучитьСведенияОбОрганизации(ПараметрыОтчета.Организация,,СтрокаСведений);
	СтрПериодОтчета = ПредставлениеПериода(ПараметрыОтчета.мДатаНачалаПериодаОтчета,ПараметрыОтчета.мДатаКонцаПериодаОтчета, "ФП = истина");
	
	Квартал = Лев(СтрПериодОтчета,1);
	Год		= Лев(Прав(СтрПериодОтчета,7),4);

	Контейнер.Форма200Страница2.ИИН_БИН = СведенияОбОрганизации.ИННЮЛ;
	Контейнер.Форма200Страница3.ИИН_БИН = СведенияОбОрганизации.ИННЮЛ;
	Контейнер.Форма200_01Страница1.ИИН_БИН = СведенияОбОрганизации.ИННЮЛ;
	Контейнер.Форма200_01Страница2.ИИН_БИН = СведенияОбОрганизации.ИННЮЛ;
	Контейнер.Форма200Страница2.Квартал = Квартал;
	Контейнер.Форма200Страница3.Квартал = Квартал;
	Контейнер.Форма200Страница3.Руководитель = СведенияОбОрганизации.ФИОРук;
	Контейнер.Форма200Страница3.ДатаПодачи = ТекущаяДата();
	Контейнер.Форма200Страница3.КодНалоговогоОрганаИПН = РегистрацияГоловнойОрганизации.Код;
	Контейнер.Форма200Страница3.КодНалоговогоОрганаОПВиСО = РегистрацияГоловнойОрганизации.Код;
	Контейнер.Форма200_01Страница1.Квартал = Квартал;
	Контейнер.Форма200_01Страница2.Квартал = Квартал;
	Контейнер.Форма200Страница2.Год = Год;
	Контейнер.Форма200Страница3.Год = Год;
	Контейнер.Форма200_01Страница1.Год = Год;
	Контейнер.Форма200_01Страница2.Год = Год;

	МТ = Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц = МТ;
	
	Запрос.Текст = "ВЫБРАТЬ
	|	Организации.Ссылка
	|ПОМЕСТИТЬ ВТ_СписокОрганизаций
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	Организации.ГоловнаяОрганизация = &парамОрганизация
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	&парамОрганизация
	|";
	Запрос.Выполнить();
	
	Запрос.Текст = "
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НАЧАЛОПЕРИОДА(ДанныеПроизводственногоКалендаря.Дата, МЕСЯЦ) КАК Период
	|ПОМЕСТИТЬ ВТ_ДатыПериодовГода
	|ИЗ
	|	РегистрСведений.ДанныеПроизводственногоКалендаря КАК ДанныеПроизводственногоКалендаря
	|ГДЕ
	|	ДанныеПроизводственногоКалендаря.Дата МЕЖДУ &парамПериодС И &парамПериодПо
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ГражданствоФизЛицСрезПоследних.Период КАК Период,
	|	ГражданствоФизЛицСрезПоследних.ФИО КАК ФИО,
	|	ВЫБОР
	|		КОГДА ГражданствоФизЛиц.Страна ЕСТЬ NULL 
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.СтраныМира.Казахстан)
	|		ИНАЧЕ ГражданствоФизЛиц.Страна
	|	КОНЕЦ КАК Страна
	|ПОМЕСТИТЬ ВТ_Гражданство
	|ИЗ
	|	(ВЫБРАТЬ
	|		Периоды.Период КАК Период,
	|		Периоды.ФИО КАК ФИО,
	|		МАКСИМУМ(ГражданствоФизЛиц.Период) КАК ПериодСреза
	|	ИЗ
	|		(ВЫБРАТЬ
	|			Периоды.Период КАК Период,
	|			ФизическиеЛица.Ссылка КАК ФИО
	|		ИЗ
	|			ВТ_ДатыПериодовГода КАК Периоды
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизическиеЛица
	|				ПО (ИСТИНА)
	|		ГДЕ
	|			ФизическиеЛица.ЭтоГруппа = ЛОЖЬ) КАК Периоды
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГражданствоФизическихЛиц КАК ГражданствоФизЛиц
	|			ПО (Периоды.Период >= НАЧАЛОПЕРИОДА(ГражданствоФизЛиц.Период, МЕСЯЦ))
	|				И Периоды.ФИО = ГражданствоФизЛиц.ФизическоеЛицо
	|	
	|	СГРУППИРОВАТЬ ПО
	|		Периоды.Период,
	|		Периоды.ФИО) КАК ГражданствоФизЛицСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГражданствоФизическихЛиц КАК ГражданствоФизЛиц
	|		ПО ГражданствоФизЛицСрезПоследних.ПериодСреза = ГражданствоФизЛиц.Период
	|			И ГражданствоФизЛицСрезПоследних.ФИО = ГражданствоФизЛиц.ФизическоеЛицо
	|ГДЕ
	|	ВЫБОР
	|			КОГДА ГражданствоФизЛиц.Страна ЕСТЬ NULL 
	|				ТОГДА ЗНАЧЕНИЕ(Справочник.СтраныМира.Казахстан)
	|			ИНАЧЕ ГражданствоФизЛиц.Страна
	|		КОНЕЦ = ЗНАЧЕНИЕ(Справочник.СтраныМира.Казахстан)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Период,
	|	ФИО";
	
	Запрос.Выполнить();
	
	// Определим гражданство на конец квартала (конец даты отчета).
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ГражданствоФЛ.Ссылка КАК ФизЛицо,
	|	ВЫБОР
	|		КОГДА ГражданствоФЛ.Страна ЕСТЬ NULL 
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.СтраныМира.Казахстан)
	|		ИНАЧЕ ГражданствоФЛ.Страна
	|	КОНЕЦ КАК Страна
	|ИЗ
	|	(ВЫБРАТЬ
	|		ФизическиеЛица.Ссылка КАК Ссылка,
	|		ГражданствоФизЛицСрезПоследних.ФизическоеЛицо КАК ФизЛицо,
	|		ВЫБОР
	|			КОГДА ГражданствоФизЛицСрезПоследних.Страна ЕСТЬ NULL 
	|				ТОГДА ЗНАЧЕНИЕ(Справочник.СтраныМира.Казахстан)
	|			ИНАЧЕ ГражданствоФизЛицСрезПоследних.Страна
	|		КОНЕЦ КАК Страна
	|	ИЗ
