				НазФилиала = Сред(ВыборкаОрганизации.Наименование, НачПозиция, ДлинаСтроки); 
				Контейнер.Форма210_02[НомерЛиста].Страница1[0].Значение.Вставить(("ФилиалНазв"+Шаг),НазФилиала);
				НачПозиция =НачПозиция + ДлинаСтроки;
				ДлинаСтроки = 36;
			КонецЦикла;
			
			Контейнер.Форма210_02[НомерЛиста].Страница1[0].Значение.Вставить("ИИН_БИНФилиала",           ВыборкаОрганизации.ИИН);
			Контейнер.Форма210_02[НомерЛиста].Страница1[0].Значение.Вставить("КНОНалогоплательщика",     ВыборкаОрганизации.КодНалОргана);
			Контейнер.Форма210_02[НомерЛиста].Страница1[0].Значение.Вставить("КНОФилиала",               ВыборкаОрганизации.КодНалОргана);
			Контейнер.Форма210_02[НомерЛиста].Страница2[0].Значение.Вставить("КодНалоговогоОрганаИПН",   ВыборкаОрганизации.КодНалОргана);
			Контейнер.Форма210_02[НомерЛиста].Страница2[0].Значение.Вставить("КодНалоговогоОрганаОПВиСО",ВыборкаОрганизации.КодНалОргана);
			Контейнер.Форма210_02[НомерЛиста].Страница1[0].Значение.Вставить("Очередная","Х");
			Контейнер.Форма210_02[НомерЛиста].Страница1[0].Значение.Вставить("ИИН_БИН",СведенияОбОрганизации.ИННЮЛ);
			Контейнер.Форма210_02[НомерЛиста].Страница2[0].Значение.Вставить("ИИН_БИН",СведенияОбОрганизации.ИННЮЛ);
			Контейнер.Форма210_02[НомерЛиста].Страница1[0].Значение.Вставить("Квартал",Квартал);
			Контейнер.Форма210_02[НомерЛиста].Страница2[0].Значение.Вставить("Квартал",Квартал);
			Контейнер.Форма210_02[НомерЛиста].Страница1[0].Значение.Вставить("Год",Год);
			Контейнер.Форма210_02[НомерЛиста].Страница2[0].Значение.Вставить("Год",Год);
			Контейнер.Форма210_02[НомерЛиста].Страница2[0].Значение.Вставить("Руководитель",СведенияОбОрганизации.ФИОРук);
			Контейнер.Форма210_02[НомерЛиста].Страница2[0].Значение.Вставить("ДатаПодачи",ТекущаяДата());
			
			Пока Выборка.Следующий() Цикл
				
				Если Выборка.МесяцНалоговогоПериода = Начало1Мес Тогда
					Если Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ИПН Тогда
						Контейнер.Форма210_02[НомерЛиста].Страница1[0].Значение.Вставить("П000210001101",Окр(Выборка.НалогВзнос));
					ИначеЕсли Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ОПВ Тогда
						Контейнер.Форма210_02[НомерЛиста].Страница1[0].Значение.Вставить("П000210002101",Окр(Выборка.НалогВзнос));
					ИначеЕсли Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ОППВ Тогда
						Контейнер.Форма210_02[НомерЛиста].Страница1[0].Значение.Вставить("П000210003101",Окр(Выборка.НалогВзнос));
					ИначеЕсли Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.СН Тогда
						Контейнер.Форма210_02[НомерЛиста].Страница2[0].Значение.Вставить("П000220004101",Окр(Выборка.НалогВзнос));
					ИначеЕсли Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.СО Тогда
						Контейнер.Форма210_02[НомерЛиста].Страница2[0].Значение.Вставить("П000220005101",Окр(Выборка.НалогВзнос));
					КонецЕсли;
				ИначеЕсли Выборка.МесяцНалоговогоПериода = Начало2Мес Тогда
					Если Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ИПН Тогда
						Контейнер.Форма210_02[НомерЛиста].Страница1[0].Значение.Вставить("П000210001201",Окр(Выборка.НалогВзнос));
					ИначеЕсли Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ОПВ Тогда
						Контейнер.Форма210_02[НомерЛиста].Страница1[0].Значение.Вставить("П000210002201",Окр(Выборка.НалогВзнос));
					ИначеЕсли Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ОППВ Тогда
						Контейнер.Форма210_02[НомерЛиста].Страница1[0].Значение.Вставить("П000210003201",Окр(Выборка.НалогВзнос));
					ИначеЕсли Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.СН Тогда
						Контейнер.Форма210_02[НомерЛиста].Страница2[0].Значение.Вставить("П000220004201",Окр(Выборка.НалогВзнос));
					ИначеЕсли Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.СО Тогда
						Контейнер.Форма210_02[НомерЛиста].Страница2[0].Значение.Вставить("П000220005201",Окр(Выборка.НалогВзнос));
					КонецЕсли;
				ИначеЕсли Выборка.МесяцНалоговогоПериода = Начало3Мес Тогда
					Если Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ИПН Тогда
						Контейнер.Форма210_02[НомерЛиста].Страница1[0].Значение.Вставить("П000210001301",Окр(Выборка.НалогВзнос));
					ИначеЕсли Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ОПВ Тогда
						Контейнер.Форма210_02[НомерЛиста].Страница1[0].Значение.Вставить("П000210002301",Окр(Выборка.НалогВзнос));
					ИначеЕсли Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.ОППВ Тогда
						Контейнер.Форма210_02[НомерЛиста].Страница1[0].Значение.Вставить("П000210003301",Окр(Выборка.НалогВзнос));
					ИначеЕсли Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.СН Тогда
						Контейнер.Форма210_02[НомерЛиста].Страница2[0].Значение.Вставить("П000220004301",Окр(Выборка.НалогВзнос));
					ИначеЕсли Выборка.ВидНалогаВзносаОтчисления = Перечисления.ВидыНалоговВзносовОтчислений.СО Тогда
						Контейнер.Форма210_02[НомерЛиста].Страница2[0].Значение.Вставить("П000220005301",Окр(Выборка.НалогВзнос));
					КонецЕсли;
					
				КонецЕсли;
				
			КонецЦикла;
			
			НомерЛиста = НомерЛиста + 1;
			
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область Форма1ТКвартальная

Процедура ЗначенияПоказателей_СтатистикаФорма1ТКвартальная_2017Кв1(ПараметрыОтчета, Контейнер) Экспорт

	// Сведения для отчета берутся за последний квартал.
	ПараметрыОтчетаДляЗаполнения = ОбщегоНазначенияКлиентСервер.СкопироватьСтруктуру(ПараметрыОтчета);
	
	Квартал = Формат(ПараметрыОтчета.мДатаНачалаПериодаОтчета, "ДФ=к");
	Контейнер.Форма1ТСтраница1.Квартал1 = "0";
	Контейнер.Форма1ТСтраница1.Квартал2 = Квартал;
	
	Год = Формат(ПараметрыОтчета.мДатаНачалаПериодаОтчета, "ДФ=гггг");
	Контейнер.Форма1ТСтраница1.Год1 = Сред(Год, 1, 1);
	Контейнер.Форма1ТСтраница1.Год2 = Сред(Год, 2, 1);
	Контейнер.Форма1ТСтраница1.Год3 = Сред(Год, 3, 1);
	Контейнер.Форма1ТСтраница1.Год4 = Сред(Год, 4, 1);
	
	СтрокаСведений = "ИННЮЛ, НаимЮЛПол, ФИОРук, ФИОБух, ОКВЭД, ОКАТО, ПолныйАдрЮР, АдрФакт, АдрФактСтат, ТелОрганизации, АдресЭлектроннойПочтыОрганизации, ОснВидДеят";
	СведенияОбОрганизации = РегламентированнаяОтчетностьВызовСервера.ПолучитьСведенияОбОрганизации(ПараметрыОтчета.Организация,,СтрокаСведений);
	
	Контейнер.Форма1ТСтраница2.АдрФакт 	 	 = СведенияОбОрганизации.АдрФактСтат;
	Контейнер.Форма1ТСтраница2.НаимОКЭД		 = СведенияОбОрганизации.ОснВидДеят;
	Контейнер.Форма1ТСтраница4.НаимЮЛПол	 = СведенияОбОрганизации.НаимЮЛПол;
	Контейнер.Форма1ТСтраница4.ФИОРук	 	 = СведенияОбОрганизации.ФИОРук;
	Контейнер.Форма1ТСтраница4.ФИОБух	 	 = СведенияОбОрганизации.ФИОБух;
	Контейнер.Форма1ТСтраница4.Исполнитель 	 = Пользователи.ТекущийПользователь();
	
	Если НЕ  ПараметрыОтчета.Организация.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо Тогда
		Контейнер.Форма1ТСтраница4.АдрЮР			= СведенияОбОрганизации.ПолныйАдрЮР;
		Контейнер.Форма1ТСтраница4.ТелОрганизации	= СведенияОбОрганизации.ТелОрганизации;
		Контейнер.Форма1ТСтраница4.ЭлПочта			= СведенияОбОрганизации.АдресЭлектроннойПочтыОрганизации;
	     // Код БИН
		ДлинаИИН = СтрДлина(СведенияОбОрганизации.ИННЮЛ);
		Если ДлинаИИН <= 12 Тогда
			Для Шаг = 1 По ДлинаИИН Цикл
				Контейнер.Форма1ТСтраница1["БИН" + Шаг] = СРЕД(СведенияОбОрганизации.ИННЮЛ, Шаг, 1);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	// Код КАТО     
	КодКАТО = Лев(СведенияОбОрганизации.ОКАТО,10); // длина кода всего 9 символов, добавим 10-й
	ДлинаКАТО = СтрДлина(КодКАТО); 
	Если ДлинаКАТО <= 10 Тогда
		Для Шаг = 1 По ДлинаКАТО Цикл
			Контейнер.Форма1ТСтраница2["КодКАТО" + Шаг] = СРЕД(КодКАТО, Шаг, 1);
		КонецЦикла;
	КонецЕсли;
	// Код по ОКЭД
	ДлинаКодПоОКЭД = СтрДлина(СведенияОбОрганизации.ОКВЭД);
	Если ДлинаКодПоОКЭД <= 5 Тогда
		Для Шаг = 1 По ДлинаКодПоОКЭД Цикл
			Контейнер.Форма1ТСтраница2["КодПоОКЭД" + Шаг] = СРЕД(СведенияОбОрганизации.ОКВЭД, Шаг, 1);
		КонецЦикла;
	КонецЕсли;
	
	ИсключаемыеСостояния = Новый СписокЗначений;
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускПоБеременностиИРодам);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускПоУходуЗаРебенком);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускНеоплачиваемыйПоЗаконодательству);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускНеоплачиваемыйПоРазрешениюРаботодателя);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ДополнительныйОтпускНеоплачиваемый);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускУчебныйНеоплачиваемый);

	// Получение зарплатных данных отчета за квартал
	ДанныеОтчета = Новый ДеревоЗначений;
	ПараметрыОтчетаДляЗаполнения.Вставить("ДатаНачалаПериодаВыборки", НачалоКвартала(ПараметрыОтчета.мДатаКонцаПериодаОтчета));
	ПараметрыОтчетаДляЗаполнения.Вставить("ИсключаемыеСостояния", ИсключаемыеСостояния);  
	ПараметрыОтчетаДляЗаполнения.Вставить("КодОКВЭД", СведенияОбОрганизации.ОКВЭД);
	ДанныеДляЗаполненияРегламентированнойОтчетностиЗарплатаКадры("РегламентированныйОтчетСтатистикаФорма1Т", ПараметрыОтчетаДляЗаполнения, ДанныеОтчета);
	
	ФОТЗаКвартал = 0;
	ФОТЗаКварталОсн = 0;
	ОтработаноЧасовЗаКвартал = 0;
	СреднесписочнаяЗаКвартал = 0;
	СреднесписочнаяЗаКварталОсн = 0;
	ФактическаяЗаКвартал = 0;
	ФактическаяЗаКварталОсн = 0;
	ОтработаноЧасовПоСокращенномуГрафикуЗаКвартал = 0;
	ОтработаноЧасовСовместителиЗаКвартал = 0;
	ОтработаноЧасовПоСокращенномуГрафикуЗаКварталОсн = 0;
	ОтработаноЧасовСовместителиЗаКварталОсн = 0;
	ПринятоЗаКвартал = 0;
	ВыбылоЛиквидацияПредприятия = 0;
	ВыбылоНарушениеТрудовойДисциплины = 0;
	ВыбылоНесоответствиеДолжности = 0;
	ВыбылоОбстоятельстваНезависящиеОтВолиСторон = 0;
	ВыбылоПоДругимПричинам = 0;
	ВыбылоПоСобственномуЖеланию = 0;
	ВыбылоПосокращениюЧисленности = 0;
	ЧисленностьНеполнаяРабочаяНеделя = 0;
	Простой = 0;
	Если ДанныеОтчета <> Неопределено Тогда

		Для Каждого СтрокаОрганизация Из ДанныеОтчета.Строки Цикл
			
			Простой = Простой + СтрокаОрганизация.Простой;
			ЧисленностьНеполнаяРабочаяНеделя = ЧисленностьНеполнаяРабочаяНеделя + СтрокаОрганизация.ЧисленностьНеполнаяРабочаяНеделя;

			Для Каждого СтрокаПериод Из СтрокаОрганизация.Строки Цикл
				
				ФОТЗаКвартал = ФОТЗаКвартал + (СтрокаПериод.НачисленоРаботникамСписочногоСостава
											+ СтрокаПериод.НачисленоВнутреннимСовместителям
											+ СтрокаПериод.НачисленоВнешнимСовместителям);
				
				ФОТЗаКварталОсн = ФОТЗаКварталОсн + (СтрокаПериод.НачисленоРаботникамСписочногоСоставаОсн
													+ СтрокаПериод.НачисленоВнутреннимСовместителямОсн
													+ СтрокаПериод.НачисленоВнешнимСовместителямОсн); 
				
				ОтработаноЧасовЗаКвартал = ОтработаноЧасовЗаКвартал + (СтрокаПериод.ОтработаноЧасовСНачалаГодаРаботникамиСписочногоСостава
																	+ СтрокаПериод.ОтработаноЧасовСНачалаГодаВнешнимиСовместителями);
				
				СреднесписочнаяЗаКвартал 						 = СреднесписочнаяЗаКвартал + СтрокаПериод.СреднесписочнаяЧисленностьРК;
				СреднесписочнаяЗаКварталОсн 					 = СреднесписочнаяЗаКварталОсн + СтрокаПериод.СреднесписочнаяЧисленностьОснРК;
				ФактическаяЗаКвартал 							 = ФактическаяЗаКвартал + СтрокаПериод.ФактическаяЧисленностьРК;
				ФактическаяЗаКварталОсн 						 = ФактическаяЗаКварталОсн + СтрокаПериод.ФактическаяЧисленностьОснРК;
				ОтработаноЧасовПоСокращенномуГрафикуЗаКвартал 	 = ОтработаноЧасовПоСокращенномуГрафикуЗаКвартал + СтрокаПериод.ОтработаноЧасовПоСокращенномуГрафику;
				ОтработаноЧасовСовместителиЗаКвартал 			 = ОтработаноЧасовСовместителиЗаКвартал + СтрокаПериод.ОтработаноЧасовСовместители;
				ОтработаноЧасовПоСокращенномуГрафикуЗаКварталОсн = ОтработаноЧасовПоСокращенномуГрафикуЗаКварталОсн + СтрокаПериод.ОтработаноЧасовПоСокращенномуГрафикуОсн;
				ОтработаноЧасовСовместителиЗаКварталОсн 		 = ОтработаноЧасовСовместителиЗаКварталОсн + СтрокаПериод.ОтработаноЧасовСовместителиОсн;
				ПринятоЗаКвартал 								 = ПринятоЗаКвартал + СтрокаПериод.ПринятВПериоде;
				
				ВыбылоЛиквидацияПредприятия 				= ВыбылоЛиквидацияПредприятия + СтрокаПериод.ВыбылоЛиквидацияПредприятия;
				ВыбылоНарушениеТрудовойДисциплины 			= ВыбылоНарушениеТрудовойДисциплины + СтрокаПериод.ВыбылоНарушениеТрудовойДисциплины;
				ВыбылоНесоответствиеДолжности 				= ВыбылоНесоответствиеДолжности + СтрокаПериод.ВыбылоНесоответствиеДолжности;
				ВыбылоОбстоятельстваНезависящиеОтВолиСторон = ВыбылоОбстоятельстваНезависящиеОтВолиСторон + СтрокаПериод.ВыбылоОбстоятельстваНезависящиеОтВолиСторон;
				ВыбылоПоДругимПричинам 						= ВыбылоПоДругимПричинам + СтрокаПериод.ВыбылоПоДругимПричинам;
				ВыбылоПоСобственномуЖеланию 				= ВыбылоПоСобственномуЖеланию + СтрокаПериод.ВыбылоПоСобственномуЖеланию;
				ВыбылоПосокращениюЧисленности 			 	= ВыбылоПосокращениюЧисленности + СтрокаПериод.ВыбылоПосокращениюЧисленности;
				
			КонецЦикла;
		КонецЦикла;
		Контейнер.Форма1ТСтраница2.П000001005001 = Окр(ФОТЗаКвартал/ 1000, 2);
		Контейнер.Форма1ТСтраница3.П000001006001 = Окр(ФОТЗаКварталОсн/ 1000, 2);  
		Контейнер.Форма1ТСтраница3.П000001009001 = Окр(ОтработаноЧасовЗаКвартал/ 1000, 2);
		
		Контейнер.Форма1ТСтраница2.П000001001001 = СреднесписочнаяЗаКвартал/3;
		Контейнер.Форма1ТСтраница2.П000001002001 = СреднесписочнаяЗаКварталОсн/3;
		
		ФактическаяЗаКвартал = (ФактическаяЗаКвартал + ОтработаноЧасовПоСокращенномуГрафикуЗаКвартал + ОтработаноЧасовСовместителиЗаКвартал)/3;
		ФактическаяЗаКварталОсн = (ФактическаяЗаКварталОсн + ОтработаноЧасовПоСокращенномуГрафикуЗаКварталОсн + ОтработаноЧасовСовместителиЗаКварталОсн)/3;
		Контейнер.Форма1ТСтраница2.П000001003001 = ФактическаяЗаКвартал;
		Контейнер.Форма1ТСтраница2.П000001004001 = ФактическаяЗаКварталОсн;
		
		Контейнер.Форма1ТСтраница3.П000002002001 = ПринятоЗаКвартал;
		Контейнер.Форма1ТСтраница3.П000002004001 = ВыбылоПосокращениюЧисленности;
		Контейнер.Форма1ТСтраница3.П000002005001 = ВыбылоЛиквидацияПредприятия;
		Контейнер.Форма1ТСтраница3.П000002006001 = ВыбылоНесоответствиеДолжности;
		Контейнер.Форма1ТСтраница3.П000002007001 = ВыбылоНарушениеТрудовойДисциплины;
		Контейнер.Форма1ТСтраница3.П000002008001 = ВыбылоОбстоятельстваНезависящиеОтВолиСторон;
		Контейнер.Форма1ТСтраница3.П000002009001 = ВыбылоПоСобственномуЖеланию;
		Контейнер.Форма1ТСтраница3.П000002010001 = ВыбылоПоДругимПричинам;  
		
		Контейнер.Форма1ТСтраница4.П000002013001 = ЧисленностьНеполнаяРабочаяНеделя; 
		Контейнер.Форма1ТСтраница4.П000002014001 = Простой; 

	КонецЕсли;
	
	// Получение зарплатных данных отчета с начала года
	ПараметрыОтчетаДляЗаполнения.Вставить("СНачалаГода", Истина);
	ПараметрыОтчетаДляЗаполнения.Вставить("ДатаНачалаПериодаВыборки", НачалоГода(ПараметрыОтчета.мДатаКонцаПериодаОтчета));
	ПараметрыОтчетаДляЗаполнения.Вставить("ИсключаемыеСостояния", ИсключаемыеСостояния);
	НомерМесяцаКонцаКвартала = Месяц(ПараметрыОтчета.мДатаКонцаПериодаОтчета);
	ДанныеОтчета = Новый ДеревоЗначений;
	ДанныеДляЗаполненияРегламентированнойОтчетностиЗарплатаКадры("РегламентированныйОтчетСтатистикаФорма1Т", ПараметрыОтчетаДляЗаполнения, ДанныеОтчета);
	
	ФОТСНачалаГода = 0;
	ФОТСНачалаГодаОсн = 0;
	ОтработаноЧасовСНачалаГода = 0;
	СреднесписочнаяСНачалаГода = 0;
	СреднесписочнаяСНачалаГодаОсн = 0;
	ФактическаяСНачалаГода = 0;
	ФактическаяСНачалаГодаОсн = 0;
	ОтработаноЧасовПоСокращенномуГрафикуСНачалаГода = 0;
	ОтработаноЧасовСовместителиСНачалаГода = 0;
	ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаОсн = 0;
	ОтработаноЧасовСовместителиСНачалаГодаОсн = 0;
	ПринятоСНачалаГода = 0;
	ВыбылоЛиквидацияПредприятияСНачалаГода = 0;
	ВыбылоНарушениеТрудовойДисциплиныСНачалаГода = 0;
	ВыбылоНесоответствиеДолжностиСНачалаГода = 0;
	ВыбылоОбстоятельстваНезависящиеОтВолиСторонСНачалаГода = 0;
	ВыбылоПоДругимПричинамСНачалаГода = 0;
	ВыбылоПоСобственномуЖеланиюСНачалаГода = 0;
	ВыбылоПосокращениюЧисленностиСНачалаГода = 0;
	ЧисленностьНеполнаяРабочаяНеделяСНачалаГода = 0;
	ПростойСНачалаГода = 0;

	Если ДанныеОтчета <> Неопределено Тогда
		Для Каждого СтрокаОрганизация Из ДанныеОтчета.Строки Цикл
			
			ПростойСНачалаГода = ПростойСНачалаГода + СтрокаОрганизация.Простой;
			ЧисленностьНеполнаяРабочаяНеделяСНачалаГода = ЧисленностьНеполнаяРабочаяНеделяСНачалаГода + СтрокаОрганизация.ЧисленностьНеполнаяРабочаяНеделя;
			
			Для Каждого СтрокаПериод Из СтрокаОрганизация.Строки Цикл

				ФОТСНачалаГода = ФОТСНачалаГода + (СтрокаПериод.НачисленоРаботникамСписочногоСостава
															+ СтрокаПериод.НачисленоВнутреннимСовместителям
															+ СтрокаПериод.НачисленоВнешнимСовместителям);
										
				ФОТСНачалаГодаОсн = ФОТСНачалаГодаОсн + (СтрокаПериод.НачисленоРаботникамСписочногоСоставаОсн
													+ СтрокаПериод.НачисленоВнутреннимСовместителямОсн
													+ СтрокаПериод.НачисленоВнешнимСовместителямОсн);

				ОтработаноЧасовСНачалаГода = ОтработаноЧасовСНачалаГода + (СтрокаПериод.ОтработаноЧасовСНачалаГодаРаботникамиСписочногоСостава
																		+ СтрокаПериод.ОтработаноЧасовСНачалаГодаВнешнимиСовместителями);
				
				СреднесписочнаяСНачалаГода 							= СреднесписочнаяСНачалаГода + СтрокаПериод.СреднесписочнаяЧисленностьРК;
				СреднесписочнаяСНачалаГодаОсн 						= СреднесписочнаяСНачалаГодаОсн + СтрокаПериод.СреднесписочнаяЧисленностьОснРК;
				ФактическаяСНачалаГода 								= ФактическаяСНачалаГода + СтрокаПериод.ФактическаяЧисленностьРК;
				ФактическаяСНачалаГодаОсн 							= ФактическаяСНачалаГодаОсн + СтрокаПериод.ФактическаяЧисленностьОснРК;
				ОтработаноЧасовПоСокращенномуГрафикуСНачалаГода 	= ОтработаноЧасовПоСокращенномуГрафикуСНачалаГода + СтрокаПериод.ОтработаноЧасовПоСокращенномуГрафику;
				ОтработаноЧасовСовместителиСНачалаГода 			 	= ОтработаноЧасовСовместителиСНачалаГода + СтрокаПериод.ОтработаноЧасовСовместители;
				ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаОсн 	= ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаОсн + СтрокаПериод.ОтработаноЧасовПоСокращенномуГрафикуОсн;
				ОтработаноЧасовСовместителиСНачалаГодаОсн 		 	= ОтработаноЧасовСовместителиСНачалаГодаОсн + СтрокаПериод.ОтработаноЧасовСовместителиОсн;

				ПринятоСНачалаГода 				= ПринятоСНачалаГода + СтрокаПериод.ПринятВПериоде;
				
				ВыбылоЛиквидацияПредприятияСНачалаГода 					= ВыбылоЛиквидацияПредприятияСНачалаГода + СтрокаПериод.ВыбылоЛиквидацияПредприятия;
				ВыбылоНарушениеТрудовойДисциплиныСНачалаГода 			= ВыбылоНарушениеТрудовойДисциплиныСНачалаГода + СтрокаПериод.ВыбылоНарушениеТрудовойДисциплины;
				ВыбылоНесоответствиеДолжностиСНачалаГода 				= ВыбылоНесоответствиеДолжностиСНачалаГода + СтрокаПериод.ВыбылоНесоответствиеДолжности;
				ВыбылоОбстоятельстваНезависящиеОтВолиСторонСНачалаГода 	= ВыбылоОбстоятельстваНезависящиеОтВолиСторонСНачалаГода + СтрокаПериод.ВыбылоОбстоятельстваНезависящиеОтВолиСторон;
				ВыбылоПоДругимПричинамСНачалаГода 						= ВыбылоПоДругимПричинамСНачалаГода + СтрокаПериод.ВыбылоПоДругимПричинам;
				ВыбылоПоСобственномуЖеланиюСНачалаГода 					= ВыбылоПоСобственномуЖеланиюСНачалаГода + СтрокаПериод.ВыбылоПоСобственномуЖеланию;
				ВыбылоПосокращениюЧисленностиСНачалаГода 				= ВыбылоПосокращениюЧисленностиСНачалаГода + СтрокаПериод.ВыбылоПосокращениюЧисленности;
					
			КонецЦикла;
		КонецЦикла;
		Контейнер.Форма1ТСтраница2.П000001005002 = Окр(ФОТСНачалаГода/ 1000, 2);
		Контейнер.Форма1ТСтраница3.П000001006002 = Окр(ФОТСНачалаГодаОсн/ 1000, 2);
		Контейнер.Форма1ТСтраница3.П000001009002 = Окр(ОтработаноЧасовСНачалаГода/ 1000, 2);
		
		Контейнер.Форма1ТСтраница2.П000001001002 = СреднесписочнаяСНачалаГода/НомерМесяцаКонцаКвартала;
		Контейнер.Форма1ТСтраница2.П000001002002 = СреднесписочнаяСНачалаГодаОсн/НомерМесяцаКонцаКвартала;
		
		ФактическаяСНачалаГода = (ФактическаяСНачалаГода + ОтработаноЧасовПоСокращенномуГрафикуСНачалаГода + ОтработаноЧасовСовместителиСНачалаГода)/НомерМесяцаКонцаКвартала;
		ФактическаяСНачалаГодаОсн = (ФактическаяСНачалаГодаОсн + ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаОсн + ОтработаноЧасовСовместителиСНачалаГодаОсн)/НомерМесяцаКонцаКвартала;
		Контейнер.Форма1ТСтраница2.П000001003002 = ФактическаяСНачалаГода;
		Контейнер.Форма1ТСтраница2.П000001004002 = ФактическаяСНачалаГодаОсн;
		
		Контейнер.Форма1ТСтраница3.П000002002002 = ПринятоСНачалаГода;
		Контейнер.Форма1ТСтраница3.П000002004002 = ВыбылоПосокращениюЧисленностиСНачалаГода;
		Контейнер.Форма1ТСтраница3.П000002005002 = ВыбылоЛиквидацияПредприятияСНачалаГода;
		Контейнер.Форма1ТСтраница3.П000002006002 = ВыбылоНесоответствиеДолжностиСНачалаГода;
		Контейнер.Форма1ТСтраница3.П000002007002 = ВыбылоНарушениеТрудовойДисциплиныСНачалаГода;
		Контейнер.Форма1ТСтраница3.П000002008002 = ВыбылоОбстоятельстваНезависящиеОтВолиСторонСНачалаГода;
		Контейнер.Форма1ТСтраница3.П000002009002 = ВыбылоПоСобственномуЖеланиюСНачалаГода;
		Контейнер.Форма1ТСтраница3.П000002010002 = ВыбылоПоДругимПричинамСНачалаГода;  

		Контейнер.Форма1ТСтраница4.П000002013002 = ЧисленностьНеполнаяРабочаяНеделяСНачалаГода; 
		Контейнер.Форма1ТСтраница4.П000002014002 = ПростойСНачалаГода; 

	КонецЕсли;
	
	// Получение кадровых данных отчета за квартал
	ДанныеОтчета = Новый ДеревоЗначений;
	ПараметрыОтчетаДляЗаполнения.Вставить("ДатаНачалаПериодаВыборки", НачалоКвартала(ПараметрыОтчета.мДатаКонцаПериодаОтчета));
	ДанныеДляЗаполненияРегламентированнойОтчетностиКадроваяИстория("РегламентированныйОтчетСтатистикаФорма1Т", ПараметрыОтчетаДляЗаполнения, ДанныеОтчета);
	
	Принято = 0;
	Уволено = 0;
	НачальныеДанные = 0;
	ЧисленностьНаДатуЗаКвартал = 0;
	Если ДанныеОтчета <> Неопределено Тогда

		Для Каждого СтрокаПериод Из ДанныеОтчета.Строки Цикл
			Если СтрокаПериод.ВидСобытия <> Неопределено Тогда 
				Принято = Принято + СтрокаПериод.Прием;  
				Уволено	= Уволено + СтрокаПериод.Увольнение;
				НачальныеДанные = НачальныеДанные + СтрокаПериод.НачальныеДанные;
			КонецЕсли;
		КонецЦикла;
		
		ЧисленностьНаДатуЗаКвартал = Принято + НачальныеДанные - Уволено;
		Контейнер.Форма1ТСтраница3.П000002001001 = ЧисленностьНаДатуЗаКвартал;
		
	КонецЕсли;     
	
	Контейнер.Форма1ТСтраница3.П000001007001 = ?(ФактическаяЗаКвартал <> 0, Окр(ФОТЗаКвартал, 2)/Окр(ФактическаяЗаКвартал, 2)/3, 0);
	Контейнер.Форма1ТСтраница3.П000001007002 = ?(ФактическаяСНачалаГода <> 0, Окр(ФОТСНачалаГода, 2)/Окр(ФактическаяСНачалаГода, 2)/НомерМесяцаКонцаКвартала, 0);
	Контейнер.Форма1ТСтраница3.П000001008001 = ?(ФактическаяЗаКварталОсн <> 0, Окр(ФОТЗаКварталОсн, 2)/Окр(ФактическаяЗаКварталОсн, 2)/3, 0);
	Контейнер.Форма1ТСтраница3.П000001008002 = ?(ФактическаяСНачалаГодаОсн <> 0, Окр(ФОТСНачалаГодаОсн, 2)/Окр(ФактическаяСНачалаГодаОсн, 2)/НомерМесяцаКонцаКвартала, 0);
	
	ВсегоВыбылоСотрудниковЗаКвартал = ВыбылоПосокращениюЧисленности
									+ ВыбылоЛиквидацияПредприятия
									+ ВыбылоНесоответствиеДолжности
									+ ВыбылоНарушениеТрудовойДисциплины
									+ ВыбылоОбстоятельстваНезависящиеОтВолиСторон
									+ ВыбылоПоСобственномуЖеланию
									+ ВыбылоПоДругимПричинам;
									
	Контейнер.Форма1ТСтраница3.П000002003001 = ВсегоВыбылоСотрудниковЗаКвартал;
	ВсегоВыбылоСотрудниковСНачалаГода = ВыбылоПосокращениюЧисленностиСНачалаГода
									+ ВыбылоЛиквидацияПредприятияСНачалаГода
									+ ВыбылоНесоответствиеДолжностиСНачалаГода
									+ ВыбылоНарушениеТрудовойДисциплиныСНачалаГода
									+ ВыбылоОбстоятельстваНезависящиеОтВолиСторонСНачалаГода
									+ ВыбылоПоСобственномуЖеланиюСНачалаГода
									+ ВыбылоПоДругимПричинамСНачалаГода;
	Контейнер.Форма1ТСтраница3.П000002003002 = ВсегоВыбылоСотрудниковСНачалаГода;  
	
	// Получение кадровых данных отчета за квартал
	ДанныеОтчета = Новый ДеревоЗначений;
	ПараметрыОтчетаДляЗаполнения.Вставить("ДатаНачалаПериодаВыборки", НачалоГода(ПараметрыОтчета.мДатаКонцаПериодаОтчета));
	ДанныеДляЗаполненияРегламентированнойОтчетностиКадроваяИстория("РегламентированныйОтчетСтатистикаФорма1Т", ПараметрыОтчетаДляЗаполнения, ДанныеОтчета);
	
	Принято = 0;
	Уволено = 0;
	НачальныеДанные = 0;
	ЧисленностьНаДатуСНачалаГода = 0;
	Если ДанныеОтчета <> Неопределено Тогда

		Для Каждого СтрокаПериод Из ДанныеОтчета.Строки Цикл
			Если СтрокаПериод.ВидСобытия <> Неопределено Тогда 
				Принято = Принято + СтрокаПериод.Прием;
				Уволено	= Уволено + СтрокаПериод.Увольнение;
				НачальныеДанные = НачальныеДанные + СтрокаПериод.НачальныеДанные;
			КонецЕсли;
		КонецЦикла;
		ЧисленностьНаДатуСНачалаГода = Принято + НачальныеДанные - Уволено; 
		Контейнер.Форма1ТСтраница3.П000002001002 = ЧисленностьНаДатуСНачалаГода;
		
	КонецЕсли;   
	
	Контейнер.Форма1ТСтраница3.П000002011001 = ЧисленностьНаДатуЗаКвартал + ПринятоЗаКвартал - ВсегоВыбылоСотрудниковЗаКвартал;
	Контейнер.Форма1ТСтраница3.П000002011002 = ЧисленностьНаДатуСНачалаГода + ПринятоСНачалаГода - ВсегоВыбылоСотрудниковСНачалаГода;

	// Получение данных по штатному расписанию за квартал
	ДанныеОтчета = Новый ДеревоЗначений;
	ПараметрыОтчетаДляЗаполнения.Вставить("ДатаАктуальности ", КонецКвартала(ПараметрыОтчета.мДатаКонцаПериодаОтчета));
	ДанныеДляЗаполненияРегламентированнойОтчетностиШтатныеЕдиницы("РегламентированныйОтчетСтатистикаФорма1Т", ПараметрыОтчетаДляЗаполнения, ДанныеОтчета);
	
	ЧислоВакантныхМест = 0;
	Если ДанныеОтчета <> Неопределено Тогда
		Для Каждого СтрокаОрганизация Из ДанныеОтчета.Строки Цикл
			ЧислоВакантныхМест = ЧислоВакантныхМест + СтрокаОрганизация.Отклонение; 
		КонецЦикла;
	КонецЕсли;
	
	Контейнер.Форма1ТСтраница3.П000002012001 = ?(ЧислоВакантныхМест > 0, ЧислоВакантныхМест, 0);;
	
КонецПроцедуры

Процедура ЗначенияПоказателей_СтатистикаФорма1ТКвартальная_2018Кв1(ПараметрыОтчета, Контейнер) Экспорт

	// Сведения для отчета берутся за последний квартал.
	ПараметрыОтчетаДляЗаполнения = ОбщегоНазначенияКлиентСервер.СкопироватьСтруктуру(ПараметрыОтчета);
	
	Квартал = Формат(ПараметрыОтчета.мДатаНачалаПериодаОтчета, "ДФ=к");
	Контейнер.Форма1ТСтраница1.Квартал1 = "0";
	Контейнер.Форма1ТСтраница1.Квартал2 = Квартал;
	
	Год = Формат(ПараметрыОтчета.мДатаНачалаПериодаОтчета, "ДФ=гггг");
	Контейнер.Форма1ТСтраница1.Год1 = Сред(Год, 1, 1);
	Контейнер.Форма1ТСтраница1.Год2 = Сред(Год, 2, 1);
	Контейнер.Форма1ТСтраница1.Год3 = Сред(Год, 3, 1);
	Контейнер.Форма1ТСтраница1.Год4 = Сред(Год, 4, 1);
	
	СтрокаСведений = "ИННЮЛ, НаимЮЛПол, ФИОРук, ФИОБух, ОКВЭД, ОКАТО, ПолныйАдрЮР, АдрФакт, АдрФактСтат, ТелОрганизации, АдресЭлектроннойПочтыОрганизации, ОснВидДеят";
	СведенияОбОрганизации = РегламентированнаяОтчетностьВызовСервера.ПолучитьСведенияОбОрганизации(ПараметрыОтчета.Организация,,СтрокаСведений);
	
	Контейнер.Форма1ТСтраница2.АдрФакт 	 	 = СведенияОбОрганизации.АдрФактСтат;
	Контейнер.Форма1ТСтраница2.НаимОКЭД		 = СведенияОбОрганизации.ОснВидДеят;
	Контейнер.Форма1ТСтраница4.НаимЮЛПол	 = СведенияОбОрганизации.НаимЮЛПол;
	Контейнер.Форма1ТСтраница4.Исполнитель 	 = Пользователи.ТекущийПользователь();
	Контейнер.Форма1ТСтраница5.ФИОРук	 	 = СведенияОбОрганизации.ФИОРук;
	Контейнер.Форма1ТСтраница5.ФИОБух	 	 = СведенияОбОрганизации.ФИОБух;
	
	Если НЕ  ПараметрыОтчета.Организация.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо Тогда
		Контейнер.Форма1ТСтраница4.АдрЮР			= СведенияОбОрганизации.ПолныйАдрЮР;
		Контейнер.Форма1ТСтраница4.ТелОрганизации	= СведенияОбОрганизации.ТелОрганизации;
		Контейнер.Форма1ТСтраница4.ЭлПочта			= СведенияОбОрганизации.АдресЭлектроннойПочтыОрганизации;
	     // Код БИН
		ДлинаИИН = СтрДлина(СведенияОбОрганизации.ИННЮЛ);
		Если ДлинаИИН <= 12 Тогда
			Для Шаг = 1 По ДлинаИИН Цикл
				Контейнер.Форма1ТСтраница1["БИН" + Шаг] = СРЕД(СведенияОбОрганизации.ИННЮЛ, Шаг, 1);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	// Код КАТО     
	КодКАТО = Лев(СведенияОбОрганизации.ОКАТО,10); // длина кода всего 9 символов, добавим 10-й
	ДлинаКАТО = СтрДлина(КодКАТО); 
	Если ДлинаКАТО <= 10 Тогда
		Для Шаг = 1 По ДлинаКАТО Цикл
			Контейнер.Форма1ТСтраница2["КодКАТО" + Шаг] = СРЕД(КодКАТО, Шаг, 1);
		КонецЦикла;
	КонецЕсли;
	// Код по ОКЭД
	ДлинаКодПоОКЭД = СтрДлина(СведенияОбОрганизации.ОКВЭД);
	Если ДлинаКодПоОКЭД <= 5 Тогда
		Для Шаг = 1 По ДлинаКодПоОКЭД Цикл
			Контейнер.Форма1ТСтраница2["КодПоОКЭД" + Шаг] = СРЕД(СведенияОбОрганизации.ОКВЭД, Шаг, 1);
		КонецЦикла;
	КонецЕсли;
	
	ИсключаемыеСостояния = Новый СписокЗначений;
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускПоБеременностиИРодам);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускПоУходуЗаРебенком);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускНеоплачиваемыйПоЗаконодательству);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускНеоплачиваемыйПоРазрешениюРаботодателя);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ДополнительныйОтпускНеоплачиваемый);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускУчебныйНеоплачиваемый);

	// Получение зарплатных данных отчета за квартал
	ДанныеОтчета = Новый ДеревоЗначений;
	ПараметрыОтчетаДляЗаполнения.Вставить("ДатаНачалаПериодаВыборки", НачалоКвартала(ПараметрыОтчета.мДатаКонцаПериодаОтчета));
	ПараметрыОтчетаДляЗаполнения.Вставить("ИсключаемыеСостояния", ИсключаемыеСостояния);  
	ПараметрыОтчетаДляЗаполнения.Вставить("КодОКВЭД", СведенияОбОрганизации.ОКВЭД);
	ДанныеДляЗаполненияРегламентированнойОтчетностиЗарплатаКадры("РегламентированныйОтчетСтатистикаФорма1Т", ПараметрыОтчетаДляЗаполнения, ДанныеОтчета);
	
	ФОТЗаКвартал = 0;
	ФОТЗаКварталОсн = 0;
	ОтработаноЧасовЗаКвартал = 0;
	СреднесписочнаяЗаКвартал = 0;
	СреднесписочнаяЗаКварталОсн = 0;
	ФактическаяЗаКвартал = 0;
	ФактическаяЗаКварталОсн = 0;
	ОтработаноЧасовПоСокращенномуГрафикуЗаКвартал = 0;
	ОтработаноЧасовСовместителиЗаКвартал = 0;
	ОтработаноЧасовПоСокращенномуГрафикуЗаКварталОсн = 0;
	ОтработаноЧасовСовместителиЗаКварталОсн = 0;
	ПринятоЗаКвартал = 0;
	ВыбылоЛиквидацияПредприятия = 0;
	ВыбылоНарушениеТрудовойДисциплины = 0;
	ВыбылоНесоответствиеДолжности = 0;
	ВыбылоОбстоятельстваНезависящиеОтВолиСторон = 0;
	ВыбылоПоДругимПричинам = 0;
	ВыбылоПоСобственномуЖеланию = 0;
	ВыбылоПосокращениюЧисленности = 0;
	ЧисленностьНеполнаяРабочаяНеделя = 0;
	Простой = 0;
	СреднесписочнаяЗаКварталЖенщины = 0;
	ФактическаяЗаКварталЖенщины = 0;
	СреднесписочнаяСовместителиЗаКвартал = 0;
	СреднесписочнаяГПХЗаКвартал = 0;
	ОтработаноЧасовПоСокращенномуГрафикуЗаКварталЖенщины = 0;
	ОтработаноЧасовСовместителиЗаКварталЖенщины = 0;
	Если ДанныеОтчета <> Неопределено Тогда

		Для Каждого СтрокаОрганизация Из ДанныеОтчета.Строки Цикл
			
			Простой = Простой + СтрокаОрганизация.Простой;
			ЧисленностьНеполнаяРабочаяНеделя = ЧисленностьНеполнаяРабочаяНеделя + СтрокаОрганизация.ЧисленностьНеполнаяРабочаяНеделя;

			Для Каждого СтрокаПериод Из СтрокаОрганизация.Строки Цикл
				
				ФОТЗаКвартал = ФОТЗаКвартал + (СтрокаПериод.НачисленоРаботникамСписочногоСостава
											+ СтрокаПериод.НачисленоВнутреннимСовместителям
											+ СтрокаПериод.НачисленоВнешнимСовместителям);
				
				ФОТЗаКварталОсн = ФОТЗаКварталОсн + (СтрокаПериод.НачисленоРаботникамСписочногоСоставаОсн
													+ СтрокаПериод.НачисленоВнутреннимСовместителямОсн
													+ СтрокаПериод.НачисленоВнешнимСовместителямОсн); 
				
				ОтработаноЧасовЗаКвартал = ОтработаноЧасовЗаКвартал + (СтрокаПериод.ОтработаноЧасовСНачалаГодаРаботникамиСписочногоСостава
																	+ СтрокаПериод.ОтработаноЧасовСНачалаГодаВнешнимиСовместителями);
				
				СреднесписочнаяЗаКвартал 						 = СреднесписочнаяЗаКвартал + СтрокаПериод.СреднесписочнаяЧисленностьРК;
				СреднесписочнаяЗаКварталОсн 					 = СреднесписочнаяЗаКварталОсн + СтрокаПериод.СреднесписочнаяЧисленностьОснРК;
				СреднесписочнаяЗаКварталЖенщины					 = СреднесписочнаяЗаКварталЖенщины + СтрокаПериод.СреднесписочнаяЧисленностьЖенщинРК;
				СреднесписочнаяСовместителиЗаКвартал 			 = СреднесписочнаяСовместителиЗаКвартал + СтрокаПериод.СреднесписочнаяЧисленностьВнешнихСовместителей;
				СреднесписочнаяГПХЗаКвартал						 = СреднесписочнаяГПХЗаКвартал + СтрокаПериод.СреднесписочнаяЧисленностьГПХРК;
				ФактическаяЗаКвартал 							 = ФактическаяЗаКвартал + СтрокаПериод.ФактическаяЧисленностьРК;
				ФактическаяЗаКварталЖенщины 					 = ФактическаяЗаКварталЖенщины + СтрокаПериод.ФактическаяЧисленностьЖенщинРК;
				ФактическаяЗаКварталОсн 						 = ФактическаяЗаКварталОсн + СтрокаПериод.ФактическаяЧисленностьОснРК;
				ОтработаноЧасовПоСокращенномуГрафикуЗаКвартал 	 = ОтработаноЧасовПоСокращенномуГрафикуЗаКвартал + СтрокаПериод.ОтработаноЧасовПоСокращенномуГрафику;
				ОтработаноЧасовСовместителиЗаКвартал 			 = ОтработаноЧасовСовместителиЗаКвартал + СтрокаПериод.ОтработаноЧасовСовместители;
				ОтработаноЧасовПоСокращенномуГрафикуЗаКварталОсн = ОтработаноЧасовПоСокращенномуГрафикуЗаКварталОсн + СтрокаПериод.ОтработаноЧасовПоСокращенномуГрафикуОсн;
				ОтработаноЧасовСовместителиЗаКварталОсн 		 = ОтработаноЧасовСовместителиЗаКварталОсн + СтрокаПериод.ОтработаноЧасовСовместителиОсн;
				ОтработаноЧасовПоСокращенномуГрафикуЗаКварталЖенщины 	= ОтработаноЧасовПоСокращенномуГрафикуЗаКварталЖенщины + СтрокаПериод.ОтработаноЧасовПоСокращенномуГрафикуЖенщины;
				ОтработаноЧасовСовместителиЗаКварталЖенщины 			= ОтработаноЧасовСовместителиЗаКварталЖенщины + СтрокаПериод.ОтработаноЧасовСовместителиЖенщины;
				ПринятоЗаКвартал 								 = ПринятоЗаКвартал + СтрокаПериод.ПринятВПериоде;
				
				ВыбылоЛиквидацияПредприятия 				= ВыбылоЛиквидацияПредприятия + СтрокаПериод.ВыбылоЛиквидацияПредприятия;
				ВыбылоНарушениеТрудовойДисциплины 			= ВыбылоНарушениеТрудовойДисциплины + СтрокаПериод.ВыбылоНарушениеТрудовойДисциплины;
				ВыбылоНесоответствиеДолжности 				= ВыбылоНесоответствиеДолжности + СтрокаПериод.ВыбылоНесоответствиеДолжности;
				ВыбылоОбстоятельстваНезависящиеОтВолиСторон = ВыбылоОбстоятельстваНезависящиеОтВолиСторон + СтрокаПериод.ВыбылоОбстоятельстваНезависящиеОтВолиСторон;
				ВыбылоПоДругимПричинам 						= ВыбылоПоДругимПричинам + СтрокаПериод.ВыбылоПоДругимПричинам;
				ВыбылоПоСобственномуЖеланию 				= ВыбылоПоСобственномуЖеланию + СтрокаПериод.ВыбылоПоСобственномуЖеланию;
				ВыбылоПосокращениюЧисленности 			 	= ВыбылоПосокращениюЧисленности + СтрокаПериод.ВыбылоПосокращениюЧисленности;
				
			КонецЦикла;
		КонецЦикла;         
		Контейнер.Форма1ТСтраница2.П000001005001 = Окр(ФОТЗаКвартал/ 1000, 2);
		Контейнер.Форма1ТСтраница3.П000001006001 = Окр(ФОТЗаКварталОсн/ 1000, 2);  
		Контейнер.Форма1ТСтраница3.П000001009001 = Окр(ОтработаноЧасовЗаКвартал/ 1000, 2);
		
		СреднесписочнаяЗаКвартал			 	 = СреднесписочнаяЗаКвартал/3;
		СреднесписочнаяЗаКварталОсн 		 	 = СреднесписочнаяЗаКварталОсн/3;
		СреднесписочнаяЗаКварталЖенщины 	 	 = СреднесписочнаяЗаКварталЖенщины/3;
		СреднесписочнаяСовместителиЗаКвартал 	 = СреднесписочнаяСовместителиЗаКвартал/3;
		СреднесписочнаяГПХЗаКвартал 		 	 = СреднесписочнаяГПХЗаКвартал/3;
		
		Контейнер.Форма1ТСтраница2.П000001001001 = ?(СреднесписочнаяЗаКвартал > 0 И СреднесписочнаяЗаКвартал < 1, 1, СреднесписочнаяЗаКвартал);
		Контейнер.Форма1ТСтраница2.П000001002001 = ?(СреднесписочнаяЗаКварталОсн > 0 И СреднесписочнаяЗаКварталОсн < 1, 1, СреднесписочнаяЗаКварталОсн);
		Контейнер.Форма1ТСтраница3.П000001010001 = ?(СреднесписочнаяЗаКварталЖенщины > 0 И СреднесписочнаяЗаКварталЖенщины < 1, 1, СреднесписочнаяЗаКварталЖенщины);
		Контейнер.Форма1ТСтраница4.П000003001001 = ?(СреднесписочнаяСовместителиЗаКвартал >0 И СреднесписочнаяСовместителиЗаКвартал < 1, 1, СреднесписочнаяСовместителиЗаКвартал);
		Контейнер.Форма1ТСтраница4.П000003002001 = ?(СреднесписочнаяГПХЗаКвартал > 0 И СреднесписочнаяГПХЗаКвартал < 1, 1, СреднесписочнаяГПХЗаКвартал);
		
		ФактическаяЗаКвартал = (ФактическаяЗаКвартал + ОтработаноЧасовПоСокращенномуГрафикуЗаКвартал + ОтработаноЧасовСовместителиЗаКвартал)/3;
		ФактическаяЗаКварталОсн = (ФактическаяЗаКварталОсн + ОтработаноЧасовПоСокращенномуГрафикуЗаКварталОсн + ОтработаноЧасовСовместителиЗаКварталОсн)/3;
		ФактическаяЗаКварталЖенщины = (ФактическаяЗаКварталЖенщины + ОтработаноЧасовПоСокращенномуГрафикуЗаКварталЖенщины + ОтработаноЧасовСовместителиЗаКварталЖенщины)/3;
		Контейнер.Форма1ТСтраница2.П000001003001 = ФактическаяЗаКвартал;
		Контейнер.Форма1ТСтраница2.П000001004001 = ФактическаяЗаКварталОсн;
		Контейнер.Форма1ТСтраница3.П000001011001 = ФактическаяЗаКварталЖенщины;
		
		Контейнер.Форма1ТСтраница3.П000002002001 = ПринятоЗаКвартал;
		Контейнер.Форма1ТСтраница3.П000002004001 = ВыбылоПосокращениюЧисленности;
		Контейнер.Форма1ТСтраница3.П000002005001 = ВыбылоЛиквидацияПредприятия;
		Контейнер.Форма1ТСтраница3.П000002006001 = ВыбылоНесоответствиеДолжности;
		Контейнер.Форма1ТСтраница3.П000002007001 = ВыбылоНарушениеТрудовойДисциплины;
		Контейнер.Форма1ТСтраница3.П000002008001 = ВыбылоОбстоятельстваНезависящиеОтВолиСторон;
		Контейнер.Форма1ТСтраница3.П000002009001 = ВыбылоПоСобственномуЖеланию;
		Контейнер.Форма1ТСтраница3.П000002010001 = ВыбылоПоДругимПричинам;  
		
		Контейнер.Форма1ТСтраница4.П000002013001 = ЧисленностьНеполнаяРабочаяНеделя; 
		Контейнер.Форма1ТСтраница4.П000002014001 = Простой; 

	КонецЕсли;
	
	// Получение зарплатных данных отчета с начала года
	ПараметрыОтчетаДляЗаполнения.Вставить("СНачалаГода", Истина);
	ПараметрыОтчетаДляЗаполнения.Вставить("ДатаНачалаПериодаВыборки", НачалоГода(ПараметрыОтчета.мДатаКонцаПериодаОтчета));
	ПараметрыОтчетаДляЗаполнения.Вставить("ИсключаемыеСостояния", ИсключаемыеСостояния);
	НомерМесяцаКонцаКвартала = Месяц(ПараметрыОтчета.мДатаКонцаПериодаОтчета);
	ДанныеОтчета = Новый ДеревоЗначений;
	ДанныеДляЗаполненияРегламентированнойОтчетностиЗарплатаКадры("РегламентированныйОтчетСтатистикаФорма1Т", ПараметрыОтчетаДляЗаполнения, ДанныеОтчета);
	
	ФОТСНачалаГода = 0;
	ФОТСНачалаГодаОсн = 0;
	ОтработаноЧасовСНачалаГода = 0;
	СреднесписочнаяСНачалаГода = 0;
	СреднесписочнаяСНачалаГодаОсн = 0;
	ФактическаяСНачалаГода = 0;
	ФактическаяСНачалаГодаОсн = 0;
	ОтработаноЧасовПоСокращенномуГрафикуСНачалаГода = 0;
	ОтработаноЧасовСовместителиСНачалаГода = 0;
	ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаОсн = 0;
	ОтработаноЧасовСовместителиСНачалаГодаОсн = 0;
	ПринятоСНачалаГода = 0;
	ВыбылоЛиквидацияПредприятияСНачалаГода = 0;
	ВыбылоНарушениеТрудовойДисциплиныСНачалаГода = 0;
	ВыбылоНесоответствиеДолжностиСНачалаГода = 0;
	ВыбылоОбстоятельстваНезависящиеОтВолиСторонСНачалаГода = 0;
	ВыбылоПоДругимПричинамСНачалаГода = 0;
	ВыбылоПоСобственномуЖеланиюСНачалаГода = 0;
	ВыбылоПосокращениюЧисленностиСНачалаГода = 0;
	ЧисленностьНеполнаяРабочаяНеделяСНачалаГода = 0;
	ПростойСНачалаГода = 0;
	СреднесписочнаяСНачалаГодаЖенщины = 0;
	ФактическаяСНачалаГодаЖенщины = 0; 
	СреднесписочнаяСовместителиСНачалаГода = 0;
	СреднесписочнаяГПХСНачалаГода = 0;
	ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаЖенщины = 0;
	ОтработаноЧасовСовместителиСНачалаГодаЖенщины = 0;

	Если ДанныеОтчета <> Неопределено Тогда
		Для Каждого СтрокаОрганизация Из ДанныеОтчета.Строки Цикл
			
			ПростойСНачалаГода = ПростойСНачалаГода + СтрокаОрганизация.Простой;
			ЧисленностьНеполнаяРабочаяНеделяСНачалаГода = ЧисленностьНеполнаяРабочаяНеделяСНачалаГода + СтрокаОрганизация.ЧисленностьНеполнаяРабочаяНеделя;
			
			Для Каждого СтрокаПериод Из СтрокаОрганизация.Строки Цикл

				ФОТСНачалаГода = ФОТСНачалаГода + (СтрокаПериод.НачисленоРаботникамСписочногоСостава
															+ СтрокаПериод.НачисленоВнутреннимСовместителям
															+ СтрокаПериод.НачисленоВнешнимСовместителям);
										
				ФОТСНачалаГодаОсн = ФОТСНачалаГодаОсн + (СтрокаПериод.НачисленоРаботникамСписочногоСоставаОсн
													+ СтрокаПериод.НачисленоВнутреннимСовместителямОсн
													+ СтрокаПериод.НачисленоВнешнимСовместителямОсн);

				ОтработаноЧасовСНачалаГода = ОтработаноЧасовСНачалаГода + (СтрокаПериод.ОтработаноЧасовСНачалаГодаРаботникамиСписочногоСостава
																		+ СтрокаПериод.ОтработаноЧасовСНачалаГодаВнешнимиСовместителями);
				
				СреднесписочнаяСНачалаГода 							= СреднесписочнаяСНачалаГода + СтрокаПериод.СреднесписочнаяЧисленностьРК;
				СреднесписочнаяСНачалаГодаОсн 						= СреднесписочнаяСНачалаГодаОсн + СтрокаПериод.СреднесписочнаяЧисленностьОснРК;
				СреднесписочнаяСНачалаГодаЖенщины					= СреднесписочнаяСНачалаГодаЖенщины + СтрокаПериод.СреднесписочнаяЧисленностьЖенщинРК;
				СреднесписочнаяСовместителиСНачалаГода 				= СреднесписочнаяСовместителиСНачалаГода + СтрокаПериод.СреднесписочнаяЧисленностьВнешнихСовместителей;
				СреднесписочнаяГПХСНачалаГода                       = СреднесписочнаяГПХСНачалаГода + СтрокаПериод.СреднесписочнаяЧисленностьГПХРК;
				ФактическаяСНачалаГода 								= ФактическаяСНачалаГода + СтрокаПериод.ФактическаяЧисленностьРК;
				ФактическаяСНачалаГодаОсн 							= ФактическаяСНачалаГодаОсн + СтрокаПериод.ФактическаяЧисленностьОснРК;
				ФактическаяСНачалаГодаЖенщины 						= ФактическаяСНачалаГодаЖенщины + СтрокаПериод.ФактическаяЧисленностьЖенщинРК;
				ОтработаноЧасовПоСокращенномуГрафикуСНачалаГода 	= ОтработаноЧасовПоСокращенномуГрафикуСНачалаГода + СтрокаПериод.ОтработаноЧасовПоСокращенномуГрафику;
				ОтработаноЧасовСовместителиСНачалаГода 			 	= ОтработаноЧасовСовместителиСНачалаГода + СтрокаПериод.ОтработаноЧасовСовместители;
				ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаОсн 	= ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаОсн + СтрокаПериод.ОтработаноЧасовПоСокращенномуГрафикуОсн;
				ОтработаноЧасовСовместителиСНачалаГодаОсн 		 	= ОтработаноЧасовСовместителиСНачалаГодаОсн + СтрокаПериод.ОтработаноЧасовСовместителиОсн;
				ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаЖенщины 	= ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаЖенщины + СтрокаПериод.ОтработаноЧасовПоСокращенномуГрафикуЖенщины;
				ОтработаноЧасовСовместителиСНачалаГодаЖенщины 			= ОтработаноЧасовСовместителиСНачалаГодаЖенщины + СтрокаПериод.ОтработаноЧасовСовместителиЖенщины;
				ПринятоСНачалаГода 									= ПринятоСНачалаГода + СтрокаПериод.ПринятВПериоде;
				
				ВыбылоЛиквидацияПредприятияСНачалаГода 					= ВыбылоЛиквидацияПредприятияСНачалаГода + СтрокаПериод.ВыбылоЛиквидацияПредприятия;
				ВыбылоНарушениеТрудовойДисциплиныСНачалаГода 			= ВыбылоНарушениеТрудовойДисциплиныСНачалаГода + СтрокаПериод.ВыбылоНарушениеТрудовойДисциплины;
				ВыбылоНесоответствиеДолжностиСНачалаГода 				= ВыбылоНесоответствиеДолжностиСНачалаГода + СтрокаПериод.ВыбылоНесоответствиеДолжности;
				ВыбылоОбстоятельстваНезависящиеОтВолиСторонСНачалаГода 	= ВыбылоОбстоятельстваНезависящиеОтВолиСторонСНачалаГода + СтрокаПериод.ВыбылоОбстоятельстваНезависящиеОтВолиСторон;
				ВыбылоПоДругимПричинамСНачалаГода 						= ВыбылоПоДругимПричинамСНачалаГода + СтрокаПериод.ВыбылоПоДругимПричинам;
				ВыбылоПоСобственномуЖеланиюСНачалаГода 					= ВыбылоПоСобственномуЖеланиюСНачалаГода + СтрокаПериод.ВыбылоПоСобственномуЖеланию;
				ВыбылоПосокращениюЧисленностиСНачалаГода 				= ВыбылоПосокращениюЧисленностиСНачалаГода + СтрокаПериод.ВыбылоПосокращениюЧисленности;
					
			КонецЦикла;
		КонецЦикла;
		Контейнер.Форма1ТСтраница2.П000001005002 = Окр(ФОТСНачалаГода/ 1000, 2);
		Контейнер.Форма1ТСтраница3.П000001006002 = Окр(ФОТСНачалаГодаОсн/ 1000, 2);
		Контейнер.Форма1ТСтраница3.П000001009002 = Окр(ОтработаноЧасовСНачалаГода/ 1000, 2);
		
		СреднесписочнаяСНачалаГода			 	 = СреднесписочнаяСНачалаГода/НомерМесяцаКонцаКвартала;
		СреднесписочнаяСНачалаГодаОсн 		 	 = СреднесписочнаяСНачалаГодаОсн/НомерМесяцаКонцаКвартала;
		СреднесписочнаяСНачалаГодаЖенщины 	 	 = СреднесписочнаяСНачалаГодаЖенщины/НомерМесяцаКонцаКвартала;
		СреднесписочнаяСовместителиСНачалаГода 	 = СреднесписочнаяСовместителиСНачалаГода/НомерМесяцаКонцаКвартала;
		СреднесписочнаяГПХСНачалаГода 		 	 = СреднесписочнаяГПХСНачалаГода/НомерМесяцаКонцаКвартала;
		
		Контейнер.Форма1ТСтраница2.П000001001002 = ?(СреднесписочнаяСНачалаГода > 0 И СреднесписочнаяСНачалаГода < 1, 1, СреднесписочнаяСНачалаГода);
		Контейнер.Форма1ТСтраница2.П000001002002 = ?(СреднесписочнаяСНачалаГодаОсн > 0 И СреднесписочнаяСНачалаГодаОсн < 1, 1, СреднесписочнаяСНачалаГодаОсн);
		Контейнер.Форма1ТСтраница3.П000001010002 = ?(СреднесписочнаяСНачалаГодаЖенщины > 0 И СреднесписочнаяСНачалаГодаЖенщины < 1, 1, СреднесписочнаяСНачалаГодаЖенщины);
		Контейнер.Форма1ТСтраница4.П000003001002 = ?(СреднесписочнаяСовместителиСНачалаГода > 0 И СреднесписочнаяСовместителиСНачалаГода < 1, 1, СреднесписочнаяСовместителиСНачалаГода);
		Контейнер.Форма1ТСтраница4.П000003002002 = ?(СреднесписочнаяГПХСНачалаГода > 0 И СреднесписочнаяГПХСНачалаГода < 1, 1, СреднесписочнаяГПХСНачалаГода);
		
		ФактическаяСНачалаГода = (ФактическаяСНачалаГода + ОтработаноЧасовПоСокращенномуГрафикуСНачалаГода + ОтработаноЧасовСовместителиСНачалаГода)/НомерМесяцаКонцаКвартала;
		ФактическаяСНачалаГодаОсн = (ФактическаяСНачалаГодаОсн + ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаОсн + ОтработаноЧасовСовместителиСНачалаГодаОсн)/НомерМесяцаКонцаКвартала;
		ФактическаяСНачалаГодаЖенщины = (ФактическаяСНачалаГодаЖенщины + ОтработаноЧасовПоСокращенномуГрафикуСНачалаГодаЖенщины + ОтработаноЧасовСовместителиСНачалаГодаЖенщины)/НомерМесяцаКонцаКвартала;
		Контейнер.Форма1ТСтраница2.П000001003002 = ФактическаяСНачалаГода;
		Контейнер.Форма1ТСтраница2.П000001004002 = ФактическаяСНачалаГодаОсн;
		Контейнер.Форма1ТСтраница3.П000001011002 = ФактическаяСНачалаГодаЖенщины;
		
		Контейнер.Форма1ТСтраница3.П000002002002 = ПринятоСНачалаГода;
		Контейнер.Форма1ТСтраница3.П000002004002 = ВыбылоПосокращениюЧисленностиСНачалаГода;
		Контейнер.Форма1ТСтраница3.П000002005002 = ВыбылоЛиквидацияПредприятияСНачалаГода;
		Контейнер.Форма1ТСтраница3.П000002006002 = ВыбылоНесоответствиеДолжностиСНачалаГода;
		Контейнер.Форма1ТСтраница3.П000002007002 = ВыбылоНарушениеТрудовойДисциплиныСНачалаГода;
		Контейнер.Форма1ТСтраница3.П000002008002 = ВыбылоОбстоятельстваНезависящиеОтВолиСторонСНачалаГода;
		Контейнер.Форма1ТСтраница3.П000002009002 = ВыбылоПоСобственномуЖеланиюСНачалаГода;
		Контейнер.Форма1ТСтраница3.П000002010002 = ВыбылоПоДругимПричинамСНачалаГода;  

		Контейнер.Форма1ТСтраница4.П000002013002 = ЧисленностьНеполнаяРабочаяНеделяСНачалаГода; 
		Контейнер.Форма1ТСтраница4.П000002014002 = ПростойСНачалаГода; 

	КонецЕсли;
	
	// Получение кадровых данных отчета за квартал
	ДанныеОтчета = Новый ДеревоЗначений;
	ПараметрыОтчетаДляЗаполнения.Вставить("ДатаНачалаПериодаВыборки", НачалоКвартала(ПараметрыОтчета.мДатаКонцаПериодаОтчета));
	ДанныеДляЗаполненияРегламентированнойОтчетностиКадроваяИстория("РегламентированныйОтчетСтатистикаФорма1Т", ПараметрыОтчетаДляЗаполнения, ДанныеОтчета);
	
	Принято = 0;
	Уволено = 0;
	НачальныеДанные = 0;
	ЧисленностьНаДатуЗаКвартал = 0;
	Если ДанныеОтчета <> Неопределено Тогда

		Для Каждого СтрокаПериод Из ДанныеОтчета.Строки Цикл
			Если СтрокаПериод.ВидСобытия <> Неопределено Тогда 
				Принято = Принято + СтрокаПериод.Прием;  
				Уволено	= Уволено + СтрокаПериод.Увольнение;
				НачальныеДанные = НачальныеДанные + СтрокаПериод.НачальныеДанные;
			КонецЕсли;
		КонецЦикла;
		
		ЧисленностьНаДатуЗаКвартал = Принято + НачальныеДанные - Уволено;
		Контейнер.Форма1ТСтраница3.П000002001001 = ЧисленностьНаДатуЗаКвартал;
		
	КонецЕсли;     
	
	Контейнер.Форма1ТСтраница3.П000001007001 = ?(ФактическаяЗаКвартал <> 0, Окр(ФОТЗаКвартал, 2)/Окр(ФактическаяЗаКвартал, 2)/3, 0);
	Контейнер.Форма1ТСтраница3.П000001007002 = ?(ФактическаяСНачалаГода <> 0, Окр(ФОТСНачалаГода, 2)/Окр(ФактическаяСНачалаГода, 2)/НомерМесяцаКонцаКвартала, 0);
	Контейнер.Форма1ТСтраница3.П000001008001 = ?(ФактическаяЗаКварталОсн <> 0, Окр(ФОТЗаКварталОсн, 2)/Окр(ФактическаяЗаКварталОсн, 2)/3, 0);
	Контейнер.Форма1ТСтраница3.П000001008002 = ?(ФактическаяСНачалаГодаОсн <> 0, Окр(ФОТСНачалаГодаОсн, 2)/Окр(ФактическаяСНачалаГодаОсн, 2)/НомерМесяцаКонцаКвартала, 0);
	
	ВсегоВыбылоСотрудниковЗаКвартал = ВыбылоПосокращениюЧисленности
									+ ВыбылоЛиквидацияПредприятия
									+ ВыбылоНесоответствиеДолжности
									+ ВыбылоНарушениеТрудовойДисциплины
									+ ВыбылоОбстоятельстваНезависящиеОтВолиСторон
									+ ВыбылоПоСобственномуЖеланию
									+ ВыбылоПоДругимПричинам;
									
	Контейнер.Форма1ТСтраница3.П000002003001 = ВсегоВыбылоСотрудниковЗаКвартал;
	ВсегоВыбылоСотрудниковСНачалаГода = ВыбылоПосокращениюЧисленностиСНачалаГода
									+ ВыбылоЛиквидацияПредприятияСНачалаГода
									+ ВыбылоНесоответствиеДолжностиСНачалаГода
									+ ВыбылоНарушениеТрудовойДисциплиныСНачалаГода
									+ ВыбылоОбстоятельстваНезависящиеОтВолиСторонСНачалаГода
									+ ВыбылоПоСобственномуЖеланиюСНачалаГода
									+ ВыбылоПоДругимПричинамСНачалаГода;
	Контейнер.Форма1ТСтраница3.П000002003002 = ВсегоВыбылоСотрудниковСНачалаГода;  
	
	// Получение кадровых данных отчета за квартал
	ДанныеОтчета = Новый ДеревоЗначений;
	ПараметрыОтчетаДляЗаполнения.Вставить("ДатаНачалаПериодаВыборки", НачалоГода(ПараметрыОтчета.мДатаКонцаПериодаОтчета));
	ДанныеДляЗаполненияРегламентированнойОтчетностиКадроваяИстория("РегламентированныйОтчетСтатистикаФорма1Т", ПараметрыОтчетаДляЗаполнения, ДанныеОтчета);
	
	Принято = 0;
	Уволено = 0;
	НачальныеДанные = 0;
	ЧисленностьНаДатуСНачалаГода = 0;
	Если ДанныеОтчета <> Неопределено Тогда

		Для Каждого СтрокаПериод Из ДанныеОтчета.Строки Цикл
			Если СтрокаПериод.ВидСобытия <> Неопределено Тогда 
				Принято = Принято + СтрокаПериод.Прием;
				Уволено	= Уволено + СтрокаПериод.Увольнение;
				НачальныеДанные = НачальныеДанные + СтрокаПериод.НачальныеДанные;
			КонецЕсли;
		КонецЦикла;
		ЧисленностьНаДатуСНачалаГода = Принято + НачальныеДанные - Уволено; 
		Контейнер.Форма1ТСтраница3.П000002001002 = ЧисленностьНаДатуСНачалаГода;
		
	КонецЕсли;   
	
	Контейнер.Форма1ТСтраница3.П000002011001 = ЧисленностьНаДатуЗаКвартал + ПринятоЗаКвартал - ВсегоВыбылоСотрудниковЗаКвартал;
	Контейнер.Форма1ТСтраница3.П000002011002 = ЧисленностьНаДатуСНачалаГода + ПринятоСНачалаГода - ВсегоВыбылоСотрудниковСНачалаГода;

	// Получение данных по штатному расписанию за квартал
	ДанныеОтчета = Новый ДеревоЗначений;
	ПараметрыОтчетаДляЗаполнения.Вставить("ДатаАктуальности ", КонецКвартала(ПараметрыОтчета.мДатаКонцаПериодаОтчета));
	ДанныеДляЗаполненияРегламентированнойОтчетностиШтатныеЕдиницы("РегламентированныйОтчетСтатистикаФорма1Т", ПараметрыОтчетаДляЗаполнения, ДанныеОтчета);
	
	ЧислоВакантныхМест = 0;
	Если ДанныеОтчета <> Неопределено Тогда
		Для Каждого СтрокаОрганизация Из ДанныеОтчета.Строки Цикл
			ЧислоВакантныхМест = ЧислоВакантныхМест + СтрокаОрганизация.Отклонение; 
		КонецЦикла;
	КонецЕсли;
	
	Контейнер.Форма1ТСтраница4.П000002012001 = ?(ЧислоВакантныхМест > 0, ЧислоВакантныхМест, 0);;
	
КонецПроцедуры

Процедура ДанныеДляЗаполненияРегламентированнойОтчетностиКадроваяИстория(Вариант, ПараметрыОтчета, ДанныеОтчета) Экспорт
	
	СхемаКомпоновки = Отчеты.КадроваяИсторияСотрудников.ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
	
	ПараметрыОтчета.Вставить("Вариант", Вариант);
	ЗарплатаКадрыОбщиеНаборыДанных.ЗаполнитьОбщиеИсточникиДанныхОтчета(Новый Структура("СхемаКомпоновкиДанных", СхемаКомпоновки));
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	ПараметрыОтчета.Вставить("ЭтоКадроваяИстория", Истина);
	НастройкиОтчета = ЗаполнитьКомпоновщикНастроек(Вариант, ПараметрыОтчета, СхемаКомпоновки.ВариантыНастроек[Вариант].Настройки);
	
	// Запрос данных
	МакетКомпоновкиДанных = КомпоновщикМакета.Выполнить(СхемаКомпоновки,
		НастройкиОтчета, , , Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновкиДанных, , , Истина);
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ПроцессорВывода.УстановитьОбъект(ДанныеОтчета);
	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
	
КонецПроцедуры

Процедура ДанныеДляЗаполненияРегламентированнойОтчетностиЗарплатаКадры(Вариант, ПараметрыОтчета, ДанныеОтчета) Экспорт
	
	РегламентированнаяОтчетностьПереопределяемыйРК.ДанныеДляЗаполненияРегламентированнойОтчетностиЗарплатаКадры(Вариант, ПараметрыОтчета, ДанныеОтчета);
	
КонецПроцедуры

Процедура ДанныеДляЗаполненияРегламентированнойОтчетностиШтатныеЕдиницы(Вариант, ПараметрыОтчета, ДанныеОтчета) Экспорт
	
	СхемаКомпоновки = Отчеты.ШтатноеРасписание.ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");
	
	ПараметрыОтчета.Вставить("Вариант", Вариант);
	ЗарплатаКадрыОбщиеНаборыДанных.ЗаполнитьОбщиеИсточникиДанныхОтчета(Новый Структура("СхемаКомпоновкиДанных", СхемаКомпоновки));
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	ПараметрыОтчета.Вставить("ЭтоШтатноеРасписание", Истина);
	НастройкиОтчета = ЗаполнитьКомпоновщикНастроек(Вариант, ПараметрыОтчета, СхемаКомпоновки.ВариантыНастроек[Вариант].Настройки);
	
	МакетКомпоновкиДанных = КомпоновщикМакета.Выполнить(СхемаКомпоновки,
		НастройкиОтчета, , , Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновкиДанных, , , Истина);
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ПроцессорВывода.УстановитьОбъект(ДанныеОтчета);
	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
	
КонецПроцедуры

Функция ЗаполнитьКомпоновщикНастроек(Вариант, ПараметрыОтчета, НастройкиВарианта)
	
	Возврат РегламентированнаяОтчетностьПереопределяемыйРК.ЗаполнитьКомпоновщикНастроек(Вариант, ПараметрыОтчета, НастройкиВарианта);
	
КонецФункции

Процедура ЗначенияПоказателей_СтатистикаФорма1ТКвартальная_2019Кв1(ПараметрыОтчета, Контейнер) Экспорт

	// Сведения для отчета берутся за последний квартал.
	ПараметрыОтчетаДляЗаполнения = ОбщегоНазначенияКлиентСервер.СкопироватьСтруктуру(ПараметрыОтчета);
	
	Квартал = Формат(ПараметрыОтчета.мДатаНачалаПериодаОтчета, "ДФ=к");
	Контейнер.Форма1ТСтраница1.Квартал1 = "0";
	Контейнер.Форма1ТСтраница1.Квартал2 = Квартал;
	
	Год = Формат(ПараметрыОтчета.мДатаНачалаПериодаОтчета, "ДФ=гггг");
	Контейнер.Форма1ТСтраница1.Год1 = Сред(Год, 1, 1);
	Контейнер.Форма1ТСтраница1.Год2 = Сред(Год, 2, 1);
	Контейнер.Форма1ТСтраница1.Год3 = Сред(Год, 3, 1);
	Контейнер.Форма1ТСтраница1.Год4 = Сред(Год, 4, 1);
	
	СтрокаСведений = "ИННЮЛ, НаимЮЛПол, ФИОРук, ФИОБух, ОКВЭД, ОКАТО, ПолныйАдрЮР, АдрФакт, АдрФактСтат, ТелОрганизации, АдресЭлектроннойПочтыОрганизации, ОснВидДеят";
	СведенияОбОрганизации = РегламентированнаяОтчетностьВызовСервера.ПолучитьСведенияОбОрганизации(ПараметрыОтчета.Организация,,СтрокаСведений);
	
	Контейнер.Форма1ТСтраница2.АдрФакт 	 	 = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(ПараметрыОтчета.Организация, Справочники.ВидыКонтактнойИнформации.ФактАдресОрганизации, ПараметрыОтчета.мДатаКонцаПериодаОтчета);
	Контейнер.Форма1ТСтраница2.НаимОКЭД		 = СведенияОбОрганизации.ОснВидДеят;
	Контейнер.Форма1ТСтраница4.НаимЮЛПол	 = СведенияОбОрганизации.НаимЮЛПол;
	Контейнер.Форма1ТСтраница4.Исполнитель 	 = Пользователи.ТекущийПользователь();
	Контейнер.Форма1ТСтраница5.ФИОРук	 	 = СведенияОбОрганизации.ФИОРук;
	Контейнер.Форма1ТСтраница5.ФИОБух	 	 = СведенияОбОрганизации.ФИОБух;
	
	Если НЕ  ПараметрыОтчета.Организация.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо Тогда
		Контейнер.Форма1ТСтраница4.АдрЮР			= СведенияОбОрганизации.ПолныйАдрЮР;
		Контейнер.Форма1ТСтраница4.ТелОрганизации	= СведенияОбОрганизации.ТелОрганизации;
		Контейнер.Форма1ТСтраница4.ЭлПочта			= СведенияОбОрганизации.АдресЭлектроннойПочтыОрганизации;
	     // Код БИН
		ДлинаИИН = СтрДлина(СведенияОбОрганизации.ИННЮЛ);
		Если ДлинаИИН <= 12 Тогда
			Для Шаг = 1 По ДлинаИИН Цикл
				Контейнер.Форма1ТСтраница1["БИН" + Шаг] = СРЕД(СведенияОбОрганизации.ИННЮЛ, Шаг, 1);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	// Код КАТО     
	КодКАТО = Лев(СведенияОбОрганизации.ОКАТО,10); // длина кода всего 9 символов, добавим 10-й
	ДлинаКАТО = СтрДлина(КодКАТО); 
	Если ДлинаКАТО <= 10 Тогда
		Для Шаг = 1 По ДлинаКАТО Цикл
			Контейнер.Форма1ТСтраница2["КодКАТО" + Шаг] = СРЕД(КодКАТО, Шаг, 1);
		КонецЦикла;
	КонецЕсли;
	// Код по ОКЭД
	ДлинаКодПоОКЭД = СтрДлина(СведенияОбОрганизации.ОКВЭД);
	Если ДлинаКодПоОКЭД <= 5 Тогда
		Для Шаг = 1 По ДлинаКодПоОКЭД Цикл
			Контейнер.Форма1ТСтраница2["КодПоОКЭД" + Шаг] = СРЕД(СведенияОбОрганизации.ОКВЭД, Шаг, 1);
		КонецЦикла;
	КонецЕсли;
	
	ИсключаемыеСостояния = Новый СписокЗначений;
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускПоБеременностиИРодам);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускПоУходуЗаРебенком);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускНеоплачиваемыйПоЗаконодательству);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускНеоплачиваемыйПоРазрешениюРаботодателя);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ДополнительныйОтпускНеоплачиваемый);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускУчебныйНеоплачиваемый);

	// Получение зарплатных данных отчета за квартал
	ДанныеОтчета = Новый ДеревоЗначений;
	ПараметрыОтчетаДляЗаполнения.Вставить("ДатаНачалаПериодаВыборки", НачалоКвартала(ПараметрыОтчета.мДатаКонцаПериодаОтчета));
	ПараметрыОтчетаДляЗаполнения.Вставить("ИсключаемыеСостояния", ИсключаемыеСостояния);  
	ПараметрыОтчетаДляЗаполнения.Вставить("КодОКВЭД", СведенияОбОрганизации.ОКВЭД);
	ДанныеДляЗаполненияРегламентированнойОтчетностиЗарплатаКадры("РегламентированныйОтчетСтатистикаФорма1Т", ПараметрыОтчетаДляЗаполнения, ДанныеОтчета);
	
	ФОТЗаКвартал = 0;
	ФОТЗаКварталОсн = 0;
	ОтработаноЧасовЗаКвартал = 0;
	СреднесписочнаяЗаКвартал = 0;
	СреднесписочнаяЗаКварталОсн = 0;
	ФактическаяЗаКвартал = 0;
	ФактическаяЗаКварталОсн = 0;
	ОтработаноЧасовПоСокращенномуГрафикуЗаКвартал = 0;
	ОтработаноЧасовСовместителиЗаКвартал = 0;
	ОтработаноЧасовПоСокращенномуГрафикуЗаКварталОсн = 0;
	ОтработаноЧасовСовместителиЗаКварталОсн = 0;
	ПринятоЗаКвартал = 0;
	ВыбылоЛиквидацияПредприятия = 0;
	ВыбылоНарушениеТрудовойДисциплины = 0;
	ВыбылоНесоответствиеДолжности = 0;
	ВыбылоОбстоятельстваНезависящиеОтВолиСторон = 0;
	ВыбылоПоДругимПричинам = 0;
	ВыбылоПоСобственномуЖеланию = 0;
	ВыбылоПосокращениюЧисленности = 0;
	ЧисленностьНеполнаяРабочаяНеделя = 0;
	Простой = 0;
	СреднесписочнаяЗаКварталЖенщины = 0;
	ФактическаяЗаКварталЖенщины = 0;
	СреднесписочнаяСовместителиЗаКвартал = 0;
	СреднесписочнаяГПХЗаКвартал = 0;
	ОтработаноЧасовПоСокращенномуГрафикуЗаКварталЖенщины = 0;
	ОтработаноЧасовСовместителиЗаКварталЖенщины = 0;
	Если ДанныеОтчета <> Неопределено Тогда

		Для Каждого СтрокаОрганизация Из ДанныеОтчета.Строки Цикл
			
			Простой = Простой + СтрокаОрганизация.Простой;
			ЧисленностьНеполнаяРабочаяНеделя = ЧисленностьНеполнаяРабочаяНеделя + СтрокаОрганизация.ЧисленностьНеполнаяРабочаяНеделя;

			Для Каждого СтрокаПериод Из СтрокаОрганизация.Строки Цикл
				
				ФОТЗаКвартал = ФОТЗаКвартал + (СтрокаПериод.НачисленоРаботникамСписочногоСостава
											+ СтрокаПериод.НачисленоВнутреннимСовместителям
											+ СтрокаПериод.НачисленоВнешнимСовместителям);
				
				ФОТЗаКварталОсн = ФОТЗаКварталОсн + (СтрокаПериод.НачисленоРаботникамСписочногоСоставаОсн
													+ СтрокаПериод.НачисленоВнутреннимСовместителямОсн
													+ СтрокаПериод.НачисленоВнешнимСовместителямОсн); 
				
				ОтработаноЧасовЗаКвартал = ОтработаноЧасовЗаКвартал + (СтрокаПериод.ОтработаноЧасовСНачалаГодаРаботникамиСписочногоСостава
																	+ СтрокаПериод.ОтработаноЧасовСНачалаГодаВнешнимиСовместителями);
				
				СреднесписочнаяЗаКвартал 						 = СреднесписочнаяЗаКвартал + СтрокаПериод.СреднесписочнаяЧисленностьРК;
				СреднесписочнаяЗаКварталОсн 					 = СреднесписочнаяЗаКварталОсн + СтрокаПериод.СреднесписочнаяЧисленностьОснРК;
				СреднесписочнаяЗаКварталЖенщины					 = СреднесписочнаяЗаКварталЖенщины + СтрокаПериод.СреднесписочнаяЧисленностьЖенщинРК;
				СреднесписочнаяСовместителиЗаКвартал 			 = СреднесписочнаяСовместителиЗаКвартал + СтрокаПериод.СреднесписочнаяЧисленностьВнешнихСовместителей;
				СреднесписочнаяГПХЗаКвартал						 = СреднесписочнаяГПХЗаКвартал + СтрокаПериод.СреднесписочнаяЧисленностьГПХРК;
				ФактическаяЗаКвартал 							 = ФактическаяЗаКвартал + СтрокаПериод.ФактическаяЧисленностьРК;
				ФактическаяЗаКварталЖенщины 					 = ФактическаяЗаКварталЖенщины + СтрокаПериод.ФактическаяЧисленностьЖенщинРК;
				ФактическаяЗаКварталОсн 						 = ФактическаяЗаКварталОсн + СтрокаПериод.ФактическаяЧисленностьОснРК;
				ОтработаноЧасовПоСокращенномуГрафикуЗаКвартал 	 = ОтработаноЧасовПоСокращенномуГрафикуЗаКвартал + СтрокаПериод.ОтработаноЧасовПоСокращенномуГрафику;
				ОтработаноЧасовСовместителиЗаКвартал 			 = ОтработаноЧасовСовместителиЗаКвартал + СтрокаПериод.ОтработаноЧасовСовместители;
				ОтработаноЧасовПоСокращенномуГрафикуЗаКварталОсн = ОтработаноЧасовПоСокращенномуГрафикуЗаКварталОсн + СтрокаПериод.ОтработаноЧасовПоСокращенномуГрафикуОсн;
				ОтработаноЧасовСовместителиЗаКварталОсн 		 = ОтработаноЧасовСовместителиЗаКварталОсн + СтрокаПериод.ОтработаноЧасовСовместителиОсн;
				ОтработаноЧасовПоСокращенномуГрафикуЗаКварталЖенщины 	= ОтработаноЧасовПоСокращенномуГрафикуЗаКварталЖенщины + СтрокаПериод.ОтработаноЧасовПоСокращенномуГрафикуЖенщины;
				ОтработаноЧасовСовместителиЗаКварталЖенщины 			= ОтработаноЧасовСовместителиЗаКварталЖенщины + СтрокаПериод.ОтработаноЧасовСовместителиЖенщины;
				ПринятоЗаКвартал 								 = ПринятоЗаКвартал + СтрокаПериод.ПринятВПериоде;
				
				ВыбылоЛиквидацияПредприятия 				= ВыбылоЛиквидацияПредприятия + СтрокаПериод.ВыбылоЛиквидацияПредприятия;
				ВыбылоНарушениеТрудовойДисциплины 			= ВыбылоНарушениеТрудовойДисциплины + СтрокаПериод.ВыбылоНарушениеТрудовойДисциплины;
