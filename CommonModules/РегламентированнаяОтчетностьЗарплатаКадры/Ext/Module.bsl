									СуммаСНИсчисленный = СуммаСНИсчисленный + Окр(Выборка.НалогВзносИсчисленный);
		                        КонецЕсли;
														
							ИначеЕсли Выборка.ВидНалогаИсчисленный = Перечисления.ВидыНалоговВзносовОтчислений.СО Тогда 
								
