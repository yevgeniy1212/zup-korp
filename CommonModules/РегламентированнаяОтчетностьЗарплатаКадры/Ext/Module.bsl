	НомерЛиста = 0;
	ВыборкаРегистрации = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Контейнер.Форма200_06.Очистить();
	
	Пока ВыборкаРегистрации.Следующий() Цикл
		
		ВыборкаОрганизации = ВыборкаРегистрации.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		ПоследнийНомерЛистаПредыдущейРегистрации = НомерЛиста;
		
		Пока ВыборкаОрганизации.Следующий() Цикл
			
			Выборка = ВыборкаОрганизации.Выбрать();
			
			Если ЗначениеЗаполнено(ВыборкаОрганизации.Наименование) Тогда
				ИИНФилиала = ВыборкаОрганизации.БИН;
			ИначеЕсли ВыборкаОрганизации.Организация <> ПараметрыОтчета.Организация ИЛИ ВыборкаОрганизации.Регистрация <> РегистрацияГоловнойОрганизации Тогда
				СведенияОФилиале = РегламентированнаяОтчетностьВызовСервера.ПолучитьСведенияОбОрганизации(ВыборкаОрганизации.Организация,,СтрокаСведений);
				ИИНФилиала = СведенияОФилиале.ИННЮЛ;
			Иначе // головная организация
				ИИНФилиала = "";
			КонецЕсли;
			
			Если Выборка.Количество() <> 0 Тогда
				
				ЕПИмеется = Истина;
				
				Если ВыборкаОрганизации.Количество() >= (НомерЛиста - ПоследнийНомерЛистаПредыдущейРегистрации) + 1 Тогда
