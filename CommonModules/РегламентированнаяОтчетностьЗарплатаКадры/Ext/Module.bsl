	|	МАКСИМУМ(ЕСТЬNULL(ФизЛица.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент))),
	|	МАКСИМУМ(ЕСТЬNULL(ФизЛица.КодДок, """")),
	|	МАКСИМУМ(ЕСТЬNULL(ФизЛица.Номер, """")),
	|	МАКСИМУМ(ЕСТЬNULL(ФизЛица.ДатаВыдачи, &парамПустаяДата)),
	|	МАКСИМУМ(ЕСТЬNULL(ФизЛица.ФамилияИмяОтчество, """")),
	|	ВТ_ИсчисленныеПрочиеВычеты.ФизЛицоСтруктурногоПодразделения,
	|	"""",
