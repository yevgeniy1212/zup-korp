	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_СведенияОДоходах
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_ФизЛица
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_ПрочиеВычеты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_ИсчисленныеПрочиеВычеты
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_ЗадолженностьПоДоходамФизЛицу
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ ВТ_ВыплаченоФизЛицу
	|";
	
	ВыборкаФИО = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	НомерСтроки = 2;
	
	// используется в 200.02 и 200.05
	ОписаниеТиповСтрока12 = Новый ОписаниеТипов("Строка",,Новый КвалификаторыСтроки(12));
	ОписаниеТиповЧисло12  = Новый ОписаниеТипов("Число", Новый КвалификаторыЧисла(12, 0));
	
	ТаблицаСтандартныхВычетов = Новый ТаблицаЗначений;
	ТаблицаПрочихВычетов = Новый ТаблицаЗначений;
	ТаблицаНеоблагаемыхДоходов = Новый ТаблицаЗначений;
	
	ТаблицаСтандартныхВычетов.Колонки.Добавить("КодСтроки", ОписаниеТиповСтрока12);
	ТаблицаСтандартныхВычетов.Колонки.Добавить("Сумма", ОписаниеТиповЧисло12);
	
	ТаблицаПрочихВычетов.Колонки.Добавить("КодСтроки", ОписаниеТиповСтрока12);
	ТаблицаПрочихВычетов.Колонки.Добавить("Сумма", ОписаниеТиповЧисло12);

	ТаблицаНеоблагаемыхДоходов.Колонки.Добавить("КодСтроки", ОписаниеТиповСтрока12);
	ТаблицаНеоблагаемыхДоходов.Колонки.Добавить("Сумма", ОписаниеТиповЧисло12);
	
	Пока ВыборкаФИО.Следующий() Цикл
		
		ВыборкаПоСтруктурному = ВыборкаФИО.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаПоСтруктурному.Следующий() Цикл
		
			Выборка = ВыборкаПоСтруктурному.Выбрать();
			Если Выборка.Количество() <>  0 Тогда
				
				НоваяСтрокаСтр1 = Контейнер.Форма200_02Страница1_ДанныеДопСтрок.Добавить();
				НоваяСтрокаСтр2 = Контейнер.Форма200_02Страница2_ДанныеДопСтрок.Добавить();
				НоваяСтрокаСтр3 = Контейнер.Форма200_02Страница3_ДанныеДопСтрок.Добавить();
				НоваяСтрокаСтр4 = Контейнер.Форма200_02Страница4_ДанныеДопСтрок.Добавить();
				НоваяСтрокаСтр5 = Контейнер.Форма200_02Страница5_ДанныеДопСтрок.Добавить();
				НоваяСтрокаСтр6 = Контейнер.Форма200_02Страница6_ДанныеДопСтрок.Добавить();
				НоваяСтрокаСтр7 = Контейнер.Форма200_02Страница7_ДанныеДопСтрок.Добавить();
				НоваяСтрокаСтр8 = Контейнер.Форма200_02Страница8_ДанныеДопСтрок.Добавить();
				НоваяСтрокаСтр9 = Контейнер.Форма200_02Страница9_ДанныеДопСтрок.Добавить();
				
				ТаблицаСтандартныхВычетов.Очистить();
				ТаблицаПрочихВычетов.Очистить();
				ТаблицаНеоблагаемыхДоходов.Очистить();
				
				ПерваяСтрокаСтандартныхВычетовЗаполнена = Ложь;
				ПерваяСтрокаПрочихВычетовЗаполнена = Ложь;
				ПерваяСтрокаНеоблагаемыхДоходовЗаполнена = Ложь;
					
			КонецЕсли;
			
			ПервыйПроход = Истина;  //!!!
			
			СуммаООСМС = 0;
			СуммаВОСМС = 0;
			СуммаВОСМСИсчисленный = 0;
			
			Пока Выборка.Следующий() Цикл
				
				Если ПервыйПроход Тогда
					
					НоваяСтрокаСтр1.П000210000101 = НомерСтроки;
					НоваяСтрокаСтр2.П000220000101 = НомерСтроки;
					НоваяСтрокаСтр3.П000230000101 = НомерСтроки;
					НоваяСтрокаСтр4.П000240000201 = НомерСтроки;
					НоваяСтрокаСтр5.П000250000201 = НомерСтроки;
					НоваяСтрокаСтр6.П000260000201 = НомерСтроки;
					НоваяСтрокаСтр7.П000270000201 = НомерСтроки;
					НоваяСтрокаСтр8.П000280000201 = НомерСтроки;
					НоваяСтрокаСтр9.П000290000201 = НомерСтроки;
					
					НоваяСтрокаСтр1.П000210000102 = Выборка.ФамилияИмяОтчество;
					НоваяСтрокаСтр1.П000210000102Ссылка = Выборка.ФизическоеЛицо;

					НоваяСтрокаСтр1.П000210000103 = Выборка.ИИН;
					НоваяСтрокаСтр1.П000210000104 = ?(ЗначениеЗаполнено(Выборка.СтранаГражданства), Выборка.КодСтраны, "00");
					НоваяСтрокаСтр1.П000210000105 = ?(Выборка.СтатусНалогплательщика = Перечисления.СтатусыФизическихЛицНалогоплательщиков.Резидент, "1", "2");
					НоваяСтрокаСтр1.П000210000106 = ?(Выборка.СтатусНалогплательщика = Перечисления.СтатусыФизическихЛицНалогоплательщиков.Резидент, "KZ", Выборка.КодСтраны);
					НоваяСтрокаСтр2.П000220000102 = Выборка.ИИНВСтранеГражданства;
					НоваяСтрокаСтр2.П000220000103 = Выборка.КодДокумента;
					НоваяСтрокаСтр2.П000220000104 = Выборка.НомерДокумента;
					НоваяСтрокаСтр2.П000220000105 = Выборка.ДатаВыдачиДокумента;
					НоваяСтрокаСтр3.П000230000102 = 1200;
					НоваяСтрокаСтр3.П000230000107 = ?(Выборка.ФизЛицоСтруктурногоПодразделения > 0, "X", "");
					НоваяСтрокаСтр3.П000230000108 = 10;
					
					НоваяСтрокаСтр4.П000240000202 = Окр(ВыборкаПоСтруктурному.СуммаДохода);

				КонецЕсли;
				
				Если Выборка.ВидНалогаИсчисленный <> Перечисления.ВидыНалоговВзносовОтчислений.ПустаяСсылка() Тогда
						
					Если Выборка.ВидНалогаИсчисленный = Перечисления.ВидыНалоговВзносовОтчислений.ИПН Тогда 
						
						Если ЗначениеЗаполнено(Выборка.КодСтроки) Тогда
							
							Если ТипЗнч(Выборка.КодСтроки) = Тип("Строка") Тогда
								
								НомерСтатьиНК = Выборка.КодСтроки;
								
							Иначе
								
								ТекстСообщения = НСтр("ru = 'При заполнении приложения 200.02 для <%1> не задан код строки Декларации!'");								
								ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, Выборка.КодСтроки);			
								ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения, Выборка.КодСтроки);

								НомерСтатьиНК = "";
								
							КонецЕсли;
							
							Если НЕ ПерваяСтрокаНеоблагаемыхДоходовЗаполнена Тогда
								
								ПерваяСтрокаНеоблагаемыхДоходовЗаполнена = Истина;
								
								Если СтрНайти(НомерСтатьиНК, "654") > 0 Тогда
									НоваяСтрокаСтр4.П000240000205 = Окр(Выборка.НеоблагаемыйДоходИсчисленный);
								Иначе
									НоваяСтрокаСтр4.П000240000204 = Окр(Выборка.НеоблагаемыйДоходИсчисленный);
								КонецЕсли;
								
								ПерваяСтрокаНеоблагаемыхДоходовЗаполнена = Истина;
								НоваяСтрокаСтр4.П000240000203 = НомерСтатьиНК;
									
							Иначе
								
								Строка = ТаблицаНеоблагаемыхДоходов.Добавить();
								Строка.КодСтроки = НомерСтатьиНК;
								Строка.Сумма = Окр(Выборка.НеоблагаемыйДоходИсчисленный);
								
							КонецЕсли;
							
						Иначе
							
							НоваяСтрокаСтр6.П000260000204 = Окр(Выборка.НалогВзносИсчисленный);
							НоваяСтрокаСтр7.П000270000203 = Окр(Выборка.НалогВзносРасход);
							
						КонецЕсли;
						
					ИначеЕсли Выборка.ВидНалогаИсчисленный = Перечисления.ВидыНалоговВзносовОтчислений.СН Тогда 
						
						НоваяСтрокаСтр8.П000280000203 = Окр(Выборка.ОбъектИсчисления);
						// СН исчисленный
						НоваяСтрокаСтр8.П000280000204 = Окр(Выборка.НалогВзносИсчисленный) + НоваяСтрокаСтр8.П000280000205;
						НоваяСтрокаСтр9.П000290000202 = Окр(Выборка.НалогВзносИсчисленный);
						
					ИначеЕсли Выборка.ВидНалогаИсчисленный = Перечисления.ВидыНалоговВзносовОтчислений.СО Тогда 
						
						НоваяСтрокаСтр8.П000280000205 = Окр(Выборка.НалогВзносИсчисленный);
						// СН исчисленный
						НоваяСтрокаСтр8.П000280000204 = НоваяСтрокаСтр8.П000280000204 + Окр(Выборка.НалогВзносИсчисленный);
						
					ИначеЕсли Выборка.ВидНалогаИсчисленный = Перечисления.ВидыНалоговВзносовОтчислений.ОПВ Тогда 
						
						НоваяСтрокаСтр5.П000250000202 = Окр(Выборка.НалогВзносИсчисленный);
						НоваяСтрокаСтр7.П000270000204 = Окр(Выборка.НалогВзносРасход);
						
					ИначеЕсли Выборка.ВидНалогаИсчисленный = Перечисления.ВидыНалоговВзносовОтчислений.ОППВ Тогда 
						
						НоваяСтрокаСтр9.П000290000203 = Окр(Выборка.НалогВзносИсчисленный);
						
					ИначеЕсли Выборка.ВидНалогаИсчисленный = "ВыплаченоДоходов" Тогда 
						
						НоваяСтрокаСтр7.П000270000202 = Окр(Выборка.ВыплаченоДоходов);
											
					ИначеЕсли Выборка.ВидНалогаИсчисленный = "ЗадолженностьЗаКвартал" Тогда 
						
						НоваяСтрокаСтр6.П000260000205 = Окр(Выборка.ЗадолженностьЗаКвартал);
											
					ИначеЕсли Выборка.ВидНалогаИсчисленный = Перечисления.ВидыНалоговВзносовОтчислений.ООСМС Тогда 
						
						СуммаООСМС = СуммаООСМС + Окр(Выборка.НалогВзносИсчисленный);
						
					ИначеЕсли Выборка.ВидНалогаИсчисленный = Перечисления.ВидыНалоговВзносовОтчислений.ВОСМС Тогда 
						
						СуммаВОСМСИсчисленный = СуммаВОСМСИсчисленный + Окр(Выборка.НалогВзносИсчисленный);
						СуммаВОСМС = СуммаВОСМС + Окр(Выборка.НалогВзносРасход);
						
					ИначеЕсли  ТипЗнч(Выборка.ВидНалогаИсчисленный) = Тип("СправочникСсылка.ВидыВычетовИПН")
						И Выборка.ВидНалогаИсчисленный = Справочники.ВидыВычетовИПН.ДобровольныеПенсионныеВзносы
						ИЛИ Выборка.ВидНалогаИсчисленный = Справочники.ВидыВычетовИПН.ВознагражденияПоЖилищнымЗаймам 
						ИЛИ Выборка.ВидНалогаИсчисленный = Справочники.ВидыВычетовИПН.НаОплатуМедицинскихУслуг Тогда 
					
						Если НЕ ПерваяСтрокаПрочихВычетовЗаполнена Тогда
							
							ПерваяСтрокаПрочихВычетовЗаполнена = Истина;
							
							НоваяСтрокаСтр6.П000260000203 = Окр(Выборка.ПримененныйВычетИсчисленный);
							
							Если Выборка.ВидНалогаИсчисленный = Справочники.ВидыВычетовИПН.ДобровольныеПенсионныеВзносы Тогда
								НоваяСтрокаСтр6.П000260000202 = "1";
							ИначеЕсли Выборка.ВидНалогаИсчисленный = Справочники.ВидыВычетовИПН.НаОплатуМедицинскихУслуг Тогда
								НоваяСтрокаСтр6.П000260000202 = "2";
							ИначеЕсли Выборка.ВидНалогаИсчисленный = Справочники.ВидыВычетовИПН.ВознагражденияПоЖилищнымЗаймам Тогда
								НоваяСтрокаСтр6.П000260000202 = "3";
							КонецЕсли;
							
						Иначе
							
							Строка = ТаблицаПрочихВычетов.Добавить();
							
							Если Выборка.ВидНалогаИсчисленный = Справочники.ВидыВычетовИПН.ДобровольныеПенсионныеВзносы Тогда
								Строка.КодСтроки = "1";
							ИначеЕсли Выборка.ВидНалогаИсчисленный = Справочники.ВидыВычетовИПН.НаОплатуМедицинскихУслуг Тогда
								Строка.КодСтроки = "2";
							ИначеЕсли Выборка.ВидНалогаИсчисленный = Справочники.ВидыВычетовИПН.ВознагражденияПоЖилищнымЗаймам Тогда
								Строка.КодСтроки = "3";
							КонецЕсли;
							
							Строка.Сумма = Окр(Выборка.ПримененныйВычетИсчисленный);
							
						КонецЕсли;
						
					ИначеЕсли ТипЗнч(Выборка.ВидНалогаИсчисленный) = Тип("СправочникСсылка.ВидыВычетовИПН")
						И (Выборка.ВидНалогаИсчисленный = Справочники.ВидыВычетовИПН.Стандартный1МЗП
						ИЛИ Выборка.ВидНалогаИсчисленный = Справочники.ВидыВычетовИПН.Стандартный75МЗПИнвалиды
						ИЛИ Выборка.ВидНалогаИсчисленный = Справочники.ВидыВычетовИПН.Стандартный75МЗПРодители) Тогда
						
						Если НЕ ПерваяСтрокаСтандартныхВычетовЗаполнена Тогда
							
							ПерваяСтрокаСтандартныхВычетовЗаполнена = Истина;
							
							НоваяСтрокаСтр5.П000250000205 = Окр(Выборка.ПримененныйВычетИсчисленный);
							
							Если Выборка.ВидНалогаИсчисленный = Справочники.ВидыВычетовИПН.Стандартный1МЗП Тогда
								НоваяСтрокаСтр5.П000250000204 = "1";
							ИначеЕсли Выборка.ВидНалогаИсчисленный = Справочники.ВидыВычетовИПН.Стандартный75МЗПИнвалиды Тогда
								НоваяСтрокаСтр5.П000250000204 = "2";
							ИначеЕсли Выборка.ВидНалогаИсчисленный = Справочники.ВидыВычетовИПН.Стандартный75МЗПРодители Тогда
								НоваяСтрокаСтр5.П000250000204 = "3";
							КонецЕсли;
							
						Иначе
							
							Строка = ТаблицаСтандартныхВычетов.Добавить();
							
							Если Выборка.ВидНалогаИсчисленный = Справочники.ВидыВычетовИПН.Стандартный1МЗП Тогда
								Строка.КодСтроки = "1";
							ИначеЕсли Выборка.ВидНалогаИсчисленный = Справочники.ВидыВычетовИПН.Стандартный75МЗПИнвалиды Тогда
								Строка.КодСтроки = "2";
							ИначеЕсли Выборка.ВидНалогаИсчисленный = Справочники.ВидыВычетовИПН.Стандартный75МЗПРодители Тогда
								Строка.КодСтроки = "3";
							КонецЕсли;
							
							Строка.Сумма = Окр(Выборка.ПримененныйВычетИсчисленный);
							
						КонецЕсли;
						
					КонецЕсли;
					
				КонецЕсли;
				
				ПервыйПроход = Ложь;
				
			КонецЦикла;
			
			НоваяСтрокаСтр5.П000250000203 = СуммаВОСМСИсчисленный;
			НоваяСтрокаСтр7.П000270000205 = СуммаВОСМС;
			
			НоваяСтрокаСтр9.П000290000204 = СуммаООСМС;
			
			ТаблицаСтандартныхВычетов.Свернуть("КодСтроки", "Сумма");
			ТаблицаПрочихВычетов.Свернуть("КодСтроки", "Сумма");
			ТаблицаНеоблагаемыхДоходов.Свернуть("КодСтроки", "Сумма");
			
			КоличествоТаблицаСтандартныхВычетов = ТаблицаСтандартныхВычетов.Количество();
			КоличествоТаблицаПрочихВычетов = ТаблицаПрочихВычетов.Количество();
			КоличествоНеоблагаемыхДоходов = ТаблицаНеоблагаемыхДоходов.Количество();
			
			КлючевыеПоляСтраница1 = Новый Структура("П000210000102, П000210000103, П000210000104, П000210000105, П000210000106, П000210000102Ссылка");
			КлючевыеПоляСтраница2 = Новый Структура("П000220000102, П000220000103, П000220000104, П000220000105");
			КлючевыеПоляСтраница3 = Новый Структура("П000230000102, П000230000103, П000230000104, П000230000105, П000230000106, П000230000107, П000230000108");
			
			ЗаполнитьЗначенияСвойств(КлючевыеПоляСтраница1, НоваяСтрокаСтр1);
			ЗаполнитьЗначенияСвойств(КлючевыеПоляСтраница2, НоваяСтрокаСтр2);
			ЗаполнитьЗначенияСвойств(КлючевыеПоляСтраница3, НоваяСтрокаСтр3);
			
			МаксимальноеКоличествоСтрок = Макс(КоличествоТаблицаСтандартныхВычетов, КоличествоТаблицаПрочихВычетов, КоличествоНеоблагаемыхДоходов);
			
			Счетчик = 0;
			
			Пока Счетчик < МаксимальноеКоличествоСтрок Цикл
				
