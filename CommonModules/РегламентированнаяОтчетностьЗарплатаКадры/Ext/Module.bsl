				СоответствияПолейГруппировкиНомерамРазделов.Вставить(8, ВозрастПоСтрокам);
				
				КолонкиСуммирования = "Прием, Увольнение, НачальныеДанные";  
				ИмяПользовательскогоПоляНомерТаблицы = СоответствияПолейНомерамПользовательскихКолонок.Получить("Раздел8");
				Отбор = Новый Структура(ИмяПользовательскогоПоляНомерТаблицы, Истина);
				Таблица = ДанныеОтчетаТЗ.Скопировать(Отбор);
				Таблица.Свернуть(СоответствияПолейГруппировкиНомерамРазделов.Получить(8), КолонкиСуммирования);
				
				Для Каждого СтрокаТаблицы Из Таблица Цикл
					Для НомерСтроки = 1 По 4 Цикл
						ИмяПользовательскогоПоляНомерСтроки = СоответствияПолейНомерамПользовательскихКолонок.Получить("Возраст" + НомерСтроки);
						Если СтрокаТаблицы[ИмяПользовательскогоПоляНомерСтроки] = Строка(НомерСтроки) + "Возраст" Тогда
							ПринятоПоВозрасту = СтрокаТаблицы.Прием;
							УволеноПоВозрасту = СтрокаТаблицы.Увольнение;
							НачальныеДанныеПоВозрасту = СтрокаТаблицы.НачальныеДанные;
							ЧисленностьНаКонецГодаПоВозрасту = ПринятоПоВозрасту + НачальныеДанныеПоВозрасту - УволеноПоВозрасту;
							
							Контейнер.Форма1ТСтраница9["П000008" + Формат(НомерСтроки+1,"ЧЦ=3; ЧВН=") + "001"] = Контейнер.Форма1ТСтраница9["П000008" + Формат(НомерСтроки+1,"ЧЦ=3; ЧВН=") + "001"] + ЧисленностьНаКонецГодаПоВозрасту;
						КонецЕсли;
					КонецЦикла;
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
		ЧисленностьНаКонецГода = Принято + НачальныеДанные - Уволено; 
		ЧисленностьНаКонецГодаПенсионеры = ПринятоПенсионеры + НачальныеДанныеПенсионеры - УволеноПенсионеры; 
		ЧисленностьНаКонецГодаИнвалиды = ПринятоИнвалиды + НачальныеДанныеИнвалиды - УволеноИнвалиды; 
		ЧисленностьНаКонецГодаИнвалидыЖенщины = ПринятоИнвалидыЖенщины + НачальныеДанныеИнвалидыЖенщины - УволеноИнвалидыЖенщины; 

		Контейнер.Форма1ТСтраница9.П000008001001 = ЧисленностьНаКонецГода;
		Контейнер.Форма1ТСтраница9.П000008006001 = ЧисленностьНаКонецГодаПенсионеры;
		Контейнер.Форма1ТСтраница9.П000008007001 = ЧисленностьНаКонецГодаИнвалиды;
		Контейнер.Форма1ТСтраница10.П000008008001 = ЧисленностьНаКонецГодаИнвалидыЖенщины;
		
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗначенияПоказателей_СтатистикаФорма1ТГодовая_2020Кв1(ПараметрыОтчета, Контейнер) Экспорт

	// Сведения для отчета берутся за год.
