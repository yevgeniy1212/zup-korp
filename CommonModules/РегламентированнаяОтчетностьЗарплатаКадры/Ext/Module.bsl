Процедура ЗначенияПоказателей_СтатистикаФорма1ТЗП_2017Кв1(ПараметрыОтчета, Контейнер) Экспорт

	// Сведения для отчета берутся за последний квартал.
	ПараметрыОтчетаДляЗаполнения = ОбщегоНазначенияКлиентСервер.СкопироватьСтруктуру(ПараметрыОтчета);
	
	Год = Формат(ПараметрыОтчета.мДатаНачалаПериодаОтчета, "ДФ=гггг");
	Контейнер.Форма1ТСтраница1.Год1 = Сред(Год, 1, 1);
	Контейнер.Форма1ТСтраница1.Год2 = Сред(Год, 2, 1);
	Контейнер.Форма1ТСтраница1.Год3 = Сред(Год, 3, 1);
	Контейнер.Форма1ТСтраница1.Год4 = Сред(Год, 4, 1);
	
	СтрокаСведений = "ИННЮЛ, НаимЮЛПол, ФИОРук, ФИОБух, ОКВЭД, ОКАТО, АдрЮР, ПолныйАдрЮР, АдрФакт, ТелОрганизации, АдресЭлектроннойПочтыОрганизации, ОснВидДеят";
	СведенияОбОрганизации = РегламентированнаяОтчетностьВызовСервера.ПолучитьСведенияОбОрганизации(ПараметрыОтчета.Организация,,СтрокаСведений);
	
	Контейнер.Форма1ТСтраница4.НаимЮЛПол 	 = СведенияОбОрганизации.НаимЮЛПол;
	Контейнер.Форма1ТСтраница4.ФИОРук	 	 = СведенияОбОрганизации.ФИОРук;
	Контейнер.Форма1ТСтраница4.ФИОБух	 	 = СведенияОбОрганизации.ФИОБух;
	Контейнер.Форма1ТСтраница4.Исполнитель 	 = Пользователи.ТекущийПользователь();
	
	Если НЕ  ПараметрыОтчета.Организация.ЮридическоеФизическоеЛицо = Перечисления.ЮридическоеФизическоеЛицо.ФизическоеЛицо Тогда
		Контейнер.Форма1ТСтраница4.АдрЮР			= СведенияОбОрганизации.ПолныйАдрЮР;
		Контейнер.Форма1ТСтраница4.ТелОрганизации	= СведенияОбОрганизации.ТелОрганизации;
		Контейнер.Форма1ТСтраница4.ЭлПочта			= СведенияОбОрганизации.АдресЭлектроннойПочтыОрганизации;
	     // Код БИН
		ДлинаИИН = СтрДлина(СведенияОбОрганизации.ИННЮЛ);
		Если ДлинаИИН <= 12 Тогда
			Для Шаг = 1 По ДлинаИИН Цикл
				Контейнер.Форма1ТСтраница1["БИН" + Шаг] = СРЕД(СведенияОбОрганизации.ИННЮЛ, Шаг, 1);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;

	ИсключаемыеСостояния = Новый СписокЗначений;
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускПоБеременностиИРодам);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускПоУходуЗаРебенком);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускНеоплачиваемыйПоЗаконодательству);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускНеоплачиваемыйПоРазрешениюРаботодателя);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ДополнительныйОтпускНеоплачиваемый);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускУчебныйНеоплачиваемый);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускУчебныйОплачиваемый);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.БолезньБезОплаты);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.Болезнь);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.Прогул);
	ИсключаемыеСостояния.Добавить(Перечисления.СостоянияСотрудника.ПростойПоВинеРаботника);

	// Получение зарплатных данных отчета за квартал
	ДанныеОтчета = Новый ДеревоЗначений;
	ПараметрыОтчетаДляЗаполнения.Вставить("ИсключаемыеСостояния", ИсключаемыеСостояния);
	ПараметрыОтчетаДляЗаполнения.Вставить("ЗП", Истина);	
	ПараметрыОтчетаДляЗаполнения.Вставить("ДатаНачалаПериодаВыборки", НачалоМесяца(ПараметрыОтчета.мДатаКонцаПериодаОтчета));
	ДанныеДляЗаполненияРегламентированнойОтчетностиЗарплатаКадры("РегламентированныйОтчетСтатистикаФорма1Т", ПараметрыОтчетаДляЗаполнения, ДанныеОтчета);
		
	Если ДанныеОтчета <> Неопределено Тогда
		
		Для Каждого СтрокаОрганизация Из ДанныеОтчета.Строки Цикл
			Для Каждого СтрокаПериод Из СтрокаОрганизация.Строки Цикл
				Для каждого СтрокаСотрудник Из СтрокаПериод.Строки Цикл
				
					Для НомерСтроки = 1 По 10 Цикл
						Если СтрокаСотрудник.ФактическаяЧисленностьРК >= 1 Тогда
