					НоваяСтрокаСтр4.П000140000205 = Окр(Выборка.НалогВзносИсчисленный);
					
				ИначеЕсли Выборка.ВидНалогаИсчисленный = Перечисления.ВидыНалоговВзносовОтчислений.ОППВ Тогда 
					
					НоваяСтрокаСтр5.П000150000202 = Окр(Выборка.НалогВзносИсчисленный);
					
				КонецЕсли;
				
			КонецЕсли;
			
