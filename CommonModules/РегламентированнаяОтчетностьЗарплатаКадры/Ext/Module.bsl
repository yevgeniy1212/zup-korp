	|УНИЧТОЖИТЬ ВТ_ИсчисленныеНалогиВзносы";
	
	НомерЛиста = 0;
	ВыборкаРегистрации = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Контейнер.Форма200_06.Очистить();
	
	Пока ВыборкаРегистрации.Следующий() Цикл
		
		ВыборкаОрганизации = ВыборкаРегистрации.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		ПоследнийНомерЛистаПредыдущейРегистрации = НомерЛиста;
		
		Пока ВыборкаОрганизации.Следующий() Цикл
			
			Выборка = ВыборкаОрганизации.Выбрать();
			
			Если ЗначениеЗаполнено(ВыборкаОрганизации.Наименование)
				ИЛИ ВыборкаОрганизации.Организация <> ПараметрыОтчета.Организация ИЛИ ВыборкаОрганизации.Регистрация <> РегистрацияГоловнойОрганизации Тогда
				ИИНФилиала = ВыборкаОрганизации.БИН;
			Иначе // головная организация
				ИИНФилиала = "";
			КонецЕсли;
			
			Если Выборка.Количество() <> 0 Тогда
				
				ЕПИмеется = Истина;
				
				Если ВыборкаОрганизации.Количество() >= (НомерЛиста - ПоследнийНомерЛистаПредыдущейРегистрации) + 1 Тогда
					НовСтрокаТЗ = Контейнер.Форма200_06.Добавить();
				КонецЕсли;
				
				Контейнер.Форма200_06[НомерЛиста].ИИН_БИНФилиала = ИИНФилиала;
				
				Контейнер.Форма200_06[НомерЛиста].Страница1Итоги = Новый Структура;
				Контейнер.Форма200_06[НомерЛиста].Страница2Итоги = Новый Структура;
				Контейнер.Форма200_06[НомерЛиста].Страница3Итоги = Новый Структура;
				
				НомерСтроки = 2;
				ИндексСтроки = 0;
				Пока Выборка.Следующий() Цикл
					НовСтрокаТЗ.Страница1.Добавить();
					НовСтрокаТЗ.Страница1[ИндексСтроки].Значение = Новый Структура;
					НовСтрокаТЗ.Страница2.Добавить();
					НовСтрокаТЗ.Страница2[ИндексСтроки].Значение = Новый Структура;
					НовСтрокаТЗ.Страница3.Добавить();
					НовСтрокаТЗ.Страница3[ИндексСтроки].Значение = Новый Структура;
					
					Контейнер.Форма200_06[НомерЛиста].Страница1[ИндексСтроки].Значение.Вставить("П000610000201", НомерСтроки);
					Контейнер.Форма200_06[НомерЛиста].Страница2[ИндексСтроки].Значение.Вставить("П000620000201", НомерСтроки);
					Контейнер.Форма200_06[НомерЛиста].Страница3[ИндексСтроки].Значение.Вставить("П000630000201", НомерСтроки);
					
					Контейнер.Форма200_06[НомерЛиста].Страница1[ИндексСтроки].Значение.Вставить("П000610000202", Выборка.ФИОФизЛица);
					Контейнер.Форма200_06[НомерЛиста].Страница1[ИндексСтроки].Значение.Вставить("П000610000202Ссылка", Выборка.ФизическоеЛицо);
					Контейнер.Форма200_06[НомерЛиста].Страница1[ИндексСтроки].Значение.Вставить("П000610000203", Выборка.ИИН);
					
					СписокКатегорий = Новый СписокЗначений;
					Если Выборка.Категория1 <> "" Тогда
						СписокКатегорий.Добавить(Выборка.Категория1);
					КонецЕсли;
					Если Выборка.Категория2 <> "" Тогда
						СписокКатегорий.Добавить(Выборка.Категория2);
					КонецЕсли;
					Если Выборка.Категория3 <> "" Тогда
						СписокКатегорий.Добавить(Выборка.Категория3);
					КонецЕсли;
					Если Выборка.Категория4 <> "" Тогда
						СписокКатегорий.Добавить(Выборка.Категория4);
					КонецЕсли;
					Контейнер.Форма200_06[НомерЛиста].Страница1[ИндексСтроки].Значение.Вставить("П000610000204", СписокКатегорий);
					
					Контейнер.Форма200_06[НомерЛиста].Страница1[ИндексСтроки].Значение.Вставить("П000610000205", Окр(Выборка.СуммаДохода));
					Контейнер.Форма200_06[НомерЛиста].Страница2[ИндексСтроки].Значение.Вставить("П000620000202", Выборка.НалогВзносИсчисленный);
					Контейнер.Форма200_06[НомерЛиста].Страница3[ИндексСтроки].Значение.Вставить("П000630000205", Выборка.НалогВзносИсчисленный);
					Контейнер.Форма200_06[НомерЛиста].Страница2[ИндексСтроки].Значение.Вставить("П000620000203", Выборка.ИПН);
					Контейнер.Форма200_06[НомерЛиста].Страница2[ИндексСтроки].Значение.Вставить("П000620000204", Выборка.ОПВ);
					Контейнер.Форма200_06[НомерЛиста].Страница2[ИндексСтроки].Значение.Вставить("П000620000205", Выборка.ВОСМС);
					Контейнер.Форма200_06[НомерЛиста].Страница3[ИндексСтроки].Значение.Вставить("П000630000202", Выборка.СО);
					Контейнер.Форма200_06[НомерЛиста].Страница3[ИндексСтроки].Значение.Вставить("П000630000203", Выборка.ООСМС);
					Контейнер.Форма200_06[НомерЛиста].Страница3[ИндексСтроки].Значение.Вставить("П000630000204", Выборка.ОПВР);
					Контейнер.Форма200_06[НомерЛиста].Страница3[ИндексСтроки].Значение.Вставить("П000630000206", ?(ЗначениеЗаполнено(Выборка.КодСтраны), ?(Выборка.КодСтраны = "KZ", "KZ", Выборка.КодСтраны), "00"));
					Контейнер.Форма200_06[НомерЛиста].Страница3[ИндексСтроки].Значение.Вставить("П000630000207", Выборка.СотрудникФилиала);
					
					НомерСтроки = НомерСтроки + 1;
					ИндексСтроки = ИндексСтроки + 1;
				КонецЦикла;
				
			КонецЕсли;
			
			НомерЛиста = НомерЛиста + 1;
		КонецЦикла;
		
	КонецЦикла;
		
	Если ЕПИмеется Тогда
		Контейнер.Форма200Страница1.Вставить("Приложение6","Х");
		Контейнер.Форма200Страница1.Вставить("КоличествоПриложений200_06", НомерЛиста);
	Иначе
		Контейнер.Форма200Страница1.Вставить("Приложение6","");
		Контейнер.Форма200Страница1.Вставить("КоличествоПриложений200_06","");
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область Форма210

Процедура ЗаполнитьФорма2102016Кв1(ПараметрыОтчета, Контейнер) Экспорт
	
	Начало1Мес = НачалоМесяца(ПараметрыОтчета.мДатаНачалаПериодаОтчета);
	Начало2Мес = ДобавитьМесяц(Начало1Мес, 1);
	Начало3Мес = ДобавитьМесяц(Начало2Мес, 1);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("парамПериодС", 				              НачалоМесяца(ПараметрыОтчета.мДатаНачалаПериодаОтчета));
	Запрос.УстановитьПараметр("парамПериодПо", 				              КонецМесяца(ПараметрыОтчета.мДатаКонцаПериодаОтчета));
	Запрос.УстановитьПараметр("парамПослеПериодПо", 		              КонецМесяца(ПараметрыОтчета.мДатаКонцаПериодаОтчета) + 1);
	Запрос.УстановитьПараметр("парамОрганизация",	 		              ПараметрыОтчета.Организация);
	Запрос.УстановитьПараметр("парамПустаяДата",			              Дата("00010101000000"));
	Запрос.УстановитьПараметр("парамСписокСтруктурныхЕдиниц",             ПараметрыОтчета.СписокСтруктурныхединиц);
	
	ВидыОсобыхНачисленийУдержаний = Новый Массив;
	ВидыОсобыхНачисленийУдержаний.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.КомпенсацияЗаЗадержкуЗарплаты);
	ВидыОсобыхНачисленийУдержаний.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ПогашениеЗаймаИзЗарплаты);
	ВидыОсобыхНачисленийУдержаний.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ПроцентыПоЗайму);
	ВидыОсобыхНачисленийУдержаний.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.МатериальнаяВыгодаПоЗаймам);
	Запрос.УстановитьПараметр("ВидыОсобыхНачисленийУдержаний",             ВидыОсобыхНачисленийУдержаний);
	
	ВидыОперацийИПН = Новый Массив;
	ВидыОперацийИПН.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ИПН);
	ВидыОперацийИПН.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ИПНДоходыКонтрагентов);
	ВидыОперацийИПН.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ИПНРасчетыСБывшимиСотрудниками);
	Запрос.УстановитьПараметр("ВидыОперацийИПН", ВидыОперацийИПН);
	
	РегистрацияГоловнойОрганизации = РегламентированнаяОтчетностьРК.РегистрацияВНалоговомОргане(ПараметрыОтчета.Организация,КонецМесяца(ПараметрыОтчета.мДатаКонцаПериодаОтчета));
	
	Запрос.УстановитьПараметр("парамРегистрацияГоловнойОрганизации", РегистрацияГоловнойОрганизации);
	
	// Если налогоплательщик - ИП, то исключим данные самого индивидуального предпринимателя.
	Если РегламентированнаяОтчетностьРК.ИндивидуальныйПредприниматель(ПараметрыОтчета.Организация) Тогда
		Запрос.УстановитьПараметр("парамИндивидуальныйПредприниматель", ПараметрыОтчета.Организация.ИндивидуальныйПредприниматель);
	Иначе
