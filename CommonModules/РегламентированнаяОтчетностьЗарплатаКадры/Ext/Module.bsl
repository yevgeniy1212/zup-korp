						НоваяСтрокаСтр5 = Контейнер.Форма200_02Страница5_ДанныеДопСтрок.Добавить();
						НоваяСтрокаСтр6 = Контейнер.Форма200_02Страница6_ДанныеДопСтрок.Добавить();
						НоваяСтрокаСтр7 = Контейнер.Форма200_02Страница7_ДанныеДопСтрок.Добавить();
						НоваяСтрокаСтр8 = Контейнер.Форма200_02Страница8_ДанныеДопСтрок.Добавить();
						НоваяСтрокаСтр9 = Контейнер.Форма200_02Страница9_ДанныеДопСтрок.Добавить();
						
