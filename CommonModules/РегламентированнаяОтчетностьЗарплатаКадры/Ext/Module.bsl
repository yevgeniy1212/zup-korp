Процедура ЗаполнитьФорма2002021Кв1(ПараметрыОтчета, Контейнер) Экспорт
	
	Начало1Мес = НачалоМесяца(ПараметрыОтчета.мДатаНачалаПериодаОтчета);
	Начало2Мес = ДобавитьМесяц(Начало1Мес, 1);
	Начало3Мес = ДобавитьМесяц(Начало2Мес, 1);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("парамПериодС", 				              НачалоМесяца(ПараметрыОтчета.мДатаНачалаПериодаОтчета));
	Запрос.УстановитьПараметр("парамПериодПо", 				              КонецМесяца(ПараметрыОтчета.мДатаКонцаПериодаОтчета));
	Запрос.УстановитьПараметр("парамПослеПериодПо", 		              КонецМесяца(ПараметрыОтчета.мДатаКонцаПериодаОтчета) + 1);
	Запрос.УстановитьПараметр("парамОрганизация",	 		              ПараметрыОтчета.Организация);
	Запрос.УстановитьПараметр("парамСписокСтруктурныхЕдиниц",             ПараметрыОтчета.СписокСтруктурныхединиц);
	Запрос.УстановитьПараметр("парамНалоговыйКомитетГоловнойОрганизации", ПараметрыОтчета.Организация.РегистрацияВНалоговомОргане);
	Запрос.УстановитьПараметр("парамПустаяДата",			              Дата("00010101000000"));
	
	ВидыОсобыхНачисленийУдержаний = Новый Массив;
	ВидыОсобыхНачисленийУдержаний.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.КомпенсацияЗаЗадержкуЗарплаты);
	ВидыОсобыхНачисленийУдержаний.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ПогашениеЗаймаИзЗарплаты);
	ВидыОсобыхНачисленийУдержаний.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ПроцентыПоЗайму);
	ВидыОсобыхНачисленийУдержаний.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.МатериальнаяВыгодаПоЗаймам);
	Запрос.УстановитьПараметр("ВидыОсобыхНачисленийУдержаний",             ВидыОсобыхНачисленийУдержаний);
	
	ВидыНалоговВзносов = Новый Массив;
	ВидыНалоговВзносов.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ИПН);
	ВидыНалоговВзносов.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ИПНДоходыКонтрагентов);
	ВидыНалоговВзносов.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ИПНРасчетыСБывшимиСотрудниками);
	ВидыНалоговВзносов.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ИПНДивиденды);
	ВидыНалоговВзносов.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ОПВ);
	ВидыНалоговВзносов.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ОПВДоходыКонтрагентов);
	ВидыНалоговВзносов.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ОПВРасчетыСБывшимиСотрудниками);
	ВидыНалоговВзносов.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ВОСМС);
	ВидыНалоговВзносов.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ВОСМСДоходыКонтрагентов);
	ВидыНалоговВзносов.Добавить(Перечисления.ВидыОсобыхНачисленийИУдержаний.ВОСМСРасчетыСБывшимиСотрудниками);
	Запрос.УстановитьПараметр("ВидыНалоговВзносов", ВидыНалоговВзносов);

	РегистрацияГоловнойОрганизации = РегламентированнаяОтчетностьРК.РегистрацияВНалоговомОргане(ПараметрыОтчета.Организация,КонецМесяца(ПараметрыОтчета.мДатаКонцаПериодаОтчета));
	
	Запрос.УстановитьПараметр("парамРегистрацияГоловнойОрганизации", РегистрацияГоловнойОрганизации);
	
	// Если налогоплательщик - ИП, то исключим данные самого индивидуального предпринимателя.
	Если РегламентированнаяОтчетностьРК.ИндивидуальныйПредприниматель(ПараметрыОтчета.Организация) Тогда
		Запрос.УстановитьПараметр("парамИндивидуальныйПредприниматель", ПараметрыОтчета.Организация.ИндивидуальныйПредприниматель);
	Иначе
		Запрос.УстановитьПараметр("парамИндивидуальныйПредприниматель", Неопределено);
	КонецЕсли;
	
	СтрокаСведений = "ИННЮЛ, НаимЮЛПол, ФИОРук";
	СведенияОбОрганизации = РегламентированнаяОтчетностьВызовСервера.ПолучитьСведенияОбОрганизации(ПараметрыОтчета.Организация,,СтрокаСведений);
	СтрПериодОтчета = ПредставлениеПериода(ПараметрыОтчета.мДатаНачалаПериодаОтчета,ПараметрыОтчета.мДатаКонцаПериодаОтчета, "ФП = истина");
	
	Квартал = Лев(СтрПериодОтчета,1);
	Год		= Лев(Прав(СтрПериодОтчета,7),4);

	Контейнер.Форма200Страница2.ИИН_БИН = СведенияОбОрганизации.ИННЮЛ;
	Контейнер.Форма200Страница3.ИИН_БИН = СведенияОбОрганизации.ИННЮЛ;
	Контейнер.Форма200_01Страница1.ИИН_БИН = СведенияОбОрганизации.ИННЮЛ;
	Контейнер.Форма200_01Страница2.ИИН_БИН = СведенияОбОрганизации.ИННЮЛ;
	Контейнер.Форма200Страница2.Квартал = Квартал;
	Контейнер.Форма200Страница3.Квартал = Квартал;
	Контейнер.Форма200Страница3.Руководитель = СведенияОбОрганизации.ФИОРук;
	Контейнер.Форма200Страница3.ДатаПодачи = ТекущаяДата();
	Контейнер.Форма200Страница3.КодНалоговогоОрганаИПН = РегистрацияГоловнойОрганизации.Код;
	Контейнер.Форма200Страница3.КодНалоговогоОрганаОПВиСО = РегистрацияГоловнойОрганизации.Код;
	Контейнер.Форма200_01Страница1.Квартал = Квартал;
	Контейнер.Форма200_01Страница2.Квартал = Квартал;
	Контейнер.Форма200Страница2.Год = Год;
	Контейнер.Форма200Страница3.Год = Год;
	Контейнер.Форма200_01Страница1.Год = Год;
	Контейнер.Форма200_01Страница2.Год = Год;

	МТ = Новый МенеджерВременныхТаблиц;
	Запрос.МенеджерВременныхТаблиц = МТ;
	
	Запрос.Текст = "ВЫБРАТЬ
	|	Организации.Ссылка
	|ПОМЕСТИТЬ ВТ_СписокОрганизаций
	|ИЗ
	|	Справочник.Организации КАК Организации
	|ГДЕ
	|	Организации.ГоловнаяОрганизация = &парамОрганизация
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	&парамОрганизация
	|";
	Запрос.Выполнить();
	
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	КадроваяИсторияСотрудниковСрезПоследних.ФизическоеЛицо КАК ФизическоеЛицо
	|ПОМЕСТИТЬ ВТ_СписокРаботников
	|ИЗ
	|	РегистрСведений.КадроваяИсторияСотрудников.СрезПоследних(&парамПериодС, Организация = &парамОрганизация) КАК КадроваяИсторияСотрудниковСрезПоследних
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	КадроваяИсторияСотрудников.ФизическоеЛицо
	|ИЗ
	|	РегистрСведений.КадроваяИсторияСотрудников КАК КадроваяИсторияСотрудников
	|ГДЕ
	|	КадроваяИсторияСотрудников.Организация = &парамОрганизация
	|	И КадроваяИсторияСотрудников.Период МЕЖДУ &парамПериодС И &парамПериодПо
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	КадроваяИсторияСотрудниковСрезПоследних.ФизическоеЛицо
	|";

	Запрос.Выполнить();

	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	НАЧАЛОПЕРИОДА(ДанныеПроизводственногоКалендаря.Дата, МЕСЯЦ) КАК Период
	|ПОМЕСТИТЬ ВТ_ДатыПериодовГода
	|ИЗ
	|	РегистрСведений.ДанныеПроизводственногоКалендаря КАК ДанныеПроизводственногоКалендаря
	|ГДЕ
	|	ДанныеПроизводственногоКалендаря.Дата МЕЖДУ &парамПериодС И &парамПериодПо
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Периоды.Период КАК Период,
	|	ФизическиеЛица.Ссылка КАК ФИО
	|ПОМЕСТИТЬ ВТ_Периоды
	|ИЗ
	|	ВТ_ДатыПериодовГода КАК Периоды
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица КАК ФизическиеЛица
	|		ПО (ИСТИНА)
	|ГДЕ
	|	ФизическиеЛица.ЭтоГруппа = ЛОЖЬ
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Период,
	|	ФИО
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Периоды.Период КАК Период,
	|	Периоды.ФИО КАК ФИО,
	|	МАКСИМУМ(ГражданствоФизЛиц.Период) КАК ПериодСреза
	|ПОМЕСТИТЬ ВТ_ГражданствоФизЛицСрезПоследних
	|ИЗ
	|	ВТ_Периоды КАК Периоды
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГражданствоФизическихЛиц КАК ГражданствоФизЛиц
	|		ПО (Периоды.Период >= НАЧАЛОПЕРИОДА(ГражданствоФизЛиц.Период, МЕСЯЦ))
	|			И Периоды.ФИО = ГражданствоФизЛиц.ФизическоеЛицо
	|
	|СГРУППИРОВАТЬ ПО
	|	Периоды.Период,
	|	Периоды.ФИО
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ПериодСреза,
	|	ФИО
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ГражданствоФизЛицСрезПоследних.Период КАК Период,
	|	ГражданствоФизЛицСрезПоследних.ФИО КАК ФИО,
	|	ВЫБОР
	|		КОГДА ГражданствоФизЛиц.Страна ЕСТЬ NULL
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.СтраныМира.Казахстан)
	|		ИНАЧЕ ГражданствоФизЛиц.Страна
	|	КОНЕЦ КАК Страна,
	|	ВЫБОР
	|		КОГДА ЕСТЬNULL(СтатусФизическихЛицКакНалогоплательщиковСрезПоследних.Статус, ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)) = ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Нерезидент)
	|			ТОГДА ЕСТЬNULL(ГражданствоФизЛиц.Страна, ЗНАЧЕНИЕ(Справочник.СтраныМира.Казахстан))
	|		ИНАЧЕ ГражданствоФизЛиц.Страна
	|	КОНЕЦ КАК СтранаРезидентства,
	|	СтатусФизическихЛицКакНалогоплательщиковСрезПоследних.Статус КАК Статус,
	|	ГражданствоФизЛиц.ИНН КАК ИНН
	|ПОМЕСТИТЬ ВТ_ГражданствоВсехФизЛиц
	|ИЗ
	|	ВТ_ГражданствоФизЛицСрезПоследних КАК ГражданствоФизЛицСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ГражданствоФизическихЛиц КАК ГражданствоФизЛиц
	|		ПО ГражданствоФизЛицСрезПоследних.ПериодСреза = ГражданствоФизЛиц.Период
	|			И ГражданствоФизЛицСрезПоследних.ФИО = ГражданствоФизЛиц.ФизическоеЛицо
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СтатусФизическихЛицКакНалогоплательщиков.СрезПоследних(&парамПериодПо, ) КАК СтатусФизическихЛицКакНалогоплательщиковСрезПоследних
	|		ПО ГражданствоФизЛицСрезПоследних.ФИО = СтатусФизическихЛицКакНалогоплательщиковСрезПоследних.ФизическоеЛицо
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Период,
	|	ФИО
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ГражданствоВсехФизЛиц.Период КАК Период,
	|	ВТ_ГражданствоВсехФизЛиц.ФИО КАК ФИО,
	|	ВТ_ГражданствоВсехФизЛиц.Страна КАК Страна,
	|	ВТ_ГражданствоВсехФизЛиц.СтранаРезидентства КАК СтранаРезидентства,
	|	ВТ_ГражданствоВсехФизЛиц.Статус КАК Статус,
	|	ВТ_ГражданствоВсехФизЛиц.ИНН КАК ИНН
	|ПОМЕСТИТЬ ВТ_Гражданство
	|ИЗ
	|	ВТ_ГражданствоВсехФизЛиц КАК ВТ_ГражданствоВсехФизЛиц
	|ГДЕ
	|	НЕ ВЫБОР
	|				КОГДА ВТ_ГражданствоВсехФизЛиц.Страна ЕСТЬ NULL
	|					ТОГДА ЗНАЧЕНИЕ(Справочник.СтраныМира.Казахстан)
	|				ИНАЧЕ ВТ_ГражданствоВсехФизЛиц.Страна
	|			КОНЕЦ = ЗНАЧЕНИЕ(Справочник.СтраныМира.Казахстан)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Период,
	|	ФИО
	|";
	
	Запрос.Выполнить();

	//200.00 Шапка 
	
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ВТ_СписокРаботников.ФизическоеЛицо КАК ФизическоеЛицо,
	|	НАЧАЛОПЕРИОДА(СведенияОДоходахФизическихЛиц.Период, МЕСЯЦ) КАК МесяцНалоговогоПериода
	|ПОМЕСТИТЬ ВТ_СписокРаботниковСПериодом
	|ИЗ
	|	РегистрНакопления.СведенияОДоходахФизическихЛиц.Обороты(
	|			&парамПериодС,
	|			&парамПериодПо,
	|			МЕСЯЦ,
	|			Организация = &парамОрганизация
	|				И РегистрацияВНалоговомОргане = &парамРегистрацияГоловнойОрганизации
	|				И ФизическоеЛицо <> &парамИндивидуальныйПредприниматель) КАК СведенияОДоходахФизическихЛиц
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_СписокРаботников КАК ВТ_СписокРаботников
	|		ПО (ВТ_СписокРаботников.ФизическоеЛицо = СведенияОДоходахФизическихЛиц.ФизическоеЛицо)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВТ_СписокРаботниковСПериодом.ФизическоеЛицо) КАК ЧисленностьРаботников,
	|	ВТ_СписокРаботниковСПериодом.МесяцНалоговогоПериода КАК МесяцНалоговогоПериода,
	|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВЫБОР 
	|				КОГДА НЕ ВТ_Гражданство.ФИО ЕСТЬ NULL
	|					ТОГДА ВТ_Гражданство.ФИО
	|				ИНАЧЕ NULL
	|			КОНЕЦ) КАК ЧисленностьИностранцев
	|ИЗ
	|	ВТ_СписокРаботниковСПериодом КАК ВТ_СписокРаботниковСПериодом
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_Гражданство КАК ВТ_Гражданство
	|		ПО (ВТ_СписокРаботниковСПериодом.МесяцНалоговогоПериода = ВТ_Гражданство.Период)
	|			И (ВТ_СписокРаботниковСПериодом.ФизическоеЛицо = ВТ_Гражданство.ФИО)	
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_СписокРаботниковСПериодом.МесяцНалоговогоПериода";
		
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		
		Если Выборка.МесяцНалоговогоПериода = Начало1Мес Тогда
			Контейнер.Форма200Страница1.ЧисленностьРаботников1 = Окр(Выборка.ЧисленностьРаботников);
			Контейнер.Форма200Страница1.ЧисленностьИностранцев1 = Окр(Выборка.ЧисленностьИностранцев);
		ИначеЕсли Выборка.МесяцНалоговогоПериода = Начало2Мес Тогда
			Контейнер.Форма200Страница1.ЧисленностьРаботников2 = Окр(Выборка.ЧисленностьРаботников);
			Контейнер.Форма200Страница1.ЧисленностьИностранцев2 = Окр(Выборка.ЧисленностьИностранцев);
		ИначеЕсли Выборка.МесяцНалоговогоПериода = Начало3Мес Тогда
			Контейнер.Форма200Страница1.ЧисленностьРаботников3 = Окр(Выборка.ЧисленностьРаботников);
			Контейнер.Форма200Страница1.ЧисленностьИностранцев3 = Окр(Выборка.ЧисленностьИностранцев);
		КонецЕсли;
		
	КонецЦикла;
	
	//200.01.001
	ТекстЗапроса =
	"ВЫБРАТЬ
