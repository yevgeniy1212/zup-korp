Функция ТекстЗапросаПоОтклонениюШтатногоРасписанияОтКадровогоПлана()
	
	Текст = 
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПоказателиКадровогоПланаОбороты.Позиция КАК Позиция,
	|	ПоказателиКадровогоПланаОбороты.Подразделение КАК МестоВСтруктуреПредприятия,
	|	ПоказателиКадровогоПланаОбороты.Позиция.Должность КАК Должность,
	|	СУММА(ПоказателиКадровогоПланаОбороты.Значение) КАК КоличествоСтавок
	|ПОМЕСТИТЬ ВТПоказателиКадровогоПлана
	|ИЗ
	|	РегистрНакопления.ПоказателиКадровогоПлана КАК ПоказателиКадровогоПланаОбороты
	|ГДЕ
	|	ПоказателиКадровогоПланаОбороты.Период МЕЖДУ &НачалоПериода И &КонецПериода
	|	И ПоказателиКадровогоПланаОбороты.Сценарий = &Сценарий
	|	И ПоказателиКадровогоПланаОбороты.Показатель.Категория = ЗНАЧЕНИЕ(Перечисление.КатегорииРасходовНаПерсонал.КоличествоСтавок)
	|	И ПоказателиКадровогоПланаОбороты.Подразделение В
	|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|				Т.МестоВСтруктуреПредприятия
	|			ИЗ
	|				ВТШтатноеРасписание КАК Т)
	|
	|СГРУППИРОВАТЬ ПО
	|	ПоказателиКадровогоПланаОбороты.Позиция,
	|	ПоказателиКадровогоПланаОбороты.Подразделение,
	|	ПоказателиКадровогоПланаОбороты.Позиция.Должность
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ПоказателиКадровогоПлана.Позиция,
	|	ПоказателиКадровогоПлана.Подразделение,
	|	ПоказателиКадровогоПлана.Позиция.Должность,
	|	0
	|ИЗ
	|	РегистрНакопления.ПоказателиКадровогоПлана КАК ПоказателиКадровогоПлана
	|ГДЕ
	|	ПоказателиКадровогоПлана.Сценарий = &Сценарий
	|	И ПоказателиКадровогоПлана.Показатель.Категория = ЗНАЧЕНИЕ(Перечисление.КатегорииРасходовНаПерсонал.КоличествоСтавок)
	|	И ПоказателиКадровогоПлана.Значение = 0
	|	И ПоказателиКадровогоПлана.Подразделение В
	|			(ВЫБРАТЬ РАЗЛИЧНЫЕ
	|				Т.МестоВСтруктуреПредприятия
	|			ИЗ
	|				ВТШтатноеРасписание КАК Т)
	|	И ПоказателиКадровогоПлана.Период МЕЖДУ &НачалоПериода И &КонецПериода
	|
	|СГРУППИРОВАТЬ ПО
	|	ПоказателиКадровогоПлана.Позиция,
	|	ПоказателиКадровогоПлана.Подразделение,
	|	ПоказателиКадровогоПлана.Позиция.Должность
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Позиция
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ
	|	ПоказателиКадровогоПлана.МестоВСтруктуреПредприятия КАК МестоВСтруктуреПредприятия,
	|	ВЫБОР
	|		КОГДА СтруктураПредприятия.Источник ЕСТЬ NULL
	|				ИЛИ СтруктураПредприятия.Источник = НЕОПРЕДЕЛЕНО
	|			ТОГДА ВЫБОР
	|					КОГДА ПозицииШтатногоРасписанияПоКадровомуПлану.ПозицияШтатногоРасписания ЕСТЬ NULL
	|						ТОГДА ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка)
	|					ИНАЧЕ ПозицииШтатногоРасписанияПоКадровомуПлану.ПозицияШтатногоРасписания.Подразделение
	|				КОНЕЦ
	|		ИНАЧЕ СтруктураПредприятия.Источник
	|	КОНЕЦ КАК Подразделение,
	|	ВЫБОР
	|		КОГДА ПозицииШтатногоРасписанияПоКадровомуПлану.ПозицияШтатногоРасписания ЕСТЬ NULL
	|			ТОГДА ПоказателиКадровогоПлана.Должность
	|		ИНАЧЕ ПозицииШтатногоРасписанияПоКадровомуПлану.ПозицияШтатногоРасписания.Должность
	|	КОНЕЦ КАК Должность,
	|	ПоказателиКадровогоПлана.Позиция КАК ПозицияКадровогоПлана,
	|	ЕСТЬNULL(ПозицииШтатногоРасписанияПоКадровомуПлану.ПозицияШтатногоРасписания, ЗНАЧЕНИЕ(Справочник.ШтатноеРасписание.ПустаяСсылка)) КАК ПозицияШтатногоРасписания,
	|	ПоказателиКадровогоПлана.КоличествоСтавок КАК КоличествоСтавок
	|ПОМЕСТИТЬ ВТПозицииКадровогоПлана
	|ИЗ
	|	ВТПоказателиКадровогоПлана КАК ПоказателиКадровогоПлана
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПозицииШтатногоРасписанияПоКадровомуПлану КАК ПозицииШтатногоРасписанияПоКадровомуПлану
	|		ПО ПоказателиКадровогоПлана.Позиция = ПозицииШтатногоРасписанияПоКадровомуПлану.ПозицияКадровогоПлана
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.СтруктураПредприятия КАК СтруктураПредприятия
	|		ПО ПоказателиКадровогоПлана.МестоВСтруктуреПредприятия = СтруктураПредприятия.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ПозицииКадровогоПлана.ПозицияКадровогоПлана КАК ПозицияКадровогоПлана,
	|	ПозицииКадровогоПлана.МестоВСтруктуреПредприятия КАК МестоВСтруктуреПредприятия,
	|	ПозицииКадровогоПлана.Подразделение КАК Подразделение,
	|	ПозицииКадровогоПлана.Должность КАК Должность,
	|	ЕСТЬNULL(ПозицииШтатногоРасписания.ПозицияШтатногоРасписания, ЗНАЧЕНИЕ(Справочник.ШтатноеРасписание.ПустаяСсылка)) КАК ПозицияШтатногоРасписания,
	|	СУММА(ПозицииКадровогоПлана.КоличествоСтавок) КАК КоличествоСтавок
	|ПОМЕСТИТЬ ВТПозицииСИзменениями
	|ИЗ
	|	ВТПозицииКадровогоПлана КАК ПозицииКадровогоПлана
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТШтатноеРасписание КАК ПозицииШтатногоРасписания
	|		ПО (ПозицииШтатногоРасписания.ПозицияШтатногоРасписания = ПозицииКадровогоПлана.ПозицияШтатногоРасписания)
	|
	|СГРУППИРОВАТЬ ПО
	|	ПозицииКадровогоПлана.ПозицияКадровогоПлана,
	|	ПозицииКадровогоПлана.МестоВСтруктуреПредприятия,
	|	ПозицииКадровогоПлана.Подразделение,
	|	ПозицииКадровогоПлана.Должность,
	|	ЕСТЬNULL(ПозицииШтатногоРасписания.ПозицияШтатногоРасписания, ЗНАЧЕНИЕ(Справочник.ШтатноеРасписание.ПустаяСсылка))
	|
	|ИМЕЮЩИЕ
	|	СУММА(ЕСТЬNULL(ПозицииШтатногоРасписания.КоличествоСтавок, 0)) <> СУММА(ПозицииКадровогоПлана.КоличествоСтавок)";
	
	Возврат Текст;
	
КонецФункции

Процедура ЗаполнитьИнформационнуюСтрокуЗанятости(СтрокаТаблицы) Экспорт
	
	ВакантноСтавок = СтрокаТаблицы.КоличествоСтавок - СтрокаТаблицы.ЗанятоСтавок;
	
	ЧастиНадписи = Новый Массив;
	
	ЧастиНадписи.Добавить(Новый ФорматированнаяСтрока(Строка(СтрокаТаблицы.Сценарий), ШрифтыСтиля.ВажнаяНадписьШрифт));
	ЧастиНадписи.Добавить(": ");
	
	ТекстВакантноСтавок = СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(
		НСтр("ru = ';Вакантна %1 ставка;;Вакантно %1 ставки;Вакантно %1 ставок;Вакантно %1 ставки'"), 
		ВакантноСтавок);
	ЧастиНадписи.Добавить(Новый ФорматированнаяСтрока(ТекстВакантноСтавок, ШрифтыСтиля.ВажнаяНадписьШрифт));
	
	ТекстКоличествоСтавок = СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(
		НСтр("ru = ';запланирована %1 ставка;;запланировано %1 ставки;запланировано %1 ставок;запланировано %1 ставки'"), 
		СтрокаТаблицы.КоличествоСтавок);
	ЧастиНадписи.Добавить(" (");
	ЧастиНадписи.Добавить(ТекстКоличествоСтавок);
	
	ТекстЗанятоСтавок = СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(
		НСтр("ru = ';занята %1 ставка;;занято %1 ставки;занято %1 ставок;занято %1 ставки'"), 
		СтрокаТаблицы.ЗанятоСтавок);
	ЧастиНадписи.Добавить(", ");
	ЧастиНадписи.Добавить(ТекстЗанятоСтавок);
	
	Сотрудников = СтрокаТаблицы.ЗанятоСотрудниками.Количество();
	Если Сотрудников > 0 Тогда
		ЧастиНадписи.Добавить(" ");
		ЧастиНадписи.Добавить(СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(
			НСтр("ru = ';сотрудником;;сотрудниками;сотрудниками;сотрудниками'"), 
			Сотрудников));
		ЧастиНадписи.Добавить(" ");
		СотрудниковВключено = 0;
		Для Каждого Сотрудник Из СтрокаТаблицы.ЗанятоСотрудниками Цикл
			Если СотрудниковВключено = 3 Тогда
				Прервать;
			КонецЕсли;
			ФамилияИнициалы = ФизическиеЛицаКлиентСервер.ФамилияИнициалы(Строка(Сотрудник));
			Если СотрудниковВключено > 0 Тогда
				ЧастиНадписи.Добавить(", ");
			КонецЕсли;
			ЧастиНадписи.Добавить(Новый ФорматированнаяСтрока(ФамилияИнициалы, , , , ПолучитьНавигационнуюСсылку(Сотрудник)));
			СотрудниковВключено = СотрудниковВключено + 1;
		КонецЦикла;
		ЕщеОсталось = Сотрудников - СотрудниковВключено;
		Если ЕщеОсталось > 0 Тогда
			ЧастиНадписи.Добавить(" ");
			ЧастиНадписи.Добавить(НСтр("ru = 'и'"));
			ЧастиНадписи.Добавить(" ");
			ТекстЕщеСотрудники = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'еще %1'"), 
				ЕщеОсталось);
			ЧастиНадписи.Добавить(Новый ФорматированнаяСтрока(ТекстЕщеСотрудники, , , , "СотрудникиПозиции"));
		КонецЕсли;
	КонецЕсли;
	
	ЧастиНадписи.Добавить(")");
	
	СтрокаТаблицы.ИнформационнаяСтрокаЗанятости = Новый ФорматированнаяСтрока(ЧастиНадписи);
	
КонецПроцедуры

Функция МесяцСтрокой(НомерМесяца, СЗаглавнойБуквы = Ложь) Экспорт
	
	МесяцСтрокой = НРег(Формат(Дата(10, НомерМесяца, 1), НСтр("ru='ДФ=''ММММ'''")));
	
	Если СЗаглавнойБуквы Тогда 
		МесяцСтрокой = ВРег(Сред(МесяцСтрокой, 1, 1)) + Сред(МесяцСтрокой, 2);
	КонецЕсли;
	
	Возврат МесяцСтрокой;
	
КонецФункции

Процедура СоздатьВТПериодыРаботыСотрудников(МенеджерВременныхТаблиц, ИмяВТПозиции, ДатаНачала, ДатаОкончания) Экспорт

	УдалитьВТ = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВТПозиции.Позиция КАК Позиция
		|ИЗ
		|	#ВТПозиции КАК ВТПозиции";
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "#ВТПозиции", ИмяВТПозиции);
	
	РезультатПозиций = Запрос.Выполнить();
	МассивПозиций = РезультатПозиций.Выгрузить().ВыгрузитьКолонку("Позиция");
	
	ПараметрыПолученияСотрудников = КадровыйУчет.ПараметрыПолученияСотрудниковОрганизацийПоСпискуФизическихЛиц();
	ПараметрыПолученияСотрудников.НачалоПериода = ДатаНачала;
	ПараметрыПолученияСотрудников.ОкончаниеПериода = ДатаОкончания;
	ПараметрыПолученияСотрудников.КадровыеДанные = "ДолжностьПоШтатномуРасписанию,Состояние";
	
	ЗарплатаКадрыОбщиеНаборыДанных.ДобавитьВКоллекциюОтбор(
		ПараметрыПолученияСотрудников.Отборы, "ДолжностьПоШтатномуРасписанию", "В", МассивПозиций);
	
	КадровыйУчет.СоздатьВТСотрудникиОрганизации(Запрос.МенеджерВременныхТаблиц, Истина, ПараметрыПолученияСотрудников);
	УдалитьВТ.Добавить("ВТСотрудникиОрганизации");
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	КадровыеДанныеСотрудников.Сотрудник КАК Сотрудник,
		|	&ДатаНачала КАК ДатаНачала,
		|	&ДатаОкончания КАК ДатаОкончания
		|ПОМЕСТИТЬ ВТФильтрДляПериодовРаботыСотрудников
		|ИЗ
		|	ВТСотрудникиОрганизации КАК КадровыеДанныеСотрудников
		|ГДЕ
		|	КадровыеДанныеСотрудников.Состояние В (&Состояния)";

	Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
	Состояния = Новый Массив;
	Состояния.Добавить(Перечисления.СостоянияСотрудника.Работа);
	Состояния.Добавить(Перечисления.СостоянияСотрудника.РаботаВОтпускеПоУходуЗаРебенком);
	Запрос.УстановитьПараметр("Состояния", Состояния);
	
	Запрос.Выполнить();
	УдалитьВТ.Добавить("ВТФильтрДляПериодовРаботыСотрудников");
	
	ЗарплатаКадрыПериодическиеРегистры.СоздатьВТИмяРегистраПериоды(
		"КадроваяИсторияСотрудников",
		МенеджерВременныхТаблиц,
		Истина,
		ЗарплатаКадрыОбщиеНаборыДанных.ОписаниеФильтраДляСоздатьВТИмяРегистра("ВТФильтрДляПериодовРаботыСотрудников", "Сотрудник"),
		ЗарплатаКадрыОбщиеНаборыДанных.ПараметрыПостроенияДляСоздатьВТИмяРегистра(),
		"ВТРабочиеМестаСотрудников");
		
	УдалитьВТ.Добавить("ВТРабочиеМестаСотрудников");
	
	ЗарплатаКадрыОбщиеНаборыДанных.СоздатьВТПериоды(Запрос.МенеджерВременныхТаблиц, ДатаНачала, ДатаОкончания);
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	МАКСИМУМ(ЕСТЬNULL(ПозицииПоКадровомуПлану.ПозицияКадровогоПлана, НЕОПРЕДЕЛЕНО)) КАК ПозицияКадровогоПлана,
		|	Позиции.Позиция КАК Позиция
		|ПОМЕСТИТЬ ВТШтатноеРасписаниеСКадровымПланом
		|ИЗ
		|	#ВТПозиции КАК Позиции
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПозицииШтатногоРасписанияПоКадровомуПлану КАК ПозицииПоКадровомуПлану
		|		ПО Позиции.Позиция = ПозицииПоКадровомуПлану.ПозицияШтатногоРасписания
		|СГРУППИРОВАТЬ ПО
		|	Позиции.Позиция
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Позиция
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Периоды.Период КАК Период,
		|	ВТПозиции.Позиция КАК Позиция,
		|	ВТПозиции.Подразделение КАК Подразделение,
		|	ВЫРАЗИТЬ(ВТПозиции.Позиция КАК Справочник.ШтатноеРасписание).Владелец КАК Организация,
		|	ШтатноеРасписаниеСКадровымПланом.ПозицияКадровогоПлана КАК ПозицияКадровогоПлана
		|ПОМЕСТИТЬ ВТПериодыПозиций
		|ИЗ
		|	ВТПериоды КАК Периоды,
		|	#ВТПозиции КАК ВТПозиции
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТШтатноеРасписаниеСКадровымПланом КАК ШтатноеРасписаниеСКадровымПланом
		|		ПО ВТПозиции.Позиция = ШтатноеРасписаниеСКадровымПланом.Позиция
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПериодыРаботыСотрудников.Сотрудник КАК Сотрудник,
		|	ВЫБОР
		|		КОГДА ПериодыРаботыСотрудников.НачалоПериода < ФильтрДляПериодовРаботыСотрудников.ДатаНачала
		|			ТОГДА ФильтрДляПериодовРаботыСотрудников.ДатаНачала
		|		ИНАЧЕ ПериодыРаботыСотрудников.НачалоПериода
		|	КОНЕЦ КАК ДатаНачала,
		|	ВЫБОР
		|		КОГДА ПериодыРаботыСотрудников.КонецПериода > ФильтрДляПериодовРаботыСотрудников.ДатаОкончания
		|			ТОГДА ФильтрДляПериодовРаботыСотрудников.ДатаОкончания
		|		ИНАЧЕ ПериодыРаботыСотрудников.КонецПериода
		|	КОНЕЦ КАК ДатаОкончания,
		|	ПериодыРаботыСотрудников.ДолжностьПоШтатномуРасписанию КАК Позиция,
		|	ПериодыРаботыСотрудников.Подразделение КАК Подразделение,
		|	ПериодыРаботыСотрудников.Организация КАК Организация,
		|	ПериодыРаботыСотрудников.КоличествоСтавок КАК КоличествоСтавок
		|ПОМЕСТИТЬ ВТПериодыРаботыСотрудниковПредварительно
		|ИЗ
		|	ВТРабочиеМестаСотрудников КАК ПериодыРаботыСотрудников
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ #ВТПозиции КАК ВТПозиции
		|		ПО ПериодыРаботыСотрудников.ДолжностьПоШтатномуРасписанию = ВТПозиции.Позиция
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТФильтрДляПериодовРаботыСотрудников КАК ФильтрДляПериодовРаботыСотрудников
		|		ПО ПериодыРаботыСотрудников.Сотрудник = ФильтрДляПериодовРаботыСотрудников.Сотрудник
		|ГДЕ
		|	ПериодыРаботыСотрудников.ВидСобытия <> ЗНАЧЕНИЕ(Перечисление.ВидыКадровыхСобытий.Увольнение)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПериодыПозиций.Период КАК Период,
		|	ПериодыПозиций.Позиция КАК Позиция,
		|	ПериодыРаботыСотрудников.Сотрудник КАК Сотрудник
		|ПОМЕСТИТЬ ВТПозицииПустышки
		|ИЗ
		|	ВТПериодыПозиций КАК ПериодыПозиций
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыРаботыСотрудниковПредварительно КАК ПериодыРаботыСотрудников
		|		ПО ПериодыПозиций.Позиция = ПериодыРаботыСотрудников.Позиция
		|		И (ВЫБОР
		|			КОГДА ПериодыПозиций.Период < ПериодыРаботыСотрудников.ДатаНачала
		|				ТОГДА ИСТИНА
		|			КОГДА ПериодыПозиций.Период > ПериодыРаботыСотрудников.ДатаОкончания
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ЛОЖЬ
		|		КОНЕЦ)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПозицииПустышки.Позиция КАК Позиция,
		|	ПозицииПустышки.Сотрудник КАК Сотрудник
		|ПОМЕСТИТЬ ВТПозицииПустышкиСгруппированные
		|ИЗ
		|	ВТПозицииПустышки КАК ПозицииПустышки
		|СГРУППИРОВАТЬ ПО
		|	ПозицииПустышки.Позиция,
		|	ПозицииПустышки.Сотрудник
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПериодыПозиций.Период КАК Период,
		|	ПериодыПозиций.Позиция КАК Позиция,
		|	ПериодыРаботыСотрудников.Сотрудник КАК Сотрудник
		|ПОМЕСТИТЬ ВТПозицииЗаполненные
		|ИЗ
		|	ВТПериодыПозиций КАК ПериодыПозиций
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыРаботыСотрудниковПредварительно КАК ПериодыРаботыСотрудников
		|		ПО ПериодыПозиций.Позиция = ПериодыРаботыСотрудников.Позиция
		|		И (ПериодыПозиций.Период >= НАЧАЛОПЕРИОДА(ПериодыРаботыСотрудников.ДатаНачала, МЕСЯЦ))
		|		И ПериодыПозиций.Период <= ПериодыРаботыСотрудников.ДатаОкончания
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПозицииЗаполненные.Позиция КАК Позиция,
		|	ПозицииЗаполненные.Сотрудник КАК Сотрудник
		|ПОМЕСТИТЬ ВТПозицииЗаполненныеСгруппированные
		|ИЗ
		|	ВТПозицииЗаполненные КАК ПозицииЗаполненные
		|СГРУППИРОВАТЬ ПО
		|	ПозицииЗаполненные.Позиция,
		|	ПозицииЗаполненные.Сотрудник
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПозицииПустышки.Сотрудник КАК Сотрудник,
		|	ПериодыПозиций.Период КАК Период,
		|	ПериодыПозиций.Позиция КАК Позиция,
		|	ПериодыПозиций.Подразделение КАК Подразделение,
		|	ПериодыПозиций.Организация КАК Организация,
		|	ПериодыПозиций.ПозицияКадровогоПлана КАК ПозицияКадровогоПлана
		|ПОМЕСТИТЬ ВТПериодыРаботыПустышки
		|ИЗ
		|	ВТПериодыПозиций КАК ПериодыПозиций
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПозицииПустышкиСгруппированные КАК ПозицииПустышки
		|		ПО ПериодыПозиций.Позиция = ПозицииПустышки.Позиция
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПозицииЗаполненные.Сотрудник КАК Сотрудник,
		|	ПериодыПозиций.Период КАК Период,
		|	ПериодыПозиций.Позиция КАК Позиция,
		|	ПериодыПозиций.Подразделение КАК Подразделение,
		|	ПериодыПозиций.Организация КАК Организация,
		|	ПериодыПозиций.ПозицияКадровогоПлана КАК ПозицияКадровогоПлана
		|ПОМЕСТИТЬ ВТПериодыРаботыЗаполненные
		|ИЗ
		|	ВТПериодыПозиций КАК ПериодыПозиций
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПозицииЗаполненныеСгруппированные КАК ПозицииЗаполненные
		|		ПО ПериодыПозиций.Позиция = ПозицииЗаполненные.Позиция
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(ПериодыРаботыЗаполненные.Сотрудник, НЕОПРЕДЕЛЕНО) КАК Сотрудник,
		|	ПериодыПозиций.Период КАК Период,
		|	ЕСТЬNULL(ПериодыРаботыЗаполненные.Позиция, ПериодыПозиций.Позиция) КАК Позиция,
		|	ЕСТЬNULL(ПериодыРаботыЗаполненные.Подразделение, ПериодыПозиций.Подразделение) КАК Подразделение,
		|	ЕСТЬNULL(ПериодыРаботыСотрудников.КоличествоСтавок, ВЫБОР
		|		КОГДА ЕСТЬNULL(ПериодыРаботыЗаполненные.Сотрудник, НЕОПРЕДЕЛЕНО) = НЕОПРЕДЕЛЕНО
		|			ТОГДА 1
		|		ИНАЧЕ 0
		|	КОНЕЦ) КАК КоличествоСтавок,
		|	ЕСТЬNULL(ПериодыРаботыЗаполненные.Организация, ПериодыПозиций.Организация) КАК Организация,
		|	ПериодыПозиций.ПозицияКадровогоПлана КАК ПозицияКадровогоПлана,
		|	ЕСТЬNULL(ПериодыРаботыЗаполненные.Сотрудник, НЕОПРЕДЕЛЕНО) КАК СотрудникГруппировка
		|ПОМЕСТИТЬ ВТПериодыРаботыСотрудников
		|ИЗ
		|	ВТПериодыПозиций КАК ПериодыПозиций
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТПериодыРаботыЗаполненные КАК ПериодыРаботыЗаполненные
		|		ПО ПериодыПозиций.Позиция = ПериодыРаботыЗаполненные.Позиция
		|		И ПериодыПозиций.Период = ПериодыРаботыЗаполненные.Период
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТПериодыРаботыСотрудниковПредварительно КАК ПериодыРаботыСотрудников
		|		ПО (ПериодыРаботыЗаполненные.Позиция = ПериодыРаботыСотрудников.Позиция)
		|		И (ПериодыРаботыЗаполненные.Сотрудник = ПериодыРаботыСотрудников.Сотрудник)
		|		И (ПериодыРаботыЗаполненные.Период >= НАЧАЛОПЕРИОДА(ПериодыРаботыСотрудников.ДатаНачала, МЕСЯЦ))
		|		И (ПериодыРаботыЗаполненные.Период <= ПериодыРаботыСотрудников.ДатаОкончания)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	НЕОПРЕДЕЛЕНО,
		|	ПериодыРаботыПустышки.Период,
		|	ПериодыРаботыПустышки.Позиция,
		|	ПериодыРаботыПустышки.Подразделение,
		|	ВЫБОР
		|		КОГДА ПериодыРаботыСотрудников.ДатаНачала ЕСТЬ NULL
		|			ТОГДА 0
		|		ИНАЧЕ 1
		|	КОНЕЦ,
		|	ПериодыРаботыПустышки.Организация,
		|	ПериодыРаботыПустышки.ПозицияКадровогоПлана,
		|	ПериодыРаботыПустышки.Сотрудник
		|ИЗ
		|	ВТПериодыПозиций КАК ПериодыПозиций
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыРаботыПустышки КАК ПериодыРаботыПустышки
		|		ПО ПериодыПозиций.Позиция = ПериодыРаботыПустышки.Позиция
		|		И ПериодыПозиций.Период = ПериодыРаботыПустышки.Период
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТПериодыРаботыСотрудниковПредварительно КАК ПериодыРаботыСотрудников
		|		ПО (ПериодыРаботыПустышки.Позиция = ПериодыРаботыСотрудников.Позиция)
		|		И (ПериодыРаботыПустышки.Сотрудник = ПериодыРаботыСотрудников.Сотрудник)
		|		И (ВЫБОР
		|			КОГДА ПериодыРаботыПустышки.Период < НАЧАЛОПЕРИОДА(ПериодыРаботыСотрудников.ДатаНачала, МЕСЯЦ)
		|				ТОГДА ИСТИНА
		|			КОГДА ПериодыРаботыПустышки.Период > КОНЕЦПЕРИОДА(ПериодыРаботыСотрудников.ДатаОкончания, МЕСЯЦ)
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ЛОЖЬ
		|		КОНЕЦ)";
	
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "#ВТПозиции", ИмяВТПозиции);
	
	Запрос.Выполнить();
	
	УдалитьВТ.Добавить("ВТШтатноеРасписаниеСКадровымПланом");
	УдалитьВТ.Добавить("ВТПериодыПозиций");
	УдалитьВТ.Добавить("ВТПериодыРаботыСотрудниковПредварительно");
	УдалитьВТ.Добавить("ВТПозицииПустышки");
	УдалитьВТ.Добавить("ВТПозицииПустышкиСгруппированные");
	УдалитьВТ.Добавить("ВТПозицииЗаполненные");
	УдалитьВТ.Добавить("ВТПозицииЗаполненныеСгруппированные");
	УдалитьВТ.Добавить("ВТПериодыРаботыПустышки");
	УдалитьВТ.Добавить("ВТПериодыРаботыЗаполненные");
	
	ЗарплатаКадры.УничтожитьВТ(Запрос.МенеджерВременныхТаблиц, УдалитьВТ);

КонецПроцедуры

Функция ПодчиненныеПодразделения(Подразделение) Экспорт
	
	Возврат ОрганизационнаяСтруктура.ПодчиненныеПодразделения(ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Подразделение));
	
КонецФункции

Функция СвойстваПоказателейСценария(Сценарий, КадровыйПлан = Неопределено) Экспорт
	
	Если ЗначениеЗаполнено(КадровыйПлан) Тогда
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("КадровыйПлан", КадровыйПлан);
		Запрос.УстановитьПараметр("ПоказательКоличествоСтавок", ПоказательКоличествоСтавок());
		Запрос.Текст = 
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ЗначенияПоказателей.Показатель,
			|	ЗначенияПоказателей.Показатель.Категория КАК Категория,
			|	ЗначенияПоказателей.Показатель.КраткоеНаименование КАК КраткоеНаименование
			|ИЗ
			|	РегистрСведений.ЗначенияПоказателейКадровыхПланов КАК ЗначенияПоказателей
			|ГДЕ
			|	ЗначенияПоказателей.КадровыйПлан = &КадровыйПлан
			|	И НЕ ЗначенияПоказателей.Показатель = &ПоказательКоличествоСтавок";
		РезультатЗапроса = Запрос.Выполнить();
		Если Не РезультатЗапроса.Пустой() Тогда
			Возврат СвойстваПоказателейПоВыборкеРезультатаЗапроса(РезультатЗапроса.Выбрать());
		КонецЕсли;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Сценарий", Сценарий);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПоказателиКадровогоПланирования.Показатель,
		|	ПоказателиКадровогоПланирования.Показатель.Категория КАК Категория,
		|	ПоказателиКадровогоПланирования.Показатель.КраткоеНаименование КАК КраткоеНаименование
		|ИЗ
		|	Справочник.Сценарии.ПоказателиКадровогоПланирования КАК ПоказателиКадровогоПланирования
		|ГДЕ
		|	ПоказателиКадровогоПланирования.Ссылка = &Сценарий";
	
	Возврат СвойстваПоказателейПоВыборкеРезультатаЗапроса(Запрос.Выполнить().Выбрать());
	
КонецФункции

Функция СвойстваПоказателейПоВыборкеРезультатаЗапроса(Выборка, КадровыйПлан = Неопределено) Экспорт
	
	СвойстваПоказателей = Новый Соответствие;
	УникальныеИменаПоказателей = Новый Массив;
	
	Если КадровыйПлан = Неопределено Тогда
		Пока Выборка.Следующий() Цикл
			ЗаполнитьСвойстваПоказателя(Выборка, УникальныеИменаПоказателей, СвойстваПоказателей);
		КонецЦикла;
	Иначе
		Пока Выборка.НайтиСледующий(КадровыйПлан, "КадровыйПлан") Цикл
			ЗаполнитьСвойстваПоказателя(Выборка, УникальныеИменаПоказателей, СвойстваПоказателей);
		КонецЦикла;
	КонецЕсли;
	
	СвойстваПоказателей.Вставить("УникальныеИменаПоказателей", Новый ФиксированныйМассив(УникальныеИменаПоказателей));
	Возврат СвойстваПоказателей;
	
КонецФункции

Процедура ЗаполнитьСвойстваПоказателя(Выборка, УникальныеИменаПоказателей, СвойстваПоказателей)
	
	Свойства = Новый Структура("Показатель,Категория,КраткоеНаименование");
	ЗаполнитьЗначенияСвойств(Свойства, Выборка);
	УникальноеИмяПоказателя = УникальноеИмяПоказателя(Выборка.Показатель);
	Свойства.Вставить("УникальноеИмяПоказателя", УникальноеИмяПоказателя);
	СвойстваПоказателей.Вставить(УникальноеИмяПоказателя, Свойства);
	УникальныеИменаПоказателей.Добавить(УникальноеИмяПоказателя);
	
КонецПроцедуры

Функция УникальноеИмяПоказателя(Ссылка) Экспорт
	
	Возврат "Показатель" + СтрЗаменить(Строка(Ссылка.УникальныйИдентификатор()), "-", "");
	
КонецФункции

Процедура УстановитьСвязьПозиций(ПозицияШтатногоРасписания, ПозицияКадровогоПлана) Экспорт
	
	МенеджерЗаписи = РегистрыСведений.ПозицииШтатногоРасписанияПоКадровомуПлану.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.ПозицияКадровогоПлана = ПозицияКадровогоПлана;
	МенеджерЗаписи.ПозицияШтатногоРасписания = ПозицияШтатногоРасписания;
	МенеджерЗаписи.Записать();
	
КонецПроцедуры

#КонецОбласти