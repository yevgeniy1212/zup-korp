#Область ДвиженияПоПоказателямКадровогоПлана

Процедура СформироватьДвиженияПоПоказателямКадровогоПлана(Движения, ДанныеДляПроведения) Экспорт
	
	Если Не ДанныеДляПроведения.Свойство("ПоказателиКадровогоПлана")
		Или Не ЗначениеЗаполнено(ДанныеДляПроведения.ПоказателиКадровогоПлана) Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого СтрокаДанныхДляПроведения Из ДанныеДляПроведения.ПоказателиКадровогоПлана Цикл
		СтрокаДвижений = Движения.ПоказателиКадровогоПлана.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаДвижений, СтрокаДанныхДляПроведения);
	КонецЦикла;
	
	Если Движения.ПоказателиКадровогоПлана.Количество() > 0 Тогда
		Движения.ПоказателиКадровогоПлана.Записывать = Истина;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ШтатноеРасписание

Функция ДлительнаяОперацияЗаполненияПоКадровомуПлану(Форма, Сценарий, УчитыватьМесяц = Ложь) Экспорт
	
	Объект = Форма.Объект;
	ПараметрыМетода = Новый Структура("Организация,Подразделение,ДатаВступленияВСилу");
	ЗаполнитьЗначенияСвойств(ПараметрыМетода, Объект);
	
	Если УчитыватьМесяц Тогда
		ПараметрыМетода.ДатаВступленияВСилу = Объект.МесяцВступленияВСилу;
	КонецЕсли;
	ПараметрыМетода.Вставить("Позиции", Объект.Позиции.Выгрузить());
	ПараметрыМетода.Вставить("Начисления", Объект.Начисления.Выгрузить());
	ПараметрыМетода.Вставить("Показатели", Объект.Показатели.Выгрузить());
	ПараметрыМетода.Вставить("Сценарий", Сценарий);
	ПараметрыМетода.Вставить("ЕжегодныеОтпуска", Объект.ЕжегодныеОтпуска.Выгрузить());
	ПараметрыМетода.Вставить("Специальности", Объект.Специальности.Выгрузить());
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(Форма.УникальныйИдентификатор);
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения,
		"УправлениеШтатнымРасписанием.РезультатЗаполненияПоТекущейКадровойРасстановке", ПараметрыМетода);
	
КонецФункции

Функция ЗапросПоОтклонениюШтатногоРасписания(ПараметрыВыполнения, ТекущиеПозиции, СтандартнаяОбработка) Экспорт
	
	Если Не ПараметрыВыполнения.Свойство("Сценарий") Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;

	Дата = ПараметрыВыполнения.ДатаВступленияВСилу;
	Организация = ПараметрыВыполнения.Организация;
	Подразделение = ПараметрыВыполнения.Подразделение;	
		
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ТекущиеПозиции", ТекущиеПозиции);
	Запрос.УстановитьПараметр("НачалоПериода", НачалоМесяца(Дата));
	Запрос.УстановитьПараметр("КонецПериода", КонецМесяца(Дата));
	Запрос.УстановитьПараметр("Сценарий", ПараметрыВыполнения.Сценарий);
	
	ПараметрыПостроения = УправлениеШтатнымРасписанием.ПараметрыПостроенияВТШтатноеРасписание(Дата, Организация, Подразделение);	
	УправлениеШтатнымРасписанием.СоздатьВТШтатноеРасписание(
		Запрос.МенеджерВременныхТаблиц, Истина, ПараметрыПостроения, "Подразделение,МестоВСтруктуреПредприятия,Должность,КоличествоСтавок");
	
	Запрос.Текст = ТекстЗапросаПоОтклонениюШтатногоРасписанияОтКадровогоПлана();
	Запрос.Выполнить();
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПозицииШтатногоРасписанияПоКадровомуПлану.ПозицияШтатногоРасписания КАК ПозицияШтатногоРасписания,
	|	МАКСИМУМ(ПозицииШтатногоРасписанияПоКадровомуПлану.ПозицияКадровогоПлана) КАК ПозицияКадровогоПлана
	|ПОМЕСТИТЬ ВТПозицииШтатногоРасписанияПоКадровомуПлану
	|ИЗ
	|	РегистрСведений.ПозицииШтатногоРасписанияПоКадровомуПлану КАК ПозицииШтатногоРасписанияПоКадровомуПлану
	|
	|СГРУППИРОВАТЬ ПО
	|	ПозицииШтатногоРасписанияПоКадровомуПлану.ПозицияШтатногоРасписания
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ПозицияШтатногоРасписания,
	|	ПозицияКадровогоПлана
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТекущиеПозиции.Должность КАК Должность,
	|	ТекущиеПозиции.Подразделение КАК Подразделение,
	|	ТекущиеПозиции.МестоВСтруктуреПредприятия КАК МестоВСтруктуреПредприятия,
	|	ТекущиеПозиции.КоличествоСтавок КАК КоличествоСтавок,
	|	ТекущиеПозиции.Позиция КАК Позиция,
	|	ТекущиеПозиции.ПозицияКадровогоПлана КАК ПозицияКадровогоПлана,
	|	ТекущиеПозиции.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ ВТТекущиеПозицииПредварительно
	|ИЗ
	|	&ТекущиеПозиции КАК ТекущиеПозиции
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Позиция
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ТекущиеПозиции.Должность КАК Должность,
	|	ТекущиеПозиции.Подразделение КАК Подразделение,
	|	ТекущиеПозиции.МестоВСтруктуреПредприятия КАК МестоВСтруктуреПредприятия,
	|	ТекущиеПозиции.КоличествоСтавок КАК КоличествоСтавок,
	|	ТекущиеПозиции.Позиция КАК Позиция,
	|	ВЫБОР
	|		КОГДА ТекущиеПозиции.ПозицияКадровогоПлана = ЗНАЧЕНИЕ(Справочник.ПозицииКадровогоПлана.ПустаяСсылка)
	|			ТОГДА ПозицииШтатногоРасписанияПоКадровомуПлану.ПозицияКадровогоПлана
	|		ИНАЧЕ ТекущиеПозиции.ПозицияКадровогоПлана
	|	КОНЕЦ КАК ПозицияКадровогоПлана,
	|	ТекущиеПозиции.НомерСтроки КАК НомерСтроки
	|ПОМЕСТИТЬ ВТТекущиеПозиции
	|ИЗ
	|	ВТТекущиеПозицииПредварительно КАК ТекущиеПозиции
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТПозицииШтатногоРасписанияПоКадровомуПлану КАК ПозицииШтатногоРасписанияПоКадровомуПлану
	|		ПО ТекущиеПозиции.Позиция = ПозицииШтатногоРасписанияПоКадровомуПлану.ПозицияШтатногоРасписания
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Подразделение,
	|	Должность
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ИзмененияШтатногоРасписания.Должность, ТекущиеПозиции.Должность) КАК Должность,
	|	ЕСТЬNULL(ИзмененияШтатногоРасписания.Подразделение, ТекущиеПозиции.Подразделение) КАК Подразделение,
	|	ЕСТЬNULL(ИзмененияШтатногоРасписания.МестоВСтруктуреПредприятия, ТекущиеПозиции.МестоВСтруктуреПредприятия) КАК МестоВСтруктуреПредприятия,
	|	ЕСТЬNULL(ИзмененияШтатногоРасписания.КоличествоСтавок, ТекущиеПозиции.КоличествоСтавок) КАК КоличествоСтавок,
	|	ЕСТЬNULL(ИзмененияШтатногоРасписания.ПозицияШтатногоРасписания, ТекущиеПозиции.Позиция) КАК Позиция,
	|	ЕСТЬNULL(ИзмененияШтатногоРасписания.ПозицияКадровогоПлана, ТекущиеПозиции.ПозицияКадровогоПлана) КАК ПозицияКадровогоПлана,
	|	ВЫБОР
	|		КОГДА ТекущиеПозиции.НомерСтроки ЕСТЬ NULL
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК НоваяСтрока,
	|	ЕСТЬNULL(ТекущиеПозиции.НомерСтроки, 9999999) КАК НомерСтрокиПорядок
	|ПОМЕСТИТЬ ВТИзмененияШтатногоРасписания
	|ИЗ
	|	ВТПозицииСИзменениями КАК ИзмененияШтатногоРасписания
	|		ПОЛНОЕ СОЕДИНЕНИЕ ВТТекущиеПозиции КАК ТекущиеПозиции
	|		ПО ИзмененияШтатногоРасписания.Подразделение = ТекущиеПозиции.Подразделение
	|			И ИзмененияШтатногоРасписания.Должность = ТекущиеПозиции.Должность
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ИзмененияШтатногоРасписания.Должность КАК Должность,
	|	ИзмененияШтатногоРасписания.Подразделение КАК Подразделение,
	|	ИзмененияШтатногоРасписания.МестоВСтруктуреПредприятия КАК МестоВСтруктуреПредприятия,
	|	ИзмененияШтатногоРасписания.КоличествоСтавок КАК КоличествоСтавок,
	|	ИзмененияШтатногоРасписания.Позиция КАК Позиция,
	|	ИзмененияШтатногоРасписания.ПозицияКадровогоПлана КАК ПозицияКадровогоПлана,
	|	ИзмененияШтатногоРасписания.НоваяСтрока КАК НоваяСтрока,
	|	ИзмененияШтатногоРасписания.НомерСтрокиПорядок КАК НомерСтрокиПорядок,
	|	ИзмененияШтатногоРасписания.Должность.ТарифнаяСетка КАК ТарифнаяСетка,
	|	ИзмененияШтатногоРасписания.Должность.ТарифнаяСеткаНадбавки КАК ТарифнаяСеткаНадбавки,
	|	ИзмененияШтатногоРасписания.Должность.РазрядКатегория КАК РазрядКатегория,
	|	ИзмененияШтатногоРасписания.Должность.РазрядКатегорияНадбавки КАК РазрядКатегорияНадбавки,
	|	ИзмененияШтатногоРасписания.Должность.ВзимаютсяВзносыЗаЗанятыхНаРаботахСДосрочнойПенсией КАК
	|		ВзимаютсяВзносыЗаЗанятыхНаРаботахСДосрочнойПенсией,
	|	ИзмененияШтатногоРасписания.Должность.ОснованиеДосрочногоНазначенияПенсии КАК ОснованиеДосрочногоНазначенияПенсии,
	|	ИзмененияШтатногоРасписания.Должность.ОсобыеУсловияТрудаПФР КАК ОсобыеУсловияТрудаПФР,
	|	ИзмененияШтатногоРасписания.Должность.ПроцентНадбавкиЗаВредность КАК ПроцентНадбавкиЗаВредность,
	|	ИзмененияШтатногоРасписания.Должность.ВыплачиваетсяНадбавкаЗаВредность КАК ВыплачиваетсяНадбавкаЗаВредность,
	|	ИзмененияШтатногоРасписания.Должность.КоличествоДнейДополнительногоОтпускаВГод КАК
	|		КоличествоДнейДополнительногоОтпускаВГод,
	|	ИзмененияШтатногоРасписания.Должность.КодПозицииСпискаПФР КАК КодПозицииСпискаПФР,
	|	ИзмененияШтатногоРасписания.Должность.ХарактерВыполняемыхРаботПФР КАК ХарактерВыполняемыхРаботПФР,
	|	ИзмененияШтатногоРасписания.Должность.ПервичныеДокументыПФР КАК ПервичныеДокументыПФР,
	|	ИзмененияШтатногоРасписания.Должность.ТрудоваяФункция КАК ТрудоваяФункция
	|ИЗ
	|	ВТИзмененияШтатногоРасписания КАК ИзмененияШтатногоРасписания
	|		ПОЛНОЕ СОЕДИНЕНИЕ ВТТекущиеПозиции КАК ТекущиеПозиции
	|		ПО ИзмененияШтатногоРасписания.Подразделение = ТекущиеПозиции.Подразделение
	|			И ИзмененияШтатногоРасписания.Должность = ТекущиеПозиции.Должность
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтрокиПорядок";
	
	Возврат Запрос.Выполнить();
	
КонецФункции

Процедура ЗаполнитьПозициюКадровогоПлана(СтрокаПриемник, СтрокаИсточник, СтандартнаяОбработка) Экспорт
	
	Если СтандартнаяОбработка Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(СтрокаПриемник, СтрокаИсточник, "ПозицияКадровогоПлана");
	
КонецПроцедуры

#КонецОбласти

Процедура ПередЗаписьюДокументовИзмененияШтатногоРасписания(Объект) Экспорт
	
	Если Не ИспользоватьКадровоеПланирование() Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПравоДоступа("Изменение", Метаданные.РегистрыСведений.ПозицииШтатногоРасписанияПоКадровомуПлану) Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаПозиции Из Объект.Позиции Цикл
		Если Не ЗначениеЗаполнено(СтрокаПозиции.ПозицияКадровогоПлана) Тогда
			Продолжить;
		КонецЕсли;
		УстановитьСвязьПозиций(СтрокаПозиции.Позиция, СтрокаПозиции.ПозицияКадровогоПлана);
	КонецЦикла;
	
КонецПроцедуры

// Создает временную таблицу плановых начислений сотрудников.
// При необходимости следует дополнить ВТПлановыеНачисленияСотрудников конструкцией ОБЪЕДИНИТЬ ВСЕ 
//
// Параметры:
//		МенеджерВременныхТаблиц 	- МенеджерВременныхТаблиц
//  	ИмяВТСотрудники 			- Строка - Имя ВТ, содержащей периоды работы сотрудников. см. процедуру СоздатьВТПериодыРаботыСотрудников. 
//
Процедура СоздатьВТПлановыеНачисленияСотрудников(МенеджерВременныхТаблиц, ИмяВТСотрудники = "ВТПериодыРаботыСотрудников") Экспорт
	
	ОписаниеФильтра = ЗарплатаКадрыОбщиеНаборыДанных.ОписаниеФильтраДляСоздатьВТИмяРегистра(ИмяВТСотрудники, "Сотрудник");
	ПараметрыПостроения = ЗарплатаКадрыОбщиеНаборыДанных.ПараметрыПостроенияДляСоздатьВТИмяРегистраСрез();
	ЗарплатаКадрыОбщиеНаборыДанных.ДобавитьВКоллекциюОтбор(
		ПараметрыПостроения.ОтборыПрименяемыеКСрезу, "Используется", "=", Истина);
	
	ЗарплатаКадрыПериодическиеРегистры.СоздатьВТИмяРегистраСрезПоследних(
		"ПлановыйФОТ", МенеджерВременныхТаблиц, Истина, ОписаниеФильтра, ПараметрыПостроения);

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ПлановыйФОТСрезПоследних.Период КАК Период,
		|	ПлановыйФОТСрезПоследних.Сотрудник КАК Сотрудник,
		|	ПлановыйФОТСрезПоследних.Начисление КАК Начисление,
		|	ПлановыйФОТСрезПоследних.ГоловнаяОрганизация КАК ГоловнаяОрганизация,
		|	ПлановыйФОТСрезПоследних.ВкладВФОТ КАК Сумма
		|ПОМЕСТИТЬ ВТПлановыеНачисленияСотрудников
		|ИЗ
		|	ВТПлановыйФОТСрезПоследних КАК ПлановыйФОТСрезПоследних";
	
	Запрос.Выполнить();
	
КонецПроцедуры

// Дополняет временную таблицу плановых начислений позиций штатного расписания.
// При необходимости следует дополнить ВТВременнаяТаблица конструкцией ОБЪЕДИНИТЬ ВСЕ 
//
// Параметры:
//		МенеджерВременныхТаблиц 	- МенеджерВременныхТаблиц
//									содержит обязательные таблицы:
//										"ВТНачисленияПозицийШтатногоРасписания" см. процедуру УправлениеШтатнымРасписанием.СоздатьВТНачисленияШтатногоРасписания
//  	ИмяВТСотрудники 			- Строка - Имя ВТ, содержащей периоды работы сотрудников. см. процедуру СоздатьВТПериодыРаботыСотрудников. 
//
Процедура ДополнитьТаблицуПлановыхНачисленийШтатногоРасписания(МенеджерВременныхТаблиц, ИмяВТСотрудники = "ВТПериодыРаботыСотрудников") Экспорт

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	НачисленияШтатногоРасписания.ПозицияШтатногоРасписания КАК ПозицияШтатногоРасписания,
		|	НачисленияШтатногоРасписания.Начисление КАК Начисление,
		|	НачисленияШтатногоРасписания.Размер КАК Размер
		|ПОМЕСТИТЬ ВТВременнаяТаблица
		|ИЗ
		|	ВТНачисленияПозицийШтатногоРасписания КАК НачисленияШтатногоРасписания
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТНачисленияПозицийШтатногоРасписания
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВременнаяТаблица.ПозицияШтатногоРасписания КАК ПозицияШтатногоРасписания,
		|	ВременнаяТаблица.Начисление КАК Начисление,
		|	ВременнаяТаблица.Размер КАК Размер
		|ПОМЕСТИТЬ ВТНачисленияПозицийШтатногоРасписания
		|ИЗ
		|	ВТВременнаяТаблица КАК ВременнаяТаблица
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТВременнаяТаблица";
	
	Запрос.Выполнить();

КонецПроцедуры

