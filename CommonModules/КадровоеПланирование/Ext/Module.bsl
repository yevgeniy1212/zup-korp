#Область ПрограммныйИнтерфейс

// Возвращает информацию о последнем закрытом периоде начисления зарплаты.
//
// Возвращаемое значение:
//  - ПоследнийЗакрытыйПериод - Дата - дата последнего закрытого периода.
//
Функция ПоследнийПериодВыплатОтраженияЗарплаты() Экспорт
	
	ПоследнийЗакрытыйПериод = ВзаиморасчетыССотрудникамиРасширенный.ПоследнийПериодВзаиморасчетовССотрудниками();
	
	Если Не ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.КонфигурацииЗарплатаКадрыРасширенная.ОтражениеРасчетовЗарплатыВБухучете") Тогда
		Возврат ПоследнийЗакрытыйПериод;
	КонецЕсли;
	
	Возврат Макс(ПоследнийЗакрытыйПериод, ОбщегоНазначения.ОбщийМодуль("ОтражениеРасчетовЗарплатыВБухучете").ПоследнийПериодОтраженияЗарплаты());
	
КонецФункции

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Возвращает значение константы "ИспользоватьКадровоеПланирование".
//
// Возвращаемое значение:
//  Булево - значение константы.
//
Функция ИспользоватьКадровоеПланирование() Экспорт
	Возврат Константы.ИспользоватьКадровоеПланирование.Получить();
КонецФункции

// Обновляет значение константы "ИспользоватьКадровоеПланирование".
//
// Параметры:
//  Значение - Булево - значение константы.
//
Процедура ОбновитьИспользованиеКадровогоПланирования(Знач Значение) Экспорт
	Константы.ИспользоватьКадровоеПланирование.Установить(Значение);
КонецПроцедуры

// Возвращает элемент справочника "ПоказателиКадровогоПланирования" с категорией КоличествоСтавок
//
// Возвращаемое значение:
//  СправочникСсылка.ПоказателиКадровогоПланирования
//
Функция ПоказательКоличествоСтавок() Экспорт
	
	Возврат Справочники.ПоказателиКадровогоПланирования.НайтиПоРеквизиту("Категория",
		Перечисления.КатегорииРасходовНаПерсонал.КоличествоСтавок);
	
КонецФункции

// См. Перечисления.ВидыОперацийПоЗарплате.Взносы.
Функция ВидыОперацийПоЗарплатеВзносы() Экспорт
	Возврат Перечисления.ВидыОперацийПоЗарплате.Взносы();
КонецФункции

#Область Свойства

// См. УправлениеСвойствамиПереопределяемый.ПриПолученииПредопределенныхНаборовСвойств.
Процедура ПриПолученииПредопределенныхНаборовСвойств(Наборы) Экспорт
	
	УправлениеСвойствамиБЗК.ЗарегистрироватьНаборСвойств(
		Наборы, "7488d015-ce7e-11eb-831d-9db1eefef239", Метаданные.Справочники.ПозицииКадровогоПлана);
	
	УправлениеСвойствамиБЗК.ЗарегистрироватьНаборСвойств(
		Наборы, "7488d016-ce7e-11eb-831d-9db1eefef239", Метаданные.Справочники.ПоказателиКадровогоПланирования);
	
	УправлениеСвойствамиБЗК.ЗарегистрироватьНаборСвойств(
		Наборы, "7488d017-ce7e-11eb-831d-9db1eefef239", Метаданные.Документы.КадровыйПлан);
	
КонецПроцедуры

#КонецОбласти

#Область УправлениеДоступом

// См. УправлениеДоступомПереопределяемый.ПриЗаполненииСписковСОграничениемДоступа.
Процедура ПриЗаполненииСписковСОграничениемДоступа(Списки) Экспорт
	
	Списки.Вставить(Метаданные.Документы.КадровыйПлан, Истина);
	Списки.Вставить(Метаданные.Справочники.КадровыйПланПрисоединенныеФайлы, Истина);
	Списки.Вставить(Метаданные.Справочники.ПозицииКадровогоПлана, Истина);
	Списки.Вставить(Метаданные.РегистрыНакопления.ПоказателиКадровогоПлана, Истина);
	
КонецПроцедуры

// Заполняет описателей профилей групп доступа, предназначенных для работы с кадровым планом
// см. УправлениеДоступомПереопределяемый.ЗаполнитьПоставляемыеПрофилиГруппДоступа.
Процедура ЗаполнитьПоставляемыеПрофилиГруппДоступа(ОписанияПрофилей, ПараметрыОбновления) Экспорт 
	
	ЕстьИнтерфейс = ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.ЗарплатаКадрыКомандныйИнтерфейс");
	
	ОписаниеПрофиля = ОписаниеПрофиляСпециалистПоПланированию(ЕстьИнтерфейс);
	ОписанияПрофилей.Добавить(ОписаниеПрофиля);
	
	ОписаниеПрофиля = ОписаниеПрофиляСтаршийСпециалистПоПланированию(ЕстьИнтерфейс);
	ОписанияПрофилей.Добавить(ОписаниеПрофиля);
	
КонецПроцедуры

Процедура ЗаполнитьТаблицуПереименованияОбъектовМетаданных(Итог) Экспорт
	
	ОбщегоНазначения.ДобавитьПереименование(Итог,
		"3.1.22.9",
		"Роль.НастройкаКадровогоПланирования",
		"Роль.ДобавлениеИзменениеСценариевПланирования");
	
КонецПроцедуры

#КонецОбласти

#Область ОбновлениеИнформационнойБазы

// См. ОбновлениеИнформационнойБазыБСП.ПриДобавленииОбработчиковОбновления.
Процедура ЗарегистрироватьОбработчикиОбновления(Обработчики) Экспорт
	
	Обработчик = Обработчики.Добавить();
	Обработчик.Процедура = "Справочники.ПоказателиКадровогоПланирования.НачальноеЗаполнение";
	Обработчик.НачальноеЗаполнение = Истина;
	
	Обработчик = Обработчики.Добавить();
	Обработчик.Версия = "3.1.19.72";
	Обработчик.Процедура = "Справочники.ПоказателиКадровогоПланирования.НачальноеЗаполнение";
	Обработчик.РежимВыполнения = "Отложенно";
	Обработчик.Идентификатор = Новый УникальныйИдентификатор("9a9acf99-c9d5-11eb-8317-9f9f9db68336");
	Обработчик.Комментарий = НСтр("ru = 'Заполнение показателей кадрового планирования.'");
	
	Обработчик = Обработчики.Добавить();
	Обработчик.Версия = "3.1.22.9";
	Обработчик.Процедура = "КадровоеПланирование.ДобавитьРолиДобавлениеИзменениеПоказателейКадровогоПланирования";
	Обработчик.РежимВыполнения = "Оперативно";
	
	Обработчик = Обработчики.Добавить();
	Обработчик.Версия = "3.1.22.71";
	Обработчик.Процедура = "КадровоеПланирование.ДобавитьРолиЧтениеСценариевПланирования";
	Обработчик.РежимВыполнения = "Оперативно";
	
КонецПроцедуры

Процедура ДобавитьРолиДобавлениеИзменениеПоказателейКадровогоПланирования() Экспорт
	
	ЗаменяемыеРоли = Новый Соответствие;
	
	НовыеРоли = Новый Массив;
	НовыеРоли.Добавить(Метаданные.Роли.ДобавлениеИзменениеСценариевПланирования.Имя);
	НовыеРоли.Добавить(Метаданные.Роли.ДобавлениеИзменениеПоказателейКадровогоПланирования.Имя);
	ЗаменяемыеРоли.Вставить("ДобавлениеИзменениеСценариевПланирования", НовыеРоли);
	
	УправлениеДоступом.ЗаменитьРолиВПрофилях(ЗаменяемыеРоли);
	
КонецПроцедуры

Процедура ДобавитьРолиЧтениеСценариевПланирования() Экспорт
	
	ЗаменяемыеРоли = Новый Соответствие;
	
	НовыеРоли = Новый Массив;
	НовыеРоли.Добавить(Метаданные.Роли.ЧтениеКадровогоПлана.Имя);
	НовыеРоли.Добавить(Метаданные.Роли.ЧтениеСценариевПланирования.Имя);
	ЗаменяемыеРоли.Вставить("ЧтениеКадровогоПлана", НовыеРоли);
	
	УправлениеДоступом.ЗаменитьРолиВПрофилях(ЗаменяемыеРоли);
	
КонецПроцедуры

#КонецОбласти

#Область ДляВызоваИзДругихПодсистем

#Область НастройкиВариантовОтчетов

// Содержит настройки размещения вариантов отчетов в панели отчетов.
// Описание см. ЗарплатаКадрыВариантыОтчетов.НастроитьВариантыОтчетов.
//
Процедура НастроитьВариантыОтчетов(Настройки) Экспорт
	
	ВариантыОтчетов.НастроитьОтчетВМодулеМенеджера(Настройки, Метаданные.Отчеты.СостояниеКадровогоПлана);
	ВариантыОтчетов.НастроитьОтчетВМодулеМенеджера(Настройки, Метаданные.Отчеты.СравнительныйАнализКадровогоПлана);
	
КонецПроцедуры

Функция ЗапросПоПредставлению(ИмяПредставления, ПараметрыЗапросаКомпоновки, ТолькоРазрешенные) Экспорт
	
	Запрос = Неопределено;
	Если ВРег(ИмяПредставления) = ВРег("ПоказателиКадровогоПлана") Тогда
		Если ПолучитьФункциональнуюОпцию("ИспользоватьКадровоеПланирование") Тогда
			Запрос = Новый Запрос;
			Запрос.УстановитьПараметр("ПоказательКоличествоСтавок", ПоказательКоличествоСтавок());
			Запрос.Текст = 
				"ВЫБРАТЬ РАЗРЕШЕННЫЕ
				|	ПоказателиКадровогоПлана.Период КАК Период,
				|	ПоказателиКадровогоПлана.Сценарий КАК Сценарий,
				|	ПоказателиКадровогоПлана.Подразделение КАК Подразделение,
				|	ПоказателиКадровогоПлана.Позиция КАК Позиция,
				|	ПоказателиКадровогоПлана.ФизическоеЛицо КАК ФизическоеЛицо,
				|	ПоказателиКадровогоПлана.Сотрудник КАК Сотрудник,
				|	ПоказателиКадровогоПлана.Показатель КАК Показатель,
				|	ПоказателиКадровогоПлана.ЗависимаяВакансия КАК ЗависимаяВакансия,
				|	СУММА(ПоказателиКадровогоПлана.Значение) КАК Значение
				|ПОМЕСТИТЬ ВТПредварительноПоказателиКадровогоПлана
				|ИЗ
				|	РегистрНакопления.ПоказателиКадровогоПлана КАК ПоказателиКадровогоПлана
				|ГДЕ
				|	ПоказателиКадровогоПлана.Период МЕЖДУ &НачалоПериода И &КонецПериода
				|{ГДЕ
				|	(ПоказателиКадровогоПлана.Сценарий = &Сценарий),
				|	(ПоказателиКадровогоПлана.Подразделение В ИЕРАРХИИ (&Подразделение))}
				|
				|СГРУППИРОВАТЬ ПО
				|	ПоказателиКадровогоПлана.Период,
				|	ПоказателиКадровогоПлана.Сценарий,
				|	ПоказателиКадровогоПлана.Подразделение,
				|	ПоказателиКадровогоПлана.Позиция,
				|	ПоказателиКадровогоПлана.ФизическоеЛицо,
				|	ПоказателиКадровогоПлана.Сотрудник,
				|	ПоказателиКадровогоПлана.Показатель,
				|	ПоказателиКадровогоПлана.ЗависимаяВакансия
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	ПоказателиКадровогоПлана.Сценарий КАК Сценарий,
				|	ПоказателиКадровогоПлана.Подразделение КАК Подразделение,
				|	ПоказателиКадровогоПлана.Позиция КАК Позиция,
				|	ПоказателиКадровогоПлана.ФизическоеЛицо КАК ФизическоеЛицо,
				|	ПоказателиКадровогоПлана.Сотрудник КАК Сотрудник,
				|	ПоказателиКадровогоПлана.Показатель КАК Показатель,
				|	ПоказателиКадровогоПлана.ЗависимаяВакансия КАК ЗависимаяВакансия
				|ПОМЕСТИТЬ ВТЗаполненныеПоказатели
				|ИЗ
				|	ВТПредварительноПоказателиКадровогоПлана КАК ПоказателиКадровогоПлана
				|ГДЕ
				|	ПоказателиКадровогоПлана.Показатель = &ПоказательКоличествоСтавок
				|
				|СГРУППИРОВАТЬ ПО
				|	ПоказателиКадровогоПлана.Сценарий,
				|	ПоказателиКадровогоПлана.Подразделение,
				|	ПоказателиКадровогоПлана.Позиция,
				|	ПоказателиКадровогоПлана.ФизическоеЛицо,
				|	ПоказателиКадровогоПлана.Сотрудник,
				|	ПоказателиКадровогоПлана.Показатель,
				|	ПоказателиКадровогоПлана.ЗависимаяВакансия
				|
				|ИМЕЮЩИЕ
				|	СУММА(ПоказателиКадровогоПлана.Значение) > 0
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ
				|	ПоказателиКадровогоПлана.Период КАК Период,
				|	ПоказателиКадровогоПлана.Сценарий КАК Сценарий,
				|	ПоказателиКадровогоПлана.Подразделение КАК Подразделение,
				|	ПоказателиКадровогоПлана.Позиция КАК Позиция,
				|	ПоказателиКадровогоПлана.ФизическоеЛицо КАК ФизическоеЛицо,
				|	ПоказателиКадровогоПлана.Сотрудник КАК Сотрудник,
				|	ПоказателиКадровогоПлана.Показатель КАК Показатель,
				|	ПоказателиКадровогоПлана.ЗависимаяВакансия КАК ЗависимаяВакансия,
				|	ПоказателиКадровогоПлана.Значение КАК Значение,
				|	0 КАК ФОТ,
				|	0 КАК ФОТМин,
				|	0 КАК ФОТМакс,
				|	0 КАК ФОТПозиции,
				|	0 КАК ФОТПозицииМин,
				|	0 КАК ФОТПозицииМакс,
				|	0 КАК ОкладТариф,
				|	0 КАК ОкладТарифМин,
				|	0 КАК ОкладТарифМакс,
				|	ЛОЖЬ КАК Занята
				|ПОМЕСТИТЬ Представления_ПоказателиКадровогоПлана
				|ИЗ
				|	ВТПредварительноПоказателиКадровогоПлана КАК ПоказателиКадровогоПлана
				|ГДЕ
				|	(ПоказателиКадровогоПлана.Сценарий, ПоказателиКадровогоПлана.Подразделение, ПоказателиКадровогоПлана.Позиция, ПоказателиКадровогоПлана.ФизическоеЛицо, ПоказателиКадровогоПлана.Сотрудник, ПоказателиКадровогоПлана.ЗависимаяВакансия) В
				|			(ВЫБРАТЬ
				|				Т.Сценарий,
				|				Т.Подразделение,
				|				Т.Позиция,
				|				Т.ФизическоеЛицо,
				|				Т.Сотрудник,
				|				Т.ЗависимаяВакансия
				|			ИЗ
				|				ВТЗаполненныеПоказатели КАК Т)";
				
			Если ПараметрыЗапросаКомпоновки.Свойство("СценарийОбязателен") Тогда
				Если ВРег(ПараметрыЗапросаКомпоновки["СценарийОбязателен"]) = "ИСТИНА" Тогда
					Запрос.Текст = СтрЗаменить(Запрос.Текст, "{ГДЕ", "");
					Запрос.Текст = СтрЗаменить(Запрос.Текст, "(ПоказателиКадровогоПлана.Сценарий = &Сценарий),", "И ПоказателиКадровогоПлана.Сценарий = &Сценарий");
					Запрос.Текст = СтрЗаменить(Запрос.Текст, "(ПоказателиКадровогоПлана.Подразделение", "{ГДЕ (ПоказателиКадровогоПлана.Подразделение");
				КонецЕсли;
			КонецЕсли; 
			
			ЗарплатаКадрыОбщиеНаборыДанных.УстановитьВыборкуТолькоРазрешенныхДанных(Запрос.Текст, ТолькоРазрешенные);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Запрос;
	
КонецФункции

