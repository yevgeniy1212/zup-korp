////////////////////////////////////////////////////////////////////////////////
// Подсистема "Охрана труда"
//
////////////////////////////////////////////////////////////////////////////////

#Область СлужебныйПрограммныйИнтерфейс

#Область Периодичность

Функция ПроизвольноеЗначениеСпискаВыбораПериодов(Форма) Экспорт
	Возврат Форма.ПроизвольноеЗначениеСпискаВыбора;
КонецФункции

Функция СтруктураПериодаПоПредставлению(Форма, ПериодСтрокой) Экспорт
	
	СтруктураПериода = Неопределено;
	Если ПериодСтрокой = Форма.ПроизвольноеЗначениеСпискаВыбора Тогда
		Возврат СтруктураПериода;
	КонецЕсли;
	
	Для Каждого ЗначениеСписка Из Форма.СписокВыбораПериодов Цикл
		Если ЗначениеСписка.Представление = ПериодСтрокой Тогда
			СтруктураПериода = ЗначениеСписка.Значение;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат СтруктураПериода;
	
КонецФункции

#КонецОбласти

Процедура ДополнитьОписаниеДополнительнойФормыСотрудника(ОписаниеФормы, ИмяОткрываемойФормы, СтандартнаяОбработка) Экспорт
	
	Если ИмяОткрываемойФормы = "ОбщаяФорма.СотрудникиОхранаТруда" Тогда
		
		СтандартнаяОбработка = Ложь;
		
		ОписаниеФормы.КлючевыеРеквизиты.Вставить("СотрудникСсылка");
		ОписаниеФормы.КлючевыеРеквизиты.Вставить("Заголовок", "Сотрудник.Наименование");
		
	КонецЕсли;
	
КонецПроцедуры

Процедура УстановитьРабочееМестоКомментарий(Форма) Экспорт
	
	Элемент = Форма.Элементы.Найти("РабочееМестоКомментарий");
	Если Элемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ИзменитьРабочееМесто = ОбщегоНазначенияКлиентСервер.ПолучитьРеквизитФормыПоПути(Форма, "Объект.ИзменитьРабочееМесто");
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Форма.Элементы, "РабочееМестоКомментарий", "Видимость", ИзменитьРабочееМесто);
	
	Если ИзменитьРабочееМесто Тогда
		Если ЗначениеЗаполнено(Форма.ТекущееРабочееМесто) Тогда
			Форма.РабочееМестоКомментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
					НСтр("ru = 'Ранее сотрудник занимал рабочее место ""%1""'"), Форма.ТекущееРабочееМесто);
		Иначе
			Форма.РабочееМестоКомментарий = НСтр("ru = 'Сотруднику еще не назначено рабочее место'");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПроверитьЗначениеВидимостиСпецоценки(Форма, РазрешитьВидимостьСпецоценки) Экспорт
	
	РазрешитьВидимостьСпецоценки = РазрешитьВидимостьСпецоценки
		И Не Форма.ПолучитьФункциональнуюОпциюФормы("ИспользоватьСпециальнуюОценкуУсловийТруда");
	
КонецПроцедуры

#КонецОбласти