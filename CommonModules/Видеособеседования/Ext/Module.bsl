//@Strict-types

#Область СлужебныйПрограммныйИнтерфейс

// Параметры:
//  Использование - Булево
Процедура ПриИзмененииИспользованияПодсистемы(Использование) Экспорт
	
	Если Использование Тогда
		СоздатьШаблоныСообщений();
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  ПараметрыПланируемогоЭтапа - Структура
Процедура ДополнитьПараметрыПланируемогоЭтапа(ПараметрыПланируемогоЭтапа) Экспорт
	
	Если Видеоконференции.ИспользуютсяВидеоконференции() Тогда
		ПараметрыПланируемогоЭтапа.Вставить("СсылкаНаВидеоконференцию", "");
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  ЭтапРаботы - Структура
//  ПараметрыПланируемогоЭтапа - Структура
Процедура ЗаполнитьПараметрыПланируемогоЭтапа(ЭтапРаботы, ПараметрыПланируемогоЭтапа) Экспорт
	
	Если Видеоконференции.ИспользуютсяВидеоконференции() Тогда
		ПараметрыПланируемогоЭтапа.СсылкаНаВидеоконференцию = ЭтапРаботы.СсылкаНаВидеоконференцию;
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  Параметры - Структура
//  Описание - Строка
Процедура ДополнитьОписаниеПланируемогоЭтапа(Параметры, Описание) Экспорт
	
	Если Видеоконференции.ИспользуютсяВидеоконференции() Тогда
		СсылкаНаВидеоконференцию = Параметры.СсылкаНаВидеоконференцию;
		
		Если ЗначениеЗаполнено(СсылкаНаВидеоконференцию) Тогда
			Описание = СтрШаблон(НСтр("ru = '%1
									|
									|Встреча в видеоформате. Ссылка для участия:
									|%2'"), 
								Описание, СсылкаНаВидеоконференцию);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  РеквизитыЭтапа - СтрокаДереваЗначений
Процедура ДополнитьШаблонСообщения(РеквизитыЭтапа) Экспорт
	
	Если Видеоконференции.ИспользуютсяВидеоконференции() Тогда
		// Ссылка на видеоконференцию.
		НоваяСтрока = РеквизитыЭтапа.Добавить();
		НоваяСтрока.Имя = "ЭтапРаботы.СсылкаНаВидеоконференцию";
		НоваяСтрока.Представление = НСтр("ru = 'Ссылка на видеоконференцию'");
		
		// Ссылка на видеоконференцию для кандидата.
		НоваяСтрока = РеквизитыЭтапа.Добавить();
		НоваяСтрока.Имя = "ЭтапРаботы.СсылкаНаВидеоконференциюДляКандидата";
		НоваяСтрока.Представление = НСтр("ru = 'Ссылка на видеоконференцию (для кандидата)'");
		
		// Сервис видеоконференции.
		НоваяСтрока = РеквизитыЭтапа.Добавить();
		НоваяСтрока.Имя = "ЭтапРаботы.СервисВидеоконференции";
		НоваяСтрока.Представление = НСтр("ru = 'Сервис видеоконференции'");
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  РеквизитыЭтапа - Структура
//  ПараметрыСообщения - Структура:
// * СсылкаНаВидеоконференцию - Строка
// * СсылкаНаВидеоконференциюДляКандидата - Строка
// * СервисВидеоконференции - Строка
Процедура ЗаполнитьЗначенияРеквизитовШаблонаСообщения(РеквизитыЭтапа, ПараметрыСообщения) Экспорт
	
	Если Видеоконференции.ИспользуютсяВидеоконференции() Тогда
		РеквизитыЭтапа.Вставить("СсылкаНаВидеоконференцию",
			ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыСообщения, "СсылкаНаВидеоконференцию", ""));
		РеквизитыЭтапа.Вставить("СсылкаНаВидеоконференциюДляКандидата",
			ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыСообщения, "СсылкаНаВидеоконференциюДляКандидата", ""));
		РеквизитыЭтапа.Вставить("СервисВидеоконференции",
			ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПараметрыСообщения, "СервисВидеоконференции", ""));
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  Параметры - См. ВидеособеседованияКлиент.НовыеПараметрыВидеособеседования
//  УникальныйИдентификатор - УникальныйИдентификатор
// 
// Возвращаемое значение:
//  См. ДлительныеОперации.ВыполнитьФункцию
Функция ДлительнаяОперацияСозданияВидеособеседования(Параметры, УникальныйИдентификатор) Экспорт
	
	НастройкиВидеоконференции = НастройкиВидеоконференции(Параметры);
	
	ИмяПроцедуры = "Видеоконференции.СоздатьВидеоконференцию";
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		УникальныйИдентификатор, ИмяПроцедуры, Параметры.УчетнаяЗапись, НастройкиВидеоконференции);
	
КонецФункции

// Параметры:
//  Параметры - См. ВидеособеседованияКлиент.НовыеПараметрыВидеособеседования
//  УникальныйИдентификатор - УникальныйИдентификатор
// 
// Возвращаемое значение:
//  См. ДлительныеОперации.ВыполнитьФункцию
Функция ДлительнаяОперацияОбновленияВидеособеседования(Параметры, УникальныйИдентификатор) Экспорт
	
	НастройкиВидеоконференции = НастройкиВидеоконференции(Параметры);
	
	ИмяПроцедуры = "Видеоконференции.ОбновитьВидеоконференцию";
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		УникальныйИдентификатор, ИмяПроцедуры, Параметры.УчетнаяЗапись, НастройкиВидеоконференции);
	
КонецФункции

// Параметры:
//  Параметры - См. ВидеособеседованияКлиент.НовыеПараметрыВидеособеседования
//  Пользователь - СправочникСсылка.Пользователи
// 
// Возвращаемое значение:
//  Булево
Функция ПользовательЯвляетсяУчастником(Параметры, Пользователь = Неопределено) Экспорт
	
	Если Пользователь = Неопределено Тогда
		Пользователь = Пользователи.ТекущийПользователь();
	КонецЕсли;
	
	НастройкиВидеоконференции = ВидеоконференцииСлужебный.НовыеНастройкиВидеоконференции();
	
	ДобавитьПользователейВУчастники(
		НастройкиВидеоконференции.Участники, ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Пользователь));
	
	Возврат Видеоконференции.ПользовательЯвляетсяУчастником(
		Параметры.УчетнаяЗапись,
		Параметры.Идентификатор,
		ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(НастройкиВидеоконференции.Участники[0]));
	
КонецФункции

// Параметры:
//  Параметры - См. ВидеособеседованияКлиент.НовыеПараметрыВидеособеседования
//  Пользователь - СправочникСсылка.Пользователи
Процедура ДобавитьПользователяВУчастники(Параметры, Пользователь = Неопределено) Экспорт
	
	Если Пользователь = Неопределено Тогда
		Пользователь = Пользователи.ТекущийПользователь();
	КонецЕсли;
	
	НастройкиВидеоконференции = ВидеоконференцииСлужебный.НовыеНастройкиВидеоконференции();
	
	ДобавитьПользователейВУчастники(
		НастройкиВидеоконференции.Участники, ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Пользователь));
	
	Видеоконференции.ДобавитьПользователяВУчастники(
		Параметры.УчетнаяЗапись,
		Параметры.Идентификатор,
		ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(НастройкиВидеоконференции.Участники[0]));
	
КонецПроцедуры

// Параметры:
//  Параметры - См. ВидеособеседованияКлиент.НовыеПараметрыВидеособеседования
// 
// Возвращаемое значение:
//  Массив Из Строка
Функция ВидеоконференцииПоКандидату(Параметры) Экспорт
	
	Возврат ПодборПерсонала.ВидеоконференцииПоКандидату(Параметры.УчетнаяЗапись, Параметры.Кандидат);
	
КонецФункции

// Параметры:
//  Параметры - См. ВидеособеседованияКлиент.НовыеПараметрыВидеособеседования
Процедура ОтменитьВидеоконференцииПоКандидату(Параметры) Экспорт
	
	Если Не ПодборПерсонала.ОтменитьВидеоконференцииПоКандидату(
		Параметры.Кандидат, Параметры.УчетнаяЗапись, Параметры.Идентификатор) Тогда
		ВызватьИсключение ВидеоконференцииСлужебный.ТекстИсключения(
			НСтр("ru = 'Не удалось отменить видеоконференции по кандидату.'"));
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  Параметры - См. ВидеособеседованияКлиент.НовыеПараметрыВидеособеседования
// 
// Возвращаемое значение:
//  Структура - Данные пересечений видеоконференций:
// * ЕстьПересечения - Булево -
// * Предупреждение - Строка -
Функция ДанныеПересеченийВидеоконференций(Параметры) Экспорт
	
	ДанныеОПересечениях = Новый Структура("ЕстьПересечения, Предупреждение", Ложь, "");
	
	Если Видеоконференции.ДанныеСервиса(Параметры.УчетнаяЗапись).ДоступноПланирование Тогда
		ДанныеПересеченияВидеоконференций = ПодборПерсонала.ДанныеПересеченияВидеоконференций(
			Параметры.УчетнаяЗапись, Параметры.Начало, Параметры.Окончание);
		
		Если ДанныеПересеченияВидеоконференций.ЕстьПересечения Тогда
			ДанныеОПересечениях.ЕстьПересечения = Истина;
			
			ДанныеОПересечениях.Предупреждение = 
				СтрШаблон(НСтр("ru = 'Невозможно запланировать видеоконференцию для выбранной учетной записи. 
								|Время занято для этапа ""%1 (%2)"", %3 с %4 до %5'"), 
								ДанныеПересеченияВидеоконференций.ЭтапРаботы,
								ДанныеПересеченияВидеоконференций.Кандидат,
								Формат(ДанныеПересеченияВидеоконференций.Начало, НСтр("ru = 'ДЛФ=D'")),
								Формат(ДанныеПересеченияВидеоконференций.Начало, НСтр("ru = 'ДФ=HH:mm'")),
								Формат(ДанныеПересеченияВидеоконференций.Окончание, НСтр("ru = 'ДФ=HH:mm'")));
		КонецЕсли;
	КонецЕсли;
	
	Возврат ДанныеОПересечениях;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция НастройкиВидеоконференции(Параметры)
	
	НастройкиВидеоконференции = ВидеоконференцииСлужебный.НовыеНастройкиВидеоконференции();
	
	ДанныеКандидата = ДанныеКандидата(Параметры.Кандидат);
	
	НастройкиВидеоконференции.Тема = СтрШаблон("%1 (%2)",
		Параметры.Этап,
		ФизическиеЛицаКлиентСервер.ФамилияИнициалы(ДанныеКандидата.ФИО));
	
	НастройкиВидеоконференции.Начало = Параметры.Начало;
	НастройкиВидеоконференции.Продолжительность = (Параметры.Окончание - Параметры.Начало) / 60;
	НастройкиВидеоконференции.Идентификатор = Параметры.Идентификатор;
	
	ДобавитьПользователейВУчастники(
		НастройкиВидеоконференции.Участники, Параметры.Участники);
	
	ДобавитьКандидатаВУчастники(НастройкиВидеоконференции.Участники, ДанныеКандидата);
	
	НастройкиВидеоконференции.Участники = ОбщегоНазначения.ТаблицаЗначенийВМассив(НастройкиВидеоконференции.Участники);
	
	Возврат НастройкиВидеоконференции;
	
КонецФункции

Процедура ДобавитьПользователейВУчастники(Участники, Пользователи)
	
	ДанныеПользователей = ОбщегоНазначения.ЗначенияРеквизитовОбъектов(
		Пользователи, "Наименование,ФизическоеЛицо,ИдентификаторПользователяИБ");
	
	УстановитьПривилегированныйРежим(Истина);
	Для каждого Пользователь Из Пользователи Цикл
		ДанныеПользователя = ДанныеПользователей[Пользователь];
		
		ДанныеУчастника = Участники.Добавить();
		
		Если ЗначениеЗаполнено(ДанныеПользователя.ФизическоеЛицо) Тогда
			ЗаполнитьЗначенияСвойств(ДанныеУчастника, ДанныеФизическогоЛица(ДанныеПользователя.ФизическоеЛицо));
		Иначе
			ДанныеУчастника.ФИО = ДанныеПользователя.Наименование;
			ДанныеУчастника.Представление = ДанныеПользователя.Наименование;
			ДанныеУчастника.АдресЭП = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
				Пользователь, Справочники.ВидыКонтактнойИнформации.EmailПользователя);
		КонецЕсли;
		
		ДанныеУчастника.ИдентификаторПользователяИБ = ДанныеПользователя.ИдентификаторПользователяИБ;
	КонецЦикла;
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

Процедура ДобавитьКандидатаВУчастники(Участники, ДанныеКандидата)
	
	ЗаполнитьЗначенияСвойств(Участники.Добавить(), ДанныеКандидата);
	
КонецПроцедуры

Функция ДанныеФизическогоЛица(ФизическоеЛицо)
	
	ДанныеФизическогоЛица = Новый Структура("ФИО,Представление,АдресЭП");
	
	ДанныеФизическогоЛица.ФИО = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ФизическоеЛицо, "ФИО");
	ДанныеФизическогоЛица.Представление = ФизическиеЛицаКлиентСервер.ФамилияИнициалы(ДанныеФизическогоЛица.ФИО);
	ДанныеФизическогоЛица.АдресЭП = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
		ФизическоеЛицо, Справочники.ВидыКонтактнойИнформации.EMailФизическиеЛица);
	
	Возврат ДанныеФизическогоЛица;
	
КонецФункции

Функция ДанныеКандидата(Кандидат)
	
	Результат = Новый Структура();
	
	ДанныеКандидата = Справочники.Кандидаты.ДанныеКандидата(Кандидат);
	
	Если Не ЗначениеЗаполнено(ДанныеКандидата.EMail) Тогда
		ВызватьИсключение НСтр("ru = 'Чтобы пригласить кандидата заполните адрес его электронной почты'");
	КонецЕсли;
	
	Результат.Вставить("ФИО", ДанныеКандидата.ФИО);
	Результат.Вставить("Представление", ФизическиеЛицаКлиентСервер.ФамилияИнициалы(ДанныеКандидата.ФИО));
	Результат.Вставить("АдресЭП", ДанныеКандидата.EMail);
	
	Возврат Результат;
	
КонецФункции

Процедура СоздатьШаблоныСообщений()
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ШаблоныСообщений.Ссылка
	|ИЗ
	|	Справочник.ШаблоныСообщений КАК ШаблоныСообщений
	|ГДЕ
	|	ШаблоныСообщений.ВладелецШаблона = ЗНАЧЕНИЕ(Перечисление.ИспользованиеШаблоновСообщенийПриПодбореПерсонала.ИзменениеЭтапаРаботыСКандидатом)
	|	И (ШаблоныСообщений.ТекстШаблонаПисьма ПОДОБНО ""%СервисВидеоконференции%""
	|	ИЛИ ШаблоныСообщений.ТекстШаблонаПисьмаHTML ПОДОБНО ""%СервисВидеоконференции%"")
	|	И НЕ ШаблоныСообщений.ПометкаУдаления";
	
	Если Не Запрос.Выполнить().Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	// АПК:1223-выкл. Личные местоимения используются в текстах шаблонов
	
	// Приглашение на видеособеседование (для кандидата).
	ПараметрыШаблона = ШаблоныСообщений.ОписаниеПараметровШаблона();
	ПараметрыШаблона.ПолноеИмяТипаНазначения = Метаданные.Справочники.Кандидаты.ПолноеИмя();
	ПараметрыШаблона.Назначение = Метаданные.Справочники.Кандидаты.Синоним;
	ПараметрыШаблона.ТипШаблона = "Письмо";
	Если ПолучитьФункциональнуюОпцию("ИспользоватьПочтовыйКлиент") 
		И Не ПолучитьФункциональнуюОпцию("ОтправлятьПисьмаВФорматеHTML") Тогда
		ПараметрыШаблона.ФорматПисьма = Перечисления.СпособыРедактированияЭлектронныхПисем.ОбычныйТекст;
	КонецЕсли;
	ПараметрыШаблона.Тема = НСтр("ru = 'Приглашение на видеособеседование'");
	ПараметрыШаблона.Текст = 
		НСтр("ru = 'Добрый день, [Кандидаты.ФизическоеЛицо.Имя] [Кандидаты.ФизическоеЛицо.Отчество]!
			|
			|Наша компания [Кандидаты.Организация.Наименование] получила ваш отклик на вакансию «[Кандидаты.Вакансия]».
