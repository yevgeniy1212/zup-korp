#Область ПрограммныйИнтерфейс

#Область ВыгрузкаВJSON

// Выполняет выгрузку данных отчетности 1С в формате JSON.  
// Перед началом выгрузки инициирует подключение расширения работы с файлами, 
// после чего запускается процедура обработки выгрузки.
//
// Параметры:  
//   ДополнительныеПараметры - Структура - вспомогательные параметры:
//	 	* СтруктураРеквизитовФормы - реквизит формы "СтруктураРеквизитовФормы"
//	 	* РезультатВыгрузки - Строка - адрес хранилища, содержащего готовый текст формы в формате JSON.
Процедура ВыгрузитьВJSONОтчетность1С(ДополнительныеПараметры) Экспорт
		
	ОписаниеОповещения = Новый ОписаниеОповещения("ВыгрузитьПослеПодключенияРасширенияРаботыСФайламиОтчетность1С", ЭтотОбъект, ДополнительныеПараметры);	
	
	НачатьПодключениеРасширенияРаботыСФайлами(ОписаниеОповещения);
   
КонецПроцедуры

// Выполняет продолжение процесса выгрузки отчетности 1С в формате JSON
// после подключения расширения работы с файлами.  
// В зависимости от состояния подключения либо открывает диалог сохранения файла,
// либо загружает сформированный файл с сервера.
//
// Параметры:  
//   Подключено - Булево - признак того, что расширение работы с файлами успешно подключено.  
//     * Истина  - выполняется открытие диалога сохранения файла.  
//     * Ложь    - производится получение готового файла с сервера.  
//   ДополнительныеПараметры - Структура - дополнительные данные, содержащие:  
//     * СтруктураРеквизитовФормы.мВыбраннаяФорма - строка с полным именем формы;  
//     * СтруктураРеквизитовФормы.мГод - год формирования отчета;  
//     * РезультатВыгрузки - результат формирования JSON-файла на сервере.
Процедура ВыгрузитьПослеПодключенияРасширенияРаботыСФайламиОтчетность1С(Подключено, ДополнительныеПараметры) Экспорт
	
	ИмяФайла = Отчетность1СКлиентСервер.СФормироватьИмяФайла_ВыгрузкаJSON(ДополнительныеПараметры);
	
	Если Подключено Тогда
		ДиалогСохраненияФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
		ДиалогСохраненияФайла.ПолноеИмяФайла = ИмяФайла;	
		ДиалогСохраненияФайла.Фильтр = Отчетность1СКлиентСервер.ФильтрДиалоговВыбораИСохраненияРегламентированногоОтчета();	
		ДиалогСохраненияФайла.МножественныйВыбор = Ложь;
		ДиалогСохраненияФайла.Заголовок = НСтр("ru = 'Укажите файл'");		
		ОписаниеОповещения = Новый ОписаниеОповещения("ВыгрузитьЗавершениеОтчетность1С", ЭтотОбъект, ДополнительныеПараметры);
		ДиалогСохраненияФайла.Показать(ОписаниеОповещения);
	Иначе 
		
		РезультатВыгрузки = ДополнительныеПараметры.РезультатВыгрузки;

		НачатьПолучениеФайлаССервера(РезультатВыгрузки, ИмяФайла); 
	КонецЕсли;
КонецПроцедуры

// Завершает процесс выгрузки отчетности 1С в формате JSON.  
// Сохраняет сформированный файл из временного хранилища на локальный диск пользователя.
//
// Параметры:  
//   Результат - Массив или Неопределено - результат работы диалога сохранения файла.  
//     * Неопределено – если пользователь отменил выбор файла.  
//     * Массив – содержит путь к выбранному файлу.  
//   ДополнительныеПараметры - Структура - содержит данные, необходимые для сохранения файла,  
//     включая результат выгрузки (АдресВременногоХранилища).
//
Процедура ВыгрузитьЗавершениеОтчетность1С(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	АдресВременногоХранилища = ДополнительныеПараметры.РезультатВыгрузки;
		
	ПолноеИмяФайла = Результат[0];
	ПолучаемыеФайлы = Новый Массив;
	ПолучаемыеФайлы.Добавить(Новый ОписаниеПередаваемогоФайла(ПолноеИмяФайла, АдресВременногоХранилища));
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяФайла",ПолноеИмяФайла); 
	Обработчик = Новый ОписаниеОповещения("ВыгрузитьФайлНаКлиентеЗавершениеОтчетность1С", ЭтотОбъект,ДополнительныеПараметры);
	ПараметрыСохранения = ПараметрыСохраненияФайлов();
	ПараметрыСохранения.Интерактивно = Ложь;
	СохранитьФайлы(Обработчик, ПолучаемыеФайлы, ПараметрыСохранения);
КонецПроцедуры

// Завершает процесс выгрузки файла отчетности 1С на клиенте.  
// Отображает пользователю уведомление об успешном сохранении данных и  
// предоставляет ссылку на каталог, в котором расположен сохраненный файл.
//
// Параметры:  
//   ПолученныеФайлы - Массив или Неопределено - содержит сведения о сохраненных файлах.  
//     * Неопределено – если файлы не были получены (например, в веб-клиенте).  
//     * Массив – список успешно сохраненных файлов.  
//   ДополнительныеПараметры - Структура - содержит параметры сохранения,  
//     включая полное имя сохраненного файла (ключ "ИмяФайла").
//
Процедура ВыгрузитьФайлНаКлиентеЗавершениеОтчетность1С(ПолученныеФайлы, ДополнительныеПараметры) Экспорт
	
	ТекстЗаголовка = НСтр("ru = 'Данные успешно выгружены в файл'");
	
	СтруктураФайла = Отчетность1СКлиентСервер.РазложитьПолноеИмяФайла(ДополнительныеПараметры.ИмяФайла);
	
	РабочийКаталог = СтруктураФайла.Путь;

	#Если НЕ ВебКлиент Тогда
		ПоказатьОповещениеПользователя(
		ТекстЗаголовка, "file:///" + СтрЗаменить(СокрЛП(РабочийКаталог), "\", "/"),
		РабочийКаталог);
	#Иначе
		Если НЕ ЗначениеЗаполнено(ПолученныеФайлы) Тогда
			Возврат;
		КонецЕсли;                                                    
		
		ПоказатьОповещениеПользователя(
		ТекстЗаголовка,,
		РабочийКаталог);
	#КонецЕсли
	
	ТекстСообщения = Отчетность1СКлиентСервер.СформироватьТекстСообщения_ВыгрузкаJSON(СтруктураФайла);
	Отчетность1СКлиентСервер.СообщитьПользователю(ТекстСообщения);
КонецПроцедуры

// см. Отчетность1СКлиентПереопределяемый.ПараметрыСохраненияФайлов()
Функция ПараметрыСохраненияФайлов() Экспорт
	Возврат Отчетность1СКлиентПереопределяемый.ПараметрыСохраненияФайлов();
КонецФункции

// см. Отчетность1СКлиентПереопределяемый.СохранитьФайлы()
Процедура СохранитьФайлы(ОбработчикЗавершения, СохраняемыеФайлы, ПараметрыСохранения = Неопределено) Экспорт
	Отчетность1СКлиентПереопределяемый.СохранитьФайлы(ОбработчикЗавершения, СохраняемыеФайлы, ПараметрыСохранения);
КонецПроцедуры

#КонецОбласти

#Область ПроверкаФЛК
// Выполняет проверку заполнения формы перед отправкой или сохранением.
//
// Параметры:
//  ПризнакОтправкаФормы – Булево. Определяет, выполняется ли проверка перед непосредственной отправкой формы
//                         (Истина) или перед локальной проверкой без отправки (Ложь).
//  Форма – Объект формы регламентированной отчетности, для которой выполняется проверка.
//
Процедура ПроверитьЗаполнение(ПризнакОтправкаФормы, Форма) Экспорт
	ОчиститьСообщения();
	Отчетность1СКлиентСервер.ОчиститьТаблицуОшибок(Форма);
	УстановитьДоступностьЭлементовФормы(Форма, Ложь, Отчетность1СКлиентСервер.ТекстСообщения_ПроверитьЗаполнение());
	
	СтруктураПараметров = Форма.ПолучитьСтруктуруПараметровОтчетность1С("ПроверкаФЛК");
	СтруктураПараметров.Вставить("ПризнакОтправкаФормы", ПризнакОтправкаФормы);
			
	ОтправитьДанныеНаВалидацию(СтруктураПараметров, Форма.УникальныйИдентификатор, Форма);	
КонецПроцедуры

// Отправляет отчетные данные на сервер для форматно-логической проверки (ФЛК).
//
// Параметры:
//  СтруктураПараметров – Структура. Содержит параметры отчета и контекст проверки (см. Отчетность1ССервер.СформироватьСтруктуруПараметров()).  
//  УникальныйИдентификатор – Строка. Уникальный идентификатор формы для синхронизации результатов.  
//  Форма – Объект формы, из которой инициируется проверка.
//
Процедура ОтправитьДанныеНаВалидацию(СтруктураПараметров, УникальныйИдентификатор, Форма) Экспорт
	// 1. Запуск фонового задания на сервере.
	ДлительнаяОперация  = Отчетность1СВызовСервера.ОтправитьДанныеНаВалидацию(СтруктураПараметров, УникальныйИдентификатор);
	
	// 2. Подключение обработчика завершения фонового задания.
	ДополнительныеПараметры = Новый Структура("УникальныйИдентификатор", УникальныйИдентификатор);
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(Форма);
    Оповещение = Новый ОписаниеОповещения("ПолучениеРезультатаОтправкиНаВалидацию", ЭтотОбъект, ДополнительныеПараметры);
    ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация , Оповещение, ПараметрыОжидания);
КонецПроцедуры

// Обрабатывает результат фоновой проверки отчетных данных (ФЛК).  
//
// Параметры:  
//  Результат – Произвольный. Содержит данные, возвращенные фоновым заданием проверки.  
//  ДополнительныеПараметры – Структура (Необязательный). Содержит служебную информацию, включая уникальный идентификатор формы.  
//
Процедура ПолучениеРезультатаОтправкиНаВалидацию(Результат, ДополнительныеПараметры = Неопределено) Экспорт
	Если Результат = Неопределено Тогда
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("Доступность", Истина);
		ПараметрыОповещения.Вставить("Сообщение", НСтр("ru='Произошла ошибка отправки!'"));
		ПараметрыОповещения.Вставить("УникальныйИдентификатор", ДополнительныеПараметры.УникальныйИдентификатор);
		ПараметрыОповещения.Вставить("УстановитьВидимостьДоступностьРеквизитов", Истина);
		Оповестить("УстановитьДоступностьЭлементовФормыОтчетность1С", ПараметрыОповещения);
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("Доступность", Истина);
		ПараметрыОповещения.Вставить("Сообщение", Отчетность1СКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Не удалось получить результат: %1'"), Результат.КраткоеПредставлениеОшибки));
		ПараметрыОповещения.Вставить("УникальныйИдентификатор", ДополнительныеПараметры.УникальныйИдентификатор);
		ПараметрыОповещения.Вставить("УстановитьВидимостьДоступностьРеквизитов", Истина);
		Оповестить("УстановитьДоступностьЭлементовФормыОтчетность1С", ПараметрыОповещения);
		Возврат;
	КонецЕсли;
	
	СтруктураРезультата = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
  	УдалитьИзВременногоХранилища(Результат.АдресРезультата);
		
	Если ЗначениеЗаполнено(СтруктураРезультата.Сообщение) Тогда
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("Доступность", Истина);
		ПараметрыОповещения.Вставить("Сообщение", СтруктураРезультата.Сообщение);
		ПараметрыОповещения.Вставить("УникальныйИдентификатор", ДополнительныеПараметры.УникальныйИдентификатор);
		ПараметрыОповещения.Вставить("УстановитьВидимостьДоступностьРеквизитов", Истина);
		Оповестить("УстановитьДоступностьЭлементовФормыОтчетность1С", ПараметрыОповещения);
	КонецЕсли;
	
	Если СтруктураРезультата.Возврат Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураРезультатаИзХранилища = СтруктураРезультата.СтруктураРезультатаИзХранилища;
	СтруктураРезультатаИзХранилища.Вставить("ВремяОжидания", 0.2);
	СтруктураРезультатаИзХранилища.Вставить("УникальныйИдентификатор", ДополнительныеПараметры.УникальныйИдентификатор);
	СтруктураРезультатаИзХранилища.Вставить("ИдентификаторПользователя", СтруктураРезультатаИзХранилища.ИдентификаторПользователя);
	СтруктураРезультатаИзХранилища.Вставить("НаименованиеПользователя", СтруктураРезультатаИзХранилища.НаименованиеПользователя);
	АдресПараметровПолученияДанныхВалидации = ПоместитьВоВременноеХранилище(СтруктураРезультатаИзХранилища, ДополнительныеПараметры.УникальныйИдентификатор);
	
	//Пакет успешно отправлен в очередь, получаем статус
	ПараметрыОповещения = Новый Структура;
	ПараметрыОповещения.Вставить("АдресПараметровПолученияДанныхВалидации", АдресПараметровПолученияДанныхВалидации);
	ПараметрыОповещения.Вставить("УникальныйИдентификатор", ДополнительныеПараметры.УникальныйИдентификатор);
	Оповестить("ЖдатьРезультатОтправкиОтчетность1С", ПараметрыОповещения);

КонецПроцедуры

// Ожидает результат проверки данных (ФЛК) от сервера и при необходимости повторно запускает запрос.
//
// Параметры:  
//  Форма – Объект формы, для которой выполняется ожидание результата.
//
Функция ЖдатьРезультатОтправки(Форма) Экспорт
		
	МакВремяОжидания = 120;
	
	СтруктураРезультатаИзХранилища = ПолучитьИзВременногоХранилища(Форма.АдресПараметровПолученияДанныхВалидацииОтчетность1С);
	
	Если СтруктураРезультатаИзХранилища.ВремяОжидания < МакВремяОжидания Тогда
		
		СтруктураРезультатаИзХранилища.ВремяОжидания = СтруктураРезультатаИзХранилища.ВремяОжидания + 
		СтруктураРезультатаИзХранилища.ВремяОжидания * 1.3;
		
		Форма.АдресПараметровПолученияДанныхВалидацииОтчетность1С = ПоместитьВоВременноеХранилище(СтруктураРезультатаИзХранилища, Форма.УникальныйИдентификатор);
		
		// 1. Запуск фонового задания на сервере.
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("ИдентификаторФормы", СтруктураРезультатаИзХранилища.ИдентификаторФормы);
		СтруктураПараметров.Вставить("Организация", СтруктураРезультатаИзХранилища.Организация);
		СтруктураПараметров.Вставить("ИдентификаторПользователя", СтруктураРезультатаИзХранилища.ИдентификаторПользователя);
		СтруктураПараметров.Вставить("НаименованиеПользователя", СтруктураРезультатаИзХранилища.НаименованиеПользователя);
		ДлительнаяОперация  = Отчетность1СВызовСервера.ПолучитьРезультатВалидации(СтруктураПараметров, Форма.УникальныйИдентификатор);
		
		// 2. Подключение обработчика завершения фонового задания.
		ДополнительныеПараметры = Новый Структура("УникальныйИдентификатор", СтруктураРезультатаИзХранилища.УникальныйИдентификатор);
		ДополнительныеПараметры.Вставить("АдресПараметровПолученияДанныхВалидации", Форма.АдресПараметровПолученияДанныхВалидацииОтчетность1С);
		ДополнительныеПараметры.Вставить("ПризнакОтправкаФормы", СтруктураРезультатаИзХранилища.ПризнакОтправкаФормы);
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(Форма);
	    Оповещение = Новый ОписаниеОповещения("ПослеПолученияРезультатаВалидации", ЭтотОбъект, ДополнительныеПараметры);
	    ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация , Оповещение, ПараметрыОжидания);
		
	Иначе
		
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("Доступность", Истина);
		ПараметрыОповещения.Вставить("Сообщение", НСтр("ru='Не удалось получить результат, попробуйте позднее.'"));
		ПараметрыОповещения.Вставить("УникальныйИдентификатор", Форма.УникальныйИдентификатор);
		ПараметрыОповещения.Вставить("УстановитьВидимостьДоступностьРеквизитов", Истина);
		Оповестить("УстановитьДоступностьЭлементовФормыОтчетность1С", ПараметрыОповещения);
				
	КонецЕсли;

КонецФункции

// Обрабатывает результат проверки данных (ФЛК) после получения ответа от сервера.
//
// Параметры:  
//  Результат – Структура, содержащая данные фонового задания или ссылку на временное хранилище с результатом.  
//  ДополнительныеПараметры – Структура с параметрами вызова (УникальныйИдентификатор, ПризнакОтправкаФормы и др.).
//
Процедура ПослеПолученияРезультатаВалидации(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда // Пользователь отменил задание.
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("Доступность", Истина);
		ПараметрыОповещения.Вставить("Сообщение", НСтр("ru='Действие прервано. Не удалось получить результат.'"));
		ПараметрыОповещения.Вставить("УникальныйИдентификатор", ДополнительныеПараметры.УникальныйИдентификатор);
		ПараметрыОповещения.Вставить("УстановитьВидимостьДоступностьРеквизитов", Истина);
		Оповестить("УстановитьДоступностьЭлементовФормыОтчетность1С", ПараметрыОповещения);
		Возврат;
	КонецЕсли;

	Если Результат.Статус = "Ошибка" Тогда
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("Доступность", Истина);
		ПараметрыОповещения.Вставить("Сообщение", Отчетность1СКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Не удалось получить результат: %1'"), Результат.КраткоеПредставлениеОшибки));
		ПараметрыОповещения.Вставить("УникальныйИдентификатор", ДополнительныеПараметры.УникальныйИдентификатор);
		ПараметрыОповещения.Вставить("УстановитьВидимостьДоступностьРеквизитов", Истина);
		Оповестить("УстановитьДоступностьЭлементовФормыОтчетность1С", ПараметрыОповещения);
	    Возврат;
	КонецЕсли;

	СтруктураРезультата = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
  	УдалитьИзВременногоХранилища(Результат.АдресРезультата);
		
	Если СтруктураРезультата.Статус = "Ошибка" Тогда                                           
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("Доступность", Истина);
		ПараметрыОповещения.Вставить("Сообщение", СтруктураРезультата.ПодробноеОписаниеОшибки);
		ПараметрыОповещения.Вставить("УникальныйИдентификатор", ДополнительныеПараметры.УникальныйИдентификатор);
		ПараметрыОповещения.Вставить("УстановитьВидимостьДоступностьРеквизитов", Истина);
		Оповестить("УстановитьДоступностьЭлементовФормыОтчетность1С", ПараметрыОповещения);
		Возврат;
	КонецЕсли;
	
	Если СтруктураРезультата.Статус = "Успех" Тогда		
		ДанныеИзХранилищаПослеВалидации = Новый Структура;
		ДанныеИзХранилищаПослеВалидации.Вставить("ДанныеПослеВалидации", СтруктураРезультата.ДанныеПослеВалидации);
		ДанныеИзХранилищаПослеВалидации.Вставить("ИдентификаторФормы", СтруктураРезультата.ИдентификаторФормы);
	    ДанныеИзХранилищаПослеВалидации.Вставить("УникальныйИдентификатор", ДополнительныеПараметры.УникальныйИдентификатор);
		ДанныеИзХранилищаПослеВалидации.Вставить("ПризнакОтправкаФормы", ДополнительныеПараметры.ПризнакОтправкаФормы);	
		Оповестить("СформироватьДеревоОшибокСоШлюзаОтчетность1С", ДанныеИзХранилищаПослеВалидации);
		
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("Доступность", Истина);
		ПараметрыОповещения.Вставить("УникальныйИдентификатор", ДополнительныеПараметры.УникальныйИдентификатор);
		ПараметрыОповещения.Вставить("УстановитьВидимостьДоступностьРеквизитов", Истина);
		Оповестить("УстановитьДоступностьЭлементовФормыОтчетность1С", ПараметрыОповещения);
	
		Если ДополнительныеПараметры.ПризнакОтправкаФормы Тогда
			Оповестить("ОтправитьИсходящиеОтчетыНаШлюзПослеПроверки", ДополнительныеПараметры);
		КонецЕсли;
	Иначе	
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("АдресПараметровПолученияДанныхВалидации", ДополнительныеПараметры.АдресПараметровПолученияДанныхВалидации);
		ПараметрыОповещения.Вставить("УникальныйИдентификатор", ДополнительныеПараметры.УникальныйИдентификатор);
		Оповестить("ЖдатьРезультатОтправкиОтчетность1С", ПараметрыОповещения);
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область Отправка

// Ожидает результат проверки данных (ФЛК) от сервера и при необходимости повторно запускает запрос.
//
// Параметры:  
//  Форма – Объект формы, для которой выполняется ожидание результата.
//
Функция ПроверитьУсловияОтправки(Форма, ГраницаГодФормирования, ТипДействия) Экспорт
	Если ТипДействия = Отчетность1СКлиентСервер.ТипЗапроса_ОтправитьФорму() И 
		 Форма.СтатусПриемаОтчетность1С = ПредопределенноеЗначение("Перечисление.СтатусыПриемаОтчетность1С.Принят") Тогда
		 
		 ТекстСообщения = НСтр("ru = 'Форма уже была успешно принята сервером. Повторная отправка не требуется.");
			
		Отчетность1СКлиентСервер.СообщитьПользователю(ТекстСообщения);		
		Возврат Ложь;
	КонецЕсли; 	
	
	ГодФормирования = Год(Форма.СтруктураРеквизитовФормы.мДатаНачалаПериодаОтчета);
		
	Если ГраницаГодФормирования < ГодФормирования Тогда 
		ТекстСообщения = Отчетность1СКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Отчет не предназначен для выгрузки в JSON в период формирования %1 г. Пожалуйста, обновите комплект отчетов.'"), Формат(ГодФормирования,"ЧГ=0"));
			
		Отчетность1СКлиентСервер.СообщитьПользователю(ТекстСообщения);		
		Возврат Ложь;
	КонецЕсли;       
	
	Возврат Истина;

КонецФункции

// Выполняет отправку данных отчётности в зависимости от состояния данных.
// Поведение:
//  • Если переданы подготовленные данные (ДанныеJSONДляОтправки), выполняется непосредственная отправка отчёта через шлюз.  
//  • Если данные не переданы, выполняется проверка заполнения формы перед последующей отправкой.
//
// Параметры:
//  Форма – Объект формы или другой источник данных, из которого выполняется отправка.  
//  СтруктураПараметров – Структура с параметрами для формирования и отправки отчёта.  
//  ДанныеJSONДляОтправки (необязательный) – Подготовленные данные в формате JSON.  
//
Процедура ОтправитьИзИсточника(Форма, СтруктураПараметров, ДанныеJSONДляОтправки = "") Экспорт	
	Если ЗначениеЗаполнено(ДанныеJSONДляОтправки) Тогда
		Оповестить("СохранитьОтчетность1С", Форма.УникальныйИдентификатор);
		Если ТипЗнч(Форма) = Тип("УправляемаяФорма") Тогда
			ДополнительныеПараметры = Новый Структура("УникальныйИдентификатор", СтруктураПараметров.УникальныйИдентификатор);
			ОтправитьИсходящиеОтчетыПослеПроверки(СтруктураПараметров, ДополнительныеПараметры, ДанныеJSONДляОтправки)
		КонецЕсли;
	Иначе
		ПроверитьЗаполнение(Истина, Форма);
	КонецЕсли;
КонецПроцедуры

// Отправляет исходящие отчеты после проверки, выполняя подготовку данных и выбор метода подписи.
//
// Параметры:
//  СтруктураПараметров – Структура, содержащая данные исходящего отчета (см. Отчетность1ССервер.СформироватьСтруктуруПараметров_Отправка).
//  ДополнительныеПараметры – Структура, в которую добавляются параметры для отправки и подписи отчета.
//  ДанныеJSONДляОтправки – Строка (необязательный параметр), данные отчета в формате JSON.
//
Процедура ОтправитьИсходящиеОтчетыПослеПроверки(СтруктураПараметров, ДополнительныеПараметры, ДанныеJSONДляОтправки = "") Экспорт
		
	Если НЕ ЗначениеЗаполнено(ДанныеJSONДляОтправки) Тогда
		Возврат;
	КонецЕсли;	
	
	ДополнительныеПараметры.Вставить("ИсходящийОтчетДокумент", СтруктураПараметров.ИсходящийОтчетДокумент);
	ДополнительныеПараметры.Вставить("ИсходящийОтчетДанныеJSON", ДанныеJSONДляОтправки);	
	ДополнительныеПараметры.Вставить("ИдентификаторФормыВСистемеПриема", СтруктураПараметров.ИдентификаторФормыВСистемеПриема); 
	ДополнительныеПараметры.Вставить("ИдентификаторФормы", СтруктураПараметров.ИдентификаторФормы); 
	ДополнительныеПараметры.Вставить("СтатусОбработки", "Не отправлен"); 	
	ДополнительныеПараметры.Вставить("ЭтоОтправкаОтчета", Истина); 	
	ДополнительныеПараметры.Вставить("ИдентификаторПользователя", СтруктураПараметров.ИдентификаторПользователя); 	
	ДополнительныеПараметры.Вставить("НаименованиеПользователя", СтруктураПараметров.НаименованиеПользователя);
	ДополнительныеПараметры.Вставить("Организация", СтруктураПараметров.Налогоплательщик);	
	ДополнительныеПараметры.Вставить("ИмяФормыФЛК", СтруктураПараметров.ИмяФормыФЛК);
	ДополнительныеПараметры.Вставить("СоответствиеСинонимов", СтруктураПараметров.СоответствиеСинонимов);
	ДополнительныеПараметры.Вставить("ТипФормы", СтруктураПараметров.ТипФормы);
	
	// Выбор метода подписи: Kalkan или NCALayer
	Если Отчетность1СВызовСервера.ИспользоватьВнешнююКриптографиюДляКомпоненты() И Отчетность1СВызовСервера.ВыполнятьКриптографическиеОперацииНаКлиенте() Тогда	
		// Если используется Kalkan	
		Оповещение = Новый ОписаниеОповещения("ПодписатьИОтправитьОтчетПослеУказанияДанныхКлюча", ЭтотОбъект, ДополнительныеПараметры);
		ОткрытьФормуВводаДанных(Оповещение, ДополнительныеПараметры);	
	Иначе
		// Если используется NCALayer
		ПодписатьИОтправитьОтчетПослеУказанияДанныхКлюча(, ДополнительныеПараметры);	
	КонецЕсли;
	
КонецПроцедуры

// Подписывает отчет и отправляет его после выбора данных ключа (через Kalkan или NCALayer).
// Выполняет криптографическую операцию, отправку на сервер и обработку результата.
//
// Параметры:
//  Результат – Структура, данные выбранного сертификата (для Kalkan), может быть Неопределено.
//  ДополнительныеПараметры – Структура, содержащая сведения об отчете, пользователе и параметрах отправки.
//
Асинх Процедура ПодписатьИОтправитьОтчетПослеУказанияДанныхКлюча(Результат, ДополнительныеПараметры) Экспорт	
		
	МассивДокументовДляПодписи = Новый Массив;
	МассивДокументовДляПодписи.Добавить(ДополнительныеПараметры.ИсходящийОтчетДанныеJSON);
	
	// Тип провайдера определяет подпись документов
	Если НЕ Отчетность1СВызовСервера.ИспользоватьВнешнююКриптографиюДляКомпоненты() Тогда	
		ПодписанныеДанные = Ждать ПодписатьМассивДокументовНаКлиенте(МассивДокументовДляПодписи,ДополнительныеПараметры.ИдентификаторПользователя);	
	ИначеЕсли Отчетность1СВызовСервера.ИспользоватьВнешнююКриптографиюДляКомпоненты() И ТипЗнч(Результат) = Тип("Структура") Тогда			
		ПодписанныеДанные = Ждать ПодписатьМассивДокументовНаКлиенте(МассивДокументовДляПодписи,ДополнительныеПараметры.ИдентификаторПользователя,Результат);			
	Иначе
		ТекстСообщения = НСтр("ru = 'Выбор сертификата отменен пользователем.'");
		
		// Возможно пользователь отменил операцию. Возврат ошибки от сокета
		Отчетность1СКлиентСервер.СообщитьПользователю(ТекстСообщения);	
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ПодписанныеДанные) ИЛИ ПодписанныеДанные.Количество() < 1 Тогда
		// пользователь мог отменить операцию
		Возврат;
	КонецЕсли;	      
	
	ДополнительныеПараметры.Вставить("ДанныеДляОтправки", ПодписанныеДанные[0]);
	ДополнительныеПараметры.Вставить("ТипЗапроса", Отчетность1СКлиентСервер.ТипЗапроса_ОтправитьФорму());
	
	ОтправитьТранспортныйЗапрос(ДополнительныеПараметры,ДополнительныеПараметры.УникальныйИдентификатор);
			
КонецПроцедуры

// Подписывает массив документов на клиенте с использованием криптопровайдера (Kalkan или NCALayer).
// Возвращает массив подписанных данных в формате JSON.
//
// Параметры:
//  ДанныеДляПодписи – Массив, содержащий данные документов, подлежащих подписи.
//  ИдентификаторПользователя – Уникальный идентификатор пользователя, от имени которого выполняется подпись.
//  ПараметрыКлюча – (Необязательный) Структура с параметрами ключа для подписи (используется при внешней криптографии).
//
// Возвращаемое значение:
//  Массив (JSON) – Подписанные данные, либо пустая строка в случае ошибки.
Асинх Функция ПодписатьМассивДокументовНаКлиенте(ДанныеДляПодписи, ИдентификаторПользователя, ПараметрыКлюча=Неопределено)
	
	ДанныеJSON = ДанныеДляПодписи;
	ПараметрыВзаимодействия = Отчетность1СКлиентСервер.ПолучитьПараметрыВзаимодействияКриптопровайдера(ИдентификаторПользователя, ДанныеJSON, ПараметрыКлюча);
	ОтветСервиса = Ждать КриптографияКлиентАсинх.СоздатьЭЦП_XML(ДанныеJSON, ПараметрыВзаимодействия);		
		
	Если ОтветСервиса = Неопределено ИЛИ ОтветСервиса.ЭтоОшибка Тогда
		ТекстСообщения = ?(ОтветСервиса = Неопределено, НСтр("ru='Не удалось выполнить подпись.'"), ОтветСервиса.ТекстОшибки);
		Отчетность1СКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат "";
	КонецЕсли;
	
	РезультатПодписиJSON = ОтветСервиса.ПодписанныеДанные;
	
	Возврат РезультатПодписиJSON;
КонецФункции

// см. Отчетность1СВызовСервера.ОтправитьТранспортныйЗапросОтчетность1С()
Процедура ОтправитьТранспортныйЗапрос(ДополнительныеПараметры, УникальныйИдентификатор)
	// 1. Запуск фонового задания на сервере.
	ДлительнаяОперация  = Отчетность1СВызовСервера.ОтправитьТранспортныйЗапрос(ДополнительныеПараметры, УникальныйИдентификатор);
	
	// 2. Подключение обработчика завершения фонового задания.
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(Неопределено);
    Оповещение = Новый ОписаниеОповещения("ПолучениеРезультатаОтправкиТранспортногоЗапроса", ЭтотОбъект, ДополнительныеПараметры);
    ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация , Оповещение, ПараметрыОжидания);
	
КонецПроцедуры

// Обрабатывает результат фоновой отправки транспортного запроса.  
//
// Параметры:  
//  Результат – Произвольный. Содержит данные, возвращенные фоновым заданием проверки.  
//  ДополнительныеПараметры – Структура (Необязательный). Содержит служебную информацию, включая уникальный идентификатор формы.  
//
Процедура ПолучениеРезультатаОтправкиТранспортногоЗапроса(Результат, ДополнительныеПараметры = Неопределено) Экспорт
	Если Результат = Неопределено Тогда
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("Доступность", Истина);
		ПараметрыОповещения.Вставить("Сообщение", НСтр("ru='Произошла ошибка отправки!'"));
		ПараметрыОповещения.Вставить("УникальныйИдентификатор", ДополнительныеПараметры.УникальныйИдентификатор);
		ПараметрыОповещения.Вставить("УстановитьВидимостьДоступностьРеквизитов", Истина);
		Оповестить("УстановитьДоступностьЭлементовФормыОтчетность1С", ПараметрыОповещения);
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("Доступность", Истина);
		ПараметрыОповещения.Вставить("Сообщение", Отчетность1СКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru='Не удалось получить результат: %1'"), Результат.КраткоеПредставлениеОшибки));
		ПараметрыОповещения.Вставить("УникальныйИдентификатор", ДополнительныеПараметры.УникальныйИдентификатор);
		ПараметрыОповещения.Вставить("УстановитьВидимостьДоступностьРеквизитов", Истина);
		Оповестить("УстановитьДоступностьЭлементовФормыОтчетность1С", ПараметрыОповещения);
		Возврат;
	КонецЕсли;
	
	Если ДополнительныеПараметры.Свойство("НетДоступа") И ДополнительныеПараметры.НетДоступа Тогда
		ДополнительныеПараметры.Вставить("Возврат", Истина);
		Возврат;
	КонецЕсли;
	
	Если ДополнительныеПараметры.ТипЗапроса = Отчетность1СКлиентСервер.ТипЗапроса_ОтправитьФорму() Тогда
		УникальныйИдентификатор = ДополнительныеПараметры.УникальныйИдентификатор;
			
		Оповестить("ЗаписьРегламентированногоОтчетаОтчетность1С", ДополнительныеПараметры);
		  
		Если ДополнительныеПараметры.Свойство("ЕстьОшибка") И ДополнительныеПараметры.ЕстьОшибка Тогда
			Отчетность1СКлиентСервер.СообщитьПользователю(ДополнительныеПараметры.ТекстОшибки);	
			Возврат;
		КонецЕсли;
		
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("Доступность", Ложь);
		ПараметрыОповещения.Вставить("УникальныйИдентификатор", УникальныйИдентификатор);
		ПараметрыОповещения.Вставить("УстановитьВидимостьДоступностьРеквизитов", Истина);
		ПараметрыОповещения.Вставить("ТекстФормыВыполненияДлительныхОпераций", Отчетность1СКлиентСервер.ТекстСообщения_ОтправкаФормы());
		Оповестить("УстановитьДоступностьЭлементовФормыОтчетность1С", ПараметрыОповещения);
                                                                                      
		АдресПараметровПолученияДанныхВалидации = ПоместитьВоВременноеХранилище(Новый Структура("ВремяОжидания", 1), УникальныйИдентификатор);
		
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("АдресПараметровПолученияДанныхВалидации", АдресПараметровПолученияДанныхВалидации);
		ПараметрыОповещения.Вставить("УникальныйИдентификатор", УникальныйИдентификатор);
		
		Оповестить("ОбновитьСтатусОтчетность1С", ПараметрыОповещения);
			
	ИначеЕсли ДополнительныеПараметры.ТипЗапроса = Отчетность1СКлиентСервер.ТипЗапроса_ОбновитьСтатус() Тогда		     	
		Если ДополнительныеПараметры.Свойство("ПолученоУведомление") И ДополнительныеПараметры.ПолученоУведомление Тогда
			Оповестить("ЗаписьРегламентированногоОтчетаОтчетность1С", ДополнительныеПараметры);
			ДополнительныеПараметры.Вставить("Возврат", Истина);
		КонецЕсли;
		
		Если ДополнительныеПараметры.Свойство("ЕстьОшибка") И ДополнительныеПараметры.ЕстьОшибка Тогда
			Оповестить("ЗаписьРегламентированногоОтчетаОтчетность1С", ДополнительныеПараметры);
			ДополнительныеПараметры.Вставить("Сообщение", ДополнительныеПараметры.ТекстОшибки);
			ДополнительныеПараметры.Вставить("Возврат", Истина);
		КонецЕсли;	
	КонецЕсли;	

КонецПроцедуры

#КонецОбласти

#Область ОбновитьСтатус

// Выполняет обновление статуса отправленных отчетов и при необходимости инициирует повторную отправку.
//
// Параметры:
//  Источник – Объект формы, из которого выполняется обновление статуса.  
//  СтруктураПараметров – Структура с параметрами для обновления статуса отправленных отчетов.  
//  ТипОбновленияСтатуса (необязательный) – Уточняет тип выполняемого обновления (может быть Неопределено).
//
Процедура ОбновитьСтатус(СтруктураПараметров, ТипОбновленияСтатуса=Неопределено) Экспорт	
	СтруктураВозвращаемая = ОбновитьСтатусОтправленныхОтчетов(СтруктураПараметров, ТипОбновленияСтатуса);
			
	Если СтруктураВозвращаемая.Возврат Тогда			
		
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("Доступность", Истина);
		ПараметрыОповещения.Вставить("УникальныйИдентификатор", СтруктураПараметров.УникальныйИдентификатор);
		ПараметрыОповещения.Вставить("УстановитьВидимостьДоступностьРеквизитов", Истина);
		
		Если СтруктураВозвращаемая.Свойство("Сообщение") И ЗначениеЗаполнено(СтруктураВозвращаемая.Сообщение) Тогда
			ПараметрыОповещения.Вставить("Сообщение", СтруктураВозвращаемая.Сообщение);	
		КонецЕсли;
		
		Оповестить("УстановитьДоступностьЭлементовФормыОтчетность1С", ПараметрыОповещения);	
	Иначе
		Отчетность1СКлиентСервер.СообщитьПользователю(НСтр("ru='Сообщение еще не обработано. Попробуйте обновить его статус позднее, через 30-60 секунд.'"));
	КонецЕсли;
	
КонецПроцедуры

// Ожидает результат обновления статуса отправленной формы отчета от сервера и при необходимости повторно запускает запрос.
//
// Параметры:  
//  Форма – Объект формы, для которой выполняется ожидание результата.
//  СтруктураПараметров – Структура с параметрами для обновления статуса отправленных отчетов.  
//  ТипОбновленияСтатуса (необязательный) – Уточняет тип выполняемого обновления (может быть Неопределено).
//
Функция ЖдатьРезультатОбновленияСтатуса(Форма, СтруктураПараметров, ТипОбновленияСтатуса=Неопределено) Экспорт
	МакВремяОжидания = 120;
	
	СтруктураРезультатаИзХранилища = ПолучитьИзВременногоХранилища(Форма.АдресПараметровПолученияДанныхВалидацииОтчетность1С);	
	
	Если СтруктураРезультатаИзХранилища.ВремяОжидания < МакВремяОжидания Тогда
		
		СтруктураРезультатаИзХранилища.ВремяОжидания = СтруктураРезультатаИзХранилища.ВремяОжидания + 
		СтруктураРезультатаИзХранилища.ВремяОжидания * 1.3;
		
		Форма.АдресПараметровПолученияДанныхВалидацииОтчетность1С = ПоместитьВоВременноеХранилище(СтруктураРезультатаИзХранилища, Форма.УникальныйИдентификатор);
	
		ПослеПолученияРезультатаОбновленияСтатуса(,Форма, СтруктураПараметров, ТипОбновленияСтатуса);
					
	Иначе
		
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("Доступность", Истина);
		ПараметрыОповещения.Вставить("Сообщение", НСтр("ru='Не удалось получить результат, попробуйте позднее.'"));
		ПараметрыОповещения.Вставить("УникальныйИдентификатор", Форма.УникальныйИдентификатор);
		ПараметрыОповещения.Вставить("УстановитьВидимостьДоступностьРеквизитов", Истина);
		Оповестить("УстановитьДоступностьЭлементовФормыОтчетность1С", ПараметрыОповещения);	
			
	КонецЕсли;

КонецФункции

// Обрабатывает результат обновления статуса исходящего отчета после запроса.
//
// Параметры:
//  ДополнительныеПараметры (Структура, Необязательный) – вспомогательные данные, могут быть переопределены внутри процедуры.
//  Источник – объект формы, из которой вызвано обновление.
//  СтруктураПараметров – структура с параметрами отчета (включая УникальныйИдентификатор).
//  ТипОбновленияСтатуса (Необязательный) – тип выполняемого обновления.
//
Процедура ПослеПолученияРезультатаОбновленияСтатуса(ДополнительныеПараметры = Неопределено, Источник, СтруктураПараметров, ТипОбновленияСтатуса=Неопределено) Экспорт	
	СтруктураВозвращаемая = ОбновитьСтатусОтправленныхОтчетов(СтруктураПараметров, ТипОбновленияСтатуса);
	           
	Если СтруктураВозвращаемая.Возврат Тогда
		
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("Доступность", Истина);
		ПараметрыОповещения.Вставить("УникальныйИдентификатор", СтруктураПараметров.УникальныйИдентификатор);
		ПараметрыОповещения.Вставить("УстановитьВидимостьДоступностьРеквизитов", Истина);
					
		Если СтруктураВозвращаемая.Свойство("Сообщение") И ЗначениеЗаполнено(СтруктураВозвращаемая.Сообщение) Тогда
			ПараметрыОповещения.Вставить("Сообщение", СтруктураВозвращаемая.Сообщение);	
		КонецЕсли;
		
		Оповестить("УстановитьДоступностьЭлементовФормыОтчетность1С", ПараметрыОповещения);
	Иначе
		ПараметрыОповещения = Новый Структура;
		ПараметрыОповещения.Вставить("АдресПараметровПолученияДанныхВалидации", Источник.АдресПараметровПолученияДанныхВалидацииОтчетность1С);
		ПараметрыОповещения.Вставить("УникальныйИдентификатор", СтруктураПараметров.УникальныйИдентификатор);
		Оповестить("ОбновитьСтатусОтчетность1С", ПараметрыОповещения);
	КонецЕсли;
			      
КонецПроцедуры

// Обновляет статус отправленных отчетов и формирует параметры для проверки уведомлений.
//
// Параметры:
//  СтруктураПараметров – Структура, содержащая данные отправленного отчета (см. Отчетность1ССервер.СформироватьСтруктуруПараметров_Отправка)
//  ДополнительныеПараметры – Структура, в которую добавляются параметры для запроса статуса.
//  ТипОбновленияСтатуса – Произвольное значение, определяющее тип обновления (необязательный параметр).
//
// Возвращаемое значение:
//  Результат – Значение, возвращаемое функцией ОбновитьСтатусОтправкиОтчета(), если номер сообщения шлюза заполнен.
//  Неопределено – Если номер сообщения шлюза не указан.
Функция ОбновитьСтатусОтправленныхОтчетов(СтруктураПараметров, ТипОбновленияСтатуса=Неопределено) Экспорт
	ДополнительныеПараметры = Новый Структура("УникальныйИдентификатор", СтруктураПараметров.УникальныйИдентификатор);
	
	ИдентификаторФормы = СтруктураПараметров.ИдентификаторФормы;
	
	// Запрос для получения статуса и уведомления отправленного отчета
	ДополнительныеПараметры.Вставить("ИсходящийОтчетДокумент", СтруктураПараметров.ИсходящийОтчетДокумент);
	ДополнительныеПараметры.Вставить("ИдентификаторФормыВСистемеПриема", СтруктураПараметров.ИдентификаторФормыВСистемеПриема);
	ДополнительныеПараметры.Вставить("ИдентификаторФормы", ИдентификаторФормы);
	ДополнительныеПараметры.Вставить("СоответствиеСинонимов", СтруктураПараметров.СоответствиеСинонимов);
	ДополнительныеПараметры.Вставить("ИдентификаторПользователя", СтруктураПараметров.ИдентификаторПользователя); 	
	ДополнительныеПараметры.Вставить("НаименованиеПользователя", СтруктураПараметров.НаименованиеПользователя);
	ДополнительныеПараметры.Вставить("Организация", СтруктураПараметров.Налогоплательщик);
	ДополнительныеПараметры.Вставить("ТипЗапроса", Отчетность1СКлиентСервер.ТипЗапроса_ОбновитьСтатус());
	ДополнительныеПараметры.Вставить("ТипФормы", СтруктураПараметров.ТипФормы);
	
	СтруктураВозвращаемая = Новый Структура;
	СтруктураВозвращаемая.Вставить("Возврат", Ложь);
	СтруктураВозвращаемая.Вставить("Сообщение", "");
			
	Если НЕ ЗначениеЗаполнено(ИдентификаторФормы) Тогда
		СтруктураВозвращаемая.Вставить("Возврат", Истина);
		СтруктураВозвращаемая.Вставить("Сообщение", НСтр("ru='Не заполнен идентификатор формы'"));
		Возврат СтруктураВозвращаемая;
	КонецЕсли;
	
	ОтправитьТранспортныйЗапрос(ДополнительныеПараметры,СтруктураПараметров.УникальныйИдентификатор);
			
	СтруктураВозвращаемая.Вставить("Возврат", ДополнительныеПараметры.Возврат);
	Если ДополнительныеПараметры.Свойство("ЕстьОшибка") И ДополнительныеПараметры.ЕстьОшибка Тогда
		СтруктураВозвращаемая.Вставить("Сообщение", ДополнительныеПараметры.ТекстОшибки);
	КонецЕсли;		
	
	Возврат СтруктураВозвращаемая;	
КонецФункции

// Формирует и выводит уведомление по исходящему отчету в виде табличного документа.
//
// Параметры:
//  Источник – форма, из которой выполняется вызов (управляемая форма).
//  Уведомление – данные уведомления, полученные с сервера.
//
Процедура ПоказатьУведомление(Источник, Уведомление) Экспорт
	ТабДок = Отчетность1СВызовСервера.СформироватьУведомление(Уведомление);
	
	//Создаём новую коллекцию печатных форм
	КоллекцияПечатныхФорм = Отчетность1СКлиентПереопределяемый.НоваяКоллекцияПечатныхФорм("ПФ_MXL_УведомлениеПоФНООтчетность1С");
	
	//Добавляем в коллекцию сформированный табличный документ
	КоллекцияПечатныхФорм[0].ТабличныйДокумент = ТабДок;
	
	//Устанавливаем параметры печати (при необходимости)
	КоллекцияПечатныхФорм[0].Экземпляров = 1;
	КоллекцияПечатныхФорм[0].СинонимМакета = Источник.НомерУведомленияОтчетность1С;  //Так будет выглядеть имя файла при сохранении в файл из формы "Печать документов"
	
	//Вывод через стандартную процедуру БСП
 	Отчетность1СКлиентПереопределяемый.ПечатьДокументов(КоллекцияПечатныхФорм, Неопределено, Источник);
КонецПроцедуры

#КонецОбласти

#Область УправлениеИнтерфейсомФормы

// Обрабатывает оповещения, связанные с процессами формы.
// В зависимости от имени события выполняет соответствующие действия
Процедура ОбработкаОповещения(Форма, ИмяСобытия, Параметр, Источник) Экспорт
	Если (ИмяСобытия = "УстановитьДоступностьЭлементовФормыОтчетность1С") И (Параметр.Свойство("УникальныйИдентификатор") И Параметр.УникальныйИдентификатор = Форма.УникальныйИдентификатор) Тогда
		ТекстФормыВыполненияДлительныхОпераций = ?(Параметр.Свойство("ТекстФормыВыполненияДлительныхОпераций"),
												   Параметр.ТекстФормыВыполненияДлительныхОпераций,
												   Неопределено);			                                                   
		УстановитьДоступностьЭлементовФормы(Форма, Параметр.Доступность, ТекстФормыВыполненияДлительныхОпераций);
		Если Параметр.Свойство("Сообщение") Тогда
			Отчетность1СКлиентСервер.СообщитьПользователю(Параметр.Сообщение);
		КонецЕсли;
		Если Параметр.Свойство("УстановитьВидимостьДоступностьРеквизитов") Тогда
			Форма.ОбработатьОповещениеОтчетность1СНаКлиенте(Новый Структура("УстановитьВидимостьДоступностьРеквизитов", Параметр.УстановитьВидимостьДоступностьРеквизитов));
		КонецЕсли;
	КонецЕсли;
	
	Если (ИмяСобытия = "ЖдатьРезультатОтправкиОтчетность1С") И (Параметр.Свойство("УникальныйИдентификатор") И Параметр.УникальныйИдентификатор = Форма.УникальныйИдентификатор) Тогда
		Форма.АдресПараметровПолученияДанныхВалидацииОтчетность1С = Параметр.АдресПараметровПолученияДанныхВалидации;
		Форма.ПодключитьОбработчикОжидания("ЖдатьРезультатОтправкиОтчетность1С", 1, Истина);
	КонецЕсли;
	
	Если (ИмяСобытия = "СформироватьДеревоОшибокСоШлюзаОтчетность1С") И (Параметр.Свойство("УникальныйИдентификатор") И Параметр.УникальныйИдентификатор = Форма.УникальныйИдентификатор) Тогда
		Форма.ОбработатьОповещениеОтчетность1СНаКлиенте(Новый Структура("СформироватьДеревоОшибокСоШлюза", Параметр));	
	КонецЕсли;
	
	Если (ИмяСобытия = "ОтправитьИсходящиеОтчетыНаШлюзПослеПроверки") И (Параметр.Свойство("УникальныйИдентификатор") И Параметр.УникальныйИдентификатор = Форма.УникальныйИдентификатор) Тогда
		ЕстьОшибкиСУчетомКритичности = Форма.ТаблицаОшибокОтчетность1С.НайтиСтроки(Новый Структура("Критичность", Истина)).Количество();
		Если ЕстьОшибкиСУчетомКритичности Тогда
			ТекстСообщения = НСтр("ru = 'Для отправки формы необходимо заполнить обязательные поля и устранить критичные ошибки.'");
			Отчетность1СКлиентСервер.СообщитьПользователю(ТекстСообщения);
			ПоказатьПредупреждение(,ТекстСообщения,100, НСтр("ru='Форма не может быть отправлена'"));
			Возврат;
		КонецЕсли;
		Форма.ОбработатьОповещениеОтчетность1СНаКлиенте(Новый Структура("Отправить", Истина));			
	КонецЕсли;
	
	Если ИмяСобытия = "ЗаписьРегламентированногоОтчетаОтчетность1С" И (Параметр.Свойство("УникальныйИдентификатор") И Параметр.УникальныйИдентификатор = Форма.УникальныйИдентификатор) Тогда
		
		СтруктураОповещений = Новый Структура;
		
		Если Параметр.Свойство("ИдентификаторФормыВСистемеПриема") Тогда 
			Форма.ИдентификаторФормыВСистемеПриемаОтчетность1С = Параметр.ИдентификаторФормыВСистемеПриема;
		КонецЕсли;
		Если Параметр.Свойство("ИдентификаторФормы") Тогда 
			Форма.ИдентификаторФормыОтчетность1С = Параметр.ИдентификаторФормы;
		КонецЕсли;
		Если Параметр.Свойство("ИдентификаторПользователя") Тогда 
			Форма.ИдентификаторПользователяОтчетность1С = Параметр.ИдентификаторПользователя;;
		КонецЕсли;
		Если Параметр.Свойство("ЕстьОшибкиФЛК") Тогда 
			ОбновитьДеревоОшибок = Параметр.Свойство("ЕстьОшибкиФЛК") И Параметр.ЕстьОшибкиФЛК;
			
			СтруктураОповещений.Вставить("ЗаполнитьТаблицуФЛКОтчета", Параметр);	
			СтруктураОповещений.Вставить("ОбновитьДеревоОшибок", ОбновитьДеревоОшибок);
		КонецЕсли;
		Если Параметр.Свойство("Уведомление") Тогда 
			Форма.УведомлениеОтчетность1С = Параметр.Уведомление;
		КонецЕсли;
		Если Параметр.Свойство("СтатусПриема") Тогда 
			Форма.СтатусПриемаОтчетность1С = Параметр.СтатусПриема;
		КонецЕсли;
			
		Модифицированность = Истина;
		
		СтруктураОповещений.Вставить("ОбновитьСтатусПриема", Истина);
		СтруктураОповещений.Вставить("УстановитьВидимостьДоступностьРеквизитов", Истина);
		СтруктураОповещений.Вставить("Сохранить", Истина);
		
		Форма.ОбработатьОповещениеОтчетность1СНаКлиенте(СтруктураОповещений);
	КонецЕсли;
	
	Если ИмяСобытия = "ОбновитьСтатусОтчетность1С" И (Параметр.Свойство("УникальныйИдентификатор") И Параметр.УникальныйИдентификатор = Форма.УникальныйИдентификатор) Тогда
		Если Форма.Элементы.Найти("ФормаОбновитьСтатусОтчетность1С") <> Неопределено Тогда
			Если ЗначениеЗаполнено(Форма.ИдентификаторФормыОтчетность1С) Тогда	
				Форма.АдресПараметровПолученияДанныхВалидацииОтчетность1С = Параметр.АдресПараметровПолученияДанныхВалидации;
				Форма.ПодключитьОбработчикОжидания("ЖдатьРезультатОбновленияСтатусаОтчетность1С", 5, Истина);						
			КонецЕсли;
		КонецЕсли;	
	КонецЕсли;
	
	Если ИмяСобытия = "СохранитьОтчетность1С" И Параметр = Форма.УникальныйИдентификатор Тогда
		Форма.ОбработатьОповещениеОтчетность1СНаКлиенте(Новый Структура("Сохранить", Истина));	
	КонецЕсли;
	
КонецПроцедуры

// Управляет доступностью элементов формы и отображением окна ожидания.
//
// Параметры:
//  Форма – Управляемая форма, в которой нужно изменить доступность элементов.
//  Доступность – Булево. Истина – элементы формы доступны, Ложь – заблокированы.
//  ТекстСообщения – Строка (необязательный). Пользовательское сообщение, отображаемое при блокировке.
//
Процедура УстановитьДоступностьЭлементовФормы(Форма, Доступность, ТекстСообщения = Неопределено) Экспорт

	Для Каждого ТекЭлемент Из Форма.Элементы Цикл
		Если ТипЗнч(ТекЭлемент) <> Тип("ДекорацияФормы") Тогда
			ТекЭлемент.Доступность = Доступность;
		КонецЕсли;
	КонецЦикла;
	Если Доступность Тогда
		ДополнительныеПараметры = Неопределено;
		Оповестить("ЗавершениеОперацииWSSocket", ДополнительныеПараметры, Форма);
	Иначе
		ПараметрыДлительнойОперации = Новый Структура;
		ПараметрыДлительнойОперации.Вставить("ТекстСообщения", ?(ТекстСообщения=Неопределено, НСтр("ru='Пожалуйста, подождите.'"), ТекстСообщения));

		ОткрытьФорму("ОбщаяФорма.ДлительнаяОперацияОтчетность1С",ПараметрыДлительнойОперации,ЭтотОбъект,,,,,РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	КонецЕсли;

КонецПроцедуры

// Выполняет обработчики элементов формы
//
// Параметры:
//  ИмяКоманды – Строка
//     Имя команды выполняемого обработчика.
//  Форма – УправляемаяФорма  
//     Форма, из которой вызвана процедура.
//  СтандартнаяОбработка – Булево
//     Определяет поведение стандартной обработки.
//  Элементы – ЭлементыФормы
//     Содержит элементы управляемой формы, включая дерево ошибок.
Процедура ОбработчикЭлементовФормыОтчетность1С(ИмяКоманды, Форма, СтандартнаяОбработка, Элементы) Экспорт
	Если ИмяКоманды = "НомерУведомленияОтчетность1С" Тогда
		НомерУведомленияОтчетность1СНажатие(Форма, СтандартнаяОбработка);
	ИначеЕсли ИмяКоманды = "ДатаУведомленияОтчетность1С" Тогда
		ДатаУведомленияОтчетность1СНажатие(Форма, СтандартнаяОбработка);
	ИначеЕсли ИмяКоманды = "ИдентификаторФормыОтчетность1С" Тогда
		ИдентификаторФормыОтчетность1СНажатие(Форма, СтандартнаяОбработка);
	ИначеЕсли ИмяКоманды = "ИдентификаторФормыВСистемеПриемаОтчетность1С" Тогда
		ИдентификаторФормыВСистемеПриемаОтчетность1СНажатие(Форма, СтандартнаяОбработка);
	ИначеЕсли ИмяКоманды = "ДатаУведомленияОтчетность1С" Тогда
		ДатаУведомленияОтчетность1СНажатие(Форма, СтандартнаяОбработка);
	ИначеЕсли ИмяКоманды = "ДеревоОшибокОтчетность1С" Тогда
		ДеревоОшибокОтчетность1СПриАктивизацииСтроки(Форма, Элементы);
	ИначеЕсли ИмяКоманды = "ДеревоОшибокСвернутьВсеСтрокиОтчетность1С" Тогда
		СвернутьВсеСтрокиВДеревеОшибок(Элементы, Форма.ДеревоОшибокОтчетность1С);
	ИначеЕсли ИмяКоманды = "ДеревоОшибокРазвернутьВсеСтрокиОтчетность1С" Тогда
		РазвернутьВсеСтрокиВДеревеОшибок(Элементы, Форма.ДеревоОшибокОтчетность1С);	
	КонецЕсли;
КонецПроцедуры

// Свертывает все строки (узлы) дерева ошибок формы отчетности.
//
// Параметры:
//  Элементы – ЭлементыФормы
//     Содержит элементы управляемой формы, включая дерево ошибок.
//  Дерево – ДанныеФормыДерево
//     Дерево данных, в котором требуется свернуть все строки.
//
Процедура СвернутьВсеСтрокиВДеревеОшибок(Элементы, Дерево) Экспорт
	ЭлементыДерева = Дерево.ПолучитьЭлементы();
    Для каждого ЭлементДерева Из ЭлементыДерева Цикл
		Если ЭлементДерева.ПолучитьЭлементы().Количество() > 0 Тогда
			СвернутьВсеСтрокиВДеревеОшибок(Элементы, ЭлементДерева);
			Элементы.ДеревоОшибокОтчетность1С.Свернуть(ЭлементДерева.ПолучитьИдентификатор());
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

// Разворачивает все строки (узлы) дерева ошибок формы отчетности.
//
// Параметры:
//  Элементы – ЭлементыФормы  
//     Содержит элементы управляемой формы, включая дерево ошибок.  
//  Дерево – ДанныеФормыДерево  
//     Дерево данных, в котором требуется развернуть все строки.  
//
Процедура РазвернутьВсеСтрокиВДеревеОшибок(Элементы, Дерево) Экспорт
	ЭлементыДерева = Дерево.ПолучитьЭлементы();
    Для Каждого ЭлементДерева Из ЭлементыДерева Цикл
		Если ЭлементДерева.ПолучитьЭлементы().Количество() > 0 Тогда
			РазвернутьВсеСтрокиВДеревеОшибок(Элементы, ЭлементДерева);
			Элементы.ДеревоОшибокОтчетность1С.Развернуть(ЭлементДерева.ПолучитьИдентификатор());
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

// Обрабатывает нажатие на элемент формы "Номер уведомления" в форме отчетности 1С.
//
// Параметры:
//  Форма – УправляемаяФорма  
//     Форма, из которой вызвана процедура.
//
Процедура НомерУведомленияОтчетность1СНажатие(Форма, СтандартнаяОбработка) Экспорт
	СтандартнаяОбработка = Ложь;
	Если ЗначениеЗаполнено(Форма.УведомлениеОтчетность1С) Тогда
		ПоказатьУведомление(Форма, Форма.УведомлениеОтчетность1С);
	Иначе
		ТекстСообщения = НСтр("ru = 'Уведомление отсутствует.'");			
		Отчетность1СКлиентСервер.СообщитьПользователю(ТекстСообщения);		
	КонецЕсли;
КонецПроцедуры

// Обрабатывает нажатие на элемент формы "Дата уведомления" в форме отчетности 1С.
//
// Параметры:
//  Форма – УправляемаяФорма  
//     Форма, из которой вызвана процедура.
//
Процедура ДатаУведомленияОтчетность1СНажатие(Форма, СтандартнаяОбработка) Экспорт
	СтандартнаяОбработка = Ложь;
	ТекстСообщения = Отчетность1СКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Дата уведомления: %1.'"), СокрЛП(Форма.ДатаУведомленияОтчетность1С));			
	Отчетность1СКлиентСервер.СообщитьПользователю(ТекстСообщения);
КонецПроцедуры

// Отображает пользователю идентификатор отправленной формы отчетности 1С.
//
// Параметры:
//  Форма – УправляемаяФорма  
//     Форма, из которой вызвана процедура.
//
Процедура ИдентификаторФормыОтчетность1СНажатие(Форма, СтандартнаяОбработка) Экспорт
	СтандартнаяОбработка = Ложь;
	ТекстСообщения = Отчетность1СКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Идентификатор отправленной формы: %1.'"), СокрЛП(Форма.ИдентификаторФормыОтчетность1С));			
	Отчетность1СКлиентСервер.СообщитьПользователю(ТекстСообщения);
КонецПроцедуры

// Отображает пользователю внешний идентификатор отправленной формы отчетности 1С.
//
// Параметры:
//  Форма – УправляемаяФорма  
//     Форма, из которой вызывается процедура.
//
Процедура ИдентификаторФормыВСистемеПриемаОтчетность1СНажатие(Форма, СтандартнаяОбработка) Экспорт
	СтандартнаяОбработка = Ложь;
	ТекстСообщения = Отчетность1СКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Внешний идентификатор формы: %1.'"), СокрЛП(Форма.ИдентификаторФормыВСистемеПриемаОтчетность1С));			
	Отчетность1СКлиентСервер.СообщитьПользователю(ТекстСообщения);
КонецПроцедуры

// Обрабатывает активацию строки в дереве ошибок формы отчетности 1С.
//
// Параметры:
//  Форма – УправляемаяФорма  
//     Форма, содержащая дерево ошибок.
//  Элементы – КоллекцияЭлементовФормы  
//     Набор элементов формы, включая дерево ошибок и области для отображения деталей.
//
Процедура ДеревоОшибокОтчетность1СПриАктивизацииСтроки(Форма, Элементы) Экспорт
	ТД = Элементы.ДеревоОшибокОтчетность1С.ТекущиеДанные;
	Если ТД  = Неопределено Тогда
		// если нет ошибок
		Возврат;
	КонецЕсли;	
	Форма.РезультатПроверкиТекущийОтчетность1С = ТД.Ошибка;
	
	Результат = Окр(СтрДлина(Форма.РезультатПроверкиТекущийОтчетность1С) / Элементы.ГруппаПодсказкаПодробноОтчетность1С.ПодчиненныеЭлементы.РезультатПроверкиТекущийОтчетность1С.Ширина); 
	Элементы.ГруппаПодсказкаПодробноОтчетность1С.ПодчиненныеЭлементы.РезультатПроверкиТекущийОтчетность1С.МаксимальнаяВысота = ?(Результат > 0, Результат, 1);
	Элементы.ГруппаПодсказкаПодробноОтчетность1С.ПодчиненныеЭлементы.РезультатПроверкиТекущийОтчетность1С.Высота = 
	                                                 Элементы.ГруппаПодсказкаПодробноОтчетность1С.ПодчиненныеЭлементы.РезультатПроверкиТекущийОтчетность1С.МаксимальнаяВысота;
	Элементы.ГруппаПодсказкаПодробноКритичноОтчетность1С.Видимость = ТД.Критичность;
	Элементы.ГруппаПодсказкаПодробноНеКритичноОтчетность1С.Видимость = НЕ ТД.Критичность;
КонецПроцедуры

// Очищает оформление ошибок во всех полях табличных документов формы отчетности 1С.
//
// Параметры:
//  Форма – УправляемаяФорма  
//     Форма, содержащая таблицу ошибок и элементы табличных документов, 
//     в которых требуется удалить визуальное оформление ошибок.
//
Процедура ОчиститьОформлениеВсехПолейИзТаблицыОшибок(Форма) Экспорт
	Для Каждого Строка Из Форма.ТаблицаОшибокОтчетность1С Цикл
		Реквизит = Строка.Реквизит;
		КодФормы = Строка.КодФормы;
		Страница = Строка.Страница;
		Если ЗначениеЗаполнено(Реквизит) Тогда
			Попытка
				Область = Форма[КодФормы + "ПолеТабличногоДокумента" + Страница].Область(Реквизит);
				СнятьОформлениеОшибки(Область);
			Исключение	
			КонецПопытки;
		КонецЕсли;
	КонецЦикла;
КонецПроцедуры

// Снимает визуальное оформление ошибки с указанной области табличного документа.
//
// Параметры:
//  Область – ОбластьТабличногоДокумента  
//     Область табличного документа, с которой требуется убрать оформление ошибки.
//
Процедура СнятьОформлениеОшибки(Область) Экспорт
	// если ячейка была выделена как ошибочная, то сбрасываем выделение
	Область.Узор = Неопределено;
	Область.ЦветУзора = Новый Цвет();
КонецПроцедуры

#КонецОбласти

#Область Криптобиблиотека

// см. Отчетность1СКлиентПереопределяемый.ОткрытьФормуВводаДанных()
Процедура ОткрытьФормуВводаДанных(ОбработчикОповещения = Неопределено, ПараметрыФормы = Неопределено) Экспорт
	
	Отчетность1СКлиентПереопределяемый.ОткрытьФормуВводаДанных(ОбработчикОповещения, ПараметрыФормы);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#КонецОбласти