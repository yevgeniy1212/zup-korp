Функция МассивСтруктурЗнаниеЯзыковИзТекста(Знач ТекстДляРаспознаванияИсходный, Знач ФорматРезюме = Неопределено)
	
	ТекущийБлок = НазваниеТекущегоБлокаПоФорматуРезюме("ЗнаниеЯзыков", ФорматРезюме);
	
	ПозНач = СтрНайти(ТекстДляРаспознаванияИсходный, ТекущийБлок);
	
	Если ПозНач > 0 Тогда
		ПозКон = СтрНайти(ТекстДляРаспознаванияИсходный, Символы.ПС,, ПозНач);
		
		Если ПозКон = 0 Тогда // Если в строке нет переноса строки, то берем весь оставшийся текст после текущего блока.
			ТекстДляРаспознавания = СокрЛП(Сред(ТекстДляРаспознаванияИсходный, ПозНач + СтрДлина(ТекущийБлок)));
		Иначе
			ТекстДляРаспознавания = Сред(ТекстДляРаспознаванияИсходный, ПозКон + 1);
		КонецЕсли;
	Иначе
		ТекстДляРаспознавания = "";
	КонецЕсли;
	
	КоличествоСтрок = СтрЧислоСтрок(ТекстДляРаспознавания);
	ЗнаниеЯзыковМассив = Новый Массив;
	
	Для Ид = 1 По КоличествоСтрок Цикл
		
		ТекущаяСтрока = СтрПолучитьСтроку(ТекстДляРаспознавания, Ид);
		ТекущаяСтрока = СокрЛП(ТекущаяСтрока);
		
		Если СледующийБлокРезюме(ТекущаяСтрока, ТекущийБлок, ФорматРезюме) Тогда
			Прервать;
		КонецЕсли;
		
		Если ТекущаяСтрока = "" Тогда
			Продолжить;
		КонецЕсли;
		
		ТекущаяСтрока = СтрЗаменить(ТекущаяСтрока,"—", "-");
		
		Если ФорматРезюме <> ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ИсточникиИнформацииОКандидатах.SuperJob")
			И СтрНайти(ТекущаяСтрока, "-") = 0 Тогда
				Продолжить;
		Иначе
			ТекущаяСтрока = СтрЗаменить(ТекущаяСтрока,":", "-");
		КонецЕсли;
		
		Если СтрЗаканчиваетсяНа(ТекущаяСтрока, "-") Тогда
			Ид = Ид + 1;
			Если Ид <= КоличествоСтрок Тогда 
				ТекущаяСтрока = ТекущаяСтрока + СтрПолучитьСтроку(ТекстДляРаспознавания, Ид)
			Иначе
				Продолжить;
			КонецЕсли;
		КонецЕсли;
		
		ЧастиЗнанияЯзыков = СтрРазделить(ТекущаяСтрока, "-");
		СтруктураСтрокиЗнаниеЯзыков = СтруктураСтрокиЗнаниеЯзыков();
		Если ЧастиЗнанияЯзыков.Количество() > 1 Тогда
			СтруктураСтрокиЗнаниеЯзыков.Язык = Справочники.ЯзыкиНародовМира.НайтиПоНаименованию(СокрЛП(ЧастиЗнанияЯзыков[0]));
			СтруктураСтрокиЗнаниеЯзыков.СтепеньЗнанияЯзыкаКандидата = СтепеньЗнанияЯзыка(ЧастиЗнанияЯзыков[1]);
			СтруктураСтрокиЗнаниеЯзыков.Содержание = ТекущаяСтрока;
			ЗнаниеЯзыковМассив.Добавить(СтруктураСтрокиЗнаниеЯзыков);
		Иначе
			Продолжить;
		КонецЕсли;
		
	КонецЦикла;
	
	ДозаполнитьМассивСтруктурЗнаниеЯзыков(ЗнаниеЯзыковМассив);
	
	Возврат ЗнаниеЯзыковМассив;
	
КонецФункции

Процедура ДозаполнитьМассивСтруктурЗнаниеЯзыков(МассивЯзыков)
	
	Для Каждого Язык Из МассивЯзыков Цикл
		
		Позиция = СтрНайти(Язык.Язык, "язык");
		Если Позиция <> 0 Тогда
			Язык.Язык = Сред(Язык.Язык, 1, Позиция - 2);
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Язык.СтепеньЗнанияЯзыкаКандидата) Тогда
			Язык.СтепеньЗнанияЯзыкаКандидата = Справочники.СтепениЗнанияЯзыкаКандидата.СтепеньЗнанияЯзыкаПоУровнюВладения(
				Перечисления.УровниВладенияЯзыком.A1);
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция НазваниеТекущегоБлокаПоФорматуРезюме(Знач ТипБлока, Знач ВидРезюме)
	
	НазваниеТекущегоБлока = "";
	
	Если ВидРезюме = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ИсточникиИнформацииОКандидатах.HeadHunter") Тогда
		Если ТипБлока = "ЗнаниеЯзыков" Тогда
			НазваниеТекущегоБлока = "Знание языков";
		КонецЕсли;
	ИначеЕсли ВидРезюме = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ИсточникиИнформацииОКандидатах.SuperJob") Тогда
		Если ТипБлока = "ЗнаниеЯзыков" Тогда
			НазваниеТекущегоБлока = "Иностранные языки";
		КонецЕсли; 
	Иначе
	
	КонецЕсли;
	
	Возврат НазваниеТекущегоБлока;
	
КонецФункции

Функция СтепеньЗнанияЯзыка(Знач СтепеньЗнанияСтрока)
	
	Результат = Неопределено;
	СтепеньЗнанияСтрока = СокрЛП(СтепеньЗнанияСтрока);
	СтепеньЗнанияСтрока = НРег(СтепеньЗнанияСтрока);
	
	Если СтрНайти("a1а1", СтепеньЗнанияСтрока) Тогда
		Результат = Справочники.СтепениЗнанияЯзыкаКандидата.СтепеньЗнанияЯзыкаПоУровнюВладения(
			Перечисления.УровниВладенияЯзыком.A1);
		Возврат Результат;
	КонецЕсли;
	
	Если СтрНайти("a2а2", СтепеньЗнанияСтрока) Тогда
		Результат = Справочники.СтепениЗнанияЯзыкаКандидата.СтепеньЗнанияЯзыкаПоУровнюВладения(
			Перечисления.УровниВладенияЯзыком.A2);
		Возврат Результат;
	КонецЕсли;
	
	Если СтрНайти("b1", СтепеньЗнанияСтрока) Тогда
		Результат = Справочники.СтепениЗнанияЯзыкаКандидата.СтепеньЗнанияЯзыкаПоУровнюВладения(
			Перечисления.УровниВладенияЯзыком.B1);
		Возврат Результат;
	КонецЕсли;
	
	Если СтрНайти("b2", СтепеньЗнанияСтрока) Тогда
		Результат = Справочники.СтепениЗнанияЯзыкаКандидата.СтепеньЗнанияЯзыкаПоУровнюВладения(
			Перечисления.УровниВладенияЯзыком.B2);
		Возврат Результат;
	КонецЕсли;
	
	Если СтрНайти("c1с1", СтепеньЗнанияСтрока) Тогда
		Результат = Справочники.СтепениЗнанияЯзыкаКандидата.СтепеньЗнанияЯзыкаПоУровнюВладения(
			Перечисления.УровниВладенияЯзыком.C1);
		Возврат Результат;
	КонецЕсли;
	
	Если СтрНайти("c2с2родной", СтепеньЗнанияСтрока) Тогда
		Результат = Справочники.СтепениЗнанияЯзыкаКандидата.СтепеньЗнанияЯзыкаПоУровнюВладения(
			Перечисления.УровниВладенияЯзыком.C2);
		Возврат Результат;
	КонецЕсли;
	
	СтрокаДляПоиска = "базовыйбазовыйбазовые знаниячитаю профессиональную литературутехнический";
	
	Если СтрНайти(СтрокаДляПоиска, СтепеньЗнанияСтрока) Тогда
		Результат = Справочники.СтепениЗнанияЯзыкаКандидата.СтепеньЗнанияЯзыкаПоУровнюВладения(
			Перечисления.УровниВладенияЯзыком.A2);
		Возврат Результат;
	КонецЕсли;
	
	СтрокаДляПоиска = "intermediateсреднийразговорныймогу проходить интервью";
	
	Если СтрНайти(СтрокаДляПоиска, СтепеньЗнанияСтрока) Тогда
		Результат = Справочники.СтепениЗнанияЯзыкаКандидата.СтепеньЗнанияЯзыкаПоУровнюВладения(
			Перечисления.УровниВладенияЯзыком.B2);
		Возврат Результат;
	КонецЕсли;
	
	СтрокаДляПоиска = "fluencyсвободно владею"; //АПК:216,1297
	
