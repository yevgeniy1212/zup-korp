
#Область СлужебныйПрограммныйИнтерфейс

// См. ПодключаемыеКомандыПереопределяемый.ПриОпределенииВидовПодключаемыхКоманд
Процедура ПриОпределенииВидовПодключаемыхКоманд(ВидыПодключаемыхКоманд) Экспорт
	
	Вид = ВидыПодключаемыхКоманд.Добавить();
	Вид.Имя = "СоздатьКандидата";
	Вид.ИмяПодменю = "СоздатьКандидата";
	Вид.Заголовок = НСтр("ru = 'Создать кандидата'");
	Вид.Порядок = 50;
	Вид.Картинка = Новый Картинка;
	Вид.Отображение = ОтображениеКнопки.Текст;
	
КонецПроцедуры

// См. ПодключаемыеКомандыПереопределяемый.ПриОпределенииКомандПодключенныхКОбъекту
Процедура ПриОпределенииКомандПодключенныхКОбъекту(НастройкиФормы, Источники, ПодключенныеОтчетыИОбработки, Команды) Экспорт
	
	Если Источники.Строки.Найти(Метаданные.ЖурналыДокументов.Взаимодействия, "Метаданные") <> Неопределено Тогда
		Команда = Команды.Добавить();
		Команда.Вид = "СоздатьКандидата";
		Команда.Представление = НСтр("ru = 'Создать кандидата'"); //КоманднаяПанельВариантаНавигации
		Команда.ВидимостьВФормах = "ФормаСписка";
		Команда.Обработчик = "РазборРезюмеКлиент.СоздатьКандидатаПоВложениюПодключаемый";
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьСписокВложений(Вложения, Расширения, Результат) Экспорт
	
	Для Каждого Вложение Из Вложения Цикл
		Если Расширения.Найти(Вложение.Расширение) <> Неопределено Тогда
			СтрокаСписка = Результат.Добавить();
			СтрокаСписка.Значение = Вложение.Ссылка;
			СтрокаСписка.Представление = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = '%1.%2'"),
				Вложение.Наименование, Вложение.Расширение);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция РезультатРазбораРезюме(ФайлыРезюме, ДанныеФайловWord, СпособРазбораРезюме) Экспорт
	
	СтруктураОтвета = СтруктурыОтвета();
	ДанныеКандидатов = СтруктураОтвета.ДанныеКандидатов;
	ТекстыРезюме = Новый Массив;
	
	ПолучитьРезюмеИзФайлов(ДанныеКандидатов, ФайлыРезюме, ТекстыРезюме);
	ПолучитьРезюмеИзДанныхФайловWord(ДанныеКандидатов, ДанныеФайловWord, ТекстыРезюме);
	
	Если СпособРазбораРезюме <> РазборРезюмеКлиентСервер.СпособыРазбораРезюме().ВнешнийСервис Тогда
		ЗаполнитьДанныеКандидатов(ДанныеКандидатов);
		Возврат СтруктураОтвета;
	КонецЕсли;
	
	РезультатЗапроса = РазборРезюмеСемантическийАнализ.ЗапросКСервису(ТекстыРезюме);
	Если РезультатЗапроса.Данные <> Неопределено Тогда
		РазборРезюмеСемантическийАнализ.ПрочитатьРезультатЗапроса(РезультатЗапроса.Данные, ДанныеКандидатов);
		Возврат СтруктураОтвета;
	КонецЕсли;
	
	СтруктураОтвета.СтруктураОшибки.ОшибкаСервиса = РезультатЗапроса.ОшибкаСервиса;
	СтруктураОтвета.СтруктураОшибки.ОписаниеОшибки = РезультатЗапроса.ОписаниеОшибки;
	ЗаполнитьДанныеКандидатов(ДанныеКандидатов);
	
	Возврат СтруктураОтвета;
	
КонецФункции

Функция СписокСоответствийСемейноеПоложение() Экспорт
	
	СоответствиеКлассификаторов = Новый Соответствие();
	
	СоответствиеКлассификаторов.Вставить("холост", Справочники.СостояниеВБраке.НайтиПоКоду(1));
	СоответствиеКлассификаторов.Вставить("не замужем", Справочники.СостояниеВБраке.НайтиПоКоду(1));
	СоответствиеКлассификаторов.Вставить("женат", Справочники.СостояниеВБраке.НайтиПоКоду(2));
	СоответствиеКлассификаторов.Вставить("замужем", Справочники.СостояниеВБраке.НайтиПоКоду(2));
	СоответствиеКлассификаторов.Вставить("разведен", Справочники.СостояниеВБраке.НайтиПоКоду(5));
	СоответствиеКлассификаторов.Вставить("разведена", Справочники.СостояниеВБраке.НайтиПоКоду(5));
	
	Возврат СоответствиеКлассификаторов;
	
КонецФункции

Функция СтрокаКакЧисло(Знач ИсходнаяСтрока) Экспорт
	
	ИсходнаяСтрока = СокрЛП(ИсходнаяСтрока);
	Результат = 0;
	ЗнаковПослеЗапятой = -1;
	ЗнакОтрицательный = Ложь;
	Длина = СтрДлина(ИсходнаяСтрока);
	Для НомерСимвола = 1 По Длина Цикл
		КодСимвола = КодСимвола(ИсходнаяСтрока, НомерСимвола);
		Если КодСимвола = 32 Или КодСимвола = 160 Тогда // Пробел или неразрывный пробел.
			// Пропуск (действие не требуется).
		ИначеЕсли КодСимвола = 45 Или КодСимвола = 40 Тогда // Минус или открывающая скобка.
			Если Результат <> 0 Тогда
				Возврат Неопределено;
			КонецЕсли;
			ЗнакОтрицательный = Истина;
		ИначеЕсли КодСимвола = 41 Тогда // Закрывающая скобка.
			Если Не ЗнакОтрицательный Или Результат = 0 Тогда // Не было открывающей скобки или нет числа.
				Возврат Неопределено;
			КонецЕсли;
			// Пропуск (действие не требуется).
		ИначеЕсли КодСимвола = 44 Или КодСимвола = 46 Тогда // Запятая или точка.
			Если ЗнаковПослеЗапятой <> -1 Тогда
				Возврат Неопределено; // Разделитель уже был, следовательно это не число.
			КонецЕсли;
			ЗнаковПослеЗапятой = 0; // Запуск отсчета знаков после запятой.
		ИначеЕсли КодСимвола > 47 И КодСимвола < 58 Тогда // Число.
			Если ЗнаковПослеЗапятой <> -1 Тогда
				ЗнаковПослеЗапятой = ЗнаковПослеЗапятой + 1;
			КонецЕсли;
			Число = КодСимвола - 48;
			Результат = Результат * 10 + Число;
		КонецЕсли;
	КонецЦикла;
	
	Если ЗнаковПослеЗапятой > 0 Тогда
		Результат = Результат / Pow(10, ЗнаковПослеЗапятой);
	КонецЕсли;
	Если ЗнакОтрицательный Тогда
		Результат = -Результат;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область РаботаСФайламиРезюме

Процедура ПолучитьРезюмеИзФайлов(ДанныеКандидатов, ФайлыРезюме, ТекстыРезюме)
	
	Если ФайлыРезюме = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ВременныйКаталог = ФайловаяСистема.СоздатьВременныйКаталог();
	
	Для Каждого ФайлРезюме Из ФайлыРезюме Цикл
		СтруктураРезюме = ПодборПерсоналаКлиентСервер.ОписаниеРезюмеКандидата();
		РасширениеФайла = ОбщегоНазначенияКлиентСервер.ПолучитьРасширениеИмениФайла(ФайлРезюме.ИмяФайла);
		ИмяВременногоФайла = СтрШаблон("%1.%2", Новый УникальныйИдентификатор, РасширениеФайла);
		ВременныйФайл = СоздатьВременныйФайл(ВременныйКаталог, ИмяВременногоФайла, ФайлРезюме.ДвоичныеДанные);
		
		Если РазборРезюмеКлиентСервер.ЭтоФорматTXT(РасширениеФайла) Тогда 
			ТекстРезюме = ТекстИзФайлаTXT(ВременныйФайл, ВременныйКаталог);
		ИначеЕсли РазборРезюмеКлиентСервер.ЭтоФорматPDF(РасширениеФайла) Тогда
			ТекстРезюме = ТекстИзФайлаPDF(ВременныйФайл, ВременныйКаталог);
			СтруктураРезюме.Фото = ФотоИзФайлаPDF(ВременныйФайл, ВременныйКаталог);
		КонецЕсли;
		ТекстРезюме = РазборРезюмеКлиентСервер.ТекстПослеНормализации(ТекстРезюме);
		
		СтруктураРезюме.ТекстРезюме = ТекстРезюме;
		СтруктураРезюме.ФайлРезюме.ИмяФайла = ФайлРезюме.ИмяФайла;
		СтруктураРезюме.ФайлРезюме.ПолноеИмя = ФайлРезюме.ПолноеИмя;
		СтруктураРезюме.ФайлРезюме.Хранение = ФайлРезюме.Хранение;
		СтруктураРезюме.ИсточникИнформации = РазборРезюмеКлиентСервер.ИсточникИнформацииПоТексту(ТекстРезюме);
		
		ТекстыРезюме.Добавить(ТекстРезюме);
		ДанныеКандидатов.Добавить(СтруктураРезюме);
	КонецЦикла;
	
	ФайловаяСистема.УдалитьВременныйКаталог(ВременныйКаталог);
	
КонецПроцедуры

Процедура ПолучитьРезюмеИзДанныхФайловWord(ДанныеКандидатов, ДанныеФайловWord, ТекстыРезюме)
	
	Если ДанныеФайловWord = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ДанныеФайлаWord Из ДанныеФайловWord Цикл
		СтруктураРезюме = ПодборПерсоналаКлиентСервер.ОписаниеРезюмеКандидата();
		СтруктураРезюме.ТекстРезюме = ДанныеФайлаWord.ТекстРезюме;
		СтруктураРезюме.ФайлРезюме.ИмяФайла = ДанныеФайлаWord.Файл.ИмяФайла;
		СтруктураРезюме.ФайлРезюме.ПолноеИмя = ДанныеФайлаWord.Файл.ПолноеИмя;
		СтруктураРезюме.ФайлРезюме.Хранение = ДанныеФайлаWord.Файл.Хранение;
		СтруктураРезюме.Фото = ДанныеФайлаWord.Фотография;
		СтруктураРезюме.ИсточникИнформации = ДанныеФайлаWord.ИсточникИнформации;
		ТекстыРезюме.Добавить(ДанныеФайлаWord.ТекстРезюме);
		ДанныеКандидатов.Добавить(СтруктураРезюме);
	КонецЦикла;
	
КонецПроцедуры

Процедура ВыполнитьКомандуMuPDF(Команда, ИмяФайлаPDF, ВременныйКаталог, ИмяФайлаTXT = "")
	
	ПолныйПуть = ОбщегоНазначенияКлиентСервер.ДобавитьКонечныйРазделительПути(
		ПодборПерсонала.УстановленныеНастройки().ПутьККаталогуMuPDF);
	
	Если ЗначениеЗаполнено(ИмяФайлаTXT) Тогда
		ИмяСоздаваемогоФайла = ИмяФайлаTXT;
	Иначе
		ИмяСоздаваемогоФайла = "";
	КонецЕсли;
	
	СтрокаКоманды = СтрШаблон("""%1mutool.exe"" %2 %3 ""%4""", СокрЛП(ПолныйПуть), Команда, ИмяСоздаваемогоФайла, ИмяФайлаPDF);
	
	Попытка
		ПараметрыЗапускаПрограммы = ФайловаяСистема.ПараметрыЗапускаПрограммы();
		ПараметрыЗапускаПрограммы.ТекущийКаталог = ВременныйКаталог;
		ПараметрыЗапускаПрограммы.ДождатьсяЗавершения = Истина;
		Результат = ФайловаяСистема.ЗапуститьПрограмму(СтрокаКоманды, ПараметрыЗапускаПрограммы);
	Исключение
		ФайловаяСистема.УдалитьВременныйКаталог(ВременныйКаталог);
		ТекстИсключения = СтрШаблон(НСтр("ru = 'Ошибка при запуске MuPDF:
			|%1
			|(%2)'"),
			СтрокаКоманды,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗаписьЖурналаРегистрации(НСтр("ru = 'Запуск MuPDF'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,,,
			ТекстИсключения);
		ВызватьИсключение ТекстИсключения;
	КонецПопытки;
	
	Если Результат.КодВозврата <> 0 Тогда
		ФайловаяСистема.УдалитьВременныйКаталог(ВременныйКаталог);
		ТекстИсключения = СтрШаблон(НСтр("ru = 'Ошибка %1 при работе MuPDF:
			|%2
			|Возможно, нарушена структура командной строки.'"),
			Результат.КодВозврата,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗаписьЖурналаРегистрации(НСтр("ru = 'Запуск MuPDF'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,,,
			ТекстИсключения);
		ВызватьИсключение ТекстИсключения;
	КонецЕсли;
	
КонецПроцедуры

Функция СоздатьВременныйФайл(ВременныйКаталог, ИмяФайла, ДвоичныеДанные = Неопределено)
	
	ВременныйФайл = ФайловаяСистема.УникальноеИмяФайла(СтрШаблон("%1%2", ВременныйКаталог, ИмяФайла));
	
	Попытка
		Если ДвоичныеДанные = Неопределено Тогда
			ТекстовыйДокумент = Новый ТекстовыйДокумент;
			ТекстовыйДокумент.Записать(ВременныйФайл, КодировкаТекста.UTF8);
		Иначе
			ДвоичныеДанные.Записать(ВременныйФайл);
		КонецЕсли;
		Возврат ВременныйФайл;
	Исключение
		ТекстИсключения = СтрШаблон(НСтр("ru = 'Не удалось записать %1 на сервере
			|по причине: %2'", ОбщегоНазначения.КодОсновногоЯзыка()),
			ИмяФайла, ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗаписьЖурналаРегистрации(НСтр("ru = 'Разбор резюме.Запись файла на сервере'",
			ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,,,
			ТекстИсключения);
		ВызватьИсключение ТекстИсключения;
	КонецПопытки;
	
КонецФункции

Функция ТекстИзФайлаTXT(ВременныйФайлTXT, ВременныйКаталог)
	
	ИзвлеченныйТекст = "";
	
	Извлечение = Новый ИзвлечениеТекста(ВременныйФайлTXT);
	Попытка
		ИзвлеченныйТекст = Извлечение.ПолучитьТекст();
	Исключение
		ФайловаяСистема.УдалитьВременныйКаталог(ВременныйКаталог);
		ТекстИсключения = СтрШаблон(НСтр("ru = 'Не удалось извлечь текст резюме из файла TXT
			|по причине: %1'", ОбщегоНазначения.КодОсновногоЯзыка()),
			ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗаписьЖурналаРегистрации(НСтр("ru = 'Разбор резюме.Извлечение текста'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,,,
			ТекстИсключения);
		ВызватьИсключение ТекстИсключения;	
	КонецПопытки;
	
	Возврат ИзвлеченныйТекст;
	
КонецФункции

Функция ТекстИзФайлаPDF(ВременныйФайлPDF, ВременныйКаталог)
	
	ИмяВременногоФайлаTXT = СтрШаблон("%1.txt", Новый УникальныйИдентификатор);
	ВременныйФайлTXT = СоздатьВременныйФайл(ВременныйКаталог, ИмяВременногоФайлаTXT);
	ВыполнитьКомандуMuPDF("convert -o", ВременныйФайлPDF, ВременныйКаталог, ВременныйФайлTXT);
	
	ИзвлеченныйТекст = "";
	ТекстовыйФайл = Новый ТекстовыйДокумент;
	Попытка
		ТекстовыйФайл.Прочитать(ВременныйФайлTXT,
			КодировкаТекста.UTF8,
			Символы.ВК + Символы.ПС);
		ИзвлеченныйТекст = ТекстовыйФайл.ПолучитьТекст();
	Исключение
		ФайловаяСистема.УдалитьВременныйКаталог(ВременныйКаталог);
		ТекстИсключения = СтрШаблон(НСтр("ru = 'Не удалось извлечь текст резюме из файла PDF
			|по причине: %1'", ОбщегоНазначения.КодОсновногоЯзыка()),
			ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗаписьЖурналаРегистрации(НСтр("ru = 'Разбор резюме.Извлечение текста'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,,,
			ТекстИсключения);
		ВызватьИсключение ТекстИсключения;
	КонецПопытки;
	
	Возврат ИзвлеченныйТекст;
	
КонецФункции

Функция ФотоИзФайлаPDF(ВременныйФайлPDF, ВременныйКаталог)
	
	ВыполнитьКомандуMuPDF("extract", ВременныйФайлPDF, ВременныйКаталог);
	
	РазмерФотографии = 0;
	Фотография = Неопределено;
	МассивФайлов = НайтиФайлы(ВременныйКаталог, "im*");
	Для Каждого Файл Из МассивФайлов Цикл
		
		Картинка = Новый Картинка(Файл.ПолноеИмя);
		Если Картинка.РазмерФайла() > РазмерФотографии Тогда
			РазмерФотографии = Картинка.РазмерФайла();
			Фотография = Картинка;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Фотография;
	
КонецФункции

#КонецОбласти

#Область ПоискДанныхРезюме

Функция ПравилоПоискаПоКлючу(КлючПоиска,
							 ЯвляетсяЗначением,
							 КоличествоСимволовПодЗначение,
							 УчитыватьРегистр,
							 ЭтоСписок = Ложь,
							 КлючОкончанияПоиска = Неопределено)
	
	ПравилоПоиска = Новый Структура();
	
	ПравилоПоиска.Вставить("КлючПоиска", КлючПоиска);
	ПравилоПоиска.Вставить("ЯвляетсяЗначением", ЯвляетсяЗначением);
	ПравилоПоиска.Вставить("КоличествоСимволовПодЗначение", КоличествоСимволовПодЗначение);
	ПравилоПоиска.Вставить("УчитыватьРегистр", УчитыватьРегистр);
	ПравилоПоиска.Вставить("ЭтоСписок", ЭтоСписок);
	
	Если КлючОкончанияПоиска <> Неопределено Тогда
		ПравилоПоиска.Вставить("КлючОкончанияПоиска", КлючОкончанияПоиска);
	КонецЕсли;
	
	Возврат ПравилоПоиска;
	
КонецФункции

Функция ЗначениеИзТекстаПоКлючевомуСлову(Знач ТекстДляРаспознавания, Знач ПравилоПоиска)
	
	ЗначениеИзТекста = "";
	КлючПоиска = ПравилоПоиска.КлючПоиска;
	КоличествоСимволовПодЗначение = ПравилоПоиска.КоличествоСимволовПодЗначение;
	
	ЯвляетсяЗначением = Ложь;
	Если Не ПравилоПоиска.Свойство("ЯвляетсяЗначением", ЯвляетсяЗначением) Тогда
		ЯвляетсяЗначением = Ложь;
	КонецЕсли;
	
	УчитыватьРегистр = Ложь;
	Если Не ПравилоПоиска.Свойство("УчитыватьРегистр", УчитыватьРегистр) Тогда
		УчитыватьРегистр = Ложь;
	КонецЕсли;
	
	Если УчитыватьРегистр Тогда
		ПозицияНачала = СтрНайти(ТекстДляРаспознавания, КлючПоиска);
	Иначе
		ПозицияНачала = СтрНайти(НРег(ТекстДляРаспознавания), НРег(КлючПоиска));
	КонецЕсли;
	
	ПозицияОкончанияПоиска = Неопределено;
	Если ПравилоПоиска.Свойство("КлючОкончанияПоиска") Тогда
		КлючОкончанияПоиска = ПравилоПоиска.КлючОкончанияПоиска;
		ПозицияОкончанияПоиска = СтрНайти(ТекстДляРаспознавания, КлючОкончанияПоиска);
	КонецЕсли;
	
	Если ПозицияНачала > 0 Тогда
		
		Если ПравилоПоиска.ЭтоСписок Тогда
			Если ПравилоПоиска.ЯвляетсяЗначением = Истина Тогда
				Пока ПозицияНачала > 0 Цикл
					ПозицияКонца = СтрНайти(ТекстДляРаспознавания, Символы.ПС,, ПозицияНачала);
					Если ПозицияКонца = 0 Тогда // Если в строке нет переноса строки, то берем весь оставшийся текст после текущего блока.
						ЗначениеИзТекста = СокрЛП(Сред(ТекстДляРаспознавания, ПозицияНачала + СтрДлина(КлючПоиска)));
						Прервать;
					ИначеЕсли СтрДлина(КлючПоиска) <> (ПозицияКонца-ПозицияНачала) Тогда
						ПозицияНачала = СтрНайти(ТекстДляРаспознавания, КлючПоиска,,ПозицияКонца);
					Иначе
						ЗначениеИзТекста = Сред(ТекстДляРаспознавания, ПозицияКонца + 1);
						Прервать;
					КонецЕсли;
				КонецЦикла;
			Иначе
				ПозицияКонца = СтрНайти(ТекстДляРаспознавания, Символы.ПС,, ПозицияНачала);
				Если ПозицияОкончанияПоиска <> Неопределено И ПозицияОкончанияПоиска <> 0 Тогда
					ЗначениеИзТекста = Сред(ТекстДляРаспознавания, ПозицияКонца + 1, ПозицияОкончанияПоиска - ПозицияКонца - 1);
				Иначе
					ЗначениеИзТекста = Сред(ТекстДляРаспознавания, ПозицияКонца + 1);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		Если ЯвляетсяЗначением Тогда
			ЗначениеИзТекста = КлючПоиска;
		КонецЕсли;
		
		Если КоличествоСимволовПодЗначение > 0 Тогда
			ЗначениеИзТекста = ЗначениеИзТекста + Сред(ТекстДляРаспознавания, ПозицияНачала + СтрДлина(КлючПоиска), КоличествоСимволовПодЗначение);
		ИначеЕсли КоличествоСимволовПодЗначение < 0 Тогда
			ПозицияНачала = ?((ПозицияНачала + КоличествоСимволовПодЗначение) > 0, ПозицияНачала + КоличествоСимволовПодЗначение, 1);
			ЗначениеИзТекста = Сред(ТекстДляРаспознавания, ПозицияНачала, - КоличествоСимволовПодЗначение) + ЗначениеИзТекста;
		КонецЕсли;
		
		Если Не ЯвляетсяЗначением Тогда
			ЗначениеИзТекста = СтрЗаменить(ЗначениеИзТекста, КлючПоиска, "");
		КонецЕсли;
		
		ЗначениеИзТекста = СтрЗаменить(ЗначениеИзТекста, ":", "");
		ЗначениеИзТекста = СтрЗаменить(ЗначениеИзТекста, ";", "");
		
		ЗначениеИзТекста = СокрЛП(ЗначениеИзТекста);
		КлючПоискаПС = Символы.ПС;
		НаправлениеПоискаЗначение = ?(КоличествоСимволовПодЗначение > 0, НаправлениеПоиска.СНачала, НаправлениеПоиска.СКонца);
		ПозНачПС = СтрНайти(ЗначениеИзТекста, КлючПоискаПС, НаправлениеПоискаЗначение);
		
		Если ПозНачПС > 0 Тогда
			Если КоличествоСимволовПодЗначение > 0 Тогда
				ЗначениеИзТекста = Лев(ЗначениеИзТекста, ПозНачПС);
			ИначеЕсли КоличествоСимволовПодЗначение < 0 Тогда
				ЗначениеИзТекста = Сред(ЗначениеИзТекста, ПозНачПС);
			КонецЕсли;
			
			ЗначениеИзТекста = СокрЛП(ЗначениеИзТекста);
		КонецЕсли;
	КонецЕсли;
	
	Возврат ЗначениеИзТекста;
	
КонецФункции

#КонецОбласти

Процедура ЗаполнитьДанныеКандидатов(ДанныеКандидатов)
	
	Для Каждого ДанныеКандидата Из ДанныеКандидатов Цикл
		ЗаполнитьДанныеКандидата(ДанныеКандидата);
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьДанныеКандидата(ДанныеКандидата)
	
	СтруктураДанныхРезюме = СтруктураДанныхРезюмеОбщая(ДанныеКандидата.ТекстРезюме);
	
	ДанныеКандидатаПоВерсииHH = СтруктураДанныхРезюмеHH(ДанныеКандидата.ТекстРезюме);
	ДозаполнитьСтруктураДанныхРезюме(СтруктураДанныхРезюме, ДанныеКандидатаПоВерсииHH);
	
	ДанныеКандидатаПоВерсииSJ = СтруктураДанныхРезюмеSJ(ДанныеКандидата.ТекстРезюме);
	ДозаполнитьСтруктураДанныхРезюме(СтруктураДанныхРезюме, ДанныеКандидатаПоВерсииSJ);
	
	Для Каждого КлючИЗначение Из СтруктураДанныхРезюме Цикл
		Если Не ЗначениеЗаполнено(КлючИЗначение.Значение) Или Не ДанныеКандидата.Свойство(КлючИЗначение.Ключ) Тогда
			Продолжить;
		КонецЕсли;
		Если ТипЗнч(КлючИЗначение.Значение) = Тип("Массив") Тогда
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(
				ДанныеКандидата[КлючИЗначение.Ключ], КлючИЗначение.Значение);
		Иначе
			ДанныеКандидата[КлючИЗначение.Ключ] = КлючИЗначение.Значение;
		КонецЕсли;
	КонецЦикла;
	
	ЗначениеСвойства = Неопределено;
	
	Если СтруктураДанныхРезюме.Свойство("Телефон", ЗначениеСвойства) И ЗначениеЗаполнено(ЗначениеСвойства) Тогда
		ДанныеКандидата.КонтактнаяИнформация.Добавить(
			Новый Структура(
			"Тип,Вид,Представление",
			Перечисления.ТипыКонтактнойИнформации.Телефон,
			ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.ТелефонЛичныеДанныеКандидатов"),
			ЗначениеСвойства));
	КонецЕсли;
	
	Если СтруктураДанныхРезюме.Свойство("EMail", ЗначениеСвойства) И ЗначениеЗаполнено(ЗначениеСвойства) Тогда
		ДанныеКандидата.КонтактнаяИнформация.Добавить(
			Новый Структура(
			"Тип,Вид,Представление",
			Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты,
			ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.EMailЛичныеДанныеКандидатов"),
			ЗначениеСвойства));
	КонецЕсли;
	
	Если СтруктураДанныхРезюме.Свойство("Адрес", ЗначениеСвойства) И ЗначениеЗаполнено(ЗначениеСвойства) Тогда
		ДанныеКандидата.КонтактнаяИнформация.Добавить(
			Новый Структура(
			"Тип,Вид,Представление",
			Перечисления.ТипыКонтактнойИнформации.Адрес,
			ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.АдресЛичныеДанныеКандидатов"),
			ЗначениеСвойства));
	КонецЕсли;
	
	Если СтруктураДанныхРезюме.Свойство("ТекущееГражданство", ЗначениеСвойства) И ЗначениеЗаполнено(ЗначениеСвойства) Тогда
		ДанныеКандидата.Гражданство.Добавить(Новый Структура("Страна, Дата", Строка(ЗначениеСвойства)));
	КонецЕсли;
	
	Если СтруктураДанныхРезюме.Свойство("СостояниеВБракеСсылка", ЗначениеСвойства) И ЗначениеЗаполнено(ЗначениеСвойства) Тогда
		ДанныеКандидата.СостояниеВБраке.Добавить(Новый Структура("СостояниеВБраке, Дата", ЗначениеСвойства));
	КонецЕсли;
	
КонецПроцедуры

Процедура ДозаполнитьСтруктураДанныхРезюме(СтруктураДанныхРезюме, ДанныеКандидатаПоВерсии)
	
	Для Каждого КлючИЗначение Из ДанныеКандидатаПоВерсии Цикл
		ТекущееЗначениеДанных = Неопределено;
		СтруктураДанныхРезюме.Свойство(КлючИЗначение.Ключ, ТекущееЗначениеДанных);
		Если ТипЗнч(КлючИЗначение.Значение) <> Тип("Массив") Тогда
			Если Не ЗначениеЗаполнено(ТекущееЗначениеДанных) Тогда
				СтруктураДанныхРезюме.Вставить(КлючИЗначение.Ключ, КлючИЗначение.Значение);
			КонецЕсли;
		Иначе
			СтруктураДанныхРезюме.Вставить(КлючИЗначение.Ключ, 
				ЗначениеНаиболееПодходящееДаннымРезюме(
					КлючИЗначение.Ключ, ТекущееЗначениеДанных, КлючИЗначение.Значение));
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция СтруктурыОтвета()
	
	СтруктураОтвета = Новый Структура;
	СтруктураОтвета.Вставить("ДанныеКандидатов", Новый Массив);
	СтруктураОтвета.Вставить("СтруктураОшибки", СтруктураОшибкиРазбораРезюме());
	
	Возврат СтруктураОтвета;
	
КонецФункции

Функция СтруктураОшибкиРазбораРезюме()
	
	СтруктураОшибки = Новый Структура;
	СтруктураОшибки.Вставить("ОшибкаСервиса", Ложь);
	СтруктураОшибки.Вставить("ОписаниеОшибки", "");
	
	Возврат СтруктураОшибки;
	
КонецФункции

Функция ЗначениеНаиболееПодходящееДаннымРезюме(Имя, ТекущееЗначение, НовоеЗначение)
	
	Если НовоеЗначение = Неопределено
		ИЛИ НовоеЗначение.Количество() = 0 Тогда
		Возврат ТекущееЗначение;
	КонецЕсли;
	
	Если ТекущееЗначение = Неопределено
		ИЛИ ТекущееЗначение.Количество() = 0 Тогда
		Возврат НовоеЗначение;
	КонецЕсли;
	
	Если Имя = "ТрудоваяДеятельность" Тогда
		КлючевоеПоле = "ДатаНачала";
		
		ВесТекущегоЗначения = 0;
		СуммаЗначения = 0;
		Для Каждого ТекЭлемент Из ТекущееЗначение Цикл
			Если ЗначениеЗаполнено(ТекЭлемент[КлючевоеПоле]) Тогда
				СуммаЗначения = СуммаЗначения + 1;
			КонецЕсли;
		КонецЦикла;
		ВесТекущегоЗначения = СуммаЗначения/ТекущееЗначение.Количество();
		
		ВесНовогоЗначения = 0;
		СуммаЗначения = 0;
		Для Каждого ТекЭлемент Из НовоеЗначение Цикл
			Если ЗначениеЗаполнено(ТекЭлемент[КлючевоеПоле]) Тогда
				СуммаЗначения = СуммаЗначения + 1;
			КонецЕсли;
		КонецЦикла;
		ВесНовогоЗначения = СуммаЗначения/НовоеЗначение.Количество();
		
		Если ВесТекущегоЗначения >= ВесНовогоЗначения Тогда
			Возврат ТекущееЗначение;
		Иначе
			Возврат НовоеЗначение;
		КонецЕсли;
		
	ИначеЕсли Имя = "Образование" Тогда
		КлючевоеПоле = "Окончание";
		
		ВесТекущегоЗначения = 0;
		СуммаЗначения = 0;
		Для Каждого ТекЭлемент Из ТекущееЗначение Цикл
			Если ЗначениеЗаполнено(ТекЭлемент[КлючевоеПоле]) И ТекЭлемент[КлючевоеПоле] > 1900 Тогда
					СуммаЗначения = СуммаЗначения + 1;
			КонецЕсли;
		КонецЦикла;
		ВесТекущегоЗначения = СуммаЗначения/ТекущееЗначение.Количество();
		
		ВесНовогоЗначения = 0;
		СуммаЗначения = 0;
		Для Каждого ТекЭлемент Из НовоеЗначение Цикл
			Если ЗначениеЗаполнено(ТекЭлемент[КлючевоеПоле]) И ТекЭлемент[КлючевоеПоле] > 1900 Тогда
				СуммаЗначения = СуммаЗначения + 1;
			КонецЕсли;
		КонецЦикла;
		ВесНовогоЗначения = СуммаЗначения/НовоеЗначение.Количество();
		
		Если ВесТекущегоЗначения >= ВесНовогоЗначения Тогда
			Возврат ТекущееЗначение;
		Иначе
			Возврат НовоеЗначение;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ТекущееЗначение;
	
КонецФункции

Функция СтруктураДанныхРезюмеВнутренняя()
	
	СтруктураДанныхКандидата = Новый Структура();
	СтруктураДанныхКандидата.Вставить("Фамилия");
	СтруктураДанныхКандидата.Вставить("Имя");
	СтруктураДанныхКандидата.Вставить("Отчество");
	СтруктураДанныхКандидата.Вставить("Гражданство");
	СтруктураДанныхКандидата.Вставить("ДатаРождения");
	СтруктураДанныхКандидата.Вставить("ЗнаниеЯзыков");
	СтруктураДанныхКандидата.Вставить("ИсточникИнформации");
	СтруктураДанныхКандидата.Вставить("КонтактнаяИнформация");
	СтруктураДанныхКандидата.Вставить("МестоРождения");
	СтруктураДанныхКандидата.Вставить("ОжидаемыйДоход");
	СтруктураДанныхКандидата.Вставить("Образование");
	СтруктураДанныхКандидата.Вставить("Пол");
	СтруктураДанныхКандидата.Вставить("СостояниеВБраке");
	СтруктураДанныхКандидата.Вставить("ТрудоваяДеятельность");
	
	Возврат СтруктураДанныхКандидата;
	
КонецФункции

Функция СтруктураДанныхРезюмеОбщая(Знач ТекстДляРаспознавания)
	
	СобственнаяСтруктураДанных = СтруктураДанныхРезюмеВнутренняя();
	
	ЗаполнитьЗначенияСвойств(СобственнаяСтруктураДанных, ФизическиеЛицаКлиентСервер.ЧастиИмени(ФИОИзТекста(ТекстДляРаспознавания)));
	
	ОжидаемыйДоходИзТекста = ОжидаемыйДоходИзТекста(ТекстДляРаспознавания);
	
	СобственнаяСтруктураДанных.Вставить("ОжидаемыйДоход", ОжидаемыйДоходИзТекста.ОжидаемыйДоход);
	СобственнаяСтруктураДанных.Вставить("ВалютаДохода", ОжидаемыйДоходИзТекста.ВалютаДохода);
	СобственнаяСтруктураДанных.Вставить("ПериодичностьДохода", Перечисления.ПериодичностьОжидаемогоДоходаКандидатов.Месяц);
	СобственнаяСтруктураДанных.Вставить("Пол", Строка(ПолИзТекста(ТекстДляРаспознавания, СобственнаяСтруктураДанных.Отчество)));
	СобственнаяСтруктураДанных.Вставить("ДатаРождения",ДатаРожденияИзТекста(ТекстДляРаспознавания));
	СобственнаяСтруктураДанных.Вставить("EMail", EMailИзТекста(ТекстДляРаспознавания));
	СобственнаяСтруктураДанных.Вставить("Телефон", ТелефонИзТекста(ТекстДляРаспознавания));
	СобственнаяСтруктураДанных.Вставить("Адрес", АдресИзТекста(ТекстДляРаспознавания));
	СобственнаяСтруктураДанных.Вставить("МестоРождения", МестоРожденияИзТекста(ТекстДляРаспознавания));
	СобственнаяСтруктураДанных.Вставить("ТекущееГражданство", Строка(ГражданствоИзТекста(ТекстДляРаспознавания)));
	СобственнаяСтруктураДанных.Вставить("СостояниеВБракеСсылка", СостояниеВБракеИзТекста(ТекстДляРаспознавания));
	
	Возврат СобственнаяСтруктураДанных;
	
КонецФункции

Функция СтруктураДанныхРезюмеHH(Знач ТекстДляРаспознавания)
	
	СтруктураДанныхРезюме = СтруктураДанныхРезюмеОбщая(ТекстДляРаспознавания);
	
	ФорматРезюме = ПредопределенноеЗначение("Справочник.ИсточникиИнформацииОКандидатах.HeadHunter");
	
	СтруктураДанныхРезюме.Вставить("ТрудоваяДеятельность", МассивСтруктурОпытРаботыИзТекста(ТекстДляРаспознавания, ФорматРезюме));
	
	СтруктураДанныхРезюме.Вставить("Образование", МассивСтруктурОбразованиеИзТекста(ТекстДляРаспознавания, ФорматРезюме));
	
	СтруктураДанныхРезюме.Вставить("ЗнаниеЯзыков", МассивСтруктурЗнаниеЯзыковИзТекста(ТекстДляРаспознавания, ФорматРезюме)); 
	
	СтруктураДанныхРезюме.Вставить("СодержаниеПрочее", ПрочееИзТекста(ТекстДляРаспознавания, ФорматРезюме));
	
	Возврат СтруктураДанныхРезюме;
	
КонецФункции

