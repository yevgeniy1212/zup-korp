Процедура ПКО_Документ_ВыплатаДепонированнойЗарплаты_Касса_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	Если СтекВыгрузки.Количество() > 1 Тогда
		Возврат;
	КонецЕсли;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	СУММА(ВыплатаДепонированнойЗарплатыДепоненты.Сумма) КАК Сумма,
	|	ВыплатаДепонированнойЗарплаты.ФизическоеЛицо КАК Сотрудник,
	|	ВыплатаДепонированнойЗарплатыДепоненты.Ссылка.Дата КАК ДатаВедомостиНаВыплатуЗарплаты,
	|	ВыплатаДепонированнойЗарплатыДепоненты.Ведомость.Подразделение КАК ПодразделениеОрганизации,
	|	ВыплатаДепонированнойЗарплатыДепоненты.Ведомость.ПериодРегистрации КАК МесяцНачисления,
	|	ВыплатаДепонированнойЗарплатыДепоненты.Ссылка.Номер КАК НомерВедомости,
	|	ИСТИНА КАК Депонент
	|ИЗ
	|	Документ.ВыплатаДепонированнойЗарплаты КАК ВыплатаДепонированнойЗарплаты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВыплатаДепонированнойЗарплаты.Депоненты КАК ВыплатаДепонированнойЗарплатыДепоненты
	|		ПО (ВыплатаДепонированнойЗарплатыДепоненты.Ссылка = ВыплатаДепонированнойЗарплаты.Ссылка)
	|ГДЕ
	|	ВыплатаДепонированнойЗарплаты.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ВыплатаДепонированнойЗарплатыДепоненты.Ссылка.Номер,
	|	ВыплатаДепонированнойЗарплатыДепоненты.Ссылка.Дата,
	|	ВыплатаДепонированнойЗарплатыДепоненты.Ведомость.Подразделение,
	|	ВыплатаДепонированнойЗарплатыДепоненты.Ведомость.ПериодРегистрации,
	|	ВыплатаДепонированнойЗарплаты.ФизическоеЛицо";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Ссылка", ДанныеИБ.Ссылка);
	
	РасшифровкаПлатежа = Запрос.Выполнить().Выгрузить();
	РасшифровкаПлатежа.Колонки.Добавить("НомерВедомостиНаВыплатуЗарплаты");
	
	Для Каждого Строка Из РасшифровкаПлатежа Цикл
		НомерВедомостиНаВыплатуЗарплаты = Лев(Строка.НомерВедомости, 5) +"В" + Прав(Строка.НомерВедомости, 5);
		Строка.НомерВедомостиНаВыплатуЗарплаты = НомерВедомостиНаВыплатуЗарплаты;
		Строка.Сотрудник = ФизическоеЛицоДляВыгрузки(Строка.Сотрудник, КомпонентыОбмена.ПараметрыКонвертации);
	КонецЦикла;
	
	ДанныеXDTO.Вставить("РасшифровкаПлатежа", РасшифровкаПлатежа);
	
	ДанныеXDTO.Вставить("Валюта", ЗначениеВИнструкциюПКО(КомпонентыОбмена, ЗарплатаКадры.ВалютаУчетаЗаработнойПлаты()));
	ДанныеXDTO.Вставить("Сумма", ДанныеXDTO.РасшифровкаПлатежа.Итог("Сумма"));
	ДанныеXDTO.КлючевыеСвойства.Вставить("Номер", Лев(ДанныеXDTO.КлючевыеСвойства.Номер, 5) +"В" + Прав(ДанныеXDTO.КлючевыеСвойства.Номер, 5));
КонецПроцедуры
