Процедура ПКО_Документ_ВедомостьПрочихДоходовВКассу_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	Если СтекВыгрузки.Количество() > 1 Тогда
		Возврат;
	КонецЕсли;
	
	ТекстЗапроса = 
	"ВЫБРАТЬ
	|	ВедомостьПрочихДоходовВКассу.Номер КАК НомерВедомости,
	|	ВедомостьПрочихДоходовВКассу.Дата КАК ДатаВедомостиНаВыплатуЗарплаты,
	|	ВедомостьПрочихДоходовВКассу.ПериодРегистрации КАК МесяцНачисления,
	|	СУММА(ВедомостьПрочихДоходовВКассуВыплаты.КВыплате) КАК Сумма,
	|	ВедомостьПрочихДоходовВКассуВыплаты.ПериодВзаиморасчетов КАК ПериодВзаиморасчетовВедомости,
	|	ВЫБОР
	|		КОГДА ВЫРАЗИТЬ(ВедомостьПрочихДоходовВКассу.Подразделение КАК Справочник.ПодразделенияОрганизаций).ОбособленноеПодразделение
	|			ТОГДА ВедомостьПрочихДоходовВКассу.Подразделение
	|		ИНАЧЕ ЗНАЧЕНИЕ(Справочник.ПодразделенияОрганизаций.ПустаяСсылка)
	|	КОНЕЦ КАК СтруктурноеПодразделение,
	|	ВедомостьПрочихДоходовВКассуВыплаты.ФизическоеЛицо КАК ФизическоеЛицо
	|ИЗ
	|	Документ.ВедомостьПрочихДоходовВКассу КАК ВедомостьПрочихДоходовВКассу
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВедомостьПрочихДоходовВКассу.Выплаты КАК ВедомостьПрочихДоходовВКассуВыплаты
	|		ПО (ВедомостьПрочихДоходовВКассуВыплаты.Ссылка = ВедомостьПрочихДоходовВКассу.Ссылка)
	|ГДЕ
	|	ВедомостьПрочихДоходовВКассу.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	ВедомостьПрочихДоходовВКассу.Номер,
	|	ВедомостьПрочихДоходовВКассу.Дата,
	|	ВедомостьПрочихДоходовВКассу.ПериодРегистрации,
	|	ВедомостьПрочихДоходовВКассуВыплаты.ПериодВзаиморасчетов,
	|	ВедомостьПрочихДоходовВКассу.Подразделение,
	|	ВедомостьПрочихДоходовВКассуВыплаты.ФизическоеЛицо";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Ссылка", ДанныеИБ.Ссылка);
	
	РасшифровкаПлатежа = Запрос.Выполнить().Выгрузить();
	
	Если РасшифровкаПлатежа.Количество() > 0 Тогда
	  	Для Каждого Строка ИЗ  РасшифровкаПлатежа Цикл
			Строка.ФизическоеЛицо = ФизЛицоНезарплатныеДоходыДляВыгрузки(Строка.ФизическоеЛицо, КомпонентыОбмена.ПараметрыКонвертации);
		КонецЦикла;
	КонецЕсли;
	           
	//Статус, Валюта
	ЗаполнитьОбщиеДанныеЗаявкиНаРасходДС(КомпонентыОбмена, ДанныеXDTO);
	
	ДанныеXDTO.Вставить("РасшифровкаПлатежа", РасшифровкаПлатежа);
	
	ДанныеXDTO.Вставить("Сумма", ДанныеXDTO.РасшифровкаПлатежа.Итог("Сумма"));
	ДанныеXDTO.КлючевыеСвойства.Вставить("Номер", Лев(ДанныеXDTO.КлючевыеСвойства.Номер, 5) +"П" + Прав(ДанныеXDTO.КлючевыеСвойства.Номер, 5));
КонецПроцедуры
