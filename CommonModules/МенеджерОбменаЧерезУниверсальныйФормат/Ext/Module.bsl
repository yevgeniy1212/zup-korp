Процедура ПКО_Справочник_Организации_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	СтруктураКлючевыхСвойств = ДанныеXDTO.КлючевыеСвойства;
	Если СтекВыгрузки.Количество() > 1 Тогда
		СтруктураКлючевыхСвойств = ДанныеXDTO;
	КонецЕсли;
	
	КодОКАТО = "";
	Если ЗначениеЗаполнено(ДанныеИБ.РегистрацияВНалоговомОргане) Тогда
		РеквизитыРегистрации = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ДанныеИБ.РегистрацияВНалоговомОргане, "КодПоОКАТО");
		
		КодОКАТО = РеквизитыРегистрации.КодПоОКАТО;
	КонецЕсли;
	
	ВыгрузитьДополнительныеРеквизитыИСведения(КомпонентыОбмена, ДанныеИБ, ДанныеXDTO, Истина);
	
	ДанныеXDTO.Вставить("ОКАТО", КодОКАТО);  
	 
	КодПоОКПО = "";
	Если ЗначениеЗаполнено(ДанныеИБ.КодПоОКПО) Тогда
		
		КодПоОКПО = Прав(ДанныеИБ.КодПоОКПО, 12);;
	КонецЕсли;
	ДанныеXDTO.Вставить("ОКПО", КодПоОКПО);
КонецПроцедуры
