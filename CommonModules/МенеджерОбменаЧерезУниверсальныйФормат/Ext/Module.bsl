		ЗначенияДляОтправки.Вставить(Перечисления.ВидыОперацийРезервовПоОплатеТруда.Списание, "Списание");
		ПравилоКонвертации.КонвертацииЗначенийПриОтправке = ЗначенияДляОтправки;
	
		// Перечисление_ВидыРезервовПоОплатеТруда.
		ПравилоКонвертации = ПравилаКонвертации.Добавить();
		ПравилоКонвертации.ИмяПКПД = "Перечисление_ВидыРезервовПоОплатеТруда";
