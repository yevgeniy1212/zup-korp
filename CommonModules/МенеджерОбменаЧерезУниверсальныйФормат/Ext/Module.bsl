Процедура ПКО_Документ_ПеречислениеВзносовИОтчислений_УП_ОТ_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	Если СтекВыгрузки.Количество() > 1 Тогда
		Возврат;
	КонецЕсли;
	
	// Статус, Валюта.
	ЗаполнитьОбщиеДанныеЗаявкиНаРасходДС(КомпонентыОбмена, ДанныеXDTO);
	
	ДанныеXDTO.Вставить("ЖелательнаяФормаОплатыНаличные",       Ложь);
	ДанныеXDTO.Вставить("ЖелательнаяФормаОплатыБезналичные",    Истина);
	ДанныеXDTO.Вставить("ЖелательнаяФормаОплатыПлатежнаяКарта", Ложь);
	ДанныеXDTO.Вставить("УтвержденнаяФормаОплаты",              "Безналичная");
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
		|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.Номер КАК НомерВедомостиНаВыплатуЗарплаты,
		|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.Дата КАК ДатаВедомостиНаВыплатуЗарплаты,
		|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.ВидНалогаВзносаОтчисления КАК ВидОперацииСсылка,
		|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.ВидПлатежа КАК ВидПлатежаСсылка,
		|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.ФизическоеЛицо КАК Сотрудник,
		|	СУММА(ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.НалогВзнос) КАК Сумма
		|ИЗ
		|	Документ.ПеречислениеВзносовИОтчислений КАК ПеречислениеВзносовИОтчислений
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПеречислениеВзносовИОтчислений.ВедомостиНаПеречислениеВзносовИОтчислений КАК ПеречислениеВзносовИОтчисленийВедомостиНаПеречислениеВзносовИОтчислений
		|		ПО (ПеречислениеВзносовИОтчисленийВедомостиНаПеречислениеВзносовИОтчислений.Ссылка = ПеречислениеВзносовИОтчислений.Ссылка)
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВедомостьНаПеречислениеВзносовОтчислений.НалогиВзносыОтчисления КАК ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления
		|		ПО (ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка = ПеречислениеВзносовИОтчисленийВедомостиНаПеречислениеВзносовИОтчислений.Ведомость)
		|ГДЕ
		|	ПеречислениеВзносовИОтчисленийВедомостиНаПеречислениеВзносовИОтчислений.Ссылка = &Ссылка
		|
		|СГРУППИРОВАТЬ ПО
		|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.Дата,
		|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.ВидНалогаВзносаОтчисления,
		|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.ВидПлатежа,
		|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.ФизическоеЛицо,
		|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.Номер");
	Запрос.УстановитьПараметр("Ссылка", ДанныеИБ.Ссылка);
	
	ТаблицаРасшифровка = Запрос.Выполнить().Выгрузить();
	
	ДобавитьИдентификаторПеречисленияПоСсылке(ТаблицаРасшифровка, "ВидОперации");
	ДобавитьИдентификаторПеречисленияПоСсылке(ТаблицаРасшифровка, "ВидПлатежа");
	
	ДанныеXDTO.Вставить("РасшифровкаПлатежа", ТаблицаРасшифровка);
	
	ДанныеXDTO.Вставить("Сумма", ТаблицаРасшифровка.Итог("Сумма"));
КонецПроцедуры
