Процедура ПКО_Справочник_ПодразделенияОрганизаций_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	Если ДанныеИБ.ОбособленноеПодразделение Тогда
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ПодразделенияОрганизаций.Ссылка,
		|	ПодразделенияОрганизаций.РегистрацияВНалоговомОргане.ИНН КАК ИНН,
		|	ПодразделенияОрганизаций.РегистрацияВНалоговомОргане.НаименованиеОбособленногоПодразделения КАК НаименованиеПолное
		|ИЗ
		|	Справочник.ПодразделенияОрганизаций КАК ПодразделенияОрганизаций
		|ГДЕ
		|	ПодразделенияОрганизаций.Ссылка = &Ссылка";
			
		Запрос = Новый Запрос(ТекстЗапроса);
		Запрос.УстановитьПараметр("Ссылка", ДанныеИБ.Ссылка);
	
		Результат = Запрос.Выполнить().Выгрузить();
	
		Если Результат.Количество() > 0 Тогда
			ДанныеXDTO.КлючевыеСвойства.Вставить("ИНН", Результат[0].ИНН);
			ДанныеXDTO.Вставить("НаименованиеПолное", Результат[0].НаименованиеПолное);
		Иначе
			ДанныеXDTO.КлючевыеСвойства.Вставить("ИНН", "");
			ДанныеXDTO.Вставить("НаименованиеПолное", "");
		КонецЕсли;
	Иначе
		ДанныеXDTO.КлючевыеСвойства.Вставить("ИНН", "");
		ДанныеXDTO.Вставить("НаименованиеПолное", "");
	КонецЕсли;
КонецПроцедуры
