Процедура ПОД_Документ_ПлатежноеПоручение_ПриОбработке(ДанныеИБ, ИспользованиеПКО, КомпонентыОбмена)
	ИспользованиеПКО.Документ_ПлатежноеПоручение = Ложь;
	    ИспользованиеПКО.Документ_ПлатежноеПоручение_УП_ОТ = Ложь;
	    ИспользованиеПКО.Документ_ПлатежноеПоручениеПДПеречислением_Заявка = Ложь;
	   	ИспользованиеПКО.Документ_ВедомостьНаВыплатуЗППеречислением_Заявка = Ложь; 
	   	
	    Если КомпонентыОбмена.УзелКорреспондента.ВариантНастройки = "ОбменЗУП31БП" Тогда
	        Если ДанныеИБ.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПлатежногоПоручения.ПеречислениеПрочихДоходов") Тогда
	            Если ДанныеИБ.Ведомости.Количество() > 0 Тогда
	                СпособВыплаты = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ДанныеИБ.Ведомости[0].Ведомость, "СпособВыплаты");
	                Если СпособВыплаты = ПредопределенноеЗначение("Перечисление.СпособыВыплатыПрочихДоходов.ВыплатаПрочихДоходов")
	               		ИЛИ СпособВыплаты = ПредопределенноеЗначение("Перечисление.СпособыВыплатыПрочихДоходов.ВыплатыБывшимСотрудникам") Тогда
	                    ИспользованиеПКО.Документ_ПлатежноеПоручение = Истина;
	                Иначе
	                    ИспользованиеПКО.Документ_ПлатежноеПоручение = Ложь;
	                КонецЕсли;
	            КонецЕсли;
	        Иначе
	            ИспользованиеПКО.Документ_ПлатежноеПоручение = Истина;
	        КонецЕсли;
	    ИначеЕсли КомпонентыОбмена.УзелКорреспондента.ВариантНастройки = "ОбменУП2ЗУП3"
	        И КомпонентыОбмена.УзелКорреспондента.ОтправлятьВедомости Тогда
	        Если ДанныеИБ.Ведомости.Количество() > 0 Тогда
	            Если ДанныеИБ.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПлатежногоПоручения.ПеречислениеПрочихДоходов") Тогда
	                Если ТипЗнч(ДанныеИБ.Ведомости[0].Ведомость) = Тип("ДокументСсылка.ВедомостьПрочихДоходовВБанк") Тогда
	                    ИспользованиеПКО.Документ_ПлатежноеПоручение_УП_ОТ = Истина;
	                ИначеЕсли ТипЗнч(ДанныеИБ.Ведомости[0].Ведомость) = Тип("ДокументСсылка.ВедомостьПрочихДоходовПеречислением") Тогда
	                    ИспользованиеПКО.Документ_ПлатежноеПоручениеПДПеречислением_Заявка = Истина;
	                КонецЕсли;
	            ИначеЕсли ДанныеИБ.ВидОперации = ПредопределенноеЗначение("Перечисление.ВидыОперацийПлатежногоПоручения.ПеречислениеЗарплаты") Тогда
	                Если ТипЗнч(ДанныеИБ.Ведомости[0].Ведомость) = Тип("ДокументСсылка.ВедомостьНаВыплатуЗарплатыВБанк") Тогда
	                    ИспользованиеПКО.Документ_ПлатежноеПоручение_УП_ОТ = Истина;
	                ИначеЕсли ТипЗнч(ДанныеИБ.Ведомости[0].Ведомость) = Тип("ДокументСсылка.ВедомостьНаВыплатуЗарплатыПеречислением") Тогда
	                    ИспользованиеПКО.Документ_ВедомостьНаВыплатуЗППеречислением_Заявка = Истина;
	                КонецЕсли;
	            КонецЕсли;
	        КонецЕсли;  
	    КонецЕсли;
КонецПроцедуры
