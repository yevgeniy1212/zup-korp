Процедура ПКО_Документ_НачислениеОценочныхОбязательств_БК_ОТ_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	Если СтекВыгрузки.Количество() > 1 Тогда
			Возврат;
		КонецЕсли;
		
		ПодчиненностьПодразделений = Новый ТаблицаЗначений;
		ПодчиненностьПодразделений.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
		ПодчиненностьПодразделений.Колонки.Добавить("ВышестоящееПодразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПодчиненностьПодразделений.Подразделение КАК Подразделение,
		|	ПодчиненностьПодразделений.Подразделение.ОбособленноеПодразделение КАК ОбособленноеПодразделение,
		|	ПодчиненностьПодразделений.ВышестоящееПодразделение КАК ВышестоящееПодразделение
		|ИЗ
		|	РегистрСведений.ПодчиненностьПодразделенийОрганизаций КАК ПодчиненностьПодразделений
		|ГДЕ
		|	ПодчиненностьПодразделений.ВышестоящееПодразделение.ОбособленноеПодразделение = ИСТИНА
		|ИТОГИ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ВышестоящееПодразделение)
		|ПО
		|	Подразделение,
		|	ОбособленноеПодразделение";
		
		Результат = Запрос.Выполнить();
		
		ИтогиПоВышестоящим = Результат.Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		ВыборкаПоПодразделениям = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаПоПодразделениям.Следующий() Цикл
			Если ВыборкаПоПодразделениям.ОбособленноеПодразделение Тогда
				НоваяСтрока = ПодчиненностьПодразделений.Добавить(); 
				НоваяСтрока.Подразделение = ВыборкаПоПодразделениям.Подразделение;
			    НоваяСтрока.ВышестоящееПодразделение = ВыборкаПоПодразделениям.Подразделение;
			Иначе
				ВыборкаОбособленноеПодразделение = ВыборкаПоПодразделениям.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				ВыборкаОбособленноеПодразделение.Следующий();
				
				Выборка = ВыборкаОбособленноеПодразделение.Выбрать();
				Уровень = 0;
				НоваяСтрока = ПодчиненностьПодразделений.Добавить(); 
				НоваяСтрока.Подразделение = ВыборкаОбособленноеПодразделение.Подразделение;
				Пока Выборка.Следующий() Цикл
					Если ВыборкаОбособленноеПодразделение.ВышестоящееПодразделение = 1 Тогда
						ВышестоящееПодразделение = Выборка.ВышестоящееПодразделение;
					Иначе
						НайденнаяСтрока = ИтогиПоВышестоящим.Строки.Найти(Выборка.ВышестоящееПодразделение, "Подразделение");
						Если НайденнаяСтрока.ВышестоящееПодразделение > Уровень Тогда
							ВышестоящееПодразделение = Выборка.ВышестоящееПодразделение;
							Уровень = НайденнаяСтрока.ВышестоящееПодразделение;
						КонецЕсли;
					КонецЕсли;
				КонецЦикла;
				НоваяСтрока.ВышестоящееПодразделение = ВышестоящееПодразделение;
			КонецЕсли;	
		КонецЦикла;
		
		Запрос = Новый Запрос();
		Запрос.Текст =	
			"ВЫБРАТЬ РАЗЛИЧНЫЕ
