Процедура ПОД_Документ_ВедомостьНаВыплатуЗарплатыВКассу_ПриОбработке(ДанныеИБ, ИспользованиеПКО, КомпонентыОбмена)
	ИспользованиеПКО.Документ_ВедомостьНаВыплатуЗарплатыВКассу = Ложь;
	ИспользованиеПКО.Документ_ВедомостьНаВыплатуЗПВКассу_УП_ОТ = Ложь;
	ИспользованиеПКО.Документ_ВедомостьНаВыплатуЗПВКассу_Заявка_УП = Ложь;
	
	Если КомпонентыОбмена.УзелКорреспондента.ВариантНастройки = "ОбменЗУП31БП" Тогда
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ВзаиморасчетыСДепонентами.Ведомость КАК Ведомость,
		|	ВзаиморасчетыСДепонентами.ФизическоеЛицо КАК ФизическоеЛицо
		|ПОМЕСТИТЬ ВТДепонирования
		|ИЗ
		|	РегистрНакопления.ВзаиморасчетыСДепонентами КАК ВзаиморасчетыСДепонентами
		|ГДЕ
		|	ВзаиморасчетыСДепонентами.ВидДвижения = ЗНАЧЕНИЕ(ВидДвиженияНакопления.Приход)
		|	И ВзаиморасчетыСДепонентами.Ведомость = &Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВедомостьНаВыплатуЗарплатыВКассу.Номер КАК НомерВедомости,
		|	ВедомостьНаВыплатуЗарплатыВКассу.Дата КАК ДатаВедомостиНаВыплатуЗарплаты,
		|	ВедомостьНаВыплатуЗарплатыВКассу.ПериодРегистрации КАК МесяцНачисления,
		|	ВедомостьНаВыплатуЗарплатыВКассу.Подразделение КАК ПодразделениеОрганизации,
		|	СУММА(ВедомостьНаВыплатуЗарплатыВКассуЗарплата.КВыплате) КАК Сумма,
		|	ВедомостьНаВыплатуЗарплатыВКассуЗарплата.ФизическоеЛицо КАК Сотрудник,
		|	ЛОЖЬ КАК Депонент
		|ИЗ
		|	Документ.ВедомостьНаВыплатуЗарплатыВКассу КАК ВедомостьНаВыплатуЗарплатыВКассу
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВедомостьНаВыплатуЗарплатыВКассу.Зарплата КАК ВедомостьНаВыплатуЗарплатыВКассуЗарплата
		|		ПО (ВедомостьНаВыплатуЗарплатыВКассуЗарплата.Ссылка = ВедомостьНаВыплатуЗарплатыВКассу.Ссылка)
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДепонирования КАК Депоненты
		|		ПО (Депоненты.Ведомость = ВедомостьНаВыплатуЗарплатыВКассу.Ссылка)
		|			И (Депоненты.ФизическоеЛицо = ВедомостьНаВыплатуЗарплатыВКассуЗарплата.ФизическоеЛицо)
		|ГДЕ
		|	ВедомостьНаВыплатуЗарплатыВКассу.Ссылка = &Ссылка
		|	И Депоненты.ФизическоеЛицо ЕСТЬ NULL
		|
		|СГРУППИРОВАТЬ ПО
		|	ВедомостьНаВыплатуЗарплатыВКассу.Номер,
		|	ВедомостьНаВыплатуЗарплатыВКассу.Дата,
		|	ВедомостьНаВыплатуЗарплатыВКассу.ПериодРегистрации,
		|	ВедомостьНаВыплатуЗарплатыВКассу.Подразделение,
		|	ВедомостьНаВыплатуЗарплатыВКассуЗарплата.ФизическоеЛицо
		|";
	
		Запрос = Новый Запрос(ТекстЗапроса);
		Запрос.УстановитьПараметр("Ссылка", ДанныеИБ.Ссылка);
	
		РезультатВыборки = Запрос.Выполнить().Выгрузить();
	
		Если РезультатВыборки.Количество() = 0 Тогда
			ИспользованиеПКО.Документ_ВедомостьНаВыплатуЗарплатыВКассу = Ложь;
		Иначе
			ИспользованиеПКО.Документ_ВедомостьНаВыплатуЗарплатыВКассу = Истина;
		КонецЕсли;
	
	ИначеЕсли КомпонентыОбмена.УзелКорреспондента.ВариантНастройки = "ОбменУП2ЗУП3" 
	        И КомпонентыОбмена.УзелКорреспондента.ОтправлятьВедомости Тогда
		
		Если Не ДанныеИБ.Проведен Тогда
			Возврат;
		КонецЕсли;
		
		ЕстьСуммаКВыплата = ЕстьСуммаКВыплата(ДанныеИБ, Ложь);
		
		Если Не КомпонентыОбмена.ПараметрыКонвертации.ОтправлятьВедомостиКакЗаявки Тогда
			ИспользованиеПКО.Документ_ВедомостьНаВыплатуЗПВКассу_Заявка_УП = ЕстьСуммаКВыплата;
		ИначеЕсли КомпонентыОбмена.ПараметрыКонвертации.ОтправлятьВедомостиКакЗаявки Тогда
			ИспользованиеПКО.Документ_ВедомостьНаВыплатуЗПВКассу_УП_ОТ = ЕстьСуммаКВыплата;
		КонецЕсли;
	
	КонецЕсли;
КонецПроцедуры
