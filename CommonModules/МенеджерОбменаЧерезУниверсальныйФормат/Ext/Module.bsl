	|			И (ВзаиморасчетыССотрудниками.Регистратор = ДепонированиеЗарплатыДепоненты.Ссылка.Ведомость)
	|ГДЕ
	|	ДепонированиеЗарплатыДепоненты.Ссылка В(&Ссылка)
	|
	|СГРУППИРОВАТЬ ПО
	|	ДепонированиеЗарплатыДепоненты.Ссылка.Ведомость.Дата,
	|	ДепонированиеЗарплатыДепоненты.Ссылка.Ведомость.Номер,
	|	ДепонированиеЗарплатыДепоненты.Ссылка.Ведомость.ПериодРегистрации,
	|	ДепонированиеЗарплатыДепоненты.Ссылка.Ведомость,
	|	ДепонированиеЗарплатыДепоненты.Ссылка.Ведомость.Подразделение,
	|	ВзаиморасчетыССотрудниками.ФизическоеЛицо";
	
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Ссылка", ДанныеИБ.Ссылка);
	
	РасшифровкаПлатежа = Запрос.Выполнить().Выгрузить();
	РасшифровкаПлатежа.Колонки.Добавить("НомерВедомостиНаВыплатуЗарплаты");
	
	Для Каждого Строка Из РасшифровкаПлатежа Цикл
	
		НомерВедомостиНаВыплатуЗарплаты = Лев(Строка.НомерВедомости, 5) +"Д" + Прав(Строка.НомерВедомости, 5);
		Строка.НомерВедомостиНаВыплатуЗарплаты = НомерВедомостиНаВыплатуЗарплаты;
		Строка.Сотрудник = ФизическоеЛицоДляВыгрузки(Строка.Сотрудник, КомпонентыОбмена.ПараметрыКонвертации);
	КонецЦикла;
	
	ДанныеXDTO.Вставить("РасшифровкаПлатежа", РасшифровкаПлатежа);
	
	ДанныеXDTO.Вставить("Сумма", ДанныеXDTO.РасшифровкаПлатежа.Итог("Сумма"));
	ДанныеXDTO.КлючевыеСвойства.Вставить("Номер", Лев(ДанныеXDTO.КлючевыеСвойства.Номер, 5) +"Д" + Прав(ДанныеXDTO.КлючевыеСвойства.Номер, 5))
КонецПроцедуры
