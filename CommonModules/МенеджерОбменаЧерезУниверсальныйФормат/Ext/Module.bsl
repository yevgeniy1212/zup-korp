	ФизическиеЛица = ДанныеИБ.Сотрудники.ВыгрузитьКолонку("ФизическоеЛицо");
	
	//Сумма,
	//РасшифровкаПлатежа: Сумма, НомерВедомостиНаВозвратЗарплаты, ДатаВедомостиНаВозвратЗарплаты, Сотрудник 
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ведомость", ДанныеИБ.Ведомость);
	Запрос.УстановитьПараметр("ФизическиеЛица", ФизическиеЛица);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗарплатаКВыплате.Регистратор.Номер КАК НомерВедомости,
		|	ЗарплатаКВыплате.Регистратор.Дата КАК ДатаВедомостиНаВозвратЗарплаты,
		|	ЗарплатаКВыплате.Подразделение КАК ПодразделениеОрганизации,
		|	ЗарплатаКВыплате.Период КАК МесяцНачисления,
		|	СУММА(ЗарплатаКВыплате.СуммаКВыплате) КАК Сумма,
		|	ЗарплатаКВыплате.ФизическоеЛицо КАК Сотрудник
		|ИЗ
		|	РегистрНакопления.ЗарплатаКВыплате КАК ЗарплатаКВыплате
		|ГДЕ
		|	ЗарплатаКВыплате.Регистратор = &Ведомость
		|	И ЗарплатаКВыплате.ФизическоеЛицо В(&ФизическиеЛица)
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗарплатаКВыплате.Регистратор.Номер,
		|	ЗарплатаКВыплате.Регистратор.Дата,
		|	ЗарплатаКВыплате.Подразделение,
		|	ЗарплатаКВыплате.Период,
		|	ЗарплатаКВыплате.ФизическоеЛицо";
	
	РасшифровкаПлатежа = Запрос.Выполнить().Выгрузить();
	РасшифровкаПлатежа.Колонки.Добавить("НомерВедомостиНаВозвратЗарплаты");
	
	Для Каждого Строка Из РасшифровкаПлатежа Цикл
		Если ТипЗнч(ДанныеИБ.Ведомость) = Тип("ДокументСсылка.ВедомостьНаВыплатуЗарплатыПеречислением") Тогда
			НомерВедомостиНаВозвратЗарплаты = Лев(Строка.НомерВедомости, 5) +"С" + Прав(Строка.НомерВедомости, 5);
		Иначе
			НомерВедомостиНаВозвратЗарплаты = Лев(Строка.НомерВедомости, 5) +"Б" + Прав(Строка.НомерВедомости, 5);
		КонецЕсли;
		Строка.НомерВедомостиНаВозвратЗарплаты = НомерВедомостиНаВозвратЗарплаты;
		Строка.Сотрудник = ФизическоеЛицоДляВыгрузки(Строка.Сотрудник, КомпонентыОбмена.ПараметрыКонвертации);
	КонецЦикла; 
	
	ДанныеXDTO.Вставить("РасшифровкаПлатежа", РасшифровкаПлатежа);
	
	ДанныеXDTO.Вставить("Валюта", ЗарплатаКадры.ВалютаУчетаЗаработнойПлаты());
	
	ДанныеXDTO.Вставить("Сумма", ДанныеXDTO.РасшифровкаПлатежа.Итог("Сумма"));
	
	ДанныеXDTO.КлючевыеСвойства.Вставить("Номер", Лев(ДанныеXDTO.КлючевыеСвойства.Номер, 5) +"Б" + Прав(ДанныеXDTO.КлючевыеСвойства.Номер, 5));
КонецПроцедуры
