Процедура ПКО_Документ_ВедомостьНаВозвратПрочихВыплат_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	Если СтекВыгрузки.Количество() > 1 Тогда
			Возврат;
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Ссылка", ДанныеИБ.Ссылка);
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПлатежноеПоручениеВедомости.Ссылка.Контрагент КАК Контрагент,
		|	ПлатежноеПоручениеВедомости.Ссылка.БанковскийСчет КАК БанковскийСчет,
		|	ПлатежноеПоручениеВедомости.Ссылка.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента,
		|	ПлатежноеПоручениеВедомости.Ссылка.КодНазначенияПлатежа КАК КодНазначенияПлатежа,
		|	ПлатежноеПоручениеВедомости.Ссылка.НазначениеПлатежа КАК НазначениеПлатежа
		|ИЗ
		|	Документ.ВедомостьНаВозвратПрочихВыплат КАК ВедомостьНаВозвратПрочихВыплат
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПлатежноеПоручение.ВедомостиПрочие КАК ПлатежноеПоручениеВедомости
		|		ПО (ВедомостьНаВозвратПрочихВыплат.ДокументОснование = ПлатежноеПоручениеВедомости.Ведомость)
		|ГДЕ
		|	ВедомостьНаВозвратПрочихВыплат.Ссылка = &Ссылка";
		
		Выборка = Запрос.Выполнить().Выбрать();
		
		Если Выборка.Количество() > 0 Тогда
			Пока Выборка.Следующий() Цикл
				ДанныеXDTO.Вставить("БанковскийСчетОрганизации", Выборка.БанковскийСчет);
				ДанныеXDTO.Вставить("БанковскийСчет", Выборка.БанковскийСчетКонтрагента);
				ДанныеXDTO.Вставить("НазначениеПлатежа", Выборка.НазначениеПлатежа);
				ДанныеXDTO.Вставить("КодНазначенияПлатежа", Выборка.КодНазначенияПлатежа);
			КонецЦикла;
		КонецЕсли; 
			
		ТекстЗапроса = 
		"ВЫБРАТЬ
		|	ВедомостьНаВозвратПрочихВыплатПрочиеВыплаты.Ссылка.Дата КАК ДатаВедомостиНаВозвратЗарплаты,
		|	ВедомостьНаВозвратПрочихВыплатПрочиеВыплаты.Ссылка.Номер КАК НомерВедомостиНаВозвратЗарплаты,
		|	ВедомостьНаВозвратПрочихВыплатПрочиеВыплаты.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ВедомостьНаВозвратПрочихВыплатПрочиеВыплаты.ПериодВзаиморасчетов КАК ПериодВзаиморасчетов,
		|	СУММА(ВедомостьНаВозвратПрочихВыплатПрочиеВыплаты.Сумма) КАК Сумма
		|ИЗ
		|	Документ.ВедомостьНаВозвратПрочихВыплат КАК ВедомостьНаВозвратПрочихВыплат
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВедомостьНаВозвратПрочихВыплат.ПрочиеВыплаты КАК ВедомостьНаВозвратПрочихВыплатПрочиеВыплаты
		|		ПО (ВедомостьНаВозвратПрочихВыплатПрочиеВыплаты.Ссылка = ВедомостьНаВозвратПрочихВыплат.Ссылка)
		|
		|ГДЕ
		|	ВедомостьНаВозвратПрочихВыплат.Ссылка = &Ссылка
		|СГРУППИРОВАТЬ ПО
		|	ВедомостьНаВозвратПрочихВыплатПрочиеВыплаты.ФизическоеЛицо,
		|	ВедомостьНаВозвратПрочихВыплатПрочиеВыплаты.ПериодВзаиморасчетов,
	    |	ВедомостьНаВозвратПрочихВыплатПрочиеВыплаты.Ссылка.Дата,
		|	ВедомостьНаВозвратПрочихВыплатПрочиеВыплаты.Ссылка.Номер";
		
		Запрос = Новый Запрос(ТекстЗапроса);
		Запрос.УстановитьПараметр("Ссылка", ДанныеИБ.Ссылка);
		
		ПрочиеВыплаты = Запрос.Выполнить().Выгрузить();
		
		ДанныеXDTO.Вставить("ПрочиеВыплаты",ПрочиеВыплаты);     
		
		ДанныеXDTO.Вставить("СуммаДокумента", ДанныеXDTO.ПрочиеВыплаты.Итог("Сумма"));
		
		ДанныеXDTO.Вставить("Валюта", ЗарплатаКадры.ВалютаУчетаЗаработнойПлаты());
		
		ДанныеXDTO.КлючевыеСвойства.Вставить("Номер", Лев(ДанныеXDTO.КлючевыеСвойства.Номер, 5) +"П" + Прав(ДанныеXDTO.КлючевыеСвойства.Номер, 5));
КонецПроцедуры
