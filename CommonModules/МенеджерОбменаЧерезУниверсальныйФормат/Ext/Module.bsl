Процедура ПОД_Документ_ВедомостьПрочихДоходовВКассу_ПриОбработке(ДанныеИБ, ИспользованиеПКО, КомпонентыОбмена)
	ИспользованиеПКО.Документ_ВедомостьПрочихДоходовВКассу = Ложь;
	ИспользованиеПКО.Документ_ВедомостьПрочихДоходовВКассу_УП_От = Ложь;
	ИспользованиеПКО.Документ_ВедомостьПрочихДоходовВКассу_Заявка_УП = Ложь;
	
	Если КомпонентыОбмена.УзелКорреспондента.ВариантНастройки = "ОбменЗУП31БП" Тогда
		Если ДанныеИБ.СпособВыплаты = Перечисления.СпособыВыплатыПрочихДоходов.ВыплатаПрочихДоходов
			ИЛИ ДанныеИБ.СпособВыплаты = Перечисления.СпособыВыплатыПрочихДоходов.ВыплатыБывшимСотрудникам Тогда
			ИспользованиеПКО.Документ_ВедомостьПрочихДоходовВКассу = Истина;
		КонецЕсли;
	ИначеЕсли КомпонентыОбмена.УзелКорреспондента.ВариантНастройки = "ОбменУП2ЗУП3"
	  		И КомпонентыОбмена.УзелКорреспондента.ОтправлятьВедомости Тогда
		Если ДанныеИБ.СпособВыплаты = Перечисления.СпособыВыплатыПрочихДоходов.ВыплатаПрочихДоходов 
			ИЛИ ДанныеИБ.СпособВыплаты = Перечисления.СпособыВыплатыПрочихДоходов.ВыплатыБывшимСотрудникам Тогда
	
			Если Не ДанныеИБ.Проведен Тогда
				Возврат;
			КонецЕсли;
			
			ЕстьСуммаКВыплата = ЕстьСуммаКВыплата(ДанныеИБ, Истина);
			 
			Если НЕ КомпонентыОбмена.ПараметрыКонвертации.ОтправлятьВедомостиКакЗаявки Тогда
				ИспользованиеПКО.Документ_ВедомостьПрочихДоходовВКассу_Заявка_УП = ЕстьСуммаКВыплата;
			ИначеЕсли КомпонентыОбмена.ПараметрыКонвертации.ОтправлятьВедомостиКакЗаявки Тогда
				ИспользованиеПКО.Документ_ВедомостьПрочихДоходовВКассу_УП_От = ЕстьСуммаКВыплата;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры
