Процедура ПКО_Документ_ПеречислениеВзносовИОтчислений_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	Если СтекВыгрузки.Количество() > 1 Тогда
			Возврат;
		КонецЕсли;
		
		//Статус, Валюта
		ЗаполнитьОбщиеДанныеЗаявкиНаРасходДС(КомпонентыОбмена, ДанныеXDTO);
		
		ТекстЗапроса = 
			"ВЫБРАТЬ
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.Номер КАК НомерВедомости,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.Дата КАК ДатаВедомостиНаВыплатуЗарплаты,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.ПериодРегистрации КАК МесяцНачисления,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.ВидНалогаВзносаОтчисления КАК ВидОперацииСсылка,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.Подразделение КАК ПодразделениеОрганизации,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.ВидПлатежа КАК ВидПлатежаСсылка,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.ФизическоеЛицо КАК Сотрудник,
			|	СУММА(ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.НалогВзнос) КАК Сумма,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.МесяцПериода КАК ПериодВзаиморасчетовВедомости, 
			|	СУММА(ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.СуммаПлатежа) КАК СуммаПлатежа,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.ВключаетОПВ КАК ВключаетОПВ,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.ВключаетВОСМС КАК ВключаетВОСМС,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.ВключаетИПН КАК ВключаетИПН,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.ВключаетСО КАК ВключаетСО,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.ВключаетООСМС КАК ВключаетООСМС,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.ВидДохода КАК ВидДоходаСсылка,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.ВключаетОПВР КАК ВключаетОПВР
			|ИЗ
			|	Документ.ПеречислениеВзносовИОтчислений КАК ПеречислениеВзносовИОтчислений
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПеречислениеВзносовИОтчислений.ВедомостиНаПеречислениеВзносовИОтчислений КАК ПеречислениеВзносовИОтчисленийВедомостиНаПеречислениеВзносовИОтчислений
			|		ПО (ПеречислениеВзносовИОтчисленийВедомостиНаПеречислениеВзносовИОтчислений.Ссылка = ПеречислениеВзносовИОтчислений.Ссылка)
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ВедомостьНаПеречислениеВзносовОтчислений.НалогиВзносыОтчисления КАК ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления
			|		ПО (ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка = ПеречислениеВзносовИОтчисленийВедомостиНаПеречислениеВзносовИОтчислений.Ведомость)
			|ГДЕ
			|	ПеречислениеВзносовИОтчисленийВедомостиНаПеречислениеВзносовИОтчислений.Ссылка = &Ссылка
			|
			|СГРУППИРОВАТЬ ПО
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.Дата,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.ПериодРегистрации,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.ВидНалогаВзносаОтчисления,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.Подразделение,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.ВидПлатежа,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.ФизическоеЛицо,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.МесяцПериода, 
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.Номер,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.ВключаетОПВ,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.ВключаетВОСМС,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.ВключаетИПН,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.ВключаетСО,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.ВключаетООСМС,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.Ссылка.ВидДохода,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.ВключаетОПВР
			|
			|УПОРЯДОЧИТЬ ПО
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.ФизическоеЛицо.Фамилия,
			|	ВедомостьНаПеречислениеВзносовОтчисленийНалогиВзносыОтчисления.ФизическоеЛицо.Имя,
			|	ПериодВзаиморасчетовВедомости";	  
		
		Запрос = Новый Запрос(ТекстЗапроса);
		Запрос.УстановитьПараметр("Ссылка", ДанныеИБ.Ссылка);
		
		РасшифровкаПлатежа = Запрос.Выполнить().Выгрузить();
		РасшифровкаПлатежа.Колонки.Добавить("НомерВедомостиНаВыплатуЗарплаты");
		РасшифровкаПлатежа.Колонки.Добавить("ВидДохода");
		
		Для Каждого Строка Из РасшифровкаПлатежа Цикл
		   
		   	Если Строка.ВидДоходаСсылка = Справочники.ВидыДоходов.ДоходыОтРаботодателя 
		   		ИЛИ Строка.ВидДоходаСсылка = Справочники.ВидыДоходов.ПустаяСсылка() Тогда
				Строка.Сотрудник = ФизическоеЛицоДляВыгрузки(Строка.Сотрудник, КомпонентыОбмена.ПараметрыКонвертации);
			Иначе 
				Строка.Сотрудник = ФизЛицоНезарплатныеДоходыДляВыгрузки(Строка.Сотрудник, КомпонентыОбмена.ПараметрыКонвертации);
			КонецЕсли;
			
			НомерВедомостиНаВыплатуЗарплаты = Лев(Строка.НомерВедомости, 5) +"В" + Прав(Строка.НомерВедомости, 5);
			Строка.НомерВедомостиНаВыплатуЗарплаты = НомерВедомостиНаВыплатуЗарплаты;
	        Строка.ВидДохода = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Строка.ВидДоходаСсылка, "Наименование");
		КонецЦикла;
		
		ДобавитьИдентификаторПеречисленияПоСсылке(РасшифровкаПлатежа, "ВидОперации");
		ДобавитьИдентификаторПеречисленияПоСсылке(РасшифровкаПлатежа, "ВидПлатежа");
		
		ДанныеXDTO.Вставить("РасшифровкаПлатежа", РасшифровкаПлатежа);
		
		ДанныеXDTO.Вставить("Валюта", ЗарплатаКадры.ВалютаУчетаЗаработнойПлаты());
		
		ДанныеXDTO.КлючевыеСвойства.Вставить("Номер", Лев(ДанныеXDTO.КлючевыеСвойства.Номер, 5) +"В" + Прав(ДанныеXDTO.КлючевыеСвойства.Номер, 5));
		
		Если ТипЗнч(ДанныеИБ.ФактическийПлательщик) = Тип("СправочникСсылка.Организации") Тогда
		    ДанныеXDTO.Вставить("ФактическийПлательщик", Новый Структура("Значение, ИмяПКО", ДанныеИБ.ФактическийПлательщик, "Справочник_Организации"));
		Иначе
		    ДанныеXDTO.Вставить("ФактическийПлательщик", Новый Структура("Значение, ИмяПКО", ДанныеИБ.ФактическийПлательщик, "Справочник_ПодразделенияОрганизаций"));
		КонецЕсли;
КонецПроцедуры
