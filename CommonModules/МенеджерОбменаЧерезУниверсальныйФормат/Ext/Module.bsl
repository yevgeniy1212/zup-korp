Процедура ПКО_Документ_СведенияОНезачисленныхВзносахОтчислениях_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	Если СтекВыгрузки.Количество() > 1 Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДанныеИБ.Ссылка);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПеречислениеВзносовИОтчислений.Ссылка.Контрагент КАК Контрагент,
	|	ПеречислениеВзносовИОтчислений.Ссылка.БанковскийСчет КАК БанковскийСчет,
	|	ПеречислениеВзносовИОтчислений.Ссылка.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента,
	|	ПеречислениеВзносовИОтчислений.Ссылка.КодНазначенияПлатежа КАК КодНазначенияПлатежа,
	|	ПеречислениеВзносовИОтчислений.Ссылка.НазначениеПлатежа КАК НазначениеПлатежа
	|ИЗ
	|	Документ.СведенияОНезачисленныхВзносахОтчислениях КАК СведенияОНезачисленныхВзносахОтчислениях
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПеречислениеВзносовИОтчислений.ВедомостиНаПеречислениеВзносовИОтчислений КАК ПеречислениеВзносовИОтчислений
	|		ПО СведенияОНезачисленныхВзносахОтчислениях.Ведомость = ПеречислениеВзносовИОтчислений.Ведомость
	|ГДЕ
	|	СведенияОНезачисленныхВзносахОтчислениях.Ссылка = &Ссылка";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Количество() > 0 Тогда
		Пока Выборка.Следующий() Цикл
			ДанныеXDTO.Вставить("Контрагент", Выборка.Контрагент);
			ДанныеXDTO.Вставить("БанковскийСчетОрганизации", Выборка.БанковскийСчет);
			ДанныеXDTO.Вставить("БанковскийСчет", Выборка.БанковскийСчетКонтрагента);
			ДанныеXDTO.Вставить("НазначениеПлатежа", Выборка.НазначениеПлатежа);
			ДанныеXDTO.Вставить("КодНазначенияПлатежа", Выборка.КодНазначенияПлатежа);
		КонецЦикла;
	КонецЕсли;
	
	//Статус, Валюта
	ЗаполнитьОбщиеДанныеЗаявкиНаРасходДС(КомпонентыОбмена, ДанныеXDTO);
	
	ФизическиеЛица = ДанныеИБ.Сотрудники.ВыгрузитьКолонку("ФизическоеЛицо");
	
	//Сумма,
	//РасшифровкаПлатежа: Сумма, НомерВедомостиНаВозвратЗарплаты, ДатаВедомостиНаВозвратЗарплаты, Сотрудник, Месяц начисления
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ведомость", ДанныеИБ.Ссылка);
	Запрос.УстановитьПараметр("ФизическиеЛица", ФизическиеЛица);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.Регистратор.Номер КАК НомерВедомостиНаВозвратЗарплаты,
	|	НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.Регистратор.Дата КАК ДатаВедомостиНаВозвратЗарплаты,
	|	НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.Регистратор.Подразделение КАК ПодразделениеОрганизации,
	|	ВедомостьНаПеречислениеВзносовОтчислений.ПериодРегистрации КАК МесяцНачисления,
	|	СУММА(-НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.НалогВзнос) КАК Сумма,
	|	НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.ВидНалогаВзносаОтчисления КАК ВидОперацииСсылка,
	|	ВЫБОР
	|		КОГДА НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.ВидДохода = ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ПустаяСсылка)
	|			ТОГДА ЗНАЧЕНИЕ(Справочник.ВидыДоходов.ДоходыОтРаботодателя)
	|		ИНАЧЕ НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.ВидДохода
	|	КОНЕЦ КАК ВидДоходаСсылка,
	|	НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.ВидПлатежа КАК ВидПлатежаСсылка,
	|	НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.ФизическоеЛицо КАК Сотрудник
	|ИЗ
	|	РегистрНакопления.НалогиВзносыОтчисленияРасчетыСБюджетомИФондами КАК НалогиВзносыОтчисленияРасчетыСБюджетомИФондами
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ВедомостьНаПеречислениеВзносовОтчислений КАК ВедомостьНаПеречислениеВзносовОтчислений
	|		ПО (ВЫРАЗИТЬ(НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.Регистратор КАК Документ.СведенияОНезачисленныхВзносахОтчислениях).Ведомость = ВедомостьНаПеречислениеВзносовОтчислений.Ссылка)
	|ГДЕ
	|	НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.Регистратор = &Ведомость
	|
	|СГРУППИРОВАТЬ ПО
	|	НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.Регистратор.Номер,
	|	НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.Регистратор.Дата,
	|	НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.Регистратор.Подразделение,
	|	ВедомостьНаПеречислениеВзносовОтчислений.ПериодРегистрации,
	|	НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.ВидНалогаВзносаОтчисления,
	|	НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.ВидДохода,
	|	НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.ВидПлатежа,
	|	НалогиВзносыОтчисленияРасчетыСБюджетомИФондами.ФизическоеЛицо";
	
	РасшифровкаПлатежа = Запрос.Выполнить().Выгрузить();
	РасшифровкаПлатежа.Колонки.Добавить("ВидДохода");
	
	Для Каждого Строка Из РасшифровкаПлатежа Цикл
	   	Если Строка.ВидДоходаСсылка = Справочники.ВидыДоходов.ДоходыОтРаботодателя 
	   		ИЛИ Строка.ВидДоходаСсылка = Справочники.ВидыДоходов.ПустаяСсылка() Тогда
			Строка.Сотрудник = ФизическоеЛицоДляВыгрузки(Строка.Сотрудник, КомпонентыОбмена.ПараметрыКонвертации);
		Иначе 
			Строка.Сотрудник = ФизЛицоНезарплатныеДоходыДляВыгрузки(Строка.Сотрудник, КомпонентыОбмена.ПараметрыКонвертации);
		КонецЕсли;
		НомерВедомостиНаВозвратЗарплаты = Лев(Строка.НомерВедомостиНаВозвратЗарплаты, 5) +"В" + Прав(Строка.НомерВедомостиНаВозвратЗарплаты, 5);
		Строка.НомерВедомостиНаВозвратЗарплаты = НомерВедомостиНаВозвратЗарплаты;
	    Строка.ВидДохода = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Строка.ВидДоходаСсылка, "Наименование");
	КонецЦикла;
	
	ДобавитьИдентификаторПеречисленияПоСсылке(РасшифровкаПлатежа, "ВидОперации");
	ДобавитьИдентификаторПеречисленияПоСсылке(РасшифровкаПлатежа, "ВидПлатежа");
	
	ДанныеXDTO.Вставить("РасшифровкаПлатежа", РасшифровкаПлатежа);
	
	ДанныеXDTO.Вставить("Валюта", ЗарплатаКадры.ВалютаУчетаЗаработнойПлаты());
	
	ДанныеXDTO.Вставить("Сумма", ДанныеXDTO.РасшифровкаПлатежа.Итог("Сумма"));
	
	ДанныеXDTO.КлючевыеСвойства.Вставить("Номер", Лев(ДанныеXDTO.КлючевыеСвойства.Номер, 5) +"В" + Прав(ДанныеXDTO.КлючевыеСвойства.Номер, 5));
КонецПроцедуры
