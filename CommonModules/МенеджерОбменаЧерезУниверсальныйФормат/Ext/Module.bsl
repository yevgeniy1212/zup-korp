Процедура ПОД_Документ_СведенияОНезачисленнойЗарплате_ПриОбработке(ДанныеИБ, ИспользованиеПКО, КомпонентыОбмена)
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДанныеИБ.Ссылка);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СведенияОНезачисленнойЗарплате.Ведомость КАК Ведомость
	|ИЗ
	|	Документ.СведенияОНезачисленнойЗарплате КАК СведенияОНезачисленнойЗарплате
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПлатежноеПоручение.Ведомости КАК ПлатежноеПоручениеВедомости
	|		ПО (СведенияОНезачисленнойЗарплате.Ведомость = ПлатежноеПоручениеВедомости.Ведомость)
	|ГДЕ
	|	СведенияОНезачисленнойЗарплате.Ссылка = &Ссылка";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Количество() > 0 Тогда  
	    Пока Выборка.Следующий() Цикл
	        Если ТипЗнч(Выборка.Ведомость) = Тип("ДокументСсылка.ВедомостьНаВыплатуЗарплатыПеречислением")
	            ИЛИ ТипЗнч(Выборка.Ведомость) = Тип("ДокументСсылка.ВедомостьНаВыплатуЗарплатыВБанк") Тогда
	            ИспользованиеПКО.Документ_СведенияОНезачисленнойЗарплате = Истина;  
	        Иначе
	            ИспользованиеПКО.Документ_СведенияОНезачисленнойЗарплате = Ложь;
	        КонецЕсли;        	
	    КонецЦикла; 		
	Иначе
		ИспользованиеПКО.Документ_СведенияОНезачисленнойЗарплате = Ложь;
	КонецЕсли;
КонецПроцедуры
