Процедура ПКО_Документ_СведенияОНезачисленнойЗарплате_ПриОтправкеДанных(ДанныеИБ, ДанныеXDTO, КомпонентыОбмена, СтекВыгрузки)
	Если СтекВыгрузки.Количество() > 1 Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка", ДанныеИБ.Ссылка);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПлатежноеПоручениеВедомости.Ссылка.Контрагент КАК Контрагент,
	|	ПлатежноеПоручениеВедомости.Ссылка.БанковскийСчет КАК БанковскийСчет,
	|	ПлатежноеПоручениеВедомости.Ссылка.БанковскийСчетКонтрагента КАК БанковскийСчетКонтрагента,
	|	ПлатежноеПоручениеВедомости.Ссылка.КодНазначенияПлатежа КАК КодНазначенияПлатежа,
	|	ПлатежноеПоручениеВедомости.Ссылка.НазначениеПлатежа КАК НазначениеПлатежа
	|ИЗ
	|	Документ.СведенияОНезачисленнойЗарплате КАК СведенияОНезачисленнойЗарплате
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПлатежноеПоручение.Ведомости КАК ПлатежноеПоручениеВедомости
	|		ПО (СведенияОНезачисленнойЗарплате.Ведомость = ПлатежноеПоручениеВедомости.Ведомость)
	|ГДЕ
	|	СведенияОНезачисленнойЗарплате.Ссылка = &Ссылка";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Количество() > 0 Тогда
		Пока Выборка.Следующий() Цикл
			ДанныеXDTO.Вставить("Контрагент", Выборка.Контрагент);
