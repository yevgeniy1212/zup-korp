		ДобавитьИдентификаторПеречисленияПоСсылке(ТаблицаУдержаннаяЗарплата, "ВидОперации");
		
		ДанныеXDTO.Вставить("УдержаннаяЗарплата", ТаблицаУдержаннаяЗарплата);
		
		//РегламентированныеУдержания
		ТаблицаРегламентированныеУдержания = РезультатыЗапроса[7].Выгрузить();
	
		ДобавитьИдентификаторПеречисленияПоСсылке(ТаблицаРегламентированныеУдержания, "ВидОперации");
		
		ДанныеXDTO.Вставить("РегламентированныеУдержания", ТаблицаРегламентированныеУдержания);
		
		// ПеняПоВзносамИОтчислениям
		ТаблицаПеняПоВзносамИОтчислениям = РезультатыЗапроса[9].Выгрузить();
	
		ДобавитьИдентификаторПеречисленияПоСсылке(ТаблицаПеняПоВзносамИОтчислениям, "ВидОперации");
		ДобавитьИдентификаторПеречисленияПоСсылке(ТаблицаПеняПоВзносамИОтчислениям, "ВидПлатежа");
		
		ДанныеXDTO.Вставить("ПеняПоВзносамИОтчислениям", ТаблицаПеняПоВзносамИОтчислениям);
КонецПроцедуры
