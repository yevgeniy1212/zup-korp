			Дело.ПараметрыФормы.Вставить("СписокФайлов", СписокФайлов.ВыгрузитьЗначения());
			
			Дело.Форма          = "ОбщаяФорма.СохранениеПодписанныхФайлов";
			
		КонецЕсли;
		
	КонецЦикла;
	
