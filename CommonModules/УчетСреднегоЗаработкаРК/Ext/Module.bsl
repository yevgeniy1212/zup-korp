
#Область ПолучениеДанныхДляРасчетаСреднегоЗаработка

// Получает таблицу коэффициентов по месяцам, 
// которые необходимо применить к среднему заработку из-за проводимой индексации заработка.
//
// Параметры:
//	ИсходныеДанные - таблица значений, 
//		созданная конструктором см. ПустаяТаблицаИсходныхДанныхРасчетаОбщегоСреднегоЗаработка
//	КоэффициентУчитываетПоследующиеИндексации 
//		- если Истина, коэффициент на конкретный месяц учитывает все индексации произошедшие ПОСЛЕ него (для расчета
//		показателя КоэффициентИндексации)
//		- если Ложь, коэффициент на конкретный месяц учитывает все индексации произошедшие ДО него.
//
Функция ДанныеИндексации(ИсходныеДанные, КоэффициентУчитываетПоследующиеИндексации = Ложь) Экспорт
	
	ДанныеИндексации = Новый ТаблицаЗначений;
	ДанныеИндексации.Колонки.Добавить("Сотрудник");
	ДанныеИндексации.Колонки.Добавить("Период");
	
	Если КоэффициентУчитываетПоследующиеИндексации Тогда
		ДанныеИндексации.Колонки.Добавить("ИдентификаторСтроки");
		ДанныеИндексации.Колонки.Добавить("Коэффициент");
		ДанныеИндексации.Колонки.Добавить("ДатаНачала");
		ДанныеИндексации.Колонки.Добавить("ДатаОкончания");
	Иначе
		ДанныеИндексации.Колонки.Добавить("КоэффициентИндексации");
	КонецЕсли;
	
	Если ИсходныеДанные.Количество() = 0 Тогда
		Возврат ДанныеИндексации;
	КонецЕсли;
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИсходныеДанные.Сотрудник КАК Сотрудник,
		|	ИсходныеДанные.ДатаНачалаСобытия КАК ДатаНачалаСобытия,
		|	ИсходныеДанные.НачалоПериодаРасчетаСреднего КАК НачалоПериодаРасчетаСреднего,
		|	ИсходныеДанные.ОкончаниеПериодаРасчетаСреднего КАК ОкончаниеПериодаРасчетаСреднего,
		|	0 КАК ИдентификаторСтроки
		|ПОМЕСТИТЬ ВТИсходныеДанные
		|ИЗ
		|	&ИсходныеДанные КАК ИсходныеДанные
		|;
		| 
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсходныеДанные.Сотрудник КАК Сотрудник,
		|	ИсходныеДанные.ДатаНачалаСобытия КАК ДатаНачалаСобытия,
		|	МИНИМУМ(ИсходныеДанные.НачалоПериодаРасчетаСреднего) КАК НачалоПериодаРасчетаСреднего,
		|	МАКСИМУМ(ИсходныеДанные.ОкончаниеПериодаРасчетаСреднего) КАК ОкончаниеПериодаРасчетаСреднего,
		// для получения кадровых данных ограничения по периодам (в рамках среднего) не используем,
		// т.к необходимо видеть кадровые на начальную и последнюю дату (т.е учитывать предыдущую и последующую историю перемещений)
		|	ДАТАВРЕМЯ(1, 1, 1) КАК НачалоПериодаРасчетаДляКадрового,
		|	ДАТАВРЕМЯ(3999, 1, 1) КАК ОкончаниеПериодаРасчетаДляКадрового,
		|	0 КАК ИдентификаторСтроки
		|ПОМЕСТИТЬ ВТИсходныеДанныеДляТаблицаПериодов
		|ИЗ
		|	ВТИсходныеДанные КАК ИсходныеДанные
		|
		|СГРУППИРОВАТЬ ПО
		|	ИсходныеДанные.Сотрудник,
		|	ИсходныеДанные.ДатаНачалаСобытия,
		|	0
		|;
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МИНИМУМ(НАЧАЛОПЕРИОДА(ИсходныеДанные.НачалоПериодаРасчетаСреднего, МЕСЯЦ)) КАК НачалоПервогоИнтервала,
		|	МАКСИМУМ(КОНЕЦПЕРИОДА(ИсходныеДанные.ОкончаниеПериодаРасчетаСреднего, МЕСЯЦ)) КАК ОкончаниеПоследнегоИнтервала
		|ИЗ
		|	ВТИсходныеДанные КАК ИсходныеДанные";
		
	Если КоэффициентУчитываетПоследующиеИндексации Тогда
		
		// в случае получения показателя используем ИдентификаторСтроки расчета для корректной подстановки коэффициента в нужную строку расчета;
		// вместо ВТПериоды будем использовать ПериодДействияНачало для определения дат, на которые необходимо получить коэффициент
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "0 КАК ИдентификаторСтроки", 
												 "ИсходныеДанные.ИдентификаторСтроки КАК ИдентификаторСтроки,
												 |ИсходныеДанные.ПериодДействияНачало КАК ПериодДействияНачало");
		
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "0", 
												 "ИсходныеДанные.ИдентификаторСтроки,
												 |ИсходныеДанные.ПериодДействияНачало");
		
	КонецЕсли;
	
	Запрос.УстановитьПараметр("ИсходныеДанные", ИсходныеДанные);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат ДанныеИндексации;
	КонецЕсли;

	Сотрудник = ИсходныеДанные[0].Сотрудник;
	
	Если КоэффициентУчитываетПоследующиеИндексации Тогда
		ПериодРегистрации = НачалоМесяца(ИсходныеДанные[0].ПериодДействияНачало);
	Иначе
		ПериодРегистрации = НачалоМесяца(ИсходныеДанные[0].ДатаНачалаСобытия);
	КонецЕсли;
	
	ДанныеСотрудника = КадровыйУчет.КадровыеДанныеСотрудников(Ложь, Сотрудник, "Организация, ДатаПриема", ПериодРегистрации);
	
	Если ДанныеСотрудника.Количество() = 0 Тогда
		ВызватьИсключение НСтр("ru = 'Невозможно получить данные порядка учета среднего заработка из-за отсутствия необходимых данных кадрового учета'");
	КонецЕсли;
	
	Организация = ДанныеСотрудника[0].Организация;
	ДатаПриема = ДанныеСотрудника[0].ДатаПриема;
	
	УчитыватьИзмененияРазряда = Истина;
	УчитыватьИзмененияПодразделения = ЗарплатаКадрыРКПовтИсп.ВариантУчетаКадровыхПерестановок(Организация, ПериодРегистрации) = Перечисления.ВариантыУчетаКадровыхПерестановок.ДолжностьРазрядПодразделение;
	РассчитыватьКоэффициентИндексацииВПределахКадровыхПерестановок = ЗарплатаКадрыРКПовтИсп.РассчитыватьКоэффициентИндексацииВПределахКадровыхПерестановок(Организация, ПериодРегистрации);
	
	// поддержим существовавший расчет
	Если НЕ РассчитыватьКоэффициентИндексацииВПределахКадровыхПерестановок Тогда
		УчитыватьИзмененияРазряда = Ложь;
		УчитыватьИзмененияПодразделения = Истина;
	КонецЕсли;
	
	ЭтоКоэффициентУчитываетПоследующиеИндексацииВПределахКадровых = КоэффициентУчитываетПоследующиеИндексации И РассчитыватьКоэффициентИндексацииВПределахКадровыхПерестановок;
	
	// при расчете периоды события не учитываем кадровые перемещения (РассчитыватьКоэффициентИндексацииВПределахКадровыхПерестановок поддержим существовавший расчет)
	Если НЕ ЭтоКоэффициентУчитываетПоследующиеИндексацииВПределахКадровых Тогда
	
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		
		// Создаем ВТ с месяцами
		ЗарплатаКадрыОбщиеНаборыДанных.СоздатьВТПериоды(МенеджерВременныхТаблиц, Выборка.НачалоПервогоИнтервала, Выборка.ОкончаниеПоследнегоИнтервала);
		
		// Получим кадровые данные
		ОписаниеФильтра = ЗарплатаКадрыОбщиеНаборыДанных.ОписаниеФильтраДляСоздатьВТИмяРегистра(
			"ВТИсходныеДанныеДляТаблицаПериодов", 
			"Сотрудник");
			
		ОписаниеФильтра.СоответствиеИзмеренийРегистраИзмерениямФильтра.Вставить("ДатаНачала", "НачалоПериодаРасчетаДляКадрового");
		ОписаниеФильтра.СоответствиеИзмеренийРегистраИзмерениямФильтра.Вставить("ДатаОкончания", "ОкончаниеПериодаРасчетаДляКадрового");
		
		ПараметрыПостроения = ЗарплатаКадрыПериодическиеРегистры.ПараметрыПостроенияДляСоздатьВТИмяРегистра();
        ПараметрыПостроения.ИсключатьНеИспользуемыеПоля = Ложь;
		// не используем параметр ВключатьЗаписиНаНачалоПериода, тк он не используется в построении запроса для интервального регистра в СоздатьВТИмяРегистраПериоды
		//ПараметрыПостроения.ВключатьЗаписиНаНачалоПериода = Истина;
		
		ЗарплатаКадрыПериодическиеРегистры.СоздатьВТИмяРегистраПериоды(
			"КадроваяИсторияСотрудников",
			МенеджерВременныхТаблиц,
			Истина,
			ОписаниеФильтра,
			ПараметрыПостроения,
			"ВТИнтервалыКадроваяИсторияСотрудников");
			
		ЗарплатаКадрыПериодическиеРегистры.СоздатьВТИмяРегистраПериоды(
			"РазрядыКатегорииСотрудников",
			МенеджерВременныхТаблиц,
			Истина,
			ОписаниеФильтра,
			,
			"ВТИнтервалыРазрядыКатегорииСотрудников");
			
		Запрос.Текст = "
			|ВЫБРАТЬ
			|	ИсходныеДанныеДляТаблицаПериодов.Сотрудник КАК Сотрудник,
			|	ИнтервалыКадроваяИсторияСотрудников.Должность КАК Должность,
			|	ИнтервалыКадроваяИсторияСотрудников.Подразделение КАК Подразделение,
			|	ВЫБОР
			|		КОГДА ИнтервалыКадроваяИсторияСотрудников.ЭтоВозвратноеСобытие
			|			ТОГДА ИнтервалыКадроваяИсторияСотрудников.НачалоПериода
			|		ИНАЧЕ ИнтервалыКадроваяИсторияСотрудников.Период
			|	КОНЕЦ КАК ПериодЗаписи,
			|	ИнтервалыКадроваяИсторияСотрудников.ВидСобытия КАК ВидСобытия,
			|	ИнтервалыКадроваяИсторияСотрудников.НачалоПериода КАК НачалоПериода,
			|	ИнтервалыКадроваяИсторияСотрудников.КонецПериода КАК КонецПериода,
			|	ИсходныеДанныеДляТаблицаПериодов.НачалоПериодаРасчетаСреднего КАК НачалоПериодаРасчетаСреднего,
			|	ИсходныеДанныеДляТаблицаПериодов.ОкончаниеПериодаРасчетаСреднего КАК ОкончаниеПериодаРасчетаСреднего,
			|	ИсходныеДанныеДляТаблицаПериодов.ОкончаниеПериодаРасчетаДляКадрового КАК ОкончаниеПериодаРасчетаДляКадрового,
			// дата начала кадрового события
			|	ИнтервалыКадроваяИсторияСотрудников.НачалоПериода КАК Период
			|ПОМЕСТИТЬ ВТКадровыеПеремещенияЗаПериодДанные
			|ИЗ
			|	ВТИсходныеДанныеДляТаблицаПериодов КАК ИсходныеДанныеДляТаблицаПериодов
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТИнтервалыКадроваяИсторияСотрудников КАК ИнтервалыКадроваяИсторияСотрудников
			|		ПО ИсходныеДанныеДляТаблицаПериодов.Сотрудник = ИнтервалыКадроваяИсторияСотрудников.Сотрудник
			|
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	КадровыеПеремещения.Сотрудник КАК Сотрудник,
			|	КадровыеПеремещения.Должность КАК Должность,
			|	КадровыеПеремещения.Подразделение КАК Подразделение,
			|	КадровыеПеремещения.ВидСобытия КАК ВидСобытия,
			|	КадровыеПеремещения.ПериодЗаписи КАК ПериодЗаписи,
			|	КадровыеПеремещения.НачалоПериода КАК НачалоПериода,
			|	КадровыеПеремещения.КонецПериода КАК КонецПериода,
			|	КадровыеПеремещения.НачалоПериодаРасчетаСреднего КАК НачалоПериодаРасчетаСреднего,
			|	КадровыеПеремещения.ОкончаниеПериодаРасчетаСреднего КАК ОкончаниеПериодаРасчетаСреднего,
			|	КадровыеПеремещения.ОкончаниеПериодаРасчетаДляКадрового КАК ОкончаниеПериодаРасчетаДляКадрового,
			|	МАКСИМУМ(ЕСТЬNULL(КадровыеПеремещенияПредыдущая.ПериодЗаписи, ДАТАВРЕМЯ(1,1,1)))  КАК ПериодПредыдущейЗаписи,
			// дата начала кадрового события
			|	КадровыеПеремещения.Период КАК Период
			|ПОМЕСТИТЬ ВТКадровыеПеремещенияПериодыПредыдущейЗаписи
			|ИЗ
			|	ВТКадровыеПеремещенияЗаПериодДанные КАК КадровыеПеремещения
			|	ЛЕВОЕ СОЕДИНЕНИЕ ВТКадровыеПеремещенияЗаПериодДанные КАК КадровыеПеремещенияПредыдущая
			|		ПО КадровыеПеремещения.Сотрудник = КадровыеПеремещенияПредыдущая.Сотрудник
			|           И (КадровыеПеремещения.ПериодЗаписи > КадровыеПеремещенияПредыдущая.ПериодЗаписи)
			|
			|СГРУППИРОВАТЬ ПО
			|	КадровыеПеремещения.Сотрудник,
			|	КадровыеПеремещения.Должность,
			|	КадровыеПеремещения.Подразделение,
			|	КадровыеПеремещения.ВидСобытия,
			|	КадровыеПеремещения.ПериодЗаписи,
			|	КадровыеПеремещения.НачалоПериода,
			|	КадровыеПеремещения.КонецПериода,
			|	КадровыеПеремещения.НачалоПериода,
			|	КадровыеПеремещения.КонецПериода,
			|	КадровыеПеремещения.НачалоПериодаРасчетаСреднего,
			|	КадровыеПеремещения.ОкончаниеПериодаРасчетаСреднего,
			|	КадровыеПеремещения.ОкончаниеПериодаРасчетаДляКадрового,
			|	КадровыеПеремещения.Период
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ
			|	КадровыеПеремещения.Сотрудник КАК Сотрудник,
			|	КадровыеПеремещения.Должность КАК Должность,
			|	КадровыеПеремещения.Подразделение КАК Подразделение,
			|	КадровыеПеремещения.ПериодЗаписи КАК ПериодЗаписи,
			|	КадровыеПеремещения.ПериодПредыдущейЗаписи КАК ПериодПредыдущейЗаписи,
			|	ВЫБОР
			|		КОГДА КадровыеПеремещения.ПериодПредыдущейЗаписи <= КадровыеПеремещения.НачалоПериодаРасчетаСреднего
			|			ТОГДА ДАТАВРЕМЯ(1, 1, 1)
			|		ИНАЧЕ КадровыеПеремещения.НачалоПериода
			|	КОНЕЦ КАК НачалоПериода,
			|	ВЫБОР
			|		КОГДА НАЧАЛОПЕРИОДА(КадровыеПеремещения.КонецПериода, ДЕНЬ) = КадровыеПеремещения.ОкончаниеПериодаРасчетаДляКадрового
			|			ТОГДА ДАТАВРЕМЯ(3999, 1, 1)
			|		ИНАЧЕ КадровыеПеремещения.КонецПериода
			|	КОНЕЦ КАК КонецПериода,
			|	КадровыеПеремещения.Период КАК Период
			|ПОМЕСТИТЬ ВТКадровыеПеремещенияЗаПериод
			|ИЗ
			|	ВТКадровыеПеремещенияПериодыПредыдущейЗаписи КАК КадровыеПеремещения
			// анализируем НачалоПериода и КонецПериода - как периоды фактического наступления события (без сдвигов)
			|ГДЕ
			|	(КадровыеПеремещения.НачалоПериода МЕЖДУ КадровыеПеремещения.НачалоПериодаРасчетаСреднего И КадровыеПеремещения.ОкончаниеПериодаРасчетаСреднего
			|			ИЛИ КадровыеПеремещения.КонецПериода МЕЖДУ КадровыеПеремещения.НачалоПериодаРасчетаСреднего И КадровыеПеремещения.ОкончаниеПериодаРасчетаСреднего)
			|	И КадровыеПеремещения.ВидСобытия = ЗНАЧЕНИЕ(Перечисление.ВидыКадровыхСобытий.Перемещение)
			|
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|УНИЧТОЖИТЬ ВТКадровыеПеремещенияЗаПериодДанные
			|
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|УНИЧТОЖИТЬ ВТКадровыеПеремещенияПериодыПредыдущейЗаписи
			|
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
