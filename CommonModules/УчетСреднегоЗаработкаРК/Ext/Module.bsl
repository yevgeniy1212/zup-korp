			|		ПО КадровыеПеремещенияЗаПериод.Сотрудник = ИсходныеДанные.Сотрудник
			// будем использовать только записи попадающие в интересующий период (ранее получены кадровые данные без ограничений по периоду)
			|			И ((КадровыеПеремещенияЗаПериод.НачалоПериода МЕЖДУ ИсходныеДанные.НачалоПериодаРасчетаСреднего И ИсходныеДанные.ОкончаниеПериодаРасчетаСреднего
			|				ИЛИ КадровыеПеремещенияЗаПериод.КонецПериода МЕЖДУ ИсходныеДанные.НачалоПериодаРасчетаСреднего И ИсходныеДанные.ОкончаниеПериодаРасчетаСреднего)
			// или внутри периода было перемещение, при этом первоначальное событие было вне рамок периода
			|           ИЛИ ((КадровыеПеремещенияЗаПериод.НачалоПериода = ДАТАВРЕМЯ(1, 1, 1)
			|           	ИЛИ КадровыеПеремещенияЗаПериод.КонецПериода = ДАТАВРЕМЯ(3999, 1, 1))
			|				И КадровыеПеремещенияЗаПериод.Период МЕЖДУ ИсходныеДанные.НачалоПериодаРасчетаСреднего И ИсходныеДанные.ОкончаниеПериодаРасчетаСреднего)) 
			|
			|ГДЕ
			|	КадровыеПеремещенияЗаПериод.Подразделение <> ИнтервалыКадроваяИсторияСотрудников.Подразделение
			|", "") + "
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			// при расчете коэффициента в рамках периода события среднего рассматриваем одно кадровое перемещение
			|" + ?(РассчитыватьКоэффициентИндексацииВПределахКадровыхПерестановок И НЕ КоэффициентУчитываетПоследующиеИндексации, "
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ВсеДатыКадровыхПерестановок.Сотрудник КАК Сотрудник,
			|	ВсеДатыКадровыхПерестановок.Период КАК Период,
			|	ВсеДатыКадровыхПерестановок.НачалоПериода КАК НачалоПериода,
			|	ВсеДатыКадровыхПерестановок.КонецПериода КАК КонецПериода
			|ИЗ
			|	ВТВсеДатыКадровыхПерестановок КАК ВсеДатыКадровыхПерестановок
			|
			|УПОРЯДОЧИТЬ ПО
			|	ВсеДатыКадровыхПерестановок.Период
			|
			|", "
			|
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ВсеДатыКадровыхПерестановок.Сотрудник КАК Сотрудник,
			// при расчете коэффициента в рамках периода события находим самое раннее событие смены 
			|	" + ?(КоэффициентУчитываетПоследующиеИндексации, "МИНИМУМ", "МАКСИМУМ") + "(ВсеДатыКадровыхПерестановок.Период) КАК Период
			|ПОМЕСТИТЬ ВТМаксимумыДатКадровыхПерестановок
			|ИЗ
			|	ВТВсеДатыКадровыхПерестановок КАК ВсеДатыКадровыхПерестановок
			|
			|СГРУППИРОВАТЬ ПО
			|	ВсеДатыКадровыхПерестановок.Сотрудник
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ВсеДатыКадровыхПерестановок.Сотрудник КАК Сотрудник,
			|	ВсеДатыКадровыхПерестановок.Период КАК Период,
			|	ВсеДатыКадровыхПерестановок.НачалоПериода КАК НачалоПериода,
			|	ВсеДатыКадровыхПерестановок.КонецПериода КАК КонецПериода
			|ПОМЕСТИТЬ ВТПериодыКадровыхПерестановок
			|ИЗ
			|	ВТВсеДатыКадровыхПерестановок КАК ВсеДатыКадровыхПерестановок
			|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТМаксимумыДатКадровыхПерестановок КАК МаксимумыДатКадровыхПерестановок
			|		ПО ВсеДатыКадровыхПерестановок.Сотрудник = МаксимумыДатКадровыхПерестановок.Сотрудник
			|			И ВсеДатыКадровыхПерестановок.Период = МаксимумыДатКадровыхПерестановок.Период
			|
			|ИНДЕКСИРОВАТЬ ПО
			|	ВсеДатыКадровыхПерестановок.Сотрудник,
			|   ВсеДатыКадровыхПерестановок.Период") + "
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|УНИЧТОЖИТЬ ВТИнтервалыКадроваяИсторияСотрудников
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|УНИЧТОЖИТЬ ВТКадровыеПеремещенияЗаПериод
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|УНИЧТОЖИТЬ ВТВсеДатыКадровыхПерестановок
			|" + ?(КоэффициентУчитываетПоследующиеИндексации И РассчитыватьКоэффициентИндексацииВПределахКадровыхПерестановок, "
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|УНИЧТОЖИТЬ ВТМаксимумыДатКадровыхПерестановок
			|", "") + "
			|" + ?(УчитыватьИзмененияРазряда, "
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|УНИЧТОЖИТЬ ВТИнтервалыРазрядыКатегорииСотрудников
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|УНИЧТОЖИТЬ ВТИзменениеРазрядовЗаПериод
			|", "") + "
			|";
			
	    // обработаем таблицу периодов, чтобы не было "разрывов" между перидами строк при включенной настройке РассчитыватьКоэффициентИндексацииВПределахКадровыхПерестановок 
		Если РассчитыватьКоэффициентИндексацииВПределахКадровыхПерестановок И НЕ КоэффициентУчитываетПоследующиеИндексации Тогда
			
			ПериодыКадровыхПерестановок = Запрос.Выполнить().Выгрузить();
			
			КоличествоСтрок = ПериодыКадровыхПерестановок.Количество();
			
			// в общем случае при наличии учитываемого кадрового должно быть как минимум две строки: прием и перемещение.
			Если КоличествоСтрок > 1 Тогда
				
				СчетчикСтрок = 0;
				
				// внутри могут быть неучитываемые перемещения (например, не учитывается изменения подразделения в среднем)
				// тогда могут возникать "разрывы" по периодам, исправим это, сделав непрерывными периоды между строками
				Для Каждого СтрокаТаблицыПериодов Из ПериодыКадровыхПерестановок Цикл
					
					Если СчетчикСтрок = 0 Тогда
						
						СчетчикСтрок = СчетчикСтрок + 1;
						
						КонецПериода  = СтрокаТаблицыПериодов.КонецПериода;
						
						Продолжить;
						
					КонецЕсли;
					
					// исправим "разрывы" в датах строк
					СтрокаТаблицыПериодов.НачалоПериода = НачалоДня(КонецПериода + 86400);
					
					СчетчикСтрок = СчетчикСтрок + 1;
					
					//НачалоПериода = СтрокаТаблицыПериодов.НачалоПериода;
					КонецПериода  = СтрокаТаблицыПериодов.КонецПериода;
					
				КонецЦикла;
				
				// проверим в последней строке КонецПериода 01.01.3999
				Если ПериодыКадровыхПерестановок[КоличествоСтрок - 1].КонецПериода <> Дата('39990101') Тогда
					
					ПериодыКадровыхПерестановок[КоличествоСтрок - 1].КонецПериода = Дата('39990101');
					
				КонецЕсли;
				
			// обработаем ситуацию, когда прием имеет дату окончания внутри периода расчета (из-за неучитываемого кадрового перемещения), 
			// для корреткности применения коэффициента будем считать такие записи действующие на весь период среднего
			ИначеЕсли ПериодыКадровыхПерестановок.Количество() = 1 Тогда
				
				ПериодыКадровыхПерестановок[0].КонецПериода = Дата('39990101');
				
			КонецЕсли;
			
			Запрос.УстановитьПараметр("ПериодыКадровыхПерестановок", ПериодыКадровыхПерестановок);
			Запрос.Текст = "
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
		    |	ВсеДатыКадровыхПерестановок.Сотрудник КАК Сотрудник,
		    |	ВсеДатыКадровыхПерестановок.Период КАК Период,
		    |	ВсеДатыКадровыхПерестановок.НачалоПериода КАК НачалоПериода,
		    |	ВсеДатыКадровыхПерестановок.КонецПериода КАК КонецПериода
		    |ПОМЕСТИТЬ ВТПериодыКадровыхПерестановок
		    |ИЗ
		    |	&ПериодыКадровыхПерестановок КАК ВсеДатыКадровыхПерестановок
			|
			|ИНДЕКСИРОВАТЬ ПО
			|	ВсеДатыКадровыхПерестановок.Сотрудник,
			|   ВсеДатыКадровыхПерестановок.Период";
		
		КонецЕсли;

		Запрос.Выполнить();
	
	КонецЕсли;	
	
	// Выбираем коэффициенты индексации заработка: 
	// - для расчета показателя КоэффициентИндексации - для каждой строки начислений 
	// выборка коэффициентов всех индексаций, случившихся ПОСЛЕ даты начала события
	// - для индексации выплат, учитываемых при расчете периода среднего заработка, 
	// для каждого месяца выбираем коэффициенты индексаций, случившихся ДО даты начала события

	Если КоэффициентУчитываетПоследующиеИндексации Тогда
		
		Если РассчитыватьКоэффициентИндексацииВПределахКадровыхПерестановок Тогда
			
			КоэффициентыИндексацииЗаработкаТекст = 
				"ВЫБРАТЬ
				|	ИсходныеДанные.Сотрудник КАК Сотрудник,
				|	ИсходныеДанные.ДатаНачалаСобытия,
				|	ИсходныеДанные.ИдентификаторСтроки,
				// При расчете показателя начисления принимаем во внимание период действия начало начислений
				|	ИсходныеДанные.ПериодДействияНачало КАК Период,
				|	МИНИМУМ(КоэффициентИндексацииЗаработка.ДатаИндексации) КАК ДатаИндексации,
				|	МАКСИМУМ(ЕСТЬNULL(КоэффициентИндексацииЗаработка.Период, ДАТАВРЕМЯ(1,1,1))) КАК ПериодИндексации
				|ПОМЕСТИТЬ ВТКоэффициентыИндексацииЗаработка
				|ИЗ
				|	ВТИсходныеДанные КАК ИсходныеДанные
				|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КоэффициентИндексацииЗаработка КАК КоэффициентИндексацииЗаработка
				|		ПО ИсходныеДанные.Сотрудник = КоэффициентИндексацииЗаработка.Сотрудник
				|			И (ИсходныеДанные.ПериодДействияНачало >= КоэффициентИндексацииЗаработка.Период)
				|			И (КоэффициентИндексацииЗаработка.Период >= ИсходныеДанные.НачалоПериодаРасчетаСреднего И КоэффициентИндексацииЗаработка.Период < ИсходныеДанные.ОкончаниеПериодаРасчетаСреднего)
				|				И КоэффициентИндексацииЗаработка.Период >= ИсходныеДанные.ДатаНачалаСобытия
				|				И КоэффициентИндексацииЗаработка.Период = КоэффициентИндексацииЗаработка.ДатаИндексации
				|
				|СГРУППИРОВАТЬ ПО
				|	ИсходныеДанные.Сотрудник,
				|	ИсходныеДанные.ДатаНачалаСобытия,
				|	ИсходныеДанные.ИдентификаторСтроки,
				|	ИсходныеДанные.ПериодДействияНачало
				|
				|ИНДЕКСИРОВАТЬ ПО
				|	ИсходныеДанные.Сотрудник,
				|	ИсходныеДанные.ПериодДействияНачало";
				
				
		Иначе
			
			// поддержим существовавший расчет
			КоэффициентыИндексацииЗаработкаТекст = 
				"ВЫБРАТЬ
				|	ИсходныеДанные.Сотрудник КАК Сотрудник,
				|	ИсходныеДанные.ДатаНачалаСобытия,
				|	ИсходныеДанные.ИдентификаторСтроки,
				// При расчете показателя начисления принимаем во внимание период действия начало начислений
				|	ИсходныеДанные.ПериодДействияНачало КАК Период,
				|	КоэффициентИндексацииЗаработка.ДатаИндексации КАК ДатаИндексации,
				|	МАКСИМУМ(ЕСТЬNULL(КоэффициентИндексацииЗаработка.Период, ДАТАВРЕМЯ(1,1,1))) КАК ПериодИндексации
				|ПОМЕСТИТЬ ВТКоэффициентыИндексацииЗаработка
				|ИЗ
				|	ВТИсходныеДанные КАК ИсходныеДанные
				|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КоэффициентИндексацииЗаработка КАК КоэффициентИндексацииЗаработка
				|		ПО ИсходныеДанные.Сотрудник = КоэффициентИндексацииЗаработка.Сотрудник
				|			И (ИсходныеДанные.ПериодДействияНачало >= КоэффициентИндексацииЗаработка.Период)
				|			И (КоэффициентИндексацииЗаработка.Период >= ИсходныеДанные.НачалоПериодаРасчетаСреднего И КоэффициентИндексацииЗаработка.Период < ИсходныеДанные.ОкончаниеПериодаРасчетаСреднего)
				|				И КоэффициентИндексацииЗаработка.Период >= ИсходныеДанные.ДатаНачалаСобытия
				// выбираем одну актуальную на дату ввода индексации запись
				|				И КоэффициентИндексацииЗаработка.Период = КоэффициентИндексацииЗаработка.ДатаИндексации
				|
				|СГРУППИРОВАТЬ ПО
				|	ИсходныеДанные.Сотрудник,
				|	ИсходныеДанные.ДатаНачалаСобытия,
				|	ИсходныеДанные.ИдентификаторСтроки,
				|	КоэффициентИндексацииЗаработка.ДатаИндексации,
				|	ИсходныеДанные.ПериодДействияНачало
				|
				|ИНДЕКСИРОВАТЬ ПО
				|	ИсходныеДанные.Сотрудник,
				|	ИсходныеДанные.ПериодДействияНачало";
				
		КонецЕсли;
		
	Иначе
		
		Если РассчитыватьКоэффициентИндексацииВПределахКадровыхПерестановок Тогда
			
			КоэффициентыИндексацииЗаработкаТекст = "
				|ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	КоэффициентыИндексацииЗаработка.Сотрудник КАК Сотрудник,
				|	ПериодыКадровыхПерестановок.НачалоПериода КАК НачалоПериода,
				|	ПериодыКадровыхПерестановок.КонецПериода КАК КонецПериода,
				|	МАКСИМУМ(КоэффициентыИндексацииЗаработка.Период) КАК Период
				|ПОМЕСТИТЬ ВТПериодыИндексации
				|
				|ИЗ
				|	ВТИсходныеДанные КАК ИсходныеДанные
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.КоэффициентИндексацииЗаработка КАК КоэффициентыИндексацииЗаработка
				|		ПО ИсходныеДанные.Сотрудник = КоэффициентыИндексацииЗаработка.Сотрудник
				|			И ИсходныеДанные.НачалоПериодаРасчетаСреднего < КоэффициентыИндексацииЗаработка.Период
				|			И ИсходныеДанные.ДатаНачалаСобытия > КоэффициентыИндексацииЗаработка.Период
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыКадровыхПерестановок КАК ПериодыКадровыхПерестановок
				|		ПО ИсходныеДанные.Сотрудник = ПериодыКадровыхПерестановок.Сотрудник
				|			И (КоэффициентыИндексацииЗаработка.Период >= ПериодыКадровыхПерестановок.НачалоПериода)
				|			И (КоэффициентыИндексацииЗаработка.Период <= ПериодыКадровыхПерестановок.КонецПериода)
				|
				|ГДЕ
				|	КоэффициентыИндексацииЗаработка.Коэффициент > 1
				|
				|СГРУППИРОВАТЬ ПО
				|	КоэффициентыИндексацииЗаработка.Сотрудник,
				|	ПериодыКадровыхПерестановок.НачалоПериода,
				|	ПериодыКадровыхПерестановок.КонецПериода
				|
				|;
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	КоэффициентыИндексацииЗаработка.Сотрудник КАК Сотрудник,
				|	КоэффициентыИндексацииЗаработка.ДатаИндексации КАК ДатаИндексации,
				|	ВЫБОР
				|		КОГДА КоэффициентыИндексацииЗаработка.КоэффициентИндексации < 1
				|			ТОГДА 1
				|		ИНАЧЕ ВЫБОР 
				|				КОГДА КоэффициентыИндексацииЗаработка.ДатаИндексации = ПериодыИндексации.НачалоПериода
				|					ТОГДА 1
				|				ИНАЧЕ КоэффициентыИндексацииЗаработка.КоэффициентИндексации
				|			  КОНЕЦ
				|	КОНЕЦ КАК КоэффициентИндексации
				|ПОМЕСТИТЬ ВТКоэффициентыИндексацииЗаработкаОбщая
				|
				|ИЗ
				|	РегистрСведений.КоэффициентИндексацииЗаработка КАК КоэффициентыИндексацииЗаработка
				|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТПериодыИндексации КАК ПериодыИндексации
				|		ПО КоэффициентыИндексацииЗаработка.Сотрудник = ПериодыИндексации.Сотрудник
				|			И КоэффициентыИндексацииЗаработка.Период = ПериодыИндексации.Период
				|			И КоэффициентыИндексацииЗаработка.ДатаИндексации МЕЖДУ ПериодыИндексации.НачалоПериода И ПериодыИндексации.КонецПериода
				|
				|ОБЪЕДИНИТЬ
				// добавим строки для кадровых перемещений без индексации (коэффициент равен 1)
				|
				|ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	ПериодыКадровыхПерестановок.Сотрудник,
				|	ПериодыКадровыхПерестановок.Период,
				|	1
				|ИЗ
				|	ВТПериодыКадровыхПерестановок КАК ПериодыКадровыхПерестановок
				|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КоэффициентИндексацииЗаработка КАК КоэффициентыИндексацииЗаработка
				|		ПО ПериодыКадровыхПерестановок.Сотрудник = КоэффициентыИндексацииЗаработка.Сотрудник
				// в запросе будем анализировать все кадровые перемещения (как на начало месяца, которые равны индексации, так и в течение месяца, так как они также влияют на коэффицент индексации месяца)
				// в условии ГДЕ отсечем ненужные записи
				|			И (ПериодыКадровыхПерестановок.Период = КоэффициентыИндексацииЗаработка.Период
				|				ИЛИ НАЧАЛОПЕРИОДА(ПериодыКадровыхПерестановок.Период, МЕСЯЦ) = КоэффициентыИндексацииЗаработка.Период)
				|
				|ГДЕ 
				// учтем следующие варианты (в скобках коэффициент индексации среднего заработка в периоде расчета, без скобок коэффициент индексации назначаемый кадровым событием, <> - кадровое перемещение)
				// Вариант 1. 01.09	- (1.35) | 01.10 - (1)    - 1.35  | 10.10 - <> | 01.11 - (1)
				// Вариант 2. 01.09	- (1)    | 01.10 - (1)    - <>    | -		   | 01.11 - (1)
				// Вариант 3. 01.09	- (1)	 | 01.10 - (1.35) - <>    | -		   | 01.11 - (1) - 1.35 
				// Вариант 4. 01.09	- (1)    | 01.10 - (1)	   		  | 10.10 - <> | 01.11 - (1) - 1.35 
				|	(КоэффициентыИндексацииЗаработка.Сотрудник) ЕСТЬ NULL
				|		ИЛИ НАЧАЛОПЕРИОДА(ПериодыКадровыхПерестановок.НачалоПериода, ДЕНЬ) < НАЧАЛОПЕРИОДА(КоэффициентыИндексацииЗаработка.Период, ДЕНЬ)
				|
				|;
				|////////////////////////////////////////////////////////////////////////////////
				|ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	КоэффициентыИндексацииЗаработкаОбщая.Сотрудник,
				// коэффициент индексации начинает действовать в обратную сторону и распространяет действие на предыдущий период
				// с начала предшествующего месяца (за каждый месяц, предшествующий повышению, исчисляется с учетом коэффициента повышения)
				// к началу месяца не приводим, тк в месяце может быть несколько индексаций, но не в одну дату, 
				// поэтому в целях контроля кадрового перемещения интересует конкретный день
				|	НАЧАЛОПЕРИОДА(КоэффициентыИндексацииЗаработкаОбщая.ДатаИндексации, МЕСЯЦ) КАК ДатаИндексации,
				// если в одном месяце в разные даты было и индексация и кадровое перемещение
				// берем коэффициент кадрового перемещения - единицу (меньший)
				|	МИНИМУМ(КоэффициентыИндексацииЗаработкаОбщая.КоэффициентИндексации)
				|ПОМЕСТИТЬ ВТКоэффициентыИндексацииЗаработка
				|
				|ИЗ
				|	ВТКоэффициентыИндексацииЗаработкаОбщая КАК КоэффициентыИндексацииЗаработкаОбщая
				|
				|СГРУППИРОВАТЬ ПО
				|	КоэффициентыИндексацииЗаработкаОбщая.Сотрудник,
				|	НАЧАЛОПЕРИОДА(КоэффициентыИндексацииЗаработкаОбщая.ДатаИндексации, МЕСЯЦ)
				|
				|ИНДЕКСИРОВАТЬ ПО
				|	КоэффициентыИндексацииЗаработкаОбщая.Сотрудник,
				|   НАЧАЛОПЕРИОДА(КоэффициентыИндексацииЗаработкаОбщая.ДатаИндексации, МЕСЯЦ)
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|УНИЧТОЖИТЬ ВТПериодыИндексации
				|;
				|
				|////////////////////////////////////////////////////////////////////////////////
				|УНИЧТОЖИТЬ ВТКоэффициентыИндексацииЗаработкаОбщая
				|";
			
		Иначе
			
			// поддержим существовавший расчет
			КоэффициентыИндексацииЗаработкаТекст = 
