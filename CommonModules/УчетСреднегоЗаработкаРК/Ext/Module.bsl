	Запрос.Текст = СтрЗаменить(Запрос.Текст, "КоэффициентыИндексацииЗаработка.Период", "НАЧАЛОПЕРИОДА(КоэффициентыИндексацииЗаработка.Период, ДЕНЬ)");
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "КоэффициентИндексацииЗаработка.Период", "НАЧАЛОПЕРИОДА(КоэффициентИндексацииЗаработка.Период, ДЕНЬ)");
	// ЗУП РК индексация в рамках дня
	
	РезультатЗапроса = Запрос.Выполнить();
	
	// Обходя результаты запроса агрегируем коэффициенты.
	ВыборкаПоСотрудникам = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
