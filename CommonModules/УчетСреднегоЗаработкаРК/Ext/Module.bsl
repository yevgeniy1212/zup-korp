		// если расчет в рамках кадровых перемещений	
		Иначе
			
			
			Если КоэффициентУчитываетПоследующиеИндексации Тогда
				
				СтрокаИндексации[ИмяКолонкиКоэффициента] = ВыборкаПоСотрудникам.КоэффициентИндексации;
				
			Иначе	
			
				Если ВыборкаПоСотрудникам.КоэффициентИндексации = Null Тогда
					СтрокаИндексации[ИмяКолонкиКоэффициента] = ПредыдущийКоэффициентИндексации;
				Иначе
					СтрокаИндексации[ИмяКолонкиКоэффициента] = ВыборкаПоСотрудникам.КоэффициентИндексации;
				КонецЕсли;
				
				Если ПредыдущийКоэффициентИндексации <> ВыборкаПоСотрудникам.КоэффициентИндексации
					И ВыборкаПоСотрудникам.КоэффициентИндексации <> Null Тогда
					
					ПредыдущийКоэффициентИндексации = ВыборкаПоСотрудникам.КоэффициентИндексации;
					
				КонецЕсли;
				
			КонецЕсли;
				
		КонецЕсли;
		
		Если КоэффициентУчитываетПоследующиеИндексации Тогда
			СтрокаИндексации.ИдентификаторСтроки = ВыборкаПоСотрудникам.ИдентификаторСтроки;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ДанныеИндексации;
	
КонецФункции

// Определяет порядок учета рабочего времени при расчете среднего заработка.
//
Функция ПорядокУчетаРабочегоВремени(Сотрудник, ДатаАктуальности, Организация = Неопределено) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	КадровыеДанныеТекст = "Подразделение" + ?(Организация = Неопределено, ",Организация", ""); 
	КадровыеДанные = КадровыйУчет.КадровыеДанныеСотрудников(Истина, Сотрудник, КадровыеДанныеТекст, ДатаАктуальности);

	Запрос.УстановитьПараметр("Организация", ?(Организация = Неопределено И КадровыеДанные.Количество() > 0, КадровыеДанные[0].Организация, Организация));
	Запрос.УстановитьПараметр("Подразделение", ?(КадровыеДанные.Количество() > 0, КадровыеДанные[0].Подразделение, Справочники.ПодразделенияОрганизаций.ПустаяСсылка()));
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	Запрос.УстановитьПараметр("ДатаАктуальности", ДатаАктуальности);
	
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	1 КАК Приоритет,
		|	РасчетСреднегоЗаработкаСотрудниковСрезПоследних.УчетРабочегоВремени
		|ПОМЕСТИТЬ ВТНастройкиРасчетаСреднегоЗаработка
		|ИЗ
		|	РегистрСведений.РасчетСреднегоЗаработкаСотрудников.СрезПоследних(&ДатаАктуальности, Сотрудник = &Сотрудник) КАК РасчетСреднегоЗаработкаСотрудниковСрезПоследних
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	2,
		|	РасчетСреднегоЗаработкаПодразделенийСрезПоследних.УчетРабочегоВремени
		|ИЗ
		|	РегистрСведений.РасчетСреднегоЗаработкаПодразделений.СрезПоследних(&ДатаАктуальности, Подразделение = &Подразделение) КАК РасчетСреднегоЗаработкаПодразделенийСрезПоследних
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	3,
		|	РасчетСреднегоЗаработкаОрганизацийСрезПоследних.УчетРабочегоВремени
		|ИЗ
		|	РегистрСведений.РасчетСреднегоЗаработкаОрганизаций.СрезПоследних(&ДатаАктуальности, Организация = &Организация) КАК РасчетСреднегоЗаработкаОрганизацийСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НастройкиРасчетаСреднегоЗаработка.УчетРабочегоВремени
		|ИЗ
		|	(ВЫБРАТЬ
		|		МИНИМУМ(НастройкиРасчетаСреднегоЗаработка.Приоритет) КАК Приоритет
		|	ИЗ
		|		ВТНастройкиРасчетаСреднегоЗаработка КАК НастройкиРасчетаСреднегоЗаработка) КАК МинимальноеЗначениеПриоритета
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНастройкиРасчетаСреднегоЗаработка КАК НастройкиРасчетаСреднегоЗаработка
		|		ПО МинимальноеЗначениеПриоритета.Приоритет = НастройкиРасчетаСреднегоЗаработка.Приоритет";
		
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.УчетРабочегоВремени;
	Иначе 
		Возврат Перечисления.УчетРабочегоВремениПриРасчетеСреднегоЗаработка.ПоФактическомуГрафику;
	КонецЕсли;
	
КонецФункции

Процедура СоздатьВТПорядокУчетаРабочегоВремени(Организация = Неопределено, МенеджерВременныхТаблиц, СтрокиРасчета) Экспорт
	
	Если МенеджерВременныхТаблиц.Таблицы.Найти("ВТПорядокУчетаРабочегоВремени") <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаНачислений = Новый ТаблицаЗначений;
	
	Если Организация = Неопределено Тогда
		ТаблицаНачислений.Колонки.Добавить("Организация", Новый ОписаниеТипов("СправочникСсылка.Организации"));
	КонецЕсли;
	
	ТаблицаНачислений.Колонки.Добавить("ИдентификаторСтроки", Новый ОписаниеТипов("Число"));
	ТаблицаНачислений.Колонки.Добавить("ДатаНачала", Новый ОписаниеТипов("Дата"));
	ТаблицаНачислений.Колонки.Добавить("Подразделение", Новый ОписаниеТипов("СправочникСсылка.ПодразделенияОрганизаций"));
	ТаблицаНачислений.Колонки.Добавить("Сотрудник", Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
	
	Для Каждого СтрокаРасчета Из СтрокиРасчета Цикл
		ЗаполнитьЗначенияСвойств(ТаблицаНачислений.Добавить(), СтрокаРасчета.Значение);		
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ТаблицаНачислений", ТаблицаНачислений);
	
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Начисления.ИдентификаторСтроки КАК ИдентификаторСтроки,
		|" + ?(Организация = Неопределено, "Начисления.Организация КАК Организация,", "") + "
		|	Начисления.Подразделение КАК Подразделение,
		|	Начисления.Сотрудник КАК Сотрудник,
		|   Начисления.ДатаНачала КАК ДатаНачала
		|ПОМЕСТИТЬ ВТТаблицаНачислений
		|ИЗ
		|	&ТаблицаНачислений КАК Начисления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(РасчетСреднегоЗаработкаСотрудников.Период) КАК Период,
		|	РасчетСреднегоЗаработкаСотрудников.Сотрудник,
		|	Начисления.ИдентификаторСтроки
		|ПОМЕСТИТЬ ВТПериодыСотрудников
		|ИЗ
		|	ВТТаблицаНачислений КАК Начисления
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РасчетСреднегоЗаработкаСотрудников КАК РасчетСреднегоЗаработкаСотрудников
		|		ПО Начисления.Сотрудник = РасчетСреднегоЗаработкаСотрудников.Сотрудник
		|			И Начисления.ДатаНачала >= РасчетСреднегоЗаработкаСотрудников.Период
		|
		|СГРУППИРОВАТЬ ПО
		|	Начисления.ИдентификаторСтроки,
		|	РасчетСреднегоЗаработкаСотрудников.Сотрудник
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТПериодыСотрудников.ИдентификаторСтроки,
		|	ВТПериодыСотрудников.Сотрудник,
		|	РасчетСреднегоЗаработкаСотрудников.УчетРабочегоВремени,
        |	РасчетСреднегоЗаработкаСотрудников.УчетРабочегоВремениДляСуммированногоУчета
		|ПОМЕСТИТЬ ВТУчетВремениПоСотрудникам
		|ИЗ
		|	ВТПериодыСотрудников КАК ВТПериодыСотрудников
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РасчетСреднегоЗаработкаСотрудников КАК РасчетСреднегоЗаработкаСотрудников
		|		ПО ВТПериодыСотрудников.Период = РасчетСреднегоЗаработкаСотрудников.Период
		|			И ВТПериодыСотрудников.Сотрудник = РасчетСреднегоЗаработкаСотрудников.Сотрудник
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(РасчетСреднегоЗаработкаПодразделений.Период) КАК Период,
		|	РасчетСреднегоЗаработкаПодразделений.Подразделение,
		|	Начисления.ИдентификаторСтроки
		|ПОМЕСТИТЬ ВТПериодыПодразделений
		|ИЗ
		|	ВТТаблицаНачислений КАК Начисления
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РасчетСреднегоЗаработкаПодразделений КАК РасчетСреднегоЗаработкаПодразделений
		|		ПО Начисления.Подразделение = РасчетСреднегоЗаработкаПодразделений.Подразделение
		|			И Начисления.ДатаНачала >= РасчетСреднегоЗаработкаПодразделений.Период
		|
		|СГРУППИРОВАТЬ ПО
		|	Начисления.ИдентификаторСтроки,
		|	РасчетСреднегоЗаработкаПодразделений.Подразделение
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТПериодыПодразделений.ИдентификаторСтроки,
		|	ВТПериодыПодразделений.Подразделение,
		|	РасчетСреднегоЗаработкаПодразделений.УчетРабочегоВремени,
		|	РасчетСреднегоЗаработкаПодразделений.УчетРабочегоВремениДляСуммированногоУчета
		|ПОМЕСТИТЬ ВТУчетВремениПоПодразделениям
		|ИЗ
		|	ВТПериодыПодразделений КАК ВТПериодыПодразделений
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РасчетСреднегоЗаработкаПодразделений КАК РасчетСреднегоЗаработкаПодразделений
		|		ПО ВТПериодыПодразделений.Период = РасчетСреднегоЗаработкаПодразделений.Период
		|			И ВТПериодыПодразделений.Подразделение = РасчетСреднегоЗаработкаПодразделений.Подразделение
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(РасчетСреднегоЗаработкаОрганизаций.Период) КАК Период,
		|	РасчетСреднегоЗаработкаОрганизаций.Организация,
		|	Начисления.ИдентификаторСтроки
		|ПОМЕСТИТЬ ВТПериодыОрганизаций
		|ИЗ
		|	ВТТаблицаНачислений КАК Начисления
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РасчетСреднегоЗаработкаОрганизаций КАК РасчетСреднегоЗаработкаОрганизаций
		|" + ?(Организация = Неопределено, "ПО Начисления.Организация = РасчетСреднегоЗаработкаОрганизаций.Организация", "
		|		ПО РасчетСреднегоЗаработкаОрганизаций.Организация = &Организация") + "
		|			И Начисления.ДатаНачала >= РасчетСреднегоЗаработкаОрганизаций.Период
		|
		|СГРУППИРОВАТЬ ПО
		|	Начисления.ИдентификаторСтроки,
		|	РасчетСреднегоЗаработкаОрганизаций.Организация
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТПериодыОрганизаций.ИдентификаторСтроки,
		|	ВТПериодыОрганизаций.Организация,
		|	РасчетСреднегоЗаработкаОрганизаций.УчетРабочегоВремени,
		|	РасчетСреднегоЗаработкаОрганизаций.УчетРабочегоВремениДляСуммированногоУчета
		|ПОМЕСТИТЬ ВТУчетВремениПоОрганизациям
		|ИЗ
		|	ВТПериодыОрганизаций КАК ВТПериодыОрганизаций
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РасчетСреднегоЗаработкаОрганизаций КАК РасчетСреднегоЗаработкаОрганизаций
		|		ПО ВТПериодыОрганизаций.Период = РасчетСреднегоЗаработкаОрганизаций.Период
		|			И ВТПериодыОрганизаций.Организация = РасчетСреднегоЗаработкаОрганизаций.Организация
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	1 КАК Приоритет,
		|	ВТУчетВремениПоСотрудникам.ИдентификаторСтроки,
		|	ВТУчетВремениПоСотрудникам.УчетРабочегоВремени,
		|	ВТУчетВремениПоСотрудникам.УчетРабочегоВремениДляСуммированногоУчета
		|ПОМЕСТИТЬ ВТНастройкиРасчетаСреднегоЗаработка
		|ИЗ
		|	ВТУчетВремениПоСотрудникам КАК ВТУчетВремениПоСотрудникам
		|
        |ОБЪЕДИНИТЬ ВСЕ
        |
		|ВЫБРАТЬ
		|	2,
		|	ВТУчетВремениПоПодразделениям.ИдентификаторСтроки,
		|	ВТУчетВремениПоПодразделениям.УчетРабочегоВремени,
		|	ВТУчетВремениПоПодразделениям.УчетРабочегоВремениДляСуммированногоУчета
		|ИЗ
		|	ВТУчетВремениПоПодразделениям КАК ВТУчетВремениПоПодразделениям
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	3,
		|	ВТУчетВремениПоОрганизациям.ИдентификаторСтроки,
		|	ВТУчетВремениПоОрганизациям.УчетРабочегоВремени,
		|	ВТУчетВремениПоОрганизациям.УчетРабочегоВремениДляСуммированногоУчета
		|ИЗ
		|	ВТУчетВремениПоОрганизациям КАК ВТУчетВремениПоОрганизациям
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МинимальноеЗначениеПриоритета.ИдентификаторСтроки,
		|	ВТНастройкиРасчетаСреднегоЗаработка.УчетРабочегоВремени,
		|	ВТНастройкиРасчетаСреднегоЗаработка.УчетРабочегоВремениДляСуммированногоУчета
		|ПОМЕСТИТЬ ВТПорядокУчетаРабочегоВремени
		|ИЗ
		|	(ВЫБРАТЬ
		|		МИНИМУМ(ВТНастройкиРасчетаСреднегоЗаработка.Приоритет) КАК Приоритет,
		|		ВТНастройкиРасчетаСреднегоЗаработка.ИдентификаторСтроки КАК ИдентификаторСтроки
		|	ИЗ
		|		ВТНастройкиРасчетаСреднегоЗаработка КАК ВТНастройкиРасчетаСреднегоЗаработка
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ВТНастройкиРасчетаСреднегоЗаработка.ИдентификаторСтроки) КАК МинимальноеЗначениеПриоритета
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНастройкиРасчетаСреднегоЗаработка КАК ВТНастройкиРасчетаСреднегоЗаработка
		|		ПО МинимальноеЗначениеПриоритета.Приоритет = ВТНастройкиРасчетаСреднегоЗаработка.Приоритет
		|			И МинимальноеЗначениеПриоритета.ИдентификаторСтроки = ВТНастройкиРасчетаСреднегоЗаработка.ИдентификаторСтроки
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТУчетВремениПоОрганизациям КАК ВТУчетВремениПоОрганизациям
		|		ПО ВТУчетВремениПоОрганизациям.ИдентификаторСтроки = ВТНастройкиРасчетаСреднегоЗаработка.ИдентификаторСтроки";
		
	Запрос.Выполнить();	
	Запрос.Текст = "ВЫБРАТЬ * ИЗ ВТПорядокУчетаРабочегоВремени";
	
	УдалитьВТ = Новый Массив;
	УдалитьВТ.Добавить("ВТТаблицаНачислений");
	УдалитьВТ.Добавить("ВТПериодыСотрудников");
	УдалитьВТ.Добавить("ВТУчетВремениПоСотрудникам");
	УдалитьВТ.Добавить("ВТПериодыПодразделений");
	УдалитьВТ.Добавить("ВТУчетВремениПоПодразделениям");
	УдалитьВТ.Добавить("ВТПериодыОрганизаций");
	УдалитьВТ.Добавить("ВТУчетВремениПоОрганизациям");
	УдалитьВТ.Добавить("ВТНастройкиРасчетаСреднегоЗаработка");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УдалитьВТ);
	
КонецПроцедуры

Процедура СоздатьВТДоляНеполногоРабочегоВремени(МенеджерВременныхТаблиц, СтрокиРасчета) Экспорт
	
	Если МенеджерВременныхТаблиц.Таблицы.Найти("ВТДоляНеполногоРабочегоВремени") <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТаблицаНачислений = Новый ТаблицаЗначений;
	
	ТаблицаНачислений.Колонки.Добавить("ИдентификаторСтроки", Новый ОписаниеТипов("Число"));
	ТаблицаНачислений.Колонки.Добавить("ДатаНачала", Новый ОписаниеТипов("Дата"));
	ТаблицаНачислений.Колонки.Добавить("Сотрудник", Новый ОписаниеТипов("СправочникСсылка.Сотрудники"));
	
	Для Каждого СтрокаРасчета Из СтрокиРасчета Цикл
		ЗаполнитьЗначенияСвойств(ТаблицаНачислений.Добавить(), СтрокаРасчета.Значение);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ТаблицаНачислений", ТаблицаНачислений);
	
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Начисления.ИдентификаторСтроки КАК ИдентификаторСтроки,
		|	Начисления.Сотрудник КАК Сотрудник,
		|	Начисления.ДатаНачала КАК ДатаНачала
		|ПОМЕСТИТЬ ВТИсходныеДанные
		|ИЗ
		|	&ТаблицаНачислений КАК Начисления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсходныеДанные.ДатаНачала КАК Период,
		|	ИсходныеДанные.Сотрудник,
		|	ДАТАВРЕМЯ(1, 1, 1) КАК НачалоПериодаРасчетаДляКадрового,
		|	ДАТАВРЕМЯ(3999, 1, 1) КАК ОкончаниеПериодаРасчетаДляКадрового,
		|	ИсходныеДанные.ИдентификаторСтроки
		|ПОМЕСТИТЬ ВТИсходныеДанныеДляТаблицаПериодов
		|ИЗ
		|	ВТИсходныеДанные КАК ИсходныеДанные";
	
	Запрос.Выполнить();
	
	// Получим кадровые данные
	ОписаниеФильтра = ЗарплатаКадрыОбщиеНаборыДанных.ОписаниеФильтраДляСоздатьВТИмяРегистра(
		"ВТИсходныеДанныеДляТаблицаПериодов", 
		"Сотрудник");
		
	ОписаниеФильтра.СоответствиеИзмеренийРегистраИзмерениямФильтра.Вставить("ДатаНачала", "НачалоПериодаРасчетаДляКадрового");
	ОписаниеФильтра.СоответствиеИзмеренийРегистраИзмерениямФильтра.Вставить("ДатаОкончания", "ОкончаниеПериодаРасчетаДляКадрового");
	
	ПараметрыПостроения = ЗарплатаКадрыПериодическиеРегистры.ПараметрыПостроенияДляСоздатьВТИмяРегистра();
	ПараметрыПостроения.ИсключатьНеИспользуемыеПоля = Ложь;
	
	ЗарплатаКадрыПериодическиеРегистры.СоздатьВТИмяРегистраПериоды(
		"КадроваяИсторияСотрудников",
		МенеджерВременныхТаблиц,
		Истина,
		ОписаниеФильтра,
		ПараметрыПостроения,
		"ВТИнтервалыКадроваяИсторияСотрудников");
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Начисления.ИдентификаторСтроки КАК ИдентификаторСтроки,
		|	Начисления.Сотрудник КАК Сотрудник,
		|	Начисления.ДатаНачала КАК ДатаНачала
		|ПОМЕСТИТЬ ВТТаблицаНачислений
		|ИЗ
		|	&ТаблицаНачислений КАК Начисления
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	МАКСИМУМ(ЕСТЬNULL(КадроваяИсторияСотрудников.НачалоПериода, ДАТАВРЕМЯ(1,1,1))) КАК НачалоПериода,
		|	Начисления.Сотрудник,
		|	Начисления.ИдентификаторСтроки
		|ПОМЕСТИТЬ ВТПериодыСотрудников
		|ИЗ
		|	ВТТаблицаНачислений КАК Начисления
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИнтервалыКадроваяИсторияСотрудников КАК КадроваяИсторияСотрудников
		|		ПО Начисления.Сотрудник = КадроваяИсторияСотрудников.Сотрудник
		|			И Начисления.ДатаНачала >= НАЧАЛОПЕРИОДА(КадроваяИсторияСотрудников.НачалоПериода, ДЕНЬ)
		|
		|СГРУППИРОВАТЬ ПО
		|	Начисления.ИдентификаторСтроки,
		|	Начисления.Сотрудник
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТПериодыСотрудников.ИдентификаторСтроки,
		|	ВТПериодыСотрудников.Сотрудник,
		|	ВЫБОР
		|		КОГДА КадроваяИсторияСотрудников.КоличествоСтавок ЕСТЬ NULL
		|			ТОГДА 1
		|		КОГДА КадроваяИсторияСотрудников.КоличествоСтавок > 1
		|			ТОГДА 1
		|		ИНАЧЕ КадроваяИсторияСотрудников.КоличествоСтавок
		|	КОНЕЦ КАК КоличествоСтавок
		|ПОМЕСТИТЬ ВТДоляНеполногоРабочегоВремени
		|ИЗ
		|	ВТПериодыСотрудников КАК ВТПериодыСотрудников
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТИнтервалыКадроваяИсторияСотрудников КАК КадроваяИсторияСотрудников
		|		ПО ВТПериодыСотрудников.НачалоПериода = КадроваяИсторияСотрудников.НачалоПериода
		|			И ВТПериодыСотрудников.Сотрудник = КадроваяИсторияСотрудников.Сотрудник";
	
	Запрос.Выполнить();
	
	УдалитьВТ = Новый Массив;
	УдалитьВТ.Добавить("ВТИсходныеДанные");
	УдалитьВТ.Добавить("ВТИсходныеДанныеДляТаблицаПериодов");
	УдалитьВТ.Добавить("ВТТаблицаНачислений");
	УдалитьВТ.Добавить("ВТПериодыСотрудников");
	УдалитьВТ.Добавить("ВТИнтервалыКадроваяИсторияСотрудников");
	
	ЗарплатаКадры.УничтожитьВТ(МенеджерВременныхТаблиц, УдалитьВТ);
	
КонецПроцедуры

Процедура ОбработатьТаблицуКоэффициентовИндексации(ТаблицаКоэффициентыИндексации) Экспорт

	ТаблицаКоэффициентыИндексацииОбработанная = ТаблицаКоэффициентыИндексации.СкопироватьКолонки();
	
	ТекущийСотрудник = "";
	ТекущийПериод = "";
	КоэффициентИндексации = 1;
	
	Для Каждого СтрокаТаблицы Из ТаблицаКоэффициентыИндексации Цикл 
		
		Если ТекущийСотрудник <> СтрокаТаблицы.Сотрудник
			ИЛИ ТекущийПериод <> СтрокаТаблицы.Период Тогда
			
			// Установим новые текущие значения
			ТекущийСотрудник = СтрокаТаблицы.Сотрудник;
			ТекущийПериод = СтрокаТаблицы.Период;
			
			КоэффициентИндексации = СтрокаТаблицы.КоэффициентИндексации;
			
			ОбработаннаяСтрока = ТаблицаКоэффициентыИндексацииОбработанная.Добавить();
			
			ОбработаннаяСтрока.Период                   = СтрокаТаблицы.Период;
			ОбработаннаяСтрока.Сотрудник                = СтрокаТаблицы.Сотрудник;
			ОбработаннаяСтрока.ДатаИндексации			= СтрокаТаблицы.ДатаИндексации;
			ОбработаннаяСтрока.Коэффициент				= СтрокаТаблицы.Коэффициент;
			ОбработаннаяСтрока.КоэффициентИндексации	= КоэффициентИндексации;
			
		Иначе
			
			КоэффициентИндексации = КоэффициентИндексации * СтрокаТаблицы.КоэффициентИндексации;
			
			ОбработаннаяСтрока = ТаблицаКоэффициентыИндексацииОбработанная.Добавить();
			ОбработаннаяСтрока.Период                   = СтрокаТаблицы.Период;
			ОбработаннаяСтрока.Сотрудник                = СтрокаТаблицы.Сотрудник;
			ОбработаннаяСтрока.ДатаИндексации			= СтрокаТаблицы.ДатаИндексации;
			ОбработаннаяСтрока.Коэффициент				= СтрокаТаблицы.Коэффициент;
			ОбработаннаяСтрока.КоэффициентИндексации	= КоэффициентИндексации;

		КонецЕсли;
		
	КонецЦикла;
	
	ТаблицаКоэффициентыИндексации = ТаблицаКоэффициентыИндексацииОбработанная.Скопировать();
	
КонецПроцедуры

Функция РассчитыватьКоэффициентИндексацииВПределахКадровыхПерестановок(Организация, Период) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ДатаСреза", НачалоМесяца(Период));
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	УчетнаяПолитикаОрганизацийСрезПоследних.РассчитыватьКоэффициентИндексацииВПределахКадровыхПерестановок
	|ИЗ
	|	РегистрСведений.РасчетСреднегоЗаработкаОрганизаций.СрезПоследних(&ДатаСреза, Организация = &Организация) КАК УчетнаяПолитикаОрганизацийСрезПоследних";
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.РассчитыватьКоэффициентИндексацииВПределахКадровыхПерестановок;

КонецФункции

Функция ВариантУчетаКадровыхПерестановок(Организация, Период) Экспорт

	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("ДатаСреза", НачалоМесяца(Период));
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	УчетнаяПолитикаОрганизацийСрезПоследних.ВариантУчетаКадровыхПерестановок
	|ИЗ
	|	РегистрСведений.РасчетСреднегоЗаработкаОрганизаций.СрезПоследних(&ДатаСреза, Организация = &Организация) КАК УчетнаяПолитикаОрганизацийСрезПоследних";
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		Возврат Перечисления.ВариантыУчетаКадровыхПерестановок.ДолжностьРазрядПодразделение;
	КонецЕсли;
	
	Выборка = Результат.Выбрать();
	Выборка.Следующий();
	Возврат Выборка.ВариантУчетаКадровыхПерестановок;

КонецФункции

Функция КоэффициентИндексацииЗаработка(Фильтр, ДатыНачалаСобытий) Экспорт

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Фильтр", Фильтр);
	Запрос.УстановитьПараметр("ДатыНачалаСобытия", ДатыНачалаСобытий);
	Запрос.УстановитьПараметр("КоэффициентИндексацииСреднегоЗаработка", ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ПоказателиРасчетаЗарплаты.КоэффициентИндексацииСреднегоЗаработка"));
	
	Запрос.Текст = Запрос.Текст +
		"ВЫБРАТЬ
		|   ВсеДатыНачала.Сотрудник,
		|   ВсеДатыНачала.ДатаНачала,
		|   ВсеДатыНачала.ДатаОкончания
		|ПОМЕСТИТЬ ВТНачисления
		|ИЗ 
		|	&Фильтр КАК ВсеДатыНачала
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|   ВсеДатыНачала.Сотрудник,
		|   ВсеДатыНачала.Дата КАК ДатаНачалаСобытия
		|ПОМЕСТИТЬ ВТДатыНачалаСобытияПоДанным
		|ИЗ 
		|	&ДатыНачалаСобытия КАК ВсеДатыНачала
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	Начисления.Сотрудник,
		// необходим для корректного получения коэффициентов при делении периода
		|	Начисления.ДатаНачала КАК ПериодДействияНачало,
		// коэффициентов индексации будем получать от даты начала события 
		|	ЕСТЬNULL(ДатыНачалаСобытияПоДаннымВТ.ДатаНачалаСобытия, Начисления.ДатаНачала) КАК НачалоПериодаРасчетаСреднего,
		|	Начисления.ДатаОкончания КАК ОкончаниеПериодаРасчетаСреднего,
		|	&КоэффициентИндексацииСреднегоЗаработка КАК Показатель,
		|	ЕСТЬNULL(ДатыНачалаСобытияПоДаннымВТ.ДатаНачалаСобытия, Начисления.ДатаНачала) КАК ДатаНачалаСобытия,
		|	0 КАК ИдентификаторСтроки
		|ИЗ
		|	ВТНачисления КАК Начисления
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДатыНачалаСобытияПоДанным КАК ДатыНачалаСобытияПоДаннымВТ
		|		ПО (ДатыНачалаСобытияПоДаннымВТ.Сотрудник = Начисления.Сотрудник)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Начисления.Сотрудник";

	УстановитьПривилегированныйРежим(Истина);
	ИсходныеДанные = Запрос.Выполнить().Выгрузить();
	ДанныеИндексации = УчетСреднегоЗаработкаРК.ДанныеИндексации(ИсходныеДанные, Истина);
	УстановитьПривилегированныйРежим(Ложь);

	Возврат ДанныеИндексации;
	
КонецФункции

