				|			И (КоэффициентИндексацииЗаработка.Период >= ИсходныеДанные.НачалоПериодаРасчетаСреднего И КоэффициентИндексацииЗаработка.Период < ИсходныеДанные.ДатаНачалаСобытия)
				// выбираем одну актуальную на дату ввода индексации запись
				|			И (КоэффициентИндексацииЗаработка.ДатаИндексации = КоэффициентИндексацииЗаработка.Период)
				|
				|СГРУППИРОВАТЬ ПО
				|	ИсходныеДанные.Сотрудник,
				|	ИсходныеДанные.ДатаНачалаСобытия,
				|	ИсходныеДанные.ИдентификаторСтроки,
				|	Месяцы.Период
				|
				|ИНДЕКСИРОВАТЬ ПО
				|	ИсходныеДанные.Сотрудник,
				|	Месяцы.Период";
			
		КонецЕсли;
			
	КонецЕсли;
	
	// ЗУП РК индексация в рамках дня
	КоэффициентыИндексацииЗаработкаТекст = СтрЗаменить(КоэффициентыИндексацииЗаработкаТекст, "КоэффициентыИндексацииЗаработка.Период", "НАЧАЛОПЕРИОДА(КоэффициентыИндексацииЗаработка.Период, ДЕНЬ)");
	КоэффициентыИндексацииЗаработкаТекст = СтрЗаменить(КоэффициентыИндексацииЗаработкаТекст, "КоэффициентИндексацииЗаработка.Период", "НАЧАЛОПЕРИОДА(КоэффициентИндексацииЗаработка.Период, ДЕНЬ)");  
	// ЗУП РК индексация в рамках дня
	
	Запрос.Текст = КоэффициентыИндексацииЗаработкаТекст;
	Запрос.Выполнить();

	Если КоэффициентУчитываетПоследующиеИндексации Тогда	
		
		Если РассчитыватьКоэффициентИндексацииВПределахКадровыхПерестановок Тогда
			
			// при расчете показателей не учитываем кадровые перемещения, приводим коэффициенты индексации
			// к текущему за месяц расчета заработку
			Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	ИсходныеДанные.Сотрудник КАК Сотрудник,
				|	ИсходныеДанные.Период КАК Период,
				|	ИсходныеДанные.ИдентификаторСтроки КАК ИдентификаторСтроки,
				//  В расчетном периоде было изменение места работы, коэффициент устанавливается равным единице
				|	ЕСТЬNULL(КоэффициентИндексацииЗаработка.КоэффициентИндексации, 1) КАК КоэффициентИндексации
				|ИЗ
				|	ВТКоэффициентыИндексацииЗаработка КАК ИсходныеДанные
				|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.КоэффициентИндексацииЗаработка КАК КоэффициентИндексацииЗаработка
				|		ПО ИсходныеДанные.Сотрудник = КоэффициентИндексацииЗаработка.Сотрудник
				|			И ИсходныеДанные.ПериодИндексации = КоэффициентИндексацииЗаработка.Период
				|			И ИсходныеДанные.ДатаИндексации = КоэффициентИндексацииЗаработка.ДатаИндексации
				|
				|УПОРЯДОЧИТЬ ПО
				|	ИдентификаторСтроки,
				|	Сотрудник,
				|	Период УБЫВ";
			
		Иначе
			
			// поддержим существовавший расчет
			Запрос.Текст = 
				"ВЫБРАТЬ РАЗЛИЧНЫЕ
				|	ИсходныеДанные.Сотрудник КАК Сотрудник,
				|	ИсходныеДанные.Период КАК Период,
				|	ИсходныеДанные.ИдентификаторСтроки КАК ИдентификаторСтроки,
				//  В расчетном периоде было изменение места работы, коэффициент устанавливается равным единице
				|	ВЫБОР
