#Область СтатистикиКонфигурации

// АПК:1297-выкл Статистика, не локализуется

Функция СтатистикаГрафикаУчетаСамочувствия()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(ГрафикУчетаСамочувствия.Ссылка) КАК Замеров
		|ИЗ
		|	Справочник.ГрафикУчетаСамочувствияСотрудников КАК ГрафикУчетаСамочувствия
		|ГДЕ
		|	ГрафикУчетаСамочувствия.Недействительная = ЛОЖЬ
		|	И ГрафикУчетаСамочувствия.ПометкаУдаления = ЛОЖЬ";
	
	ПоказателиСтатистики = Новый Соответствие;
	ПоказателиСтатистики.Вставить("Замеров", Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Замеров")[0]);
	
	Возврат ПоказателиСтатистики;
	
КонецФункции

