#Область ОжидаемыйДоход

Функция ОжидаемыйДоходВВалютеПоУмолчанию(ОжидаемыйДоход, Валюта, Периодичность, КурсыВалют = Неопределено) Экспорт
	
	Возврат ПредставлениеОжидаемогоДохода(ОжидаемыйДоходВМесяц(
		СуммаВВалютеПоУмолчанию(ОжидаемыйДоход, Валюта, КурсыВалют), Периодичность));
	
КонецФункции

Функция СуммаВВалютеПоУмолчанию(Номинал, Валюта, КурсыВалют = Неопределено) Экспорт
	
	ВалютаПоУмолчанию = ЗарплатаКадрыВызовСервера.ВалютаУчетаЗаработнойПлаты();
	Если Не ЗначениеЗаполнено(Валюта) Или Валюта = ВалютаПоУмолчанию Тогда
		Возврат Номинал;
	КонецЕсли;
	
	Возврат РаботаСКурсамиВалютКлиентСервер.ПересчитатьПоКурсу(Номинал,
		КурсВалюты(Валюта, КурсыВалют), ОписаниеКурсаВалюты(ВалютаПоУмолчанию));
	
КонецФункции

Функция ПредставлениеОжидаемогоДохода(ОжидаемыйДоход, ВалютаПоУмолчанию = "") Экспорт
	
	Если ОжидаемыйДоход * Pow(10, -6) >= 1 Тогда
		Шаблон = НСтр("ru = '%1 млн. %2'");
		ОжидаемыйДоход = ОкруглениеОжидаемогоДоходаМлн(ОжидаемыйДоход);
	Иначе
		Шаблон = НСтр("ru = '%1 %2'");
		ОжидаемыйДоход = ОкруглениеОжидаемогоДохода(ОжидаемыйДоход);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ОжидаемыйДоход) Тогда
		Возврат Формат(ОжидаемыйДоход, "ЧН=' '");
	КонецЕсли;
	
	Возврат СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		Шаблон, ОжидаемыйДоход, ВалютаПоУмолчанию);
	
КонецФункции

// АПК:581-выкл Экспорт не избыточен - функция нужна в обработке ПоискРезюмеВИнтернете

Функция ОжидаемыйДоходВМесяц(ОжидаемыйДоход, ПериодичностьДохода) Экспорт
	
	Если ПериодичностьДохода = ПредопределенноеЗначение("Перечисление.ПериодичностьОжидаемогоДоходаКандидатов.Час") Тогда
		ОжидаемыйДоходВМесяц = ОкруглениеОжидаемогоДохода(ОжидаемыйДоход * 160);
	ИначеЕсли ПериодичностьДохода = ПредопределенноеЗначение("Перечисление.ПериодичностьОжидаемогоДоходаКандидатов.Год") Тогда
		ОжидаемыйДоходВМесяц = ОкруглениеОжидаемогоДохода(ОжидаемыйДоход / 12);
	Иначе
		ОжидаемыйДоходВМесяц = ОкруглениеОжидаемогоДохода(ОжидаемыйДоход);
	КонецЕсли;
	
	Возврат ОжидаемыйДоходВМесяц
	
КонецФункции

// АПК:581-вкл

Процедура РассчитатьДоходПоВалюте(ОжидаемыйДоход, Валюта, НоваяВалюта) Экспорт
	
	Если ОжидаемыйДоход = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ВалютаПоУмолчанию = ЗарплатаКадрыВызовСервера.ВалютаУчетаЗаработнойПлаты();
	
	Если Не ЗначениеЗаполнено(НоваяВалюта) Тогда
		НоваяВалюта = ВалютаПоУмолчанию;
	КонецЕсли;
	
	ОжидаемыйДоход = ОкруглениеОжидаемогоДохода(РаботаСКурсамиВалютКлиентСервер.ПересчитатьПоКурсу(ОжидаемыйДоход,
		КурсВалюты(Валюта), КурсВалюты(НоваяВалюта)));
	
КонецПроцедуры

Процедура РассчитатьДоходПоПериодичности(ОжидаемыйДоход, ПериодичностьДохода, НоваяПериодичность) Экспорт
	
	Если ОжидаемыйДоход = 0 Или ПериодичностьДохода = НоваяПериодичность Тогда
		Возврат;
	КонецЕсли;
	
	Если НоваяПериодичность = ПредопределенноеЗначение("Перечисление.ПериодичностьОжидаемогоДоходаКандидатов.ПустаяСсылка") Тогда
		НоваяПериодичность = ПредопределенноеЗначение("Перечисление.ПериодичностьОжидаемогоДоходаКандидатов.Месяц");
	КонецЕсли;
	
	ОжидаемыйДоходВМесяц = ОжидаемыйДоходВМесяц(ОжидаемыйДоход, ПериодичностьДохода);
	
	Если НоваяПериодичность = ПредопределенноеЗначение("Перечисление.ПериодичностьОжидаемогоДоходаКандидатов.Час") Тогда
		ОжидаемыйДоход = ОжидаемыйДоходВМесяц / 160;
	ИначеЕсли НоваяПериодичность = ПредопределенноеЗначение("Перечисление.ПериодичностьОжидаемогоДоходаКандидатов.Год") Тогда
		ОжидаемыйДоход = ОжидаемыйДоходВМесяц * 12;
	Иначе
		ОжидаемыйДоход = ОжидаемыйДоходВМесяц;
	КонецЕсли;
	
КонецПроцедуры

