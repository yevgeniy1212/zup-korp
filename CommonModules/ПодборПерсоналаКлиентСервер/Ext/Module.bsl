#Область ОжидаемыйДоход

Функция КурсВалюты(Валюта, КурсыВалют = Неопределено)
	
	Если КурсыВалют <> Неопределено Тогда
		КурсВалюты = КурсыВалют[Валюта];
	Иначе
		КурсВалюты = ПодборПерсоналаВызовСервера.ПолучитьКурсВалюты(Валюта);
		Возврат КурсВалюты;
	КонецЕсли;
	
	Если КурсВалюты = Неопределено Тогда
		КурсВалюты = ПодборПерсоналаВызовСервера.ПолучитьКурсВалюты(Валюта);
		КурсыВалют.Вставить(Валюта, КурсВалюты);
	КонецЕсли;
	
	Возврат КурсВалюты;
	
КонецФункции

Функция ОкруглениеОжидаемогоДохода(ОжидаемыйДоход)
	Возврат Окр(ОжидаемыйДоход / Pow(10, 2), 1, 1) * Pow(10, 2);
КонецФункции

Функция ОкруглениеОжидаемогоДоходаМлн(ОжидаемыйДоход)
	Возврат Окр(ОжидаемыйДоход * Pow(10, -3), 0, 1) * Pow(10, -3);
КонецФункции

Функция ОписаниеКурсаВалюты(Валюта, Курс = 1, Кратность = 1)
	
	Описание = Новый Структура();
	Описание.Вставить("Валюта", Валюта);
	Описание.Вставить("Курс", Курс);
	Описание.Вставить("Кратность", Кратность);
	Возврат Описание;
	
КонецФункции

