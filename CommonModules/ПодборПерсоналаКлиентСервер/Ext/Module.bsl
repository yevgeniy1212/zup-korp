	Возврат Описание;
	
КонецФункции

Функция ОписаниеРешенияПоКандидату() Экспорт
	
	ОписаниеРешения = Новый Структура();
	ОписаниеРешения.Вставить("Решение");
	ОписаниеРешения.Вставить("ДатаРешения");
	ОписаниеРешения.Вставить("Причина");
	ОписаниеРешения.Вставить("Комментарий");
	
