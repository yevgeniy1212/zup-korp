Процедура ОбработатьДокументыСпецоценки(ВыборкаРегистратор, ТаблицаСвязейРабочихМестСПозициями)
	
	Пока ВыборкаРегистратор.Следующий() Цикл
		ЕстьСотрудники = Ложь;
		ЕстьТолькоРабочиеМеста = Ложь;
		ИмяТЧ = "РабочиеМеста";
		ИмяПоляПоиска = "УдалитьРабочееМесто";
		
		ДокументСсылка = ВыборкаРегистратор.Ссылка;
		ТипДокумента = ТипЗнч(ДокументСсылка);
		Если ТипДокумента = Тип("ДокументСсылка.ДекларацияСоответствияУсловийТруда") Тогда
			ЕстьТолькоРабочиеМеста = Истина;
		ИначеЕсли ТипДокумента = Тип("ДокументСсылка.НесчастныйСлучайНаПроизводстве") Тогда
			ЕстьТолькоРабочиеМеста = Истина;
			ИмяТЧ = "Пострадавшие";
			ИмяПоляПоиска = "УдалитьДолжностьПоШтатномуРасписанию";
		ИначеЕсли ТипДокумента = Тип("ДокументСсылка.ПодготовкаСпецоценкиУсловийТруда") Тогда
			ЕстьСотрудники = Истина;
		КонецЕсли;
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить(ДокументСсылка.Метаданные().ПолноеИмя());
		ЭлементБлокировки.УстановитьЗначение("Ссылка", ДокументСсылка);
		Блокировка.Заблокировать();
		
		ДокументОбъект = ДокументСсылка.ПолучитьОбъект();
		ЗаблокироватьДанныеДляРедактирования(ДокументСсылка);
		
		ВыборкаРабочиеМеста = ВыборкаРегистратор.Выбрать();
		Пока ВыборкаРабочиеМеста.Следующий() Цикл
			СтруктураПоиска = Новый Структура(ИмяПоляПоиска + ", НомерСтроки");
			СтруктураПоиска[ИмяПоляПоиска] = ВыборкаРабочиеМеста.УдалитьРабочееМесто;
			СтруктураПоиска.НомерСтроки = ВыборкаРабочиеМеста.НомерСтроки;
			
			СтрокиТЧ = ДокументОбъект[ИмяТЧ].НайтиСтроки(СтруктураПоиска);
			
			Если СтрокиТЧ.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаТЧ = СтрокиТЧ[0];
			СтрокаТЧ.РабочееМесто = ВыборкаРабочиеМеста.РабочееМесто;
			
			Если ЕстьТолькоРабочиеМеста Тогда
				Продолжить;
			КонецЕсли;
			
			СтрокаТЧ.ИдентификаторСтрокиРабочегоМеста = ВыборкаРабочиеМеста.НомерСтроки;
			СтрокаТЧ.Должность = ВыборкаРабочиеМеста.Должность;
			СтрокаТЧ.Подразделение = ВыборкаРабочиеМеста.Подразделение;
			
			СтруктураПоиска.Удалить("НомерСтроки");
			
			Если ЕстьСотрудники И ДокументОбъект.Сотрудники.Количество() > 0 Тогда
				СтрокиТЧСотрудники = ДокументОбъект.Сотрудники.НайтиСтроки(СтруктураПоиска);
				Для Каждого СтрокаСотрудника Из СтрокиТЧСотрудники Цикл
					СтрокаСотрудника.РабочееМесто = ВыборкаРабочиеМеста.РабочееМесто;
					СтрокаСотрудника.ИдентификаторСтрокиРабочегоМеста = ВыборкаРабочиеМеста.НомерСтроки;
				КонецЦикла;
			КонецЕсли;
			
			Если ДокументОбъект.АналогичныеМеста.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			МассивАналогичных = Новый Массив;
			МассивАналогичных.Добавить(СтрокаТЧ.РабочееМесто);
			
			СтрокиТЧАналогичные = ДокументОбъект.АналогичныеМеста.НайтиСтроки(СтруктураПоиска);
			Для Каждого СтрокаАналогичные Из СтрокиТЧАналогичные Цикл
				СтруктураПоискаАналога = Новый Структура("Позиция", СтрокаАналогичные.УдалитьАналогичноеМесто);
				СвязиАналогичных = ТаблицаСвязейРабочихМестСПозициями.НайтиСтроки(СтруктураПоискаАналога);
				Если СвязиАналогичных.Количество() = 0 Тогда
					Продолжить;
				КонецЕсли;
				Для Каждого АналогичноеМесто Из СвязиАналогичных Цикл
					Если МассивАналогичных.Найти(АналогичноеМесто.РабочееМесто) = Неопределено Тогда
						МассивАналогичных.Добавить(АналогичноеМесто.РабочееМесто);
						СтрокаАналогичные.АналогичноеМесто = АналогичноеМесто.РабочееМесто;
						Прервать;
					КонецЕсли;
				КонецЦикла;
				СтрокаАналогичные.ИдентификаторСтрокиРабочегоМеста = ВыборкаРабочиеМеста.НомерСтроки;
			КонецЦикла;
		КонецЦикла;
		
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ДокументОбъект);
	КонецЦикла; 
	
КонецПроцедуры

Процедура ЗарегистрироватьРабочиеМестаСотрудников(ВыборкаРегистратор)
	
	Пока ВыборкаРегистратор.Следующий() Цикл
		ДокументСсылка = ВыборкаРегистратор.Регистратор;
		ТипДокумента = ТипЗнч(ДокументСсылка);
		ИмяДокумента = Метаданные.НайтиПоТипу(ТипДокумента).Имя;
		
		Блокировка = Новый БлокировкаДанных;
		Блокировка.Добавить("РегистрСведений.РабочиеМестаСотрудников");
		ЭлементБлокировки = Блокировка.Добавить(ДокументСсылка.Метаданные().ПолноеИмя());
		ЭлементБлокировки.УстановитьЗначение("Ссылка", ДокументСсылка);
		Блокировка.Заблокировать();
		
		НаборЗаписей = РегистрыСведений.РабочиеМестаСотрудников.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Регистратор.Установить(ДокументСсылка);
		
		ДокументОбъект = ДокументСсылка.ПолучитьОбъект();
		ЗаблокироватьДанныеДляРедактирования(ДокументСсылка);
		
		СтруктураПоиска = Новый Структура("Сотрудник");
		ЗаписатьДокумент = Ложь;
		
		ВыборкаРабочихМест = ВыборкаРегистратор.Выбрать();
		Пока ВыборкаРабочихМест.Следующий() Цикл
			НовоеРабочееМестоСотрудника = НаборЗаписей.Добавить();
			ЗаполнитьЗначенияСвойств(НовоеРабочееМестоСотрудника, ВыборкаРабочихМест);
			Если ТипДокумента = Тип("ДокументСсылка.ВосстановлениеВДолжности")
			 Или ТипДокумента = Тип("ДокументСсылка.ПриемНаРаботу")
			 Или ТипДокумента = Тип("ДокументСсылка.НазначениеПодработки") Тогда
				ДокументОбъект.РабочееМесто = ВыборкаРабочихМест.РабочееМесто;
			ИначеЕсли ТипДокумента = Тип("ДокументСсылка.КадровыйПеревод") Тогда
				ДокументОбъект.РабочееМесто = ВыборкаРабочихМест.РабочееМесто;
				ДокументОбъект.ИзменитьРабочееМесто = Истина;
			ИначеЕсли ТипДокумента = Тип("ДокументСсылка.НачальнаяШтатнаяРасстановка")
			 Или ТипДокумента = Тип("ДокументСсылка.ПеремещениеВДругоеПодразделение")
			 Или ТипДокумента = Тип("ДокументСсылка.ПриемНаРаботуСписком")
			 Или ТипДокумента = Тип("ДокументСсылка.КадровыйПереводСписком") Тогда
				ЗаполнитьЗначенияСвойств(СтруктураПоиска, ВыборкаРабочихМест);
				СтрокиТЧ = ДокументОбъект.Сотрудники.НайтиСтроки(СтруктураПоиска);
				Если СтрокиТЧ.Количество() = 0 Тогда
					Продолжить;
				КонецЕсли;
				СтрокаТЧ = СтрокиТЧ[0];
				СтрокаТЧ.РабочееМесто = ВыборкаРабочихМест.РабочееМесто;
				Если ТипДокумента = Тип("ДокументСсылка.КадровыйПереводСписком") Тогда
					СтрокаТЧ.ИзменитьРабочееМесто = Истина;
				КонецЕсли;
			ИначеЕсли ТипДокумента = Тип("ДокументСсылка.ПереносДанных") Тогда
				НовыйРегистр = ДокументОбъект.ТаблицаРегистров.Добавить();
				НовыйРегистр.Имя = "РабочиеМестаСотрудников";
			Иначе
				Продолжить;
			КонецЕсли;
			ЗаписатьДокумент = Истина;			
		КонецЦикла;
		
		Если НаборЗаписей.Количество() > 0 И ЗначениеЗаполнено(НаборЗаписей[0].Регистратор) Тогда
			ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
		КонецЕсли; 
		
		Если Не ЗаписатьДокумент Тогда
			Продолжить;
		КонецЕсли;
		
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ДокументОбъект);
			
		Если ТипДокумента = Тип("ДокументСсылка.КадровыйПереводСписком") Тогда			
			ДанныеДляРегистрацииВУчете = Документы.КадровыйПеревод.ДанныеДляРегистрацииВУчетаСтажаПФР(
				ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ДокументСсылка), Истина);
		ИначеЕсли ТипДокумента = Тип("ДокументСсылка.ПриемНаРаботу")
			Или ТипДокумента = Тип("ДокументСсылка.ПриемНаРаботуСписком")
			Или ТипДокумента = Тип("ДокументСсылка.КадровыйПеревод")
			Или ТипДокумента = Тип("ДокументСсылка.ВосстановлениеВДолжности")
			Или ТипДокумента = Тип("ДокументСсылка.НачальнаяШтатнаяРасстановка") 
			Или ТипДокумента = Тип("ДокументСсылка.ПеремещениеВДругоеПодразделение") Тогда
				
			ДанныеДляРегистрацииВУчете = Документы[ИмяДокумента].ДанныеДляРегистрацииВУчетаСтажаПФР(
				ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ДокументСсылка));
		Иначе
			Продолжить;
		КонецЕсли;
		
		УчетСтажаПФР.ЗарегистрироватьПериодыВУчетеСтажаПФР(ДокументОбъект.Движения, ДанныеДляРегистрацииВУчете.Получить(ДокументСсылка));
		ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(ДокументОбъект.Движения.ПараметрыПериодовСтажаПФР);
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьИспользованиеОсобыхУсловийТруда(ПараметрыОбновления)
	
	ПараметрыОбновления.ОбработкаЗавершена = Ложь;
	
	НачатьТранзакцию();
	Попытка
		Блокировка = Новый БлокировкаДанных;
		Блокировка.Добавить("Константа.ИспользоватьОсобыеУсловияТруда");
		Блокировка.Заблокировать();
	
		МенеджерКонстанты = Константы.ИспользоватьОсобыеУсловияТруда.СоздатьМенеджерЗначения();
		МенеджерКонстанты.Значение = Истина;
		
		ОбновлениеИнформационнойБазы.ЗаписатьДанные(МенеджерКонстанты);
	
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Обновление информационной базы.Не удалось установить использование особых условий труда'",
			ОбщегоНазначения.КодОсновногоЯзыка()), УровеньЖурналаРегистрации.Ошибка, , , 
			ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат;
	КонецПопытки;
	
	ПараметрыОбновления.ОбработкаЗавершена = Истина;
	
КонецПроцедуры

Процедура ЗаполнитьРезультатыСпецоценкиНовымиВреднымиФакторами(ПараметрыОбновления = Неопределено) Экспорт

	ОбновлениеИБ = ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый;
	
	Если ПараметрыОбновления = Неопределено Тогда
		ПараметрыОбновления = Новый Структура("ОбработкаЗавершена");
	КонецЕсли;
	
	Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыКорпоративнаяПодсистемы.ОхранаТруда.МедицинскиеОсмотры") Тогда
		МодульМедицинскиеОсмотры = ОбщегоНазначения.ОбщийМодуль("МедицинскиеОсмотры");
	Иначе
		ОбновлениеИБ.ЗавершитьОбработчик(ПараметрыОбновления);
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВредныеФакторыРезультатовСпецоценки.Ссылка КАК Документ
		|ПОМЕСТИТЬ ВТРезультатыСпецоценкиОбновленные
		|ИЗ
		|	Документ.РезультатыСпецоценкиУсловийТруда.ВредныеФакторы КАК ВредныеФакторыРезультатовСпецоценки
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	РезультатыСпецоценкиУсловийТруда.Ссылка КАК Документ
		|ИЗ
		|	Документ.РезультатыСпецоценкиУсловийТруда КАК РезультатыСпецоценкиУсловийТруда
		|ГДЕ
		|	НЕ РезультатыСпецоценкиУсловийТруда.Ссылка В (&Обработанные)
		|	И НЕ РезультатыСпецоценкиУсловийТруда.ПометкаУдаления
		|	И НЕ РезультатыСпецоценкиУсловийТруда.Ссылка В
		|		(ВЫБРАТЬ
		|			РезультатыСпецоценкиОбновленные.Документ
		|		ИЗ
		|			ВТРезультатыСпецоценкиОбновленные КАК РезультатыСпецоценкиОбновленные)";
	
	Если Не ПараметрыОбновления.Свойство("Обработанные") Тогда
		Обработанные = Новый Массив;
		ПараметрыОбновления.Вставить("Обработанные");
	ИначеЕсли ПараметрыОбновления.Обработанные = Неопределено Тогда
		Обработанные = Новый Массив;
	Иначе
		Обработанные = ПараметрыОбновления.Обработанные;
	КонецЕсли;
	Запрос.УстановитьПараметр("Обработанные", Обработанные);
	
	ОбновляемыеДанные = ОбновлениеИБ.ВыполнитьЗапросПолученияОбновляемыхДанных(Запрос, ПараметрыОбновления);
	
	Если ОбновляемыеДанные.Пустой() Тогда
		ОбновлениеИБ.ЗавершитьОбработчик(ПараметрыОбновления);
		Возврат;
	КонецЕсли;
	
	ОбновлениеИБ.ПродолжитьОбработчик(ПараметрыОбновления);
	
	ДокументыКОбновлению = ОбновляемыеДанные.Выгрузить().ВыгрузитьКолонку("Документ");
	Запрос.УстановитьПараметр("ДокументыКОбновлению", ДокументыКОбновлению);
	
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВредныеФакторыИВидыРаботРабочегоМеста.РабочееМесто КАК РабочееМесто,
		|	ВредныеФакторыИВидыРаботРабочегоМеста.ВредныйФактор КАК ВредныйФактор
		|ПОМЕСТИТЬ ВТВредныеФакторыРабочегоМеста
		|ИЗ
		|	РегистрСведений.ВредныеФакторыИВидыРаботРабочегоМеста КАК ВредныеФакторыИВидыРаботРабочегоМеста
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РабочиеМестаРезультатаСпецоценки.Ссылка КАК Документ,
		|	РабочиеМестаРезультатаСпецоценки.ИдентификаторСтрокиРабочегоМеста КАК ИдентификаторСтрокиРабочегоМеста,
		|	ВредныеФакторыРабочегоМеста.ВредныйФактор КАК ВредныйФактор,
		|	НЕ ВредныеФакторыРабочегоМеста.ВредныйФактор ЕСТЬ NULL КАК ЕстьСоответствие
		|ПОМЕСТИТЬ ВТДокументыСВреднымиФакторами
		|ИЗ
		|	Документ.РезультатыСпецоценкиУсловийТруда.РабочиеМеста КАК РабочиеМестаРезультатаСпецоценки
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТВредныеФакторыРабочегоМеста КАК ВредныеФакторыРабочегоМеста
		|		ПО РабочиеМестаРезультатаСпецоценки.РабочееМесто = ВредныеФакторыРабочегоМеста.РабочееМесто
		|ГДЕ
		|	РабочиеМестаРезультатаСпецоценки.Ссылка В(&ДокументыКОбновлению)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДокументыСВреднымиФакторами.Документ КАК Документ,
		|	МАКСИМУМ(ДокументыСВреднымиФакторами.ЕстьСоответствие) КАК ЕстьСоответствие
		|ИЗ
		|	ВТДокументыСВреднымиФакторами КАК ДокументыСВреднымиФакторами
		|
		|СГРУППИРОВАТЬ ПО
		|	ДокументыСВреднымиФакторами.Документ
		|
		|УПОРЯДОЧИТЬ ПО
		|	Документ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ДокументыСВреднымиФакторами.Документ КАК Документ,
		|	ДокументыСВреднымиФакторами.ИдентификаторСтрокиРабочегоМеста КАК ИдентификаторСтрокиРабочегоМеста,
		|	ДокументыСВреднымиФакторами.ВредныйФактор КАК ВредныйФактор,
		|	ДокументыСВреднымиФакторами.ЕстьСоответствие КАК ЕстьСоответствие
		|ИЗ
		|	ВТДокументыСВреднымиФакторами КАК ДокументыСВреднымиФакторами
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДокументыСВреднымиФакторами.Документ,
		|	ДокументыСВреднымиФакторами.ИдентификаторСтрокиРабочегоМеста";
		
	РезультатыЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаДокументов = РезультатыЗапроса[2].Выбрать();
	ВыборкаФакторов = РезультатыЗапроса[3].Выбрать();
	Пока ВыборкаДокументов.Следующий() Цикл
		Если Не ВыборкаДокументов.ЕстьСоответствие Тогда
			Продолжить;
		КонецЕсли;
		ДокументОбъект = ВыборкаДокументов.Документ.ПолучитьОбъект();
		ВыборкаФакторов.СледующийПоЗначениюПоля("Документ");
		Пока ВыборкаФакторов.Следующий() Цикл
			Если ВыборкаФакторов.ЕстьСоответствие Тогда
				НоваяСтрока = ДокументОбъект.ВредныеФакторы.Добавить();
				НоваяСтрока.ВредныйФактор = ВыборкаФакторов.ВредныйФактор;
				НоваяСтрока.ИдентификаторСтрокиРабочегоМеста = ВыборкаФакторов.ИдентификаторСтрокиРабочегоМеста;
			КонецЕсли;
		КонецЦикла;
		ЗаблокироватьДанныеДляРедактирования(ВыборкаДокументов.Документ);
		ДокументОбъект.ВредныеФакторы.Свернуть("ИдентификаторСтрокиРабочегоМеста, ВредныйФактор"); 
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ДокументОбъект);
	КонецЦикла;
	
	ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Обработанные, ДокументыКОбновлению);
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "Обработанные", Обработанные);
	МодульМедицинскиеОсмотры.ОбновитьВредныеФакторыРабочихМест();
	
КонецПроцедуры

Процедура ЗаполнитьТабличнуюЧастьМедосмотры(ПараметрыОбновления = Неопределено) Экспорт

	ОбновлениеИБ = ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый;
	
	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьНесчастныеСлучаиНаПроизводстве") Тогда
		ОбновлениеИБ.ЗавершитьОбработчик(ПараметрыОбновления);
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаПриказа223Н", ДатаВступленияВСилуПриказа223Н());
	Запрос.Текст =
		"ВЫБРАТЬ
		|	НесчастныйСлучайНаПроизводствеПострадавшие.Ссылка КАК Ссылка,
		|	НесчастныйСлучайНаПроизводствеПострадавшие.РабочееМесто КАК РабочееМесто,
		|	НесчастныйСлучайНаПроизводствеПострадавшие.Пострадавший КАК Пострадавший,
		|	НесчастныйСлучайНаПроизводствеПострадавшие.Ссылка.ДатаПроисшествия КАК ДатаПроисшествия
		|ПОМЕСТИТЬ ВТНесчастныеСлучаи
		|ИЗ
		|	Документ.НесчастныйСлучайНаПроизводстве.Пострадавшие КАК НесчастныйСлучайНаПроизводствеПострадавшие
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.НесчастныйСлучайНаПроизводстве.МедицинскиеОсмотры КАК
		|			НесчастныйСлучайНаПроизводствеМедицинскиеОсмотры
		|		ПО (НесчастныйСлучайНаПроизводствеПострадавшие.Ссылка = НесчастныйСлучайНаПроизводствеМедицинскиеОсмотры.Ссылка)
		|		И
		|			(НесчастныйСлучайНаПроизводствеПострадавшие.Пострадавший = НесчастныйСлучайНаПроизводствеМедицинскиеОсмотры.Пострадавший)
		|ГДЕ
		|	НесчастныйСлучайНаПроизводствеПострадавшие.Ссылка.ДатаПроисшествия >= &ДатаПриказа223Н
		|	И ВЫБОР
		|		КОГДА ИСТИНА В
		|			(ВЫБРАТЬ ПЕРВЫЕ 1
		|				ИСТИНА
		|			ИЗ
		|				РегистрСведений.ПериодическиеМедицинскиеОсмотры КАК ПериодическиеМедицинскиеОсмотры
		|			ГДЕ
		|				ПериодическиеМедицинскиеОсмотры.ФизическоеЛицо = НесчастныйСлучайНаПроизводствеПострадавшие.Пострадавший
		|				И ПериодическиеМедицинскиеОсмотры.РабочееМесто = НесчастныйСлучайНаПроизводствеПострадавшие.РабочееМесто
		|				И
		|					ПериодическиеМедицинскиеОсмотры.ДатаПройденногоОсмотра <= НесчастныйСлучайНаПроизводствеПострадавшие.Ссылка.ДатаПроисшествия)
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ
		|	И НесчастныйСлучайНаПроизводствеМедицинскиеОсмотры.РезультатОсмотра ЕСТЬ NULL
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НесчастныеСлучаи.Ссылка КАК Ссылка,
		|	ПериодическиеМедицинскиеОсмотры.ДатаПройденногоОсмотра КАК ДатаПройденногоОсмотра,
		|	ПериодическиеМедицинскиеОсмотры.ФизическоеЛицо КАК Пострадавший,
		|	ПериодическиеМедицинскиеОсмотры.ВидОсмотра КАК ВидОсмотра,
		|	ПериодическиеМедицинскиеОсмотры.РезультатОсмотра КАК РезультатОсмотра
		|ИЗ
		|	РегистрСведений.ПериодическиеМедицинскиеОсмотры КАК ПериодическиеМедицинскиеОсмотры
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТНесчастныеСлучаи КАК НесчастныеСлучаи
		|		ПО ПериодическиеМедицинскиеОсмотры.ФизическоеЛицо = НесчастныеСлучаи.Пострадавший
		|		И ПериодическиеМедицинскиеОсмотры.РабочееМесто = НесчастныеСлучаи.РабочееМесто
		|		И ПериодическиеМедицинскиеОсмотры.ДатаПройденногоОсмотра <= НесчастныеСлучаи.ДатаПроисшествия
		|ИТОГИ
		|ПО
		|	Ссылка";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		ОбновлениеИБ.ЗавершитьОбработчик(ПараметрыОбновления);
		Возврат;
	КонецЕсли;
	
	ОбновлениеИБ.ПродолжитьОбработчик(ПараметрыОбновления);
	
	ВыборкаДокументов = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаДокументов.Следующий() Цикл
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("Документ.НесчастныйСлучайНаПроизводстве");
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		ЭлементБлокировки.УстановитьЗначение("Ссылка", ВыборкаДокументов.Ссылка);
		НачатьТранзакцию();
		Попытка
			Блокировка.Заблокировать();
			ДокументОбъект = ВыборкаДокументов.Ссылка.ПолучитьОбъект();
			ДокументОбъект.МедицинскиеОсмотры.Очистить();
			Выборка = ВыборкаДокументов.Выбрать();
			Пока Выборка.Следующий() Цикл
				ЗаполнитьЗначенияСвойств(ДокументОбъект.МедицинскиеОсмотры.Добавить(), Выборка);
			КонецЦикла;
			ДокументОбъект.ОбменДанными.Загрузка = Истина;
			ДокументОбъект.Записать();
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ТекстСообщения = СтрШаблон(
				НСтр("ru = 'Заполнение табличной части Медосмотры документа %1.Ошибка блокировки'",
				ОбщегоНазначения.КодОсновногоЯзыка()), ВыборкаДокументов.Ссылка);
			ЗаписьЖурналаРегистрации(ТекстСообщения, УровеньЖурналаРегистрации.Ошибка, , ВыборкаДокументов.Ссылка,
				ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			Продолжить;
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ВыгрузкаЗагрузкаДанных

// Заполняет массив типов неразделенных данных, для которых поддерживается сопоставление ссылок
// при загрузке данных в другую информационную базу.
//
// Параметры:
//  Типы - Массив(ОбъектМетаданных).
//
Процедура ПриЗаполненииТиповОбщихДанныхПоддерживающихСопоставлениеСсылокПриЗагрузке(Типы) Экспорт
	
	// Здесь перечисляются неразделенные объекты метаданных ссылочного типа, имеющие непредопределенные элементы.
	// В модуле менеджера таких объектов должна быть определена функция ПоляЕстественногоКлюча, 
	// составляющая массив полей для однозначной идентификации элемента.
	
	Типы.Добавить(Метаданные.Справочники.ВидыПроисшествий);
	Типы.Добавить(Метаданные.Справочники.ПричиныПроисшествий);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти