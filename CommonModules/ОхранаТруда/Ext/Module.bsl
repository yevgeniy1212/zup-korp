Процедура ИзменитьНаименованияРабочихМест(РабочиеМеста, ТаблицаАналогичныхМест)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВТАналогичныеРабочиеМеста.АналогичноеРабочееМесто КАК АналогичноеРабочееМесто,
		|	ВТАналогичныеРабочиеМеста.РабочееМесто КАК РабочееМесто
		|ПОМЕСТИТЬ ВТАналогичныеРабочиеМеста
		|ИЗ
		|	&АналогичныеРабочиеМеста КАК ВТАналогичныеРабочиеМеста
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РабочиеМестаОхраныТруда.Ссылка КАК Ссылка,
		|	РабочиеМестаОхраныТруда.Наименование КАК Наименование,
		|	РабочиеМестаОхраныТруда.Подразделение КАК Подразделение,
		|	РабочиеМестаОхраныТруда.Должность КАК Должность,
		|	РабочиеМестаОхраныТруда.Номер КАК Номер
		|ПОМЕСТИТЬ ВТРабочиеМеста
		|ИЗ
		|	Справочник.РабочиеМестаОхраныТруда КАК РабочиеМестаОхраныТруда
		|ГДЕ
		|	РабочиеМестаОхраныТруда.Ссылка В(&РабочиеМеста)
		|	И НЕ РабочиеМестаОхраныТруда.НомерВручную
		|	И НЕ РабочиеМестаОхраныТруда.ЭтоГруппа
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТРабочиеМеста.Ссылка КАК Ссылка,
		|	ВТРабочиеМеста.Наименование КАК Наименование,
		|	ВТРабочиеМеста.Подразделение КАК Подразделение,
		|	ВТРабочиеМеста.Должность КАК Должность,
		|	ВТРабочиеМеста.Номер КАК Номер,
		|	ЕСТЬNULL(ВТАналогичныеРабочиеМеста.РабочееМесто.Номер, """") КАК НомерОсновногоРабочегоМеста
		|ИЗ
		|	ВТРабочиеМеста КАК ВТРабочиеМеста
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТАналогичныеРабочиеМеста КАК ВТАналогичныеРабочиеМеста
		|		ПО ВТРабочиеМеста.Ссылка = ВТАналогичныеРабочиеМеста.АналогичноеРабочееМесто";
	
	Запрос.УстановитьПараметр("АналогичныеРабочиеМеста", ТаблицаАналогичныхМест);
	Запрос.УстановитьПараметр("РабочиеМеста", РабочиеМеста);
	
	РезультатЗапроса = Запрос.Выполнить();	
	ДанныеНаименования = РезультатЗапроса.Выбрать();
	
	Пока ДанныеНаименования.Следующий() Цикл
		НовоеНаименование = НаименованиеРабочегоМеста(
			ДанныеНаименования.Подразделение,
			ДанныеНаименования.Должность,
			ДанныеНаименования.Номер,
			ДанныеНаименования.НомерОсновногоРабочегоМеста);
	
		Если ДанныеНаименования.Наименование = НовоеНаименование Тогда
			Продолжить;
		КонецЕсли;
		
		Попытка
			ЗаблокироватьДанныеДляРедактирования(ДанныеНаименования.Ссылка);
		Исключение
			ТекстОшибки = СтрШаблон(
				НСтр("ru = 'Не удалось изменить наименование рабочего места ""%1"":
				|%2'"),
				ДанныеНаименования.Наименование,
				КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			ОбщегоНазначения.СообщитьПользователю(ТекстОшибки);
			Продолжить;
		КонецПопытки;
		
		РабочееМестоОбъект = ДанныеНаименования.Ссылка.ПолучитьОбъект();
		РабочееМестоОбъект.Наименование = НовоеНаименование;
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(РабочееМестоОбъект);
		РазблокироватьДанныеДляРедактирования(ДанныеНаименования.Ссылка);
	КонецЦикла;
	
КонецПроцедуры

