
#Область СлужебныйПрограммныйИнтерфейс

Процедура ДополнитьОписаниеПрофиля(ОписаниеПрофиля) Экспорт
	
	ЗарплатаКадрыРасширенный.ДобавитьВОписаниеПрофиляРоль(ОписаниеПрофиля, "ИспользованиеИнтеграцииРекрутинговыхСайтов", "ЗарплатаКадрыКорпоративнаяПодсистемы.ИнтеграцияРекрутинговыхСайтов");	
	
КонецПроцедуры

// См. ОбновлениеИнформационнойБазыБСП.ПриДобавленииОбработчиковОбновления.
Процедура ЗарегистрироватьОбработчикиОбновления(Обработчики) Экспорт
	
	Обработчик = Обработчики.Добавить();
	Обработчик.Версия				= "3.1.17.1";
	Обработчик.Идентификатор		= Новый УникальныйИдентификатор("5460f494-0d67-11eb-a3ee-4cedfb950b0c");
	Обработчик.Процедура			= "РекрутинговыеСайты.НачальноеЗаполнениеОтветственныхВПубликацияхВакансий";
	Обработчик.РежимВыполнения		= "Отложенно";
	Обработчик.Комментарий			= НСтр("ru = 'Первоначальное заполнение ответственных за публикацию вакансий'");
	
КонецПроцедуры

Процедура ОчиститьНастройкиИнтеграцииРекрутинговыхСайтов() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	НачатьТранзакцию();
	Попытка
		Блокировка = Новый БлокировкаДанных;
		Блокировка.Добавить("РегистрСведений.НастройкиИнтеграцииРекрутинговыхСайтов");
		Блокировка.Заблокировать();
		
		Набор = РегистрыСведений.НастройкиИнтеграцииРекрутинговыхСайтов.СоздатьНаборЗаписей();
		Набор.Прочитать();
		
		Для Каждого Запись Из Набор Цикл
			Запись.Использовать = Ложь;
		КонецЦикла;
		
		Набор.Записать();
	Исключение
		ОтменитьТранзакцию();
		
		Описание = НСтр("ru = 'Не удалоось очистить настройки интеграции с рекрутинговыми сайтами.'");
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Очистка настроек интеграции с рекрутинговыми сайтами'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,,,
			Описание + Символы.ПС + ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат;
	КонецПопытки;
	
	ЗафиксироватьТранзакцию();
	
КонецПроцедуры

Процедура НачальноеЗаполнениеОтветственныхВПубликацияхВакансий(ПараметрыОбновления = Неопределено) Экспорт
	
	ПараметрыОбновления.ОбработкаЗавершена = Истина;
	ЗаполненыОтветственныеВПубликацияхВакансий();
	
КонецПроцедуры

// См. РаботаВБезопасномРежимеПереопределяемый.ПриЗаполненииРазрешенийНаДоступКВнешнимРесурсам.
Процедура ПриЗаполненииРазрешенийНаДоступКВнешнимРесурсам(ЗапросыРазрешений) Экспорт
	
	Разрешения = Новый Массив;
	Для Каждого ОписаниеСайта Из АдресаРекрутинговыхСайтов() Цикл
		Разрешения.Добавить(
			РаботаВБезопасномРежиме.РазрешениеНаИспользованиеИнтернетРесурса("HTTPS", ОписаниеСайта.Адрес, , 
				СтрШаблон(НСтр("ru = 'Веб-сервис доступа к вакансиям и кандидатам ""%1.""'"), ОписаниеСайта.Наименование)));
	КонецЦикла;
	ЗапросыРазрешений.Добавить(РаботаВБезопасномРежиме.ЗапросНаИспользованиеВнешнихРесурсов(Разрешения));
	
КонецПроцедуры

// См. процедуру РегламентныеЗаданияПереопределяемый.ПриОпределенииНастроекРегламентныхЗаданий.
Процедура ПриОпределенииНастроекРегламентныхЗаданий(Настройки) Экспорт

	Настройка = Настройки.Добавить();
	Настройка.РегламентноеЗадание = Метаданные.РегламентныеЗадания.ПолучениеОткликовСРекрутинговыхСайтов;
	Настройка.ФункциональнаяОпция = Метаданные.ФункциональныеОпции.ИспользоватьИнтеграциюРекрутинговыхСайтов;
	Настройка.РаботаетСВнешнимиРесурсами = Истина;

	ЗагрузкаКандидатовИзИнтернета.ПриОпределенииНастроекРегламентныхЗаданий(Настройки);

КонецПроцедуры

// Процедура регламентного задания ПолучениеОткликовСРекрутинговыхСайтов.
//
Процедура ПолучениеОткликовСРекрутинговыхСайтов() Экспорт
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.ПолучениеОткликовСРекрутинговыхСайтов);
	ПолучитьВсеОтклики();
	
КонецПроцедуры

#Область ОчередьЗаданий

// См. ОчередьЗаданийПереопределяемый.ПриПолученииСпискаШаблонов.
Процедура ПриПолученииСпискаШаблоновОчередиЗаданий(Шаблоны) Экспорт
	Шаблоны.Добавить(Метаданные.РегламентныеЗадания.ПолучениеОткликовСРекрутинговыхСайтов.Имя);
	ЗагрузкаКандидатовИзИнтернета.ПриПолученииСпискаШаблоновОчередиЗаданий(Шаблоны);
КонецПроцедуры

// См. ОчередьЗаданийПереопределяемый.ПриОпределенииПсевдонимовОбработчиков.
Процедура ПриОпределенииПсевдонимовОбработчиков(СоответствиеИменПсевдонимам) Экспорт
	СоответствиеИменПсевдонимам.Вставить(Метаданные.РегламентныеЗадания.ПолучениеОткликовСРекрутинговыхСайтов.ИмяМетода);
	ЗагрузкаКандидатовИзИнтернета.ПриОпределенииПсевдонимовОбработчиков(СоответствиеИменПсевдонимам);
КонецПроцедуры

#КонецОбласти

#Область ТекущиеДела

// См. ТекущиеДелаПереопределяемый.ПриОпределенииОбработчиковТекущихДел.
Процедура ПриОпределенииОбработчиковТекущихДел(Обработчики) Экспорт
	
	Если Не ИспользуетсяИнтеграцияРекрутинговыхСайтов() Тогда
		Возврат;
	КонецЕсли;
	
	Обработчики.Добавить(РекрутинговыеСайты);
	
КонецПроцедуры

// См. ТекущиеДелаПереопределяемый.ПриОпределенииОбработчиковТекущихДел.
Процедура ПриЗаполненииСпискаТекущихДел(ТекущиеДела) Экспорт
	
	Если ОбщегоНазначения.РазделениеВключено() Тогда
		Возврат; // Модель сервиса.
	КонецЕсли;
	
	Если Не ПравоДоступа("Чтение", Метаданные.Справочники.Вакансии) Тогда
		Возврат; // Нет прав.
	КонецЕсли;
	
	МодульТекущиеДелаСервер = ОбщегоНазначения.ОбщийМодуль("ТекущиеДелаСервер");
	Разделы = МодульТекущиеДелаСервер.РазделыДляОбъекта("Справочник.Вакансии");
	Если Разделы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ОтборОткликов = Новый ОтборКомпоновкиДанных();
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ОтборОткликов, "Ответственный", Пользователи.АвторизованныйПользователь());
	ОткликиКандидатов = ПодборПерсонала.ОткликиКандидатов(ОтборОткликов.Элементы);
	
	КоличествоОткликов = ОткликиКандидатов.Количество();
	Если КоличествоОткликов = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Раздел Из Разделы Цикл
		Дело = ТекущиеДела.Добавить();
		Дело.Идентификатор	= "НеРассмотренныеОтклики";
		Дело.ЕстьДела		= Истина;
		Дело.Важное			= Истина;
		Дело.Владелец		= Раздел;
		Дело.Представление	= НСтр("ru = 'Есть не рассмотренные отклики'");
		Дело.Количество		= КоличествоОткликов;
		Дело.Форма			= "Справочник.Вакансии.Форма.ФормаСписка";
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

// Возвращаемое значение:
//  Булево
Функция ИспользуетсяИнтеграцияРекрутинговыхСайтов() Экспорт
	
	Возврат ПолучитьФункциональнуюОпцию("ИспользоватьИнтеграциюРекрутинговыхСайтов");
	
КонецФункции

// Возвращаемое значение:
//  Булево
Функция ДоступнаИнтеграцияРекрутинговыхСайтов() Экспорт
	
	Возврат ИспользуетсяИнтеграцияРекрутинговыхСайтов()
		И ПравоДоступа("Использование", Метаданные.Обработки.ПубликацияВакансийНаРекрутинговыхСайтах);
	
КонецФункции

Функция ИспользуемыеСайты() Экспорт

	Возврат Новый ФиксированныйМассив(РекрутинговыеСайтыВнутренний.ИспользуемыеСайты());

КонецФункции

Функция НастроенныеСайты(Пользователь = Неопределено) Экспорт

	НастроенныеСайты = Новый Массив();
	
	Если Не ИспользуетсяИнтеграцияРекрутинговыхСайтов() Тогда
		Возврат Новый ФиксированныйМассив(НастроенныеСайты);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Пользователь) Тогда
		Пользователь = Пользователи.ТекущийПользователь();
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	НастройкиИнтеграцииРекрутинговыхСайтов.РекрутинговыйСайт КАК Ссылка
	|ИЗ
	|	РегистрСведений.НастройкиИнтеграцииРекрутинговыхСайтов КАК НастройкиИнтеграцииРекрутинговыхСайтов
	|ГДЕ
	|	НастройкиИнтеграцииРекрутинговыхСайтов.Пользователь = &Пользователь
	|	И НастройкиИнтеграцииРекрутинговыхСайтов.Использовать";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		НастроенныеСайты.Добавить(Выборка.Ссылка);
	КонецЦикла;
	
	Возврат Новый ФиксированныйМассив(НастроенныеСайты);

КонецФункции

Функция ДанныеСайтов(Сайты = Неопределено) Экспорт

	Возврат РекрутинговыеСайтыСлужебный.ДанныеСайтов(Сайты);

КонецФункции

// См. Обработки.МенеджерИнтеграцииСРекрутинговымиСайтами.НовыйМенеджер
Функция МенеджерРекрутинговыхСайтов(Сайты = Неопределено, Пользователь = Неопределено, ТолькоНастроенные = Истина) Экспорт
	
	Возврат РекрутинговыеСайтыСлужебный.МенеджерРекрутинговыхСайтов(Сайты, Пользователь, ТолькоНастроенные);
	
КонецФункции

#Область Интерфейс

Функция ПроверитьПодключение(Сайты = Неопределено) Экспорт
	
	Менеджер = МенеджерРекрутинговыхСайтов(Сайты, Пользователи.ТекущийПользователь(), Ложь);
	
	Возврат Менеджер.ПроверитьПодключение();
	
КонецФункции

Функция Подключить(ПараметрыПодключения) Экспорт
	
	Менеджер = МенеджерРекрутинговыхСайтов(
		ПараметрыПодключения.Сайт, Пользователи.ТекущийПользователь(), Ложь);
	
	Возврат Менеджер.Подключить(ПараметрыПодключения);
	
КонецФункции

Функция ЗагрузитьКлассификаторы(Сайты) Экспорт
	
	Менеджер = МенеджерРекрутинговыхСайтов(Сайты);
	
	Возврат Менеджер.ЗагрузитьКлассификаторы();
	
КонецФункции

// См. РекрутинговыеСайтыСлужебный.СохранитьКлассификаторы
Процедура СохранитьКлассификаторы(Классификаторы, ДанныеСайтов) Экспорт
	
	РекрутинговыеСайтыСлужебный.СохранитьКлассификаторы(Классификаторы, ДанныеСайтов);
	
КонецПроцедуры

Функция НайтиКандидатов(ПараметрыПроцедуры, УникальныйИдентификатор, АдресХранилища) Экспорт
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияВФоне(УникальныйИдентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Поиск кандидатов'");
	
	Результат = ДлительныеОперации.ВыполнитьВФоне(
		"РекрутинговыеСайты.ВыполнитьПоискКандидатов",
		ПараметрыПроцедуры,
		ПараметрыВыполнения);
	
	АдресХранилища = Результат.АдресРезультата;
	
	Возврат Результат;
	
КонецФункции

Функция ВыполнитьПоискКандидатов(Параметры) Экспорт
	
	Менеджер = МенеджерРекрутинговыхСайтов(Параметры.Сайты);
	
	Возврат Менеджер.НайтиКандидатов(Параметры);
	
КонецФункции

// Параметры:
//  Сайт - СправочникСсылка.ИсточникиИнформацииОКандидатах
//  Пользователь - Неопределено, СправочникСсылка.Пользователи -
//  БылиОшибки - Булево
// 
// Возвращаемое значение:
//  Неопределено, Массив Из СправочникСсылка.Вакансии -
Функция ВакансииССайта(Сайт, Пользователь = Неопределено, БылиОшибки = Ложь) Экспорт
	
	Менеджер = МенеджерРекрутинговыхСайтов(Сайт, Пользователь);
	
	Возврат Менеджер.ВакансииССайта(Сайт, БылиОшибки);
	
КонецФункции

Функция ОпубликоватьВакансию(Вакансия, Сайт, Дерево) Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией();
	
	Менеджер = МенеджерРекрутинговыхСайтов(Сайт);
	
	Результат = Менеджер.ОпубликоватьВакансию(Сайт, Дерево);
	
	ИдентификаторВакансии = Результат.ИдентификаторВакансии;
	
	Если ЗначениеЗаполнено(ИдентификаторВакансии) Тогда
		ИдентификаторВакансии = Формат(ИдентификаторВакансии, "ЧГ=0");
		
		АдресПубликации = Менеджер.АдресВакансии(Сайт, ИдентификаторВакансии);
		
		РекрутинговыеСайтыСлужебный.ЗаписьВРегистрИнформацииОПубликации(
			Вакансия, Сайт, ИдентификаторВакансии, АдресПубликации);
		
		ЗаписьВРегистрДанныеПубликации(Вакансия, Сайт, Дерево);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПрименитьТарифКВакансии(Сайт, Идентификатор, Тариф) Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией();
	
	Менеджер = МенеджерРекрутинговыхСайтов(Сайт);
	
	Результат = Менеджер.ПрименитьТарифКВакансии(Сайт, Идентификатор, Тариф);
	
	Возврат Результат;
	
КонецФункции

Функция ПовторноОпубликоватьВакансию(Вакансия, Сайт, Дерево, ИдентификаторВакансии = Неопределено) Экспорт
	
	Менеджер = МенеджерРекрутинговыхСайтов(Сайт);
	
	Результат = Менеджер.ПовторноОпубликоватьВакансию(Сайт, Дерево, Вакансия, ИдентификаторВакансии);
	
	Если Результат.Успешно Тогда
		ИдентификаторВакансии = Формат(ИдентификаторВакансии, "ЧГ=0");
		АдресПубликации = Менеджер.АдресВакансии(Сайт, ИдентификаторВакансии);
		
		РекрутинговыеСайтыСлужебный.ЗаписьВРегистрИнформацииОПубликации(
			Вакансия, Сайт, ИдентификаторВакансии, АдресПубликации);
			
		ЗаписьВРегистрДанныеПубликации(Вакансия, Сайт, Дерево);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОбновитьПубликациюВакансии(Вакансия, Сайт, Дерево, ИдентификаторВакансии = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(ИдентификаторВакансии) Тогда
		ИдентификаторВакансии = РекрутинговыеСайтыСлужебный.ИдентификаторВакансии(Вакансия, Сайт);
	КонецЕсли;
	
	Менеджер = МенеджерРекрутинговыхСайтов(Сайт);
	
	Результат = Менеджер.ОбновитьПубликациюВакансии(Сайт, Дерево, ИдентификаторВакансии);
	
	Если Результат.Успешно Тогда
		РекрутинговыеСайтыСлужебный.ЗаписьВРегистрИнформацииОПубликации(Вакансия, Сайт);
		ЗаписьВРегистрДанныеПубликации(Вакансия, Сайт, Дерево);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СинхронизироватьСвойстваПубликацииВакансии(Вакансия, Сайт, ИдентификаторВакансии = Неопределено) Экспорт
	
	Успешно = Истина;
	
	Если Не ЗначениеЗаполнено(ИдентификаторВакансии) Тогда
		ИдентификаторВакансии = РекрутинговыеСайтыСлужебный.ИдентификаторВакансии(Вакансия, Сайт);
	КонецЕсли;
	
	ТекущиеСвойства = СвойстваПубликацииВакансии(Вакансия, Сайт);
	СвойстваНаСайте = СвойстваПубликацииВакансииНаСайте(Сайт, ИдентификаторВакансии);
	
	Если ЗначениеЗаполнено(СвойстваНаСайте) Тогда
		Если ТекущиеСвойства.Опубликована <> СвойстваНаСайте.Опубликована Тогда
			РекрутинговыеСайтыСлужебный.ЗаписьВРегистрИнформацииОПубликации(Вакансия, Сайт , , , СвойстваНаСайте);
		КонецЕсли;
	Иначе
		Успешно = Ложь;
	КонецЕсли;
	
	Возврат Успешно;
	
КонецФункции

Функция СвойстваПубликацииВакансии(Вакансия, Сайт) Экспорт
	
	СвойстваПубликации = РекрутинговыеСайтыСлужебный.НовыеСвойстваПубликацииВакансии();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПубликацияВакансий.ДатаПубликации КАК ДатаПубликации,
	|	ПубликацияВакансий.ДатаОбновления КАК ДатаОбновления,
	|	ПубликацияВакансий.ДатаСнятияСПубликации КАК ДатаСнятияСПубликации,
	|	ВЫБОР
	|		КОГДА ПубликацияВакансий.ДатаПубликации <> &ПустаяДата
	|				И ПубликацияВакансий.ДатаСнятияСПубликации = &ПустаяДата
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК Опубликована
	|ИЗ
	|	РегистрСведений.ПубликацияВакансий КАК ПубликацияВакансий
	|ГДЕ
	|	ПубликацияВакансий.Вакансия = &Вакансия
	|	И ПубликацияВакансий.МестоПубликации = &Сайт";
	
	Запрос.УстановитьПараметр("Вакансия", Вакансия);
	Запрос.УстановитьПараметр("Сайт", Сайт);
	Запрос.УстановитьПараметр("ПустаяДата", '00010101');
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(СвойстваПубликации, Выборка);
	КонецЕсли;
	
	Возврат СвойстваПубликации;
	
КонецФункции

// Параметры:
//  Вакансия - СправочникСсылка.Вакансии
//  Сайт - СправочникСсылка.ИсточникиИнформацииОКандидатах
//  ИдентификаторВакансии - Неопределено, Строка -
// 
// Возвращаемое значение:
//  См. РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией
Функция СнятьПубликациюВакансии(Вакансия, Сайт, ИдентификаторВакансии = Неопределено) Экспорт
	
	Если Не ЗначениеЗаполнено(ИдентификаторВакансии) Тогда
		ИдентификаторВакансии = РекрутинговыеСайтыСлужебный.ИдентификаторВакансии(Вакансия, Сайт);
	КонецЕсли;
	
	Менеджер = МенеджерРекрутинговыхСайтов(Сайт);
	
	РезультатДействия = Менеджер.СнятьПубликациюВакансии(Сайт, ИдентификаторВакансии);
	
	Если РезультатДействия.Успешно Тогда
		ОтметитьПубликациюВакансииСнятой(Вакансия, Сайт);
	КонецЕсли;
	
	Возврат РезультатДействия;
	
КонецФункции

Процедура ПолучитьОтклики(Вакансия, Сайт, Пользователь = Неопределено) Экспорт
	
	Менеджер = МенеджерРекрутинговыхСайтов(Сайт, Пользователь);
	
	Менеджер.ПолучитьОтклики(Сайт, Вакансия);

КонецПроцедуры

Функция ОтветственныйЗаПубликацию(Вакансия, Сайт) Экспорт
	
	Результат = Неопределено;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ПубликацияВакансий.Ответственный КАК Ответственный
	|ИЗ
	|	РегистрСведений.ПубликацияВакансий КАК ПубликацияВакансий
	|ГДЕ
	|	ПубликацияВакансий.Вакансия = &Вакансия
	|	И ПубликацияВакансий.МестоПубликации = &МестоПубликации");
	Запрос.УстановитьПараметр("Вакансия", Вакансия);
	Запрос.УстановитьПараметр("МестоПубликации", Сайт);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Результат;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Выборка.Следующий();
	Если ЗначениеЗаполнено(Выборка.Ответственный) Тогда
		Результат = Выборка.Ответственный;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПоляВакансии(Сайт, ОбновлениеПубликации = Ложь, ПовторнаяПубликация = Ложь) Экспорт
	
