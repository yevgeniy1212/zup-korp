Функция АдресаРекрутинговыхСайтов()
	
	АдресаСайтов = Новый Массив();
	
	РекрутинговыеСайтыВнутренний.ПриЗаполненииАдресовРекрутинговыхСайтов(АдресаСайтов);
	
	Возврат АдресаСайтов;
	
КонецФункции

Функция ПоляСТекстом(Сайт)
	
	ПоляСТекстом = Новый Массив;
	ВидыПолей = ВидыПолей(Сайт);
	
	ПоляСМногострочнымВводом = ВидыПолей.СМногострочнымВводом;
	ПоляСТекстомВHTML = ВидыПолей.СТекстомВHTML;
	
	Если ЗначениеЗаполнено(ПоляСМногострочнымВводом) Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ПоляСТекстом, ПоляСМногострочнымВводом);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПоляСТекстомВHTML) Тогда
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(ПоляСТекстом, ПоляСТекстомВHTML);
	КонецЕсли;
	
	Возврат ПоляСТекстом;
	
КонецФункции

Функция ПредставлениеСпискаВВидеМассиваСтруктур(Список)
	
	МассивЗначений = Новый Массив;
	
	Для Каждого ЭлементСписка Из Список Цикл
		СтруктураЗначений = Новый Структура;
		СтруктураЗначений.Вставить("Значение", ЭлементСписка.Значение);
		СтруктураЗначений.Вставить("Представление", ЭлементСписка.Представление);
		
		МассивЗначений.Добавить(СтруктураЗначений);
	КонецЦикла;
	
	Возврат МассивЗначений;
	
КонецФункции

// Параметры:
//  Вакансия - СправочникСсылка.Вакансии
//  Сайт - СправочникСсылка.ИсточникиИнформацииОКандидатах
Процедура ОтметитьПубликациюВакансииСнятой(Вакансия, Сайт) Экспорт
	
	СвойстваПубликации = РекрутинговыеСайтыСлужебный.НовыеСвойстваПубликацииВакансии();
	СвойстваПубликации.ДатаСнятияСПубликации = ТекущаяДатаСеанса();
	
	РекрутинговыеСайтыСлужебный.ЗаписьВРегистрИнформацииОПубликации(Вакансия, Сайт, , , СвойстваПубликации);
	
КонецПроцедуры

Функция ЗаполненыОтветственныеВПубликацияхВакансий()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	НастройкиИнтеграцииРекрутинговыхСайтов.Пользователь КАК Пользователь,
	|	НастройкиИнтеграцииРекрутинговыхСайтов.РекрутинговыйСайт КАК Сайт
	|ИЗ
	|	РегистрСведений.НастройкиИнтеграцииРекрутинговыхСайтов КАК НастройкиИнтеграцииРекрутинговыхСайтов
	|ГДЕ
	|	НастройкиИнтеграцииРекрутинговыхСайтов.Использовать");
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Истина;
	КонецЕсли;
	
	Таблица = Новый ТаблицаЗначений;
	Таблица.Колонки.Добавить("Сайт", Новый ОписаниеТипов("СправочникСсылка.ИсточникиИнформацииОКандидатах"));
	Таблица.Колонки.Добавить("Пользователь", Новый ОписаниеТипов("СправочникСсылка.Пользователи"));
	Таблица.Колонки.Добавить("ИдентификаторВакансии", Новый ОписаниеТипов("Строка"));
	
	ДанныеСайтов = ДанныеСайтов();
	
	БылиОшибки = Ложь;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		
		Вакансии = ВакансииССайта(Выборка.Сайт, Выборка.Пользователь, БылиОшибки);
		Если Не ЗначениеЗаполнено(Вакансии) Тогда
			Продолжить;
		КонецЕсли;
		
		ДанныеСайта = ДанныеСайтов[Выборка.Сайт];
		
		Для Каждого Вакансия Из Вакансии Цикл
			НоваяСтрока = Таблица.Добавить();
			НоваяСтрока.Сайт = Выборка.Сайт;
			НоваяСтрока.Пользователь = Выборка.Пользователь;
			НоваяСтрока.ИдентификаторВакансии = 
				Формат(Вакансия[ДанныеСайта.ИменаПутейКДаннымВакансии.Идентификатор], "ЧГ=0");
		КонецЦикла;
	КонецЦикла;
	
	Если Таблица.Количество() = 0 Тогда
		Возврат Не БылиОшибки;
	КонецЕсли;
	
	НачатьТранзакцию();
	Попытка
		Блокировка = Новый БлокировкаДанных;
		ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.ПубликацияВакансий");
		ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;
		ЭлементБлокировки.ИсточникДанных = Таблица;
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("ИдентификаторВакансии", "ИдентификаторВакансии");
		ЭлементБлокировки.ИспользоватьИзИсточникаДанных("МестоПубликации", "Сайт");
		Блокировка.Заблокировать();
	
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	Таблица.Сайт КАК Сайт,
		|	Таблица.Пользователь КАК Пользователь,
		|	Таблица.ИдентификаторВакансии КАК ИдентификаторВакансии
		|ПОМЕСТИТЬ ВТТаблица
		|ИЗ
		|	&Таблица КАК Таблица
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПубликацияВакансий.Вакансия КАК Вакансия,
		|	ПубликацияВакансий.МестоПубликации КАК МестоПубликации,
		|	ВТТаблица.Пользователь КАК Пользователь
		|ИЗ
		|	РегистрСведений.ПубликацияВакансий КАК ПубликацияВакансий
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТТаблица КАК ВТТаблица
		|		ПО ((ВЫРАЗИТЬ(ПубликацияВакансий.ИдентификаторВакансии КАК СТРОКА(100))) = (ВЫРАЗИТЬ(ВТТаблица.ИдентификаторВакансии КАК СТРОКА(100))))
		|			И ПубликацияВакансий.МестоПубликации = ВТТаблица.Сайт");
		Запрос.УстановитьПараметр("Таблица", Таблица);
		
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() Тогда
			ЗафиксироватьТранзакцию();
			Возврат Не БылиОшибки;
		КонецЕсли;
	
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл
			НаборЗаписей = РегистрыСведений.ПубликацияВакансий.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Вакансия.Установить(Выборка.Вакансия);
			НаборЗаписей.Отбор.МестоПубликации.Установить(Выборка.МестоПубликации);
			НаборЗаписей.Прочитать();
			Если НаборЗаписей.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			НаборЗаписей[0].Ответственный = Выборка.Пользователь;
			ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей);
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
		Возврат Не БылиОшибки;
		
	Исключение
		ОтменитьТранзакцию();
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Заполнение ответственных в публикациях вакансий'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,,,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции

Процедура ПолучитьВсеОтклики()
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	НастройкиИнтеграцииРекрутинговыхСайтов.Пользователь КАК Пользователь,
	|	НастройкиИнтеграцииРекрутинговыхСайтов.РекрутинговыйСайт КАК РекрутинговыйСайт
	|ПОМЕСТИТЬ ВТ_ПользователиСайты
	|ИЗ
	|	РегистрСведений.НастройкиИнтеграцииРекрутинговыхСайтов КАК НастройкиИнтеграцииРекрутинговыхСайтов
	|ГДЕ
	|	НастройкиИнтеграцииРекрутинговыхСайтов.Использовать
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_ПользователиСайты.РекрутинговыйСайт КАК Сайт,
	|	ВТ_ПользователиСайты.Пользователь КАК Пользователь,
	|	ПубликацияВакансий.Вакансия КАК Вакансия,
	|	ПубликацияВакансий.Ответственный
	|ИЗ
	|	ВТ_ПользователиСайты КАК ВТ_ПользователиСайты
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ПубликацияВакансий КАК ПубликацияВакансий
	|		ПО ВТ_ПользователиСайты.РекрутинговыйСайт = ПубликацияВакансий.МестоПубликации
	|		И ВТ_ПользователиСайты.Пользователь = ПубликацияВакансий.Ответственный
	|		И (ПубликацияВакансий.ДатаСнятияСПубликации = ДАТАВРЕМЯ(1, 1, 1))");
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		ПолучитьОтклики(Выборка.Вакансия, Выборка.Сайт, Выборка.Пользователь);
	КонецЦикла;
	
КонецПроцедуры

Функция СвойстваПубликацииВакансииНаСайте(Сайт, ИдентификаторВакансии)
	
	Менеджер = МенеджерРекрутинговыхСайтов(Сайт);
	
	Возврат Менеджер.СвойстваПубликацииВакансииНаСайте(Сайт, ИдентификаторВакансии);
	
КонецФункции

#КонецОбласти
