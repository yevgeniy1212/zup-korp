КонецФункции

Функция ДанныеКандидатаССайта(АдресРезюме, Пользователь = Неопределено) Экспорт

	Если Не ЗначениеЗаполнено(Пользователь) Тогда
		Пользователь = Пользователи.ТекущийПользователь();
	КонецЕсли;
	
	ИспользуемыеСайты = НастроенныеСайты(Пользователь);
	
	ОбщегоНазначенияКлиентСервер.Проверить(ИспользуемыеСайты <> Неопределено Или ИспользуемыеСайты.Количество() > 0, 
		НСтр("ru = 'Не включено использование ни одного рекрутингового сайта.'"));
	
	Менеджер = МенеджерРекрутинговыхСайтов(, Пользователь, Ложь);
	
	ДанныеРезюмеПоАдресу = Менеджер.ДанныеРезюмеПоАдресу(АдресРезюме);
	
	ОбщегоНазначенияКлиентСервер.Проверить(ИспользуемыеСайты.Найти(ДанныеРезюмеПоАдресу.Сайт) <> Неопределено, 
		СтрШаблон(НСтр("ru = 'Адрес резюме с %1, но использование этого сайта не включено. 
						   |Проверьте подключение сайта в Персональных настройках.'"), ДанныеРезюмеПоАдресу.Сайт));
	
	Менеджер = МенеджерРекрутинговыхСайтов(ДанныеРезюмеПоАдресу.Сайт, Пользователь);
	
	ДанныеКандидата = Менеджер.ДанныеКандидатаССайта(ДанныеРезюмеПоАдресу.ИдентификаторРезюме);

	Возврат ДанныеКандидата;
	
КонецФункции

Функция СайтыСПубликациейВакансии(Вакансия, ПроверяемыеСайты = Неопределено, ТолькоАктивные = Ложь) Экспорт
	
	СайтыСПубликациями = СайтыСПубликациямиВакансий(Вакансия, ПроверяемыеСайты, ТолькоАктивные);
	
	Если СайтыСПубликациями.Количество() > 0 Тогда
		Возврат СайтыСПубликациями.Получить(Вакансия);
	Иначе
		Возврат Новый Массив;
	КонецЕсли;
	
КонецФункции

Функция СайтыСПубликациямиВакансий(Знач Вакансии, ПроверяемыеСайты = Неопределено, ТолькоАктивные = Ложь) Экспорт
	
	СайтыСПубликациямиВакансий = Новый Соответствие;
	
	Если Не ЗначениеЗаполнено(Вакансии) Тогда
		Возврат СайтыСПубликациямиВакансий;
	КонецЕсли;
	
	Если ТипЗнч(Вакансии) <> Тип("Массив") Тогда
		Вакансии = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Вакансии);
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ПубликацияВакансий.Вакансия КАК Вакансия,
	|	ПубликацияВакансий.МестоПубликации КАК Сайт
	|ИЗ
	|	РегистрСведений.ПубликацияВакансий КАК ПубликацияВакансий
	|ГДЕ
	|	ПубликацияВакансий.Вакансия В(&Вакансия)
	|	И &УсловиеПоСайтам
	|	И &УсловиеПоПубликация
	|ИТОГИ ПО
	|	Вакансия";
	
	Если ЗначениеЗаполнено(ПроверяемыеСайты) Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоСайтам", "ПубликацияВакансий.МестоПубликации В (&Сайты)");
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоСайтам", "ИСТИНА");
	КонецЕсли;
	
	Если ТолькоАктивные Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоПубликация", "ПубликацияВакансий.ДатаСнятияСПубликации = ДАТАВРЕМЯ(1, 1, 1)");
	Иначе
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "&УсловиеПоПубликация", "ИСТИНА");
	КонецЕсли;
	
	Запрос.УстановитьПараметр("Вакансия", Вакансии);
	Запрос.УстановитьПараметр("Сайты", ПроверяемыеСайты);
	
	ВыборкаВакансий = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаВакансий.Следующий() Цикл
		
		МестаПубликации = Новый Массив;
		ВыборкаМестПубликации = ВыборкаВакансий.Выбрать();
		
		Пока ВыборкаМестПубликации.Следующий() Цикл
			МестаПубликации.Добавить(ВыборкаМестПубликации.Сайт);
		КонецЦикла;
		
		СайтыСПубликациямиВакансий.Вставить(ВыборкаВакансий.Вакансия, МестаПубликации);
		
	КонецЦикла;
	
	Возврат СайтыСПубликациямиВакансий;
	
КонецФункции

// Параметры:
//  Вакансия - СправочникСсылка.Вакансии
// 
// Возвращаемое значение:
//  Неопределено, Массив Из СправочникСсылка.ИсточникиИнформацииОКандидатах -
Функция СайтыСПубликациями(Вакансия) Экспорт
	
	Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	ПубликацияВакансий.МестоПубликации КАК МестоПубликации
		|ИЗ
		|	РегистрСведений.ПубликацияВакансий КАК ПубликацияВакансий
		|ГДЕ
		|	ПубликацияВакансий.Вакансия = &Вакансия");
	Запрос.УстановитьПараметр("Вакансия", Вакансия);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	Иначе
		Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("МестоПубликации");
	КонецЕсли;
	
КонецФункции

Процедура ДобавитьКомментарийПользователя(ДанныеКандидата, Пользователь, КомментарийПользователя, ДоступностьКомментария, 
	ДатаКомментария = Неопределено) Экспорт

	Если Не ЗначениеЗаполнено(КомментарийПользователя) Тогда
		Возврат;
	КонецЕсли;
	
	Если ДатаКомментария = Неопределено Тогда
		ДатаКомментария = ТекущаяДатаСеанса();
	КонецЕсли;
	
	КомментарииТаблица = РекрутинговыеСайтыСлужебный.ТаблицаКомментарииКандидатов();
	
	НоваяСтрока = КомментарииТаблица.Добавить();
	НоваяСтрока.Период = ДатаКомментария;
	НоваяСтрока.Комментарий = КомментарийПользователя;
	НоваяСтрока.Пользователь = Пользователь;
	НоваяСтрока.ТолькоДляАвтора = ДоступностьКомментария = Перечисления.ДоступностьКомментарияКандидата.ТолькоДляАвтора;
	
	ДанныеКандидата.Комментарии.Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(НоваяСтрока));
	
КонецПроцедуры

Процедура ЗагрузитьКомментарииКандидата(Кандидат) Экспорт
	
	Если Не ИспользуетсяИнтеграцияРекрутинговыхСайтов() Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПравоДоступа("Изменение", Метаданные.РегистрыСведений.НастройкиИнтеграцииРекрутинговыхСайтов) Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеРезюме = РекрутинговыеСайтыСлужебный.ДанныеРезюме(Кандидат);
	
	Если ДанныеРезюме.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Сайты = ОбщегоНазначенияКлиентСервер.СвернутьМассив(ДанныеРезюме.ВыгрузитьКолонку("МестоПубликации"));
	
	Если ЗначениеЗаполнено(Сайты) Тогда
		Менеджер = МенеджерРекрутинговыхСайтов(Сайты);
		Менеджер.ЗагрузитьКомментарииКандидата(Кандидат, ДанныеРезюме);
	КонецЕсли;
	
КонецПроцедуры

Функция ДоступныеДляПолученияКонтакты(Сайт, АдресРезюме) Экспорт
	
	Результат = ПодборПерсоналаКлиентСервер.ДоступностьКонтактовВРезюме();
	
