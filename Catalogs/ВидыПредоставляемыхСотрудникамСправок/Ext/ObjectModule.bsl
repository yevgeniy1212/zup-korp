#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ПередЗаписью(Отказ)
	
	Если ЗарплатаКадры.ОтключитьБизнесЛогикуПриЗаписи(ЭтотОбъект) Тогда
		Возврат;
	КонецЕсли;
	
	Если ДополнительныеСвойства.Свойство("ОбновитьОбразец") Тогда
		СформироватьОбразец();
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Если ВАрхиве Или Не ПолучитьФункциональнуюОпцию("ИспользуетсяСервисКабинетСотрудника") Тогда
		ПроверяемыеРеквизиты.Удалить(ПроверяемыеРеквизиты.Найти("ПредставлениеСправки"));
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Создает и сохраняет образец в присоединенном файле.
Процедура СформироватьОбразец()
	
	Образец = Справочники.ВидыПредоставляемыхСотрудникамСправок.ОбразецСправки(ВидШаблона, ШаблонСправки,
		ИдентификаторМакета);
	
	Если Образец = Неопределено Или Образец.ВысотаТаблицы = 0 Тогда
		ОбразецСправки = Справочники.ВидыПредоставляемыхСотрудникамСправокПрисоединенныеФайлы.ПустаяСсылка();
	Иначе
		Если ЗначениеЗаполнено(Ссылка) Тогда
			ВладелецФайлов = Ссылка;
		Иначе
			ВладелецФайлов = Справочники.ВидыПредоставляемыхСотрудникамСправок.ПолучитьСсылку();
			УстановитьСсылкуНового(ВладелецФайлов);
		КонецЕсли;
		
		СамообслуживаниеСотрудников.СохранитьТабличныйДокументВПрисоединенномФайле(ЭтотОбъект, ВладелецФайлов,
			Образец, "ОбразецСправки", НСтр("ru = 'Образец справки'"), КадровыйЭДОВызовСервера.ТипФайлаЭлектронногоДокумента());
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли