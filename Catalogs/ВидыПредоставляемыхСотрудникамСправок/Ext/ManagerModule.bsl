// Возвращает табличный документ образца по произвольному шаблону.
// 
// Параметры:
//  ШаблонСправки - СправочникСсылка.ВидыПредоставляемыхСотрудникамСправокПрисоединенныеФайлы - Шаблон справки
// 
// Возвращаемое значение:
//  ТабличныйДокумент
Функция ОбразецПоПроизвольномуШаблону(ШаблонСправки)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	
	Если Не ЗначениеЗаполнено(ШаблонСправки) Тогда
		Возврат ТабличныйДокумент;
	КонецЕсли;
	
	МакетСправки = МакетСправкиИзПрисоединенногоФайла(ШаблонСправки);
	
	ОбластьВывода = МакетСправки.ПолучитьОбласть(1, 1, МакетСправки.ВысотаТаблицы, МакетСправки.ШиринаТаблицы);
	
	ДанныеДляПечати = ДанныеДляОбразца();
	
	ОбластьВывода.Параметры.Заполнить(ДанныеДляПечати);
	ТабличныйДокумент.Вывести(ОбластьВывода);
	
	Возврат ТабличныйДокумент;
	
КонецФункции

// Возвращает табличный документ образца по печатной форме.
// 
// Параметры:
//  ИдентификаторМакета - Строка
// 
// Возвращаемое значение:
//  ТабличныйДокумент
Функция ОбразецПоПечатнойФорме(ИдентификаторМакета)
	
	Если ИдентификаторМакета = "ПФ_MXL_СправкаСМестаРаботы" Тогда
		Образец = ОбразецСправкиИзКадровыхПриказов(УправлениеПечатью.МакетПечатнойФормы(
			"Обработка.ПечатьКадровыхПриказовРасширенная.ПФ_MXL_СправкаСМестаРаботы"));
	ИначеЕсли ИдентификаторМакета = "ПФ_MXL_СправкаОДоходахПроизвольнаяФорма" Тогда
		Образец = ОбразецСправкиИзКадровыхПриказов(УправлениеПечатью.МакетПечатнойФормы(
			"Обработка.ПечатьКадровыхПриказовРасширенная.ПФ_MXL_СправкаОДоходахПроизвольнаяФорма"), Истина);
	ИначеЕсли ИдентификаторМакета = "СправкаПоОтпускамСотрудника" Тогда
		Образец = ОбразецСправкиПоОтпускам();
		Образец.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	ИначеЕсли ИдентификаторМакета = "ПФ_MXL_СправкаОСреднемЗаработке2019" Тогда
		Образец = ОбразецСправкиОСреднемЗаработке();
	Иначе
		Результат = ПечатнаяФормаСправкиПоМакету(
			ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Справочники.Сотрудники.ПустаяСсылка()),
			ИдентификаторМакета, Новый Структура, Истина);
		Если Результат.ОК Тогда
			Образец = Результат.ТабличныйДокумент;
		Иначе
			Образец = Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Образец;
	
КонецФункции

Функция ОбразецСправкиИзКадровыхПриказов(Макет, ЭтоСправкаОДоходах = Ложь)
	
	ДокументРезультат = Новый ТабличныйДокумент;
	ДанныеДляЗаполнения = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ДанныеДляОбразца());
	
	// АПК:БЗК.277-выкл
	Обработки.ПечатьКадровыхПриказовРасширенная.ВывестиДанныеСправкиВТабличныйДокумент(Макет, ДокументРезультат,
		ДанныеДляЗаполнения, Новый СписокЗначений, ЭтоСправкаОДоходах);
	// АПК:БЗК.277-вкл
	
	Возврат ДокументРезультат;
	
КонецФункции 

