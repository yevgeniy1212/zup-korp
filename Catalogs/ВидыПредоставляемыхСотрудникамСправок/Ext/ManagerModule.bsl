#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

#Область ОбработчикиПравилРегистрации

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ШаблонОбработчика
Процедура ПриЗаполненииНастроекОбработчиковПравилРегистрации(Настройки) Экспорт
	ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляУправленческихДанных(Настройки);
	ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОбъектаСПрисоединеннымиФайлами(Настройки);
КонецПроцедуры

#КонецОбласти

#Область ПечатьСправки

// Печатная форма справки сотруднику.
// 
// Параметры:
//  Сотрудники - Массив из СправочникСсылка.Сотрудники
//  ПараметрыСправки - Структура:
//   * ИдентификаторЗапроса - Строка, Число, УникальныйИдентификатор -
//   * ФизическоеЛицо - СправочникСсылка.ФизическиеЛица -
//   * Организация - СправочникСсылка.Организации -
//   * ВидСправки - СправочникСсылка.ВидыПредоставляемыхСотрудникамСправок -
//   * ДатаАктуальности - Дата -
//   * ДополнительныеПоля - Структура -
// 
// Возвращаемое значение:
//  см. СамообслуживаниеСотрудников.НовыйРезультатПолученияСправки
Функция ПечатнаяФормаСправки(Сотрудники, ПараметрыСправки) Экспорт
	
	ЗначенияРеквизитов = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ПараметрыСправки.ВидСправки,
		"ВидШаблона, ШаблонСправки, ИдентификаторМакета");
	ВидШаблона = ЗначенияРеквизитов.ВидШаблона;
	
	Если ВидШаблона = Перечисления.ВидыШаблоновСправокСотрудникам.МакетПечатнойФормы Тогда
		Результат = ПечатнаяФормаСправкиПоМакету(Сотрудники, ЗначенияРеквизитов.ИдентификаторМакета,
			ПараметрыСправки);
	ИначеЕсли ВидШаблона = Перечисления.ВидыШаблоновСправокСотрудникам.ПроизвольныйМакет Тогда
		Результат = ПечатнаяФормаСправкиПоПроизвольномуШаблону(Сотрудники, ЗначенияРеквизитов.ШаблонСправки,
			ПараметрыСправки);
	Иначе
		Результат = СамообслуживаниеСотрудников.НовыйРезультатПолученияСправки();
		Результат.ОК = Ложь;
		Результат.ОписаниеОшибки = СтрШаблон(НСтр("ru = 'Неизвестный вид шаблона %1 у вида справки %2'"), ВидШаблона,
			ПараметрыСправки.ВидСправки);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ДоступныеКомандыПечати() Экспорт
	
	Идентификаторы = ИдентификаторыПодключаемыхМакетов();
	
	// АПК:БЗК.277-выкл
	КомандыПечати = УправлениеПечатью.КомандыПечатиОбъекта(Метаданные.Справочники.Сотрудники);
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(
		УправлениеПечатью.КомандыПечатиОбъекта(Метаданные.Справочники.ФизическиеЛица), КомандыПечати);
	// АПК:БЗК.277-вкл
		
	КомандыПечатиРезультат = КомандыПечати.СкопироватьКолонки();
	Для Каждого КомандаПечати Из КомандыПечати Цикл
		Если Идентификаторы.Найти(КомандаПечати.Идентификатор) = Неопределено
			И КомандаПечати.МенеджерПечати <> "СтандартныеПодсистемы.ДополнительныеОтчетыИОбработки" Тогда
			Продолжить;
		КонецЕсли;
		НоваяСтрока = КомандыПечатиРезультат.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, КомандаПечати);
	КонецЦикла;
	
	Возврат КомандыПечатиРезультат;
	
КонецФункции

#КонецОбласти

#Область ОбразцыСправок

// Возвращает сформированный образец справки.
// 
// Параметры: ВидСправки - СправочникСсылка.ВидыПредоставляемыхСотрудникамСправок
//  ВидШаблона - ПеречислениеСсылка.ВидыШаблоновСправокСотрудникам
//  ШаблонСправки - СправочникСсылка.ВидыПредоставляемыхСотрудникамСправокПрисоединенныеФайлы
//  ИдентификаторМакета - Строка
// 
// Возвращаемое значение:
//  ТабличныйДокумент, Неопределено -- Образец справки
Функция ОбразецСправки(ВидШаблона, ШаблонСправки, ИдентификаторМакета) Экспорт
	
	Если ВидШаблона = Перечисления.ВидыШаблоновСправокСотрудникам.ПроизвольныйМакет Тогда
		Образец = ОбразецПоПроизвольномуШаблону(ШаблонСправки);
	ИначеЕсли ВидШаблона = Перечисления.ВидыШаблоновСправокСотрудникам.МакетПечатнойФормы Тогда
		Образец = ОбразецПоПечатнойФорме(ИдентификаторМакета);
	Иначе
		ОбщегоНазначенияКлиентСервер.Проверить(Ложь,
			СтрШаблон(НСтр("ru = 'Неизвестный вид шаблона справки %1'"), ВидШаблона),
			"Справочник.ВидыПредоставляемыхСотрудникамСправок.ОбразецСправки");
	КонецЕсли;
	
	Возврат Образец;
	
КонецФункции

#КонецОбласти

// Возвращает массив актуальных видов справок, предоставляемых сотрудникам.
// 
// Возвращаемое значение:
//  Массив из СправочникСсылка.ВидыПредоставляемыхСотрудникамСправок
Функция ВидыПредоставляемыхСотрудникамСправок() Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ВидыПредоставляемыхСотрудникамСправок.Ссылка
		|ИЗ
		|	Справочник.ВидыПредоставляемыхСотрудникамСправок КАК ВидыПредоставляемыхСотрудникамСправок
		|ГДЕ
		|	НЕ ВидыПредоставляемыхСотрудникамСправок.ВАрхиве
		|	И НЕ ВидыПредоставляемыхСотрудникамСправок.ПометкаУдаления";
	
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	
КонецФункции

// Возвращает данные о видах справок, предоставляемых сотрудникам.
// 
// Параметры:
//  ВидыСправок - массив из СправочникСсылка.ВидыПредоставляемыхСотрудникамСправок -
// 
// Возвращаемое значение:
//  ТаблицаЗначений:
//    * ВидСправки - СправочникСсылка.ВидыПредоставляемыхСотрудникамСправок
//    * ПометкаУдаления - Булево
//    * Представление - Строка
//    * Описание - Строка
//    * ВАрхиве - Булево
//    * РеквизитДопУпорядочивания - Число
//    * Шаблон - СправочникСсылка.ВидыПредоставляемыхСотрудникамСправокПрисоединенныеФайлы
//    * ЕстьМакет - Булево
Функция ДанныеВидовСправокПредоставляемыхСотрудникам(ВидыСправок) Экспорт

	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ВидыСправок", ВидыСправок);
	Запрос.УстановитьПараметр("ПустаяСтрока", "");
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ВидыПредоставляемыхСотрудникамСправок.Ссылка КАК ВидСправки,
		|	ВидыПредоставляемыхСотрудникамСправок.ПометкаУдаления КАК ПометкаУдаления,
		|	ВидыПредоставляемыхСотрудникамСправок.ПредставлениеСправки КАК Представление,
		|	ВидыПредоставляемыхСотрудникамСправок.Описание КАК Описание,
		|	ВидыПредоставляемыхСотрудникамСправок.ВАрхиве КАК ВАрхиве,
		|	ВидыПредоставляемыхСотрудникамСправок.РеквизитДопУпорядочивания КАК РеквизитДопУпорядочивания,
		|	ВидыПредоставляемыхСотрудникамСправок.ОбразецСправки КАК Шаблон,
		|	ВЫБОР
		|		КОГДА
		|			ВидыПредоставляемыхСотрудникамСправок.ВидШаблона = ЗНАЧЕНИЕ(Перечисление.ВидыШаблоновСправокСотрудникам.МакетПечатнойФормы)
		|			ТОГДА ВЫБОР
		|				КОГДА ВидыПредоставляемыхСотрудникамСправок.ИдентификаторМакета = &ПустаяСтрока
		|					ТОГДА Ложь
		|				ИНАЧЕ Истина
		|			КОНЕЦ
		|		ИНАЧЕ ВЫБОР
		|			КОГДА
		|				ВидыПредоставляемыхСотрудникамСправок.ШаблонСправки = ЗНАЧЕНИЕ(Справочник.ВидыПредоставляемыхСотрудникамСправокПрисоединенныеФайлы.ПустаяСсылка)
		|				ТОГДА Ложь
		|			ИНАЧЕ Истина
		|		КОНЕЦ
		|	КОНЕЦ КАК ЕстьМакет
		|ИЗ
		|	Справочник.ВидыПредоставляемыхСотрудникамСправок КАК ВидыПредоставляемыхСотрудникамСправок
		|ГДЕ
		|	ВидыПредоставляемыхСотрудникамСправок.Ссылка В (&ВидыСправок)";
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Процедура СоздатьВТОбщиеДанныеСправок(МенеджерВременныхТаблиц, Сотрудники) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Период = ТекущаяДатаСеанса();
	
	Запрос.УстановитьПараметр("Период", Период);
	Запрос.УстановитьПараметр("Сотрудники", Сотрудники);
	
	Запрос.Текст =
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	&Период,
		|	Сотрудники.Ссылка КАК Сотрудник
		|ПОМЕСТИТЬ ВТСотрудникиПериоды
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|ГДЕ
		|	Сотрудники.Ссылка В(&Сотрудники)";
		
	Запрос.Выполнить();
	
	ОписательВременныхТаблиц = КадровыйУчет.ОписательВременныхТаблицДляСоздатьВТКадровыеДанныеСотрудников(
		Запрос.МенеджерВременныхТаблиц, "ВТСотрудникиПериоды");
	
	КадровыйУчет.СоздатьВТКадровыеДанныеСотрудников(ОписательВременныхТаблиц, Истина, КадровыеДанныеДляСправки());
	
	Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	КадровыеДанные.Период КАК Период,
		|	КадровыеДанные.Организация КАК Организация
		|ИЗ
		|	ВТКадровыеДанныеСотрудников КАК КадровыеДанные
		|ГДЕ
		|	НЕ КадровыеДанные.Организация ЕСТЬ NULL";
	
	СведенияОбОрганизациях = ЗарплатаКадрыОтчеты.ДанныеОрганизаций( , Период);
	ЗарплатаКадры.СоздатьВТПоТаблицеЗначений(МенеджерВременныхТаблиц, СведенияОбОрганизациях, "ВТДанныеОрганизаций");
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	КадровыеДанныеСотрудников.Сотрудник КАК Ссылка,
		|	КадровыеДанныеСотрудников.Период КАК Период,
		|	КадровыеДанныеСотрудников.Период КАК ДатаСправки,
		|	КадровыеДанныеСотрудников.Организация КАК Организация,
		|	КадровыеДанныеСотрудников.ФизическоеЛицо КАК ФизическоеЛицо,
		|	КадровыеДанныеСотрудников.ДатаПриема КАК ДатаПриема,
		|	КадровыеДанныеСотрудников.Должность КАК Должность,
		|	КадровыеДанныеСотрудников.ФИОПолные КАК ФИОПолные,
		|	КадровыеДанныеСотрудников.Пол КАК Пол,
		|	КадровыеДанныеСотрудников.ДокументПредставление КАК ДокументПредставление,
		|	КадровыеДанныеСотрудников.АдресДляИнформированияПредставление КАК АдресДляИнформирования,
		|	КадровыеДанныеСотрудников.АдресПоПропискеПредставление КАК АдресПоПрописке,
		|	КадровыеДанныеСотрудников.АдресМестаПроживанияПредставление КАК АдресМестаПроживания,
		|	КадровыеДанныеСотрудников.ТелефонДомашнийПредставление КАК ТелефонДомашний,
		|	КадровыеДанныеСотрудников.ТелефонРабочийПредставление КАК ТелефонРабочий,
		|	КадровыеДанныеСотрудников.ТелефонМобильныйПредставление КАК ТелефонМобильный,
		|	КадровыеДанныеСотрудников.EMailПредставление КАК EMail,
		|	КадровыеДанныеСотрудников.СостояниеВБраке КАК СостояниеВБраке,
		|	КадровыеДанныеСотрудников.Надбавка КАК Надбавка,
		|	КадровыеДанныеСотрудников.ТарифнаяСтавка КАК ТарифнаяСтавка,
		|	КадровыеДанныеСотрудников.ФОТ КАК ФОТ,
		|	КадровыеДанныеСотрудников.Аванс КАК Аванс,
		|	ВЫБОР
		|		КОГДА КадровыеДанныеСотрудников.Пол = ЗНАЧЕНИЕ(Перечисление.ПолФизическогоЛица.Мужской)
		|			ТОГДА &СтрокаЕго
		|		ИНАЧЕ &СтрокаЕе
		|	КОНЕЦ КАК ЕгоЕе,
		|	ВЫБОР
		|		КОГДА КадровыеДанныеСотрудников.Пол = ЗНАЧЕНИЕ(Перечисление.ПолФизическогоЛица.Мужской)
		|			ТОГДА &СтрокаОн
		|		ИНАЧЕ &СтрокаОна
		|	КОНЕЦ КАК ОнОна,
		|	ДанныеОрганизаций.НаименованиеПолное КАК ОрганизацияНаименованиеПолное,
		|	ДанныеОрганизаций.ИНН КАК ОрганизацияИНН,
		|	ДанныеОрганизаций.ЮрАдрес КАК ОрганизацияАдресЮридический,
		|	ДанныеОрганизаций.ФактАдрес КАК ОрганизацияАдресФактический,
		|	ДанныеОрганизаций.ГородФактическогоАдреса КАК ОрганизацияГородФактическогоАдреса,
		|	ДанныеОрганизаций.РасчетныйСчет КАК ОрганизацияРасчетныйСчет,
		|	ДанныеОрганизаций.Банк КАК ОрганизацияБанк,
		|	ДанныеОрганизаций.КорСчет КАК ОрганизацияКорСчет,
		|	ДанныеОрганизаций.БИК КАК ОрганизацияБИК,
		|	ДанныеОрганизаций.Телефон КАК ОрганизацияТелефон,
		|	ДанныеОрганизаций.Факс КАК ОрганизацияФакс,
		|	ДанныеОрганизаций.ФИОРуководителя КАК ФИОРуководителя,
		|	ДанныеОрганизаций.ФИОГлавногоБухгалтера КАК ФИОГлавногоБухгалтера,
		|	ДанныеОрганизаций.ДолжностьРуководителя КАК ДолжностьРуководителя,
		|	ДанныеОрганизаций.ДолжностьГлавногоБухгалтера КАК ДолжностьГлавногоБухгалтера
		|ПОМЕСТИТЬ ВТОбщиеДанныеСправок
		|ИЗ
		|	ВТКадровыеДанныеСотрудников КАК КадровыеДанныеСотрудников
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДанныеОрганизаций КАК ДанныеОрганизаций
		|		ПО (ДанныеОрганизаций.Период = КадровыеДанныеСотрудников.Период)
		|		И (ДанныеОрганизаций.Организация = КадровыеДанныеСотрудников.Организация)";
		
	Запрос.УстановитьПараметр("СтрокаЕго", НСтр("ru='Его'"));
	Запрос.УстановитьПараметр("СтрокаЕе", НСтр("ru='Ее'"));
	Запрос.УстановитьПараметр("СтрокаОн", НСтр("ru='он'"));
	Запрос.УстановитьПараметр("СтрокаОна", НСтр("ru='она'"));
	
	Запрос.Выполнить();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область ПервоначальноеЗаполнениеИОбновлениеИнформационнойБазы
	
Процедура НачальноеЗаполнение() Экспорт
	
	Если Не Константы.ИспользоватьЗарплатаКадрыКорпоративнаяПодсистемы.Получить() Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИСТИНА КАК ЗначениеИстина
	|ИЗ
	|	Справочник.ВидыПредоставляемыхСотрудникамСправок КАК ВидыПредоставляемыхСотрудникамСправок
	|ГДЕ
	|	НЕ ВидыПредоставляемыхСотрудникамСправок.Предопределенный";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда 
		СоздатьЗаполнитьВидыСправок();
	КонецЕсли;
	
КонецПроцедуры

Процедура УдалитьПредопределенныеЭлементы(ПараметрыОбновления) Экспорт
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления,
		"ОбработкаЗавершена", Истина);
		
	Если ПланыОбмена.ГлавныйУзел() <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ВидыПредоставляемыхСотрудникамСправок.Ссылка КАК Ссылка,
		|	ВидыПредоставляемыхСотрудникамСправок.Наименование КАК Наименование
		|ИЗ
		|	Справочник.ВидыПредоставляемыхСотрудникамСправок КАК ВидыПредоставляемыхСотрудникамСправок
		|ГДЕ
		|	ВидыПредоставляемыхСотрудникамСправок.Предопределенный";
	
	БлокировкаДанных = Новый БлокировкаДанных;
	ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Справочник.ВидыПредоставляемыхСотрудникамСправок");
	ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Документ.ЗапросСправкиСотрудником");
	ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Документ.ЗапросСправки2НДФЛСотрудником");
	ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
	
	НачатьТранзакцию();
	Попытка
		БлокировкаДанных.Заблокировать();
		
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() Тогда
			ЗафиксироватьТранзакцию();
			Возврат;
		КонецЕсли;
		
		УдаляемыеВидыСправок = Новый Массив;
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			ПредопределенныйЭлемент = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
			ПредопределенныйЭлемент.ИмяПредопределенныхДанных  = "";
			ПредопределенныйЭлемент.ПометкаУдаления = Истина;
			ПредопределенныйЭлемент.ВАрхиве = Истина;
			ПредопределенныйЭлемент.ВидШаблона = Перечисления.ВидыШаблоновСправокСотрудникам.ПроизвольныйМакет;
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(ПредопределенныйЭлемент, Истина);
			
			Если СтрНайти(ВыборкаДетальныеЗаписи.Наименование, "2-НДФЛ") > 0 Тогда
				УдаляемыеВидыСправок.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
			КонецЕсли;
			
		КонецЦикла;
		
		Если УдаляемыеВидыСправок.Количество() = 0 Тогда
			ЗафиксироватьТранзакцию();
			Возврат;
		КонецЕсли;
		
		ЗапросыСправок = ДокументыДляПереноса(УдаляемыеВидыСправок);
		Если ЗапросыСправок.Количество() = 0 Тогда
			ЗафиксироватьТранзакцию();
			Возврат;
		КонецЕсли;
		
		ЗаменитьДокументыЗапросаСправок(ЗапросыСправок);
		ЗафиксироватьТранзакцию();
		
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

// Параметры:
//  ВидыСправок - Массив из СправочникСсылка.ВидыПредоставляемыхСотрудникамСправок
// 
// Возвращаемое значение:
//  ТаблицаЗначений:
//   * Ссылка - ДокументСсылка.ЗапросСправкиСотрудником
//   * Дата - Дата
//   * Проведен - Булево
//   * Номер - Строка
//   * ФизическоеЛицо - СправочникСсылка.ФизическиеЛица
//   * Ответственный - СправочникСсылка.Пользователи
//   * ЗапросОбработан - Булево
//   * Комментарий - Строка
//   * ВидСправкиНаименование - Строка
Функция ДокументыДляПереноса(ВидыСправок)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ЗапросСправкиСотрудником.Ссылка КАК Ссылка,
		|	ЗапросСправкиСотрудником.Проведен КАК Проведен,
		|	ЗапросСправкиСотрудником.Дата КАК Дата,
		|	ЗапросСправкиСотрудником.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ЗапросСправкиСотрудником.Ответственный КАК Ответственный,
		|	ЗапросСправкиСотрудником.ЗапросОбработан КАК ЗапросОбработан,
		|	ЗапросСправкиСотрудником.Комментарий КАК Комментарий,
		|	ЗапросСправкиСотрудником.ВидСправки.Наименование КАК ВидСправкиНаименование
		|ИЗ
		|	Документ.ЗапросСправкиСотрудником КАК ЗапросСправкиСотрудником
		|ГДЕ
		|	НЕ ЗапросСправкиСотрудником.ПометкаУдаления
		|	И ЗапросСправкиСотрудником.ВидСправки В (&ВидыСправок)";
	
	Запрос.УстановитьПараметр("ВидыСправок", ВидыСправок);
	
	Возврат Запрос.Выполнить().Выгрузить(); 
	
КонецФункции

// Параметры:
//  ЗапросыСправок - см. ДокументыДляПереноса
Процедура ЗаменитьДокументыЗапросаСправок(ЗапросыСправок)
	
	Для Каждого СтрокаТаблицы Из ЗапросыСправок Цикл
		
		ФайлыДляКопирования = ФайлыДляКопирования(СтрокаТаблицы.Ссылка);
		
		ЗапросСправки = СтрокаТаблицы.Ссылка.ПолучитьОбъект();
		ЗапросСправки.УстановитьПометкуУдаления(Истина);
		
		ЗапросСправки2НДФЛ = Документы.ЗапросСправки2НДФЛСотрудником.СоздатьДокумент();
		ЗаполнитьЗначенияСвойств(ЗапросСправки2НДФЛ, СтрокаТаблицы, , "Проведен");
		
		Если СтрокаТаблицы.ВидСправкиНаименование = НСтр("ru = '2-НДФЛ для передачи в налоговый орган'") Тогда
			ЗапросСправки2НДФЛ.НазначениеСправки = Перечисления.НазначенияСправок2НДФЛ.ДляДекларации;
		Иначе
			ЗапросСправки2НДФЛ.НазначениеСправки = Перечисления.НазначенияСправок2НДФЛ.ПодтверждениеДоходов;
		КонецЕсли;
		
		РежимЗаписи = ?(СтрокаТаблицы.Проведен, РежимЗаписиДокумента.Проведение, РежимЗаписиДокумента.Запись);
		ОбновлениеИнформационнойБазы.ЗаписатьОбъект(ЗапросСправки2НДФЛ, Истина, , РежимЗаписи); // АПК:1327 - блокировка наложена ранее
		СкопироватьПрисоединенныеФайлыЗапросов2НДФЛ(ЗапросСправки.Ссылка, ЗапросСправки2НДФЛ.Ссылка,
			ФайлыДляКопирования);
		
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  Ссылка - ДокументСсылка.ЗапросСправкиСотрудником -
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//	 * Ключ - СправочникСсылка.ЗапросСправкиСотрудникомПрисоединенныеФайлы
//	 * Значение - ДвоичныеДанные
Функция ФайлыДляКопирования(Ссылка)
	
	ФайлыДляКопирования = Новый Соответствие;
	
	КопируемыеФайлы = Новый Массив; // Массив из СправочникСсылка.ЗапросСправкиСотрудникомПрисоединенныеФайлы
	РаботаСФайлами.ЗаполнитьПрисоединенныеФайлыКОбъекту(Ссылка, КопируемыеФайлы);
	Для Каждого КопируемыйФайл Из КопируемыеФайлы Цикл
		ДвоичныеДанные = РаботаСФайлами.ДвоичныеДанныеФайла(КопируемыйФайл, Ложь);
		ФайлыДляКопирования.Вставить(КопируемыйФайл, ДвоичныеДанные);
	КонецЦикла;
	
	Возврат ФайлыДляКопирования;
	
КонецФункции

// Копирует присоединенные файлы документа "Запрос справки с места работы" в присоединенные файлы документа
// "Запрос справки 2-НДФЛ".
//
// Параметры:
//  Источник - ДокументСсылка.ЗапросСправкиСотрудником
//  Получатель - ДокументСсылка.ЗапросСправки2НДФЛСотрудником
//  ФайлыДляКопирования - см. ФайлыДляКопирования
Процедура СкопироватьПрисоединенныеФайлыЗапросов2НДФЛ(Источник, Получатель, ФайлыДляКопирования)
	
	Если ФайлыДляКопирования.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	БлокировкаДанных = Новый БлокировкаДанных;
	ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Справочник.ЗапросСправки2НДФЛСотрудникомПрисоединенныеФайлы");
	ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
	ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("РегистрСведений.ДвоичныеДанныеФайлов");
	ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
	
	Для Каждого ФайлДляКопирования Из ФайлыДляКопирования Цикл
		НачатьТранзакцию();
		Попытка
			БлокировкаДанных.Заблокировать();
			
			КопируемыйФайл = ФайлДляКопирования.Ключ;
			КопируемыйФайлОбъект = КопируемыйФайл.ПолучитьОбъект();
			
			КопияФайла = Справочники.ЗапросСправки2НДФЛСотрудникомПрисоединенныеФайлы.СоздатьЭлемент();
			КопияФайлаСсылка = Справочники.ЗапросСправки2НДФЛСотрудникомПрисоединенныеФайлы.ПолучитьСсылку();
			КопияФайла.УстановитьСсылкуНового(КопияФайлаСсылка);
			КопияФайла.Наименование = КопируемыйФайлОбъект.Наименование;
			КопияФайла.ВладелецФайла = Получатель;
			КопияФайла.ДатаМодификацииУниверсальная = КопируемыйФайлОбъект.ДатаМодификацииУниверсальная;
			КопияФайла.ДатаСоздания = КопируемыйФайлОбъект.ДатаСоздания;
			КопияФайла.Зашифрован = КопируемыйФайлОбъект.Зашифрован;
			КопияФайла.Изменил = КопируемыйФайлОбъект.Изменил;
			КопияФайла.ИндексКартинки = КопируемыйФайлОбъект.ИндексКартинки;
			КопияФайла.Описание = КопируемыйФайлОбъект.Описание;
			КопияФайла.ПутьКФайлу = КопируемыйФайлОбъект.ПутьКФайлу;
			КопияФайла.Размер = КопируемыйФайлОбъект.Размер;
			КопияФайла.Расширение = КопируемыйФайлОбъект.Расширение;
			КопияФайла.Редактирует = Справочники.Пользователи.ПустаяСсылка();
			КопияФайла.ТекстХранилище = КопируемыйФайлОбъект.ТекстХранилище;
			КопияФайла.СтатусИзвлеченияТекста = КопируемыйФайлОбъект.СтатусИзвлеченияТекста;
			КопияФайла.ФайлХранилище = КопируемыйФайлОбъект.ФайлХранилище;
			КопияФайла.ТипХраненияФайла = КопируемыйФайлОбъект.ТипХраненияФайла;
			
			ДвоичныеДанные = ФайлДляКопирования.Значение;
			Если КопируемыйФайлОбъект.ТипХраненияФайла = Перечисления.ТипыХраненияФайлов.ВИнформационнойБазе
				И ДвоичныеДанные <> Неопределено Тогда
					
				НаборЗаписей = РегистрыСведений.ДвоичныеДанныеФайлов.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Файл.Установить(КопияФайлаСсылка);
				НоваяЗапись = НаборЗаписей.Добавить();
				НоваяЗапись.Файл = КопияФайлаСсылка;
				НоваяЗапись.ДвоичныеДанныеФайла = Новый ХранилищеЗначения(ДвоичныеДанные, Новый СжатиеДанных(9));
				ОбновлениеИнформационнойБазы.ЗаписатьНаборЗаписей(НаборЗаписей, Истина, Истина);
				
			КонецЕсли;
			ОбновлениеИнформационнойБазы.ЗаписатьОбъект(КопияФайла, Истина, Истина);
			
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			ВызватьИсключение;
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьРеквизитыСправок(ПараметрыОбновления) Экспорт
	
	ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления,
		"ОбработкаЗавершена", Истина);
		
	Если Не Константы.ИспользоватьЗарплатаКадрыКорпоративнаяПодсистемы.Получить()
		Или ПланыОбмена.ГлавныйУзел() <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	БлокировкаДанных = Новый БлокировкаДанных;
	ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Справочник.ВидыПредоставляемыхСотрудникамСправок");
	ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
	
	НачатьТранзакцию();
	Попытка
		БлокировкаДанных.Заблокировать();
		СоздатьЗаполнитьВидыСправок();
		ЗаполнитьВидыСправок();
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;
		
КонецПроцедуры

Процедура СоздатьЗаполнитьВидыСправок()
	
    // ЗУПК
	СоздатьЗаполнитьВидСправки(НСтр("ru = 'С места работы'"),
		Перечисления.ВидыШаблоновСправокСотрудникам.МакетПечатнойФормы, "ПФ_MXL_СправкаСМестаРаботы");
	
	СоздатьЗаполнитьВидСправки(НСтр("ru = 'О доходах'"), Перечисления.ВидыШаблоновСправокСотрудникам.МакетПечатнойФормы,
		"ПФ_MXL_СправкаОДоходахПроизвольнаяФорма");
    // ЗУПК
		
    Если ПолучитьФункциональнуюОпцию("ОтключенныйФункционалЗарплатаКадры") Тогда
	СоздатьЗаполнитьВидСправки(НСтр("ru = 'О начисленных страховых взносах'"),
		Перечисления.ВидыШаблоновСправокСотрудникам.ПроизвольныйМакет);
		
	СоздатьЗаполнитьВидСправки(
		НСтр("ru = 'О неиспользовании (частичном использовании) дополнительных выходных дней по уходу за детьми-инвалидами'"),
		Перечисления.ВидыШаблоновСправокСотрудникам.ПроизвольныйМакет);
		
	СоздатьЗаполнитьВидСправки(НСтр("ru = 'О неполучении единовременного пособия при рождении ребенка'"),
		Перечисления.ВидыШаблоновСправокСотрудникам.ПроизвольныйМакет);
		
	СоздатьЗаполнитьВидСправки(НСтр("ru = 'О неполучении ежемесячного пособия по уходу за ребенком до 1.5 лет'"),
		Перечисления.ВидыШаблоновСправокСотрудникам.ПроизвольныйМакет);
		
	СоздатьЗаполнитьВидСправки(НСтр("ru = 'О неполучении пособия по нетрудоспособности'"),
		Перечисления.ВидыШаблоновСправокСотрудникам.ПроизвольныйМакет);
	КонецЕсли;
		
КонецПроцедуры
	
// Заполнят реквизиты ВидШаблона, СпособФормирования, ПредставлениеСправки если они не заполнены.
Процедура ЗаполнитьВидыСправок()
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВидыПредоставляемыхСотрудникамСправок.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыПредоставляемыхСотрудникамСправок КАК ВидыПредоставляемыхСотрудникамСправок
	|ГДЕ
	|	НЕ ВидыПредоставляемыхСотрудникамСправок.Предопределенный
	|	И (ВидыПредоставляемыхСотрудникамСправок.ВидШаблона = ЗНАЧЕНИЕ(Перечисление.ВидыШаблоновСправокСотрудникам.ПустаяСсылка)
	|			ИЛИ ВидыПредоставляемыхСотрудникамСправок.СпособФормирования = ЗНАЧЕНИЕ(Перечисление.СпособыФормированияСправокСотрудникам.ПустаяСсылка))";
	
	РезультатЗапроса = Запрос.Выполнить(); // АПК:1327 - блокировка наложена ранее
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		ВидСправки = Выборка.Ссылка.ПолучитьОбъект();
		ЗаполнитьВидСправки(ВидСправки, Перечисления.ВидыШаблоновСправокСотрудникам.ПроизвольныйМакет);
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  Наименование - Строка
//  ВидШаблона - ПеречислениеСсылка.ВидыШаблоновСправокСотрудникам
//  ИдентификаторМакета - Неопределено, Строка - 
//  ТребуетсяПодтверждение - Булево
Процедура СоздатьЗаполнитьВидСправки(Наименование, ВидШаблона, ИдентификаторМакета = Неопределено,
	ТребуетсяПодтверждение = Истина)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВидыПредоставляемыхСотрудникамСправок.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ВидыПредоставляемыхСотрудникамСправок КАК ВидыПредоставляемыхСотрудникамСправок
	|ГДЕ
	|	НЕ ВидыПредоставляемыхСотрудникамСправок.Предопределенный
	|	И НЕ ВидыПредоставляемыхСотрудникамСправок.ПометкаУдаления
	|	И ВидыПредоставляемыхСотрудникамСправок.Наименование = &Наименование";
	
	Запрос.УстановитьПараметр("Наименование", Наименование);
	РезультатЗапроса = Запрос.Выполнить(); // АПК:1327 - блокировка наложена ранее
	
	Если РезультатЗапроса.Пустой() Тогда
		ВидСправки = СоздатьЭлемент();
		ВидСправки.Наименование = Наименование;
		ВидСправки.ВАрхиве = Истина;
	Иначе
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ВидСправки = Выборка.Ссылка.ПолучитьОбъект();
	КонецЕсли;
	
	ЗаполнитьВидСправки(ВидСправки, ВидШаблона, ИдентификаторМакета, ТребуетсяПодтверждение);
	
КонецПроцедуры
	
// Параметры:
//  ВидСправки - СправочникОбъект.ВидыПредоставляемыхСотрудникамСправок
//  ВидШаблона - ПеречислениеСсылка.ВидыШаблоновСправокСотрудникам
//  ИдентификаторМакета - Неопределено, Строка - 
//  ТребуетсяПодтверждение - Булево
Процедура ЗаполнитьВидСправки(ВидСправки, ВидШаблона, ИдентификаторМакета = Неопределено,
	ТребуетсяПодтверждение = Истина)
	
	ВидСправки.ВидШаблона = ВидШаблона;
	
	Если Не ЗначениеЗаполнено(ВидСправки.СпособФормирования) Тогда
		Если ТребуетсяПодтверждение Тогда
			ВидСправки.СпособФормирования = Перечисления.СпособыФормированияСправокСотрудникам.ТребуетсяПодтверждение;
		Иначе
			ВидСправки.СпособФормирования = Перечисления.СпособыФормированияСправокСотрудникам.Автоматически;
		КонецЕсли;
	КонецЕсли;
	
	Если ИдентификаторМакета <> Неопределено Тогда
		ВидСправки.ИдентификаторМакета = ИдентификаторМакета;
		ВидСправки.ДополнительныеСвойства.Вставить("ОбновитьОбразец", Истина);
	КонецЕсли;
	
	ОбновлениеИнформационнойБазы.ЗаписатьДанные(ВидСправки, Истина, Истина); // АПК:1327 - блокировка наложена ранее
	
КонецПроцедуры	
	
