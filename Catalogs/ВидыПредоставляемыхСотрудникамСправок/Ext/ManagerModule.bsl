	ОстатокОтпуска.Вставить("ВидОтпуска", ВидОтпуска); 
	ОстатокОтпуска.Вставить("ВидОтпускаНаименование", ВидОтпускаНаименование); 
	ОстатокОтпуска.Вставить("РабочийГодДатаНачала", РабочийГодДатаНачала); 
	ОстатокОтпуска.Вставить("РабочийГодДатаОкончания", РабочийГодДатаОкончания); 
	ОстатокОтпуска.Вставить("Дни", Дни);
	ДанныеОстатков.Добавить(ОстатокОтпуска);
	
