Процедура ДобавитьПравоНаОтпуск(ПраваНаОтпуска, ВидЕжегодногоОтпуска, ВидЕжегодногоОтпускаНаименование,
	КоличествоДнейОтпускаВГод)
	
	Если ВидЕжегодногоОтпуска = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПравоНаОтпуск = Новый Структура;
	ПравоНаОтпуск.Вставить("ВидЕжегодногоОтпуска", ВидЕжегодногоОтпуска);
	ПравоНаОтпуск.Вставить("ВидЕжегодногоОтпускаНаименование", ВидЕжегодногоОтпускаНаименование);
	ПравоНаОтпуск.Вставить("КоличествоДнейОтпускаВГод", КоличествоДнейОтпускаВГод);
	ПравоНаОтпуск.Вставить("Предоставляется", Истина);
	
	ПраваНаОтпуска.Добавить(ПравоНаОтпуск);
	
КонецПроцедуры

Процедура ДобавитьСклоненияФИОДляОбразца(ДанныеДляОбразца, ИмяПараметра, ФИО = "")
	
	ДанныеДляОбразца.Вставить(ИмяПараметра + "РодительныйПадеж", ФИО);
	ДанныеДляОбразца.Вставить(ИмяПараметра + "ДательныйПадеж", ФИО);
	ДанныеДляОбразца.Вставить(ИмяПараметра + "ВинительныйПадеж", ФИО);
	ДанныеДляОбразца.Вставить(ИмяПараметра + "ТворительныйПадеж", ФИО);
	ДанныеДляОбразца.Вставить(ИмяПараметра + "ПредложныйПадеж", ФИО);
	
КонецПроцедуры

#КонецОбласти

// Параметры:
//  Сотрудники - Массив из СправочникСсылка.Сотрудники - Сотрудники
//  ИдентификаторМакета - Строка - идентификатор команды печати
//  ПараметрыСправки - см. СамообслуживаниеСотрудников.ПолучитьСправкуПоЗапросу.ПараметрыСправки
//  ЭтоОбразец - Булево
// 
// Возвращаемое значение:
//  см. СамообслуживаниеСотрудников.НовыйРезультатПолученияСправки 
Функция ПечатнаяФормаСправкиПоМакету(Сотрудники, ИдентификаторМакета, ПараметрыСправки, ЭтоОбразец = Ложь)
	
	Результат = СамообслуживаниеСотрудников.НовыйРезультатПолученияСправки();
	
	НастройкиСохранения = УправлениеПечатью.НастройкиСохранения();
	НастройкиСохранения.ФорматыСохранения.Добавить(ТипФайлаТабличногоДокумента.MXL);

	КомандаПечати = ДоступныеКомандыПечати().Найти(ИдентификаторМакета, "Идентификатор");

	Если КомандаПечати = Неопределено Тогда
		Результат.ОК = Ложь;
		Результат.ОписаниеОшибки = СтрШаблон(НСтр("ru = 'Не удалось найти команду печати с идентификатором %1'"),
			ИдентификаторМакета);
		Возврат Результат;
	КонецЕсли;

	ИмяКомандыОбразец = "Образец";
	Если ЭтоОбразец Тогда
		КомандаПечати.ДополнительныеПараметры.Вставить("ЭтоОбразец", Истина);
		Если КомандаПечати.МенеджерПечати = "СтандартныеПодсистемы.ДополнительныеОтчетыИОбработки" Тогда
			// это внешняя печатная форма
			КомандаПечати.Идентификатор = ИмяКомандыОбразец;
		КонецЕсли;
	КонецЕсли;
	
	Попытка
		УстановитьПривилегированныйРежим(Истина);
		ТаблицаДанныхПечати = УправлениеПечатью.НапечататьВФайл(КомандаПечати, Сотрудники, НастройкиСохранения);
		УстановитьПривилегированныйРежим(Ложь);
	Исключение
		Если ЭтоОбразец И КомандаПечати.Идентификатор = ИмяКомандыОбразец Тогда
			Результат.ОК = Ложь;
			Результат.ОписаниеОшибки =
				НСтр("ru = 'Для формирования образца справки во внешней печатной форме должен быть реализован метод Образец()'");
			Возврат Результат;
		Иначе
			ВызватьИсключение ОписаниеОшибки();
		КонецЕсли;
	КонецПопытки;
	
	Если ТаблицаДанныхПечати.Количество() = 0 Тогда
		Результат.ОК = Ложь;
		Результат.ОписаниеОшибки = СтрШаблон(
			НСтр("ru = 'Не удалось сформировать печатную форму по команде печати с идентификатором %1'"),
			ИдентификаторМакета);
		Возврат Результат;
	КонецЕсли;
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	Если ТаблицаДанныхПечати.Количество() = 1 Тогда
		ТабличныйДокумент = УправлениеПечатью.ТабличныйДокументПоДвоичнымДанным(ТаблицаДанныхПечати[0].ДвоичныеДанные);
	Иначе
		Для Сч = 0 По ТаблицаДанныхПечати.Количество() - 1 Цикл
			Если ТабличныйДокумент.ВысотаТаблицы > 0 Тогда
				ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;
			ТабличныйДокумент.Вывести(УправлениеПечатью.ТабличныйДокументПоДвоичнымДанным(
				ТаблицаДанныхПечати[Сч].ДвоичныеДанные));
		КонецЦикла;
	КонецЕсли;
	
	Результат.ТабличныйДокумент = ТабличныйДокумент;
	
	Возврат Результат;

КонецФункции

// Возвращает табличный документ справки по произвольному шаблону.
// 
// Параметры:
//  Сотрудники - Массив из СправочникСсылка.Сотрудники - Сотрудники
//  ШаблонСправки - СправочникСсылка.ВидыПредоставляемыхСотрудникамСправокПрисоединенныеФайлы - Шаблон справки
//  ПараметрыСправки - см. СамообслуживаниеСотрудников.ПолучитьСправкуПоЗапросу.ПараметрыСправки
// 
// Возвращаемое значение:
//  см. СамообслуживаниеСотрудников.НовыйРезультатПолученияСправки
Функция ПечатнаяФормаСправкиПоПроизвольномуШаблону(Сотрудники, ШаблонСправки, ПараметрыСправки)
	
	Результат = СамообслуживаниеСотрудников.НовыйРезультатПолученияСправки();
	
	Если Не ЗначениеЗаполнено(ШаблонСправки) Тогда
		Результат.ОК = Ложь;
		Результат.ОписаниеОшибки = СтрШаблон(НСтр("ru = 'Для вида справки ""%1"" не задан шаблон справки.'"),
			ПараметрыСправки.ВидСправки);
		Возврат Результат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПараметрыСправки.ДатаАктуальности) Тогда
		Период = ПараметрыСправки.ДатаАктуальности;
	Иначе
		Период = ТекущаяДатаСеанса();
	КонецЕсли;
	
	МакетСправки = МакетСправкиИзПрисоединенногоФайла(ШаблонСправки);
	ТабличныйДокумент = Новый ТабличныйДокумент;
	
	ОбластьВывода = МакетСправки.ПолучитьОбласть(1, 1, МакетСправки.ВысотаТаблицы, МакетСправки.ШиринаТаблицы);
	
	ДанныеДляПечати = ДанныеДляПечатиСправкиПоШаблону(Сотрудники, Период);
	
	Если ДанныеДляПечати.Количество() > 0 Тогда
		Для Каждого СтрокаТаблицы Из ДанныеДляПечати Цикл
			Если ДанныеДляПечати.Индекс(СтрокаТаблицы) > 0 Тогда
				ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;
			ЗаполнитьПараметрыСправки(ОбластьВывода, СтрокаТаблицы);
			ТабличныйДокумент.Вывести(ОбластьВывода);
		КонецЦикла;
	КонецЕсли;
	
	Результат.ТабличныйДокумент = ТабличныйДокумент;
	
	Возврат Результат;
	
КонецФункции

// Данные для печати справки по шаблону.
// 
// Параметры:
//  Сотрудники - Массив из СправочникСсылка.Сотрудники
//  Период - Дата - 
// 
// Возвращаемое значение:
//  ТаблицаЗначений - 
Функция ДанныеДляПечатиСправкиПоШаблону(Сотрудники, Период)
	
	ТаблицаДанных = Новый ТаблицаЗначений;
	
	СхемаКомпоновки = Отчеты.ПечатнаяФормаСправкаПредоставляемаяСотруднику.ПолучитьМакет(
		"ОсновнаяСхемаКомпоновкиДанных");
	
	//@skip-check dynamic-access-method-not-found
	//@skip-check property-return-type
	Настройки = СхемаКомпоновки.ВариантыНастроек.Найти("Основной").Настройки; // НастройкиКомпоновкиДанных
	
	КомпоновщикНастроек = Новый КомпоновщикНастроекКомпоновкиДанных();
	КомпоновщикНастроек.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(СхемаКомпоновки));
	КомпоновщикНастроек.ЗагрузитьНастройки(Настройки);
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	СоздатьВТОбщиеДанныеСправок(МенеджерВременныхТаблиц, Сотрудники);

	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновки, КомпоновщикНастроек.Настройки, , ,
		Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки, , , , , МенеджерВременныхТаблиц);
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ПроцессорВывода.УстановитьОбъект(ТаблицаДанных);
	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
	
	Возврат ТаблицаДанных;
	
КонецФункции

Функция МакетСправкиИзПрисоединенногоФайла(ПрисоединенныйФайл)
	
	МакетСправки = Новый ТабличныйДокумент;
	
	Если Не ЗначениеЗаполнено(ПрисоединенныйФайл) Тогда
		Возврат МакетСправки;
	КонецЕсли;
	
	ДвоичныеДанныеШаблона = РаботаСФайлами.ДвоичныеДанныеФайла(ПрисоединенныйФайл); // ДвоичныеДанные
	Поток = ДвоичныеДанныеШаблона.ОткрытьПотокДляЧтения(); 
	
	МакетСправки.Прочитать(Поток);
	
	Возврат МакетСправки;
	
КонецФункции

Процедура ЗаполнитьПараметрыСправки(ОбластьВывода, СтрокаТаблицы)
	
	СтруктураДанныхСтроки = ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(СтрокаТаблицы);
	
	Пол = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(СтруктураДанныхСтроки, "Пол", Неопределено);
	ЗаполнитьСклоненияФИО(СтруктураДанныхСтроки, "ФИОПолные", Пол);
	ЗаполнитьСклоненияФИО(СтруктураДанныхСтроки, "ФИОРуководителя", Пол);
	ЗаполнитьСклоненияФИО(СтруктураДанныхСтроки, "ФИОГлавногоБухгалтера", Пол);
	ЗаполнитьСклоненияПараметра(СтруктураДанныхСтроки, "Должность");
	ЗаполнитьСклоненияПараметра(СтруктураДанныхСтроки, "ДолжностьРуководителя");
	ЗаполнитьСклоненияПараметра(СтруктураДанныхСтроки, "ДолжностьГлавногоБухгалтера");
	
	Для Каждого КлючЗначение Из СтруктураДанныхСтроки Цикл
		Если ТипЗнч(КлючЗначение.Значение) = Тип("Дата") Тогда
			СтруктураДанныхСтроки[КлючЗначение.Ключ] = Формат(КлючЗначение.Значение, "ДЛФ=Д");
		КонецЕсли;
	КонецЦикла;
	
	ОбластьВывода.Параметры.Заполнить(СтруктураДанныхСтроки);
	
КонецПроцедуры

Процедура ЗаполнитьСклоненияФИО(Данные, ИмяПараметра, Пол = Неопределено)
	
	ИменительныйПадеж = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Данные, ИмяПараметра, "");
	Если Не ЗначениеЗаполнено(ИменительныйПадеж) Тогда
		Возврат;
	КонецЕсли;
	
	ФизическиеЛицаЗарплатаКадры.Просклонять(ИменительныйПадеж, 2, Данные[ИмяПараметра + "РодительныйПадеж"], Пол);
	ФизическиеЛицаЗарплатаКадры.Просклонять(ИменительныйПадеж, 3, Данные[ИмяПараметра + "ДательныйПадеж"], Пол);
	ФизическиеЛицаЗарплатаКадры.Просклонять(ИменительныйПадеж, 4, Данные[ИмяПараметра + "ВинительныйПадеж"], Пол);
	ФизическиеЛицаЗарплатаКадры.Просклонять(ИменительныйПадеж, 5, Данные[ИмяПараметра + "ТворительныйПадеж"], Пол);
	ФизическиеЛицаЗарплатаКадры.Просклонять(ИменительныйПадеж, 6, Данные[ИмяПараметра + "ПредложныйПадеж"], Пол);
	
КонецПроцедуры

Процедура ЗаполнитьСклоненияПараметра(Данные, ИмяПараметра)
	
	ИменительныйПадеж = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Данные, ИмяПараметра, "");
	
	Если ОбщегоНазначения.ЭтоСсылка(ТипЗнч(ИменительныйПадеж)) Тогда
		ИменительныйПадеж = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ИменительныйПадеж, "Наименование");
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ИменительныйПадеж) Тогда
		Возврат;
	КонецЕсли;
	
	Данные[ИмяПараметра + "РодительныйПадеж"] = СклонениеПредставленийОбъектов.ПросклонятьПредставление(
		ИменительныйПадеж, 2);
	Данные[ИмяПараметра + "ДательныйПадеж"] = СклонениеПредставленийОбъектов.ПросклонятьПредставление(
		ИменительныйПадеж, 3);
	Данные[ИмяПараметра + "ВинительныйПадеж"] = СклонениеПредставленийОбъектов.ПросклонятьПредставление(
		ИменительныйПадеж, 4);
	Данные[ИмяПараметра + "ТворительныйПадеж"] = СклонениеПредставленийОбъектов.ПросклонятьПредставление(
		ИменительныйПадеж, 5);
	Данные[ИмяПараметра + "ПредложныйПадеж"] = СклонениеПредставленийОбъектов.ПросклонятьПредставление(
		ИменительныйПадеж, 6);
	
КонецПроцедуры

