	СтрокаДанные.РаботаГрафикРаботыЧасовВДеньСокращенныйПредставление = "_____";
	СтрокаДанные.РаботаГрафикРаботыНедельный = Истина;
	СтрокаДанные.РаботаГрафикРаботыЧасовВДеньПредставление = 8;
	СтрокаДанные.РаботаГрафикРаботыЧасовВНеделю = 40;
	СтрокаДанные.РаботаДатаПриема = ДобавитьМесяц(ТекущаяДатаСеанса(), -15);
	СтрокаДанные.РаботаДатаУвольнения = ДобавитьМесяц(ТекущаяДатаСеанса(), -1);
	СтрокаДанные.РаботаОрганизацияИНН = ДанныеДляОбразца.ОрганизацияИНН;
	СтрокаДанные.РаботаОрганизацияКодОКВЭД = ДанныеДляОбразца.ОрганизацияКодОКВЭД;
	СтрокаДанные.РаботаОрганизацияНаименованиеПолное = ДанныеДляОбразца.ОрганизацияНаименованиеПолное;
	СтрокаДанные.РаботаОрганизацияНаименованиеСокращенное = ДанныеДляОбразца.Организация;
	СтрокаДанные.РаботаОрганизацияТелефонОрганизации = ДанныеДляОбразца.ОрганизацияТелефон;
	СтрокаДанные.РаботаРуководительРасшифровкаПодписи = ДанныеДляОбразца.РуководительРасшифровкаПодписи;
	СтрокаДанные.РаботаСотрудникГоловнаяОрганизация = ДанныеДляОбразца.Организация;
	
	Возврат ДаннееДляСправки;
	
КонецФункции

Функция ОбразецСправкиПоОтпускам()
	
	ДокументРезультат = Новый ТабличныйДокумент;
	ТаблицаСобытий = ДанныеДляОбразцаСправкиПоОтпускам();
	ДокументРезультат = ОстаткиОтпусков.ПечатнаяФормаСправкиПоОтпускамСотрудника(ТаблицаСобытий);
	
	Возврат ДокументРезультат;
	
КонецФункции

Функция ДанныеДляОбразцаСправкиПоОтпускам()
	
	ТестовыеДанные = ДанныеДляОбразца();
	
	ТаблицаСобытий = ОстаткиОтпусков.НоваяТаблицаСобытийДляСправки();
	
	НоваяСтрока = ТаблицаСобытий.Добавить();
	НоваяСтрока.Сотрудник = ТестовыеДанные.ФИОПолные;
	НоваяСтрока.ТекущаяОрганизация = ТестовыеДанные.Организация;
	НоваяСтрока.ТекущееПодразделение = ТестовыеДанные.Подразделение;
	НоваяСтрока.ТекущаяДолжность = ТестовыеДанные.Должность;
	
	ОтпускОсновной = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыОтпусков.Основной");
	ОтпускСеверный = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыОтпусков.Северный");
	
	// данные остатков
	ДанныеОстатков = Новый Массив;
	
	Если ОтпускОсновной <> Неопределено Тогда
		ДобавитьОстатокОтпуска(ДанныеОстатков, ТестовыеДанные.ФИОПолные, ОтпускОсновной, "Основной",
			'2020.07.01', '2021.06.30', 14);
		ДобавитьОстатокОтпуска(ДанныеОстатков, ТестовыеДанные.ФИОПолные, ОтпускОсновной, "Основной",
			'2021.07.01', '2022.06.30', 28);
		ДобавитьОстатокОтпуска(ДанныеОстатков, ТестовыеДанные.ФИОПолные, ОтпускОсновной, "Основной",
			'2022.07.01', '2022.09.15', 7);
	КонецЕсли;

	Если ОтпускСеверный <> Неопределено Тогда
		ДобавитьОстатокОтпуска(ДанныеОстатков, ТестовыеДанные.ФИОПолные, ОтпускСеверный, "Северный",
			'2020.07.01', '2021.06.30', 16);
		ДобавитьОстатокОтпуска(ДанныеОстатков, ТестовыеДанные.ФИОПолные, ОтпускСеверный, "Северный",
			'2021.07.01', '2022.06.30', 16);
		ДобавитьОстатокОтпуска(ДанныеОстатков, ТестовыеДанные.ФИОПолные, ОтпускСеверный, "Северный",
			'2022.07.01', '2022.09.15', 4);
	КонецЕсли;
	
	НоваяСтрока.ДанныеОстатков = ДанныеОстатков;
	
	// данные событий
	ДанныеСобытий = Новый Массив;
	ДобавитьСобытиеПриемНаРаботу(ДанныеСобытий);
	ДобавитьСобытиеОтпуск(ДанныеСобытий);
	ДобавитьСобытиеСейчас(ДанныеСобытий);
	НоваяСтрока.ДанныеСобытий = ДанныеСобытий;
	
	Возврат ТаблицаСобытий;
	
КонецФункции

Процедура ДобавитьСобытиеСейчас(ДанныеСобытий)
	
	Событие = Новый Структура;
	Событие.Вставить("ДатаПредыдущегоСобытия", '2022.07.07'); 
	Событие.Вставить("ДатаСобытия", '2022.09.15');
	Событие.Вставить("ДокументСобытие", "");
	Событие.Вставить("Событие", "Сегодня");
	
	НакопленоСПредыдущегоСобытия = Новый Массив;
	
	ОтпускОсновной = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыОтпусков.Основной");
	Если ОтпускОсновной <> Неопределено Тогда
		НакопленоСПредыдущегоСобытия.Добавить(Новый Структура("ВидЕжегодногоОтпуска,КоличествоДнейЗаПериод",
			ОтпускОсновной, 7));
	КонецЕсли;
	
	ОтпускСеверный = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыОтпусков.Северный");
	Если ОтпускСеверный <> Неопределено Тогда
		НакопленоСПредыдущегоСобытия.Добавить(Новый Структура("ВидЕжегодногоОтпуска,КоличествоДнейЗаПериод",
			ОтпускСеверный, 4));
	КонецЕсли;
	
	Событие.Вставить("НакопленоСПредыдущегоСобытия", НакопленоСПредыдущегоСобытия);
	
	Событие.Вставить("ФактическиеОтпуска", Неопределено);
	Событие.Вставить("ПраваНаОтпуска", Неопределено);
	Событие.Вставить("НачальныеОстаткиОтпусков", Неопределено);
	Событие.Вставить("Отклонения", Неопределено);
	Событие.Вставить("ПоследнееСобытие", Истина);
	Событие.Вставить("ПродлениеРабочегоГода", Неопределено);
	Событие.Вставить("РабочиеГодаОтпусков", Неопределено);
	
	ДанныеСобытий.Добавить(Событие);
	
КонецПроцедуры

Процедура ДобавитьСобытиеОтпуск(ДанныеСобытий)
	
	ДокументСобытие = НСтр("ru = 'Отпуск 00ЗК-000001 от 07.07.2022'");
	ДатаНачала = '2022.07.07';
	ДатаОкончания = '2022.07.20';
	
	Событие = Новый Структура;
	Событие.Вставить("ДатаПредыдущегоСобытия", '2020.07.01');
	Событие.Вставить("ДатаСобытия", ДатаНачала);
	Событие.Вставить("ДокументСобытие", ДокументСобытие);
	Событие.Вставить("Событие", ДокументСобытие);

	НакопленоСПредыдущегоСобытия = Новый Массив;
	
	ОтпускОсновной = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыОтпусков.Основной");
	Если ОтпускОсновной <> Неопределено Тогда
		НакопленоСПредыдущегоСобытия.Добавить(Новый Структура("ВидЕжегодногоОтпуска,КоличествоДнейЗаПериод",
			ОтпускОсновной, 56));
	КонецЕсли;
	
	ОтпускСеверный = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыОтпусков.Северный");
	Если ОтпускСеверный <> Неопределено Тогда
		НакопленоСПредыдущегоСобытия.Добавить(Новый Структура("ВидЕжегодногоОтпуска,КоличествоДнейЗаПериод",
			ОтпускСеверный, 32));
	КонецЕсли;
	
	Событие.Вставить("НакопленоСПредыдущегоСобытия", НакопленоСПредыдущегоСобытия);
	
	ФактическиеОтпуска = Новый Массив;
	
	ФактическийОтпуск = Новый Структура;
	ФактическийОтпуск.Вставить("ВидЕжегодногоОтпуска", Справочники.ВидыОтпусков.Основной);
	ФактическийОтпуск.Вставить("ВидЕжегодногоОтпускаНаименование", "Основной");
	ФактическийОтпуск.Вставить("ДатаВхожденияВРабочийГод", ДатаНачала);
	ФактическийОтпуск.Вставить("ДатаНачалаОтпуска", ДатаНачала);
	ФактическийОтпуск.Вставить("ДатаОкончанияОтпуска", ДатаОкончания);
	ФактическийОтпуск.Вставить("ДатаРегистрации", ДатаНачала);
	ФактическийОтпуск.Вставить("ДатаОстатков", Неопределено);
	ФактическийОтпуск.Вставить("КоличествоДнейОтпуска", 14);
	ФактическийОтпуск.Вставить("Компенсация", Ложь);
	ФактическийОтпуск.Вставить("ОснованиеИзДокумента", "");
	ФактическийОтпуск.Вставить("ПериодыОтпуска", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(
		Новый Структура("ДатаНачала,ДатаОкончания", ДатаНачала, ДатаОкончания)));
	ФактическийОтпуск.Вставить("РабочийПериодСИзДокумента", ДатаНачала);
	ФактическийОтпуск.Вставить("РабочийПериодПоИзДокумента", '2021.06.30');
	ФактическиеОтпуска.Добавить(ФактическийОтпуск);
