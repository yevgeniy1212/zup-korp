&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьДоступностьКодаДоходаНДФЛ(Форма)
	
	ДоступностьКодаНДФЛ = Форма.ОблагаетсяНДФЛ = 1;
	
	Форма.Элементы.КодДоходаНДФЛ.Доступность = ДоступностьКодаНДФЛ;
	Форма.Элементы.КодДоходаНДФЛ.АвтоОтметкаНезаполненного = ДоступностьКодаНДФЛ;
	Форма.Элементы.КодДоходаНДФЛ.ОтметкаНезаполненного = Не ЗначениеЗаполнено(Форма.Объект.КодДоходаНДФЛ);
	
КонецПроцедуры

// ЗУПК
&НаСервере
Процедура ПроинициализироватьФорму()
	
	Если ЭтаФорма.НалогообложениеНачисленийПрежняя = Неопределено Тогда
		РедактированиеПериодическихСведений.ПрочитатьЗаписьДляРедактированияВФорме(ЭтаФорма, "НалогообложениеНачислений", Объект.Ссылка);
		ДобавитьИнойВидДоходаВСписокВыбора(ЭтаФорма);
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ЭтаФорма.НалогообложениеНачисленийПрежняя.Период) Тогда
		// нет записей в регистре, нужно записать элемент
		ЭтаФорма.Модифицированность = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьПризнакиУчета(ВидДохода)
	
	ЭтаФорма.НалогообложениеНачисленийУчитыватьИПН	 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидДохода, "УчитыватьИПН");
	ЭтаФорма.НалогообложениеНачисленийУчитыватьВОСМС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидДохода, "УчитыватьВОСМС");
	ЭтаФорма.НалогообложениеНачисленийУчитыватьОПВ	 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидДохода, "УчитыватьОПВ");
	ЭтаФорма.НалогообложениеНачисленийУчитыватьСО	 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидДохода, "УчитыватьСО");
	ЭтаФорма.НалогообложениеНачисленийУчитыватьСН	 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидДохода, "УчитыватьСН");
	ЭтаФорма.НалогообложениеНачисленийУчитыватьООСМС = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидДохода, "УчитыватьООСМС");
	ЭтаФорма.НалогообложениеНачисленийУчитыватьОПВР	 = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ВидДохода, "УчитыватьОПВР");
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСпособНалогообложенияПоУмолчанию()
	
	ПолучитьПризнакиУчета(ЭтаФорма.НалогообложениеНачислений.ВидДохода);
	
	ЭтаФорма.НалогообложениеНачислений.СпособОбложенияИПН	= ?(ЭтаФорма.НалогообложениеНачисленийУчитыватьИПН, ПредопределенноеЗначение("Перечисление.СпособыНалогообложенияДоходов.ОблагаетсяЦеликом"), Неопределено);
	ЭтаФорма.НалогообложениеНачислений.СпособОбложенияВОСМС	= ?(ЭтаФорма.НалогообложениеНачисленийУчитыватьВОСМС, ПредопределенноеЗначение("Перечисление.СпособыНалогообложенияДоходов.ОблагаетсяЦеликом"), Неопределено);
	ЭтаФорма.НалогообложениеНачислений.СпособОбложенияОПВ	= ?(ЭтаФорма.НалогообложениеНачисленийУчитыватьОПВ, ПредопределенноеЗначение("Перечисление.СпособыНалогообложенияДоходов.ОблагаетсяЦеликом"), Неопределено);
	ЭтаФорма.НалогообложениеНачислений.СпособОбложенияСО	= ?(ЭтаФорма.НалогообложениеНачисленийУчитыватьСО, ПредопределенноеЗначение("Перечисление.СпособыНалогообложенияДоходов.ОблагаетсяЦеликом"), Неопределено);
	ЭтаФорма.НалогообложениеНачислений.СпособОбложенияСН	= ?(ЭтаФорма.НалогообложениеНачисленийУчитыватьСН, ПредопределенноеЗначение("Перечисление.СпособыНалогообложенияДоходов.ОблагаетсяЦеликом"), Неопределено);
	ЭтаФорма.НалогообложениеНачислений.СпособОбложенияООСМС = ?(ЭтаФорма.НалогообложениеНачисленийУчитыватьООСМС, ПредопределенноеЗначение("Перечисление.СпособыНалогообложенияДоходов.ОблагаетсяЦеликом"), Неопределено);
	ЭтаФорма.НалогообложениеНачислений.СпособОбложенияОПВР  = ?(ЭтаФорма.НалогообложениеНачисленийУчитыватьОПВР, ПредопределенноеЗначение("Перечисление.СпособыНалогообложенияДоходов.ОблагаетсяЦеликом"), Неопределено);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьВидимостьСпособовОбложения()
	
	Если НЕ ЗначениеЗаполнено(ЭтаФорма.НалогообложениеНачислений.ВидДохода) Тогда
		 ЭтаФорма.НалогообложениеНачислений.ВидДохода = ПредопределенноеЗначение("Справочник.ВидыДоходов.ДоходыОтНалоговогоАгента");
		 УстановитьСпособНалогообложенияПоУмолчанию();
	КонецЕсли;
	 
	НеОблагаетсяЧастично = ПредопределенноеЗначение("Перечисление.СпособыНалогообложенияДоходов.НеОблагаетсяЧастично"); 
	
	Элементы.НалогообложениеНачисленийДоходНеПодлежащийНалогообложениюИПН.Видимость		= ЭтаФорма.НалогообложениеНачислений.СпособОбложенияИПН	 = НеОблагаетсяЧастично;
	Элементы.НалогообложениеНачисленийДоходНеПодлежащийНалогообложениюОПВ.Видимость		= ЭтаФорма.НалогообложениеНачислений.СпособОбложенияОПВ	 = НеОблагаетсяЧастично;
	Элементы.НалогообложениеНачисленийДоходНеПодлежащийНалогообложениюВОСМС.Видимость	= ЭтаФорма.НалогообложениеНачислений.СпособОбложенияВОСМС = НеОблагаетсяЧастично;
	Элементы.НалогообложениеНачисленийДоходНеПодлежащийНалогообложениюСО.Видимость		= ЭтаФорма.НалогообложениеНачислений.СпособОбложенияСО = НеОблагаетсяЧастично;
	Элементы.НалогообложениеНачисленийДоходНеПодлежащийНалогообложениюСН.Видимость		= ЭтаФорма.НалогообложениеНачислений.СпособОбложенияСН = НеОблагаетсяЧастично;
	Элементы.НалогообложениеНачисленийДоходНеПодлежащийНалогообложениюООСМС.Видимость	= ЭтаФорма.НалогообложениеНачислений.СпособОбложенияООСМС = НеОблагаетсяЧастично;
	Элементы.НалогообложениеНачисленийДоходНеПодлежащийНалогообложениюОПВР.Видимость	= ЭтаФорма.НалогообложениеНачислений.СпособОбложенияОПВР = НеОблагаетсяЧастично;
	
	Элементы.НалогообложениеНачисленийСпособОбложенияИПН.Видимость		= ЭтаФорма.НалогообложениеНачисленийУчитыватьИПН;
	Элементы.НалогообложениеНачисленийСпособОбложенияОПВ.Видимость		= ЭтаФорма.НалогообложениеНачисленийУчитыватьОПВ;
	Элементы.НалогообложениеНачисленийСпособОбложенияВОСМС.Видимость	= ЭтаФорма.НалогообложениеНачисленийУчитыватьВОСМС;
	Элементы.НалогообложениеНачисленийСпособОбложенияСО.Видимость		= ЭтаФорма.НалогообложениеНачисленийУчитыватьСО;
	Элементы.НалогообложениеНачисленийСпособОбложенияСН.Видимость		= ЭтаФорма.НалогообложениеНачисленийУчитыватьСН;
	Элементы.НалогообложениеНачисленийСпособОбложенияООСМС.Видимость 	= ЭтаФорма.НалогообложениеНачисленийУчитыватьООСМС;
	Элементы.НалогообложениеНачисленийСпособОбложенияОПВР.Видимость	 	= ЭтаФорма.НалогообложениеНачисленийУчитыватьОПВР;
	
	Если НЕ ЗначениеЗаполнено(ЭтаФорма.НалогообложениеНачислений.Период) Тогда
		ЭтаФорма.НалогообложениеНачислений.Период = НачалоМесяца(ТекущаяДата());
	КонецЕсли;
	
	РедактированиеПериодическихСведенийКлиентСервер.ОбновитьОтображениеПолейВвода(ЭтаФорма, "НалогообложениеНачислений", Объект.Ссылка);
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьНаборЗаписейПериодическихСведений(ИмяРегистра, ВедущийОбъект) Экспорт
	
	РедактированиеПериодическихСведений.ПрочитатьНаборЗаписей(ЭтаФорма, ИмяРегистра, ВедущийОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьНалогообложениеНачислений(ТекущийОбъект)
	
	РедактированиеПериодическихСведений.ЗаписатьЗаписьПослеРедактированияВФорме(ЭтаФорма, "НалогообложениеНачислений", ТекущийОбъект.Ссылка);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьОтображениеПолейВводаНалогообложенияНачислений()
	
	РедактированиеПериодическихСведенийКлиентСервер.ОбновитьОтображениеПолейВвода(ЭтаФорма, "НалогообложениеНачислений", Объект.Ссылка);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьНаКлиенте(ЗакрытьПослеЗаписи)
	
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда
		
		Если НЕ ЗначениеЗаполнено(ЭтаФорма.НалогообложениеНачисленийПрежняя.Период) Тогда
			ЭтаФорма.НалогообложениеНачисленийНоваяЗапись = Истина;
		КонецЕсли;
		
		Если НЕ ЭтаФорма.НалогообложениеНачисленийНоваяЗапись Тогда
			
			ИзменилсяПериод = (ЭтаФорма.НалогообложениеНачислений.Период <> ЭтаФорма.НалогообложениеНачисленийПрежняя.Период);
			ИзменилисьДанные = Ложь;
			Для Каждого Поле Из ЭтаФорма.НалогообложениеНачисленийПрежняя Цикл
				Если Поле.Ключ = "Период" Тогда
					Продолжить;
				КонецЕсли;
				ИзменилисьДанные = ЭтаФорма.НалогообложениеНачислений[Поле.Ключ] <> Поле.Значение;
				Если ИзменилисьДанные Тогда
					Прервать;
				КонецЕсли;
			КонецЦикла;
			
			Если ИзменилисьДанные ИЛИ ИзменилсяПериод Тогда
				ОткрытьФормуПредупрежденияОбИзмененииНалогообложения(ЗакрытьПослеЗаписи);
				Возврат;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	ПараметрыЗаписи = Новый Структура("ПроверкаПередЗаписьюВыполнена", Истина);
	Если Записать(ПараметрыЗаписи) И ЗакрытьПослеЗаписи Тогда
		Закрыть();
	Иначе
		Если ЭтаФорма.НалогообложениеНачисленийНоваяЗапись Тогда
			ЭтаФорма.НалогообложениеНачисленийНоваяЗапись = Ложь;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуПредупрежденияОбИзмененииНалогообложения(ЗакрытьПослеИсправления = Истина, ЗаписатьДанные = Истина)
	
	ТекстКнопкиДа = НСтр("ru = 'Изменились настройки'");
	ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'При редактировании Вы изменили настройки налогообложения вида прочего дохода.
					|Если Вы исправили прежнюю запись (она была ошибочной), нажмите ""Исправлена ошибка"".
					|Если у элемента изменился вид дохода с %1, нажмите ""%2""'"),
			Формат(ЭтаФорма.НалогообложениеНачислений.Период, "ДФ='д ММММ гггг ""г""'"),
			ТекстКнопкиДа);
			
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ЗакрытьПослеИсправления", ЗакрытьПослеИсправления);
	ДополнительныеПараметры.Вставить("ЗаписатьДанные", ЗаписатьДанные);
	
	Оповещение = Новый ОписаниеОповещения("ОткрытьФормуПредупрежденияОИзмененииНалогообложенияЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	
	РедактированиеПериодическихСведенийКлиент.ЗапроситьРежимИзмененияРегистра(ЭтотОбъект, "НалогообложениеНачислений", ТекстВопроса, ТекстКнопкиДа, , Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуПредупрежденияОИзмененииНалогообложенияЗавершение(Отказ, ДополнительныеПараметры) Экспорт 

	Если Отказ = Истина Тогда
		Возврат;
	КонецЕсли;
	
	Если НЕ ЭтаФорма.НалогообложениеНачисленийНоваяЗапись Тогда
		
		ЗаписатьНалогообложениеНачислений(Объект.Ссылка);

		НалогообложениеНачисленийСтруктура = Новый Структура;
		
		Для Каждого Поле Из ЭтаФорма.НалогообложениеНачисленийПрежняя Цикл
			НалогообложениеНачисленийСтруктура.Вставить(Поле.Ключ, ЭтаФорма.НалогообложениеНачислений[Поле.Ключ]);
		КонецЦикла;
		
		ЭтаФорма.НалогообложениеНачисленийПрежняя = Новый ФиксированнаяСтруктура(НалогообложениеНачисленийСтруктура);
		
	КонецЕсли;
	
	ОбновитьВидимостьСпособовОбложения();
	
	Если ДополнительныеПараметры.ЗаписатьДанные Тогда 
		ЗаписатьНаКлиенте(ДополнительныеПараметры.ЗакрытьПослеИсправления);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ДобавитьИнойВидДоходаВСписокВыбора(Форма)
	
	Элементы = Форма.Элементы;
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(Элементы, "НалогообложениеНачисленийВидДохода") Тогда
		ТекущийВидДохода = Форма.НалогообложениеНачислений.ВидДохода;
		ВидДоходаСписок = Элементы.НалогообложениеНачисленийВидДохода.СписокВыбора;
		Если ВидДоходаСписок.НайтиПоЗначению(ТекущийВидДохода) = Неопределено Тогда
			ВидДоходаСписок.Добавить(ТекущийВидДохода);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры
