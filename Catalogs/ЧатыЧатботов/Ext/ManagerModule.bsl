#Область СлужебныеПроцедурыИФункции

Функция ОписаниеЧата() Экспорт
	
	Описание = Новый Структура(
		"Код, 
		|Наименование, 
		|Групповой");
	Описание.Групповой = Ложь;
	
	Возврат Описание;
	
КонецФункции

Функция СоздатьЧат(Код, Описание = Неопределено) Экспорт
	
	ЧатСсылка = Справочники.ЧатыЧатботов.НайтиПоКоду(Код);
	Если Не ЧатСсылка.Пустая() Тогда
		Возврат ЧатСсылка;
	КонецЕсли;
	
	Если Описание = Неопределено Тогда
		Описание = ОписаниеЧата();
	КонецЕсли;
	
	ЧатОбъект = Справочники.ЧатыЧатботов.СоздатьЭлемент();
	ЗаполнитьЗначенияСвойств(ЧатОбъект, Описание);
	ЧатОбъект.Код = Код;
	ЧатОбъект.Записать();
	
	Возврат ЧатСсылка;
	
КонецФункции

#КонецОбласти

#КонецЕсли