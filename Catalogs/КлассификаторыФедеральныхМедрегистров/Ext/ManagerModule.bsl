Функция ОбновитьСправочникФРМР(Ссылка,ОписаниеСправочника)
	Если ОписаниеСправочника = Неопределено Тогда
		Возврат Справочники.КлассификаторыФедеральныхМедрегистров.ПустаяСсылка();
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Ссылка) Тогда
		СправочникОбъект = Ссылка.ПолучитьОбъект();
	Иначе
		НайденноеОписаниеСправочника = Справочники.КлассификаторыФедеральныхМедрегистров.НайтиПоКоду(ОписаниеСправочника.oid);
		Если ЗначениеЗаполнено(НайденноеОписаниеСправочника) Тогда 
			СправочникОбъект = НайденноеОписаниеСправочника.ПолучитьОбъект();
		Иначе
			СправочникОбъект = Справочники.КлассификаторыФедеральныхМедрегистров.СоздатьЭлемент();
		КонецЕсли;
	КонецЕсли;
	
	СправочникОбъект.Наименование = ОписаниеСправочника.shortName;
	СправочникОбъект.Код 		= ОписаниеСправочника.oid;
	СправочникОбъект.Версия		= ОписаниеСправочника.version;
	СправочникОбъект.КоличествоЭлементов = ОписаниеСправочника.rowsCount;
	СправочникОбъект.Иерархия 	= ОписаниеСправочника.hierarchical;
	СправочникОбъект.Изменен 	= ОписаниеСправочника.lastUpdate;
	СправочникОбъект.ПолеИдентификатор = ОписаниеСправочника.fieldId;
	
	СправочникОбъект.СтруктураСправочника.Очистить();
	Для Каждого ПолеСправочника Из ОписаниеСправочника.fields Цикл
		ЭлементСтруктуры = СправочникОбъект.СтруктураСправочника.Добавить();
		ЭлементСтруктуры.ИмяПоля = ПолеСправочника.Ключ;
		ЭлементСтруктуры.Представление = ПолеСправочника.Значение;
	КонецЦикла;
	
	СправочникОбъект.ОбменДанными.Загрузка = Истина;
	
	СправочникОбъект.Записать();
	
	Возврат СправочникОбъект.Ссылка;
		
КонецФункции

Процедура СохранитьДанныеВСправочникЭлементыСправочниковФРМР(ТаблицаДанных, Владелец)
	
	Запрос = Новый Запрос;
	
	ТекстЗапроса = "ВЫБРАТЬ
	               |	Таблица.ID КАК Код,
	               |	Таблица.Name КАК Наименование,
	               |	Таблица.Parent_ID КАК Родитель
	               |ПОМЕСТИТЬ ВТТаблица
	               |ИЗ
	               |	&ТЗ КАК Таблица
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Таблица.Код КАК Код,
	               |	Таблица.Наименование КАК Наименование,
	               |	Таблица.Родитель КАК Родитель,
	               |	Таблица.КоличествоПодчиненных КАК КоличествоПодчиненных,
	               |	ЕСТЬNULL(ЭлементыСправочника.Ссылка, ЗНАЧЕНИЕ(Справочник.ЭлементыКлассификаторовФедеральныхМедрегистров.ПустаяСсылка)) КАК Ссылка,
	               |	ЕСТЬNULL(ЭлементыСправочника.НаименованиеПолное, """") КАК НаименованиеЭлементаСправочника
	               |ИЗ
	               |	(ВЫБРАТЬ
	               |		Таблица.Код КАК Код,
	               |		Таблица.Наименование КАК Наименование,
	               |		Таблица.Родитель КАК Родитель,
	               |		КОЛИЧЕСТВО(ТаблицаПодчиненных.Код) КАК КоличествоПодчиненных
	               |	ИЗ
	               |		ВТТаблица КАК Таблица
	               |			ЛЕВОЕ СОЕДИНЕНИЕ ВТТаблица КАК ТаблицаПодчиненных
	               |			ПО Таблица.Код = ТаблицаПодчиненных.Родитель
	               |	
	               |	СГРУППИРОВАТЬ ПО
	               |		Таблица.Код,
	               |		Таблица.Наименование,
	               |		Таблица.Родитель) КАК Таблица
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЭлементыКлассификаторовФедеральныхМедрегистров КАК ЭлементыСправочника
	               |		ПО (ЭлементыСправочника.Владелец = &Владелец)
	               |			И (ЭлементыСправочника.Код = Таблица.Код)";
	
	Запрос.Текст = ТекстЗапроса;
	Запрос.УстановитьПараметр("Владелец", Владелец);
	Запрос.УстановитьПараметр("ТЗ", ТаблицаДанных);
	ТаблицаЭлементов = Запрос.Выполнить().Выгрузить();
	ТаблицаЭлементов.Колонки.Добавить("ОписаниеЭлемента", Новый ОписаниеТипов("Структура"));
	Для Каждого ЭлементТаблицы Из ТаблицаЭлементов Цикл
		ЭлементФРМР = ТаблицаДанных.Найти(ЭлементТаблицы.Код,"ID");
		ЭлементТаблицы.ОписаниеЭлемента = ЭлементФРМР.ITEMS;
	КонецЦикла;
	
		
	Если Владелец.Иерархия Тогда
		
		ДеревоЗначений = ДеревоИзТаблицы(ТаблицаЭлементов, "Код", "Родитель");
		
		СохранитьИерархическиеДанныеСправочникЭлементыСправочниковФРМР(ДеревоЗначений.Строки, Владелец, Справочники.ЭлементыКлассификаторовФедеральныхМедрегистров.ПустаяСсылка());
		
	Иначе
		
		Для Каждого ЭлементТаблицы Из ТаблицаЭлементов Цикл
			
			СохранитьЭлементСправочникЭлементыСправочниковФРМР(ЭлементТаблицы, Владелец, Неопределено, Ложь);
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

Функция ПустаяТаблицаСодержимогоКлассификатораФРМР()
	
	ТаблицаСправочникаФРМР = Новый ТаблицаЗначений();
	ТаблицаСправочникаФРМР.Колонки.Добавить("ID",ОбщегоНазначения.ОписаниеТипаСтрока(50));
	ТаблицаСправочникаФРМР.Колонки.Добавить("NAME",ОбщегоНазначения.ОписаниеТипаСтрока(150));
	ТаблицаСправочникаФРМР.Колонки.Добавить("PARENT_ID",ОбщегоНазначения.ОписаниеТипаСтрока(30));
	ТаблицаСправочникаФРМР.Колонки.Добавить("ITEMS", Новый ОписаниеТипов("Структура"));
	
	Возврат ТаблицаСправочникаФРМР;
	
КонецФункции

Функция ПустаяСтруктураКлассификатораФРМР()
	
	Результат = Новый Структура();
	Результат.Вставить("oid");
	Результат.Вставить("version");
	Результат.Вставить("rowsCount");
	Результат.Вставить("lastUpdate");
	Результат.Вставить("fullName");
	Результат.Вставить("shortName");
	Результат.Вставить("hierarchical");
	Результат.Вставить("fieldId");
	Результат.Вставить("fields");
	
	Возврат Результат;
	
КонецФункции

Функция ПустаяТаблицаСправочниковФРМР() Экспорт
	
	ТаблицаСправочниковФРМР = Новый ТаблицаЗначений();
	ТаблицаСправочниковФРМР.Колонки.Добавить("КодКлассификатора",ОбщегоНазначения.ОписаниеТипаСтрока(50));
	ТаблицаСправочниковФРМР.Колонки.Добавить("НаименованиеКлассификатора",ОбщегоНазначения.ОписаниеТипаСтрока(150));
	ТаблицаСправочниковФРМР.Колонки.Добавить("Ссылка", Новый ОписаниеТипов("СправочникСсылка.КлассификаторыФедеральныхМедрегистров"));
	ТаблицаСправочниковФРМР.Колонки.Добавить("ТипОбъектаМетаданных", ОбщегоНазначения.ОписаниеТипаСтрока(150));
	ТаблицаСправочниковФРМР.Колонки.Добавить("ЭлементыСопоставимы", Новый ОписаниеТипов("Булево"));
	ТаблицаСправочниковФРМР.Колонки.Добавить("ОписаниеСправочника");
	
	Возврат ТаблицаСправочниковФРМР;
	
КонецФункции

Функция ПолучитьСправочникиФРМРИзМакета() Экспорт
	
	ТекстовыйДокумент = Справочники.КлассификаторыФедеральныхМедрегистров.ПолучитьМакет("СправочникиНСИ");
	Таблица = ОбщегоНазначения.ПрочитатьXMLВТаблицу(ТекстовыйДокумент.ПолучитьТекст()).Данные;
	
	СправочникиФРМР = ПустаяТаблицаСправочниковФРМР();
	
	Для Каждого ОписаниеСправочника из Таблица Цикл
		СправочникФРМР = СправочникиФРМР.Добавить();
		ЗаполнитьЗначенияСвойств(СправочникФРМР, ОписаниеСправочника);
		СправочникФРМР.ЭлементыСопоставимы = (ОписаниеСправочника.ЭлементыСопоставимы = "Истина");
	КонецЦикла;
	
	ЗаполнитьСсылкиНаСправочники(СправочникиФРМР);
	
	Возврат СправочникиФРМР;
	
КонецФункции

Процедура ЗаполнитьСсылкиНаСправочники(СправочникиФРМР) Экспорт
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Идентификаторы", СправочникиФРМР.ВыгрузитьКолонку("КодКлассификатора"));
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	КлассификаторыФедеральныхМедрегистров.Ссылка КАК Ссылка,
	|	КлассификаторыФедеральныхМедрегистров.Код КАК Код
	|ИЗ
	|	Справочник.КлассификаторыФедеральныхМедрегистров КАК КлассификаторыФедеральныхМедрегистров
	|ГДЕ
	|	КлассификаторыФедеральныхМедрегистров.Код В(&Идентификаторы)
	|	И НЕ КлассификаторыФедеральныхМедрегистров.ПометкаУдаления";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		ОписаниеСправочникаФРМР = СправочникиФРМР.Найти(Выборка.Код,"КодКлассификатора");
		ОписаниеСправочникаФРМР.Ссылка = Выборка.Ссылка;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

// Определяет возможность выбора из классификатора групп и элементов.
//
// Параметры:
//   Классификатор - СправочникСсылка.КлассификаторыФедеральныхМедрегистров.
