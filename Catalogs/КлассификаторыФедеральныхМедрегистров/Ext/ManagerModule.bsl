//
Функция КлассификаторИспользуетВыборГруппИЭлементов(Классификатор) Экспорт
	
	МассивКлассификаторов = Новый Массив();
//	МассивКлассификаторов.Добавить(Справочники.КлассификаторыФедеральныхМедрегистров.ArrayOfCertificateSpeciality);
	
	Возврат МассивКлассификаторов.Найти(Классификатор) <> Неопределено;
	
КонецФункции

Процедура УстановитьОтборПоOIDОрганизации(Список, Организация) Экспорт
	
	НастройкиОрганизации = МедицинскиеРегистры.ПолучитьНастройкиОрганизации(Организация);
		
	ГруппаОтбора = ОбщегоНазначенияКлиентСервер.СоздатьГруппуЭлементовОтбора(
		Список.Отбор.Элементы,
		НСтр("ru = 'OID организации: '") + НастройкиОрганизации.ИдентификаторДляМедрегистров,
		ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИ);
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ГруппаОтбора, "ОписаниеЭлемента.Поле", "mo_oid");
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ГруппаОтбора, "ОписаниеЭлемента.Значение", НастройкиОрганизации.ИдентификаторДляМедрегистров);
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли