// Функция строит дерево значений из таблицы значений.
// Передаваемые параметры:
// ИсходнаяТаблица - таблица, которую следует преобразовать в дерево.
// 	* КолонкаID - строка - наименование колонки-идентификатора.
// 	* КолонкаParent - строка - наименование колонки-родителя.
// Возвращаемое значение
//   Дерево значений.
//
Функция ДеревоИзТаблицы(ИсходнаяТаблица, КолонкаID="ID", КолонкаParent="Parent")
	
	ИсходнаяТаблица.Колонки.Добавить("ПолеСортировки", Новый ОписаниеТипов("Строка", , Новый КвалификаторыСтроки(10) ) );
	Для Каждого строка Из ИсходнаяТаблица Цикл
		строка.ПолеСортировки = Прав("00000"+СокрЛП(Строка[КолонкаParent]), 5);
	КонецЦикла;
	
	ИсходнаяТаблица.Сортировать("ПолеСортировки Возр");
	ДеревоРезультатов = Новый ДеревоЗначений; 
	Для Каждого Колонка Из ИсходнаяТаблица.Колонки Цикл
		Если Колонка.Имя = КолонкаParent Тогда
			Продолжить;
		КонецЕсли;
		ДеревоРезультатов.Колонки.Добавить(Колонка.Имя, Колонка.ТипЗначения);	
	КонецЦикла;
	
	Для Каждого СтрокаТаблицы Из ИсходнаяТаблица Цикл
		
		СтрокаРодитель = ДеревоРезультатов.Строки.Найти(СтрокаТаблицы[КолонкаParent], КолонкаID, Истина);
		Если СтрокаРодитель = Неопределено Тогда
			СтрокаДерева = ДеревоРезультатов.Строки.Добавить();
		Иначе
			СтрокаДерева = СтрокаРодитель.Строки.Добавить();
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(СтрокаДерева, СтрокаТаблицы);

	КонецЦикла;
	
	// Еще раз пробежаться по таблице в ситуации когда Код родителя > кода элемента
	// тогда возможна ситуация с потерянными строками.
	Для Каждого СтрокаТаблицы Из ИсходнаяТаблица Цикл
		
		СтрокаРодитель = ДеревоРезультатов.Строки.Найти(СтрокаТаблицы[КолонкаParent], КолонкаID, Истина);
		СтрокаДерева    = ДеревоРезультатов.Строки.Найти(СтрокаТаблицы[КолонкаID], КолонкаID, Истина);
		
		Если СтрокаДерева = Неопределено Тогда
			
			СтрокаДерева = ДеревоРезультатов.Строки.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаДерева, СтрокаТаблицы);
			
		КонецЕсли; 
		
		Если Не СтрокаДерева.Родитель = СтрокаРодитель Тогда
			ЗаполнитьЗначенияСвойств(СтрокаРодитель.Строки.Добавить(), СтрокаТаблицы);
			ДеревоРезультатов.Строки.Удалить(СтрокаДерева);
		КонецЕсли;
		
	КонецЦикла;
	
   Возврат ДеревоРезультатов;
   
КонецФункции

// Возвращает ссылку на элемент справочника.
//
Функция СохранитьЭлементСправочникЭлементыКлассификаторовМедРегистра(Данные, Владелец, Родитель, ЭтоГруппа)
	
	Если Данные.Наименование = Данные.НаименованиеЭлементаСправочника И ЗначениеЗаполнено(Данные.Ссылка) Тогда
		Возврат Данные.Ссылка;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Данные.Ссылка) Тогда
		
		ОбъектСправочника = Данные.Ссылка.ПолучитьОбъект();
		
	ИначеЕсли ЭтоГруппа Тогда
		
		ОбъектСправочника = Справочники.ЭлементыКлассификаторовМедРегистра.СоздатьГруппу();
		
	Иначе
		
		ОбъектСправочника = Справочники.ЭлементыКлассификаторовМедРегистра.СоздатьЭлемент();
		
	КонецЕсли;
	
	ЗаполнитьЗначенияСвойств(ОбъектСправочника, Данные, "Код,Наименование");
	ОбъектСправочника.Родитель = Родитель;
	ОбъектСправочника.Владелец = Владелец;
	
	ОбъектСправочника.ОбменДанными.Загрузка = Истина;
	
	ОбъектСправочника.Записать();
	
	Возврат ОбъектСправочника.Ссылка;
	
КонецФункции

Процедура СохранитьИерархическиеДанныеСправочникЭлементыКлассификаторовМедРегистра(КоллекцияДанных, Владелец, Родитель)
	
	Для Каждого СтрокаДанных Из КоллекцияДанных Цикл
		
		ПодчиненныеСтроки = СтрокаДанных.Строки;
		ЭтоГруппа = ПодчиненныеСтроки.Количество()>0;
		
		Ссылка = СохранитьЭлементСправочникЭлементыКлассификаторовМедРегистра(СтрокаДанных, Владелец, Родитель, ЭтоГруппа);
		
		Если ЭтоГруппа Тогда
			
			СохранитьИерархическиеДанныеСправочникЭлементыКлассификаторовМедРегистра(ПодчиненныеСтроки, Владелец, Ссылка);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция ЭлементПоКоду(КодКлассификатора) Экспорт
	
	Возврат НайтиПоКоду(КодКлассификатора);
	
КонецФункции

Процедура ДлительнаяОперацияЗагрузкиКлассификаторов(Параметры, АдресХранилища) Экспорт
	
	КлассификаторыДляЗагрузки = Параметры.КлассификаторыДляЗагрузки;
	Токен = Параметры.Токен;
	УИНОрганизации = Параметры.УИНОрганизации;
	
	HTTPСоединение = СоздатьСоединениеССервисомНСИФРМР();
	АктуализироватьОписаниеСправочниковФРМР(КлассификаторыДляЗагрузки, HTTPСоединение, Токен);
	ОбновитьСодержимоеСправочниковФРМР(КлассификаторыДляЗагрузки, HTTPСоединение, Токен, УИНОрганизации);
	
	КодыКлассификаторов = КлассификаторыДляЗагрузки.ВыгрузитьКолонку("КодКлассификатора");
	РегистрыСведений.ХарактеристикиОбъектовДляФедеральныхМедрегистров.УстановитьХарактеристикиОбъектовПоКодамКлассификаторов(КодыКлассификаторов);
	
	ПоместитьВоВременноеХранилище(Истина, АдресХранилища);
	
КонецПроцедуры

Процедура АктуализироватьОписаниеСправочниковФРМР(СправочникиФРМР, HTTPСоединение, Токен)
	
	Для Каждого СправочникФРМР из СправочникиФРМР Цикл
		СправочникФРМР.ОписаниеСправочника = ПолучитьПаспортСправочника(HTTPСоединение, Токен, СправочникФРМР.КодКлассификатора);
		СправочникФРМР.Ссылка = ОбновитьСправочникФРМР(СправочникФРМР.Ссылка, СправочникФРМР.ОписаниеСправочника);
	КонецЦикла;
	
КонецПроцедуры

Процедура ОбновитьСодержимоеСправочниковФРМР(СправочникиФРМР, HTTPСоединение, Токен,УИДОрганизации)
	
	Для Каждого СправочникФРМР из СправочникиФРМР Цикл
		СодержимоеСправочника = ПолучитьСодержимоеСправочника(HTTPСоединение, Токен, СправочникФРМР.Ссылка, УИДОрганизации);
		Если СодержимоеСправочника <> Неопределено Тогда
			СохранитьДанныеВСправочникЭлементыСправочниковФРМР(СодержимоеСправочника, СправочникФРМР.Ссылка);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Функция СоздатьСоединениеССервисомНСИФРМР()
	
	ПротоколЗащиты = Новый ЗащищенноеСоединениеOpenSSL;
	Таймаут = 60;
	Хост = "nsi.rosminzdrav.ru/port/rest";
	Соединение = Новый HTTPСоединение(Хост, , , , , Таймаут, ПротоколЗащиты);

	Возврат Соединение;
	
КонецФункции

Функция ВыполнитьЗапросHTTP(HTTPСоединение, АдресРесурса)

	Заголовки = Новый Соответствие();
	Заголовки.Вставить("Content-Type", "application/json");
	ЗапросHTTP = Новый HTTPЗапрос( АдресРесурса, Заголовки);

	ОтветHTTP = HTTPСоединение.ВызватьHTTPМетод("GET", ЗапросHTTP);
	СтруктураОтвета = Новый Структура("КодСостояния,ОтветСервера,ОтветСервераНеРасшифрованный,СообщениеОбОшибке");
	СтруктураОтвета.КодСостояния = ОтветHTTP.КодСостояния;
	
	Если ОтветHTTP.КодСостояния<400 Тогда 
		Попытка
			ОтветСервера = ОтветHTTP.ПолучитьТелоКакСтроку("UTF-8");
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(ОтветСервера);
			ДанныеJSON = ПрочитатьJSON(ЧтениеJSON, Истина);
			РезультатЗапроса = ДанныеJSON.Получить("result");
			Если РезультатЗапроса=Неопределено Тогда 
				СтруктураОтвета.СообщениеОбОшибке = НСтр("ru = 'Неверный формат ответа сервиса: '") + ОтветСервера;
			Иначе 
				Если РезультатЗапроса="ERROR" Тогда 
					СтруктураОтвета.СообщениеОбОшибке = НСтр("ru = 'Ошибка сервиса: '") + ОтветСервера;
				Иначе 
					СтруктураОтвета.ОтветСервера = ДанныеJSON;
					СтруктураОтвета.ОтветСервераНеРасшифрованный = ОтветСервера;
				КонецЕсли;
			КонецЕсли;
		Исключение
			СтруктураОтвета.СообщениеОбОшибке = ОписаниеОшибки();
		КонецПопытки;
	ИначеЕсли ОтветHTTP.КодСостояния=403 Тогда 
		СтруктураОтвета.СообщениеОбОшибке = НСтр("ru = 'Ошибка аутентификации (403 - Доступ запрещен).'");
	ИначеЕсли ОтветHTTP.КодСостояния=404 Тогда 
		СтруктураОтвета.СообщениеОбОшибке = НСтр("ru = 'Ошибка обращения к методу (404 - Страница не найдена).'");
	Иначе 
		Шаблон = НСтр("ru = 'Ошибка %1.'");
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Шаблон, ОтветHTTP.КодСостояния);
		СтруктураОтвета.СообщениеОбОшибке = ТекстСообщения;
	КонецЕсли;
	
	Возврат СтруктураОтвета;
	
КонецФункции

Функция ВыполнитьЗапросREST(HTTPСоединение, ИмяМетода, Токен = "", IDСправочника="", ДополнительныеПоля = Неопределено)
	ТекстЗапроса = ИмяМетода + ?(ЗначениеЗаполнено(Токен),"?userKey=" + Токен,"")+?(ЗначениеЗаполнено(IDСправочника),"&identifier=" + IDСправочника,"");;
	Если ДополнительныеПоля<>Неопределено Тогда
		Для Каждого ДополнительноеПоле ИЗ ДополнительныеПоля Цикл
			ТекстЗапроса = ТекстЗапроса+"&"+ДополнительноеПоле.Ключ+"="+ДополнительноеПоле.Значение;
		КонецЦикла;
	КонецЕсли;
	
	СтруктураОтвета = ВыполнитьЗапросHTTP(HTTPСоединение, ТекстЗапроса);

	Если СтруктураОтвета.СообщениеОбОшибке<>Неопределено Тогда
		ВызватьИсключение СтруктураОтвета.СообщениеОбОшибке;
	КонецЕсли;
	
	Возврат СтруктураОтвета.ОтветСервера;
	
КонецФункции

Функция ПолучитьПаспортСправочника(HTTPСоединение,Токен, IDСправочника)
	
	ОтветСервера = ВыполнитьЗапросREST(HTTPСоединение,"/passport", Токен, IDСправочника);
	
	Если ОтветСервера = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ОписаниеСправочника = ПустаяСтруктураКлассификатораФРМР();
	Для Каждого ЭлементОписания ИЗ ОписаниеСправочника Цикл
		ОписаниеСправочника[ЭлементОписания.Ключ] = ОтветСервера[ЭлементОписания.Ключ];
	КонецЦикла;
	ОписаниеСправочника.lastUpdate = СтроковыеФункцииКлиентСервер.СтрокаВДату(ОтветСервера["lastUpdate"]);
	ОписаниеСправочника.fieldId = ОтветСервера["keys"][0]["field"];
	
	ПоляСправочника = Новый Структура();
	Для Каждого ПоляСтруктурыСправочника из ОтветСервера["fields"] Цикл
		ПоляСправочника.Вставить(ПоляСтруктурыСправочника["field"], ПоляСтруктурыСправочника["alias"]);
	КонецЦикла;
	
	ОписаниеСправочника.Вставить("fields",ПоляСправочника);
	
	Возврат ОписаниеСправочника;
	
КонецФункции

Функция ПолучитьСодержимоеСправочника(HTTPСоединение,Токен,СправочникСсылка,УИДОрганизации = "")
	
//https://nsi.rosminzdrav.ru/port/rest/data?userKey=6c5cbdab-5ac3-47cc-9d04-91dd1d515ced&identifier=1.2.643.5.1.13.13.99.2.115&version=2.928&filters=mo_oid|1.2.643.5.1.13.13.12.2.37.3488

	ДополнительныеПоля = Новый Структура();
	ДополнительныеПоля.Вставить("version",СправочникСсылка.Версия);
	Если НЕ (СправочникСсылка.СтруктураСправочника.Найти("mo_oid","ИмяПоля") = НЕОПРЕДЕЛЕНО)
		И ЗначениеЗаполнено(УИДОрганизации) Тогда
		ДополнительныеПоля.Вставить("filters","mo_oid|"+УИДОрганизации);
	КонецЕсли;
	ДополнительныеПоля.Вставить("page", 1);
	ДополнительныеПоля.Вставить("size", 200);
	
	ПоляПредставлений = ВозможныеПоляПредставлений();
	ПоляРодитель = ВозможныеПоляРодитель();
	СодержимоеКлассификатора = ПустаяТаблицаСодержимогоКлассификатораФРМР();
	
	КоличествоСтраниц = Цел(СправочникСсылка.КоличествоЭлементов / 200);
	Если СправочникСсылка.КоличествоЭлементов % 200 > 0 Тогда 
		КоличествоСтраниц = КоличествоСтраниц + 1;
	КонецЕсли;
	
	Для Страница = 1 По КоличествоСтраниц Цикл 
	
	    ДополнительныеПоля.page = Страница;
		ОтветСервера = ВыполнитьЗапросREST(HTTPСоединение,"/data", Токен, СправочникСсылка.Код, ДополнительныеПоля);
		
		Если ОтветСервера = Неопределено Тогда
			Возврат Неопределено;
		КонецЕсли;
		
		Если ОтветСервера["total"]<=0 Тогда
			Прервать;
		КонецЕсли;
		
		
		ИмяПоляПредставления = Неопределено;
		ИмяПоляРодитель = Неопределено;
		
		Для Каждого СтрокаЭлемента Из ОтветСервера["list"] Цикл
			СтруктураЭлемента = Новый Структура();
			Для Каждого ОписаниеРеквизита Из СтрокаЭлемента Цикл
				СтруктураЭлемента.Вставить(ОписаниеРеквизита["column"], ОписаниеРеквизита["value"]);
				Если ИмяПоляПредставления = Неопределено Тогда
					Если ПоляПредставлений.Найти(ВРег(ОписаниеРеквизита["column"]))<> Неопределено Тогда
						ИмяПоляПредставления = ОписаниеРеквизита["column"];
					КонецЕсли;
				КонецЕсли;
				Если ИмяПоляРодитель = Неопределено Тогда
					Если ПоляРодитель.Найти(ВРег(ОписаниеРеквизита["column"]))<> Неопределено Тогда
						ИмяПоляРодитель = ОписаниеРеквизита["column"];
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
			
			СоставноеИмя = "";
			depart_name="";
			hospital_name="";
			ambulance_subdivision_name="";
			lab_subdivision_name="";
			Если СтруктураЭлемента.Свойство("depart_name",depart_name)
				И СтруктураЭлемента.Свойство("hospital_name",hospital_name)
				И СтруктураЭлемента.Свойство("ambulance_subdivision_name",ambulance_subdivision_name)
				И СтруктураЭлемента.Свойство("lab_subdivision_name",lab_subdivision_name) Тогда
				СоставноеИмя = depart_name;
				Если ЗначениеЗаполнено(hospital_name)
					И hospital_name <> depart_name Тогда
					СоставноеИмя = СоставноеИмя +" ("+hospital_name+")";
				ИначеЕсли ЗначениеЗаполнено(ambulance_subdivision_name)
					И ambulance_subdivision_name <> depart_name Тогда
					СоставноеИмя = СоставноеИмя +" ("+ambulance_subdivision_name+")";
				ИначеЕсли ЗначениеЗаполнено(lab_subdivision_name)
					И lab_subdivision_name <> depart_name Тогда
					СоставноеИмя = СоставноеИмя +" ("+lab_subdivision_name+")";
				КонецЕсли;
			Иначе
				СоставноеИмя = СтруктураЭлемента[ИмяПоляПредставления];
			КонецЕсли;
			
			ЭлементКлассификатора = СодержимоеКлассификатора.Добавить();
			ЭлементКлассификатора.ID = СтруктураЭлемента[СправочникСсылка.ПолеИдентификатор];
			ЭлементКлассификатора.NAME = СоставноеИмя;
			ЭлементКлассификатора.PARENT_ID = ?(ЗначениеЗаполнено(ИмяПоляРодитель),СтруктураЭлемента[ИмяПоляРодитель],"");
			ЭлементКлассификатора.ITEMS = СтруктураЭлемента;
		КонецЦикла;
	КонецЦикла;
	
	Возврат СодержимоеКлассификатора;
	
КонецФункции

Процедура СохранитьИерархическиеДанныеСправочникЭлементыСправочниковФРМР(КоллекцияДанных, Владелец, Родитель)
	
	Для Каждого СтрокаДанных Из КоллекцияДанных Цикл
		
		ПодчиненныеСтроки = СтрокаДанных.Строки;
		ЭтоГруппа = ПодчиненныеСтроки.Количество()>0;
		
		Ссылка = СохранитьЭлементСправочникЭлементыСправочниковФРМР(СтрокаДанных, Владелец, Родитель, ЭтоГруппа);
		
		Если ЭтоГруппа Тогда
			
			СохранитьИерархическиеДанныеСправочникЭлементыСправочниковФРМР(ПодчиненныеСтроки, Владелец, Ссылка);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Возвращает ссылку на элемент справочника.
//
Функция СохранитьЭлементСправочникЭлементыСправочниковФРМР(Данные, Владелец, Родитель, ЭтоГруппа)
	
	Если Данные.Наименование = Данные.НаименованиеЭлементаСправочника И ЗначениеЗаполнено(Данные.Ссылка) Тогда
		Возврат Данные.Ссылка;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Данные.Ссылка) Тогда
		
		ОбъектСправочника = Данные.Ссылка.ПолучитьОбъект();
		
	ИначеЕсли ЭтоГруппа Тогда
		
		ОбъектСправочника = Справочники.ЭлементыКлассификаторовФедеральныхМедрегистров.СоздатьГруппу();
		
	Иначе
		
		ОбъектСправочника = Справочники.ЭлементыКлассификаторовФедеральныхМедрегистров.СоздатьЭлемент();
		
	КонецЕсли;
	
	ОбъектСправочника.Код = Данные.Код;
	ОбъектСправочника.НаименованиеПолное = Данные.Наименование;
	ОбъектСправочника.Родитель = Родитель;
	ОбъектСправочника.Владелец = Владелец;
	
	Если Не ЭтоГруппа Тогда
		ОбъектСправочника.ОписаниеЭлемента.Очистить();	
		Для Каждого ОписаниеЭлементаФРМР ИЗ Данные.ОписаниеЭлемента Цикл
			ОписаниеЭлемента = ОбъектСправочника.ОписаниеЭлемента.Добавить();
			ОписаниеЭлемента.Поле = ОписаниеЭлементаФРМР.Ключ;
			ОписаниеЭлемента.Значение = ОписаниеЭлементаФРМР.Значение;
		КонецЦикла;
	КонецЕсли;	
		
	ОбъектСправочника.ОбменДанными.Загрузка = Истина;
	
	ОбъектСправочника.Записать();
	
	Возврат ОбъектСправочника.Ссылка;
	
КонецФункции

