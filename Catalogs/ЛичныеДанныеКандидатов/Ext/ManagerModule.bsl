// Возвращает структуру для описания личных данных кандидата
//
// Возвращаемое значение:
//  Структура - Новые данные кандидата:
//   * ФИО - Строка -
//   * Фамилия - Строка -
//   * Имя - Строка -
//   * Отчество - Строка -
//   * УточнениеНаименования - Строка -
//   * ДатаРождения - Дата -
//   * МестоРождения - Строка -
//   * Пол - ПеречислениеСсылка.ПолФизическогоЛица -
//   * СостояниеВБраке - СправочникСсылка.СостояниеВБраке -
//   * Гражданство - СправочникСсылка.СтраныМира -
//   * Фотография - СправочникСсылка.ЛичныеДанныеКандидатовПрисоединенныеФайлы -
//   * ГруппаДоступа - СправочникСсылка.ГруппыДоступаКандидатов -
//   * ЗнаниеЯзыков - Массив из Структура -
//   * Образование - Массив из Структура -
//   * Курсы - Массив из Структура -
//   * УченыеСтепени - Массив из Структура -
//   * ОпытРаботы - Массив из Структура -
Функция НовыеДанныеКандидата() Экспорт
	
	ДанныеКандидата = Новый Структура;
	
	ДанныеКандидата.Вставить("ФИО", "");
	ДанныеКандидата.Вставить("Фамилия", "");
	ДанныеКандидата.Вставить("Имя", "");
	ДанныеКандидата.Вставить("Отчество", "");
	ДанныеКандидата.Вставить("УточнениеНаименования", "");
	ДанныеКандидата.Вставить("ДатаРождения", Дата(1, 1, 1));
	ДанныеКандидата.Вставить("МестоРождения", "");
	ДанныеКандидата.Вставить("Пол", Перечисления.ПолФизическогоЛица.Мужской);
	ДанныеКандидата.Вставить("СостояниеВБраке", Справочники.СостояниеВБраке.ПустаяСсылка());
	ДанныеКандидата.Вставить("Гражданство", Справочники.СтраныМира.Россия);
	ДанныеКандидата.Вставить("Фотография", Справочники.ЛичныеДанныеКандидатовПрисоединенныеФайлы.ПустаяСсылка());
	ДанныеКандидата.Вставить("ГруппаДоступа", Справочники.ГруппыДоступаКандидатов.ПустаяСсылка());
	
	ДанныеКандидата.Вставить("ЗнаниеЯзыков", Новый Массив);
	ДанныеКандидата.Вставить("Образование", Новый Массив);
	ДанныеКандидата.Вставить("Курсы", Новый Массив);
	ДанныеКандидата.Вставить("УченыеСтепени", Новый Массив);
	ДанныеКандидата.Вставить("ОпытРаботы", Новый Массив);
	
	Возврат ДанныеКандидата;
	
КонецФункции

