// СтандартныеПодсистемы.УправлениеДоступом

// Параметры:
//   Ограничение - см. УправлениеДоступомПереопределяемый.ПриЗаполненииОграниченияДоступа.Ограничение.
Процедура ПриЗаполненииОграниченияДоступа(Ограничение) Экспорт
	
	Ограничение.Текст =
	"РазрешитьЧтениеИзменение
	|ГДЕ
	|	ЗначениеРазрешено(Ссылка)";
	
КонецПроцедуры

// Конец СтандартныеПодсистемы.УправлениеДоступом

// Заполнить данные для электронного тестирования кандидата.
// 
// Параметры:
//  ДанныеДляЗаполнения - Структура: см. ЭлектронноеТестированиеКандидатов.НовыйДанныеДляФормыЭлектронногоТестированияКандидата
//  Учащийся - СправочникСсылка.ЛичныеДанныеКандидатов
Процедура ЗаполнитьДанныеДляЭлектронногоТестированияКандидата(ДанныеДляЗаполнения, Учащийся) Экспорт
	
	ТаблицаКандидатов = Справочники.Кандидаты.КандидатыПоЛичнымДаннымКандидатов(
		ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Учащийся));

	Если ТаблицаКандидатов.Количество() > 0 Тогда
		ДанныеДляЗаполнения.ИмяОтчество = СтрШаблон("%1 %2", ТаблицаКандидатов[0].Имя, ТаблицаКандидатов[0].Отчество);
		ДанныеДляЗаполнения.Кандидат = ТаблицаКандидатов[0].Кандидат;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

// Ищет похожих кандидатов и возвращает результат поиска.
// 
// Параметры:
//  ЛичныеДанныеКандидата - СправочникСсылка.ЛичныеДанныеКандидатов -
// 
// Возвращаемое значение:
//  Структура:
//   * Фамилия - Строка
//   * Имя - Строка
//   * Отчество - Строка
//   * Телефон - Строка
//   * EMail - Строка
//   * ДанныеКандидатов - Массив из Структура:
//      ** ЛичныеДанныеКандидата - СправочникСсылка.ЛичныеДанныеКандидатов 
//      ** Наименование - Строка 
//      ** УточнениеНаименования - Строка 
//      ** ФизическоеЛицо - СправочникСсылка.ФизическиеЛица 
//      ** НомерТелефона - Строка 
//      ** Email - Строка 
//      ** Приоритет - Число 
//   * КандидатУникален - Булево
Функция НайтиПохожих(ЛичныеДанныеКандидата) Экспорт
	
	ПараметрыПоиска = ПодборПерсоналаФормы.ПараметрыПоискаПохожихКандидатов();
	СведенияОЛичныхДанных = ПодборПерсонала.ОсновныеСведенияОЛичныхДанныхКандидатов(
		ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ЛичныеДанныеКандидата));
	ЗаполнитьЗначенияСвойств(ПараметрыПоиска, СведенияОЛичныхДанных[0],
		"Фамилия,Имя,Отчество,УточнениеНаименования,Телефон,EMail");
	ПараметрыПоиска.Ссылка = ЛичныеДанныеКандидата;
	
	ПоискКандидатов = ПодборПерсоналаВызовСервера.ПодобратьПохожихКандидатов(ПараметрыПоиска);
	
	Возврат ПоискКандидатов;
	
КонецФункции

