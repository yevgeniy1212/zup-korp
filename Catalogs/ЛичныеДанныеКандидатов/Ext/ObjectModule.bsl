//@skip-check invocation-parameter-type-intersect
Процедура ЗапомнитьРеквизитыПрежнегоСостоянияОбъекта()
	
	Если ЭтоНовый() Тогда
		Возврат;
	КонецЕсли;
	
	ИменаРеквизитов = ОбщегоНазначения.ВыгрузитьКолонку(Метаданные.Справочники.ЛичныеДанныеКандидатов.Реквизиты, "Имя");
	ПрежниеЗначения = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Ссылка, СтрСоединить(ИменаРеквизитов, ",")); 
	ПрежниеЗначения.Вставить("ТаблицаКИ", Новый ФиксированныйМассив(Новый Массив));
	ПрежниеЗначения.Вставить("МобильныйТелефон", "");
	ПрежниеЗначения.Вставить("ЭлектроннаяПочта", "");
	
	ТаблицаКИ = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(Ссылка,,,Ложь);
	
	Если ТаблицаКИ.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ПрежниеЗначения.ТаблицаКИ = ОбщегоНазначения.ФиксированныеДанные(ОбщегоНазначения.ТаблицаЗначенийВМассив(ТаблицаКИ));
	
	НайденнаяСтрокаТелефон = ТаблицаКИ.Найти(ОбщегоНазначения.ПредопределенныйЭлемент(
		"Справочник.ВидыКонтактнойИнформации.ТелефонЛичныеДанныеКандидатов"), "Вид");
	Если НайденнаяСтрокаТелефон <> Неопределено Тогда
		ПрежниеЗначения.МобильныйТелефон = НайденнаяСтрокаТелефон.Представление;
	КонецЕсли;
	
	НайденнаяСтрокаЭлектроннаяПочта = ТаблицаКИ.Найти(ОбщегоНазначения.ПредопределенныйЭлемент(
		"Справочник.ВидыКонтактнойИнформации.EMailЛичныеДанныеКандидатов"), "Вид");
	Если НайденнаяСтрокаЭлектроннаяПочта <> Неопределено Тогда
		ПрежниеЗначения.ЭлектроннаяПочта = НайденнаяСтрокаЭлектроннаяПочта.Представление;
	КонецЕсли;
	
	ДополнительныеСвойства.Вставить("ПрежниеЗначения", ПрежниеЗначения);
	
КонецПроцедуры

