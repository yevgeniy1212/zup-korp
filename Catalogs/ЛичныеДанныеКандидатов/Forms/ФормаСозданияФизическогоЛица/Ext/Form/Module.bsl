// @strict-types


#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Данные = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Параметры.ЛичныеДанныеКандидата, "ФИО, Пол");
	ШаблонСтроки = СтрЗаменить(
		НСтр("ru = 'Для продолжения будет создано физическое лицо для кандидата
		| <a href=""%1"">%2</a>. Физическое лицо заполнится автоматически и будет записано.'"),
	Символы.ПС, "");

	ФИОВРодительномПадеже = Данные.ФИО;
	ФизическиеЛицаЗарплатаКадры.Просклонять(Данные.ФИО, 2, ФИОВРодительномПадеже, Данные.Пол);
	//@skip-check invocation-parameter-type-intersect
	Элементы.ТекстСообщения.Заголовок = СтроковыеФункции.ФорматированнаяСтрока(ШаблонСтроки,
		ПолучитьНавигационнуюСсылку(Параметры.ЛичныеДанныеКандидата), ФИОВРодительномПадеже);
	
	УстановитьВидимостьЭлементов();
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	Если ПолучитьФункциональнуюОпцию("ОграничиватьДоступНаУровнеЗаписей")
		И ПолучитьФункциональнуюОпцию("ОграничиватьДоступНаУровнеЗаписейФизическиеЛица") Тогда
		
		Если Не ЗначениеЗаполнено(ГруппаДоступа) Тогда
			ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не заполнена группа доступа'"), , "ГруппаДоступа", ,
				Отказ);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПродолжитьВыполнение(Команда)
	
	Если Не ПроверитьЗаполнение() Тогда
		Возврат;
	КонецЕсли;
	
	ФизическоеЛицо = СоздатьФизическоеЛицо(Параметры.ЛичныеДанныеКандидата, ГруппаДоступа);
	Закрыть(ФизическоеЛицо);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура УстановитьВидимостьЭлементов()
	
	ОграничиватьДоступНаУровнеЗаписей = ПолучитьФункциональнуюОпцию("ОграничиватьДоступНаУровнеЗаписей")
		И ПолучитьФункциональнуюОпцию("ОграничиватьДоступНаУровнеЗаписейФизическиеЛица");
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаГруппаДоступа", "Видимость",
		ОграничиватьДоступНаУровнеЗаписей);
		
	КлючСохраненияПоложенияОкна = ?(ОграничиватьДоступНаУровнеЗаписей, "ОграничиватьДоступНаУровнеЗаписей",
		"НеОграничиватьДоступНаУровнеЗаписей");
	
КонецПроцедуры

// Параметры:
//  ЛичныеДанныеКандидата - СправочникСсылка.ЛичныеДанныеКандидатов
//  ГруппаДоступа - СправочникСсылка.ГруппыДоступаФизическихЛиц
// 
// Возвращаемое значение:
//  СправочникСсылка.ФизическиеЛица
&НаСервереБезКонтекста
Функция СоздатьФизическоеЛицо(ЛичныеДанныеКандидата, ГруппаДоступа)
	
	ДополнительныеПараметры = Новый Структура;
	Если ЗначениеЗаполнено(ГруппаДоступа) Тогда
		ДополнительныеПараметры.Вставить("ГруппаДоступа", ГруппаДоступа);
	КонецЕсли;
	
	Возврат Справочники.ЛичныеДанныеКандидатов.СоздатьФизическоеЛицоПоДаннымКандидата(ЛичныеДанныеКандидата,
		ДополнительныеПараметры);
		
КонецФункции

#КонецОбласти
