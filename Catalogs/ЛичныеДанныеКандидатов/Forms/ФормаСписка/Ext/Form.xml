			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ РАЗРЕШЕННЫЕ
	НЕ ВнешниеПользователи.Ссылка ЕСТЬ NULL Как ВнешнийДоступ,
	ЛичныеДанныеКандидатов.Ссылка,
	ЛичныеДанныеКандидатов.ДатаРождения,
	ЛичныеДанныеКандидатов.ФИО,
	ВЫРАЗИТЬ(NULL КАК ЧИСЛО(1, 0)) КАК ОтсутствуетСогласие,
	ВЫБОР
		КОГДА СубъектыСоКрытымиПДн.Субъект ЕСТЬ NULL
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК ПДнСкрыты,
	ДанныеПоискаФизическихЛиц.АдресаЭлектроннойПочты КАК АдресаЭлектроннойПочты,
	ДанныеПоискаФизическихЛиц.Телефоны КАК Телефоны
ИЗ
	Справочник.ЛичныеДанныеКандидатов КАК ЛичныеДанныеКандидатов
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СубъектыДляСкрытияПерсональныхДанных КАК СубъектыСоКрытымиПДн
		ПО ЛичныеДанныеКандидатов.Ссылка = СубъектыСоКрытымиПДн.Субъект
		И (СубъектыСоКрытымиПДн.Состояние = ЗНАЧЕНИЕ(Перечисление.СостоянияСубъектовДляСкрытия.СкрытиеВыполнено))
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ФизическиеЛицаКандидатов КАК ФизическиеЛицаКандидатов
		ПО ЛичныеДанныеКандидатов.Ссылка = ФизическиеЛицаКандидатов.ЛичныеДанныеКандидата
		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВнешниеПользователи КАК ВнешниеПользователи
		ПО ЛичныеДанныеКандидатов.Ссылка = ВнешниеПользователи.ОбъектАвторизации
		И НЕ ВнешниеПользователи.Недействителен
		И НЕ ВнешниеПользователи.ПометкаУдаления
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеПоискаФизическихЛиц КАК ДанныеПоискаФизическихЛиц
		ПО ЛичныеДанныеКандидатов.Ссылка = ДанныеПоискаФизическихЛиц.ФизическоеЛицо
ГДЕ
	(СубъектыСоКрытымиПДн.Субъект ЕСТЬ NULL
	ИЛИ &amp;ПоказыватьСоСкрытымиПДн)</QueryText>
				<MainTable>Catalog.ЛичныеДанныеКандидатов</MainTable>
				<AutoSaveUserSettings>false</AutoSaveUserSettings>
				<ListSettings>
					<dcsset:filter>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>dfcece9d-5077-440b-b6b3-45a5cb4538eb</dcsset:userSettingID>
					</dcsset:filter>
					<dcsset:order>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>88619765-ccb3-46c6-ac52-38e9c992ebd4</dcsset:userSettingID>
					</dcsset:order>
					<dcsset:conditionalAppearance>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>b75fecce-942b-4aed-abc9-e6a02e460fb3</dcsset:userSettingID>
					</dcsset:conditionalAppearance>
					<dcsset:itemsViewMode>Normal</dcsset:itemsViewMode>
					<dcsset:itemsUserSettingID>911b6018-f537-43e8-a417-da56b22f9aec</dcsset:itemsUserSettingID>
				</ListSettings>
			</Settings>
		</Attribute>
