&НаСервере
Процедура ФИОПриИзмененииНаСервере()
	
	СтруктураФИО = ФизическиеЛицаКлиентСервер.ЧастиИмени(ЛичныеДанныеКандидата.ФИО);
	ЗаполнитьЗначенияСвойств(ЛичныеДанныеКандидата, СтруктураФИО, "Фамилия,Имя,Отчество");
	
	ЛичныеДанныеКандидатаОбъект = РеквизитФормыВЗначение("ЛичныеДанныеКандидата");
	
	ЛичныеДанныеКандидатаОбъект.ЗаполнитьНаименованиеПоФИО();
	Если Не ЗначениеЗаполнено(ЛичныеДанныеКандидатаОбъект.Пол) Тогда
		ЛичныеДанныеКандидатаОбъект.УстановитьПолПоОтчеству();
	КонецЕсли;
	
	ЗначениеВРеквизитФормы(ЛичныеДанныеКандидатаОбъект, "ЛичныеДанныеКандидата");
	
КонецПроцедуры

