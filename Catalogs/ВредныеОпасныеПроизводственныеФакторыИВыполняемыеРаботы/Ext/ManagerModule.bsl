Функция НайденныйВредныйФактор(ЭтоСтрокаПеречня29Н, ЗначениеПоиска, ВредныеФакторы, ДлинаНаименования = 100)
	
	Описание = ОписаниеФактора();
	
	Если ЭтоСтрокаПеречня29Н Тогда
		Описание.Удалить("Наименование");
		Описание.Код = ЗначениеПоиска;
		Описание.ВидОсмотра = Перечисления.ВидыОбследований.МедицинскийОсмотр;
	Иначе
		Описание.Удалить("Код");
		Описание.Наименование = Лев(ЗначениеПоиска, ДлинаНаименования);
		Описание.ВидОсмотра = Перечисления.ВидыОбследований.ПсихиатрическоеОсвидетельствование;
	КонецЕсли;
	
	НайденныеСтроки = ВредныеФакторы.НайтиСтроки(Описание);
	Если НайденныеСтроки.Количество() > 0 Тогда
		Возврат НайденныеСтроки[0].Ссылка;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

Функция ОписаниеФактора()
	
	Возврат Новый Структура("Код,Наименование,ВидОсмотра");
	
КонецФункции

Функция ВыполнитьЗаписьОбъекта(ДанныеОбъекта) Экспорт
	
	СправочникОбъект = ЗарплатаКадры.ДесериализоватьОбъектИзДвоичныхДанных(ДанныеОбъекта);
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить(СправочникОбъект.Ссылка.Метаданные().ПолноеИмя());
	ЭлементБлокировки.УстановитьЗначение("Ссылка", СправочникОбъект.Ссылка);
	
	НачатьТранзакцию();
	Попытка
		Блокировка.Заблокировать();
		СправочникОбъект.Записать();
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Ошибка записи классификатора вредных (опасных) производственных факторов и видов работ'", 
				ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка, , ,
			ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
	Возврат ЗарплатаКадры.СериализоватьОбъектВДвоичныеДанные(СправочникОбъект);
	
КонецФункции

