#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	НастроитьВидСписка();
	УстановитьОтборПоВидуОсмотра(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ВидОсмотраПриИзменении(Элемент)
	
	УстановитьОтборПоВидуОсмотра(ЭтотОбъект);
	
	ПодключитьОбработчикОжидания("ПриИзмененииСохраняемойНастройки", 0.2, Истина);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура НастроитьВидСписка()
	
	Если Параметры.РежимВыбора Тогда
		НастроитьВидСпискаВРежимеВыбора();
		Возврат;
	КонецЕсли;
	
	Если ПолучитьФункциональнуюОпцию("ИспользоватьПсихиатрическиеОсвидетельствования") Тогда
		ВидОсмотра = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить(
			"ВредныеОпасныеПроизводственныеФакторыИВыполняемыеРаботыСписок",
			"ВидОсмотра",
			Перечисления.ВидыОбследований.МедицинскийОсмотр);
	Иначе
		ВидОсмотра = Перечисления.ВидыОбследований.МедицинскийОсмотр;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура НастроитьВидСпискаВРежимеВыбора()
	
	Элементы.Список.РежимВыбора = Истина;
	
	Если Параметры.Отбор.Свойство("ВидОсмотра") Тогда
		ВидОсмотра = Параметры.Отбор.ВидОсмотра;
		ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ВидОсмотра", "Видимость", Ложь);
	Иначе
		ВидОсмотра = Перечисления.ВидыОбследований.МедицинскийОсмотр;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьОтборПоВидуОсмотра(Форма)
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Форма.Список, "ВидОсмотра", Форма.ВидОсмотра);
	
	Форма.Список.УсловноеОформление.Элементы.Очистить();
	ЭлементУсловногоОформления = Форма.Список.УсловноеОформление.Элементы.Добавить();
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
	
	ЭлементОтбора = ЭлементУсловногоОформления.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.НеРавно;
	ЭлементОтбора.Использование = Истина;
	ЭлементОтбора.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("ВидОсмотра");
	ЭлементОтбора.ПравоеЗначение = Форма.ВидОсмотра;
	
	Если Не Форма.Параметры.РежимВыбора Тогда
		Возврат;
	КонецЕсли;
	
	ЭлементУсловногоОформления = Форма.Список.УсловноеОформление.Элементы.Добавить();
	ЭлементУсловногоОформления.Оформление.УстановитьЗначениеПараметра("Видимость", Ложь);
	
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(ЭлементУсловногоОформления.Отбор, "ВАрхиве", Истина);
	
	#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда
		МодульОбщегоНазначения = ОбщегоНазначения;
	#Иначе
		МодульОбщегоНазначения = ОбщегоНазначенияКлиент;
	#КонецЕсли
	
	Если Форма.ВидОсмотра = МодульОбщегоНазначения.ПредопределенныйЭлемент(
		"Перечисление.ВидыОбследований.ПсихиатрическоеОсвидетельствование") Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбораДинамическогоСписка(Форма.Список, "Однократно", Истина);
	Иначе
		ОбщегоНазначенияКлиентСервер.УдалитьЭлементыГруппыОтбораДинамическогоСписка(Форма.Список, "Однократно");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииСохраняемойНастройки()
	
	Настройки = СохраняемыеНастройки();
	Настройки.ВидОсмотра = ВидОсмотра;
	СохранитьНастройкиНаСервере(Настройки);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция СохраняемыеНастройки()
	
	Настройки = Новый Структура("ВидОсмотра");
	Возврат Настройки;
	
КонецФункции

&НаСервереБезКонтекста
Процедура СохранитьНастройкиНаСервере(Настройки)
	
	Для Каждого КлючИЗначение Из Настройки Цикл
		ОбщегоНазначения.ХранилищеОбщихНастроекСохранить(
			"ВредныеОпасныеПроизводственныеФакторыИВыполняемыеРаботыСписок",
			КлючИЗначение.Ключ,
			КлючИЗначение.Значение);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти