	ОписаниеЭлемента.УчитыватьОПВ = Истина;
	ОписаниеЭлемента.УчитыватьОППВ = Истина;
	ОписаниеЭлемента.УчитыватьСО = Истина;
	ОписаниеЭлемента.УчитыватьВОСМС = Истина;
	ОписаниеЭлемента.УчитыватьООСМС = Истина;
	ОписаниеЭлемента.УчитыватьОПВР = Истина;
	ОписаниеЭлемента.УчитыватьЕП = Истина;
