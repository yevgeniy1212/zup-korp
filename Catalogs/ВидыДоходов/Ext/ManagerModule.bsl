   	ОписаниеЭлемента = ОписаниеЭлементаВидаДохода();
	ОписаниеЭлемента.ИмяПредопределенныхДанных = "ДоходыОтНалоговогоАгента";
	ОписаниеЭлемента.Описание = НСтр("ru = 'Доход, облагаемый у источника выплаты (доход по заключенным с налоговым агентом договорам ГПХ, оплата стоимости товаров, выполненных работ, оказанных услуг и др.)'"); 
	ОписаниеЭлемента.УчитыватьИПН = Истина;
	ОписаниеЭлемента.УчитыватьОПВ = Истина;
	ОписаниеЭлемента.УчитыватьВОСМС = Истина;
	ОписаниеЭлемента.УчитыватьСО = Истина;
	СоздатьЭлементВидДохода(ОписаниеЭлемента);
	
   	ОписаниеЭлемента = ОписаниеЭлементаВидаДохода();
	ОписаниеЭлемента.ИмяПредопределенныхДанных = "Дивиденды";
	ОписаниеЭлемента.Описание = НСтр("ru = 'Доходы, подлежащие выплате по акциям, части выплаты чистого дохода, распределяемые юридическим лицом между его учредителями'"); 
	ОписаниеЭлемента.УчитыватьИПН = Истина;
	СоздатьЭлементВидДохода(ОписаниеЭлемента);
	
	ОписаниеЭлемента = ОписаниеЭлементаВидаДохода();
	ОписаниеЭлемента.ИмяПредопределенныхДанных = "Выигрыши";
	ОписаниеЭлемента.Описание = НСтр("ru = 'Доходы в натуральном и денежном выражении, получаемые на конкурсах, соревнованиях (олимпиадах), фестивалях, по лотереям, розыгрышам'"); 
	ОписаниеЭлемента.УчитыватьИПН = Истина;
	СоздатьЭлементВидДохода(ОписаниеЭлемента);

	ОписаниеЭлемента = ОписаниеЭлементаВидаДохода();
	ОписаниеЭлемента.ИмяПредопределенныхДанных = "Вознаграждения";
	ОписаниеЭлемента.Описание = НСтр("ru = 'Доходы, полученные в связи с кредитом (займом, микрокредитом, долговыми ценными бумагами)'"); 
	ОписаниеЭлемента.УчитыватьИПН = Истина;
	СоздатьЭлементВидДохода(ОписаниеЭлемента);

	ОписаниеЭлемента = ОписаниеЭлементаВидаДохода();
	ОписаниеЭлемента.ИмяПредопределенныхДанных = "ПрочиеДоходы";
	ОписаниеЭлемента.Описание = НСтр("ru = 'Прочие доходы, облагаемые у источника выплаты'"); 
	ОписаниеЭлемента.УчитыватьИПН = Истина;
	СоздатьЭлементВидДохода(ОписаниеЭлемента);

	ОписаниеЭлемента = ОписаниеЭлементаВидаДохода();
	ОписаниеЭлемента.ИмяПредопределенныхДанных = "ДоходСубъектаПредпринимательства";
	ОписаниеЭлемента.Описание = НСтр("ru = 'Доход субъекта предпринимательства'"); 
	ОписаниеЭлемента.УчитыватьОПВ = Истина;
	ОписаниеЭлемента.УчитыватьВОСМС = Истина;
	ОписаниеЭлемента.УчитыватьИПН = Истина;
	ОписаниеЭлемента.УчитыватьСО = Истина;
	ОписаниеЭлемента.УчитыватьСН = Истина;
	ОписаниеЭлемента.УчитыватьОПВР = Истина;
	СоздатьЭлементВидДохода(ОписаниеЭлемента);

КонецПроцедуры

Функция ОписаниеЭлементаВидаДохода()
	Возврат Новый Структура("ИмяПредопределенныхДанных, Описание, УчитыватьИПН, УчитыватьСН, УчитыватьОПВ, УчитыватьОППВ, УчитыватьСО, УчитыватьООСМС, УчитыватьВОСМС, УчитыватьЕП, УчитыватьОПВР");	
КонецФункции	

Процедура СоздатьЭлементВидДохода(ОписаниеЭлемента)
	
	Если ЗначениеЗаполнено(ОписаниеЭлемента.ИмяПредопределенныхДанных) Тогда
		
		СсылкаПредопределенного = ОбщегоНазначенияКлиентСервер.ПредопределенныйЭлемент("Справочник.ВидыДоходов." + ОписаниеЭлемента.ИмяПредопределенныхДанных);
		Если ЗначениеЗаполнено(СсылкаПредопределенного) Тогда
			Элемент = СсылкаПредопределенного.ПолучитьОбъект();
		Иначе
			Элемент = Справочники.ВидыДоходов.СоздатьЭлемент();
			Элемент.ИмяПредопределенныхДанных = ОписаниеЭлемента.ИмяПредопределенныхДанных;
		КонецЕсли;
	
	КонецЕсли; 
	
	ЗаполнитьЗначенияСвойств(Элемент, ОписаниеЭлемента);
	Элемент.Записать();
	
КонецПроцедуры	

