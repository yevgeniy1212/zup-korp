Функция ТаблицаИнформационныхСтрокЗанятости()
	
	Таблица = Новый ТаблицаЗначений;
	Таблица.Колонки.Добавить("Сценарий", Новый ОписаниеТипов("СправочникСсылка.Сценарии"));
	Таблица.Колонки.Добавить("КоличествоСтавок", Новый ОписаниеТипов("Число"));
	Таблица.Колонки.Добавить("ЗанятоСтавок", Новый ОписаниеТипов("Число"));
	Таблица.Колонки.Добавить("ЗанятоСотрудниками", Новый ОписаниеТипов("Массив"));
	Таблица.Колонки.Добавить("ИнформационнаяСтрокаЗанятости", Новый ОписаниеТипов("ФорматированнаяСтрока"));
	
	Возврат Таблица;
	
КонецФункции

Процедура ЗаполнитьИнформационныеСтрокиЗанятости(ТаблицаИнформационныхСтрок, ДанныеПозиции)
	
	Запрос = Новый Запрос;
	ТекущаяДата = ОбщегоНазначения.ТекущаяДатаПользователя();
	Запрос.УстановитьПараметр("ДатаНачала", НачалоМесяца(ТекущаяДата));
	Запрос.УстановитьПараметр("ДатаОкончания", КонецМесяца(ТекущаяДата));
	Запрос.УстановитьПараметр("Позиция", ДанныеПозиции.Позиция);
	Запрос.УстановитьПараметр("Показатель", КадровоеПланирование.ПоказательКоличествоСтавок());
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПоказателиКадровогоПланаОбороты.Сценарий КАК Сценарий,
		|	ПоказателиКадровогоПланаОбороты.Сотрудник КАК Сотрудник,
		|	СУММА(ПоказателиКадровогоПланаОбороты.Значение) КАК КоличествоСтавок,
		|	СУММА(ВЫБОР
		|			КОГДА ПоказателиКадровогоПланаОбороты.Сотрудник = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
		|				ТОГДА 0
		|			ИНАЧЕ ПоказателиКадровогоПланаОбороты.Значение
		|		КОНЕЦ) КАК ЗанятоСтавок
		|ИЗ
		|	РегистрНакопления.ПоказателиКадровогоПлана КАК ПоказателиКадровогоПланаОбороты
		|ГДЕ
		|	ПоказателиКадровогоПланаОбороты.Период МЕЖДУ &ДатаНачала И &ДатаОкончания
		|	И ПоказателиКадровогоПланаОбороты.Позиция = &Позиция
		|	И ПоказателиКадровогоПланаОбороты.Показатель = &Показатель
		|
		|СГРУППИРОВАТЬ ПО
		|	ПоказателиКадровогоПланаОбороты.Сценарий,
		|	ПоказателиКадровогоПланаОбороты.Сотрудник
		|
		|УПОРЯДОЧИТЬ ПО
		|	Сценарий
		|ИТОГИ ПО
		|	Сценарий";
	ВыборкаСценарий = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаСценарий.Следующий() Цикл
		Выборка = ВыборкаСценарий.Выбрать();
		НоваяСтрока = ТаблицаИнформационныхСтрок.Добавить();
		НоваяСтрока.Сценарий = ВыборкаСценарий.Сценарий;
		Пока Выборка.Следующий() Цикл
			НоваяСтрока.КоличествоСтавок = НоваяСтрока.КоличествоСтавок + Выборка.КоличествоСтавок;
			НоваяСтрока.ЗанятоСтавок = НоваяСтрока.ЗанятоСтавок + Выборка.ЗанятоСтавок;
			Если Выборка.ЗанятоСтавок > 0 Тогда
				НоваяСтрока.ЗанятоСотрудниками.Добавить(Выборка.Сотрудник);
			КонецЕсли;
		КонецЦикла;
		КадровоеПланирование.ЗаполнитьИнформационнуюСтрокуЗанятости(НоваяСтрока);
	КонецЦикла;
	
КонецПроцедуры

Функция ИнформационнаяСтрокаЗанятости(ДанныеПозиции) Экспорт
	
	ТаблицаИнформационныхСтрок = ТаблицаИнформационныхСтрокЗанятости();
	ЗаполнитьИнформационныеСтрокиЗанятости(ТаблицаИнформационныхСтрок, ДанныеПозиции);
	
	Если ТаблицаИнформационныхСтрок.Количество() = 0 Тогда
		ТаблицаИнформационныхСтрок.Добавить();
	КонецЕсли;
	
	ЧастиНадписи = Новый Массив;
	Для Каждого Строка Из ТаблицаИнформационныхСтрок Цикл
		Если ЧастиНадписи.Количество() > 0 Тогда
			ЧастиНадписи.Добавить(Символы.ПС);
		КонецЕсли;
		ЧастиНадписи.Добавить(Строка.ИнформационнаяСтрокаЗанятости);
	КонецЦикла;
	
	Возврат Новый Структура("ИнформационнаяСтрокаЗанятости", Новый ФорматированнаяСтрока(ЧастиНадписи));
	
КонецФункции

#КонецОбласти

#КонецЕсли