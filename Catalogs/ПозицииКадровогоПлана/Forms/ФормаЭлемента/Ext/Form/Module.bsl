// Конец СтандартныеПодсистемы.Свойства

&НаКлиенте
Процедура ЗаписатьИЗакрытьНаКлиенте(Результат, ДополнительныеПараметры) Экспорт 
	
	ЗаписатьНаКлиенте(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьНаКлиенте(ЗакрытьПослеЗаписи, ОповещениеЗавершения = Неопределено) 
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ЗакрытьПослеЗаписи", ЗакрытьПослеЗаписи);
	ДополнительныеПараметры.Вставить("ОповещениеЗавершения", ОповещениеЗавершения);
	
	Если ОбщегоНазначенияКлиент.ПодсистемаСуществует("ЗарплатаКадрыКорпоративнаяПодсистемы.ФинансовыйУчет") Тогда
		МодульФинансовыйУчетКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("ФинансовыйУчетКлиент");
		МодульФинансовыйУчетКлиент.ЗапроситьРежимИзмененияФинансовогоУчета(ЭтотОбъект, ДополнительныеПараметры);
	Иначе 
		ЗаписатьНаКлиентеЗавершение(Ложь, ДополнительныеПараметры);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьНаКлиентеЗавершение(Отказ, ДополнительныеПараметры) Экспорт 

	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыЗаписи = Новый Структура("ПроверкаПередЗаписьюВыполнена", Истина);
	
	Если ДополнительныеПараметры.ОповещениеЗавершения <> Неопределено Тогда 
		ВыполнитьОбработкуОповещения(ДополнительныеПараметры.ОповещениеЗавершения, ПараметрыЗаписи);
	ИначеЕсли Записать(ПараметрыЗаписи) И ДополнительныеПараметры.ЗакрытьПослеЗаписи Тогда 
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриПолученииДанныхНаСервере(ТекущийОбъект = Неопределено)
	
	Если ТекущийОбъект = Неопределено Тогда
		ТекущийОбъект = Объект;
	КонецЕсли;
	
	КадровоеПланированиеФормы.ПрочитатьПозиции(
		ЭтотОбъект, ТекущийОбъект, "ПозицииШтатногоРасписанияПоКадровомуПлану", "ПозицияКадровогоПлана");
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ПрофильДолжности",
		"Видимость",
		ПравоДоступа("Чтение", Метаданные.Справочники.ПрофилиДолжностей));
	
	ДоступностьИзменения = ПравоДоступа("Изменение", Метаданные.РегистрыСведений.ПозицииШтатногоРасписанияПоКадровомуПлану);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ПозицииШтатногоРасписанияПоКадровомуПлану",
		"Доступность",
		ДоступностьИзменения);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ПозицииШтатногоРасписанияПоКадровомуПлануПодбор",
		"Доступность",
		ДоступностьИзменения);
	
	ТолькоПросмотрПозиции = Не ПравоДоступа("Добавление", Метаданные.Справочники.ПозицииКадровогоПлана);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"Шапка",
		"ТолькоПросмотр",
		ТолькоПросмотрПозиции);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(
		Элементы,
		"ПоказателиКадровогоПланирования",
		"ТолькоПросмотр",
		ТолькоПросмотрПозиции);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗаполненииНаименования()
	
	НаименованиеПозиции = Строка(Объект.Должность);
	НаименованиеПозиции = ?(ЗначениеЗаполнено(НаименованиеПозиции), НаименованиеПозиции, Строка(Объект.ПрофильДолжности));
	Объект.Наименование = НаименованиеПозиции + ?(ЗначениеЗаполнено(Объект.Подразделение), " /" + Строка(Объект.Подразделение) + "/", "");
	
КонецПроцедуры

&НаСервере
Процедура УдалитьДублиПозицийШтатногоРасписания()
	КадровоеПланированиеФормы.УдалитьДублиПозиций(ПозицииШтатногоРасписанияПоКадровомуПлану, "ПозицияШтатногоРасписания");
КонецПроцедуры

&НаСервере
Функция АдресСпискаПодобранных()
	
	Возврат ПоместитьВоВременноеХранилище(
		ПозицииШтатногоРасписанияПоКадровомуПлану.Выгрузить().ВыгрузитьКолонку("ПозицияШтатногоРасписания"), УникальныйИдентификатор);
	
КонецФункции

&НаСервере
Функция СтруктураОтбора()
	
	СтруктураОтбор = Новый Структура;
	
	Если Не ЗначениеЗаполнено(Объект.Подразделение) Тогда
		Возврат СтруктураОтбор;
	КонецЕсли;
	
	ИсточникПодразделения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.Подразделение, "Источник");
	
	Если ТипЗнч(ИсточникПодразделения) = Тип("СправочникСсылка.Организации") Тогда
		СтруктураОтбор.Вставить("Владелец", ИсточникПодразделения);
	ИначеЕсли ТипЗнч(ИсточникПодразделения) = Тип("СправочникСсылка.ПодразделенияОрганизаций") Тогда
		СтруктураОтбор.Вставить("Подразделение", ИсточникПодразделения);
	КонецЕсли;
	
	Возврат СтруктураОтбор;
	
КонецФункции

&НаКлиенте
Процедура НачатьЗаполнениеИнформацииЗанятости()
	
	Элементы.ИнформацияЗанятости.Заголовок = Неопределено;
	Элементы.ИнформацияЗанятостиЗаполняется.Видимость = Истина;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ЗавершитьЗаполнениеИнформацииЗанятости", ЭтотОбъект);
	КадровоеПланированиеКлиент.НачатьЗаполнениеИнформацииЗанятости(ДанныеПозиции(ЭтотОбъект), ЭтотОбъект, ОписаниеОповещения);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьЗаполнениеИнформацииЗанятости(Результат, ДополнительныеПараметры) Экспорт
	
	Элементы.ИнформацияЗанятостиЗаполняется.Видимость = Ложь;

	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Элементы.ИнформацияЗанятости.Заголовок =
		ПолучитьИзВременногоХранилища(Результат.АдресРезультата).ИнформационнаяСтрокаЗанятости;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПериодичностьОбновления()
	Возврат 600;
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ДанныеПозиции(Форма)
	
	Объект = Форма.Объект;
	
	ДанныеПозиции = Новый Структура(
		"Позиция,
		|Должность,
		|Подразделение");
	
	ДанныеПозиции.Позиция = Объект.Ссылка;
	ДанныеПозиции.Должность = Объект.Должность;
	ДанныеПозиции.Подразделение = Объект.Подразделение;
	
	Возврат ДанныеПозиции;
	
КонецФункции

&НаСервере
Процедура ОбработатьВыбранныеПозиции(ВыбранноеЗначение)
	
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Массив") Тогда
		ВыбранныеПозиции = ВыбранноеЗначение;
	Иначе
		ВыбранныеПозиции = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(ВыбранноеЗначение);
	КонецЕсли;
	
	Для каждого Позиция Из ВыбранныеПозиции Цикл
		СтруктураПоиска = Новый Структура("ПозицияШтатногоРасписания", Позиция);
		Если ПозицииШтатногоРасписанияПоКадровомуПлану.НайтиСтроки(СтруктураПоиска).Количество() = 0 Тогда
			ПозицииШтатногоРасписанияПоКадровомуПлану.Добавить().ПозицияШтатногоРасписания = Позиция;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьНаборЗаписейПериодическихСведений(ИмяРегистра, ВедущийОбъект) Экспорт
	РедактированиеПериодическихСведений.ПрочитатьНаборЗаписей(ЭтотОбъект, ИмяРегистра, ВедущийОбъект);
КонецПроцедуры

#КонецОбласти