&НаКлиенте
Процедура ЭтапыРаботыСКандидатамиОбработкаВыбора(Элемент, ВыбранныеЭтапы, СтандартнаяОбработка)
	
	Если ВыбранныеЭтапы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ПодборПерсоналаФормыКлиент.ТаблицаЭтаповРаботыОбработкаВыбора(ЭтотОбъект, 
		Объект.ЭтапыРаботыСКандидатами, ВыбранныеЭтапы);
	
	УстановитьПредупреждениеЗаполненностиЭтаповРаботыСКандидатами(ЭтотОбъект);
	
КонецПроцедуры

&НаКлиенте
Процедура ЭтапыРаботыСКандидатамиСпособОценкиХарактеристикПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ЭтапыРаботыСКандидатами.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущиеДанные.СпособОценкиХарактеристик) Тогда
		ТекущиеДанные.ШаблонАнкеты = Неопределено;
	Иначе
		Если (ТипЗнч(ТекущиеДанные.ШаблонАнкеты) = Тип("СправочникСсылка.ШаблоныАнкет")
			И ТекущиеДанные.СпособОценкиХарактеристик <> ПредопределенноеЗначение("Перечисление.СпособыОценкиХарактеристик.АнкетаЭлектронногоИнтервью"))
			Или (ТипЗнч(ТекущиеДанные.ШаблонАнкеты) = Тип("СправочникСсылка.ЭлектронныеКурсы")
			И ТекущиеДанные.СпособОценкиХарактеристик <> ПредопределенноеЗначение("Перечисление.СпособыОценкиХарактеристик.ЭлектронныйТест")) Тогда
			ТекущиеДанные.ШаблонАнкеты = Неопределено;
		КонецЕсли;
			
	КонецЕсли;
	
	УстановитьОграничениеТипаСпособаОценки(ТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура ЭтапыРаботыСКандидатамиШаблонАнкетыОчистка(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ТекущиеДанные = Элементы.ЭтапыРаботыСКандидатами.ТекущиеДанные;
	ТекущиеДанные.ШаблонАнкеты = Неопределено;
	Если ИспользуетсяОдинИнструментОценки Тогда
		ТекущиеДанные.СпособОценкиХарактеристик = Неопределено;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЭтапыРаботыСКандидатамиШаблонАнкетыОткрытие(Элемент, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ЭтапыРаботыСКандидатами.ТекущиеДанные;
	Если Не ЗначениеЗаполнено(ТекущиеДанные.ШаблонАнкеты) Тогда
		Возврат;
	КонецЕсли;
	
	СтандартнаяОбработка = Ложь;
	ОткрытьФормуНастройкиВопросов(ТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура ЭтапыРаботыСКандидатамиШаблонАнкетыНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.ЭтапыРаботыСКандидатами.ТекущиеДанные;
	СтандартнаяОбработка = Ложь;
	ОткрытьФормуВыбораИнструментаОценки(ТекущиеДанные);
	
КонецПроцедуры

&НаКлиенте
Процедура ЭтапыРаботыСКандидатамиШаблонАнкетыСоздание(Элемент, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	ТекущиеДанные = Элементы.ЭтапыРаботыСКандидатами.ТекущиеДанные;
	ОткрытьФормуНастройкиВопросов(ТекущиеДанные, Истина);
	
КонецПроцедуры


#КонецОбласти

