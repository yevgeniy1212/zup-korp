&НаСервере
Процедура ОбновитьЭлементыДополнительныхРеквизитов()
	УправлениеСвойствами.ОбновитьЭлементыДополнительныхРеквизитов(ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЗависимостиДополнительныхРеквизитов()
	УправлениеСвойствамиКлиент.ОбновитьЗависимостиДополнительныхРеквизитов(ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПриИзмененииДополнительногоРеквизита(Элемент)
	УправлениеСвойствамиКлиент.ОбновитьЗависимостиДополнительныхРеквизитов(ЭтотОбъект);
КонецПроцедуры

&НаСервере
Процедура СвойстваВыполнитьОтложеннуюИнициализацию()
	УправлениеСвойствами.ЗаполнитьДополнительныеРеквизитыВФорме(ЭтотОбъект);
КонецПроцедуры

// Конец СтандартныеПодсистемы.Свойства

#КонецОбласти

&НаКлиенте
Процедура ОбновитьИнформационныеСтрокиВакансии()
	
	НачатьЗаполнениеИнформацииЗанятости();
	НачатьЗаполнениеИнформационнойСтрокиКандидатов();
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ПериодичностьОбновления()
	Возврат 600;
КонецФункции

&НаКлиенте
Процедура УстановитьОграничениеТипаСпособаОценки(ТекущиеДанные)
	
	Если ТекущиеДанные.СпособОценкиХарактеристик = ПредопределенноеЗначение("Перечисление.СпособыОценкиХарактеристик.АнкетаЭлектронногоИнтервью") Тогда
		Элементы.ЭтапыРаботыСКандидатамиШаблонАнкеты.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.ШаблоныАнкет");
	ИначеЕсли ТекущиеДанные.СпособОценкиХарактеристик = ПредопределенноеЗначение("Перечисление.СпособыОценкиХарактеристик.ЭлектронныйТест") Тогда 
		Элементы.ЭтапыРаботыСКандидатамиШаблонАнкеты.ОграничениеТипа = Новый ОписаниеТипов("СправочникСсылка.ЭлектронныеКурсы");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуНастройкиВопросов(ТекущиеДанные, СозданиеНового = Ложь)
	
	УстановитьСпособОценкиДляОдногоИнструмента(ТекущиеДанные);
	
	Оповещение = Новый ОписаниеОповещения("НастройкаВопросовЗавершение", ЭтаФорма, ТекущиеДанные);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Объект", Объект.Ссылка);
	ПараметрыФормы.Вставить("СпособОценкиХарактеристик", ТекущиеДанные.СпособОценкиХарактеристик);
	ПараметрыФормы.Вставить("ШаблонАнкеты", ?(СозданиеНового, Неопределено, ТекущиеДанные.ШаблонАнкеты));
	ПараметрыФормы.Вставить("ЭтапРаботы", ТекущиеДанные.ЭтапРаботы);
	ПараметрыФормы.Вставить("АдресНастроек", АдресНастроекВопросов(ТекущиеДанные.ШаблонАнкеты, ТекущиеДанные.ЭтапРаботы));
	
	ОткрытьФорму("ОбщаяФорма.НастройкаВопросовДляСобеседования",
		ПараметрыФормы,
		ЭтаФорма,
		ТекущиеДанные.ПолучитьИдентификатор(),,,
		Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуВыбораИнструментаОценки(ТекущиеДанные)
	
	УстановитьСпособОценкиДляОдногоИнструмента(ТекущиеДанные);
	
	Оповещение = Новый ОписаниеОповещения("ВыборИнструментаОценкиЗавершение", ЭтаФорма, ТекущиеДанные);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Объект", Объект.Ссылка);
	ПараметрыФормы.Вставить("СпособОценкиХарактеристик", ТекущиеДанные.СпособОценкиХарактеристик);
	ПараметрыФормы.Вставить("ЭтапРаботы", ТекущиеДанные.ЭтапРаботы);
	ПараметрыФормы.Вставить("ИнструментОценки", ТекущиеДанные.ШаблонАнкеты);
	
	Если ТекущиеДанные.СпособОценкиХарактеристик = ПредопределенноеЗначение("Перечисление.СпособыОценкиХарактеристик.ЭлектронныйТест") Тогда
		ИмяФормыВыбора = "ОбщаяФорма.ВыборЭлектронногоТеста";
	ИначеЕсли ТекущиеДанные.СпособОценкиХарактеристик = ПредопределенноеЗначение("Перечисление.СпособыОценкиХарактеристик.АнкетаЭлектронногоИнтервью") Тогда
		ИмяФормыВыбора = "ОбщаяФорма.ВыборАнкетыЭлектронногоИнтервью";
	КонецЕсли;
	
	ОткрытьФорму(ИмяФормыВыбора,
		ПараметрыФормы,
		ЭтаФорма,
		ТекущиеДанные.ПолучитьИдентификатор(),,,
		Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкаВопросовЗавершение(Результат, ТекущиеДанные) Экспорт
	
	Если Результат = Неопределено Тогда
		Если ИспользуетсяОдинИнструментОценки Тогда
			ТекущиеДанные.СпособОценкиХарактеристик = Неопределено;
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	ОповеститьОбИзменении(Результат.СпособОценки);
	ТекущиеДанные.ШаблонАнкеты = Результат.СпособОценки;
	Модифицированность = Истина;
	
	Если Не Результат.Свойство("АдресНастроек") Тогда
		Возврат;
	КонецЕсли;
	
	НастройкиВопросовИзХранилища = ПолучитьИзВременногоХранилища(Результат.АдресНастроек);
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("СпособОценки", ТекущиеДанные.ШаблонАнкеты);
	СтруктураПоиска.Вставить("ЭтапРаботы", ТекущиеДанные.ЭтапРаботы);
	НайденныеСтроки = НастройкиВопросов.НайтиСтроки(СтруктураПоиска);
	Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
		НастройкиВопросов.Удалить(НайденнаяСтрока);
	КонецЦикла;
	Для Каждого Настройка Из НастройкиВопросовИзХранилища Цикл
		НоваяНастройка = НастройкиВопросов.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяНастройка, Настройка);
		НоваяНастройка.СпособОценки = ТекущиеДанные.ШаблонАнкеты;
		НоваяНастройка.ЭтапРаботы = ТекущиеДанные.ЭтапРаботы;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборИнструментаОценкиЗавершение(Результат, ТекущиеДанные) Экспорт
	
	Если Результат = Неопределено Тогда
		Если ИспользуетсяОдинИнструментОценки Тогда
			ТекущиеДанные.СпособОценкиХарактеристик = Неопределено;
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	Если Результат.ИнструментОценки = ТекущиеДанные.ШаблонАнкеты Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные.ШаблонАнкеты = Результат.ИнструментОценки;
	Модифицированность = Истина;
	
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("СпособОценки", ТекущиеДанные.ШаблонАнкеты);
	СтруктураПоиска.Вставить("ЭтапРаботы", ТекущиеДанные.ЭтапРаботы);
	НайденныеСтроки = НастройкиВопросов.НайтиСтроки(СтруктураПоиска);
	Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
		НастройкиВопросов.Удалить(НайденнаяСтрока);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСпособОценкиДляОдногоИнструмента(ТекущиеДанные)
	
	Если ИспользуетсяОдинИнструментОценки Тогда
		Если ИспользоватьЭлектронноеИнтервью Тогда
			ТекущиеДанные.СпособОценкиХарактеристик = ПредопределенноеЗначение("Перечисление.СпособыОценкиХарактеристик.АнкетаЭлектронногоИнтервью");
		ИначеЕсли ИспользоватьЭлектронноеТестирование Тогда
			ТекущиеДанные.СпособОценкиХарактеристик = ПредопределенноеЗначение("Перечисление.СпособыОценкиХарактеристик.ЭлектронныйТест");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция АдресНастроекВопросов(ШаблонАнкеты, ЭтапРаботы)
	
	СтруктураПоиска = Новый Структура;
	СтруктураПоиска.Вставить("СпособОценки", ШаблонАнкеты);
	СтруктураПоиска.Вставить("ЭтапРаботы", ЭтапРаботы);
	НайденныеСтроки = НастройкиВопросов.НайтиСтроки(СтруктураПоиска);
	
	Если НайденныеСтроки.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
		
	НастройкиОтветов = Новый ТаблицаЗначений();
	НастройкиОтветов.Колонки.Добавить("ВариантОтвета");
	НастройкиОтветов.Колонки.Добавить("ХарактеристикаПерсонала");
	НастройкиОтветов.Колонки.Добавить("ЗначениеХарактеристики");
	НастройкиОтветов.Колонки.Добавить("Балл");
	
	Для Каждого Настройка Из НайденныеСтроки Цикл
		СтрокаНастройки = НастройкиОтветов.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаНастройки, Настройка);
	КонецЦикла;
	
	Возврат ПоместитьВоВременноеХранилище(ОбщегоНазначения.ТаблицаЗначенийВМассив(НастройкиОтветов), УникальныйИдентификатор);

КонецФункции

&НаСервере
Процедура ЗаписатьНастройкиТеста(ВакансияСсылка)
	
	Если НастройкиВопросов.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого ЭтапРаботыСКандидатом Из Объект.ЭтапыРаботыСКандидатами Цикл
		Если Не ЗначениеЗаполнено(ЭтапРаботыСКандидатом.ШаблонАнкеты) Тогда
			Продолжить;
		КонецЕсли;
		СтруктураПоиска = Новый Структура;
		СтруктураПоиска.Вставить("СпособОценки", ЭтапРаботыСКандидатом.ШаблонАнкеты);
		СтруктураПоиска.Вставить("ЭтапРаботы", ЭтапРаботыСКандидатом.ЭтапРаботы);
		НайденныеСтроки = НастройкиВопросов.НайтиСтроки(СтруктураПоиска);
		
		Если НайденныеСтроки.Количество() > 0 Тогда
			НаборЗаписей = РегистрыСведений.НастройкаВопросовДляЭлектронногоТестирования.СоздатьНаборЗаписей();
			НаборЗаписей.Отбор.Объект.Установить(ВакансияСсылка);
			НаборЗаписей.Отбор.ЭлектронныйКурс.Установить(ЭтапРаботыСКандидатом.ШаблонАнкеты);
			НаборЗаписей.Отбор.ЭтапРаботы.Установить(ЭтапРаботыСКандидатом.ЭтапРаботы);
			НаборЗаписей.Прочитать();
			НаборЗаписей.Очистить();
			Для Каждого Настройка Из НайденныеСтроки Цикл
				Запись = НаборЗаписей.Добавить();
				ЗаполнитьЗначенияСвойств(Запись, Настройка);
				Запись.Объект = ВакансияСсылка;
				Запись.ЭлектронныйКурс = Настройка.СпособОценки;
				Запись.ЭтапРаботы = Настройка.ЭтапРаботы;
			КонецЦикла;
			НаборЗаписей.Записать(Истина);
		КонецЕсли;
		
		Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
			НастройкиВопросов.Удалить(НайденнаяСтрока);
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьСклонениеИспытательногоСрока(ИспытательныйСрок, Элемент)
	Элемент.Подсказка = СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(
		НСтр("ru = ';месяц;;месяца;месяцев;'"), ИспытательныйСрок);
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимостьПредупреждения(ИспытательныйСрок, Предупреждение)
	
	Если ИспытательныйСрок > 3 Тогда
		Предупреждение.Видимость = Истина;
	Иначе
		Предупреждение.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьЭтапыПоУмолчаниюНаКлиенте()
	Результат = УстановитьЭтапыПоУмолчаниюНаСервере();
	ПодборПерсоналаФормыКлиент.ПослеУстановкиЭтаповПоУмолчанию(ЭтотОбъект, Результат);
КонецПроцедуры

&НаСервере
Функция УстановитьЭтапыПоУмолчаниюНаСервере()
	Результат = ПодборПерсоналаФормы.УстановитьЭтапыПоУмолчанию(Объект.ЭтапыРаботыСКандидатами);
	ПодборПерсоналаФормы.ПроверитьЭтапыРаботыСКандидатамиПоУмолчанию(ЭтотОбъект, 
		Объект.ЭтапыРаботыСКандидатами, Элементы.ЭтапыПоУмолчаниюПредупреждениеГруппа);
	Возврат Результат;
КонецФункции

&НаКлиенте
Процедура ОбработкаНавигационнойСсылкиУстановкиЭтаповПоУмолчанию(НавигационнаяСсылка, СтандартнаяОбработка)
	Если НавигационнаяСсылка = "УстановитьЭтапыПоУмолчанию" Тогда
		УстановитьЭтапыПоУмолчаниюНаКлиенте();
		СтандартнаяОбработка = Ложь;
	КонецЕсли;
КонецПроцедуры

#Область РабочееМесто

&НаКлиенте
Процедура ОбработатьОповещениеРабочегоМеста(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия <> "Запись_РабочиеМестаОхраныТруда" Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеПозиции = ДанныеПозицииШтатногоРасписания(Объект.Позиция);
	СписокРабочихМест = СписокРабочихМестПоДаннымПозиции(ДанныеПозиции);
	Элементы.РабочееМесто.СписокВыбора.ЗагрузитьЗначения(СписокРабочихМест.ВыгрузитьЗначения());
	
	Если СписокРабочихМест.НайтиПоЗначению(Источник) <> Неопределено Тогда
		Объект.РабочееМесто = Источник;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СписокРабочихМестПоДаннымПозиции(ДанныеПозиции);
	
	СписокРабочихМест = ОхранаТруда.РабочиеМестаПоПодразделениюИДолжности(
		ДанныеПозиции.Подразделение,
		ДанныеПозиции.Должность,
		ДанныеПозиции.Организация);
	
	Возврат СписокРабочихМест;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура ЗаполнитьРабочееМесто(Форма, СписокРабочихМест)
	
	Если Не ЗначениеЗаполнено(СписокРабочихМест) Тогда
		Возврат;
	КонецЕсли;
	
	Если СписокРабочихМест.Количество() = 1 Тогда
		Форма.Объект.РабочееМесто = СписокРабочихМест[0].Значение;
	Иначе
		Форма.Объект.РабочееМесто = Неопределено;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти
