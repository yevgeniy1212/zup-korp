#Область СлужебныеПроцедурыИФункции	

Функция НастройкиТеста(Тест) Экспорт
	
	ДанныеТеста = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(
		Тест,
		"ВремяТеста,
		|КоличествоПопыток,
		|КоличествоВопросов,
		|РазрешитьИсправлятьОшибки,
		|ПеремешиватьВопросы,
		|ПоказыватьРезультатОтвета,
		|ПоказыватьСтатистику,
		|ПоказыватьПравильныеОтветы,
		|ДатаИзменения");
		
	ДанныеТеста.Вставить("ВремяТестаВСекундах",
		ИзучениеЭлектронныхКурсовСлужебныйSCORM.КоличествоСекундИзДаты(ДанныеТеста.ВремяТеста));
	ДанныеТеста.Удалить("ВремяТеста");
		
	Возврат ДанныеТеста;
		
КонецФункции

Функция ВопросыТеста(Тест)	Экспорт
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВЫРАЗИТЬ(СтраницыТеста.СсылкаНаЭлементКурса КАК Справочник.ТестовыеВопросы) КАК Ссылка,
		|	ВЫРАЗИТЬ(СтраницыТеста.СсылкаНаЭлементКурса КАК Справочник.ТестовыеВопросы).ТипВопроса КАК ТипВопроса
		|ИЗ
		|	Справочник.СтраницыЭлементовЭлектронныхКурсов КАК СтраницыТеста
		|ГДЕ
		|	СтраницыТеста.Владелец = &Тест
		|	И СтраницыТеста.ЭтоГруппа = ЛОЖЬ
		|	И СтраницыТеста.ПометкаУдаления = ЛОЖЬ
		|	И ТИПЗНАЧЕНИЯ(СтраницыТеста.СсылкаНаЭлементКурса) = ТИП(Справочник.ТестовыеВопросы)
		|	И ВЫРАЗИТЬ(СтраницыТеста.СсылкаНаЭлементКурса КАК Справочник.ТестовыеВопросы).ПометкаУдаления = ЛОЖЬ
		|
		|УПОРЯДОЧИТЬ ПО
		|	СтраницыТеста.Родитель,
		|	СтраницыТеста.Код";
	
	Запрос.УстановитьПараметр("Тест", Тест);
	
	Возврат Запрос.Выполнить().Выгрузить();
		
КонецФункции

Функция СоздатьТест(ЭлектронныйКурс, Наименование, Знач КонтекстРедактирования = Неопределено) Экспорт
	
	ТестОбъект = Справочники.ЭлектронныеТесты.СоздатьЭлемент();				
	ТестОбъект.Заполнить(Неопределено);
	
	ТестОбъект.Наименование        = Наименование;
	ТестОбъект.Родитель            = Справочники.ЭлектронныеКурсы.ГруппаДляХраненияПодчиненныхЭлементов(ЭлектронныйКурс, Тип("СправочникСсылка.ЭлектронныеТесты"));
	ТестОбъект.ПеремешиватьВопросы = Истина;
	
	РазработкаЭлектронныхКурсовСлужебный.УстановитьПредпочитаемогоПоставщика(ТестОбъект);
	
	ТестОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", КонтекстРедактирования);
	ТестОбъект.Записать();	
	
	Возврат ТестОбъект.Ссылка;
	
КонецФункции

#КонецОбласти

#КонецЕсли
