#Область ПодготовкаДанных

// Подготавливает таблицу с данными об образовании по неполным переданным сведениям.
//
// Параметры:
//	СведенияОбОбразовании - Массив из Структура:
//	см. Справочники.ЛичныеДанныеКандидатов.НовоеОбразованиеДляФизическогоЛица.
//
// Возвращаемое значение:
//	ТаблицаЗначений - см. Справочники.ОбразованиеФизическихЛиц.НовыеДанныеОбОбразовании
Функция ПодготовитьДанныеОбОбразовании(СведенияОбОбразовании) Экспорт
	
	ДанныеОбОбразовании = Справочники.ОбразованиеФизическихЛиц.НовыеДанныеОбОбразовании();
	
	Для Каждого Образование Из СведенияОбОбразовании Цикл
		
		СтрокаОбразование = ДанныеОбОбразовании.Добавить();
		
		СтрокаОбразование.ВидОбразования = Образование.ВидОбразования;
		Если ТипЗнч(Образование.ВидОбразования) = Тип("Строка") И ЗначениеЗаполнено(Образование.ВидОбразования) Тогда
			СтрокаОбразование.ВидОбразования = Справочники.ВидыОбразованияФизическихЛиц.НайтиПоНаименованию(
				Образование.ВидОбразования, Истина);
		КонецЕсли;
		
		Если ТипЗнч(Образование.УчебноеЗаведение) = Тип("СправочникСсылка.УчебныеЗаведения") Тогда
			СтрокаОбразование.УчебноеЗаведениеСсылка = Образование.УчебноеЗаведение;
			СтрокаОбразование.УчебноеЗаведение = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Образование.УчебноеЗаведение,
				"Наименование");
		ИначеЕсли ТипЗнч(Образование.УчебноеЗаведение) = Тип("Строка") Тогда
			СтрокаОбразование.УчебноеЗаведениеСсылка = КадровыйУчетРасширенный.НайтиСоздатьУчебноеЗаведение(
				Образование.УчебноеЗаведение);
			СтрокаОбразование.УчебноеЗаведение = Образование.УчебноеЗаведение;
		ИначеЕсли Образование.УчебноеЗаведение = Неопределено Тогда
			СтрокаОбразование.УчебноеЗаведениеСсылка = Справочники.УчебныеЗаведения.ПустаяСсылка();
			СтрокаОбразование.УчебноеЗаведение = "";
		Иначе
			ОбщегоНазначенияКлиентСервер.Проверить(Ложь,
				СтрШаблон(НСтр("ru = 'Не известный тип учебного заведения - %1'"), ТипЗнч(Образование.УчебноеЗаведение)),
				"Справочники.Кандидаты.ПодготовитьДанныеОбОбразовании");
		КонецЕсли;
		СтрокаОбразование.СпециальностьСсылка = КадровыйУчетРасширенный.НайтиСоздатьСпециальность(
			Образование.Специальность);
		СтрокаОбразование.Специальность = Образование.Специальность;
		СтрокаОбразование.Факультет = Образование.Факультет;
		
		Если Образование.Свойство("Квалификация") И ЗначениеЗаполнено(Образование.Квалификация) Тогда
			СтрокаОбразование.Квалификация = Образование.Квалификация;
		Иначе
			СтрокаОбразование.Квалификация = Образование.Факультет;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Образование.Окончание) И Образование.Окончание > 0 Тогда
			СтрокаОбразование.Окончание = Дата(Образование.Окончание, 1, 1);
		КонецЕсли;
		
		НаименованиеКурса = Неопределено;
		Если Образование.Свойство("НаименованиеКурса", НаименованиеКурса)
			И ЗначениеЗаполнено(НаименованиеКурса) Тогда
			СтрокаОбразование.НаименованиеКурса = НаименованиеКурса;
		КонецЕсли;
		
		ВидПослевузовскогоОбразования = Неопределено;
		Если Образование.Свойство("ВидПослевузовскогоОбразования", ВидПослевузовскогоОбразования)
			И ЗначениеЗаполнено(ВидПослевузовскогоОбразования) Тогда
			СтрокаОбразование.ВидПослевузовскогоОбразования = ВидПослевузовскогоОбразования;
		КонецЕсли;
		
		ВидДополнительногоОбучения = Неопределено;
		Если Образование.Свойство("ВидДополнительногоОбучения", ВидДополнительногоОбучения)
			И ЗначениеЗаполнено(ВидДополнительногоОбучения) Тогда
			СтрокаОбразование.ВидДополнительногоОбучения = ВидДополнительногоОбучения;
		КонецЕсли;
		
		Если СтрокаОбразование.ВидОбразования <>
			Справочники.ВидыОбразованияФизическихЛиц.ДополнительноеПрофессиональноеОбразование 
			И СтрокаОбразование.ВидДополнительногоОбучения <> Перечисления.ВидыПрофессиональнойПодготовки.Переподготовка
			И СтрокаОбразование.ВидДополнительногоОбучения <>
				Перечисления.ВидыПрофессиональнойПодготовки.ПовышениеКвалификации Тогда
			СтрокаОбразование.ОсновноеОбразование = Истина;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат ДанныеОбОбразовании;
	
КонецФункции

Функция НаименованиеКандидата(ФИО, УточнениеНаименованияЛичныхДанныхКандидата = "",
	УточнениеНаименованияКандидата = "") Экспорт
	
	Возврат КадровыйУчетКлиентСервер.ПолноеНаименованиеСотрудника(
		ФИО.Фамилия, 
		ФИО.Имя, 
		ФИО.Отчество, 
		УточнениеНаименованияЛичныхДанныхКандидата, 
		УточнениеНаименованияКандидата);
	
КонецФункции

