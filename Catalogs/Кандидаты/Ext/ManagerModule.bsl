Процедура ЗаполнитьЗначенияДополнительныхРеквизитовШаблонаЭтапаРаботыСКандидатами(Сообщение, ПредметСообщения, ДополнительныеПараметры)
	
	Если ТипЗнч(ПредметСообщения) <> Тип("СправочникСсылка.Кандидаты") Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьЗначенияРеквизитовОрганизацииШаблонаЭтапаРаботыСКандидатами(Сообщение, ПредметСообщения, ДополнительныеПараметры);	
	ЗаполнитьЗначенияРеквизитовЭтапаРаботыШаблонаЭтапаРаботыСКандидатами(Сообщение, ПредметСообщения, ДополнительныеПараметры);
	
КонецПроцедуры

Процедура ЗаполнитьЗначенияПолучателяВДополнительныхРеквизитахШаблона(Сообщение, ПредметСообщения, ДополнительныеПараметры)
	
	Если ТипЗнч(ПредметСообщения) <> Тип("СправочникСсылка.Кандидаты") Тогда
		Возврат;
	КонецЕсли;
	
	ШаблоныСообщенийБЗК.ЗаполнитьЗначенияПолучателяВДополнительныхРеквизитахШаблона(
		Сообщение, ПредметСообщения, ДополнительныеПараметры);
	
КонецПроцедуры

Процедура ЗаполнитьЗначениеДополнительногоРеквизитаСписокКандидатов(Сообщение, ПредметСообщения, ДополнительныеПараметры)
	
	Если ТипЗнч(ПредметСообщения) <> Тип("СправочникСсылка.Кандидаты") Тогда
		Возврат;
	КонецЕсли;

	РеквизитыГруппыСписки = Сообщение.ДополнительныеПараметры.ПроизвольныеПараметры["Списки"];
	Если РеквизитыГруппыСписки = Неопределено Или РеквизитыГруппыСписки["СписокКандидатов"] = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыСообщения = ДополнительныеПараметры.ПараметрыСообщения;
	Если ПараметрыСообщения = Неопределено 
		Или Не ПараметрыСообщения.Свойство("Кандидаты") 
		Или ПараметрыСообщения.Кандидаты.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Если ДополнительныеПараметры.ФорматПисьма = Перечисления.СпособыРедактированияЭлектронныхПисем.HTML Тогда
		ПредставлениеСписка = СписокКандидатовВФорматеHTML(ПараметрыСообщения["Кандидаты"]);
	Иначе
		ПредставлениеСписка = СписокКандидатовВФорматеОбычныйТекст(ПараметрыСообщения["Кандидаты"]);
	КонецЕсли;
	
	РеквизитыГруппыСписки.Вставить("СписокКандидатов", ПредставлениеСписка);
	
КонецПроцедуры

Процедура ЗаполнитьЗначенияДополнительныхРеквизитовАвторизацииВнешнегоПользователя(Сообщение, ПредметСообщения, ДополнительныеПараметры)
	
	Если ТипЗнч(ПредметСообщения) <> Тип("СправочникСсылка.Кандидаты") Тогда
		Возврат;
	КонецЕсли;
	
	РеквизитыАвторизации = Сообщение.ДополнительныеПараметры.ПроизвольныеПараметры["АвторизацияВнешнегоПользователя"];
		
	Если РеквизитыАвторизации = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	МассивКандидаты = Новый Массив;
	МассивКандидаты.Добавить(ПредметСообщения);
	ДанныеПользователя = ЭлектронноеТестированиеКандидатов.СоздатьВнешнихПользователейИОтправитьПриглашение(МассивКандидаты, Ложь);
	
	РеквизитыАвторизации.Вставить("ВебСсылкаПереходаВСистему",
		ДанныеПользователя.ВебСсылкаПереходаВСистему);
	РеквизитыАвторизации.Вставить("ИмяПользователяИБ",
		ДанныеПользователя.ИмяПользователя);
	РеквизитыАвторизации.Вставить("Пароль",
		ДанныеПользователя.Пароль);
	
КонецПроцедуры

Функция СписокКандидатовВФорматеHTML(Кандидаты)

	ПредставлениеСписка = "";
	Для Каждого Кандидат Из Кандидаты Цикл
		ПредставлениеСписка = ПредставлениеСписка + "<li>" + Кандидат + "</li>";
	КонецЦикла;
	Возврат "<ul>" + ПредставлениеСписка + "</ul>";
	
КонецФункции

Функция СписокКандидатовВФорматеОбычныйТекст(Кандидаты)

	ПредставлениеСписка = "";
	Для Каждого Кандидат Из Кандидаты Цикл
		Если Не ПустаяСтрока(ПредставлениеСписка) Тогда
			ПредставлениеСписка = ПредставлениеСписка + Символы.ПС;
		КонецЕсли;
		ПредставлениеСписка = ПредставлениеСписка + Кандидат;
	КонецЦикла;
	Возврат ПредставлениеСписка;
		
КонецФункции

Процедура ЗаполнитьЗначенияРеквизитовОрганизацииШаблонаЭтапаРаботыСКандидатами(Сообщение, ПредметСообщения, ДополнительныеПараметры)
	
	Если ТипЗнч(ПредметСообщения) <> Тип("СправочникСсылка.Кандидаты") Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Кандидат", ПредметСообщения);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Кандидаты.Позиция.Владелец КАК Организация,
		|	Кандидаты.ДатаРегистрации КАК ДатаРегистрации,
		|	Кандидаты.Позиция.Владелец.НаименованиеСокращенное КАК НазваниеОрганизации
		|ИЗ
		|	Справочник.Кандидаты КАК Кандидаты
		|ГДЕ
		|	Кандидаты.Ссылка = &Кандидат";
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	
	ВидФактическийАдрес = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.ФактАдресОрганизации");
	ФактическийАдресПредставление = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(
		Выборка.Организация,
		ВидФактическийАдрес,
		Выборка.ДатаРегистрации);
	
	РеквизитыОрганизации = Новый Соответствие;
	РеквизитыОрганизации.Вставить("Наименование", Выборка.НазваниеОрганизации);
	РеквизитыОрганизации.Вставить("ФактическийАдрес", ФактическийАдресПредставление);
	
	Сообщение.ЗначенияРеквизитов.Вставить("Организация", РеквизитыОрганизации);
	
КонецПроцедуры

Процедура ЗаполнитьЗначенияРеквизитовЭтапаРаботыШаблонаЭтапаРаботыСКандидатами(Сообщение, ПредметСообщения, ДополнительныеПараметры)
	
	Если ТипЗнч(ПредметСообщения) <> Тип("СправочникСсылка.Кандидаты") Тогда
		Возврат;
	КонецЕсли;
	
	РеквизитыЭтапа = Сообщение.ДополнительныеПараметры.ПроизвольныеПараметры["ЭтапРаботы"];
	Если РеквизитыЭтапа = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыСообщения = ДополнительныеПараметры.ПараметрыСообщения;
	
	Если ПараметрыСообщения = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПараметрыСообщения.Свойство("ЭтапРаботы") Тогда
		Возврат;
	КонецЕсли;
	
	РеквизитыЭтапа.Вставить("Наименование", Строка(ПараметрыСообщения.ЭтапРаботы));
	РеквизитыЭтапа.Вставить("Дата", Формат(ПараметрыСообщения.ДатаВремя, "ДЛФ=D"));
	РеквизитыЭтапа.Вставить("Время", Формат(ПараметрыСообщения.ДатаВремя, "ДФ=ЧЧ:мм"));
	
	Видеособеседования.ЗаполнитьЗначенияРеквизитовШаблонаСообщения(РеквизитыЭтапа, ПараметрыСообщения);
	
КонецПроцедуры

Функция ОтправитьРезюмеКандидатов(ШаблонСообщения, Кандидаты, Получатели, УчетнаяЗапись, ВложитьПрисоединенныеФайлы) Экспорт

	ДлительныеОперации.СообщитьПрогресс(5);
	
	Результаты = Новый Соответствие;
	
	ПараметрыОтправки = ПодборПерсоналаКлиентСервер.ОписаниеПараметровОтправкиРезюме();
	ПараметрыОтправки.ВложитьПрисоединенныеФайлы = ВложитьПрисоединенныеФайлы;
	ПараметрыОтправки.УчетнаяЗапись = УчетнаяЗапись;
	
	ОбработаноРезюме = 0;
	Для Каждого Кандидат Из Кандидаты Цикл
		РезультатОтправки = ОтправитьРезюмеКандидата(Кандидат, Получатели, ШаблонСообщения, ПараметрыОтправки);
		СохранитьРезультатОтправки(Кандидат, Получатели, РезультатОтправки);
		Результаты.Вставить(Кандидат, РезультатОтправки);
		ДлительныеОперации.СообщитьПрогресс(ПрогрессОтправки(ОбработаноРезюме, Кандидаты.Количество()));
		ОбработаноРезюме = ОбработаноРезюме + 1;
	КонецЦикла;
	
	Возврат Результаты;
	
КонецФункции

Функция ОтправитьРезюмеКандидата(Кандидат, Получатели, Шаблон, ДополнительныеПараметры)

	ПараметрыОтправки = ПодборПерсоналаКлиентСервер.ОписаниеПараметровОтправкиРезюме();
	ПараметрыОтправки.Получатели = Получатели;
	ПараметрыОтправки.ПерезаполнятьПолучателей = Истина;
	ПараметрыОтправки.ВложитьПрисоединенныеФайлы = ДополнительныеПараметры.ВложитьПрисоединенныеФайлы;
	ПараметрыОтправки.Кандидаты = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Кандидат);
	ПараметрыОтправки.УчетнаяЗапись = ДополнительныеПараметры.УчетнаяЗапись;

	РезультатОтправкиПоШаблону = ШаблоныСообщений.СформироватьСообщениеИОтправить(
		Шаблон, Кандидат, Новый УникальныйИдентификатор, ПараметрыОтправки);

	РезультатОтправки = РегистрыСведений.ОтправкаРезюме.ОписаниеРезультатаОтправки();
	РезультатОтправки.Отправлено = Не ЗначениеЗаполнено(РезультатОтправкиПоШаблону.ОписаниеОшибки);
	РезультатОтправки.ОписаниеОшибки = РезультатОтправкиПоШаблону.ОписаниеОшибки;
	РезультатОтправки.ДатаОтправления = ТекущаяДатаСеанса();
	РезультатОтправки.Письмо = РезультатОтправкиПоШаблону.СсылкаНаПисьмо;

	Возврат РезультатОтправки;
	
КонецФункции

Процедура СохранитьРезультатОтправки(Кандидат, Получатели, РезультатОтправки)

	Для Каждого СтрокаКоллекции Из Получатели Цикл
		Если Не ЗначениеЗаполнено(СтрокаКоллекции.Контакт) Тогда
			СтрокаКоллекции.Контакт = Справочники.СтроковыеКонтактыВзаимодействий.НайтиПоНаименованию(
				СтрокаКоллекции.Адрес, Истина);
		КонецЕсли;
		Если Не ЗначениеЗаполнено(СтрокаКоллекции.Контакт) Тогда
			Продолжить;
		КонецЕсли;
		РегистрыСведений.ОтправкаРезюме.ЗаписатьРезультатОтправки(Кандидат, СтрокаКоллекции.Контакт, РезультатОтправки);
	КонецЦикла;

КонецПроцедуры

Функция ОписаниеРезультатаОтправки() Экспорт
	
	Результат = Новый Структура(
		"Отправлено,
		|ОписаниеОшибки,
		|ДатаОтправления");
	Возврат Результат;
	
КонецФункции

Функция ПрогрессОтправки(Обработано, Всего)
	Возврат Макс(5, Окр(Обработано / Всего * 100));
КонецФункции

Процедура ВложитьПрисоединенныеФайлы(Сообщение, ПредметСообщения, ДополнительныеПараметры)
	
	Если ТипЗнч(ПредметСообщения) <> Тип("СправочникСсылка.Кандидаты") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ВкладыватьПрисоединенныеФайлы(Сообщение) Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Кандидат Из ДополнительныеПараметры.ПараметрыСообщения.Кандидаты Цикл
		ФайлыКандидата = Новый Массив;
		РаботаСФайлами.ЗаполнитьПрисоединенныеФайлыКОбъекту(Кандидат, ФайлыКандидата);
		Для Каждого ПрисоединенныйФайл Из ФайлыКандидата Цикл
			ОписаниеФайла = РаботаСФайлами.ДанныеФайла(ПрисоединенныйФайл.Ссылка);
			ИмяВложения = ИмяФайлаВложенияКандидата(Кандидат, ОписаниеФайла.Наименование) + "." + ОписаниеФайла.Расширение;
			Сообщение.Вложения.Вставить(ИмяВложения, ОписаниеФайла.СсылкаНаДвоичныеДанныеФайла);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Функция ВкладыватьПрисоединенныеФайлы(Сообщение)
	
	Если Не Сообщение.Свойство("ДополнительныеПараметры") Тогда
		Возврат Ложь;
	КонецЕсли;

	Если Не Сообщение["ДополнительныеПараметры"].Свойство("ПараметрыСообщения") 
		Или Сообщение["ДополнительныеПараметры"]["ПараметрыСообщения"] = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли; 
	
	Если Не Сообщение["ДополнительныеПараметры"]["ПараметрыСообщения"].Свойство("ВложитьПрисоединенныеФайлы") Тогда
		Возврат Ложь;
	КонецЕсли; 
	
	Если Не Сообщение["ДополнительныеПараметры"]["ПараметрыСообщения"]["ВложитьПрисоединенныеФайлы"] Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

// Формирует временную таблицу с кандидатами, соответствующими отбору.
// 
// Параметры:
//  МенеджерВременныхТаблиц - МенеджерВременныхТаблиц -
//  Отбор - Структура
//  ТолькоРазрешенные - Булево - если Истина, в таблицу будут включены кандидаты, доступные текущему пользователю
//  ИмяСоздаваемойВТ - Строка
Процедура СоздатьВТКандидатыПоОтбору(МенеджерВременныхТаблиц, Отбор, ТолькоРазрешенные = Истина,
	ИмяСоздаваемойВТ = "ВТКандидатыПоОтбору")
	
	ТекстЗапроса = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Кандидаты.Ссылка КАК Кандидат
		|ПОМЕСТИТЬ ВТКандидатыПоОтбору
		|ИЗ
		|	Справочник.Кандидаты КАК Кандидаты
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ТекущиеЭтапыРаботыСКандидатами КАК ТекущиеЭтапыРаботыСКандидатами
		|		ПО ТекущиеЭтапыРаботыСКандидатами.Кандидат = Кандидаты.Ссылка
		|ГДЕ
		|	&УСЛОВИЕ";
	
	Если Не ТолькоРазрешенные Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "РАЗРЕШЕННЫЕ", "");
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	
	Условие = "";
	Для Каждого КлючИЗначение Из Отбор Цикл
		Запрос.УстановитьПараметр(СтрЗаменить(КлючИЗначение.Ключ, ".", "_"), КлючИЗначение.Значение);
		ФрагментУсловия = "";
		Если Не ПустаяСтрока(Условие) Тогда
			ФрагментУсловия = " И ";
		КонецЕсли;
		Если ТипЗнч(КлючИЗначение.Значение) = Тип("Массив") Тогда
			ШаблонУсловия = "%1 В (&%2)";
		ИначеЕсли ТипЗнч(КлючИЗначение.Значение) = Тип("СтандартныйПериод") Тогда
			ШаблонУсловия = "%1 МЕЖДУ &%1ДатаНачала И &%1ДатаОкончания";
			Запрос.УстановитьПараметр(СтрШаблон("%1ДатаНачала", КлючИЗначение.Ключ), КлючИЗначение.Значение.ДатаНачала);
			Запрос.УстановитьПараметр(СтрШаблон("%1ДатаОкончания", КлючИЗначение.Ключ), КлючИЗначение.Значение.ДатаОкончания);
		Иначе
			ШаблонУсловия = "%1 = &%2";
		КонецЕсли;
		Если СтрРазделить(КлючИЗначение.Ключ, ".").Количество() = 1 Тогда
			ШаблонУсловия = "Кандидаты." + ШаблонУсловия;
		КонецЕсли;
		ФрагментУсловия = ФрагментУсловия + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонУсловия, 
			КлючИЗначение.Ключ, СтрЗаменить(КлючИЗначение.Ключ, ".", "_"));
		Условие = Условие + ФрагментУсловия;
	КонецЦикла;
	
	Если Отбор.Количество() = 0 Тогда
		ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "ГДЕ", "");
	КонецЕсли;
	
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УСЛОВИЕ", Условие);
	
	ЗарплатаКадрыОбщиеНаборыДанных.ЗаменитьИмяСоздаваемойВременнойТаблицы(ТекстЗапроса, "ВТКандидатыПоОтбору",
		ИмяСоздаваемойВТ);
		
	Запрос.Текст = ТекстЗапроса;
	Запрос.Выполнить();
	
КонецПроцедуры

Функция ПредставлениеЛет(Лет)
	Возврат СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(НСтр("ru=';%1 год;;%1 года;%1 лет;%1 года'"), Лет);
КонецФункции

Функция ПредставлениеМесяцев(Месяцев)
	Возврат СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(
		НСтр("ru=';%1 месяц;;%1 месяца;%1 месяцев;%1 месяца'"), Месяцев);
КонецФункции

