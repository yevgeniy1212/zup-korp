// Возвращаемое значение:
//  Структура - Дополнительные параметры решения по кандидату:
// * КомментарийРешения - Строка -
// * ПричинаОтклонения - СправочникСсылка.ПричиныОтклоненияКандидатов -
// * СоздатьФизическоеЛицо - Неопределено -
// * ГруппаДоступаФизическогоЛица - СправочникСсылка.ГруппыДоступаФизическихЛиц -
Функция ДополнительныеПараметрыРешенияПоКандидату() Экспорт
	
	Параметры = Новый Структура;
	Параметры.Вставить("КомментарийРешения", "");
	Параметры.Вставить("ПричинаОтклонения", Справочники.ПричиныОтклоненияКандидатов.ПустаяСсылка());
	Параметры.Вставить("СоздатьФизическоеЛицо", Неопределено);
	Параметры.Вставить("ГруппаДоступаФизическогоЛица", Справочники.ГруппыДоступаФизическихЛиц.ПустаяСсылка());
		
	Возврат Параметры;
	
КонецФункции

// Установить решение по кандидату.
// 
// Параметры:
//  Кандидат - СправочникСсылка.Кандидаты
//  Решение - ПеречислениеСсылка.СостоянияСогласования
//  ДатаРешения - Дата,Неопределено - 
//  ДополнительныеПараметры - см. ДополнительныеПараметрыРешенияПоКандидату
Процедура УстановитьРешениеПоКандидату(Кандидат, Решение, ДатаРешения = Неопределено,
	ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ДополнительныеПараметры = Неопределено Тогда
		ДополнительныеПараметры = ДополнительныеПараметрыРешенияПоКандидату();
	КонецЕсли;

	КандидатОбъект = Кандидат.ПолучитьОбъект();
	
	Попытка
		КандидатОбъект.Заблокировать();
	Исключение
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Не удалось установить решение %1 кандидату %2. 
                  |В данный момент изменение невозможно, так как кандидат редактируется другим пользователем или в другой форме программы.'"),
			Решение,
			КандидатОбъект.Наименование);
		ВызватьИсключение ТекстСообщения;
	КонецПопытки;

	Если Решение = Перечисления.СостоянияСогласования.Согласовано Тогда
		// Проверка доступности утверждения.
		Отказ = Ложь;
		КандидатОбъект.ПроверитьУтверждение(Отказ);
		Если Отказ Тогда
			Возврат;
		КонецЕсли;
		КандидатОбъект.ДополнительныеСвойства.Вставить("ГруппаДоступаФизическогоЛица",
			ДополнительныеПараметры.ГруппаДоступаФизическогоЛица);
	КонецЕсли;
	КандидатОбъект.Состояние = Решение;
	КандидатОбъект.ДатаРешения = ДатаРешения;
	КандидатОбъект.КомментарийРешения = ДополнительныеПараметры.КомментарийРешения;
	КандидатОбъект.ПричинаОтклонения = ДополнительныеПараметры.ПричинаОтклонения;
	КандидатОбъект.Записать();
	
КонецПроцедуры

// Формирует таблицу значений с данными всех кандидатов указанных физических лиц.
//
// Параметры:
//	ФизическиеЛица- Массив из СправочникСсылка.ФизическиеЛица 
//
// Возвращаемое значение:
//  ТаблицаЗначений
Функция КандидатыФизическихЛиц(ФизическиеЛица) Экспорт
	
	ЛичныеДанныеКандидатов = ОбщегоНазначенияБЗККлиентСервер.ЗначенияСоответствия(
		ПодборПерсонала.ЛичныеДанныеКандидатовФизическихЛиц(ФизическиеЛица));
	
	СведенияОКандидатах = КандидатыПоЛичнымДаннымКандидатов(ЛичныеДанныеКандидатов);
	СведенияОКандидатах.Сортировать("ФизическоеЛицо, ДатаРегистрации УБЫВ");
	
	Возврат СведенияОКандидатах;
	
КонецФункции

// Предназначен для получения физических лиц кандидатов.
// 
// Параметры:
//  Кандидаты - Массив из СправочникСсылка.Кандидаты - массив кандидатов
//  ТолькоНеПомеченныеНаУдаление - Булево -
// 
// Возвращаемое значение:
//  Соответствие Из КлючИЗначение  
// 	* Ключ - СправочникСсылка.Кандидаты - кандидат из исходного массива
// 	* Значение - СправочникСсылка.ФизическиеЛица - физическое лицо кандидата
Функция ФизическиеЛицаКандидатов(Кандидаты, ТолькоНеПомеченныеНаУдаление = Ложь) Экспорт
	
	ЛичныеДанныеКандидатов = ЛичныеДанныеКандидатов(Кандидаты);
	
	ФизическиеЛицаЛичныхДанныхКандидатов = ПодборПерсонала.ФизическиеЛицаЛичныхДанныхКандидатов(
		ОбщегоНазначенияБЗККлиентСервер.ЗначенияСоответствия(ЛичныеДанныеКандидатов), ТолькоНеПомеченныеНаУдаление);
	
	Результат = Новый Соответствие();
	
	Для Каждого ТекущийЭлемент Из ФизическиеЛицаЛичныхДанныхКандидатов Цикл
		ЛичныеДанныеКандидата = ТекущийЭлемент.Ключ;
		ФизическоеЛицо = ТекущийЭлемент.Значение;
		Для Каждого ЭлементЛичныхДанных Из ЛичныеДанныеКандидатов Цикл
			Если ЭлементЛичныхДанных.Значение = ЛичныеДанныеКандидата Тогда
				Результат.Вставить(ЭлементЛичныхДанных.Ключ, ФизическоеЛицо);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Предназначен для получения физического лица кандидата.
// 
// Параметры:
// 	Кандидат - СправочникСсылка.Кандидаты - 
// 	ТолькоНеПомеченныеНаУдаление - Булево
// 	ПривилегированныйРежим - Булево
// 	
// Возвращаемое значение:
// 	СправочникСсылка.ФизическиеЛица -
Функция ФизическоеЛицоКандидата(Кандидат, ТолькоНеПомеченныеНаУдаление = Ложь, ПривилегированныйРежим = Ложь) Экспорт
	
	Если ПривилегированныйРежим Тогда
		УстановитьПривилегированныйРежим(Истина);
	КонецЕсли;
	
	ФизическоеЛицо = ФизическиеЛицаКандидатов(ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Кандидат),
		ТолькоНеПомеченныеНаУдаление)[Кандидат];
	Если ФизическоеЛицо = Неопределено Тогда
		ФизическоеЛицо = Справочники.ФизическиеЛица.ПустаяСсылка();
	КонецЕсли;
	
	Возврат ФизическоеЛицо;
	
КонецФункции

#Область ЛичныеДанныеКандидата

// Формирует таблицу значений с данными всех кандидатов по указанным личным данным кандидатов.
// 
// Параметры:
//  ЛичныеДанныеКандидатов - Массив из СправочникСсылка.ЛичныеДанныеКандидатов
// 
// Возвращаемое значение:
//  ТаблицаЗначений
Функция КандидатыПоЛичнымДаннымКандидатов(ЛичныеДанныеКандидатов) Экспорт
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	Отбор = Новый Структура("ЛичныеДанные", ЛичныеДанныеКандидатов);
	ИмяТаблицыОтборов = "ВТОтборы";
	СоздатьВТКандидатыПоОтбору(МенеджерВременныхТаблиц, Отбор, Истина, ИмяТаблицыОтборов);
	
	СведенияОКандидатах = ПодборПерсонала.ОсновныеСведенияОКандидатахПоДаннымВТ(МенеджерВременныхТаблиц,
		ИмяТаблицыОтборов, "Кандидат");
	СведенияОКандидатах.Сортировать("ЛичныеДанныеКандидата, ДатаРегистрации УБЫВ");
	
	Возврат СведенияОКандидатах;
	
КонецФункции

// Предназначен для получения личных данных кандидатов.
// 
// Параметры:
//  Кандидаты - Массив из СправочникСсылка.Кандидаты - массив кандидатов.
// 
// Возвращаемое значение:
//  Соответствие из КлючИЗначение:
//   * Ключ - СправочникСсылка.Кандидаты - кандидат из исходного массива
//   * Значение - СправочникСсылка.ЛичныеДанныеКандидатов - личные данные кандидата
Функция ЛичныеДанныеКандидатов(Кандидаты) Экспорт
	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъектов(Кандидаты, "ЛичныеДанные", Истина);
КонецФункции

#КонецОбласти

// Массив кандидатов, соответствующих указанному отбору.
//
// Параметры:
//  Отбор	 - Структура Из КлючИЗначение:
//  	* Ключ - Строка - имя реквизита
//  	* Значение - Произвольный - значение реквизита
// 
// Возвращаемое значение:
//  Массив из СправочникСсылка.Кандидаты - кандидаты, соответствующие отбору.
//
Функция КандидатыПоОтбору(Отбор) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	СоздатьВТКандидатыПоОтбору(Запрос.МенеджерВременныхТаблиц, Отбор);
	
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Кандидаты.Кандидат
		|ИЗ
		|	ВТКандидатыПоОтбору КАК Кандидаты";
	
	РезультатЗапроса = Запрос.Выполнить();
		
	Кандидаты = Новый Массив;
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		Кандидаты.Добавить(Выборка.Кандидат);
	КонецЦикла;
	
	Возврат Кандидаты;
	
КонецФункции

Функция ДанныеКандидатов(Кандидаты) Экспорт
	Возврат ПодборПерсонала.ОсновныеСведенияОКандидатах(Кандидаты);
КонецФункции

// Данные кандидата.
// 
// Параметры:
//  Кандидат - СправочникСсылка.Кандидаты
// 
// Возвращаемое значение:
//  Неопределено, Структура - Данные кандидата
Функция ДанныеКандидата(Кандидат) Экспорт

	ДанныеКандидатов = ДанныеКандидатов(ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Кандидат));
	Если ДанныеКандидатов.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(ДанныеКандидатов[0]);
	
КонецФункции

#Область ДанныеКандидата

