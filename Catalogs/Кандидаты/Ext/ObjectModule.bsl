#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)
	
	Если ДанныеЗаполнения = Неопределено Тогда
		ЗаполнитьНовыйОбъект();
	КонецЕсли;
	
	ЗаполнитьПоЛичнымДаннымКандидата(ДанныеЗаполнения);
	ЗаполнитьПоФизическомуЛицу(ДанныеЗаполнения);
	ЗаполнитьПоВакансии(ДанныеЗаполнения);
	ЗаполнитьПоДаннымЗаполнения(ДанныеЗаполнения);
	
КонецПроцедуры

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	Если ЗначениеЗаполнено(Вакансия) Тогда
		ДанныеВакансии = Справочники.Вакансии.ДанныеВакансии(Вакансия);
		Если ДанныеВакансии.НазначениеНабора = Перечисления.НазначениеНабораПерсоналаНаВакансию.ДолжностьПодразделение Тогда
			// Допустимо пустое подразделение в этом случае.
			ОбщегоНазначенияКлиентСервер.УдалитьЗначениеИзМассива(ПроверяемыеРеквизиты, "Подразделение");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриКопировании(ОбъектКопирования)
	
	Наименование = Неопределено;
	ЛичныеДанные = Неопределено;
	Рейтинг = 0;
	Состояние = Неопределено;
	ДатаРешения = Неопределено;
	КомментарийРешения = Неопределено;
	УдалитьЭтапРаботы = Неопределено;
	ПричинаОтклонения = Неопределено;
	УточнениеНаименования = Неопределено;
	
КонецПроцедуры

Процедура ПередЗаписью(Отказ)
	
	Если ЗарплатаКадры.ОтключитьБизнесЛогикуПриЗаписи(ЭтотОбъект) Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьПрежниеДанные();

	Если ЭтоНовый() Тогда
		Если ДополнительныеСвойства.Свойство("КандидатСсылка") Тогда
			УстановитьСсылкуНового(ДополнительныеСвойства.КандидатСсылка);
		КонецЕсли;
		ЗаписатьЛичныеДанныеКандидата(Отказ);
	КонецЕсли;
	
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	
	ПодборПерсонала.ПриСкрытииПерсональныхДанныхКандидата(ЭтотОбъект, Отказ);
	
	Если ЗарплатаКадры.ОтключитьБизнесЛогикуПриЗаписи(ЭтотОбъект) Тогда
		Возврат;
	КонецЕсли;
	
	ПроверитьОтменуУтверждения(Отказ);
	ПроверитьИзменениеДатыУтверждения(Отказ);
	
	ПроверитьСогласованиеВакансии(Отказ);
	
	ЗаписатьСвязанныеОбъекты(Отказ);

	ОбновитьЭтапУтверждениеРаботыСКандидатом();
	ОбновитьТекущийЭтапРаботыСКандидатом();
	
	СоздатьФизическоеЛицо();
	
	ОбновитьПовторноИспользуемыеЗначения();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаписатьСвязанныеОбъекты(Отказ)

	Если Не ДополнительныеСвойства.Свойство("СвязанныеОбъекты") Тогда
		Возврат;
	КонецЕсли;

	Если Не ЭтоНовый() Тогда
		// Для нового кандидата личные данные записываем перед записью, т.к. на них опирается RLS.
		ЗаписатьЛичныеДанныеКандидата(Отказ);
	КонецЕсли;
	
	СвязанныеОбъекты = ДополнительныеСвойства.СвязанныеОбъекты;
	
	Если СвязанныеОбъекты.Свойство("КомментарииКандидатов") Тогда
		СвязанныеОбъекты.КомментарииКандидатов.Отбор.Кандидат.Установить(Ссылка);
		СвязанныеОбъекты.КомментарииКандидатов.Записать();
	КонецЕсли;
	
	Если СвязанныеОбъекты.Свойство("ДанныеПубликацииРезюме") Тогда
		СвязанныеОбъекты.ДанныеПубликацииРезюме.Отбор.Кандидат.Установить(Ссылка);
		СвязанныеОбъекты.ДанныеПубликацииРезюме.Записать();
	КонецЕсли;

	Если СвязанныеОбъекты.Свойство("РаботаСКандидатами") Тогда
		СвязанныеОбъекты.РаботаСКандидатами.Отбор.Кандидат.Установить(Ссылка);
		СвязанныеОбъекты.РаботаСКандидатами.Записать();
	КонецЕсли;
	
	ЗаписатьФайлРезюме(Отказ);
	
	ДополнительныеСвойства.Удалить("СвязанныеОбъекты");
	
КонецПроцедуры

Процедура ЗаписатьЛичныеДанныеКандидата(Отказ)
	
	Если Не ДополнительныеСвойства.Свойство("СвязанныеОбъекты") 
		Или Не ДополнительныеСвойства.СвязанныеОбъекты.Свойство("ЛичныеДанныеКандидата") Тогда
		Возврат;
	КонецЕсли;
	
	ЛичныеДанныеКандидатаОбъект = ДополнительныеСвойства.СвязанныеОбъекты.ЛичныеДанныеКандидата;
	
	Если ЛичныеДанныеКандидатаОбъект.ЭтоНовый() Тогда
		ЛичныеДанныеКандидатаОбъект.УстановитьСсылкуНового(
			ЛичныеДанныеКандидатаОбъект.ДополнительныеСвойства.ЛичныеДанныеКандидатаСсылка);
		ЛичныеДанныеКандидатаСсылка = ЛичныеДанныеКандидатаОбъект.ДополнительныеСвойства.ЛичныеДанныеКандидатаСсылка;
	Иначе
		ЛичныеДанныеКандидатаСсылка = ЛичныеДанныеКандидатаОбъект.Ссылка;
	КонецЕсли;
	
	Если Не ЛичныеДанныеКандидатаОбъект.ПроверитьЗаполнение() Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	Если ЛичныеДанныеКандидатаОбъект.ДополнительныеСвойства.Свойство("СвязанныеОбъекты")
		И ЛичныеДанныеКандидатаОбъект.ДополнительныеСвойства.СвязанныеОбъекты.Свойство("АдресФотографии") Тогда
			
		УстановитьПривилегированныйРежим(Истина);
		ЛичныеДанныеКандидатаОбъект.Фотография = Справочники.ЛичныеДанныеКандидатов.СохраненнаяФотография(
			ЛичныеДанныеКандидатаСсылка,
			ЛичныеДанныеКандидатаОбъект.ДополнительныеСвойства.СвязанныеОбъекты.АдресФотографии);
		УстановитьПривилегированныйРежим(Ложь);
			
	КонецЕсли;
	
	ЛичныеДанныеКандидатаОбъект.Записать();

	ЗаписатьСвязанныеОбъектыКандидата(ЛичныеДанныеКандидатаОбъект);

КонецПроцедуры

Процедура ЗаписатьСвязанныеОбъектыКандидата(ЛичныеДанныеКандидатаОбъект)
	
	ДополнительныеСвойстваЛичныхДанных = ЛичныеДанныеКандидатаОбъект.ДополнительныеСвойства;
	Если Не ДополнительныеСвойстваЛичныхДанных.Свойство("СвязанныеОбъекты") Тогда
		Возврат;
	КонецЕсли;
	
	СвязанныеОбъектыЛичныхДанных = ДополнительныеСвойстваЛичныхДанных.СвязанныеОбъекты;
	
	Если СвязанныеОбъектыЛичныхДанных.Свойство("ФизическоеЛицоСсылка")
		И ЗначениеЗаполнено(СвязанныеОбъектыЛичныхДанных.ФизическоеЛицоСсылка)
		И ЗначениеЗаполнено(ЛичныеДанные) Тогда
		РегистрыСведений.ФизическиеЛицаКандидатов.УстановитьСвязьКандидатаСФизическимЛицом(ЛичныеДанные,
			СвязанныеОбъектыЛичныхДанных.ФизическоеЛицоСсылка);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаписатьФайлРезюме(Отказ)

	Если Не ДополнительныеСвойства.СвязанныеОбъекты.Свойство("ФайлРезюме") Тогда
		Возврат;
	КонецЕсли;

	ФайлРезюме = ДополнительныеСвойства.СвязанныеОбъекты.ФайлРезюме;
	Если ПустаяСтрока(ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ФайлРезюме, "Хранение", "")) Тогда
		Возврат;
	КонецЕсли;

	СтруктураПути = ОбщегоНазначенияКлиентСервер.РазложитьПолноеИмяФайла(ФайлРезюме.ИмяФайла);
	
	ПараметрыФайла = РаботаСФайлами.ПараметрыДобавленияФайла();
	ПараметрыФайла.Автор = Ответственный;
	ПараметрыФайла.ВладелецФайлов = Ссылка;
	ПараметрыФайла.ИмяБезРасширения = СтруктураПути.ИмяБезРасширения;
	ПараметрыФайла.РасширениеБезТочки = ОбщегоНазначенияКлиентСервер.РасширениеБезТочки(СтруктураПути.Расширение);
	
	РаботаСФайлами.ДобавитьФайл(ПараметрыФайла, ФайлРезюме.Хранение);

КонецПроцедуры

Процедура ПроверитьУтверждение(Отказ) Экспорт
	
	// Проверяет доступность кандидата для одобрения.
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Вакансия", Вакансия);
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ИСТИНА КАК Поле1
		|ИЗ
		|	РегистрСведений.СостоянияВакансий.СрезПоследних(, Вакансия = &Вакансия) КАК ТекущееСостояниеВакансий
		|ГДЕ
		|	НЕ ТекущееСостояниеВакансий.Состояние В (ЗНАЧЕНИЕ(Перечисление.СостоянияВакансии.Закрыта), ЗНАЧЕНИЕ(Перечисление.СостоянияВакансии.Отменена))";
	УстановитьПривилегированныйРежим(Истина);
	РезультатЗапроса = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	Если РезультатЗапроса.Пустой() Тогда
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Кандидат %1 не может быть одобрен, вакансия не указана, закрыта или отменена.'"), Наименование);
		ВызватьИсключение ТекстСообщения;
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбновитьЭтапУтверждениеРаботыСКандидатом()
	
	ПрежниеДанные = СвойствоСтруктуры(ДополнительныеСвойства, "ПрежниеДанные", Новый Структура);
	
	ПрежнееСостояние = СвойствоСтруктуры(ПрежниеДанные, "Состояние", Перечисления.СостоянияСогласования.ПустаяСсылка());
	ПрежнийКомментарий = СвойствоСтруктуры(ПрежниеДанные, "КомментарийРешения", "");
	ПрежняяДатаРешения = СвойствоСтруктуры(ПрежниеДанные, "ДатаРешения", Дата(1, 1, 1));
	
	Состояния = Новый Массив;
	Состояния.Добавить(ПрежнееСостояние);
	Состояния.Добавить(Состояние);
	
	Согласовано = Перечисления.СостоянияСогласования.Согласовано;
	
	// Обновляем данные этапа "Утверждение, одобрение" в случае, если:
	// - состояние изменилось, и стало или было "Согласовано",
	// - или состояние осталось "Согласовано", но изменился "Комментарий решения".

	Если (Состояния.Найти(Согласовано) <> Неопределено И ПрежнееСостояние <> Состояние) 
		Или (Состояние = Согласовано 
			И (ПрежнийКомментарий <> КомментарийРешения Или ПрежняяДатаРешения <> ДатаРешения)) Тогда
		Результат = ПодборПерсоналаКлиентСервер.РезультатУстановкиЭтапаРаботыСКандидатом();
		Результат.Кандидаты = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Ссылка);
		Результат.ЭтапРаботы.Этап = Перечисления.ЭтапыРаботыСКандидатами.Утверждение;
		Если Состояние = Согласовано Тогда
			Результат.ЭтапРаботы.Состояние = Перечисления.СостоянияЭтаповРаботыСКандидатами.Пройден;
			Результат.ЭтапРаботы.Период = ДатаРешения;
			Результат.ЭтапРаботы.Комментарий = КомментарийРешения;
		КонецЕсли;
		ПодборПерсонала.УстановитьСостояниеЭтапаРаботыКандидатов(Результат);
	КонецЕсли;
	
КонецПроцедуры

Процедура ОбновитьТекущийЭтапРаботыСКандидатом()

	ПрежниеДанные = СвойствоСтруктуры(ДополнительныеСвойства, "ПрежниеДанные", Новый Структура);

	ПрежняяВакансия = СвойствоСтруктуры(ПрежниеДанные, "Вакансия", Справочники.Вакансии.ПустаяСсылка());
	ПрежнееСостояние = СвойствоСтруктуры(ПрежниеДанные, "Состояние", Перечисления.СостоянияСогласования.ПустаяСсылка());
	
	// Если изменилась вакансия, состав этапов может поменяться, в этот изменяется текущий этап.
	// Кроме того, текущий этап может измениться, если у кандидата меняется состояние с/на Отклонен.

	Состояния = Новый Массив;
	Состояния.Добавить(ПрежнееСостояние);
	Состояния.Добавить(Состояние);
	
	Отклонено = Перечисления.СостоянияСогласования.Отклонено;
	
	// Обновляем данные этапа "Утверждение, одобрение" в случае, если:
	// - состояние изменилось, и стало или было "Согласовано",
	// - или состояние осталось "Согласовано", но изменился "Комментарий решения".

	Если Вакансия <> ПрежняяВакансия Или (Состояния.Найти(Отклонено) <> Неопределено И ПрежнееСостояние <> Состояние) Тогда
		ПодборПерсонала.ОбновитьТекущийЭтапРаботыКандидатов(ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Ссылка));
	КонецЕсли;
	
КонецПроцедуры

// Создает физическое лицо при утверждении кандидата.
Процедура СоздатьФизическоеЛицо()
	
	ПрежнееСостояние = СвойствоСтруктуры(СвойствоСтруктуры(ДополнительныеСвойства, "ПрежниеДанные"), "Состояние");
	Если Состояние = ПрежнееСостояние  Или Состояние <> Перечисления.СостоянияСогласования.Согласовано Тогда
		Возврат;
	КонецЕсли;

	ФизическоеЛицо = Справочники.Кандидаты.ДанныеКандидата(Ссылка).ФизическоеЛицо;
	Если ЗначениеЗаполнено(ФизическоеЛицо) Тогда
		Возврат;
	КонецЕсли;
	
	ГруппаДоступаФизическогоЛица = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ДополнительныеСвойства,
		"ГруппаДоступаФизическогоЛица", Справочники.ГруппыДоступаФизическихЛиц.ПустаяСсылка());
	Справочники.ЛичныеДанныеКандидатов.СоздатьФизическоеЛицоПоДаннымКандидата(ЛичныеДанные,
		Новый Структура("ГруппаДоступа", ГруппаДоступаФизическогоЛица));
	
КонецПроцедуры

Процедура УдалитьФизическоеЛицо()
	
	УстановитьПривилегированныйРежим(Истина);
	
	ФизическоеЛицо = Справочники.Кандидаты.ДанныеКандидата(Ссылка).ФизическоеЛицо;
	
	Если Не ЗначениеЗаполнено(ФизическоеЛицо) Тогда
		Возврат;
	КонецЕсли;
	
	НачатьТранзакцию();
	Попытка
		РегистрыСведений.ФизическиеЛицаКандидатов.УдалитьСвязьФизическогоЛицаСКандидатом(ФизическоеЛицо);
		ФизическоеЛицоОбъект = ФизическоеЛицо.ПолучитьОбъект();
		ФизическоеЛицоОбъект.УстановитьПометкуУдаления(Истина);
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры

Процедура ЗаполнитьПрежниеДанные()

	Если ЭтоНовый() Тогда
		Возврат;
	КонецЕсли;

	ДополнительныеСвойства.Вставить("ПрежниеДанные", Справочники.Кандидаты.ДанныеКандидата(Ссылка));
	
КонецПроцедуры

Процедура ПроверитьОтменуУтверждения(Отказ)
	
	ПрежнееСостояние = СвойствоСтруктуры(СвойствоСтруктуры(ДополнительныеСвойства, "ПрежниеДанные"), "Состояние");
	Если ПрежнееСостояние <> Перечисления.СостоянияСогласования.Согласовано 
		Или Состояние = Перечисления.СостоянияСогласования.Согласовано Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаЭтапов Из ТаблицаЭтаповРаботыСКандидатом() Цикл
		Если ЭтоЭтапПриемНаРаботу(СтрокаЭтапов.ЭтапРаботы) Или ЭтоЭтапРешенияОПриеме(СтрокаЭтапов.ЭтапРаботы) Тогда
			ОбщегоНазначенияКлиентСервер.Проверить(
				Не ЭтапЗапланирован(СтрокаЭтапов.СостояниеЭтапа) И Не ЭтапПройден(СтрокаЭтапов.СостояниеЭтапа),
				СтрШаблон(НСтр("ru = 'Отменить утверждение кандидата нельзя, потому что этап «%1» уже %2.'"), 
					СтрокаЭтапов.ЭтапРаботы, НРег(СтрокаЭтапов.СостояниеЭтапа)));
		КонецЕсли;
	КонецЦикла;
	
	// проверим наличие сотрудника
	УстановитьПривилегированныйРежим(Истина);
	Сотрудник = ПодборПерсонала.СотрудникКандидата(Ссылка);
	УстановитьПривилегированныйРежим(Ложь);
	
	Если ЗначениеЗаполнено(Сотрудник) Тогда
		ТекстСообщения = 
			СтрШаблон(НСтр("ru = 'Для кандидата %1 уже был создан сотрудник. Отмена решения невозможна.'"), Наименование);
		ОбщегоНазначенияКлиентСервер.Проверить(Ложь, ТекстСообщения);
	КонецЕсли;
	
	// проверим наличие решения о приеме на работу
	РешениеОПриемеНаРаботу = Документы.РешениеОПриемеНаРаботу.РешениеПоКандидату(Ссылка);
	Если ЗначениеЗаполнено(РешениеОПриемеНаРаботу) Тогда
		ТекстСообщения = СтрШаблон(НСтр("ru = 'Для кандидата %1 уже введен документ %2. Отмена решения невозможна.'"),
			Наименование, РешениеОПриемеНаРаботу);
		ОбщегоНазначенияКлиентСервер.Проверить(Ложь, ТекстСообщения);
	КонецЕсли;
	
	УдалитьФизическоеЛицо();

КонецПроцедуры

Процедура ПроверитьИзменениеДатыУтверждения(Отказ)
	
	ПрежняяДатаРешения = СвойствоСтруктуры(СвойствоСтруктуры(ДополнительныеСвойства, "ПрежниеДанные"), "ДатаРешения");
	Если ПрежняяДатаРешения = ДатаРешения Или Состояние <> Перечисления.СостоянияСогласования.Согласовано Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого СтрокаЭтапов Из ТаблицаЭтаповРаботыСКандидатом() Цикл
		Если (ЭтоЭтапПриемНаРаботу(СтрокаЭтапов.ЭтапРаботы) Или ЭтоЭтапРешенияОПриеме(СтрокаЭтапов.ЭтапРаботы))
			И (ЭтапЗапланирован(СтрокаЭтапов.СостояниеЭтапа) Или ЭтапПройден(СтрокаЭтапов.СостояниеЭтапа)) Тогда
			ОбщегоНазначенияКлиентСервер.Проверить(ДатаРешения <= СтрокаЭтапов.ДатаВремя,
				СтрШаблон(НСтр("ru = 'Утвердить кандидата %1 нельзя, потому что этап «%2» %3 раньше, %4.'"), 
					Формат(ДатаРешения, "ДЛФ=D;"), 
					СтрокаЭтапов.ЭтапРаботы, 
					НРег(СтрокаЭтапов.СостояниеЭтапа), 
					Формат(СтрокаЭтапов.ДатаВремя, "ДЛФ=D;")));
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

Процедура ПроверитьСогласованиеВакансии(Отказ)
	
	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьСогласованиеВакансий") Тогда
		Возврат;
	КонецЕсли;
	
	Если Не СвойствоСтруктуры(ДополнительныеСвойства, "ПроверятьСогласованиеВакансии", Истина) Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Вакансия) Тогда
		Возврат;
	КонецЕсли;
	
	Если ДополнительныеСвойства.Свойство("ПрежниеДанные") 
		И ДополнительныеСвойства.ПрежниеДанные.Вакансия = Вакансия Тогда
		Возврат;
	КонецЕсли;
	
	ДанныеСогласования = Справочники.Вакансии.ДанныеСогласования(Вакансия);
	Если ДанныеСогласования.СостояниеСогласования = Перечисления.СостоянияСогласования.Отклонено Тогда
		ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Вакансию %1 отклонил %2 %3. Кандидат не может быть зарегистрирован.'"), 
			Вакансия,
			ДанныеСогласования.Рассмотрел,
			ДанныеСогласования.ДатаРассмотрения);
		ОбщегоНазначения.СообщитьПользователю(ТекстСообщения, , , , Отказ);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьНовыйОбъект()
	
	Если Не Ссылка.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Ответственный) Тогда
		ЗначенияДляЗаполнения = Новый Структура;
		ЗначенияДляЗаполнения.Вставить("Ответственный", "Ответственный");
		ЗарплатаКадры.ЗаполнитьПервоначальныеЗначенияВФорме(ЭтотОбъект, ЗначенияДляЗаполнения);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ДатаРегистрации) Тогда
		ДатаРегистрации = ТекущаяДатаСеанса();
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ВалютаДохода) Тогда
		ВалютаДохода = ЗарплатаКадрыВызовСервера.ВалютаУчетаЗаработнойПлаты();
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ПериодичностьДохода) Тогда
		ПериодичностьДохода = Перечисления.ПериодичностьОжидаемогоДоходаКандидатов.Месяц;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьПоЛичнымДаннымКандидата(ДанныеЗаполнения)

	Если ТипЗнч(ДанныеЗаполнения) <> Тип("СправочникСсылка.ЛичныеДанныеКандидатов") Тогда
		Возврат;
	КонецЕсли;
	
	ЛичныеДанные = ДанныеЗаполнения;
	ЗаполнитьНовыйОбъект();
	
	ДанныеФИО = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(ЛичныеДанные, "ФИО, УточнениеНаименования");
	Если ПустаяСтрока(ДанныеФИО.ФИО) Тогда
		Возврат;
	КонецЕсли;
	
	Наименование = Справочники.Кандидаты.НаименованиеКандидата(
		ФизическиеЛицаКлиентСервер.ЧастиИмени(ДанныеФИО.ФИО), ДанныеФИО.УточнениеНаименования, УточнениеНаименования);
	
КонецПроцедуры

Процедура ЗаполнитьПоФизическомуЛицу(ДанныеЗаполнения)

	Если ТипЗнч(ДанныеЗаполнения) <> Тип("СправочникСсылка.ФизическиеЛица") Тогда
		Возврат;
	КонецЕсли;

	СвязанныеОбъекты = Новый Структура;
	ДополнительныеСвойства.Вставить("СвязанныеОбъекты", СвязанныеОбъекты);
	
	ЛичныеДанныеКандидата = ПодборПерсонала.ЛичныеДанныеКандидатаФизическогоЛица(ДанныеЗаполнения);
	Если ЛичныеДанныеКандидата = Неопределено Тогда
		ЛичныеДанныеОбъект = Справочники.ЛичныеДанныеКандидатов.СоздатьЭлемент();
		ЛичныеДанныеОбъект.Заполнить(ДанныеЗаполнения);
	Иначе
		ЛичныеДанные = ЛичныеДанныеКандидата;
		ЛичныеДанныеОбъект = ЛичныеДанныеКандидата.ПолучитьОбъект();
	КонецЕсли;
	
	СвязанныеОбъектыЛичныхДанных = Новый Структура;
	СвязанныеОбъектыЛичныхДанных.Вставить("ФизическоеЛицоСсылка", ДанныеЗаполнения);
	ЛичныеДанныеОбъект.ДополнительныеСвойства.Вставить("СвязанныеОбъекты", СвязанныеОбъектыЛичныхДанных);
	
	СвязанныеОбъекты.Вставить("ЛичныеДанныеКандидата", ЛичныеДанныеОбъект);
	
	ЗаполнитьНовыйОбъект();
	
	КадровыеДанные = КадровыйУчет.КадровыеДанныеФизическихЛиц(Истина, ДанныеЗаполнения, "ФИО, УточнениеНаименования");
	Если КадровыеДанные.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Наименование = Справочники.Кандидаты.НаименованиеКандидата(
		ФизическиеЛицаКлиентСервер.ЧастиИмени(КадровыеДанные[0].ФИО), КадровыеДанные[0].УточнениеНаименования, 
		УточнениеНаименования);
	
КонецПроцедуры

Процедура ЗаполнитьПоВакансии(ДанныеЗаполнения)

	Если ТипЗнч(ДанныеЗаполнения) <> Тип("СправочникСсылка.Вакансии") Тогда
		Возврат;
	КонецЕсли;

	ЗаполнитьНовыйОбъект();

	Вакансия = ДанныеЗаполнения;
	
	Если ЗначениеЗаполнено(Вакансия) Тогда
		ДанныеВакансии = Справочники.Вакансии.ДанныеВакансии(Вакансия);
		Позиция = ДанныеВакансии.Позиция;
		Подразделение = ДанныеВакансии.Подразделение;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьПоДаннымЗаполнения(ДанныеЗаполнения)

	Если ТипЗнч(ДанныеЗаполнения) <> Тип("Структура") Тогда
		Возврат;
	КонецЕсли;

	Если ДанныеЗаполнения.Свойство("Ответственный") Тогда
		Ответственный = ДанныеЗаполнения.Ответственный;
	КонецЕсли;

	ЗаполнитьНовыйОбъект();

	Если ДанныеЗаполнения.Свойство("ЛичныеДанныеКандидата") Тогда
		ЗаполнитьПоЛичнымДаннымКандидата(ДанныеЗаполнения["ЛичныеДанныеКандидата"]);
	КонецЕсли;
	
	Если ДанныеЗаполнения.Свойство("ФизическоеЛицо") Тогда
		ЗаполнитьПоФизическомуЛицу(ДанныеЗаполнения["ФизическоеЛицо"]);
	КонецЕсли;
	
	Если ДанныеЗаполнения.Свойство("Вакансия") Тогда
		ЗаполнитьПоВакансии(ДанныеЗаполнения["Вакансия"]);
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Вакансия) Тогда
		Если ДанныеЗаполнения.Свойство("Подразделение") Тогда
			Подразделение = ДанныеЗаполнения["Подразделение"];
		КонецЕсли;
	КонецЕсли;

	Если ДанныеЗаполнения.Свойство("ДанныеПубликации") Тогда
		ЗаполнитьПоДаннымРезюме(ДанныеЗаполнения);
	КонецЕсли;

	Если ДанныеЗаполнения.Свойство("ГруппаДоступаКандидата") Тогда
		ЗаполнитьГруппуДоступаКандидата(ДанныеЗаполнения["ГруппаДоступаКандидата"]);
	КонецЕсли;
	
	Если ДанныеЗаполнения.Свойство("ДляЗаписи") Тогда
		ДополнительныеСвойства.Вставить("ДляЗаписи", ДанныеЗаполнения.ДляЗаписи);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьГруппуДоступаКандидата(ГруппаДоступа)
	
	ЛичныеДанныеКандидатаОбъект = ОбщегоНазначенияБЗККлиентСервер.ЗначениеСвойства(ДополнительныеСвойства,
		"СвязанныеОбъекты.ЛичныеДанныеКандидата");
		
	Если ЛичныеДанныеКандидатаОбъект <> Неопределено Тогда
		ЛичныеДанныеКандидатаОбъект.ГруппаДоступа = ГруппаДоступа;
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьПоДаннымРезюме(ДанныеРезюме)
	
	Свойства = ДополнительныеСвойства;
	
	Свойства.Вставить("КандидатСсылка", ?(ЭтоНовый(), Справочники.Кандидаты.ПолучитьСсылку(), Ссылка));
	Свойства.Вставить("СвязанныеОбъекты", Новый Структура);
	
	Если ДанныеРезюме.ДанныеПубликации <> Неопределено Тогда
		Свойства.СвязанныеОбъекты.Вставить("ДанныеПубликацииРезюме", РегистрыСведений.ДанныеПубликацииРезюме.СоздатьНаборЗаписей());
		РекрутинговыеСайты.ЗаполнитьДанныеПубликацииРезюмеНаборЗаписей(ДанныеРезюме.ИсточникИнформации,
			Свойства.СвязанныеОбъекты.ДанныеПубликацииРезюме, ДанныеРезюме.ДанныеПубликации, Свойства.КандидатСсылка);
	КонецЕсли;

	ЗаполнитьКомментарииПоДаннымРезюме(ДанныеРезюме, Свойства.КандидатСсылка);

	Свойства.СвязанныеОбъекты.Вставить("ЛичныеДанныеКандидата", 
		?(ОбщегоНазначения.СсылкаСуществует(ЛичныеДанные), 
			ЛичныеДанные.ПолучитьОбъект(), Справочники.ЛичныеДанныеКандидатов.СоздатьЭлемент()));
	ЗаполнитьЛичныеДанныеКандидатаПоДаннымРезюме(ДанныеРезюме, Свойства.СвязанныеОбъекты.ЛичныеДанныеКандидата);

	Наименование = Справочники.Кандидаты.НаименованиеКандидата(
		Свойства.СвязанныеОбъекты.ЛичныеДанныеКандидата, 
		Свойства.СвязанныеОбъекты.ЛичныеДанныеКандидата.УточнениеНаименования, 
		УточнениеНаименования);

	Если ДанныеРезюме.Свойство("ОСебе") Тогда
		ОСебе = ДанныеРезюме.ОСебе;
	КонецЕсли;
	
	АдресРезюме = ДанныеРезюме.АдресРезюме;
	ИсточникИнформации = ДанныеРезюме.ИсточникИнформации;
	
	СохраненноеРезюме = ПодборПерсоналаКлиентСервер.СтруктураHTMLРезюме();
	СохраненноеРезюме.HTML = СтрЗаменить(ДанныеРезюме.ТекстРезюме, Символы.ПС, "<br>");
	Резюме = Новый ХранилищеЗначения(СохраненноеРезюме);
	
	ОжидаемыйДоход = ДанныеРезюме.ОжидаемыйДоход;
	ВалютаДохода = ДанныеРезюме.ВалютаДохода;
	ПериодичностьДохода = ДанныеРезюме.ПериодичностьДохода;
	
	Свойства.СвязанныеОбъекты.Вставить("ФайлРезюме", ДанныеРезюме.ФайлРезюме);
	
КонецПроцедуры

Процедура ЗаполнитьКомментарииПоДаннымРезюме(ДанныеРезюме, КандидатСсылка)

	ДополнительныеСвойства.СвязанныеОбъекты.Вставить("КомментарииКандидатов", 
		РегистрыСведений.КомментарииКандидатов.СоздатьНаборЗаписей());
	
	Комментарии = ДанныеРезюме["Комментарии"];
	Если Комментарии = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НаборЗаписей = ДополнительныеСвойства.СвязанныеОбъекты.КомментарииКандидатов;

	Для Каждого СтрокаКомментария Из Комментарии Цикл
		Если Не ЗначениеЗаполнено(СтрокаКомментария.Пользователь) Тогда
			Продолжить;
		КонецЕсли;
		ЗаписьНабора = НаборЗаписей.Добавить();
		ЗаполнитьЗначенияСвойств(ЗаписьНабора, СтрокаКомментария);
		ЗаписьНабора.Кандидат = КандидатСсылка;
		ЗаписьНабора.Доступность = Перечисления.ДоступностьКомментарияКандидата.Общедоступный;
		Если СтрокаКомментария.ТолькоДляАвтора Тогда
			ЗаписьНабора.Доступность = Перечисления.ДоступностьКомментарияКандидата.ТолькоДляАвтора;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьЛичныеДанныеКандидатаПоДаннымРезюме(ДанныеРезюме, ЛичныеДанныеОбъект)
	
	ЛичныеДанныеОбъект.ДополнительныеСвойства.Вставить("ЛичныеДанныеКандидатаСсылка", 
		?(ЛичныеДанныеОбъект.ЭтоНовый(), Справочники.ЛичныеДанныеКандидатов.ПолучитьСсылку(),
			ЛичныеДанные));
	ЛичныеДанныеОбъект.ДополнительныеСвойства.Вставить("СвязанныеОбъекты", Новый Структура);
	
	ЛичныеДанные = ЛичныеДанныеОбъект.ДополнительныеСвойства.ЛичныеДанныеКандидатаСсылка;
	
	Если ДанныеРезюме.Свойство("ДатаРождения") Тогда
		ЛичныеДанныеОбъект.ДатаРождения = ДатаИзРезюме(ДанныеРезюме.ДатаРождения);
	КонецЕсли;

	ЗаполнитьФИОПоДаннымРезюме(ДанныеРезюме, ЛичныеДанныеОбъект);
	ЗаполнитьПолПоДаннымРезюме(ДанныеРезюме, ЛичныеДанныеОбъект);

	КонтактнаяИнформация = УправлениеКонтактнойИнформацией.НоваяКонтактнаяИнформация();
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(
		СвойствоСтруктуры(ДанныеРезюме, "КонтактнаяИнформация", Новый Массив), КонтактнаяИнформация);
	УправлениеКонтактнойИнформацией.УстановитьКонтактнуюИнформациюОбъекта(
		ЛичныеДанныеОбъект, КонтактнаяИнформация);
	
	ЗаполнитьОпытРаботыПоДаннымРезюме(ЛичныеДанныеОбъект, 
		СвойствоСтруктуры(ДанныеРезюме, "ТрудоваяДеятельность", Новый Массив));
	
	ЗаполнитьСостоянияВБракеПоДаннымРезюме(ЛичныеДанныеОбъект, 
		СвойствоСтруктуры(ДанныеРезюме, "СостояниеВБраке", Новый Массив));

	ЗаполнитьГражданствоПоДаннымРезюме(ЛичныеДанныеОбъект, 
		СвойствоСтруктуры(ДанныеРезюме, "Гражданство", Новый Массив));
	
	ЗаполнитьОбразованиеПоДаннымРезюме(ЛичныеДанныеОбъект, 
		СвойствоСтруктуры(ДанныеРезюме, "Образование", Новый Массив));

	ЗаполнитьЗнаниеЯзыковПоДаннымРезюме(ЛичныеДанныеОбъект, 
		СвойствоСтруктуры(ДанныеРезюме, "ЗнаниеЯзыков", Новый Массив));
	
	ЛичныеДанныеОбъект.ДополнительныеСвойства.СвязанныеОбъекты.Вставить("АдресФотографии", "");
	Если СвойствоСтруктуры(ДанныеРезюме, "Фото") <> Неопределено И ЗначениеЗаполнено(ДанныеРезюме.Фото) Тогда
		АдресФотографии = ПоместитьВоВременноеХранилище("");
		ЛичныеДанныеОбъект.ДополнительныеСвойства.СвязанныеОбъекты.АдресФотографии = АдресФотографии;
		Если ТипЗнч(ДанныеРезюме.Фото) = Тип("ДвоичныеДанные") Тогда
			Фото = ДанныеРезюме.Фото;
		ИначеЕсли ТипЗнч(ДанныеРезюме.Фото) = Тип("Картинка") Тогда
			Фото = ДанныеРезюме.Фото.ПолучитьДвоичныеДанные();
		Иначе
			ОбщегоНазначенияКлиентСервер.Проверить(Ложь,
				НСтр("ru = 'Фотография из резюме должна быть или картинкой или двоичными данными.'"),
				"ЗаполнитьЛичныеДанныеКандидатаПоДаннымРезюме");
		КонецЕсли;
		ПоместитьВоВременноеХранилище(Фото, АдресФотографии);
	КонецЕсли;
	
КонецПроцедуры

Процедура ЗаполнитьФИОПоДаннымРезюме(ДанныеРезюме, ЛичныеДанныеКандидатаОбъект)
	
	Если ДанныеРезюме.Свойство("Фамилия") Или ДанныеРезюме.Свойство("Имя") Или ДанныеРезюме.Свойство("Отчество") Тогда
		ЛичныеДанныеКандидатаОбъект.ФИО = "";
		ДополнитьПредставление(ЛичныеДанныеКандидатаОбъект.ФИО, СвойствоСтруктуры(ДанныеРезюме, "Фамилия", ""));
		ДополнитьПредставление(ЛичныеДанныеКандидатаОбъект.ФИО, СвойствоСтруктуры(ДанныеРезюме, "Имя", ""), " ");
		ДополнитьПредставление(ЛичныеДанныеКандидатаОбъект.ФИО, СвойствоСтруктуры(ДанныеРезюме, "Отчество", ""), " ");
	КонецЕсли; 

	СтруктураФИО = ФизическиеЛицаКлиентСервер.ЧастиИмени(ЛичныеДанныеКандидатаОбъект.ФИО);
	Если СтруктураФИО.Фамилия = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЛичныеДанныеКандидатаОбъект.Фамилия = СтруктураФИО.Фамилия;
	
	Если СтруктураФИО.Имя <> Неопределено Тогда
		ЛичныеДанныеКандидатаОбъект.Имя = СтруктураФИО.Имя;
	КонецЕсли;
	Если СтруктураФИО.Отчество <> Неопределено Тогда
		ЛичныеДанныеКандидатаОбъект.Отчество = СтруктураФИО.Отчество;
	КонецЕсли;

	ЛичныеДанныеКандидатаОбъект.Наименование = КадровыйУчетКлиентСервер.ПолноеНаименованиеСотрудника(
		ЛичныеДанныеКандидатаОбъект.Фамилия, 
		ЛичныеДанныеКандидатаОбъект.Имя, 
		ЛичныеДанныеКандидатаОбъект.Отчество, 
		ЛичныеДанныеКандидатаОбъект.УточнениеНаименования);

КонецПроцедуры

Процедура ЗаполнитьПолПоДаннымРезюме(ДанныеРезюме, ЛичныеДанныеКандидатаОбъект)

	Если Не ЗначениеЗаполнено(СвойствоСтруктуры(ДанныеРезюме, "Пол")) Тогда
		Если ЗначениеЗаполнено(ЛичныеДанныеКандидатаОбъект.Отчество) Тогда
			ЛичныеДанныеКандидатаОбъект.Пол = СотрудникиКлиентСервер.ОпределитьПолПоОтчеству(
				ЛичныеДанныеКандидатаОбъект.Отчество);
		КонецЕсли;
		Возврат;
	КонецЕсли;

	Пол = ДанныеРезюме.Пол;
	Если ТипЗнч(Пол) = Тип("Строка") Тогда
		Если Пол = "Мужской" Тогда
			Пол = Перечисления.ПолФизическогоЛица.Мужской;
		ИначеЕсли Пол = "Женский" Тогда
			Пол = Перечисления.ПолФизическогоЛица.Женский;
		Иначе
			ОбщегоНазначенияКлиентСервер.Проверить(Ложь, 
				СтрШаблон(НСтр("ru = 'Неизвестный пол кандидата в резюме: %1'"), Пол), 
				"Справочники.Кандидаты.МодульОбъекта.ЗаполнитьПолПоДаннымРезюме");
		КонецЕсли;
	КонецЕсли;
	ЛичныеДанныеКандидатаОбъект.Пол = Пол;

КонецПроцедуры

Процедура ЗаполнитьОпытРаботыПоДаннымРезюме(ЛичныеДанныеКандидатаОбъект, ОпытРаботы)
	
	Если ОпытРаботы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ЛичныеДанныеКандидатаОбъект.ОпытРаботы.Очистить();
	
	Для Каждого СтрокаТаблицы Из ОпытРаботы Цикл
		
		НоваяСтрока = ЛичныеДанныеКандидатаОбъект.ОпытРаботы.Добавить();
		
		НоваяСтрока.Компания = СтрокаТаблицы.Компания;
		НоваяСтрока.Должность = СтрокаТаблицы.Должность;
		НоваяСтрока.Обязанности = СтрокаТаблицы.Обязанности;
		НоваяСтрока.СфераДеятельностиКомпании = СтрокаТаблицы.СфераДеятельностиКомпании;
		НоваяСтрока.ДатаНачала = ДатаИзРезюме(СтрокаТаблицы.ДатаНачала);
		НоваяСтрока.ДатаОкончания = ДатаИзРезюме(СтрокаТаблицы.ДатаОкончания);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьСостоянияВБракеПоДаннымРезюме(ЛичныеДанныеКандидатаОбъект, СостоянияВБраке)
	
	Если СостоянияВБраке.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаТаблицы = СостоянияВБраке[0];
	СостояниеВБраке = Справочники.СостояниеВБраке.ПустаяСсылка();
	Если ТипЗнч(СтрокаТаблицы.СостояниеВБраке) = Тип("СправочникСсылка.СостояниеВБраке") Тогда
		СостояниеВБраке = СтрокаТаблицы.СостояниеВБраке;
	ИначеЕсли ТипЗнч(СтрокаТаблицы.СостояниеВБраке) = Тип("Строка") Тогда
		Если СтрокаТаблицы.СостояниеВБраке = "Женат" Или СтрокаТаблицы.СостояниеВБраке = "Замужем" Тогда // АПК:1297 - Не локализуется
			СостояниеВБраке = Справочники.СостояниеВБраке.НайтиПоКоду("2");
		ИначеЕсли СтрокаТаблицы.СостояниеВБраке = "Не женат" Или СтрокаТаблицы.СостояниеВБраке = "Не замужем" Тогда  // АПК:1297 - Не локализуется
			СостояниеВБраке = Справочники.СостояниеВБраке.НайтиПоКоду("1");
		Иначе
			ОбщегоНазначенияКлиентСервер.Проверить(Ложь, 
				СтрШаблон(НСтр("ru = 'Неизвестное состояние в браке: %1'"), СтрокаТаблицы.СостояниеВБраке), 
				"Справочники.Кандидаты.МодульОбъекта.ЗаполнитьСостоянияВБракеПоДаннымРезюме");
		КонецЕсли;
	Иначе
		ОбщегоНазначенияКлиентСервер.Проверить(Ложь, 
			СтрШаблон(НСтр("ru = 'Неизвестный тип состояния в браке: %1'"), ТипЗнч(СтрокаТаблицы.СостояниеВБраке)), 
			"Справочники.Кандидаты.МодульОбъекта.ЗаполнитьСостоянияВБракеПоДаннымРезюме");
	КонецЕсли;
	
	ЛичныеДанныеКандидатаОбъект.СостояниеВБраке = СостояниеВБраке;
	
КонецПроцедуры

Процедура ЗаполнитьГражданствоПоДаннымРезюме(ЛичныеДанныеКандидатаОбъект, Гражданство)

	Если Гражданство.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ЛичныеДанныеКандидатаОбъект.Гражданство = Справочники.СтраныМира.НайтиПоНаименованию(Гражданство[0].Страна);
	
КонецПроцедуры

Процедура ЗаполнитьОбразованиеПоДаннымРезюме(ЛичныеДанныеКандидатаОбъект, Образование)
		
	Если Образование.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ЛичныеДанныеКандидатаОбъект.Образование.Очистить();
	ЛичныеДанныеКандидатаОбъект.Курсы.Очистить();
	
	ТаблицаДанныхОбОбразовании = Справочники.Кандидаты.ПодготовитьДанныеОбОбразовании(Образование);
	Для Каждого ДанныеОбОбразовании Из ТаблицаДанныхОбОбразовании Цикл
		
		ЭтоДополнительноеОбразование = Справочники.ВидыОбразованияФизическихЛиц.ЭтоДополнительноеОбразование(
			ДанныеОбОбразовании.ВидОбразования, ДанныеОбОбразовании.ВидДополнительногоОбучения);
			
		Если ЭтоДополнительноеОбразование Тогда
			НоваяСтрока = ЛичныеДанныеКандидатаОбъект.Курсы.Добавить();
			НоваяСтрока.НаименованиеКурса = ДанныеОбОбразовании.НаименованиеКурса;
		Иначе
			НоваяСтрока = ЛичныеДанныеКандидатаОбъект.Образование.Добавить();
			НоваяСтрока.ВидОбразования = ДанныеОбОбразовании.ВидОбразования;
			НоваяСтрока.Факультет = ДанныеОбОбразовании.Факультет;
			НоваяСтрока.Специальность = ДанныеОбОбразовании.СпециальностьСсылка;
		КонецЕсли;
		
		НоваяСтрока.УчебноеЗаведение = ДанныеОбОбразовании.УчебноеЗаведениеСсылка;
		Если ЗначениеЗаполнено(ДанныеОбОбразовании.Окончание) Тогда
			НоваяСтрока.ГодОкончания = Год(ДанныеОбОбразовании.Окончание);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьЗнаниеЯзыковПоДаннымРезюме(ЛичныеДанныеКандидатаОбъект, ЗнаниеЯзыков)
	
	Если ЗнаниеЯзыков.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ЛичныеДанныеКандидатаОбъект.ЗнаниеЯзыков.Очистить();
	
	КлассификаторЯзыков = Новый ТаблицаЗначений;
	
	Для Каждого ЗнаниеЯзыка Из ЗнаниеЯзыков Цикл
		НоваяСтрока = ЛичныеДанныеКандидатаОбъект.ЗнаниеЯзыков.Добавить();
		Если ТипЗнч(ЗнаниеЯзыка.Язык) = Тип("Строка") И ЗначениеЗаполнено(ЗнаниеЯзыка.Язык) Тогда
			Язык = КадровыйУчетРасширенный.ЯзыкПоНаименованию(ЗнаниеЯзыка.Язык);
			Если Не ЗначениеЗаполнено(Язык) Тогда
				Язык = КадровыйУчетРасширенный.НовыйЯзык(ЗнаниеЯзыка.Язык, КлассификаторЯзыков);
			КонецЕсли;
			НоваяСтрока.Язык = Язык;
		Иначе
			НоваяСтрока.Язык = ЗнаниеЯзыка.Язык;
		КонецЕсли;
		НоваяСтрока.СтепеньЗнанияЯзыкаКандидата = ЗнаниеЯзыка.СтепеньЗнанияЯзыкаКандидата;
	КонецЦикла;
	
	ЛичныеДанныеКандидатаОбъект.ЗнаниеЯзыков.Сортировать("Язык");
	
КонецПроцедуры

Процедура ДополнитьПредставление(Представление, Дополнение, Разделитель = "")
	
	Если ПустаяСтрока(Дополнение) Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ПустаяСтрока(Представление) Тогда
		Представление = Представление + Разделитель;
	КонецЕсли;
	
	Представление = Представление + Дополнение;

КонецПроцедуры

Функция СвойствоСтруктуры(Структура, Ключ, ЗначениеПоУмолчанию = Неопределено)
	
	Значение = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Структура, Ключ, ЗначениеПоУмолчанию);
	
	Если Значение = Неопределено Тогда
		Возврат ЗначениеПоУмолчанию
	КонецЕсли;
	
	Возврат Значение;
	
КонецФункции

Функция ДатаИзРезюме(Дата)

	Если ТипЗнч(Дата) = Тип("Дата") Тогда
		Возврат Дата;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(Дата) Тогда
		Возврат Дата(1, 1, 1);
	КонецЕсли;
	
	Возврат Дата(СтрЗаменить(Дата, "-", ""));
	
КонецФункции

Функция ТаблицаЭтаповРаботыСКандидатом()
	
	ИмяПоля = "ТаблицаЭтаповРаботыСКандидатом";
	Если СвойствоСтруктуры(ДополнительныеСвойства, ИмяПоля) = Неопределено Тогда
		ДополнительныеСвойства.Вставить(ИмяПоля, ПодборПерсонала.ТаблицаЭтаповРаботыСКандидатомНаВакансию(Ссылка, Вакансия));
	КонецЕсли;
	Возврат СвойствоСтруктуры(ДополнительныеСвойства, ИмяПоля);
	
КонецФункции

Функция ЭтоЭтапРешенияОПриеме(ЭтапРаботы)
	Возврат ЭтапРаботы = Перечисления.ЭтапыРаботыСКандидатами.РешениеОПриемеНаРаботу;
КонецФункции

Функция ЭтоЭтапПриемНаРаботу(ЭтапРаботы)
	Возврат ЭтапРаботы = Перечисления.ЭтапыРаботыСКандидатами.ПриемНаРаботу;
КонецФункции

Функция ЭтапПройден(СостояниеЭтапа)
	Возврат СостояниеЭтапа = Перечисления.СостоянияЭтаповРаботыСКандидатами.Пройден;
КонецФункции

Функция ЭтапЗапланирован(СостояниеЭтапа)
	Возврат СостояниеЭтапа = Перечисления.СостоянияЭтаповРаботыСКандидатами.Запланирован;
КонецФункции

#КонецОбласти

