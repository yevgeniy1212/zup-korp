&НаСервере
Процедура ЗаполнитьПредставлениеТекущегоЭтапа()
	
	Если Не ЗначениеЗаполнено(ТекущийЭтап.ЭтапРаботы) Тогда
		// Список этапов отбора для вакансии не определен, или все этапы пройдены.
		Элементы.ТекущийЭтапСостояниеГруппа.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ТекущийЭтап.ЭтапРаботы) = Тип("ПеречислениеСсылка.ЭтапыРаботыСКандидатами") Тогда
		Элементы.ТекущийЭтапСостояние.Заголовок = ПредставлениеПредопределенногоЭтапа(ТекущийЭтап, 
			НайтиСтрокуРаботыСКандидатом(ЭтотОбъект, ТекущийЭтап));
	Иначе
		Элементы.ТекущийЭтапСостояние.Заголовок = ПредставлениенеНеПредопределенногоЭтапа(ТекущийЭтап, 
			НайтиСтрокуРаботыСКандидатом(ЭтотОбъект, ТекущийЭтап));
	КонецЕсли;
	
	Элементы.ТекущийЭтапСостояниеГруппа.Видимость = ЗначениеЗаполнено(Элементы.ТекущийЭтапСостояние.Заголовок);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция НайтиСтрокуРаботыСКандидатом(Форма, ТекущийЭтап)
	
	Если Не ЗначениеЗаполнено(ТекущийЭтап.ЭтапРаботы) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	НайденныеСтроки = Форма.РаботаСКандидатамиНаборЗаписей.НайтиСтроки(
		Новый Структура("ЭтапРаботы", ТекущийЭтап.ЭтапРаботы));
	Если НайденныеСтроки.Количество() = 0 Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат НайденныеСтроки[0];
	
КонецФункции

&НаСервере
Функция ПредставлениеПредопределенногоЭтапа(ТекущийЭтап, СтрокаНабора)
	
	Если ТекущийЭтап.ЭтапРаботы = Перечисления.ЭтапыРаботыСКандидатами.Утверждение Тогда
		// Ожидает утверждения (одобрения) Утвердить или Отклонить.
		Возврат СтроковыеФункции.ФорматированнаяСтрока(
			НСтр("ru = 'Ожидает утверждения (одобрения) <a href=""%1"">Утвердить</a> или <a href=""%2"">Отклонить</a>'"), 
			НавигационныеСсылкиФорматированнойСтроки().Утвердить, 
			НавигационныеСсылкиФорматированнойСтроки().Отклонить);
	ИначеЕсли ТекущийЭтап.ЭтапРаботы = Перечисления.ЭтапыРаботыСКандидатами.РешениеОПриемеНаРаботу Тогда
		Если ТекущийЭтап.Состояние = Перечисления.СостоянияЭтаповРаботыСКандидатами.ПустаяСсылка() Тогда
			// Ожидается ввод решения о приеме на работу. Ввести
			Если ПравоДоступа("Добавление", Метаданные.Документы.РешениеОПриемеНаРаботу) Тогда
				Возврат СтроковыеФункции.ФорматированнаяСтрока(
					НСтр("ru = 'Ожидается ввод решения о приеме на работу. <a href=""%1"">Ввести</a>'"), 
					НавигационныеСсылкиФорматированнойСтроки().РешениеОПриемеНаРаботуВвести);
			Иначе
				Возврат НСтр("ru = 'Ожидается ввод решения о приеме на работу'");
			КонецЕсли;
		ИначеЕсли ТекущийЭтап.Состояние = Перечисления.СостоянияЭтаповРаботыСКандидатами.Запланирован Тогда
			// Ссылка на документ, не проведен
			Возврат СтроковыеФункции.ФорматированнаяСтрока(
				НСтр("ru = '<a href=""%1"">%2</a>, не проведен'"), 
				ПолучитьНавигационнуюСсылку(СтрокаНабора.ДокументОснование),
				Строка(СтрокаНабора.ДокументОснование));
		Иначе
			ОбщегоНазначенияКлиентСервер.Проверить(Ложь, 
				СтрШаблон(НСтр("ru = 'Неожиданное состояние %1 для этапа Решение о приеме на работу'"), 
					ТекущийЭтап.Состояние), 
				"Кандидаты.ФормаЭлемента.ПредставлениеПредопределенногоЭтапа");
		КонецЕсли;
	ИначеЕсли ТекущийЭтап.ЭтапРаботы = Перечисления.ЭтапыРаботыСКандидатами.ПриемНаРаботу Тогда
		Если ТекущийЭтап.Состояние = Перечисления.СостоянияЭтаповРаботыСКандидатами.ПустаяСсылка() Тогда
			// Все этапы пройдены, ожидается прием на работу
			Возврат НСтр("ru = 'Ожидается приказ о приеме на работу'");
		ИначеЕсли ТекущийЭтап.Состояние = Перечисления.СостоянияЭтаповРаботыСКандидатами.Запланирован Тогда
			// Ссылка на документ, не проведен
			Возврат СтроковыеФункции.ФорматированнаяСтрока(
				НСтр("ru = '<a href=""%1"">%2</a>, не проведен'"), 
				ПолучитьНавигационнуюСсылку(СтрокаНабора.ДокументОснование),
				Строка(СтрокаНабора.ДокументОснование));
		КонецЕсли;
	ИначеЕсли ТекущийЭтап.ЭтапРаботы = Перечисления.ЭтапыРаботыСКандидатами.РаботаЗавершена Тогда
		Возврат НСтр("ru = 'Работа с кандидатом по этапам завершена'");
	Иначе
		ОбщегоНазначенияКлиентСервер.Проверить(Ложь, 
			СтрШаблон(НСтр("ru = 'Неожиданный текущий предопределенный этап %1'"), 
				ТекущийЭтап.ЭтапРаботы), 
			"Кандидаты.ФормаЭлемента.ПредставлениеПредопределенногоЭтапа");
	КонецЕсли;
	
КонецФункции

&НаСервере
Функция ПредставлениенеНеПредопределенногоЭтапа(ТекущийЭтап, СтрокаНабора)
	
	ДобавлятьКоманды = РольДоступнаДобавлениеИзменениеДанныхКандидатов;

	ТекстДатаВремя = СтрШаблон(НСтр("ru = '%1 в %2'"), 
		ПредставлениеДаты(ТекущийЭтап.ДатаВремя), Формат(ТекущийЭтап.ДатаВремя, "ДФ=ЧЧ:мм"));
	
	ЧастиСтроки = Новый Массив;
	ЧастиСтроки.Добавить(СтрШаблон(НСтр("ru = 'Текущий этап «%1»'"), ТекущийЭтап.ЭтапРаботы));
	
	ДобавитьПробел(ЧастиСтроки);
	Если ТекущийЭтап.Состояние = Перечисления.СостоянияЭтаповРаботыСКандидатами.Запланирован Тогда
		ЧастиСтроки.Добавить(
			СтроковыеФункции.ФорматированнаяСтрока(
				НСтр("ru = 'запланирован <a href=""%1"">%2</a>'"), 
				НавигационныеСсылкиФорматированнойСтроки().ТекущийЭтапЗапланировать, 
				ТекстДатаВремя));
	Иначе
		Если ТекущийЭтап.Состояние = Перечисления.СостоянияЭтаповРаботыСКандидатами.Пройден Тогда
			ЧастиСтроки.Добавить(
				СтроковыеФункции.ФорматированнаяСтрока(
					НСтр("ru = 'пройден <a href=""%1"">%2</a>'"), 
					НавигационныеСсылкиФорматированнойСтроки().ТекущийЭтапВыполнить, 
					ТекстДатаВремя));
			ДобавлятьКоманды = Ложь;
		ИначеЕсли ТекущийЭтап.Состояние = Перечисления.СостоянияЭтаповРаботыСКандидатами.Пропущен Тогда
			ЧастиСтроки.Добавить(СтрШаблон(НСтр("ru = 'пропущен %1'"), ТекстДатаВремя));
			ДобавлятьКоманды = Ложь;
		Иначе
			ЧастиСтроки.Добавить(НСтр("ru = 'пока не запланирован'"));
			Если ДобавлятьКоманды Тогда
				ДобавитьПробел(ЧастиСтроки);
				ЧастиСтроки.Добавить(
					Новый ФорматированнаяСтрока(НСтр("ru = 'Запланировать'"), , , , 
						НавигационныеСсылкиФорматированнойСтроки().ТекущийЭтапЗапланировать));
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если ДобавлятьКоманды Тогда
		ДобавитьПробел(ЧастиСтроки);
		Если ЗначениеЗаполнено(СвойствоСтруктуры(СтрокаНабора, "ШаблонАнкеты")) Тогда
			ЧастиСтроки.Добавить(
				Новый ФорматированнаяСтрока(НСтр("ru = 'Пройти'"), , , , 
					НавигационныеСсылкиФорматированнойСтроки().ТекущийЭтапПройти));	
		Иначе
			ЧастиСтроки.Добавить(
				Новый ФорматированнаяСтрока(НСтр("ru = 'Отметить пройденным'"), , , , 
					НавигационныеСсылкиФорматированнойСтроки().ТекущийЭтапВыполнить));
		КонецЕсли;
		ДобавитьПробел(ЧастиСтроки);
		ЧастиСтроки.Добавить(
			Новый ФорматированнаяСтрока(НСтр("ru = 'Пропустить'"), , , , 
				НавигационныеСсылкиФорматированнойСтроки().ТекущийЭтапПропустить));
	КонецЕсли;
	
	Возврат Новый ФорматированнаяСтрока(ЧастиСтроки);
	
КонецФункции

&НаСервере
Процедура ДобавитьПробел(ЧастиСтроки)
	ЧастиСтроки.Добавить(" ");
КонецПроцедуры

&НаСервере
Функция ПредставлениеДаты(Дата)
	
	ТекущаяДата = ТекущаяДатаСеанса();
	
	Если НачалоДня(ТекущаяДата) = НачалоДня(Дата) Тогда
		Возврат НСтр("ru = 'сегодня'");
	КонецЕсли;
	
	Если КонецДня(ТекущаяДата) + 1 = НачалоДня(Дата) Тогда
		Возврат НСтр("ru = 'завтра'");
	КонецЕсли;
	
	Если НачалоГода(ТекущаяДата) <> НачалоГода(Дата) Тогда
		Возврат Формат(Дата, "ДЛФ=D");
	КонецЕсли;
	
	Возврат Формат(Дата, "ДФ='д ММММ (ддд)'");
	
КонецФункции

&НаКлиенте
Процедура ОбработкаНавигационнойСсылкиТекущийЭтапЗапланировать(НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	
