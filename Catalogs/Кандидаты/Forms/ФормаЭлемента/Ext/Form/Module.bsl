#Область ОбработчикиСобытийЭлементовТаблицыФормыРаботаСКандидатом

&НаКлиенте
Процедура РаботаСКандидатомВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;

	ТекущиеДанные = Элементы.РаботаСКандидатом.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ОбработатьВыборЭтапаУтверждение(ТекущиеДанные) Тогда
	ИначеЕсли ОбработатьВыборЭтапаРешениеОПриемеНаРаботу(ТекущиеДанные) Тогда
	ИначеЕсли ОбработатьВыборЭтапаПриемНаРаботу(ТекущиеДанные) Тогда
	Иначе
		Если ЗначениеЗаполнено(ТекущиеДанные.СостояниеЭтапа) Тогда
			НачатьИзменениеСостоянияЭтапаРаботы(ТекущиеДанные);
		Иначе
			НачатьУстановкуСостоянияЭтапаРаботы(
				ПредопределенноеЗначение("Перечисление.СостоянияЭтаповРаботыСКандидатами.Запланирован"), ТекущиеДанные);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура РаботаСКандидатомПриАктивизацииСтроки(Элемент)
	
	ТекущиеДанные = Элементы.РаботаСКандидатом.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		НастроитьКомандыСпискаЭтаповРаботыСКандидатом(ЭтотОбъект);
		Возврат;
	КонецЕсли;
	
	ВыбранныйЭлемент = Элементы.РаботаСКандидатом.ТекущиеДанные.ПолучитьИдентификатор();
	Если ВыбраннаяСтрокаРаботыСКандидатом = ВыбранныйЭлемент Тогда
		Возврат;
	КонецЕсли;

	ВыбраннаяСтрокаРаботыСКандидатом = ВыбранныйЭлемент;
	НастроитьКомандыСпискаЭтаповРаботыСКандидатом(ЭтотОбъект, ВыбранныйЭлемент);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Отклонить(Команда)
	
	Решение = ПредопределенноеЗначение("Перечисление.СостоянияСогласования.Отклонено");
	НачатьПринятиеРешения(Решение);
	
КонецПроцедуры

