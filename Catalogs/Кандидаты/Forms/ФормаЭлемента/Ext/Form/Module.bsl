#Область Комментарии

&НаКлиентеНаСервереБезКонтекста
Функция ПредставлениеКомментария(Форма, ДанныеКомментария, ТекущаяДата)
	
	Автор = ДанныеКомментария.Пользователь; // СправочникСсылка.Пользователи
	Время = ДанныеКомментария.Период;
	Текст = ДанныеКомментария.Комментарий;
	
	ВремяПредставление = "";
	Если НачалоДня(Время) = НачалоДня(ТекущаяДата) Тогда
		ВремяПредставление = Формат(Время, "ДФ=ЧЧ:мм; ДЛФ=T");
	Иначе
		ВремяПредставление = Формат(Время, "ДЛФ=D");
	КонецЕсли;
	
	ПредставлениеЗаголовка = СтрШаблон("%1, %2:", ПредставлениеАвтораКомментария(Автор), ВремяПредставление);
	
	ЧастиСтроки = Новый Массив;
	ЧастиСтроки.Добавить(Новый ФорматированнаяСтрока(ПредставлениеЗаголовка, , , , "Ссылка"));
	ЧастиСтроки.Добавить(Символы.ПС);
	ЧастиСтроки.Добавить(ОтображаемыйТекстКомментария(Текст));
	
	Возврат Новый ФорматированнаяСтрока(ЧастиСтроки);
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ОтображаемыйТекстКомментария(ПолныйТекст)

	МаксимумСтрок = 3;
	МаксимумСимволов = 87;
	
	ЧастиТекста = Новый Массив;
	Строк = 0;
	Символов = 0;
	Для Каждого Строка Из СтрРазделить(ПолныйТекст, Символы.ПС) Цикл
		Если Строк >= МаксимумСтрок Или Символов >= МаксимумСимволов Тогда
			Прервать;
		КонецЕсли;
		ОсталосьСимволов = МаксимумСимволов - Символов;
		Если СтрДлина(Строка) <= ОсталосьСимволов Тогда
			ЧастиТекста.Добавить(Строка);
			Символов = Символов + СтрДлина(Строка);
		Иначе
			ЧастиТекста.Добавить(Сред(Строка, 1, ОсталосьСимволов));
			Символов = Символов + ОсталосьСимволов;
		КонецЕсли;
		Строк = Строк + 1;
	КонецЦикла;

	Если Строк > МаксимумСтрок Или СтрДлина(ПолныйТекст) > Символов + (Строк - 1) Тогда
		ЧастиТекста[ЧастиТекста.Количество() - 1] = ЧастиТекста[ЧастиТекста.Количество() - 1] + "...";
	КонецЕсли;
	
	Возврат СтрСоединить(ЧастиТекста, Символы.ПС);
	
КонецФункции

