&НаСервере
Процедура УстановитьУсловноеОформлениеТаблицыФормыРаботаСКандидатами()

	// Жирный шрифт текста для этапов в состоянии Запланирован
	Элемент = УсловноеОформление.Элементы.Добавить();
	Элемент.Поля.Элементы.Добавить().Поле = Новый ПолеКомпоновкиДанных(Элементы.РаботаСКандидатом.Имя);
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Элемент.Отбор, 
		"РаботаСКандидатамиНаборЗаписей.СостояниеЭтапа", Перечисления.СостоянияЭтаповРаботыСКандидатами.Запланирован);
	Элемент.Оформление.УстановитьЗначениеПараметра("Шрифт", ШрифтыСтиля.ВажнаяНадписьШрифт);
	
	// Цвет текста поля Период если период этапа меньше начала текущего дня
	// и этап в состоянии Запланирован или не заполнен.
	Элемент = УсловноеОформление.Элементы.Добавить();
	Элемент.Поля.Элементы.Добавить().Поле = Новый ПолеКомпоновкиДанных(Элементы.РаботаСКандидатомПериод.Имя); 
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Элемент.Отбор, 
		"РаботаСКандидатамиНаборЗаписей.Период", НачалоДня(ТекущаяДатаСеанса()), ВидСравненияКомпоновкиДанных.Меньше);
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Элемент.Отбор, 
		"РаботаСКандидатамиНаборЗаписей.СостояниеЭтапа", 
		СписокЗначенийПоМассиву(Перечисления.СостоянияЭтаповРаботыСКандидатами.Завершенные()), 
		ВидСравненияКомпоновкиДанных.НеВСписке);
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ПросроченныеДанныеЦвет);
	
	// Цвет текста если этап не заполнен.
	Элемент = УсловноеОформление.Элементы.Добавить();
	Элемент.Поля.Элементы.Добавить().Поле = Новый ПолеКомпоновкиДанных(Элементы.РаботаСКандидатом.Имя); 
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Элемент.Отбор, 
		"РаботаСКандидатамиНаборЗаписей.СостояниеЭтапа", , ВидСравненияКомпоновкиДанных.НеЗаполнено);
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ЦветНедоступногоТекста);

	// Время не выводить для предопределенных этапов, только дату.
	Элемент = УсловноеОформление.Элементы.Добавить();
	Элемент.Поля.Элементы.Добавить().Поле = Новый ПолеКомпоновкиДанных(Элементы.РаботаСКандидатомПериод.Имя); 
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(Элемент.Отбор, 
		"РаботаСКандидатамиНаборЗаписей.ЭтапРаботы", 
		СписокЗначенийПоМассиву(Перечисления.ЭтапыРаботыСКандидатами.ВсеЭтапы()), 
		ВидСравненияКомпоновкиДанных.ВСписке);
	Элемент.Оформление.УстановитьЗначениеПараметра("Формат", "ДЛФ=D");

КонецПроцедуры

