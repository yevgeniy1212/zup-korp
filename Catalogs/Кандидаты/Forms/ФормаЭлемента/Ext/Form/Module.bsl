Процедура НачатьДобавлениеКомментария()
	
	ПараметрыФормы = Новый Структура("Пользователь, Действие");
	ПараметрыФормы.Пользователь = ПользователиКлиент.АвторизованныйПользователь();
	ПараметрыФормы.Действие = ПодборПерсоналаКлиентСервер.ДействияСКомментариемПриРедактировании().Добавление;
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ЗавершитьДобавлениеКомментария", ЭтотОбъект);
	ОткрытьФорму("РегистрСведений.КомментарииКандидатов.Форма.КомментарийКандидата", ПараметрыФормы, 
		ЭтотОбъект, ЭтотОбъект, , , ОписаниеОповещения);
	
КонецПроцедуры

// Завершить добавление комментария.
// 
// Параметры:
//  Результат - см. ПодборПерсоналаКлиентСервер.РезультатРедактированияКомментария
//  ДополнительныеПараметры - Структура
&НаКлиенте
Процедура ЗавершитьДобавлениеКомментария(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.Проверить(
		Результат.Действие = ПодборПерсоналаКлиентСервер.ДействияСКомментариемПриРедактировании().Добавление, 
		НСтр("ru = 'Неопознанное действие в результате добавления комментария'"), 
		"Справочник.Кандидаты.Формы.ФормаЭлемента");
	
	Модифицированность = Истина;
	
	СтрокаНабора = КомментарииКандидатовНаборЗаписей.Добавить();
	ЗаполнитьЗначенияСвойств(СтрокаНабора, Результат.Данные);
	СтрокаНабора.Период = ОбщегоНазначенияКлиент.ДатаСеанса();
	СтрокаНабора.Кандидат = КандидатСсылка;
	СтрокаНабора.Пользователь = ПользователиКлиент.АвторизованныйПользователь();
	
	ЗаполнитьПредставлениеКомментариев(ЭтотОбъект, ОбщегоНазначенияКлиент.ДатаСеанса());
	
КонецПроцедуры

