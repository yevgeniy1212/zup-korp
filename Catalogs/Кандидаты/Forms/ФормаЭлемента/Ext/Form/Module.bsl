Процедура СвойстваВыполнитьОтложеннуюИнициализацию()
	УправлениеСвойствами.ЗаполнитьДополнительныеРеквизитыВФорме(ЭтотОбъект, КандидатОбъект);
КонецПроцедуры
// Конец СтандартныеПодсистемы.Свойства

&НаСервере
Процедура ПриПолученииДанныхНаСервере(ТекущийОбъект = Неопределено)
	
	Если ТекущийОбъект = Неопределено Тогда
		ТекущийОбъект = КандидатОбъект;
	КонецЕсли;
	
	ОбъектЛичныеДанныеКандидата = Неопределено;
	Если ТипЗнч(ТекущийОбъект) = Тип("СправочникОбъект.Кандидаты") Тогда
		ОбъектЛичныеДанныеКандидата = СвойствоСтруктуры(ТекущийОбъект.ДополнительныеСвойства,
			"СвязанныеОбъекты.ЛичныеДанныеКандидата");
	КонецЕсли;

	// Прочитать объект личные данные кандидата.
	ПрочитатьЛичныеДанныеКандидатаОбъект(ОбъектЛичныеДанныеКандидата);
	
	РольДоступнаДобавлениеИзменениеДанныхКандидатов = ПравоДоступа("Изменение", Метаданные.Справочники.Кандидаты);
	Если Не РольДоступнаДобавлениеИзменениеДанныхКандидатов Тогда
		Элементы.РаботаСКандидатом.ТолькоПросмотр = Истина;
	КонецЕсли;
	РольДоступнаДобавлениеИзменениеРешенияОПриемеНаРаботу = ПравоДоступа("Изменение", Метаданные.Документы.РешениеОПриемеНаРаботу);
	
	ПрочитатьРаботуСКандидатом(ТекущийОбъект);
	ПрочитатьДанныеПубликацииРезюме(ТекущийОбъект);
	
	ПрочитатьРезюмеHTML(ТекущийОбъект);
	
	УстановитьПанельСостояния(ТекущийОбъект);
	УстановитьДоступностьПозиции(ЭтотОбъект);
	УстановитьДоступностьПодразделения(ЭтотОбъект);
	
	Рейтинг = РейтингДляОтображения(ТекущийОбъект);
	ОтобразитьРейтинг(ЭтотОбъект, Рейтинг);
	РассчитатьСреднийРейтинг(ЭтотОбъект);
	УстановитьДоступностьРейтинга();
	
	ПрочитатьКомментарии(ТекущийОбъект, КандидатСсылка);
	УстановитьДоступностьДобавленияИзмененияКомментариев();
	
	Если ИспользоватьЭлектронноеИнтервью Или ИспользоватьЭлектронноеТестирование Тогда
		ЗаполнитьОценкуПоХарактеристикам();
	КонецЕсли;
	
	УстановитьОтображениеНадписей(ТекущийОбъект);

	СохранитьОжидаемыйДоход(ЭтотОбъект, 
		ТекущийОбъект.ОжидаемыйДоход, ТекущийОбъект.ВалютаДохода, ТекущийОбъект.ПериодичностьДохода);
	ОтобразитьОжидаемыйДоходПоУмолчанию(ЭтотОбъект, ТекущийОбъект);
	ПересчитыватьОжидаемыйДоход = Истина;
	
	ПрочитатьФайлРезюме(ТекущийОбъект);
	
	ПрочитатьДанныеДляЗаписи(ТекущийОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьЛичныеДанныеКандидатаОбъект(Знач ОбъектЛичныеДанныеКандидата = Неопределено)
	
	Если КандидатОбъект.ЛичныеДанные.Пустая() Тогда
		КандидатОбъект.ЛичныеДанные = Справочники.ЛичныеДанныеКандидатов.ПолучитьСсылку();
	КонецЕсли;
	
	Если ОбъектЛичныеДанныеКандидата = Неопределено
		И ОбщегоНазначения.СсылкаСуществует(КандидатОбъект.ЛичныеДанные) Тогда
		ОбъектЛичныеДанныеКандидата = КандидатОбъект.ЛичныеДанные.ПолучитьОбъект();
		ДополнитьЛичныеДанные(ОбъектЛичныеДанныеКандидата, ЛичныеДанныеКандидата);
	КонецЕсли;
	
	ЛичныеДанныеКандидатаСсылка = КандидатОбъект.ЛичныеДанные;
		
	Если ОбъектЛичныеДанныеКандидата <> Неопределено Тогда
		
		ЗначениеВРеквизитФормы(ОбъектЛичныеДанныеКандидата, "ЛичныеДанныеКандидата");
		
		МестоРождения = ПерсонифицированныйУчетКлиентСервер.ПредставлениеМестаРождения(
			ОбъектЛичныеДанныеКандидата.МестоРождения);
		
		// Контактная информация.
		КонтактнаяИнформацияПолеТелефонЛичныеДанныеКандидатов =
			УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(ОбъектЛичныеДанныеКандидата,
				Справочники.ВидыКонтактнойИнформации.ТелефонЛичныеДанныеКандидатов);
		КонтактнаяИнформацияПолеEMailЛичныеДанныеКандидатов =
			УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(ОбъектЛичныеДанныеКандидата,
				Справочники.ВидыКонтактнойИнформации.EMailЛичныеДанныеКандидатов);
		КонтактнаяИнформацияПолеАдресЛичныеДанныеКандидатов =
			УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъекта(ОбъектЛичныеДанныеКандидата,
				Справочники.ВидыКонтактнойИнформации.АдресЛичныеДанныеКандидатов);
			
		// Фотография.
		Если Не ЗначениеЗаполнено(АдресФотографии) Тогда
			АдресФотографии = ОбщегоНазначенияБЗККлиентСервер.ЗначениеСвойства(ОбъектЛичныеДанныеКандидата,
				"ДополнительныеСвойства.СвязанныеОбъекты.Адресфотографии");
			Если ЗначениеЗаполнено(АдресФотографии) Тогда
				Фотография = ПолучитьИзВременногоХранилища(АдресФотографии);
				АдресФотографии = ПоместитьВоВременноеХранилище(Фотография, УникальныйИдентификатор);
			Иначе
				АдресФотографии = ПодборПерсонала.АдресФотографииЛичныхДанныхКандидата(ЛичныеДанныеКандидатаСсылка);
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ЛичныеДанныеКандидата.Гражданство) Тогда
		// Устанавливаем гражданство по умолчанию.
        // ЗУПК
		ЛичныеДанныеКандидата.Гражданство = Справочники.СтраныМира.Казахстан;
        // ЗУПК
	КонецЕсли;

	ЛичныеДанныеКандидатаВерсияДанных = ЛичныеДанныеКандидата.ВерсияДанных;
	
	ЗаполнитьВозраст(ЭтотОбъект, ТекущаяДатаСеанса());
	ЗаполнитьДругиеОбращенияКандидата();
	
	ЗаполнитьОбразованиеКвалификацию();
	ЗаполнитьПредставлениеОпытаРаботы();
	
	ЗаполнитьНаименованиеКандидата();
	
КонецПроцедуры

&НаСервере
Процедура ДополнитьЛичныеДанные(ОбъектПриемник, ОбъектИсточник)
	
	ЗаблокироватьЛичныеДанныеКандидатаОбъектДляРедактированияНаСервере();
	
	ДополнитьОсновыеДанные(ОбъектПриемник, ОбъектИсточник);
	ДополнитьКонтактнуюИнформацию(ОбъектПриемник, ОбъектИсточник);
	ДополнитьТрудовуюДеятельность(ОбъектПриемник, ОбъектИсточник);
	ДополнитьЗнанияЯзыков(ОбъектПриемник, ОбъектИсточник);
	ДополнитьОбразование(ОбъектПриемник, ОбъектИсточник);

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДополнитьОсновыеДанные(ОбъектПриемник, ОбъектИсточник)
	
	Если Не ЗначениеЗаполнено(ОбъектПриемник.ДатаРождения) Тогда
		ОбъектПриемник.ДатаРождения = ОбъектИсточник.ДатаРождения;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ОбъектПриемник.МестоРождения) Тогда
		ОбъектПриемник.МестоРождения = ОбъектИсточник.МестоРождения;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ОбъектПриемник.Пол) Тогда
		ОбъектПриемник.Пол = ОбъектИсточник.Пол;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ОбъектПриемник.Гражданство) Тогда
		ОбъектПриемник.Гражданство = ОбъектИсточник.Гражданство;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ОбъектПриемник.СостояниеВБраке) Тогда
		ОбъектПриемник.СостояниеВБраке = ОбъектИсточник.СостояниеВБраке;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДополнитьКонтактнуюИнформацию(ОбъектПриемник, ОбъектИсточник)
	
	Для каждого СтрокаКИ Из ОбъектИсточник.КонтактнаяИнформация Цикл
		Если Не ЗначениеЗаполнено(СтрокаКИ.Значение) Тогда
			Продолжить;
		КонецЕсли;
		УправлениеКонтактнойИнформацией.ДобавитьКонтактнуюИнформацию(ОбъектПриемник, СтрокаКИ.Значение, СтрокаКИ.Вид);
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДополнитьТрудовуюДеятельность(ОбъектПриемник, ОбъектИсточник)
	
	Для Каждого ТекущийОпытРаботы Из ОбъектИсточник.ОпытРаботы Цикл
		
		НовыйОпытРаботы = Неопределено;
		
		Отбор = Новый Структура("Компания, ДатаНачала, ДатаОкончания, Должность");
		ЗаполнитьЗначенияСвойств(Отбор, ТекущийОпытРаботы);
		Если ЗначениеЗаполнено(ОбъектПриемник.ОпытРаботы.НайтиСтроки(Отбор)) Тогда
			Продолжить;
		КонецЕсли;
		
		Отбор = Новый Структура("ДатаНачала, ДатаОкончания");
		ЗаполнитьЗначенияСвойств(Отбор, ТекущийОпытРаботы);
		НайденныеСтроки = ОбъектПриемник.ОпытРаботы.НайтиСтроки(Отбор);
		Если НайденныеСтроки.Количество() = 1 Тогда
			НовыйОпытРаботы = НайденныеСтроки[0];
		КонецЕсли;
		
		Отбор = Новый Структура("Компания, ДатаНачала, Должность");
		ЗаполнитьЗначенияСвойств(Отбор, ТекущийОпытРаботы);
		НайденныеСтроки = ОбъектПриемник.ОпытРаботы.НайтиСтроки(Отбор);
		Если НайденныеСтроки.Количество() = 1 Тогда
			НовыйОпытРаботы = НайденныеСтроки[0];
		КонецЕсли;
			
		Если НовыйОпытРаботы = Неопределено Тогда
			НовыйОпытРаботы = ОбъектПриемник.ОпытРаботы.Добавить();
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(НовыйОпытРаботы, ТекущийОпытРаботы);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДополнитьЗнанияЯзыков(ОбъектПриемник, ОбъектИсточник)
	
	Для Каждого СтрокаИсточник Из ОбъектИсточник.ЗнаниеЯзыков Цикл
		НайденныеСтроки = ОбъектПриемник.ЗнаниеЯзыков.НайтиСтроки(Новый Структура("Язык", СтрокаИсточник.Язык));
		Если ЗначениеЗаполнено(НайденныеСтроки) Тогда
			Если ЗначениеЗаполнено(СтрокаИсточник.СтепеньЗнанияЯзыкаКандидата)
					И Не НайденныеСтроки[0].СтепеньЗнанияЯзыкаКандидата = СтрокаИсточник.СтепеньЗнанияЯзыкаКандидата Тогда
				НайденныеСтроки[0].СтепеньЗнанияЯзыкаКандидата = СтрокаИсточник.СтепеньЗнанияЯзыкаКандидата;
			КонецЕсли;
			Продолжить;
		КонецЕсли;
		НоваяСтрока = ОбъектПриемник.ЗнаниеЯзыков.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаИсточник);
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ДополнитьОбразование(ОбъектПриемник, ОбъектИсточник)
	
	Для Каждого СтрокаИсточник Из ОбъектИсточник.Образование Цикл
		
		Отбор = Новый Структура("ВидОбразования, УчебноеЗаведение, ГодОкончания");
		ЗаполнитьЗначенияСвойств(Отбор, СтрокаИсточник);
		Отбор.УчебноеЗаведение = СтрокаИсточник.УчебноеЗаведение;
		Если ЗначениеЗаполнено(ОбъектПриемник.Образование.НайтиСтроки(Отбор)) Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = Неопределено;
		
		Отбор.Удалить("ГодОкончания");
		НайденныеСтроки = ОбъектПриемник.Образование.НайтиСтроки(Отбор);
		Если НайденныеСтроки.Количество() = 1 Тогда
			НоваяСтрока = НайденныеСтроки[0];
		КонецЕсли;

		Если НоваяСтрока = Неопределено Тогда
			НоваяСтрока = ОбъектПриемник.Образование.Добавить();
		КонецЕсли;
		
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаИсточник);
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьОбъектЛичныеДанныеКандидатаПоФизЛицу(ФизическоеЛицоСсылка)
	
	Если Не ЗначениеЗаполнено(ФизическоеЛицоСсылка) Тогда
		Возврат;
	КонецЕсли;

	ЛичныеДанныеСвязанныеСФизЛицом = ПодборПерсонала.ЛичныеДанныеКандидатаФизическогоЛица(ФизическоеЛицоСсылка);
	Если ЛичныеДанныеСвязанныеСФизЛицом <> Неопределено Тогда
		ЛичныеДанныеКандидатаСсылка = ЛичныеДанныеСвязанныеСФизЛицом;
		КандидатОбъект.ЛичныеДанные = ЛичныеДанныеКандидатаСсылка;
		ОбъектЛичныеДанныеКандидата = КандидатОбъект.ЛичныеДанные.ПолучитьОбъект();
		ДополнитьЛичныеДанные(ОбъектЛичныеДанныеКандидата, ЛичныеДанныеКандидата);
	Иначе
		Если КандидатОбъект.ЛичныеДанные.Пустая() Тогда
			ЛичныеДанныеКандидатаСсылка = Справочники.ЛичныеДанныеКандидатов.ПолучитьСсылку();
			КандидатОбъект.ЛичныеДанные = ЛичныеДанныеКандидатаСсылка;
		Иначе
			ЛичныеДанныеКандидатаСсылка = КандидатОбъект.ЛичныеДанные;
		КонецЕсли;
		
		ОбъектЛичныеДанныеКандидата = КандидатОбъект.ЛичныеДанные.ПолучитьОбъект();
		Если ОбъектЛичныеДанныеКандидата = Неопределено Тогда
			ОбъектЛичныеДанныеКандидата = РеквизитФормыВЗначение("ЛичныеДанныеКандидата");
		КонецЕсли;
		
		ОбъектЛичныеДанныеКандидата.Заполнить(ФизическоеЛицоСсылка);
		ДополнитьЛичныеДанные(ОбъектЛичныеДанныеКандидата, ЛичныеДанныеКандидата);
		
		// Фотография.
		АдресФотографии = КадровыйУчетРасширенный.АдресФотографииФизическогоЛица(ФизическоеЛицоСсылка);
		
		ЗначениеВРеквизитФормы(ОбъектЛичныеДанныеКандидата, "ЛичныеДанныеКандидата");
		
	КонецЕсли;
	
	ПрочитатьЛичныеДанныеКандидатаОбъект(ОбъектЛичныеДанныеКандидата);

КонецПроцедуры

&НаСервере
Процедура ПрочитатьДанныеДляЗаписи(ОбъектКандидат)

	Если ТипЗнч(ОбъектКандидат) = Тип("СправочникОбъект.Кандидаты") Тогда
		ДляЗаписи = СвойствоСтруктуры(ОбъектКандидат.ДополнительныеСвойства, "ДляЗаписи");
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПрочитатьФайлРезюме(ОбъектКандидат)

	Если ТипЗнч(ОбъектКандидат) = Тип("СправочникОбъект.Кандидаты") И ОбъектКандидат.ЭтоНовый() Тогда
		ДанныеФайла = СвойствоСтруктуры(ОбъектКандидат.ДополнительныеСвойства, "СвязанныеОбъекты.ФайлРезюме");
		Если ДанныеФайла <> Неопределено Тогда
			ФайлРезюме = ДанныеФайла;
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПрочитатьДанныеПубликацииРезюме(ОбъектКандидат)

	Если Не ПравоДоступа("Чтение", Метаданные.РегистрыСведений.ДанныеПубликацииРезюме) Тогда
		Возврат;
	КонецЕсли; 
	
	Если ТипЗнч(ОбъектКандидат) = Тип("СправочникОбъект.Кандидаты") И ОбъектКандидат.ЭтоНовый() Тогда
		НаборЗаписей = СвойствоСтруктуры(ОбъектКандидат.ДополнительныеСвойства, "СвязанныеОбъекты.ДанныеПубликацииРезюме");
		Если НаборЗаписей <> Неопределено Тогда
			ЗначениеВРеквизитФормы(НаборЗаписей, "ДанныеПубликацииРезюмеНаборЗаписей");
		КонецЕсли;
	Иначе
		НаборЗаписей = РеквизитФормыВЗначение("ДанныеПубликацииРезюмеНаборЗаписей");
		НаборЗаписей.Отбор.Кандидат.Установить(КандидатСсылка);
		НаборЗаписей.Прочитать();
		ЗначениеВРеквизитФормы(НаборЗаписей, "ДанныеПубликацииРезюмеНаборЗаписей");
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура ПрочитатьНаборЗаписейПериодическихСведений(ИмяРегистра, ВедущийОбъект) Экспорт
	РедактированиеПериодическихСведений.ПрочитатьНаборЗаписей(ЭтотОбъект, ИмяРегистра, ВедущийОбъект);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьДругиеОбращенияКандидата()
	
	ТаблицаКандидатов = Справочники.Кандидаты.КандидатыПоЛичнымДаннымКандидатов(
		ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(КандидатОбъект.ЛичныеДанные));
	
	КоличествоОбращений = 2;
	
	НомерОбращения = 1;
	Для Каждого СтрокаТаблицы Из ТаблицаКандидатов Цикл
		Если СтрокаТаблицы.Кандидат = КандидатСсылка Тогда 
			Продолжить;
		КонецЕсли;
		Если НомерОбращения > КоличествоОбращений Тогда
			Прервать;
		КонецЕсли;
		ПредставлениеОбращения = Строка(СтрокаТаблицы.Вакансия);
		Если Не ЗначениеЗаполнено(СтрокаТаблицы.Вакансия) Тогда
			ПредставлениеОбращения = Строка(СтрокаТаблицы.Подразделение);
		КонецЕсли;
		Элементы["ДругойКандидат_" + НомерОбращения].Заголовок = Новый ФорматированнаяСтрока(
			ПредставлениеОбращения, , , , ПолучитьНавигационнуюСсылку(СтрокаТаблицы.Кандидат));
		Элементы["ДругойКандидат_" + НомерОбращения].Видимость = Истина;
		НомерОбращения = НомерОбращения + 1;
	КонецЦикла;
	
	Пока НомерОбращения <= КоличествоОбращений Цикл
		Элементы["ДругойКандидат_" + НомерОбращения].Видимость = Ложь;
		НомерОбращения = НомерОбращения + 1;
	КонецЦикла;
	
	Элементы.ПолныйСписокКандидатов.Видимость = ТаблицаКандидатов.Количество() > КоличествоОбращений;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПоДаннымВакансии()
	
	Если Не ЗначениеЗаполнено(КандидатОбъект.Вакансия) Тогда
		Возврат;
	КонецЕсли;
	
	Объект = РеквизитФормыВЗначение("КандидатОбъект");
	Объект.Заполнить(КандидатОбъект.Вакансия);
	ЗначениеВРеквизитФормы(Объект, "КандидатОбъект");
	
	ПрочитатьРаботуСКандидатом();
	
	УстановитьДоступностьПозиции(ЭтотОбъект);
	УстановитьДоступностьПодразделения(ЭтотОбъект);
	
	СохранитьВыбраннуюВакансию(КандидатОбъект.Вакансия);
	ЗаполнитьИсториюВыбораВакансии();
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДанныеВакансии(Вакансия)
	Возврат Справочники.Вакансии.ДанныеВакансии(Вакансия);
КонецФункции

&НаСервереБезКонтекста
Функция ДанныеПозиции(Позиция)
	Возврат Справочники.ШтатноеРасписание.ДанныеПозицииШтатногоРасписания(Позиция);
КонецФункции

&НаСервереБезКонтекста
Процедура СохранитьВыбраннуюВакансию(Вакансия)
	
	ИсторияВыбора = ИсторияВыбораВакансии();
	ИсторияВыбора.Вставить(Вакансия, ТекущаяДатаСеанса());
	
	ОбщегоНазначения.ХранилищеОбщихНастроекСохранить(
		Метаданные.Справочники.Кандидаты.ПолноеИмя(), "ИсторияВыбораВакансии", ИсторияВыбора);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьИсториюВыбораВакансии()

	ИсторияВыбора = ИсторияВыбораВакансии();
	
	ОтборВакансий = Новый Структура();
	ОтборВакансий.Вставить("Ответственный", Пользователи.АвторизованныйПользователь());
	ОтборВакансий.Вставить("Состояние", Перечисления.СостоянияВакансии.Действующие());
	
	ДанныеВыбора = Справочники.Вакансии.ДанныеВакансий(
		Справочники.Вакансии.ВакансииПоОтбору(ОтборВакансий)).Скопировать(, "Вакансия, ПланируемаяДатаЗакрытия");
	ДанныеВыбора.Колонки.Добавить("ДатаВыбора");

	Для Каждого СтрокаДанных Из ДанныеВыбора Цикл
		Если ИсторияВыбора.Получить(СтрокаДанных.Вакансия) <> Неопределено Тогда
			СтрокаДанных.ДатаВыбора = ИсторияВыбора.Получить(СтрокаДанных.Вакансия);
		КонецЕсли;
	КонецЦикла;
	
	ДанныеВыбора.Сортировать("ДатаВыбора Убыв, ПланируемаяДатаЗакрытия Возр");
	
	Элементы.Вакансия.СписокВыбора.Очистить();
	Для Индекс = 0 По Мин(ДанныеВыбора.Количество() - 1, ГлубинаИсторииВыбораВакансии()) Цикл
		Элементы.Вакансия.СписокВыбора.Добавить(ДанныеВыбора[Индекс].Вакансия);
	КонецЦикла;

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ГлубинаИсторииВыбораВакансии()
	Возврат 7;
КонецФункции

&НаСервереБезКонтекста
Функция ИсторияВыбораВакансии()
	Возврат ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить(
		Метаданные.Справочники.Кандидаты.ПолноеИмя(), "ИсторияВыбораВакансии", Новый Соответствие());
КонецФункции

&НаСервере
Процедура УстановитьПанельСостояния(ТекущийОбъект = Неопределено)
	
	Если ТекущийОбъект = Неопределено Тогда
		ТекущийОбъект = КандидатОбъект;
	КонецЕсли;
	
	Элементы.Сотрудник.Видимость = Ложь;
	Элементы.ПричинаОтклонения.Видимость = Ложь;
	
	// Работа с кандидатом активна - не отображаем панель согласования.
	Если Не Перечисления.СостоянияСогласования.РешениеПринято(ТекущийОбъект.Состояние) Тогда
		Элементы.СостояниеГруппа.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Элементы.СостояниеГруппа.Видимость = Истина;
	Элементы.РешениеОПриемеНаРаботу.Видимость = Ложь;
	
	ПредставлениеСостояния = "";
	Если ТекущийОбъект.Состояние = Перечисления.СостоянияСогласования.Согласовано Тогда
		ПредставлениеСостояния = ?(ЭтоЖенскийПол(ЛичныеДанныеКандидата.Пол), 
			НСтр("ru = 'Одобрена, пока не принята на работу'"), НСтр("ru = 'Одобрен, пока не принят на работу'"));
		Элементы.ДатаРешения.Заголовок = НСтр("ru = 'Дата одобрения'");
		ДатаПриема = ДатаПриемаНаРаботу();
		Если ЗначениеЗаполнено(ДатаПриема) Тогда
			ПредставлениеСостояния = ?(ЭтоЖенскийПол(ЛичныеДанныеКандидата.Пол), 
				НСтр("ru = 'Одобрена, принята на работу'"), НСтр("ru = 'Одобрен, принят на работу'"));
			Сотрудник = ПодборПерсонала.СотрудникКандидата(КандидатСсылка);
			Элементы.Сотрудник.Видимость = Истина;
			Элементы.Сотрудник.Заголовок = ПредставлениеСотрудника(ДатаПриема);
		КонецЕсли;
		Элементы.РешениеОПриемеНаРаботу.Видимость = Истина;
		Элементы.РешениеОПриемеНаРаботу.Заголовок = ПредставлениеРешенияОПриемеНаРаботу();
		//@skip-check new-color
		Элементы.СостояниеГруппа.ЦветТекстаЗаголовка = Новый Цвет;
	КонецЕсли;
		
	Если ТекущийОбъект.Состояние = Перечисления.СостоянияСогласования.Отклонено Тогда
		ПредставлениеСостояния = НСтр("ru = 'Кандидат отклонен'");
		Элементы.ДатаРешения.Заголовок = НСтр("ru = 'Дата отклонения'");
		Элементы.ПричинаОтклонения.Видимость = ЗначениеЗаполнено(КандидатОбъект.ПричинаОтклонения);
		Элементы.СостояниеГруппа.ЦветТекстаЗаголовка = ЦветаСтиля.ПросроченныеДанныеЦвет;
	КонецЕсли;
	
	Элементы.СостояниеГруппа.Заголовок = ПредставлениеСостояния;
	
КонецПроцедуры

&НаСервере
Функция ПредставлениеРешенияОПриемеНаРаботу()

	// Решение о приеме на работу показываем в панели состояния только в период, 
	// когда этап Решение о приеме на работу уже пройден, 
	// а этап Прием на работу - напротив, еще не пройден.
	
	Индекс = РаботаСКандидатамиНаборЗаписей.Количество() - 1;
	Пока Индекс >= 0 Цикл
		СтрокаНабора = РаботаСКандидатамиНаборЗаписей[Индекс];
		Если СтрокаНабора.ЭтапРаботы = Перечисления.ЭтапыРаботыСКандидатами.ПриемНаРаботу Тогда
			Если СтрокаНабора.СостояниеЭтапа = Перечисления.СостоянияЭтаповРаботыСКандидатами.Пройден Тогда
				Возврат "";
			КонецЕсли;
		КонецЕсли;
		Если СтрокаНабора.ЭтапРаботы = Перечисления.ЭтапыРаботыСКандидатами.РешениеОПриемеНаРаботу Тогда
			Если СтрокаНабора.СостояниеЭтапа = Перечисления.СостоянияЭтаповРаботыСКандидатами.Пройден Тогда
				Если ЗначениеЗаполнено(СтрокаНабора.ДокументОснование) Тогда
					Возврат Новый ФорматированнаяСтрока(Строка(СтрокаНабора.ДокументОснование), , , , 
						ПолучитьНавигационнуюСсылку(СтрокаНабора.ДокументОснование));
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		Индекс = Индекс - 1;
	КонецЦикла;
	
	Возврат "";
	
КонецФункции

&НаСервере
Функция ПредставлениеСотрудника(ДатаПриема)

	Если Не УправлениеДоступом.ЧтениеРазрешено(Сотрудник) Тогда
		Возврат НСтр("ru = 'Информация недоступна'");
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ДатаПриема) Тогда
		Возврат "";
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	КадровыеДанные = КадровыйУчет.КадровыеДанныеСотрудника(Ложь, 
		Сотрудник, "Организация, ДолжностьПоШтатномуРасписанию", ДатаПриема);
	УстановитьПривилегированныйРежим(Ложь);
	Если КадровыеДанные = Неопределено Или Не ЗначениеЗаполнено(КадровыеДанные.Организация) Тогда
		Возврат НСтр("ru = 'Не удалось получить кадровые данные'");
	КонецЕсли;
	
	МужскойПол = НСтр("ru = 'Принят в %1 с %2 на позицию <a href=""%3"">%4</a>'");
	ЖенскийПол = НСтр("ru = 'Принята в %1 с %2 на позицию <a href=""%3"">%4</a>'");
	
	Возврат СтроковыеФункции.ФорматированнаяСтрока(
		?(ЭтоЖенскийПол(ЛичныеДанныеКандидата.Пол), ЖенскийПол, МужскойПол), 
		КадровыеДанные.Организация, 
		Формат(ДатаПриема, "ДЛФ=D"), 
		ПолучитьНавигационнуюСсылку(Сотрудник), 
		КадровыеДанные.ДолжностьПоШтатномуРасписанию)
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ЭтоЖенскийПол(Пол)
	Возврат Пол = ПредопределенноеЗначение("Перечисление.ПолФизическогоЛица.Женский");
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьДоступностьПозиции(Форма)
	
	КандидатОбъект = Форма.КандидатОбъект;
	Элементы = Форма.Элементы;
	
	Элементы.Позиция.Доступность = Не ЗначениеЗаполнено(КандидатОбъект.Вакансия);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьДоступностьПодразделения(Форма)
	
	КандидатОбъект = Форма.КандидатОбъект;
	Элементы = Форма.Элементы;
	
	Если ЗначениеЗаполнено(КандидатОбъект.Вакансия) 
		Или ЗначениеЗаполнено(КандидатОбъект.Позиция) Тогда
		Элементы.Подразделение.Доступность = Ложь;
	Иначе
		Элементы.Подразделение.Доступность = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСвязанныеОбъектыКандидата(ОбъектКандидат, ПараметрыЗаписи)
	
	СвязанныеОбъекты = Новый Структура();
	СвязанныеОбъекты.Вставить("ДанныеПубликацииРезюме", РеквизитФормыВЗначение("ДанныеПубликацииРезюмеНаборЗаписей"));
	Если ФайлРезюме <> Неопределено Тогда
		СвязанныеОбъекты.Вставить("ФайлРезюме", ФайлРезюме);
	КонецЕсли;
	ЗаполнитьКомментарииДляЗаписи(СвязанныеОбъекты);

	ЭтоЗаписьНовыхЛичныхДанныхКандидата = Не ОбщегоНазначения.СсылкаСуществует(ЛичныеДанныеКандидатаСсылка);
	Если ЛичныеДанныеКандидатаЗаблокированы Или ЭтоЗаписьНовыхЛичныхДанныхКандидата Тогда
		СвязанныеОбъекты.Вставить("ЛичныеДанныеКандидата", РеквизитФормыВЗначение("ЛичныеДанныеКандидата"));
		ЗаполнитьСвязанныеОбъектыЛичныхДанныхКандидата(СвязанныеОбъекты.ЛичныеДанныеКандидата);
		ПараметрыЗаписи.Вставить("ЭтоЗаписьНовыхЛичныхДанныхКандидата", ЭтоЗаписьНовыхЛичныхДанныхКандидата);
	КонецЕсли;
	
	ОбъектКандидат.ДополнительныеСвойства.Вставить("СвязанныеОбъекты", СвязанныеОбъекты);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСвязанныеОбъектыЛичныхДанныхКандидата(ОбъектЛичныеДанныеКандидата)

	УстановитьКонтактнуюИнформациюКандидата(ОбъектЛичныеДанныеКандидата);

	СвязанныеОбъекты = Новый Структура();
	
	Если ЗначениеЗаполнено(ФизическоеЛицоСсылка) Тогда
		СвязанныеОбъекты.Вставить("ФизическоеЛицоСсылка", ФизическоеЛицоСсылка);
	КонецЕсли;
	
	СвязанныеОбъекты.Вставить("АдресФотографии", АдресФотографии);
	
	ОбъектЛичныеДанныеКандидата.ДополнительныеСвойства.Вставить("СвязанныеОбъекты", СвязанныеОбъекты);
	ОбъектЛичныеДанныеКандидата.ДополнительныеСвойства.Вставить("ЛичныеДанныеКандидатаСсылка",
		ЛичныеДанныеКандидатаСсылка);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьКонтактнуюИнформациюКандидата(ОбъектЛичныеДанныеКандидата)
	
	КонтактнаяИнформация = УправлениеКонтактнойИнформацией.НоваяКонтактнаяИнформация(Ложь);
	
	// Телефон.
	СтрокаКИ = КонтактнаяИнформация.Добавить();
	СтрокаКИ.Вид = Справочники.ВидыКонтактнойИнформации.ТелефонЛичныеДанныеКандидатов;
	СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон;
	СтрокаКИ.Значение = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению(
		КонтактнаяИнформацияПолеТелефонЛичныеДанныеКандидатов,
		Справочники.ВидыКонтактнойИнформации.ТелефонЛичныеДанныеКандидатов);
	СтрокаКИ.Представление = КонтактнаяИнформацияПолеТелефонЛичныеДанныеКандидатов;
	
	// E-mail.
	СтрокаКИ = КонтактнаяИнформация.Добавить();
	СтрокаКИ.Вид = Справочники.ВидыКонтактнойИнформации.EMailЛичныеДанныеКандидатов;
	СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
	СтрокаКИ.Значение = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению(
		КонтактнаяИнформацияПолеEMailЛичныеДанныеКандидатов,
		Справочники.ВидыКонтактнойИнформации.EMailЛичныеДанныеКандидатов);
	СтрокаКИ.Представление = КонтактнаяИнформацияПолеEMailЛичныеДанныеКандидатов;
	
	// Адрес.
	СтрокаКИ = КонтактнаяИнформация.Добавить();
	СтрокаКИ.Вид = Справочники.ВидыКонтактнойИнформации.АдресЛичныеДанныеКандидатов;
	СтрокаКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Адрес;
	СтрокаКИ.Значение = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияПоПредставлению(
		КонтактнаяИнформацияПолеАдресЛичныеДанныеКандидатов,
		Справочники.ВидыКонтактнойИнформации.АдресЛичныеДанныеКандидатов);
	СтрокаКИ.Представление = КонтактнаяИнформацияПолеАдресЛичныеДанныеКандидатов;
	
	УправлениеКонтактнойИнформацией.УстановитьКонтактнуюИнформациюОбъекта(ОбъектЛичныеДанныеКандидата,
		КонтактнаяИнформация);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаблокироватьЛичныеДанныеКандидатаОбъектДляРедактирования()
	
	Если ЛичныеДанныеКандидатаЗаблокированы Тогда
		// Уже заблокирован.
		Возврат;
	КонецЕсли;
	
	ЗаблокироватьЛичныеДанныеКандидатаОбъектДляРедактированияНаСервере();
		
	Если ЛичныеДанныеКандидатаЗаблокированы Тогда
		Модифицированность = Истина;
		Возврат;
	КонецЕсли;
	
	// Не удалось заблокировать.
	ТекстПредупреждения = НСтр("ru = 'Не удается внести изменения в личные данные кандидата. 
                                |Возможно, личные данные этого кандидата редактируются другим пользователем.'");
	ПоказатьПредупреждение(, ТекстПредупреждения);
	
КонецПроцедуры

&НаСервере
Процедура РазблокироватьЛичныеДанныеКандидатаОбъектДляРедактирования()
	
	Если Не ЛичныеДанныеКандидатаЗаблокированы Тогда
		Возврат;
	КонецЕсли;
	
	РазблокироватьДанныеДляРедактирования(ЛичныеДанныеКандидатаСсылка, УникальныйИдентификатор);
	ЛичныеДанныеКандидатаЗаблокированы = Ложь;
	
КонецПроцедуры

&НаСервере
Процедура ЗаблокироватьЛичныеДанныеКандидатаОбъектДляРедактированияНаСервере()
	
	Попытка
		ЗаблокироватьДанныеДляРедактирования(ЛичныеДанныеКандидатаСсылка, ЛичныеДанныеКандидатаВерсияДанных,
			УникальныйИдентификатор);
		ЛичныеДанныеКандидатаЗаблокированы = Истина;
	Исключение
		ЛичныеДанныеКандидатаЗаблокированы = Ложь;
	КонецПопытки;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ОтобразитьРейтинг(Форма, Рейтинг)
	
	Элементы = Форма.Элементы;
	
	Для НомерЗвезды = 1 По 5 Цикл
		Страница = "Неактивная";
		Если НомерЗвезды <= Рейтинг Тогда
			Страница = "Активная";
		КонецЕсли;
		Если Элементы["Звезда" + НомерЗвезды + "Страницы"].ТекущаяСтраница <> Элементы["Звезда" + НомерЗвезды + "Страница" + Страница] Тогда
			Элементы["Звезда" + НомерЗвезды + "Страницы"].ТекущаяСтраница = Элементы["Звезда" + НомерЗвезды + "Страница" + Страница];
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьДоступностьРейтинга()
	
	Если Не ТолькоПросмотр Тогда
		Возврат;
	КонецЕсли;
	
	Для НомерЗвезды = 1 По 5 Цикл
		Элементы["Звезда_Неактивная_" + НомерЗвезды].Доступность = Ложь;
		Элементы["Звезда_Активная_" + НомерЗвезды].Доступность = Ложь;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОтображениеНадписей(ТекущийОбъект)
	
	ОтобразитьАдресРезюме();
	ПодборПерсоналаФормы.ФормаСубъектаПриПолученииДанныхНаСервере(ЭтотОбъект, ЛичныеДанныеКандидата);
	
КонецПроцедуры

&НаСервере
Процедура СкрытьКомандуСоздатьКандидата()
	Элементы.СоздатьКандидата.Видимость = Ложь;
КонецПроцедуры

&НаСервере
Процедура ПоказатьКомандуСоздатьКандидата()
	Элементы.СоздатьКандидата.Видимость = Истина;
КонецПроцедуры

&НаСервере
Функция РейтингДляОтображения(ТекущийОбъект)
	
	// Если есть общий рейтинг, показываем его.
	Если ТекущийОбъект.Рейтинг <> 0 Тогда
		Возврат ТекущийОбъект.Рейтинг;
	КонецЕсли;
	
	// Если нет, то ищем индивидуальный по пользователю.
	ИндивидуальнаяОценка = ИндивидуальнаяОценка(ТекущийОбъект.Оценки);
	Если ИндивидуальнаяОценка <> Неопределено Тогда
		Возврат ИндивидуальнаяОценка;
	КонецЕсли;
	
	Возврат 0;
	
КонецФункции

&НаСервере
Функция ИндивидуальнаяОценка(Оценки)
	
	СтрокаОценки = СтрокаИндивидуальнойОценки(Оценки, Пользователи.АвторизованныйПользователь());
	Если СтрокаОценки <> Неопределено Тогда
		Возврат СтрокаОценки.Оценка;
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция СтрокаИндивидуальнойОценки(Оценки, ТекущийПользователь)
	
	НайденныеСтроки = Оценки.НайтиСтроки(Новый Структура("Пользователь", ТекущийПользователь));
	Если НайденныеСтроки.Количество() > 0 Тогда
		Возврат НайденныеСтроки[0];
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура ЗаполнитьВозраст(Форма, ДатаВозраста)
	Форма.Возраст =	ФизическиеЛицаЗарплатаКадрыКлиентСервер.ПредставлениеВозраста(
		Форма.ЛичныеДанныеКандидата.ДатаРождения, ДатаВозраста);
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьНаименованиеКандидата()
	
	ФИО = Новый Структура("Фамилия, Имя, Отчество");
	ЗаполнитьЗначенияСвойств(ФИО, ЛичныеДанныеКандидата);
	
	КандидатОбъект.Наименование = Справочники.Кандидаты.НаименованиеКандидата(
		ФИО, 
		ЛичныеДанныеКандидата.УточнениеНаименования, 
		КандидатОбъект.УточнениеНаименования);
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьОднофамильцев()
	
	ПараметрыПоиска = СотрудникиКлиентСервер.ПараметрыПоискаПохожих();
	ЗаполнитьЗначенияСвойств(ПараметрыПоиска, ЛичныеДанныеКандидата, "Фамилия,Имя,Отчество");
	ПараметрыПоиска.Телефон = КонтактнаяИнформацияПолеТелефонЛичныеДанныеКандидатов;
	ПараметрыПоиска.EMail = КонтактнаяИнформацияПолеEMailЛичныеДанныеКандидатов;
	ПараметрыПоиска.ОбязательноЗаполненноеФИО = Ложь;
	ПоискФизЛиц = СотрудникиВызовСервера.ПодобратьСписокФизЛиц(ПараметрыПоиска);
	
	ПараметрыПоискаКандидатов = ПодборПерсоналаВызовСервера.ПараметрыПоискаПохожихКандидатов();
	ЗаполнитьЗначенияСвойств(ПараметрыПоискаКандидатов, ЛичныеДанныеКандидата,
		"Фамилия,Имя,Отчество,УточнениеНаименования");
	ПараметрыПоискаКандидатов.Ссылка = ЛичныеДанныеКандидатаСсылка;
	ПараметрыПоискаКандидатов.Телефон = СокрЛП(КонтактнаяИнформацияПолеТелефонЛичныеДанныеКандидатов);
	ПараметрыПоискаКандидатов.EMail = СокрЛП(КонтактнаяИнформацияПолеEMailЛичныеДанныеКандидатов);
	ПоискКандидатов = ПодборПерсоналаВызовСервера.ПодобратьПохожихКандидатов(ПараметрыПоискаКандидатов, Истина);
		
	Если ПоискКандидатов.КандидатУникален И ПоискФизЛиц.ФизическоеЛицоУникально Тогда
		Возврат;
	КонецЕсли;
	
	КоличествоНайденных = ПоискФизЛиц.ДанныеФизическихЛиц.Количество() + ПоискКандидатов.ДанныеКандидатов.Количество();
	
	Если КоличествоНайденных = 0 Тогда
		ТекстПредупреждения = 
			НСтр("ru = 'Найдены похожие люди, но один или несколько человек недоступны из-за ограничений прав доступа.
                  |Если заполнены только фамилия или имя, попробуйте ввести ФИО полностью, укажите телефон и адрес почты.
                  |Если проблема сохраняется, обратитесь, пожалуйста, к администратору.'");
		ПоказатьПредупреждение(, ТекстПредупреждения);
		Возврат;
	КонецЕсли;
	
	ПараметрыОткрытия = СотрудникиКлиент.ПараметрыОткрытияФормыФизическиеЛицаСПохожимиДанными(ПоискФизЛиц);
	ЗаполнитьЗначенияСвойств(ПараметрыОткрытия, ПоискКандидатов,
		"КандидатУникален, ДанныеКандидатов, ДанныеКандидатовДоступны");
	
	Оповещение = Новый ОписаниеОповещения("ПроверкаОднофамильцевЗавершение", ЭтотОбъект);
	ОткрытьФорму(
		"Справочник.ФизическиеЛица.Форма.ФизическиеЛицаСПохожимиДанными", 
		ПараметрыОткрытия, 
		ЭтотОбъект, , , , 
		Оповещение, 
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаОднофамильцевЗавершение(РезультатВыбора, ДополнительныеПараметры) Экспорт 
	
	Если РезультатВыбора = Неопределено Тогда
		ЗаполнитьПредставлениеОпытаРаботы();
		Возврат;
	КонецЕсли;
	
	Если РезультатВыбора.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(РезультатВыбора) = Тип("СправочникСсылка.ЛичныеДанныеКандидатов") Тогда
		ЛичныеДанныеКандидатаСсылка = РезультатВыбора;
		КандидатОбъект.ЛичныеДанные = РезультатВыбора;
		ПрочитатьЛичныеДанныеКандидатаОбъект();
	ИначеЕсли ТипЗнч(РезультатВыбора) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
		ФизическоеЛицоСсылка = РезультатВыбора;
		ЗаполнитьОбъектЛичныеДанныеКандидатаПоФизЛицу(РезультатВыбора);
	Иначе
		ОбщегоНазначенияКлиентСервер.Проверить(Ложь, НСтр("ru = 'Не корректный тип результата проверки однофамильцев'"),
			"ПроверкаОднофамильцевЗавершение");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция АдресДанныхДополнительнойФормыНаСервере(ОписаниеДополнительнойФормы) Экспорт
	Возврат СотрудникиФормы.АдресДанныхДополнительнойФормы(ОписаниеДополнительнойФормы, ЭтотОбъект);
КонецФункции

&НаСервере
Процедура ПрочитатьДанныеИзХранилищаВФормуНаСервере(Параметр) Экспорт
	
	СотрудникиФормы.ПрочитатьДанныеИзХранилищаВФорму(
		ЭтотОбъект,
		СотрудникиКлиентСервер.ОписаниеДополнительнойФормы(Параметр.ИмяФормы),
		Параметр.АдресВХранилище);
	
КонецПроцедуры

&НаСервере
Процедура ФИОПриИзмененииНаСервере()

	СтруктураФИО = ФизическиеЛицаКлиентСервер.ЧастиИмени(ЛичныеДанныеКандидата.ФИО);
	
	ЛичныеДанныеКандидата.Фамилия = СтруктураФИО.Фамилия;
	Если СтруктураФИО.Имя <> Неопределено Тогда
		ЛичныеДанныеКандидата.Имя = СтруктураФИО.Имя;
	КонецЕсли;
	Если СтруктураФИО.Отчество <> Неопределено Тогда
		ЛичныеДанныеКандидата.Отчество = СтруктураФИО.Отчество;
	КонецЕсли;
	
	ЛичныеДанныеКандидатаОбъект = РеквизитФормыВЗначение("ЛичныеДанныеКандидата");
	ЛичныеДанныеКандидатаОбъект.ЗаполнитьНаименованиеПоФИО();
	Если Не ЗначениеЗаполнено(ЛичныеДанныеКандидатаОбъект.Пол) Тогда
		ЛичныеДанныеКандидатаОбъект.УстановитьПолПоОтчеству();
	КонецЕсли;
	
	ЗначениеВРеквизитФормы(ЛичныеДанныеКандидатаОбъект, "ЛичныеДанныеКандидата");
	
	ЗаполнитьНаименованиеКандидата();
	ЗаполнитьПредставлениеОпытаРаботы();
		
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьЛичныеДанныеКандидата(СтруктураЗаполнения, ЭтоДругойКандидатФизЛица = Ложь)
	
	ЗаблокироватьЛичныеДанныеКандидатаОбъектДляРедактированияНаСервере();
	
	Если Не ЭтоДругойКандидатФизЛица Тогда
		Если СтруктураЗаполнения.Свойство("Фамилия") Или СтруктураЗаполнения.Свойство("Имя")
			Или СтруктураЗаполнения.Свойство("Отчество") Тогда
				
			ЛичныеДанныеКандидата.ФИО =
				?(СтруктураЗаполнения.Свойство("Фамилия") И ЗначениеЗаполнено(СтруктураЗаполнения.Фамилия),
					СтруктураЗаполнения.Фамилия, "")
				+ ?(СтруктураЗаполнения.Свойство("Имя") И ЗначениеЗаполнено(СтруктураЗаполнения.Имя),
					" " + СтруктураЗаполнения.Имя, "")
				+ ?(СтруктураЗаполнения.Свойство("Отчество") И ЗначениеЗаполнено(СтруктураЗаполнения.Отчество),
					" " + СтруктураЗаполнения.Отчество, "");
					
		КонецЕсли; 
		
		Если Не ЗначениеЗаполнено(ЛичныеДанныеКандидата.ФИО) Тогда
			ЛичныеДанныеКандидата.ФИО = "";
		КонецЕсли;
		
		ФИОПриИзмененииНаСервере();
		
	КонецЕсли;
	
	Если СтруктураЗаполнения.Свойство("КонтактнаяИнформация") 
				И ЗначениеЗаполнено(СтруктураЗаполнения.КонтактнаяИнформация) Тогда
				
		Для Каждого КонтактнаяИнформацияСтрока Из СтруктураЗаполнения.КонтактнаяИнформация Цикл
			
			Если КонтактнаяИнформацияСтрока.Вид = ОбщегоНазначения.ПредопределенныйЭлемент(
				"Справочник.ВидыКонтактнойИнформации.ТелефонЛичныеДанныеКандидатов") Тогда
				КонтактнаяИнформацияПолеТелефонЛичныеДанныеКандидатов = КонтактнаяИнформацияСтрока.Представление;
			КонецЕсли;
			
			Если КонтактнаяИнформацияСтрока.Вид = ОбщегоНазначения.ПредопределенныйЭлемент(
				"Справочник.ВидыКонтактнойИнформации.EMailЛичныеДанныеКандидатов") Тогда
				КонтактнаяИнформацияПолеEMailЛичныеДанныеКандидатов = КонтактнаяИнформацияСтрока.Представление;
			КонецЕсли; 
			
			Если КонтактнаяИнформацияСтрока.Вид = ОбщегоНазначения.ПредопределенныйЭлемент(
				"Справочник.ВидыКонтактнойИнформации.АдресЛичныеДанныеКандидатов") Тогда
				КонтактнаяИнформацияПолеАдресЛичныеДанныеКандидатов = КонтактнаяИнформацияСтрока.Представление;
			КонецЕсли;
			
		КонецЦикла;
	КонецЕсли; 
	
КонецПроцедуры

&НаСервере
Процедура ОтобразитьАдресРезюме()
	
	ЧастиСтроки = Новый Массив;
	ЧастиСтроки.Добавить(Новый ФорматированнаяСтрока(КандидатОбъект.АдресРезюме, , , , КандидатОбъект.АдресРезюме));
	
	Элементы.АдресРезюме.Заголовок = Новый ФорматированнаяСтрока(ЧастиСтроки);
	
КонецПроцедуры

&НаКлиенте
Процедура МногострочныйЭлементНачалоВыбора(ИмяТаблицыФормы, ИмяПоля, СтандартнаяОбработка, Подсказка = Неопределено)

	ТекущиеДанные = Элементы[ИмяТаблицыФормы].ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	СтандартнаяОбработка = Ложь;

	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ТекущиеДанные", ТекущиеДанные);
	ДополнительныеПараметры.Вставить("ИмяПоля", ИмяПоля);

	Оповещение = Новый ОписаниеОповещения("МногострочныйЭлементНачалоВыбораЗавершение", ЭтотОбъект,
		ДополнительныеПараметры);
	
	Если Подсказка = Неопределено Тогда
		ПоказатьВводСтроки(Оповещение, ТекущиеДанные[ИмяПоля], , , Истина);
	Иначе
		ПоказатьВводСтроки(Оповещение, ТекущиеДанные[ИмяПоля], Подсказка, , Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура МногострочныйЭлементНачалоВыбораЗавершение(Строка, ДополнительныеПараметры) Экспорт
	
	Если Строка = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеПараметры.ТекущиеДанные[ДополнительныеПараметры.ИмяПоля] = Строка;
		
КонецПроцедуры

&НаСервереБезКонтекста
Функция АнкетыПоЭтапам(Кандидат, Вакансия)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Кандидат", Кандидат);
	Запрос.УстановитьПараметр("Вакансия", Вакансия);
	Запрос.Текст =
		"ВЫБРАТЬ
		|	АнкетыКандидатов.ЭтапРаботыСКандидатом КАК ЭтапРаботы,
		|	АнкетыКандидатов.Анкета КАК Анкета,
		|	АнкетыКандидатов.Анкета.Проведен КАК ТолькоПросмотр
		|ИЗ
		|	РегистрСведений.АнкетыКандидатов КАК АнкетыКандидатов
		|ГДЕ
		|	АнкетыКандидатов.Вакансия = &Вакансия
		|	И АнкетыКандидатов.Кандидат = &Кандидат";

	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура РассчитатьСреднийРейтинг(Форма)
	
	КандидатОбъект = Форма.КандидатОбъект;
	ВсегоОценок = КандидатОбъект.Оценки.Количество();
	
	Если ВсегоОценок < 1 Тогда
		Форма.Элементы.НадписьАгрегированнаяОценка.Заголовок = Неопределено;
		Возврат;
	КонецЕсли;
	
	СреднийРейтинг = СреднийРейтинг(Форма, ВсегоОценок);
	
	Форма.Элементы.НадписьАгрегированнаяОценка.Заголовок = СтрШаблон(
		НСтр("ru = 'Средняя: %1, всего оценок %2'"), Окр(СреднийРейтинг, 2), ВсегоОценок);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция СреднийРейтинг(Форма, ВсегоОценок = Неопределено)
	
	Если ВсегоОценок = Неопределено Тогда
		ВсегоОценок = Форма.КандидатОбъект.Оценки.Количество();
	КонецЕсли;
	
	Если ВсегоОценок = 0 Тогда
		Возврат 0;
	КонецЕсли;
	
	Возврат Форма.КандидатОбъект.Оценки.Итог("Оценка") / ВсегоОценок;
	
КонецФункции

