&НаКлиенте
Процедура ПоказатьВопросПоКонтактногоДоступа(Сайт, СкрытыеКонтактыПредставление)
	
	ТекстВопроса = РекрутинговыеСайтыКлиент.ТекстВопросаПоКонтактногоДоступа(Сайт);
	Если Не ЗначениеЗаполнено(ТекстВопроса) Тогда
		Возврат;
	КонецЕсли;
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("Сайт", Сайт);
	ДополнительныеПараметры.Вставить("СкрытыеКонтактыПредставление", СкрытыеКонтактыПредставление);
	
	Оповещение = Новый ОписаниеОповещения("ВопросПоКонтактногоДоступаЗавершение", ЭтотОбъект, ДополнительныеПараметры);

	Если РекрутинговыеСайтыКлиент.БольшеНеЗадаватьВопросПоКонтактногоДоступа(Сайт) Тогда
		ПоказатьВопросСкрытыеКонтакты(СкрытыеКонтактыПредставление);
		Возврат;
	КонецЕсли;
	
	КнопкиВопроса = Новый СписокЗначений;
	КнопкиВопроса.Добавить(КодВозвратаДиалога.Да, НСтр("ru = 'Продолжить'"));
	КнопкиВопроса.Добавить(КодВозвратаДиалога.Отмена, НСтр("ru = 'Отмена'"));
	
	ДопПараметры = СтандартныеПодсистемыКлиент.ПараметрыВопросаПользователю();
	ДопПараметры.Заголовок = НСтр("ru = 'Получение ФИО и контактов'");
	ДопПараметры.Картинка = БиблиотекаКартинок.Информация32;
	ДопПараметры.ПредлагатьБольшеНеЗадаватьЭтотВопрос = Истина;
	
	СтандартныеПодсистемыКлиент.ПоказатьВопросПользователю(Оповещение, ТекстВопроса, КнопкиВопроса, ДопПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросПоКонтактногоДоступаЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если Не ЗначениеЗаполнено(РезультатВопроса) Тогда
		Возврат;
	КонецЕсли;
	
	Если Не РезультатВопроса.Значение = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	Если РезультатВопроса.БольшеНеЗадаватьЭтотВопрос Тогда
		РекрутинговыеСайтыКлиент.СохранитьБольшеНеЗадаватьВопросПоКонтактногоДоступа(ДополнительныеПараметры.Сайт);
	КонецЕсли;
	
	ПоказатьВопросСкрытыеКонтакты(ДополнительныеПараметры.СкрытыеКонтактыПредставление);
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьВопросСкрытыеКонтакты(СкрытыеКонтактыПредставление)
	
	Если Не ЗначениеЗаполнено(СкрытыеКонтактыПредставление) Тогда
		ЗавершитьВопросПоКонтактногоДоступа(Истина);
		Возврат;
	КонецЕсли;
	
	Оповещение = Новый ОписаниеОповещения("ВопросСкрытыеКонтактыЗавершение", ЭтотОбъект);
	
	ТекстВопроса = НСтр("ru = 'Этот кандидат скрыл %1.
		|При продолжении будут получены все данные, кроме этих сведений.'");
	ТекстВопроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстВопроса, СкрытыеКонтактыПредставление);
	
	КнопкиВопроса = Новый СписокЗначений;
	КнопкиВопроса.Добавить(КодВозвратаДиалога.Да, НСтр("ru = 'Продолжить'"));
	КнопкиВопроса.Добавить(КодВозвратаДиалога.Отмена, НСтр("ru = 'Отмена'"));
	
	ДопПараметры = СтандартныеПодсистемыКлиент.ПараметрыВопросаПользователю();
	ДопПараметры.Заголовок = НСтр("ru = 'Скрытые контакты'");
	ДопПараметры.Картинка = БиблиотекаКартинок.Предупреждение32;
	ДопПараметры.ПредлагатьБольшеНеЗадаватьЭтотВопрос = Ложь;
	
	СтандартныеПодсистемыКлиент.ПоказатьВопросПользователю(Оповещение, ТекстВопроса, КнопкиВопроса, ДопПараметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ВопросСкрытыеКонтактыЗавершение(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если Не РезультатВопроса.Значение = КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	ЗавершитьВопросПоКонтактногоДоступа(Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьВопросПоКонтактногоДоступа(Результат)
	
	Если Не Результат = Истина Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьКонтактыСРекрутинговогоСайта();
	ПроверитьОднофамильцев();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьКонтактыСРекрутинговогоСайта()
	
	КонтактыРезюме = РекрутинговыеСайты.КонтактыРезюме(КандидатОбъект.ИсточникИнформации, КандидатОбъект.АдресРезюме);
	
	КонтактнаяИнформация = Новый Массив;
	
	СтруктураЗаполнения = Новый Структура;
	СтруктураЗаполнения.Вставить("Фамилия", "");
	СтруктураЗаполнения.Вставить("Имя", "");
	СтруктураЗаполнения.Вставить("Отчество", "");
	СтруктураЗаполнения.Вставить("КонтактнаяИнформация", КонтактнаяИнформация);
	
	ЗаполнитьЛичныеДанныеКандидата = Ложь;
	
	Если ЗначениеЗаполнено(КонтактыРезюме.Фамилия) Тогда
		СтруктураЗаполнения.Фамилия = КонтактыРезюме.Фамилия;
		ЗаполнитьЛичныеДанныеКандидата = Истина;
	КонецЕсли;
	Если ЗначениеЗаполнено(КонтактыРезюме.Имя) Тогда
		СтруктураЗаполнения.Имя = КонтактыРезюме.Имя;
		ЗаполнитьЛичныеДанныеКандидата = Истина;
	КонецЕсли;
	Если ЗначениеЗаполнено(КонтактыРезюме.Отчество) Тогда
		СтруктураЗаполнения.Отчество = КонтактыРезюме.Отчество;
		ЗаполнитьЛичныеДанныеКандидата = Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КонтактыРезюме.Телефон) Тогда
		СтруктураТелефон = Новый Структура;
		СтруктураТелефон.Вставить("Вид", ОбщегоНазначения.ПредопределенныйЭлемент(
			"Справочник.ВидыКонтактнойИнформации.ТелефонЛичныеДанныеКандидатов"));
		СтруктураТелефон.Вставить("Представление", КонтактыРезюме.Телефон);
		КонтактнаяИнформация.Добавить(СтруктураТелефон);
		ЗаполнитьЛичныеДанныеКандидата = Истина;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КонтактыРезюме.ЭлектроннаяПочта) Тогда
		СтруктураЭлектроннаяПочта = Новый Структура;
		СтруктураЭлектроннаяПочта.Вставить("Вид", ОбщегоНазначения.ПредопределенныйЭлемент(
			"Справочник.ВидыКонтактнойИнформации.EMailЛичныеДанныеКандидатов"));
		СтруктураЭлектроннаяПочта.Вставить("Представление", КонтактыРезюме.ЭлектроннаяПочта);
		КонтактнаяИнформация.Добавить(СтруктураЭлектроннаяПочта);
		ЗаполнитьЛичныеДанныеКандидата = Истина;
	КонецЕсли;
	
	Если ЗаполнитьЛичныеДанныеКандидата Тогда
		ЗаполнитьЛичныеДанныеКандидата(СтруктураЗаполнения);
		Элементы.ПолучитьКонтакты.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьДоступностьКонтактов()
	
	Элементы.ПолучитьКонтакты.Видимость = Ложь;
	
	Если Не ЗначениеЗаполнено(КандидатОбъект.ИсточникИнформации) Или Не ЗначениеЗаполнено(КандидатОбъект.АдресРезюме) Тогда
		Возврат;
	КонецЕсли;
	
	ДлительнаяОперация = ДлительнаяОперацияПроверкиДоступностиКонтактов(УникальныйИдентификатор, 
		КандидатОбъект.ИсточникИнформации, КандидатОбъект.АдресРезюме);
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	
	Оповещение = Новый ОписаниеОповещения("ПослеПроверкиДоступностиКонтактов", ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, Оповещение, ПараметрыОжидания);
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеПроверкиДоступностиКонтактов(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		ТекстОшибки = НСтр("ru = 'Произошла ошибка при проверке доступности получения контактов кандидата с рекрутингового сайта.
				|См. подробности в Журнале регистрации.'");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки);
		Возврат;
	КонецЕсли;
	
	ДоступностьКонтактов = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
	УстановитьВидимостьПолученияКонтактов(ЭтотОбъект, ДоступностьКонтактов);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьВидимостьПолученияКонтактов(Форма, ДоступностьКонтактов)

	Форма.Элементы.ПолучитьКонтакты.Видимость = Не ДоступностьКонтактов.КонтактыОткрыты;
	Форма.СкрытыеКонтактыПредставление = СтрСоединить(ДоступностьКонтактов.СкрытыеКандидатомКонтакты, ", ");
	
	Форма.Элементы.ПолучитьКонтакты.РасширеннаяПодсказка.Заголовок = Неопределено;
	Если Не ДоступностьКонтактов.КонтактыОткрыты И Не ПустаяСтрока(ДоступностьКонтактов.КонтактыМожноОткрытьПоАдресу) Тогда
		Форма.Элементы.ПолучитьКонтакты.РасширеннаяПодсказка.Заголовок = 
			НСтр("ru = 'Для открытия контактов кандидата необходимо приобрести доступ к базе резюме.
				 |Подробности в личном кабинете рекрутингового сайта.'");
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ДлительнаяОперацияПроверкиДоступностиКонтактов(ИдентификаторФормы, Сайт, АдресРезюме)
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(ИдентификаторФормы);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = НСтр("ru = 'Определение доступности контактов резюме'");
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения,
		"РекрутинговыеСайты.ДоступныеДляПолученияКонтакты", Сайт, АдресРезюме);
	
КонецФункции

#КонецОбласти

#Область ОжидаемыйДоход

&НаКлиентеНаСервереБезКонтекста
Процедура СохранитьОжидаемыйДоход(Форма, ОжидаемыйДоход, ВалютаДохода, ПериодичностьДохода)
	
	НоваяСтрока = Форма.ИсторияОжидаемогоДохода.Добавить();
	НоваяСтрока.ОжидаемыйДоход = ОжидаемыйДоход;
	НоваяСтрока.ВалютаДохода = ВалютаДохода;
	НоваяСтрока.ПериодичностьДохода = ПериодичностьДохода;
	
КонецПроцедуры

&НаКлиенте
Функция ОжидаемыйДоходВИстории(ВалютаДохода, ПериодичностьДохода)
	
	Отбор = Новый Структура;
	Отбор.Вставить("ВалютаДохода", ВалютаДохода);
	Отбор.Вставить("ПериодичностьДохода", ПериодичностьДохода);
	Строки = ИсторияОжидаемогоДохода.НайтиСтроки(Отбор);
	
	ОжидаемыйДоход = Неопределено;
	Для Каждого НоваяСтрока Из Строки Цикл
		ОжидаемыйДоход = НоваяСтрока.ОжидаемыйДоход;
	КонецЦикла;
	
	Возврат ОжидаемыйДоход;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура ОтобразитьОжидаемыйДоходПоУмолчанию(Форма, КандидатОбъект = Неопределено)
	
	Если КандидатОбъект = Неопределено Тогда
		КандидатОбъект = Форма.КандидатОбъект;
	КонецЕсли;

	Элементы = Форма.Элементы;
	
	Если КандидатОбъект.ОжидаемыйДоход = 0 Тогда
		Элементы.ОжидаемыйДоходВВалютеПоУмолчанию.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	ВалютаПоУмолчанию = ЗарплатаКадрыВызовСервера.ВалютаУчетаЗаработнойПлаты();
	
	Если КандидатОбъект.ВалютаДохода = ВалютаПоУмолчанию Тогда
		Элементы.ОжидаемыйДоходВВалютеПоУмолчанию.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Сумма = ПодборПерсоналаКлиентСервер.СуммаВВалютеПоУмолчанию(КандидатОбъект.ОжидаемыйДоход, КандидатОбъект.ВалютаДохода);
	Если Сумма = КандидатОбъект.ОжидаемыйДоход Тогда
		Элементы.ОжидаемыйДоходВВалютеПоУмолчанию.Видимость = Ложь;
	Иначе
		Форма.ОжидаемыйДоходВВалютеПоУмолчанию = ПодборПерсоналаКлиентСервер.ПредставлениеОжидаемогоДохода(Сумма, ВалютаПоУмолчанию);
		Элементы.ОжидаемыйДоходВВалютеПоУмолчанию.Видимость = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция СвойствоСтруктуры(Структура, Ключ, ЗначениеПоУмолчанию = Неопределено)
	
	ЧастиКлюча = СтрРазделить(Ключ, ".");
	ВложеннаяСтруктура = Структура;
	Для Каждого ЧастьКлюча Из ЧастиКлюча Цикл
		Значение = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ВложеннаяСтруктура, ЧастьКлюча, ЗначениеПоУмолчанию);
		Если Значение = Неопределено Тогда
			Возврат ЗначениеПоУмолчанию;
		КонецЕсли;
		ВложеннаяСтруктура = Значение;
	КонецЦикла;

	Возврат Значение;
	
КонецФункции

#КонецОбласти

#Область ОтображениеТабличныхЧастейЛичныхДанныхКанидата

&НаСервере
Процедура ЗаполнитьОбразованиеКвалификацию(ЭтоДругойКандидатФизЛица = Ложь)
	
	ЗаполнитьПредставлениеОбразования();
	ЗаполнитьПредставлениеКурсов();
	ЗаполнитьПредставлениеЗнаниеЯзыков();
	ЗаполнитьПредставлениеУченыеСтепени();
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОтображениеЗаписиТабличнойЧасти(ИмяТабличнойЧасти, НомерЗаписи)
	
	КоличествоСтрок = ЛичныеДанныеКандидата[ИмяТабличнойЧасти].Количество();
	
	Видимость = КоличествоСтрок > НомерЗаписи - 1;
	ВидимостьИзменить = КоличествоСтрок > НомерЗаписи - 2;
	
	ИмяЭлементаПредставление = СтрШаблон("%1Представление_%2", ИмяТабличнойЧасти, НомерЗаписи);
	ИмяКнопкиИзменить = СтрШаблон("%1ЗаписьИзменить_%2", ИмяТабличнойЧасти, НомерЗаписи);
	ИмяКнопкиУдалить = СтрШаблон("%1ЗаписьУдалить_%2", ИмяТабличнойЧасти, НомерЗаписи);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, ИмяЭлементаПредставление, "Видимость",
		Видимость);
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, ИмяКнопкиИзменить, "Видимость",
		ВидимостьИзменить);
	Если Не Видимость И ВидимостьИзменить Тогда
		ЗаголовокКнопкиИзменить = "Добавить";
		КартинкаКнопкиИзменить = БиблиотекаКартинок.ДобавитьЭлементСписка;
		ГоризонтальноеПоложениеКнопкиИзменить = ГоризонтальноеПоложениеЭлемента.Лево;
	Иначе
		ЗаголовокКнопкиИзменить = "Изменить";
		КартинкаКнопкиИзменить = БиблиотекаКартинок.Изменить;
		ГоризонтальноеПоложениеКнопкиИзменить = ГоризонтальноеПоложениеЭлемента.Право;
	КонецЕсли;
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, ИмяКнопкиИзменить, "Заголовок",
		ЗаголовокКнопкиИзменить);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, ИмяКнопкиИзменить, "Картинка",
		КартинкаКнопкиИзменить);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, ИмяКнопкиИзменить,
		"ГоризонтальноеПоложениеВГруппе", ГоризонтальноеПоложениеКнопкиИзменить);
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, ИмяКнопкиУдалить, "Видимость", Ложь);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьОтображениеТабличнойЧасти(ИмяТабличнойЧасти, ИмяГруппы)
	
	УстановитьОтображениеЗаписиТабличнойЧасти(ИмяТабличнойЧасти, 1);
	УстановитьОтображениеЗаписиТабличнойЧасти(ИмяТабличнойЧасти, 2);
	УстановитьОтображениеЗаписиТабличнойЧасти(ИмяТабличнойЧасти, 3);
	
	ГруппаВидимость = ЛичныеДанныеКандидата[ИмяТабличнойЧасти].Количество() > 2;
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, ИмяГруппы, "Видимость", ГруппаВидимость);
	Если Не ГруппаВидимость Тогда
		Элементы[ИмяГруппы].Скрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПредставлениеТабличнойЧасти(ИмяТабличнойЧасти)
	
	Если ИмяТабличнойЧасти = "Образование" Тогда
		ЗаполнитьПредставлениеОбразования();
	ИначеЕсли ИмяТабличнойЧасти = "Курсы" Тогда
		ЗаполнитьПредставлениеКурсов();
	ИначеЕсли ИмяТабличнойЧасти = "ЗнаниеЯзыков" Тогда
		ЗаполнитьПредставлениеЗнаниеЯзыков();
	ИначеЕсли ИмяТабличнойЧасти = "УченыеСтепени" Тогда
		ЗаполнитьПредставлениеУченыеСтепени();
	Иначе
		ОбщегоНазначенияКлиентСервер.Проверить(Ложь,
			СтрШаблон(НСтр("ru = 'Неизвестное имя табличной части %1'"), ИмяТабличнойЧасти),
			"ЗаполнитьПредставлениеТабличнойЧасти");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПредставлениеЗнаниеЯзыков()
	
	ИдентификаторСтрокиЗнаниеЯзыков1 = ИдентификаторНовойСтроки();
	ИдентификаторСтрокиЗнаниеЯзыков2 = ИдентификаторНовойСтроки();
	ИдентификаторСтрокиЗнаниеЯзыков3 = ИдентификаторНовойСтроки();
	
	Для Каждого СтрокаТаблицы Из ЛичныеДанныеКандидата.ЗнаниеЯзыков Цикл
		Представление = ПредставлениеЗаписиОЗнанииЯзыков(СтрокаТаблицы);
		СтрокаТаблицы.Представление = Представление;
		Если СтрокаТаблицы.НомерСтроки <= 3 Тогда
			Элементы["ЗнаниеЯзыковПредставление_" + СтрокаТаблицы.НомерСтроки].Заголовок = Представление;
			ЭтотОбъект["ИдентификаторСтрокиЗнаниеЯзыков" + СтрокаТаблицы.НомерСтроки] =
				СтрокаТаблицы.ПолучитьИдентификатор();
		КонецЕсли;
	КонецЦикла;
	
	УстановитьОтображениеТабличнойЧасти("ЗнаниеЯзыков", "ЗнаниеЯзыковИзменитьГруппа");

КонецПроцедуры

&НаСервере
Функция ПредставлениеЗаписиОЗнанииЯзыков(СтрокаТаблицы)
	
	ПредставлениеЗаписи = "";
	
	Если ЗначениеЗаполнено(СтрокаТаблицы.Язык) Тогда
		ПредставлениеЗаписи = ПредставлениеЗаписи + Строка(СтрокаТаблицы.Язык);
		Если ЗначениеЗаполнено(СтрокаТаблицы.СтепеньЗнанияЯзыкаКандидата) Тогда
			СтепеньЗнанияЯзыкаКандидата = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(
				СтрокаТаблицы.СтепеньЗнанияЯзыкаКандидата, "Наименование");
			ПредставлениеЗаписи = СтрШаблон(НСтр("ru = '%1 (%2)'"), ПредставлениеЗаписи, СтепеньЗнанияЯзыкаКандидата);
		КонецЕсли;
	КонецЕсли;
	
	Возврат СтрШаблон(НСтр("ru = '%1'"), ПредставлениеЗаписи);
	
КонецФункции

&НаСервере
Процедура ЗаполнитьПредставлениеОбразования()

	ИдентификаторСтрокиОбразование1 = ИдентификаторНовойСтроки();
	ИдентификаторСтрокиОбразование2 = ИдентификаторНовойСтроки();
	ИдентификаторСтрокиОбразование3 = ИдентификаторНовойСтроки();
	
	ЛичныеДанныеКандидата.Образование.Сортировать("ГодОкончания");
	
	НаименованияСпециальностей = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(
		ЛичныеДанныеКандидата.Образование.Выгрузить().ВыгрузитьКолонку("Специальность"), "Наименование");
	
	Для Каждого СтрокаТаблицы Из ЛичныеДанныеКандидата.Образование Цикл
		Представление = ПредставлениеЗаписиОбОбразовании(СтрокаТаблицы,
			НаименованияСпециальностей.Получить(СтрокаТаблицы.Специальность));
		СтрокаТаблицы.Представление = Представление;
		Если СтрокаТаблицы.НомерСтроки <= 3 Тогда
			Элементы["ОбразованиеПредставление_" + СтрокаТаблицы.НомерСтроки].Заголовок = Представление;
			ЭтотОбъект["ИдентификаторСтрокиОбразование" + СтрокаТаблицы.НомерСтроки] =
				СтрокаТаблицы.ПолучитьИдентификатор();
		КонецЕсли;
	КонецЦикла;
	
	УстановитьОтображениеТабличнойЧасти("Образование", "ОбразованиеИзменитьГруппа");

КонецПроцедуры

&НаСервере
Функция ПредставлениеЗаписиОбОбразовании(СтрокаТаблицы, НаименованиеСпециальности)
	
	ПредставлениеЗаписи = "";
	Если ЗначениеЗаполнено(СтрокаТаблицы.ВидОбразования) Тогда
		ПредставлениеЗаписи = ПредставлениеЗаписи + СтрокаТаблицы.ВидОбразования + ", ";
	КонецЕсли;
	Если ЗначениеЗаполнено(СтрокаТаблицы.УчебноеЗаведение) Тогда
		ПредставлениеЗаписи = ПредставлениеЗаписи + СтрокаТаблицы.УчебноеЗаведение + ", ";
	КонецЕсли;
	Если ЗначениеЗаполнено(СтрокаТаблицы.ГодОкончания) Тогда
		ПредставлениеЗаписи = ПредставлениеЗаписи + Формат((СтрокаТаблицы.ГодОкончания), "ЧГ=") + " г., ";
	КонецЕсли;
	Если ЗначениеЗаполнено(НаименованиеСпециальности) Тогда
		ПредставлениеЗаписи = ПредставлениеЗаписи + НаименованиеСпециальности + ", ";
	КонецЕсли;
	
	СтроковыеФункцииКлиентСервер.УдалитьПоследнийСимволВСтроке(ПредставлениеЗаписи, 2);
	
	Возврат СтрШаблон(НСтр("ru = '%1'"), ПредставлениеЗаписи);
	
КонецФункции

&НаСервере
Процедура ЗаполнитьПредставлениеКурсов()

	ИдентификаторСтрокиКурсы1 = ИдентификаторНовойСтроки();
	ИдентификаторСтрокиКурсы2 = ИдентификаторНовойСтроки();
	ИдентификаторСтрокиКурсы3 = ИдентификаторНовойСтроки();
	
	ЛичныеДанныеКандидата.Курсы.Сортировать("ГодОкончания");
	
	Для Каждого СтрокаТаблицы Из ЛичныеДанныеКандидата.Курсы Цикл
		Представление = ПредставлениеЗаписиОКурсе(СтрокаТаблицы);
		СтрокаТаблицы.Представление = Представление;
		Если СтрокаТаблицы.НомерСтроки <= 3 Тогда
			Элементы["КурсыПредставление_" + СтрокаТаблицы.НомерСтроки].Заголовок = Представление;
			ЭтотОбъект["ИдентификаторСтрокиКурсы" + СтрокаТаблицы.НомерСтроки] = СтрокаТаблицы.ПолучитьИдентификатор();
		КонецЕсли;
	КонецЦикла;
	
	УстановитьОтображениеТабличнойЧасти("Курсы", "КурсыИзменитьГруппа");

КонецПроцедуры

&НаСервере
Функция ПредставлениеЗаписиОКурсе(СтрокаТаблицы)
	
	ПредставлениеЗаписи = "";
	
	Если ЗначениеЗаполнено(СтрокаТаблицы.НаименованиеКурса) Тогда
		ПредставлениеЗаписи = ПредставлениеЗаписи + СтрокаТаблицы.НаименованиеКурса + ", ";
	КонецЕсли;
	Если ЗначениеЗаполнено(СтрокаТаблицы.УчебноеЗаведение) Тогда
		ПредставлениеЗаписи = ПредставлениеЗаписи + СтрокаТаблицы.УчебноеЗаведение + ", ";
	КонецЕсли;
	Если ЗначениеЗаполнено(СтрокаТаблицы.ГодОкончания) Тогда
		ПредставлениеЗаписи = ПредставлениеЗаписи + Формат((СтрокаТаблицы.ГодОкончания), "ЧГ=") + " г., ";
	КонецЕсли;
	
	СтроковыеФункцииКлиентСервер.УдалитьПоследнийСимволВСтроке(ПредставлениеЗаписи, 2);
	
	Возврат СтрШаблон(НСтр("ru = '%1'"), ПредставлениеЗаписи);
	
КонецФункции

&НаСервере
Процедура ЗаполнитьПредставлениеУченыеСтепени()
	
	ИдентификаторСтрокиУченыеСтепени1 = ИдентификаторНовойСтроки();
	ИдентификаторСтрокиУченыеСтепени2 = ИдентификаторНовойСтроки();
	ИдентификаторСтрокиУченыеСтепени3 = ИдентификаторНовойСтроки();
	
	Для Каждого СтрокаТаблицы Из ЛичныеДанныеКандидата.УченыеСтепени Цикл
		Представление = ПредставлениеЗаписиУченыеСтепени(СтрокаТаблицы);
		СтрокаТаблицы.Представление = Представление;
		Если СтрокаТаблицы.НомерСтроки <= 3 Тогда
			Элементы["УченыеСтепениПредставление_" + СтрокаТаблицы.НомерСтроки].Заголовок = Представление;
			ЭтотОбъект["ИдентификаторСтрокиУченыеСтепени" + СтрокаТаблицы.НомерСтроки] =
				СтрокаТаблицы.ПолучитьИдентификатор();
		КонецЕсли;
	КонецЦикла;
	
	УстановитьОтображениеТабличнойЧасти("УченыеСтепени", "УченыеСтепениИзменитьГруппа");

КонецПроцедуры

&НаСервере
Функция ПредставлениеЗаписиУченыеСтепени(СтрокаТаблицы)
	
	ПредставлениеЗаписи = "";
	
	Если ЗначениеЗаполнено(СтрокаТаблицы.УченаяСтепень) Тогда
		ПредставлениеЗаписи = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СтрокаТаблицы.УченаяСтепень, "Наименование");
		Если ЗначениеЗаполнено(СтрокаТаблицы.ДатаПрисужденияУченойСтепени) Тогда
			ПредставлениеЗаписи = СтрШаблон("%1, %2 г.", ПредставлениеЗаписи,
				 Формат(Год(СтрокаТаблицы.ДатаПрисужденияУченойСтепени), "ЧГ="));
		КонецЕсли;
	КонецЕсли;

	Возврат СтрШаблон(НСтр("ru = '%1'"), ПредставлениеЗаписи);
	
КонецФункции

&НаСервере
Процедура ЗаполнитьПредставлениеОпытаРаботы()
	
	ЛичныеДанныеКандидата.ОпытРаботы.Сортировать("ДатаНачала Убыв");
	
	Для Каждого СтрокаТаблицы Из ЛичныеДанныеКандидата.ОпытРаботы Цикл
		СтрокаТаблицы.ДатаНачалаПредставление = ЗарплатаКадрыКлиентСервер.ПолучитьПредставлениеМесяца(
			СтрокаТаблицы.ДатаНачала);
		Если Не ЗначениеЗаполнено(СтрокаТаблицы.ДатаОкончания) Тогда
			СтрокаТаблицы.ДатаОкончанияПредставление = НСтр("ru = 'настоящее время'");
		Иначе
			СтрокаТаблицы.ДатаОкончанияПредставление = ЗарплатаКадрыКлиентСервер.ПолучитьПредставлениеМесяца(
				СтрокаТаблицы.ДатаОкончания);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область РедактированиеЛичныхДанныхКандидата

&НаКлиенте
Процедура ОткрытьФормуЗаписиТабличнойЧасти(ИмяФормы, ИмяТабличнойЧасти, НомерСтроки)
	
	ДополнительныеПараметры = Новый Структура("ИмяТабличнойЧасти,НомерСтроки", ИмяТабличнойЧасти, НомерСтроки); 
	ОписаниеОповещения = Новый ОписаниеОповещения("ОткрытьФормуСтрокиТабличнойЧастиЗавершение", ЭтотОбъект,
		ДополнительныеПараметры);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ЭтоНоваяЗапись", Ложь);
	
	ДанныеСтрокиТабличнойЧасти = СтруктураТабличнойЧасти(ИмяТабличнойЧасти);
	Если НомерСтроки = ИдентификаторНовойСтроки() Тогда
		ПараметрыФормы.ЭтоНоваяЗапись = Истина;
	Иначе
		ЗаполнитьЗначенияСвойств(ДанныеСтрокиТабличнойЧасти,
			ЛичныеДанныеКандидата[ИмяТабличнойЧасти].НайтиПоИдентификатору(НомерСтроки));
	КонецЕсли;
	ПараметрыФормы.Вставить("ДанныеСтрокиТабличнойЧасти", ДанныеСтрокиТабличнойЧасти);
	
	ОткрытьФорму(ИмяФормы, ПараметрыФормы, ЭтотОбъект, , , , ОписаниеОповещения,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
		
КонецПроцедуры

&НаСервереБезКонтекста
Функция СтруктураТабличнойЧасти(ИмяТабличнойЧасти)
	
	СтруктураТабличнойЧасти = Новый Структура;
	Для Каждого Реквизит Из Метаданные.Справочники.ЛичныеДанныеКандидатов.ТабличныеЧасти[ИмяТабличнойЧасти].Реквизиты Цикл
		СтруктураТабличнойЧасти.Вставить(Реквизит.Имя);
	КонецЦикла;
	
	Возврат СтруктураТабличнойЧасти;
	
КонецФункции

&НаКлиенте
Процедура ОткрытьФормуСтрокиТабличнойЧастиЗавершение(Результат, ДополнительныеПараметры) Экспорт

	Если Результат = "УдалитьЗапись" Тогда
		УдалитьЗаписьТабличнойЧасти(ДополнительныеПараметры);
		Возврат;
	КонецЕсли;

	Если ТипЗнч(Результат) = Тип("Структура") И Результат.Количество() > 0 Тогда
		ИмяТабличнойЧасти = ДополнительныеПараметры.ИмяТабличнойЧасти;
		НомерСтроки = ДополнительныеПараметры.НомерСтроки;
		
		Если НомерСтроки = ИдентификаторНовойСтроки() Тогда
			СтрокаДанных = ЛичныеДанныеКандидата[ИмяТабличнойЧасти].Добавить();
		Иначе
			СтрокаДанных = ЛичныеДанныеКандидата[ИмяТабличнойЧасти].НайтиПоИдентификатору(НомерСтроки);
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(СтрокаДанных, Результат);
		
		ЗаполнитьПредставлениеТабличнойЧасти(ИмяТабличнойЧасти);
		ЗаблокироватьЛичныеДанныеКандидатаОбъектДляРедактирования();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьЗаписьТабличнойЧасти(ПараметрыУдаляемойЗаписи) Экспорт
	
	ИмяТабличнойЧасти = ПараметрыУдаляемойЗаписи.ИмяТабличнойЧасти;
	НомерСтроки = ПараметрыУдаляемойЗаписи.НомерСтроки;
	
	СтрокаДанных = ЛичныеДанныеКандидата[ИмяТабличнойЧасти].НайтиПоИдентификатору(НомерСтроки);
	ЛичныеДанныеКандидата[ИмяТабличнойЧасти].Удалить(СтрокаДанных);
	ЗаполнитьПредставлениеТабличнойЧасти(ИмяТабличнойЧасти);
	ЗаблокироватьЛичныеДанныеКандидатаОбъектДляРедактирования();
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуКомпании()
	
	ДополнительныеПараметры = Новый Структура("НомерСтроки", Элементы.ОпытРаботы.ТекущиеДанные.НомерСтроки); 
	ОписаниеОповещения = Новый ОписаниеОповещения("ОткрытьФормуКомпанииЗавершение", ЭтотОбъект,
		ДополнительныеПараметры);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Компания", Элементы.ОпытРаботы.ТекущиеДанные.Компания);
	ПараметрыФормы.Вставить("СфераДеятельностиКомпании", Элементы.ОпытРаботы.ТекущиеДанные.СфераДеятельностиКомпании);
	
	ОткрытьФорму("Справочник.ЛичныеДанныеКандидатов.Форма.ФормаКомпании", ПараметрыФормы, ЭтотОбъект, , , ,
		ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуКомпанииЗавершение(Результат, ДополнительныеПараметры) Экспорт

	Если ТипЗнч(Результат) = Тип("Структура") И Результат.Количество() > 0 Тогда
		ЗаполнитьЗначенияСвойств(ЛичныеДанныеКандидата.ОпытРаботы[ДополнительныеПараметры.НомерСтроки - 1], Результат);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ДополнительнаяКонтактнаяИнформация

&НаКлиентеНаСервереБезКонтекста
Процедура СоздатьКомандуДобавленияКонтактнойИнформации(Форма)
	
	Команда = Форма.Команды.Добавить("ДобавитьКонтактнуюИнформацию");
	Команда.Действие = "Подключаемый_ДобавитьКонтактнуюИнформацию";
	
	Кнопка = Форма.Элементы.Добавить("ДобавитьКонтактнуюИнформацию", Тип("КнопкаФормы"),
		Форма.Элементы.ГруппаДругиеКонтакты);
	Кнопка.ИмяКоманды = "ДобавитьКонтактнуюИнформацию";
	Кнопка.Заголовок = НСтр("ru = 'Добавить'");
	Кнопка.Вид = ВидКнопкиФормы.Гиперссылка;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ИменаСтатическихКонтактов()
	
	ИменаСтатическихКонтактов = Новый Массив;
	ИменаСтатическихКонтактов.Добавить("КонтактнаяИнформацияПолеАдресЛичныеДанныеКандидатов");
	ИменаСтатическихКонтактов.Добавить("КонтактнаяИнформацияПолеТелефонЛичныеДанныеКандидатов");
	ИменаСтатическихКонтактов.Добавить("КонтактнаяИнформацияПолеEMailЛичныеДанныеКандидатов");
	
	Возврат ИменаСтатическихКонтактов;
	
КонецФункции

&НаСервере
Процедура ИзменитьОтображениеДополнительнойКонтактнойИнформации()
	
	КоличествоДополнительныхКонтактов = 0;
	ЗаполненныеДопКонтакты = Новый Массив;
	Для Каждого КонтактнаяИнформация Из КонтактнаяИнформацияОписаниеДополнительныхРеквизитов Цикл
		Если КонтактнаяИнформация.Вид.Предопределенный Тогда
			Продолжить;
		КонецЕсли;
		КоличествоДополнительныхКонтактов = КоличествоДополнительныхКонтактов + 1;
		Если ЗначениеЗаполнено(КонтактнаяИнформация.Представление) Тогда
			ЗаполненныеДопКонтакты.Добавить(КонтактнаяИнформация.Вид.Наименование);
		КонецЕсли;
	КонецЦикла;
	
	Если КоличествоДополнительныхКонтактов <= 2 Тогда
		Элементы.ГруппаДругиеКонтакты.ОтображатьЗаголовок = Ложь;
	Иначе
		КоличествоЗаполненныхКонтактов = ЗаполненныеДопКонтакты.Количество();
		Если КоличествоЗаполненныхКонтактов = 0 Тогда
			Элементы.ГруппаДругиеКонтакты.Заголовок = НСтр("ru = 'Другие контакты'");
		ИначеЕсли КоличествоЗаполненныхКонтактов <= 2 Тогда
			Элементы.ГруппаДругиеКонтакты.Заголовок = СтрШаблон(НСтр("ru = 'Другие контакты: %1'"),
				СтрСоединить(ЗаполненныеДопКонтакты, " и "));
		Иначе
			Элементы.ГруппаДругиеКонтакты.Заголовок = СтрШаблон(НСтр("ru = 'Другие контакты: %1, %2 и др.'"),
				ЗаполненныеДопКонтакты[0], ЗаполненныеДопКонтакты[1]);
		КонецЕсли;
		Элементы.ГруппаДругиеКонтакты.ОтображатьЗаголовок = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДоступностьДобавленияКонтактнойИнформации()
	Возврат ПравоДоступа("Добавление", Метаданные.Справочники.ВидыКонтактнойИнформации);
КонецФункции

&НаКлиенте
Процедура НачатьДобавлениеКонтактнойИнформации()
	
	Если Не ДоступностьДобавленияКонтактнойИнформации() Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Недостаточно прав доступа. Обратитесь к администратору.'"));
		Возврат;
	КонецЕсли;
	
	ЭлементыОтбора = Новый Структура("Родитель",
		ПредопределенноеЗначение("Справочник.ВидыКонтактнойИнформации.СправочникЛичныеДанныеКандидатов"));
	ПараметрыФормы = Новый Структура("ЗначенияЗаполнения", ЭлементыОтбора);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("ЗавершитьДобавлениеКонтактнойИнформации", ЭтотОбъект);
	
	ОткрытьФорму("Справочник.ВидыКонтактнойИнформации.Форма.ФормаЭлемента", ПараметрыФормы, ЭтотОбъект,,,,
		ОписаниеОповещения, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьДобавлениеКонтактнойИнформации(Результат, ДополнительныеПараметры) Экспорт
	
	Записать();
	Прочитать();
	ИзменитьОтображениеДополнительнойКонтактнойИнформации();
	
КонецПроцедуры

#КонецОбласти

&НаСервере
Функция ДатаПриемаНаРаботу()
	НайденныеСтроки = РаботаСКандидатамиНаборЗаписей.НайтиСтроки(
		Новый Структура("ЭтапРаботы", Перечисления.ЭтапыРаботыСКандидатами.ПриемНаРаботу));
	Возврат ?(НайденныеСтроки.Количество() > 0, НайденныеСтроки[0].Период, Неопределено);
КонецФункции

#КонецОбласти