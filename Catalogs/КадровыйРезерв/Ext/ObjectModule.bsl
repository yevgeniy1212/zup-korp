#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ОбработкаПроверкиЗаполнения(Отказ, ПроверяемыеРеквизиты)
	
	МассивНепроверяемыхРеквизитов = Новый Массив();
	
	Если Назначение = ПредопределенноеЗначение("Перечисление.НазначенияКадровогоРезерва.ПозицияШтатногоРасписания") Тогда
		Если ЗначениеЗаполнено(ПозицияШтатногоРасписания) И СуществуетКадровыйРезервНаДаннуюПозициюШР(ПозицияШтатногоРасписания) Тогда
			ОбщегоНазначения.СообщитьПользователю(
				НСтр("ru ='На данную позицию штатного расписания уже заведен кадровый резерв'"),
				ЭтотОбъект,
				"ПозицияШтатногоРасписания",,
				Отказ);
		КонецЕсли; 
	Иначе
		МассивНепроверяемыхРеквизитов.Добавить("ПозицияШтатногоРасписания");
	КонецЕсли;
	
	ПроверитьКорректностьУстановкиТребований(Отказ);
	
	ОбщегоНазначения.УдалитьНепроверяемыеРеквизитыИзМассива(ПроверяемыеРеквизиты, МассивНепроверяемыхРеквизитов);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция СуществуетКадровыйРезервНаДаннуюПозициюШР(ПозицияШР)
	
	СписокПозиций = КадровыйРезерв.ПодобратьПозицииРезерваПоПозицииШтатногоРасписания(ПозицияШР, Ложь);
	
	// удаляем текущую позицию
	ИндексПозиции = СписокПозиций.Найти(Ссылка);
	Если НЕ ИндексПозиции = Неопределено Тогда
		СписокПозиций.Удалить(ИндексПозиции);
	КонецЕсли;
	
	Возврат СписокПозиций.Количество() > 0;
	
КонецФункции

Процедура ПроверитьКорректностьУстановкиТребований(Отказ)

	Если МаксимальныйВозраст > 0 И МинимальныйВозраст > МаксимальныйВозраст Тогда
		ОбщегоНазначения.СообщитьПользователю(
			НСтр("ru ='Неверный диапазон возраста.'"),
			ЭтотОбъект,
			"МинимальныйВозраст",,
			Отказ);
	КонецЕсли;
	Если МаксимальныйСтажМесяцев > 0 И МинимальныйСтажМесяцев > МаксимальныйСтажМесяцев Тогда
		ОбщегоНазначения.СообщитьПользователю(
			НСтр("ru ='Неверный диапазон стажа.'"),
			ЭтотОбъект,
			"МинимальныйСтажМесяцев",,
			Отказ);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Иначе
ВызватьИсключение НСтр("ru = 'Недопустимый вызов объекта на клиенте.'");
#КонецЕсли