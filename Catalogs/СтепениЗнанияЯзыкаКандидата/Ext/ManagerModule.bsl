// @strict-types


#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

#Область ОбработчикиПравилРегистрации

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ШаблонОбработчика
Процедура ПриЗаполненииНастроекОбработчиковПравилРегистрации(Настройки) Экспорт
	ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОтбораПоРазделамДанных(Настройки, "ПодборПерсонала");
КонецПроцедуры

#КонецОбласти

// Процедура выполняет первоначальное заполнение классификатора.
Процедура ВыполнитьНачальноеЗаполнение() Экспорт

	ЧитаетИПереводит = Справочники.СтепениЗнанияЯзыка.НайтиПоКоду(1);
	ЧитаетИОбъясняется = Справочники.СтепениЗнанияЯзыка.НайтиПоКоду(2);
	ВладеетСвободно = Справочники.СтепениЗнанияЯзыка.НайтиПоКоду(3);
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить(Метаданные.Справочники.СтепениЗнанияЯзыкаКандидата.ПолноеИмя());
	ЭлементБлокировки.Режим = РежимБлокировкиДанных.Исключительный;

	НачатьТранзакцию();
	Попытка
		Блокировка.Заблокировать();
		
		СоздатьЭлементДляУровняВладенияЯзыком(Перечисления.УровниВладенияЯзыком.A1, ЧитаетИПереводит);
		СоздатьЭлементДляУровняВладенияЯзыком(Перечисления.УровниВладенияЯзыком.A2, ЧитаетИПереводит);
		СоздатьЭлементДляУровняВладенияЯзыком(Перечисления.УровниВладенияЯзыком.B1, ЧитаетИОбъясняется);
		СоздатьЭлементДляУровняВладенияЯзыком(Перечисления.УровниВладенияЯзыком.B2, ЧитаетИОбъясняется);
		СоздатьЭлементДляУровняВладенияЯзыком(Перечисления.УровниВладенияЯзыком.C1, ВладеетСвободно);
		СоздатьЭлементДляУровняВладенияЯзыком(Перечисления.УровниВладенияЯзыком.C2, ВладеетСвободно);
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;
	
КонецПроцедуры

// Получает степень знания языка кандидата по степени знания языка.
// 
// Параметры:
//  СтепеньЗнанияЯзыка - СправочникСсылка.СтепениЗнанияЯзыка
// 
// Возвращаемое значение:
//  СправочникСсылка.СтепениЗнанияЯзыкаКандидата
Функция СтепеньЗнанияЯзыкаКандидатаПоСтепениЗнанияЯзыка(СтепеньЗнанияЯзыка) Экспорт
	
	ОбщегоНазначенияКлиентСервер.ПроверитьПараметр("СтепеньЗнанияЯзыкаКандидатаПоСтепениЗнанияЯзыка",
		"СтепеньЗнанияЯзыка", СтепеньЗнанияЯзыка, Тип("СправочникСсылка.СтепениЗнанияЯзыка"));
		
	Возврат Справочники.СтепениЗнанияЯзыкаКандидата.НайтиПоРеквизиту("СтепеньЗнанияЯзыка", СтепеньЗнанияЯзыка);
	
КонецФункции

// Получает степень знания языка кандидата по уровню владения языком.
// 
// Параметры:
//  УровеньВладенияЯзыком - ПеречислениеСсылка.УровниВладенияЯзыком
// 
// Возвращаемое значение:
//  СправочникСсылка.СтепениЗнанияЯзыкаКандидата
Функция СтепеньЗнанияЯзыкаПоУровнюВладения(УровеньВладенияЯзыком) Экспорт
	
	ОбщегоНазначенияКлиентСервер.ПроверитьПараметр("СтепеньЗнанияЯзыкаКандидатаПоСтепениЗнанияЯзыка",
		"УровеньВладенияЯзыком", УровеньВладенияЯзыком, Тип("ПеречислениеСсылка.УровниВладенияЯзыком"));
		
	Возврат Справочники.СтепениЗнанияЯзыкаКандидата.НайтиПоРеквизиту("УровеньВладенияЯзыком", УровеньВладенияЯзыком);
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Параметры:
//  УровеньВладенияЯзыком - ПеречислениеСсылка.УровниВладенияЯзыком
//  СтепеньЗнанияЯзыка - СправочникСсылка.СтепениЗнанияЯзыка
Процедура СоздатьЭлементДляУровняВладенияЯзыком(УровеньВладенияЯзыком, СтепеньЗнанияЯзыка)
	
	СправочникСсылка = Справочники.СтепениЗнанияЯзыкаКандидата.НайтиПоРеквизиту("УровеньВладенияЯзыком",
		УровеньВладенияЯзыком);
		
	Если ЗначениеЗаполнено(СправочникСсылка) Тогда
		Возврат;
	КонецЕсли;
	
	СправочникОбъект = Справочники.СтепениЗнанияЯзыкаКандидата.СоздатьЭлемент();
	СправочникОбъект.Наименование = Строка(УровеньВладенияЯзыком);
	СправочникОбъект.СтепеньЗнанияЯзыка = СтепеньЗнанияЯзыка;
	СправочникОбъект.УровеньВладенияЯзыком = УровеньВладенияЯзыком;
	ОбновлениеИнформационнойБазы.ЗаписатьДанные(СправочникОбъект, Истина);
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли
