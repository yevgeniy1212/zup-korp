#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

Функция ДанныеИсточников(Источники) Экспорт
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("Источники", Источники);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Источники.Ссылка КАК Ссылка,
		|	Источники.ИмяПредопределенныхДанных КАК ИмяПредопределенныхДанных,
		|	Источники.Наименование КАК Наименование
		|ИЗ
		|	Справочник.ИсточникиИнформацииОКандидатах КАК Источники
		|ГДЕ
		|	Источники.Ссылка В (&Источники)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Наименование,
		|	Ссылка";
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

#Область ОбработчикиПравилРегистрации

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ШаблонОбработчика
Процедура ПриЗаполненииНастроекОбработчиковПравилРегистрации(Настройки) Экспорт
	ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляОтбораПоРазделамДанных(Настройки,
		"ПодборПерсонала");
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Процедура выполняет первоначальное заполнение
//
Процедура НачальноеЗаполнение() Экспорт
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИСТИНА КАК Поле1
	|ИЗ
	|	Справочник.ИсточникиИнформацииОКандидатах КАК ИсточникиИнформацииОКандидатах
	|ГДЕ
	|	НЕ ИсточникиИнформацииОКандидатах.Предопределенный");
	
	Если Не Запрос.Выполнить().Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ИсточникиИнформации = Новый Массив;
	ИсточникиИнформации.Добавить(НСтр("ru = 'Приведи друга'"));
	ИсточникиИнформации.Добавить(НСтр("ru = 'Кадровое агентство'"));
	
	Для Каждого Источник Из ИсточникиИнформации Цикл
		НовыйЭлемент = Справочники.ИсточникиИнформацииОКандидатах.СоздатьЭлемент();
		НовыйЭлемент.Наименование = Источник;
		НовыйЭлемент.ОбменДанными.Загрузка = Истина;
		НовыйЭлемент.Записать();
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли