#Область ПрограммныйИнтерфейс

// Возвращает таблицу, содержащую контактную информацию пользователей.
//
// Параметры:
//  МассивПользователей - Массив - Коллекция элементов с типом СправочникСсылка.Пользователи.
//  ВидКонтактнойИнформации - СправочникСсылка.ВидыКонтактнойИнформации - Вид контактной информации.
//
// Возвращаемое значение:
//  ТаблицаЗначений -  таблица с контактной информацией пользователей, содержащая колонки:
//    * Пользователь - СправочникСсылка.Пользователи - владелец контактной информации.
//    * АдресЭлектроннойПочты - Строка - представление контактной информации.
//
Функция ТаблицаАдресовЭлектроннойПочтыПользователей(МассивПользователей, ВидКонтактнойИнформации) Экспорт
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Пользователь", Новый ОписаниеТипов("СправочникСсылка.Пользователи"));
	Результат.Колонки.Добавить("АдресЭлектроннойПочты", Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(1500)));
	
	СоответствиеФЛ = Новый Соответствие;
	МассивФЛ = Новый Массив;
	Для Каждого Пользователь Из МассивПользователей Цикл
		ФЛ = Пользователь.ФизическоеЛицо;
		Если Не ЗначениеЗаполнено(ФЛ) Тогда
			Продолжить
		КонецЕсли;
		Если Не СоответствиеФЛ.Получить(ФЛ) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		СоответствиеФЛ.Вставить(ФЛ, Пользователь);
		МассивФЛ.Добавить(ФЛ);
	КонецЦикла;
	
	Если Не ЗначениеЗаполнено(МассивФЛ) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ТаблицаКИ = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъектов(МассивФЛ,
		Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты, ВидКонтактнойИнформации);

	Если Не ЗначениеЗаполнено(ТаблицаКИ)Тогда
		Возврат Результат;
	КонецЕсли;

	Для Каждого СтрокаКИ Из ТаблицаКИ Цикл
		НоваяСтрока = Результат.Добавить();
		НоваяСтрока.Пользователь = СоответствиеФЛ.Получить(СтрокаКИ.Объект);
		НоваяСтрока.АдресЭлектроннойПочты = СтрокаКИ.Представление;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает таблицу, содержащую контактную информацию объектов.
//
// Параметры:
//  Объекты - Массив - Коллекция элементов с типами СправочникСсылка.Пользователи и СправочникСсылка.ТерриторииИПомещения.
//  ВидКонтактнойИнформации - СправочникСсылка.ВидыКонтактнойИнформации - Вид контактной информации.
//
// Возвращаемое значение:
//  ТаблицаЗначений -  таблица с контактной информацией объектов, содержащая колонки:
//    * Объект - СправочникСсылка.Пользователи - владелец контактной информации.
//    * АдресЭлектроннойПочты - Строка - представление контактной информации.
//
Функция ТаблицаАдресовЭлектроннойПочты(Знач Объекты, ВидКонтактнойИнформации) Экспорт
	
	Если Не ТипЗнч(Объекты) = Тип("Массив") Тогда
		Объекты = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Объекты);
	КонецЕсли;
	
	Результат = Новый ТаблицаЗначений;
	МассивТипов = Новый Массив;
	МассивТипов.Добавить(Тип("СправочникСсылка.Пользователи"));
	МассивТипов.Добавить(Тип("СправочникСсылка.ТерриторииИПомещения"));
	Результат.Колонки.Добавить("Объект", Новый ОписаниеТипов(МассивТипов));
	Результат.Колонки.Добавить("АдресЭлектроннойПочты", Новый ОписаниеТипов("Строка",, Новый КвалификаторыСтроки(1500)));
	
	СоответствиеОбъектов = Новый Соответствие;
	ВладельцыКИ = Новый Массив;
	Для Каждого Объект Из Объекты Цикл
		ВладелецКИ = Объект;

		Если ТипЗнч(Объект) = Тип("СправочникСсылка.Пользователи") Тогда
			ВладелецКИ = Объект.ФизическоеЛицо;
			Если Не ЗначениеЗаполнено(ВладелецКИ) Тогда
				Продолжить;
			КонецЕсли;
			Если Не СоответствиеОбъектов.Получить(ВладелецКИ) = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			СоответствиеОбъектов.Вставить(ВладелецКИ, Объект);
		КонецЕсли;
		
		ВладельцыКИ.Добавить(ВладелецКИ);
	КонецЦикла;
	
	ТаблицаКИ = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъектов(ВладельцыКИ,
		Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты, ВидКонтактнойИнформации);
		
	Если Не ЗначениеЗаполнено(ТаблицаКИ)Тогда
		Возврат Результат;
	КонецЕсли;

	Для Каждого СтрокаКИ Из ТаблицаКИ Цикл
		НоваяСтрока = Результат.Добавить();
		Если ТипЗнч(СтрокаКИ.Объект) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
			НоваяСтрока.Объект = СоответствиеОбъектов.Получить(СтрокаКИ.Объект);
		Иначе
			НоваяСтрока.Объект = СтрокаКИ.Объект;
		КонецЕсли;
		НоваяСтрока.АдресЭлектроннойПочты = СтрокаКИ.Представление;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает представление адреса электронной почты MS Exchange пользователя.
//
// Параметры:
//  Пользователь - СправочникСсылка.Пользователи - Пользователь владелец контактной информации.
//  СерверMSExchange - СправочникСсылка.СерверыMSExchange - Сервер MS Exchange пользователя.
//
// Возвращаемое значение:
//  Строка -  Представление адреса электронной почты.
//
Функция АдресПочтовогоЯщикаПользователя(Пользователь, СерверMSExchange) Экспорт
	
	Результат = Неопределено;
	
	Если Не ЗначениеЗаполнено(Пользователь.ФизическоеЛицо) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если Не ТипЗнч(Пользователь.ФизическоеЛицо) = Тип("СправочникСсылка.ФизическиеЛица") Тогда
		Возврат Результат;
	КонецЕсли;
	
	ТаблицаКИ = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъектов(
		Пользователь.ФизическоеЛицо,
		Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты,
		СерверMSExchange.ВидКонтактнойИнформацииПользователей);

	Если Не ЗначениеЗаполнено(ТаблицаКИ) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат = НРег(ТаблицаКИ[0].Представление);
	
	Возврат Результат;
	
КонецФункции

// Возвращает представление адреса электронной почты MS Exchange помещения.
//
// Параметры:
//  Помещение - СправочникСсылка.ТерриторииИПомещения - Пользователь владелец контактной информации.
//  СерверMSExchange - СправочникСсылка.СерверыMSExchange - Сервер MS Exchange пользователя.
//
// Возвращаемое значение:
//  Строка -  Представление адреса электронной почты.
//
Функция АдресПочтовогоЯщикаПомещения(Помещение, СерверMSExchange) Экспорт
	
	Результат = Неопределено;
	
	ТаблицаКИ = УправлениеКонтактнойИнформацией.КонтактнаяИнформацияОбъектов(
		Помещение,
		Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты,
		СерверMSExchange.ВидКонтактнойИнформацииПомещений);

	Если Не ЗначениеЗаполнено(ТаблицаКИ) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат = НРег(ТаблицаКИ[0].Представление);
	
	Возврат Результат;
	
КонецФункции

// Возвращает массив настроенных серверов MS Exchange.
//
// Возвращаемое значение:
//  Массив -  Массив из СправочникСсылка.СерверыMSExchange.
//
Функция НастроенныеСерверыMSExchange() Экспорт
	
	Результат = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СерверыMSExchange.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.СерверыMSExchange КАК СерверыMSExchange
	|ГДЕ
	|	НЕ СерверыMSExchange.ПометкаУдаления";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Результат.Добавить(Выборка.Ссылка);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецЕсли
