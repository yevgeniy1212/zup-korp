		НСтр("ru = 'Выберите картинку задания'"),
		НСтр("ru = 'картинка'"));
	
	НачатьПомещениеФайлов(ОповещениеЗавершения, , ДиалогВыбораФайлов, Истина, ЭтотОбъект.УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьКартинкуЗаданияВебКлиентЗавершение(Результат, Адрес, ВыбранноеИмяФайла, ДополнительныеПараметры) Экспорт
	
	Если Результат Тогда
		КартинкаЗадания = Новый ОписаниеПередаваемогоФайла(ВыбранноеИмяФайла, Адрес);
		МассивКартинок = Новый Массив;
		МассивКартинок.Добавить(КартинкаЗадания);
		ЗагрузитьКартинкуВариантаЗавершение(МассивКартинок, ДополнительныеПараметры);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьКартинкуЗаданияЗавершение(МассивКартинок, ДополнительныеПараметры) Экспорт
	
	Если МассивКартинок = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если МассивКартинок.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;	
		
	КартинкаЗадания = МассивКартинок[0].Хранение;	
	ЗаполнитьСвойстваКартинкиЗадания();
	ОтобразитьВариантОтветаНаКартинке();
	
КонецПроцедуры 

&НаСервере
Процедура ЗаполнитьСвойстваКартинкиЗадания() Экспорт
	
	Если НЕ ЭтоАдресВременногоХранилища(КартинкаЗадания) Тогда
		ВызватьИсключение НСтр("ru = 'Адрес картинки задания не найден'")
	КонецЕсли;
	
	ДвоичныеДанныеКартинки = ПолучитьИзВременногоХранилища(КартинкаЗадания);
	Если ТипЗнч(ДвоичныеДанныеКартинки) <> Тип("ДвоичныеДанные") Тогда
		СвойстваКартинкиЗадания = Неопределено;
		Возврат;
	КонецЕсли;
	
	КартинкаЗаданияДанные = Новый Картинка(ДвоичныеДанныеКартинки);
	
	СтруктураСвойствКартинки = Новый Структура("Ширина, Высота, MIMEТип, Base64");
	РазмерыКартинки = ЭлектронноеОбучениеСлужебный.РазмерыКартинки(КартинкаЗаданияДанные);
	СтруктураСвойствКартинки.Ширина = РазмерыКартинки.Ширина;
	СтруктураСвойствКартинки.Высота = РазмерыКартинки.Высота;
	
	ФорматКартинкиЗадания = КартинкаЗаданияДанные.Формат();
	Если ФорматКартинкиЗадания = ФорматКартинки.PNG Тогда
		СтруктураСвойствКартинки.MIMEТип = "image/png";
	ИначеЕсли ФорматКартинкиЗадания = ФорматКартинки.JPEG Тогда
		СтруктураСвойствКартинки.MIMEТип = "image/jpeg";
	ИначеЕсли ФорматКартинкиЗадания = ФорматКартинки.GIF Тогда
		СтруктураСвойствКартинки.MIMEТип = "image/gif";
	Иначе
		ВызватьИсключение НСтр("ru = 'Формат картинки не поддерживается'")
	КонецЕсли;
	
	СтруктураСвойствКартинки.Base64 = Base64Строка(ДвоичныеДанныеКартинки);
	
	СвойстваКартинкиЗадания = Новый ФиксированнаяСтруктура(СтруктураСвойствКартинки);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтобразитьВариантОтветаНаКартинке()	
	
	Если НЕ ЗначениеЗаполнено(КартинкаЗадания) ИЛИ СвойстваКартинкиЗадания = Неопределено
		ИЛИ Объект.ТипВопроса <> ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.ОдинИзМногихНаКартинке") Тогда
		СтраницаВыбораВариантаНаКартинке = "";
		Возврат;
	КонецЕсли;
	
	СтраницаВыбораВариантаНаКартинке = СтрЗаменить(ШаблонСтраницыВыбораВариантаНаКартинке, "{{IMAGE_SRC}}",
		"data:" + СвойстваКартинкиЗадания.MIMEТип + ";base64," + СвойстваКартинкиЗадания.Base64);
	СтраницаВыбораВариантаНаКартинке = СтрЗаменить(СтраницаВыбораВариантаНаКартинке, "/*IMAGE_SETTINGS*/",
		"width: "+ ЭлектронноеОбучениеСлужебныйКлиентСервер.ЧислоВСтроку(СвойстваКартинкиЗадания.Ширина) +
		", height: " + ЭлектронноеОбучениеСлужебныйКлиентСервер.ЧислоВСтроку(СвойстваКартинкиЗадания.Высота));		
	
	
	ТекущиеДанныеВарианта = Элементы.ВариантыОтветов.ТекущиеДанные;
	
	Если ТекущиеДанныеВарианта = Неопределено Тогда
		СтраницаВыбораВариантаНаКартинке = СтрЗаменить(СтраницаВыбораВариантаНаКартинке, "/*SHAPES*/", "");
	Иначе		
		НомерТекущейСтроки = Элементы.ВариантыОтветов.ТекущаяСтрока;
		СтраницаВыбораВариантаНаКартинке = СтрЗаменить(СтраницаВыбораВариантаНаКартинке, "/*SHAPES*/",
			КоординатыВСтрокуJS(ТекущиеДанныеВарианта.ОбластьНаКартинке, НомерТекущейСтроки, ТекущиеДанныеВарианта.Верный));			
	КонецЕсли;
			
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ЭтоКруг(КоординатыСтрока)
	Возврат РазработкаЭлектронныхКурсовСлужебныйКлиентСервер.ЭтоОбластьНаКартинкеКруг(КоординатыСтрока);
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПредставлениеТипаОбластиПоКоординатам(КоординатыСтрока)
	Если ЭтоКруг(КоординатыСтрока) Тогда
		Возврат НСтр("ru = 'Круг'");
	Иначе
		Возврат НСтр("ru = 'Прямоугольник'");
	КонецЕсли;
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция НачальныеКоординатыПрямоугольника()
	Возврат "0,0,200,200";
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция НачальныеКоординатыКруга()
	Возврат "200,200,200";
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция КоординатыВСтрокуJS(Знач КоординатыСтрока, Знач НомерВарианта, Знач Верный)
	
	Если НЕ ЗначениеЗаполнено(КоординатыСтрока) Тогда
		КоординатыСтрока = НачальныеКоординатыПрямоугольника();
	КонецЕсли;
	
	КоординатыМассив = СтрРазделить(КоординатыСтрока, ",", Ложь);
	Если КоординатыМассив.Количество() > 4
		ИЛИ КоординатыМассив.Количество() < 3 Тогда		
		ВызватьИсключение НСтр("ru = 'Неверный формат координат'");		
	КонецЕсли;
	
	Для Сч = 0 По КоординатыМассив.Количество() - 1 Цикл	
		КоординатыМассив[0] = Число(КоординатыМассив[0]);	
	КонецЦикла;	
	
	Если КоординатыМассив.Количество() = 4 Тогда
		
		КоординатыСтруктура = Новый Структура("x, y, width, height, isCorrect, name, type");
		КоординатыСтруктура.x = КоординатыМассив[0];
		КоординатыСтруктура.y = КоординатыМассив[1];
		КоординатыСтруктура.width = КоординатыМассив[2] - КоординатыМассив[0];
		КоординатыСтруктура.height = КоординатыМассив[3] - КоординатыМассив[1];
		КоординатыСтруктура.type = "Rect";
		КоординатыСтруктура.isCorrect = Верный;
		КоординатыСтруктура.name = ЭлектронноеОбучениеСлужебныйКлиентСервер.ЧислоВСтроку(НомерВарианта);
		
		КоординатыJSСтрока = "
		| {
		|	x: "+ЭлектронноеОбучениеСлужебныйКлиентСервер.ЧислоВСтроку(КоординатыСтруктура.x)+",
		|	y: "+ЭлектронноеОбучениеСлужебныйКлиентСервер.ЧислоВСтроку(КоординатыСтруктура.y)+",
		|	width: "+ЭлектронноеОбучениеСлужебныйКлиентСервер.ЧислоВСтроку(КоординатыСтруктура.width)+",
		|	height: "+ЭлектронноеОбучениеСлужебныйКлиентСервер.ЧислоВСтроку(КоординатыСтруктура.height)+",
		|	isCorrect: "+?(КоординатыСтруктура.isCorrect, "true", "false")+",
		|	name: '"+КоординатыСтруктура.name+"',
		|	type: '"+КоординатыСтруктура.type+"'
		| }";		
		
	КонецЕсли;
	
	Если КоординатыМассив.Количество() = 3 Тогда
		
		КоординатыСтруктура = Новый Структура("x, y, radius, isCorrect, name, type");
		КоординатыСтруктура.x = КоординатыМассив[0];
		КоординатыСтруктура.y = КоординатыМассив[1];
		КоординатыСтруктура.radius = КоординатыМассив[2];
		КоординатыСтруктура.type = "Circle";
		КоординатыСтруктура.isCorrect = Верный;
		КоординатыСтруктура.name = ЭлектронноеОбучениеСлужебныйКлиентСервер.ЧислоВСтроку(НомерВарианта);
		
		КоординатыJSСтрока = "
		| {
		|	x: "+ЭлектронноеОбучениеСлужебныйКлиентСервер.ЧислоВСтроку(КоординатыСтруктура.x)+",
		|	y: "+ЭлектронноеОбучениеСлужебныйКлиентСервер.ЧислоВСтроку(КоординатыСтруктура.y)+",
		|	radius: "+ЭлектронноеОбучениеСлужебныйКлиентСервер.ЧислоВСтроку(КоординатыСтруктура.radius)+",
		|	isCorrect: "+?(КоординатыСтруктура.isCorrect, "true", "false")+",
		|	name: '"+КоординатыСтруктура.name+"',
		|	type: '"+КоординатыСтруктура.type+"'
		| }";
		
	КонецЕсли;
	
	Возврат КоординатыJSСтрока	
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция СтрокаJSВКоординаты(СтрокаJS)	
	ПозицияДвоеточия = СтрНайти(СтрокаJS, ":"); // Убираем имя области до двоеточия
	Возврат Сред(СтрокаJS, ПозицияДвоеточия + 1); 
КонецФункции

&НаКлиенте
Процедура УстановитьНовыеКоординатыВарианта(СтрокаJS)
	ТекущиеДанныеТВ = Элементы.ВариантыОтветов.ТекущиеДанные;
	Если ТекущиеДанныеТВ = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ТекущиеДанныеТВ.ОбластьНаКартинке = СтрокаJSВКоординаты(СтрокаJS);
КонецПроцедуры

// Варианты ответов

&НаКлиенте
Процедура ВыбратьКартинкуДляВариантаОтвета()
	
	ТекстСообщения = НСтр("ru = 'Для загрузки картинки рекомендуется установить расширение для веб-клиента 1С:Предприятие.'");
	Обработчик = Новый ОписаниеОповещения("ЗагрузитьКартинкуВариантаПродолжение", ЭтотОбъект);
	ФайловаяСистемаКлиент.ПодключитьРасширениеДляРаботыСФайлами(Обработчик, ТекстСообщения, Истина); 
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьКартинкуВариантаПродолжение(РасширениеПодключено, ДополнительныеПараметры) Экспорт
	
	Если НЕ РасширениеПодключено Тогда
		// Веб-клиент без расширения для работы с файлами.
		ОповещениеФайла = Новый ОписаниеОповещения("ЗагрузитьКартинкуВариантаВебКлиентЗавершение", ЭтотОбъект, ДополнительныеПараметры);
		НачатьПомещениеФайла(ОповещениеФайла,,,,УникальныйИдентификатор);
		Возврат;
	КонецЕсли;
	
	ОповещениеЗавершения = Новый ОписаниеОповещения("ЗагрузитьКартинкуВариантаЗавершение", ЭтотОбъект, ДополнительныеПараметры);	
	
	МассивТиповВыбора = Новый Массив;
	МассивТиповВыбора.Добавить(ПредопределенноеЗначение("Перечисление.ТипыЭлементовЭлектронныхРесурсов.Image"));
	
	ДиалогВыбораФайлов = РазработкаЭлектронныхКурсовСлужебныйКлиент.ДиалогВыбораФайлаПоТипу(
		МассивТиповВыбора,
		НСтр("ru = 'Выберите картинку варианта'"),
		НСтр("ru = 'картинка'"));
	
	НачатьПомещениеФайлов(ОповещениеЗавершения, , ДиалогВыбораФайлов, Истина, ЭтотОбъект.УникальныйИдентификатор);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьКартинкуВариантаВебКлиентЗавершение(Результат, Адрес, ВыбранноеИмяФайла, ДополнительныеПараметры) Экспорт
	
	Если Результат Тогда
		КартинкаВарианта = Новый ОписаниеПередаваемогоФайла(ВыбранноеИмяФайла, Адрес);
		МассивКартинок = Новый Массив;
		МассивКартинок.Добавить(КартинкаВарианта);
		ЗагрузитьКартинкуВариантаЗавершение(МассивКартинок, ДополнительныеПараметры);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьКартинкуВариантаЗавершение(МассивКартинок, ДополнительныеПараметры) Экспорт
	
	Если МассивКартинок = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если МассивКартинок.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элементы.ВариантыОтветов.ТекущиеДанные;
	
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные.Картинка = МассивКартинок[0].Хранение;	
	
КонецПроцедуры  

&НаСервере
Процедура УдалитьВариантОтветаНаСервере(ВариантОтвета)
	
	Если ЭлектронноеОбучениеСлужебный.СсылкаСуществуетВБазе(ВариантОтвета, Ложь) Тогда
		ВариантОтветаОбъект = ВариантОтвета.ПолучитьОбъект();
		ВариантОтветаОбъект.УстановитьПометкуУдаления(Истина);
	КонецЕсли;
	
КонецПроцедуры

// Общее

&НаСервере
Процедура ЗагрузитьВерсиюНаСервере(ТекущийОбъект)
	
	Если НЕ ТекущийОбъект.Ссылка.Пустая() Тогда 
		
		// Загружаем текст вопроса (задание)
		
		Задание = ТекущийОбъект.Задание.Получить();		
		
		// Загружаем картинку задания
		
		КартинкаЗадания = ПоместитьВоВременноеХранилище(ТекущийОбъект.Картинка.Получить(), УникальныйИдентификатор);
		ЗаполнитьСвойстваКартинкиЗадания();
		
		// Загружаем таблицу с данными вариантов ответов
		
		ВариантыОтветов.Очистить();
		ЭлементыСоответствия.Очистить();
		
		ЗапросЭлементовСоответствия = Новый Запрос;
		ЗапросЭлементовСоответствия.Текст = 
			"ВЫБРАТЬ
			|	ВариантыЭлементовСоответствия.Ссылка КАК ЭлементСоответствия,
			|	ВариантыЭлементовСоответствия.ВариантОтвета КАК ВариантОтвета
			|ИЗ
			|	Справочник.ВариантыОтветовНаТестовыеВопросы.ВариантыЭлементаСоответствия КАК ВариантыЭлементовСоответствия
			|ГДЕ
			|	ВариантыЭлементовСоответствия.Ссылка.Владелец = &Владелец
			|	И ВариантыЭлементовСоответствия.Ссылка.ПометкаУдаления = ЛОЖЬ
			|	И ВариантыЭлементовСоответствия.Ссылка.ЭтоЭлементСоответствия = ИСТИНА";
		
		ЗапросЭлементовСоответствия.УстановитьПараметр("Владелец", ТекущийОбъект.Ссылка);
		
		ТаблицаЭлементовСоответствия = ЗапросЭлементовСоответствия.Выполнить().Выгрузить();
		// Примечание: таблицу элементов соответствия получаем для всех типов вопросов на случай,
		// если в процессе редактирования вопроса будет изменен его тип и нам понадобятся эти данные.
		
		ЗапросВариантов = Новый Запрос();
		ЗапросВариантов.Текст = "ВЫБРАТЬ
		               |	ВариантыОтветов.Ссылка КАК Ссылка,
		               |	ВариантыОтветов.Верный КАК Верный,
		               |	ВариантыОтветов.ТекстВарианта КАК ТекстВарианта,
		               |	ВариантыОтветов.Картинка КАК Картинка,
		               |	ВариантыОтветов.ОбластьНаКартинке КАК ОбластьНаКартинке,
		               |	ВариантыОтветов.НомерПоляВвода КАК НомерПоляВвода,
		               |	ВариантыОтветов.ЭтоЭлементСоответствия КАК ЭтоЭлементСоответствия
		               |ИЗ
		               |	Справочник.ВариантыОтветовНаТестовыеВопросы КАК ВариантыОтветов
		               |ГДЕ
		               |	ВариантыОтветов.Владелец = &Владелец
		               |	И ВариантыОтветов.ПометкаУдаления = ЛОЖЬ
		               |
		               |УПОРЯДОЧИТЬ ПО
		               |	ВариантыОтветов.Код";		
		
		ЗапросВариантов.УстановитьПараметр("Владелец", ТекущийОбъект.Ссылка); 
		
		ВыборкаВариантыОтветов = ЗапросВариантов.Выполнить().Выбрать();
		
		Пока ВыборкаВариантыОтветов.Следующий() Цикл
			
			Если ВыборкаВариантыОтветов.ЭтоЭлементСоответствия Тогда
				
				НоваяСтрока = ЭлементыСоответствия.Добавить();
				НоваяСтрока.Ссылка = ВыборкаВариантыОтветов.Ссылка;
				НоваяСтрока.Текст = ВыборкаВариантыОтветов.ТекстВарианта.Получить();
				НоваяСтрока.Картинка = ПоместитьВоВременноеХранилище(ВыборкаВариантыОтветов.Картинка.Получить(), ЭтотОбъект.УникальныйИдентификатор);
				
				ВариантыТекущегоЭлемента = ТаблицаЭлементовСоответствия.НайтиСтроки(Новый Структура("ЭлементСоответствия", ВыборкаВариантыОтветов.Ссылка));
				
				Для каждого СтрокаТЭС Из ВариантыТекущегоЭлемента Цикл				
					НоваяСтрока.ВариантыОтветов.Добавить(СтрокаТЭС.ВариантОтвета, СтрокаТЭС.ВариантОтвета); 				
				КонецЦикла;
				
			Иначе				
				
				НоваяСтрока = ВариантыОтветов.Добавить();
				НоваяСтрока.Ссылка = ВыборкаВариантыОтветов.Ссылка;
				НоваяСтрока.Текст = ВыборкаВариантыОтветов.ТекстВарианта.Получить();
				НоваяСтрока.Верный = ВыборкаВариантыОтветов.Верный;
				НоваяСтрока.Картинка = ПоместитьВоВременноеХранилище(ВыборкаВариантыОтветов.Картинка.Получить(), ЭтотОбъект.УникальныйИдентификатор);
				НоваяСтрока.ОбластьНаКартинке = ВыборкаВариантыОтветов.ОбластьНаКартинке;
				НоваяСтрока.ТипОбласти = ПредставлениеТипаОбластиПоКоординатам(НоваяСтрока.ОбластьНаКартинке);
				НоваяСтрока.НомерПоляВвода = ВыборкаВариантыОтветов.НомерПоляВвода; 
				
			КонецЕсли;			
				
		КонецЦикла;
		
	КонецЕсли;
	
	УстановитьДоступностьЭлементовФормы(ЭтотОбъект);
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьШаблонСтраницыВыбораВариантаНаКартинке() 
	ШаблонСтраницыВыбораВариантаНаКартинке = Справочники.ТестовыеВопросы.ПолучитьМакет("ШаблонСтраницыВыбораВариантаНаКартинке").ПолучитьТекст();
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура УстановитьДоступностьЭлементовФормы(Форма)
	
	Если Форма.Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.Последовательность")
		ИЛИ Форма.Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.ВводСКлавиатуры")
		ИЛИ Форма.Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.Соответствие") Тогда
		Форма.Элементы.ВариантыОтветовВерный.Видимость = Ложь;
	Иначе		
		Форма.Элементы.ВариантыОтветовВерный.Видимость = Истина;		
	КонецЕсли;
	
	Форма.Элементы.ГруппаКартинкаВариантов.Доступность = (Форма.ВариантыОтветов.Количество() > 0);
	Форма.Элементы.ГруппаКартинкаЭлементовСоответствия.Доступность = (Форма.ЭлементыСоответствия.Количество() > 0);
	
	Если Форма.Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.ОдинИзМногихНаКартинке") Тогда
		Форма.Элементы.ГруппаВыбораВариантаНаКартинке.Видимость = Истина;
	Иначе
		Форма.Элементы.ГруппаВыбораВариантаНаКартинке.Видимость = Ложь;
	КонецЕсли;
	
	Если Форма.Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.ОдинИзМногихНаКартинке")
		ИЛИ Форма.Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.ВводСКлавиатуры") Тогда
		Форма.Элементы.ГруппаКартинкаВариантов.Видимость = Ложь;
	Иначе
		Форма.Элементы.ГруппаКартинкаВариантов.Видимость = Истина;
	КонецЕсли;		
	
	Если Форма.Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.ОдинИзМногихНаКартинке") Тогда
		Форма.Элементы.ВариантыОтветовТипОбласти.Видимость = Истина;
	Иначе
		Форма.Элементы.ВариантыОтветовТипОбласти.Видимость = Ложь;
	КонецЕсли;	
	
	Если Форма.Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.ВводСКлавиатуры") Тогда
		Форма.Элементы.ВариантыОтветовНомерПоляВвода.Видимость = Истина;
	Иначе
		Форма.Элементы.ВариантыОтветовНомерПоляВвода.Видимость = Ложь;
	КонецЕсли;		
	
	Если Форма.Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.ВводСКлавиатуры") Тогда
		Форма.Элементы.ДекорацияВводСКлавиатуры.Видимость = Истина;
	Иначе
		Форма.Элементы.ДекорацияВводСКлавиатуры.Видимость = Ложь;
	КонецЕсли;		
	
	Если Форма.Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.ВводСКлавиатуры") Тогда
		Форма.Элементы.ВставитьПолеВвода.Видимость = Истина;
	Иначе
		Форма.Элементы.ВставитьПолеВвода.Видимость = Ложь;
	КонецЕсли;			
	
	Если Форма.Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.Соответствие") Тогда
		Форма.Элементы.ГруппаЭлементыСоответствия.Видимость = Истина;
	Иначе
		Форма.Элементы.ГруппаЭлементыСоответствия.Видимость = Ложь;
	КонецЕсли;		
	
	Если Форма.Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.Соответствие") Тогда
		Форма.Элементы.ВариантыОтветовСоответствуетЭлементу.Видимость = Истина;
	Иначе
		Форма.Элементы.ВариантыОтветовСоответствуетЭлементу.Видимость = Ложь;
	КонецЕсли;	
	
	Если Форма.Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.Соответствие") Тогда
		Форма.Элементы.НаименованиеКолонкиВариантов.Видимость = Истина;
	Иначе
		Форма.Элементы.НаименованиеКолонкиВариантов.Видимость = Ложь;
	КонецЕсли;	
	
	Если Форма.Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.Соответствие") Тогда
		Если ЗначениеЗаполнено(Форма.Объект.НаименованиеКолонкиЭлементов) Тогда
			Форма.Элементы.ЭлементыСоответствияТекст.Заголовок = Форма.Объект.НаименованиеКолонкиЭлементов;
		Иначе
			Форма.Элементы.ЭлементыСоответствияТекст.Заголовок = НСтр("ru = 'Варианты'");
		КонецЕсли;
		Если ЗначениеЗаполнено(Форма.Объект.НаименованиеКолонкиВариантов) Тогда
			Форма.Элементы.ВариантыОтветовТекст.Заголовок = Форма.Объект.НаименованиеКолонкиВариантов;
		Иначе
			Форма.Элементы.ВариантыОтветовТекст.Заголовок = НСтр("ru = 'Варианты'");
		КонецЕсли;
	Иначе
		Форма.Элементы.ЭлементыСоответствияТекст.Заголовок = "";
		Форма.Элементы.ВариантыОтветовТекст.Заголовок = "";
	КонецЕсли;
	
	Если Форма.Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.Соответствие") Тогда
		Форма.Элементы.ВариантыОтветов.Доступность = (Форма.ЭлементыСоответствия.Количество() > 0);
	Иначе
		Форма.Элементы.ВариантыОтветов.Доступность = Истина;
	КонецЕсли;
	
	Если Форма.Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.Открытый") Тогда
		Форма.Элементы.ГруппаВариантыИЭлементы.Доступность = Ложь;
	Иначе
		Форма.Элементы.ГруппаВариантыИЭлементы.Доступность = Истина;
	КонецЕсли; 
	
	Форма.Элементы.Вес.Видимость = ЗначениеЗаполнено(Форма.Страница);
	
КонецПроцедуры

&НаСервере
Процедура ПриОпределенииТиповТестовыхВопросов()
	
	СтандартнаяОбработка = Истина;
	ДоступныеТипыТестовыхВопросов = Новый Массив;
	ИсключенныеТипыТестовыхВопросов = Новый Массив;

	РазработкаЭлектронныхКурсовПереопределяемый.ПриОпределенииТиповТестовыхВопросов(
		ЭлектронныйКурс,
		КонтекстРедактирования,
		ДоступныеТипыТестовыхВопросов,
		СтандартнаяОбработка);
	
	Если СтандартнаяОбработка Тогда
		
		ИсключенныеТипыТестовыхВопросов.Добавить(Перечисления.ТипыТестовыхВопросов.Открытый);
		
	Иначе
		
		ВсеТипыВопросов = Перечисления.ТипыТестовыхВопросов.ВсеТипы();
		
		Для каждого ТипВопроса Из ВсеТипыВопросов Цикл		
			Если ДоступныеТипыТестовыхВопросов.Найти(ТипВопроса) = Неопределено Тогда
				ИсключенныеТипыТестовыхВопросов.Добавить(ТипВопроса);
			КонецЕсли;		
		КонецЦикла;		
		
	КонецЕсли;	
	
	НовыйМассив = Новый Массив();
	
	Если ИсключенныеТипыТестовыхВопросов.Количество() > 0 Тогда
		НовыйПараметр = Новый ПараметрВыбора("ИсключитьЗначения",  Новый ФиксированныйМассив(ИсключенныеТипыТестовыхВопросов));
		НовыйМассив.Добавить(НовыйПараметр);
	КонецЕсли;
	
	НовыеПараметрыВыбора = Новый ФиксированныйМассив(НовыйМассив);	
	
	Элементы.ТипВопроса.ПараметрыВыбора = НовыеПараметрыВыбора
	
КонецПроцедуры


