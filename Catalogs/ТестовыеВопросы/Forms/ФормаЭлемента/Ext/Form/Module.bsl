&НаКлиенте
Процедура ВставитьПолеВвода(Команда)
	
	ТекущиеДанные = Элементы.ВариантыОтветов.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Для вставки поля ввода добавите вариант ответа'"));
		Возврат;
	КонецЕсли;
	
	КодПеременной = "[[" + ЭлектронноеОбучениеСлужебныйКлиентСервер.ЧислоВСтроку(ТекущиеДанные.НомерПоляВвода) + "]]";
	НачалоВыделения = 0;
	КонецВыделения = 0;	
	Элементы.Задание.ПолучитьГраницыВыделения(НачалоВыделения, КонецВыделения);
	Задание.Вставить(КонецВыделения, КодПеременной);
	Модифицированность = Истина;
	
КонецПроцедуры

