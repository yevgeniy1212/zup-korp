
#Область ОбработчикиСобытийФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	// Заполняем переменные
	
	Тест                   = Параметры.Тест;
	Страница               = Параметры.Страница;
	ЭлектронныйКурс        = Параметры.ЭлектронныйКурс;
	КонтекстРедактирования = Параметры.КонтекстРедактирования;
	
	Если Объект.Ссылка.Пустая() Тогда
		Объект.Родитель = Справочники.ЭлектронныеКурсы.ГруппаДляХраненияПодчиненныхЭлементов(ЭлектронныйКурс, "СправочникСсылка.ТестовыеВопросы");
	КонецЕсли;
	
	РазработкаЭлектронныхКурсовСлужебный.УстановитьПредпочитаемогоПоставщика(Объект);
	
	Вес = 1;
	
	Если ЗначениеЗаполнено(Параметры.Страница) Тогда
		Вес = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Параметры.Страница, "ВесВопроса");
	КонецЕсли;
	
	УстановитьДоступностьЭлементовФормы(ЭтотОбъект);
	
	Если Элементы.ГруппаВыбораВариантаНаКартинке.Видимость
		И НЕ ЗначениеЗаполнено(ШаблонСтраницыВыбораВариантаНаКартинке) Тогда		
		ЗагрузитьШаблонСтраницыВыбораВариантаНаКартинке();		
	КонецЕсли;
	
	ПриОпределенииТиповТестовыхВопросов();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ОтобразитьВариантОтветаНаКартинке();
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	ЗагрузитьВерсиюНаСервере(ТекущийОбъект);
КонецПроцедуры

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
			
	ТекущийОбъект.Наименование = ЭлектронноеОбучениеСлужебный.НаименованиеЭлементаИзТекста(Задание);
	ТекущийОбъект.Задание      = Новый ХранилищеЗначения(Задание);
	
	Если ТекущийОбъект.ТипВопроса = Перечисления.ТипыТестовыхВопросов.ОдинИзМногихНаКартинке Тогда
		Если НЕ ЗначениеЗаполнено(КартинкаЗадания) Тогда
			ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Добавьте картинку с вариантами ответов'"),,,"СтраницаВыбораВариантаНаКартинке",Отказ);
			Возврат;			
		КонецЕсли;
		ТекущийОбъект.Картинка = Новый ХранилищеЗначения(ПолучитьИзВременногоХранилища(КартинкаЗадания));
	Иначе
		ТекущийОбъект.Картинка = Новый ХранилищеЗначения(Неопределено);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриЗаписиНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)	
	
	// Делаем проверки
	
	Если (Объект.ТипВопроса = Перечисления.ТипыТестовыхВопросов.ОдинИзМногих
		ИЛИ Объект.ТипВопроса = Перечисления.ТипыТестовыхВопросов.МногиеИзМногих
		ИЛИ Объект.ТипВопроса = Перечисления.ТипыТестовыхВопросов.Последовательность
		ИЛИ Объект.ТипВопроса = Перечисления.ТипыТестовыхВопросов.ОдинИзМногихНаКартинке
		ИЛИ Объект.ТипВопроса = Перечисления.ТипыТестовыхВопросов.ВводСКлавиатуры
		ИЛИ Объект.ТипВопроса = Перечисления.ТипыТестовыхВопросов.Соответствие)
		И ВариантыОтветов.Количество() = 0 Тогда
		
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Добавьте варианты ответов'"),,,"ВариантыОтветов",Отказ);				
		Возврат;
		
	КонецЕсли; 
	
	Если Объект.ТипВопроса = Перечисления.ТипыТестовыхВопросов.ОдинИзМногих
		ИЛИ Объект.ТипВопроса = Перечисления.ТипыТестовыхВопросов.МногиеИзМногих
		ИЛИ Объект.ТипВопроса = Перечисления.ТипыТестовыхВопросов.ОдинИзМногихНаКартинке Тогда		
		КоличествоВерныхВариантов = ВариантыОтветов.НайтиСтроки(Новый Структура("Верный", Истина)).Количество();		
		Если КоличествоВерныхВариантов = 0 Тогда			
			ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Укажите хотя бы один верный вариант ответа'"),,,,Отказ);
			Возврат;
		КонецЕсли;		
	КонецЕсли;
	
	НомерВарианта = 1;
	Для каждого Строка Из ВариантыОтветов Цикл			
		Если НЕ ЗначениеЗаполнено(Строка.Текст) Тогда			
			ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Укажите текст варианта ответа'"),,ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("ВариантыОтветов", НомерВарианта, "Текст"),,Отказ);
			Возврат;
		КонецЕсли;			
		НомерВарианта = НомерВарианта + 1;			
	КонецЦикла;		
	
	Если Объект.ТипВопроса = Перечисления.ТипыТестовыхВопросов.Соответствие
		И ЭлементыСоответствия.Количество() > 26 Тогда
		
		ВызватьИсключение НСтр("ru = 'Количество вариантов в первой колонке не может превышать 26'");
		
	КонецЕсли;
	
	// Записываем варианты ответа
	
	НомерВарианта = 1;
	
	Для каждого Строка Из ВариантыОтветов Цикл		
		
		Если ЭлектронноеОбучениеСлужебный.СсылкаСуществуетВБазе(Строка.Ссылка, Ложь) Тогда
			БлокировкаДанных = Новый БлокировкаДанных;
			ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Справочник.ВариантыОтветовНаТестовыеВопросы");
			ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", Строка.Ссылка);
			ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
			БлокировкаДанных.Заблокировать();			
			ВариантОбъект = Строка.Ссылка.ПолучитьОбъект();
		Иначе			
			ВариантОбъект = Справочники.ВариантыОтветовНаТестовыеВопросы.СоздатьЭлемент();			
			Если ЗначениеЗаполнено(Строка.Ссылка) Тогда
				ВариантОбъект.УстановитьСсылкуНового(Строка.Ссылка);
			КонецЕсли;
			ВариантОбъект.Владелец = ТекущийОбъект.Ссылка;			
			РазработкаЭлектронныхКурсовСлужебный.УстановитьПредпочитаемогоПоставщика(ВариантОбъект);						
		КонецЕсли;
		
		ВариантОбъект.Код = НомерВарианта;
		ВариантОбъект.Наименование = Строка.Текст;		
		ВариантОбъект.ТекстВарианта = Новый ХранилищеЗначения(Строка.Текст);
		ВариантОбъект.Верный = Строка.Верный;
		ВариантОбъект.ОбластьНаКартинке = Строка.ОбластьНаКартинке;
		ВариантОбъект.НомерПоляВвода = Строка.НомерПоляВвода;		
		Если ЗначениеЗаполнено(Строка.Картинка) Тогда			
			ВариантОбъект.Картинка = Новый ХранилищеЗначения(ПолучитьИзВременногоХранилища(Строка.Картинка));
		Иначе
			ВариантОбъект.Картинка = Новый ХранилищеЗначения(Неопределено);
		КонецЕсли;		
		
		ВариантОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", КонтекстРедактирования);
		ВариантОбъект.Записать();
		
		Строка.Ссылка = ВариантОбъект.Ссылка;
		
		НомерВарианта = НомерВарианта + 1;
		
	КонецЦикла;
	
	// Записываем элементы соответствия
	
	НомерВарианта = 1;
	
	Для каждого Строка Из ЭлементыСоответствия Цикл
		
		Если ЭлектронноеОбучениеСлужебный.СсылкаСуществуетВБазе(Строка.Ссылка, Ложь) Тогда
			БлокировкаДанных = Новый БлокировкаДанных;
			ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Справочник.ВариантыОтветовНаТестовыеВопросы");
			ЭлементБлокировкиДанных.УстановитьЗначение("Ссылка", Строка.Ссылка);
			ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
			БлокировкаДанных.Заблокировать();			
    		ВариантОбъект = Строка.Ссылка.ПолучитьОбъект();
    	Иначе			
    		ВариантОбъект = Справочники.ВариантыОтветовНаТестовыеВопросы.СоздатьЭлемент();			
			Если ЗначениеЗаполнено(Строка.Ссылка) Тогда
				ВариантОбъект.УстановитьСсылкуНового(Строка.Ссылка);
			КонецЕсли;
			ВариантОбъект.Владелец = ТекущийОбъект.Ссылка;
    		РазработкаЭлектронныхКурсовСлужебный.УстановитьПредпочитаемогоПоставщика(ВариантОбъект);						
    	КонецЕсли;
		
		ВариантОбъект.ЭтоЭлементСоответствия = Истина;
    	ВариантОбъект.Код = НомерВарианта;
    	ВариантОбъект.Наименование = Строка.Текст;		
    	ВариантОбъект.ТекстВарианта = Новый ХранилищеЗначения(Строка.Текст);
    	Если ЗначениеЗаполнено(Строка.Картинка) Тогда			
    		ВариантОбъект.Картинка = Новый ХранилищеЗначения(ПолучитьИзВременногоХранилища(Строка.Картинка));
    	Иначе
    		ВариантОбъект.Картинка = Новый ХранилищеЗначения(Неопределено);
    	КонецЕсли;		
		
		ВариантОбъект.ВариантыЭлементаСоответствия.Очистить();
		
		Для каждого ЭлементСпискаВариантов Из Строка.ВариантыОтветов Цикл
			НоваяСтрокаТВЭС = ВариантОбъект.ВариантыЭлементаСоответствия.Добавить();
			НоваяСтрокаТВЭС.ВариантОтвета = ЭлементСпискаВариантов.Значение;		
		КонецЦикла;
		
		ВариантОбъект.ДополнительныеСвойства.Вставить("КонтекстРедактирования", КонтекстРедактирования);
    	ВариантОбъект.Записать();
    	
    	Строка.Ссылка = ВариантОбъект.Ссылка;
    	
    	НомерВарианта = НомерВарианта + 1; 
		
	КонецЦикла;
	
	// Обновляем страницу теста
	
	Если ЗначениеЗаполнено(Страница) Тогда
		Справочники.СтраницыЭлементовЭлектронныхКурсов.Перезаписать(Страница, Вес);	
	КонецЕсли;		
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	Оповестить("ЭлементКурсаЗаписан", Объект.Ссылка, ЭтотОбъект);
	
	Если ЗначениеЗаполнено(Тест) Тогда
		Оповестить("ПодборкаОбновлена", Тест, ЭтотОбъект);
	КонецЕсли;	
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

// ОБРАБОТЧИКИ СОБЫТИЙ ЭЛЕМЕНТОВ ФОРМЫ

&НаКлиенте
Процедура ТипВопросаПриИзменении(Элемент)
	УстановитьДоступностьЭлементовФормы(ЭтотОбъект);
	Если Элементы.ГруппаВыбораВариантаНаКартинке.Видимость
		И НЕ ЗначениеЗаполнено(ШаблонСтраницыВыбораВариантаНаКартинке) Тогда		
		ЗагрузитьШаблонСтраницыВыбораВариантаНаКартинке();		
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ВариантыОтветовКартинкаНажатие(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ВыбратьКартинкуДляВариантаОтвета();
КонецПроцедуры

&НаКлиенте
Процедура ЭлементыСоответствияКартинкаНажатие(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ВыбратьКартинкуДляЭлементаСоответствия();
КонецПроцедуры

&НаКлиенте
Процедура СтраницаВыбораВариантаНаКартинкеПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)
	
	Если ДанныеСобытия = Неопределено Тогда		
		Возврат;		
	КонецЕсли;
		
	Если ДанныеСобытия.Element.id = "v8ImageMapExchangeData" Тогда
		СтандартнаяОбработка = Ложь;
		УстановитьНовыеКоординатыВарианта(ДанныеСобытия.Element.innerText);
	КонецЕсли;
		 
	Если НЕ ЗначениеЗаполнено(ДанныеСобытия.Element.id)
		И ТипЗнч(Элемент.Документ) = Тип("COMОбъект") Тогда
		СтандартнаяОбработка = Ложь;
		УстановитьНовыеКоординатыВарианта(Элемент.Документ.getElementById("v8ImageMapExchangeData").value);		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НаименованиеКолонкиЭлементовПриИзменении(Элемент)
	УстановитьДоступностьЭлементовФормы(ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура НаименованиеКолонкиВариантовПриИзменении(Элемент)
	УстановитьДоступностьЭлементовФормы(ЭтотОбъект);
КонецПроцедуры

&НаКлиенте
Процедура ВариантыОтветовСоответствуетЭлементуПриИзменении(Элемент)
	ОбновитьВариантыОтветаЭлементаСоответствия();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыВариантыОтветов

// ОБРАБОТЧИКИ СОБЫТИЙ ТАБЛИЦЫ ФОРМЫ ВариантыОтветов

&НаКлиенте
Процедура ВариантыОтветовПриАктивизацииСтроки(Элемент)
	Если Элементы.ВариантыОтветов.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ОтобразитьВариантОтветаНаКартинке();
КонецПроцедуры

&НаКлиенте
Процедура ВариантыОтветовПередУдалением(Элемент, Отказ)
	
	ТекущиеДанные = Элемент.ТекущиеДанные;
	
	Если ТекущиеДанные <> Неопределено И ЗначениеЗаполнено(ТекущиеДанные.Ссылка) Тогда	
		УдалитьВариантОтветаНаСервере(ТекущиеДанные.Ссылка);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВариантыОтветовВерныйПриИзменении(Элемент)
	
	Если Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.ОдинИзМногих") Тогда
		
		КоличествоВерныхВариантов = ВариантыОтветов.НайтиСтроки(Новый Структура("Верный", Истина)).Количество();
		
		Если КоличествоВерныхВариантов > 1 Тогда
			Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.МногиеИзМногих");
		КонецЕсли;
		
	КонецЕсли;		
	
КонецПроцедуры

&НаКлиенте
Процедура ВариантыОтветовПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	Если НоваяСтрока Тогда
		
		МассивПараметровК = Новый Массив;
		МассивПараметровК.Добавить(Новый УникальныйИдентификатор());
		БудущийВариантОтвета = Новый(Тип("СправочникСсылка.ВариантыОтветовНаТестовыеВопросы"), МассивПараметровК);
		Элемент.ТекущиеДанные.Ссылка = БудущийВариантОтвета;
		
		Элемент.ТекущиеДанные.ОбластьНаКартинке = НачальныеКоординатыПрямоугольника();
		Элемент.ТекущиеДанные.ТипОбласти = ПредставлениеТипаОбластиПоКоординатам(Элемент.ТекущиеДанные.ОбластьНаКартинке);
		
		Если Объект.ТипВопроса = ПредопределенноеЗначение("Перечисление.ТипыТестовыхВопросов.ВводСКлавиатуры") Тогда
			СвободныйНомер = Неопределено;
			ТекущийНомер = 1;
			Пока СвободныйНомер = Неопределено Цикл
				СтрокиСТекущимНомером = ВариантыОтветов.НайтиСтроки(Новый Структура("НомерПоляВвода", ТекущийНомер));
				Если СтрокиСТекущимНомером.Количество() = 0 Тогда
					СвободныйНомер = ТекущийНомер;
				Иначе
					ТекущийНомер = ТекущийНомер + 1;
				КонецЕсли;
			КонецЦикла;
			Элемент.ТекущиеДанные.НомерПоляВвода = СвободныйНомер;
		КонецЕсли;	
		
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ВариантыОтветовПриОкончанииРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования)
	УстановитьДоступностьЭлементовФормы(ЭтотОбъект);
	ОтобразитьВариантОтветаНаКартинке();
КонецПроцедуры

&НаКлиенте
Процедура ВариантыОтветовПослеУдаления(Элемент)
	УстановитьДоступностьЭлементовФормы(ЭтотОбъект);
	ОтобразитьВариантОтветаНаКартинке();
КонецПроцедуры

&НаКлиенте
Процедура ВариантыОтветовТипОбластиПриИзменении(Элемент)
	ТекущиеДанныеВарианта = Элементы.ВариантыОтветов.ТекущиеДанные;
	Если ТекущиеДанныеВарианта.ТипОбласти = НСтр("ru = 'Круг'") Тогда
		ТекущиеДанныеВарианта.ОбластьНаКартинке = НачальныеКоординатыКруга();		
	Иначе
		ТекущиеДанныеВарианта.ОбластьНаКартинке = НачальныеКоординатыПрямоугольника();
	КонецЕсли;
	ОтобразитьВариантОтветаНаКартинке();
КонецПроцедуры

