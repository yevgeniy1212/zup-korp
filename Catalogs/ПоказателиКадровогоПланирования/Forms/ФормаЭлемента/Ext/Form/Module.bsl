&НаСервере
Процедура ПриПолученииДанных()
	
	ЗаполнитьСписокСтраховыхВзносов();
	НастроитьВидимость();
	
КонецПроцедуры

&НаСервере
Процедура НастроитьВидимость()
	
	ЭтоЗарплата = Объект.Категория = Перечисления.КатегорииРасходовНаПерсонал.Зарплата;
	ЭтоВзносы = Объект.Категория = Перечисления.КатегорииРасходовНаПерсонал.СтраховыеВзносы;
	
	Если ЭтоЗарплата Тогда
		Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаНачисления;
	ИначеЕсли ЭтоВзносы Тогда
		Элементы.Страницы.ТекущаяСтраница = Элементы.СтраницаСтраховыеВзносы;
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "Страницы", "Видимость", ЭтоЗарплата Или ЭтоВзносы);
	
	СтандартныеПодсистемыСервер.УстановитьКлючНазначенияФормы(ЭтотОбъект, "КатегорияСценария" + Объект.Категория);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСписокСтраховыхВзносов()
	
	СтраховыеВзносы.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ВидыВзносов.Ссылка КАК ВидВзносов,
		|	ВЫБОР
		|		КОГДА ПоказателиКадровогоПланированияСтраховыеВзносы.Ссылка ЕСТЬ NULL
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК Пометка
		|ИЗ
		|	Перечисление.ВидыОперацийПоЗарплате КАК ВидыВзносов
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ПоказателиКадровогоПланирования.СтраховыеВзносы КАК
		|			ПоказателиКадровогоПланированияСтраховыеВзносы
		|		ПО ВидыВзносов.Ссылка = ПоказателиКадровогоПланированияСтраховыеВзносы.ВидВзносов
		|		И ПоказателиКадровогоПланированияСтраховыеВзносы.Ссылка = &Ссылка
		|ГДЕ
		|	ВидыВзносов.Ссылка В (&Взносы)";
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	Запрос.УстановитьПараметр("Взносы", КадровоеПланирование.ВидыОперацийПоЗарплатеВзносы());
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СтраховыеВзносы.Добавить(ВыборкаДетальныеЗаписи.ВидВзносов, , ВыборкаДетальныеЗаписи.Пометка);
	КонецЦикла;
	
	СтраховыеВзносы.СортироватьПоПредставлению();
	
КонецПроцедуры

&НаСервере
Процедура НачисленияОбработкаВыбораНаСервере(ВыбранноеЗначение)
	
	УдалениеВыбранныхНачислений(ВыбранноеЗначение.УдаленныеВидыРасчета);
	
	Для Каждого Начисление Из ВыбранноеЗначение.ДобавленныеВидыРасчета Цикл
		Если Объект.Начисления.НайтиСтроки(Новый Структура("Начисление", Начисление)).Количество() = 0 Тогда
			Объект.Начисления.Добавить().Начисление = Начисление;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УдалениеВыбранныхНачислений(УдаленныеНачисления)
	
	Для Каждого Значение Из УдаленныеНачисления Цикл
		СтрокиДляУдаления = Объект.Начисления.НайтиСтроки(Новый Структура("Начисление", Значение));
		Для Каждого ТекСтрока Из СтрокиДляУдаления Цикл 
			Объект.Начисления.Удалить(ТекСтрока);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры	

#КонецОбласти
