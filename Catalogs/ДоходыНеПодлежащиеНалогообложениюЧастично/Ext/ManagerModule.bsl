	ОписаниеЭлемента.НеИспользуется = Ложь;
	СоздатьЭлементДоходаНеПодлежащегоНалогообложениюЧастично(ОписаниеЭлемента);
	
   	ОписаниеЭлемента = ОписаниеЭлементаДоходаНеПодлежащегоНалогообложениюЧастично();
	ОписаниеЭлемента.Наименование = "Пп. 3 п. 1 ст. 436 (выплаты на погребение физического лица)";
	ОписаниеЭлемента.РазмерНеоблагаемогоДохода = 94; //...в пределах 94-кратного размера месячного расчетного показателя
