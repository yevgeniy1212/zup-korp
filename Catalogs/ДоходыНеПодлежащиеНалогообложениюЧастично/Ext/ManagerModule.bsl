КонецПроцедуры

Функция ОписаниеЭлементаДоходаНеПодлежащегоНалогообложениюЧастично()
	Возврат Новый Структура("Наименование, РазмерНеоблагаемогоДохода, ПериодПредоставления, НеИспользуется");	
КонецФункции	

Процедура СоздатьЭлементДоходаНеПодлежащегоНалогообложениюЧастично(ОписаниеЭлемента)
	
	Если ЗначениеЗаполнено(ОписаниеЭлемента.Наименование) Тогда
		
		СсылкаНаОбъект =  Справочники.ДоходыНеПодлежащиеНалогообложениюЧастично.НайтиПоНаименованию(ОписаниеЭлемента.Наименование); 
		Если ЗначениеЗаполнено(СсылкаНаОбъект) Тогда
			Элемент = СсылкаНаОбъект.ПолучитьОбъект();
		Иначе
			Элемент = Справочники.ДоходыНеПодлежащиеНалогообложениюЧастично.СоздатьЭлемент();
		КонецЕсли;
		
	КонецЕсли; 
	
	ЗаполнитьЗначенияСвойств(Элемент, ОписаниеЭлемента);
	Элемент.Записать();
	
КонецПроцедуры	

Процедура ОбновитьСправочникДоходыНеПодлежащиеНалогообложениюЧастично2023() Экспорт 
    
    ДивидендыФизическихЛиц = Справочники.ДоходыНеПодлежащиеНалогообложениюЧастично.НайтиПоНаименованию("Пп. 8 п. 1 ст. 341 (дивиденды, полученные от юридического лица – резидента)");
    
    Если ДивидендыФизическихЛиц = Справочники.ДоходыНеПодлежащиеНалогообложениюЧастично.ПустаяСсылка() Тогда
        ОписаниеЭлемента = ОписаниеЭлементаДоходаНеПодлежащегоНалогообложениюЧастично();
        ОписаниеЭлемента.Наименование = "Пп. 8 п. 1 ст. 341 (дивиденды, полученные от юридического лица – резидента)";
        ОписаниеЭлемента.РазмерНеоблагаемогоДохода = 30000; //...в пределах 30 000-кратного размера месячного расчетного показателя
        ОписаниеЭлемента.ПериодПредоставления = Перечисления.ПериодыРасчетаВычетовИКорректировокДоходов.ВПределахКалендарногоГода;
        ОписаниеЭлемента.НеИспользуется = Ложь;
        СоздатьЭлементДоходаНеПодлежащегоНалогообложениюЧастично(ОписаниеЭлемента);
        
        РегистрыСведений.РазмерыДоходовНеПодлежащихНалогообложениюЧастично.НачальноеЗаполнение();
    КонецЕсли; 
    	
КонецПроцедуры

