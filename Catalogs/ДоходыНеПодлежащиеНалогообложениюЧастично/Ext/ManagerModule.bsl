	ОписаниеЭлемента.Наименование = "Пп. 13 п. 1 ст. 432 (выплаты в связи с профессиональным обучением)";
	ОписаниеЭлемента.РазмерНеоблагаемогоДохода = 12;  //...в 12-кратном размере месячного расчетного показателя
