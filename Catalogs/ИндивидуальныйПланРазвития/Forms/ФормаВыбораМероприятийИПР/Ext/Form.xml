			</UseAlways>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ИПР.Ссылка КАК ИПР,
	ИПР.Ссылка.Подразделение КАК Подразделение,
	ИПР.Ссылка.Владелец КАК ФизическоеЛицо,
	ИПР.Мероприятие КАК Мероприятие,
	ИПР.ДатаНачала КАК ДатаНачала,
	ИПР.ДатаОкончания КАК ДатаОкончания,
	ИПР.Мероприятие.КоличествоУчебныхЧасов КАК КоличествоУчебныхЧасов,
	ИПР.Мероприятие.Стоимость КАК Стоимость,
	ИПР.Мероприятие.СпособОпределенияСтоимости КАК СпособОпределенияСтоимости
ИЗ
	Справочник.ИндивидуальныйПланРазвития.Мероприятия КАК ИПР
ГДЕ
	ИПР.ДатаНачала &lt;= &amp;ДатаОкончания
	И ИПР.ДатаОкончания &gt;= &amp;ДатаНачала
	И НЕ ИПР.Ссылка.ПометкаУдаления
	И (ИПР.Ссылка.Подразделение В ИЕРАРХИИ (&amp;Подразделение)
			ИЛИ ИПР.Ссылка.Подразделение = ЗНАЧЕНИЕ(Справочник.СтруктураПредприятия.ПустаяСсылка))</QueryText>
