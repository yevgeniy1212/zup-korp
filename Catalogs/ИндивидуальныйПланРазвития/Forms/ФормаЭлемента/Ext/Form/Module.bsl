// Конец СтандартныеПодсистемы.Свойства

#КонецОбласти 

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПриПолученииДанныхНаСервере()

	УстановитьСвойстваЭлементовФормы();
	
	ОбучениеРазвитиеФормы.ЗаполнитьКэшХарактеристикиМероприятияПоХарактеристикам(КэшХарактеристикиМероприятия, 
		Объект.РазвиваемыеХарактеристики.Выгрузить(, "Характеристика").ВыгрузитьКолонку("Характеристика"));

	ЗаполнитьВторичнуюТаблицуХарактеристики();
	ЗаполнитьВторичнуюИнформациюПланаОбучения();
	ЗаполнитьРезультатыОбучения();

КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВторичнуюТаблицуХарактеристики()
	
	ХарактеристикиПерсоналаФормы.ПрочитатьХарактеристикиВТаблицы(Объект.РазвиваемыеХарактеристики, Характеристики, ЗначенияХарактеристик);
	ДополнитьХарактеристикиДаннымиХарактеристикСотрудника();
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВторичнуюИнформациюПланаОбучения()
	
	ОбучениеРазвитиеФормы.ЗаполнитьСтрокиХарактеристикВТаблицеПрограммаОбучения(
		Объект.Мероприятия, Объект.РазвиваемыеХарактеристики, КэшХарактеристикиМероприятия);
	ОбучениеРазвитиеФормы.ЗаполнитьУчебныеЧасыПланаОбучения(ЭтаФорма, , "Объект.Мероприятия");
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРезультатыОбучения(СтрокиТаблицы = Неопределено)

	Если Не РезультатыОбученияДоступны Тогда
		Возврат;
	КонецЕсли;

	ОтборСтрок = Новый Структура("Мероприятие, ДатаНачала, ДатаОкончания");
	Результаты = РезультатыОбучения(Объект.Владелец, 
		Объект.Мероприятия.Выгрузить(СтрокиТаблицы, "Мероприятие, ДатаНачала, ДатаОкончания"));
	Обход = Обработки.ОбходКоллекции.НовыйОбход(Результаты);
	Пока Обход.СледующийПоЗначениямПолей("ФизическоеЛицо, Мероприятие, ДатаНачалаПлан, ДатаОкончанияПлан") Цикл
		ОтборСтрок.Мероприятие = Обход.ТекущиеДанные().Мероприятие;
		ОтборСтрок.ДатаНачала = Обход.ТекущиеДанные().ДатаНачалаПлан;
		ОтборСтрок.ДатаОкончания = Обход.ТекущиеДанные().ДатаОкончанияПлан;
		НайденныеСтроки = Объект.Мероприятия.НайтиСтроки(ОтборСтрок);
		Если НайденныеСтроки.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		СтрокиРезультатов = Новый Массив;
		Пока Обход.Следующий() Цикл
			СтрокиРезультатов.Добавить(Обход.ТекущиеДанные());
		КонецЦикла;
		Для Каждого СтрокаТаблицы Из НайденныеСтроки Цикл
			ЗаполнитьРезультатОбученияВСтроке(СтрокаТаблицы, СтрокиРезультатов);
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьРезультатОбучения(ТекущиеДанные)
	
	Если Не РезультатыОбученияДоступны Тогда
		Возврат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ТекущиеДанные.Мероприятие)
		Или Не ЗначениеЗаполнено(ТекущиеДанные.ДатаНачала)
		Или Не ЗначениеЗаполнено(ТекущиеДанные.ДатаОкончания) Тогда
		Возврат;
	КонецЕсли;
	
	Результаты = РезультатОбучения(
		Объект.Владелец, ТекущиеДанные.Мероприятие, ТекущиеДанные.ДатаНачала, ТекущиеДанные.ДатаОкончания);

	ЗаполнитьРезультатОбученияВСтроке(ТекущиеДанные, Результаты);

КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ЗаполнитьРезультатОбученияВСтроке(СтрокаТаблицы, РезультатыОбучения)
	
	СтрокаТаблицы.РезультатОбучения = ОбучениеРазвитиеКлиентСервер.ПредставлениеРезультатовОбучения(РезультатыОбучения);
	
	СтрокаТаблицы.ДокументыОбучения = Новый СписокЗначений();
	Для Каждого СтрокаРезультата Из РезультатыОбучения Цикл
		СтрокаТаблицы.ДокументыОбучения.Добавить(СтрокаРезультата.ДокументОбучения);
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция РезультатОбучения(ФизическоеЛицо, Мероприятие, ДатаНачала, ДатаОкончания)

	ПланМероприятий = ОбучениеРазвитие.НовыйПланМероприятий();
	НоваяСтрока = ПланМероприятий.Добавить();
	НоваяСтрока.ФизическоеЛицо = ФизическоеЛицо;
	НоваяСтрока.Мероприятие = Мероприятие;
	НоваяСтрока.ДатаНачала = ДатаНачала;
	НоваяСтрока.ДатаОкончания = ДатаОкончания;
	
	РезультатыТаблица = РезультатыОбучения(ФизическоеЛицо, ПланМероприятий);
	
	Результаты = Новый Массив;
	Для Каждого СтрокаТаблицы Из РезультатыТаблица Цикл
		Результаты.Добавить(ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(СтрокаТаблицы));
	КонецЦикла;
	
	Возврат Результаты;
	
КонецФункции

&НаСервереБезКонтекста
Функция РезультатыОбучения(ФизическоеЛицо, СтрокиТаблицы)
	
	ПланМероприятий = ОбучениеРазвитие.НовыйПланМероприятий();
	Для Каждого СтрокаТаблицы Из СтрокиТаблицы Цикл
		НоваяСтрока = ПланМероприятий.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаТаблицы);
		НоваяСтрока.ФизическоеЛицо = ФизическоеЛицо;
	КонецЦикла;
	
	Возврат ОбучениеРазвитие.РезультатыОбучения(ПланМероприятий);

КонецФункции

