&НаСервере
Функция АдресПрограммыОбучения()
	Возврат ПоместитьВоВременноеХранилище(Объект.Мероприятия.Выгрузить(, "Мероприятие,Ответственный"), УникальныйИдентификатор);
КонецФункции

&НаКлиенте
Процедура ХарактеристикиТребуетсяОбучениеПриИзмененииНаКлиенте()

	ХарактеристикиТребуетсяОбучениеПриИзмененииНаСервере();
	
	СтрокиСУдаленнымиМероприятиями = Новый Массив;
	Для каждого СтрокаМероприятия Из Объект.Мероприятия Цикл
		Если СтрокаМероприятия.СтрокаХарактеристикОчистилась Тогда
			СтрокиСУдаленнымиМероприятиями.Добавить(СтрокаМероприятия);
		КонецЕсли;
	КонецЦикла; 
	
	Если СтрокиСУдаленнымиМероприятиями.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ОповещениеОЗакрытии = Новый ОписаниеОповещения("УдалитьВыбранноеМероприятиеЗавершение", ЭтотОбъект, Новый Структура("СтрокиСУдаленнымиМероприятиями", СтрокиСУдаленнымиМероприятиями));
	
	ТекстВопроса = ТекстВопросаУдаления(СтрокиСУдаленнымиМероприятиями);
	СписокКнопок = Новый СписокЗначений;
	СписокКнопок.Добавить(КодВозвратаДиалога.Да, НСтр("ru = 'Да, исключить'"));
	СписокКнопок.Добавить(КодВозвратаДиалога.Нет, НСтр("ru = 'Нет, оставить'"));
	
	ПоказатьВопрос(ОповещениеОЗакрытии, ТекстВопроса, СписокКнопок,, КодВозвратаДиалога.Да);
		
КонецПроцедуры

&НаКлиенте
Функция ТекстВопросаУдаления(СтрокиСУдаленнымиМероприятиями)

	Если СтрокиСУдаленнымиМероприятиями.Количество() = 1 Тогда
		
		Возврат СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Не осталось характеристик, которое развивает мероприятие ""%1"".
								|Исключить его из программы обучения?'"),
			СтрокиСУдаленнымиМероприятиями[0].Мероприятие);
		
	Иначе
		
		ТекстМероприятий = "";
		Для каждого СтрокаУдаляемогоМероприятия Из СтрокиСУдаленнымиМероприятиями Цикл
			ТекстМероприятий = ТекстМероприятий + ?(ТекстМероприятий = "", "", ", ") + """" + СтрокаУдаляемогоМероприятия.Мероприятие + """";
		КонецЦикла; 
		
		Возврат СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Не осталось характеристик, которые развивают мероприятия ""%1"".
								|Исключить их из программы обучения?'"),
			ТекстМероприятий);
			
	КонецЕсли;
	
КонецФункции

&НаСервере
Процедура ХарактеристикиТребуетсяОбучениеПриИзмененииНаСервере()
	ОбучениеРазвитиеФормы.ЗаполнитьСтрокиХарактеристикВТаблицеПрограммаОбучения(Объект.Мероприятия, Характеристики, КэшХарактеристикиМероприятия, Истина);
КонецПроцедуры

&НаКлиенте
Процедура УдалитьВыбранноеМероприятиеЗавершение(Результат = Неопределено, ДополнительныеПараметры = Неопределено) Экспорт

	Если Результат <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;

	Если ДополнительныеПараметры = Неопределено ИЛИ НЕ ДополнительныеПараметры.Свойство("СтрокиСУдаленнымиМероприятиями") Тогда
		Возврат;
	КонецЕсли;
	
	Для каждого УдаляемаяСтрока Из ДополнительныеПараметры.СтрокиСУдаленнымиМероприятиями Цикл
		Объект.Мероприятия.Удалить(УдаляемаяСтрока);
	КонецЦикла; 
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьВторичныеДанныеОбученияНаСервере(ИдентификаторТекущейСтроки)
	ОбучениеРазвитиеФормы.ЗаполнитьУчебныеЧасыПланаОбучения(ЭтаФорма, ИдентификаторТекущейСтроки, "Объект.Мероприятия");
	ОбучениеРазвитиеФормы.ЗаполнитьОтветственногоВСтрокеПрограммыОбучения(ЭтаФорма, ИдентификаторТекущейСтроки, "Объект.Мероприятия");
КонецПроцедуры

&НаКлиенте
Процедура НачатьРедактированиеРезультатаВыполнения(ТекстРедактирования)
	
	ОбщегоНазначенияКлиент.ПоказатьФормуРедактированияМногострочногоТекста(
		Новый ОписаниеОповещения("ЗавершитьРедактированиеРезультатаВыполнения", ЭтотОбъект, 
			Новый Структура("ИдентификаторСтроки", Элементы.Мероприятия.ТекущиеДанные.ПолучитьИдентификатор())),
		ТекстРедактирования);

КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьРедактированиеРезультатаВыполнения(ВведенныйТекст, ДополнительныеПараметры) Экспорт
	
	Если ВведенныйТекст = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Объект.Мероприятия.НайтиПоИдентификатору(ДополнительныеПараметры.ИдентификаторСтроки).РезультатВыполнения = ВведенныйТекст;
	Модифицированность = Истина;

КонецПроцедуры

&НаКлиенте
Процедура ОткрытьХарактеристикиМероприятия(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле.Имя <> Элементы.МероприятияСтрокаХарактеристик.Имя Тогда
		Возврат;
	КонецЕсли;

	ТекущиеДанные = Элементы.Мероприятия.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Или Не ЗначениеЗаполнено(ТекущиеДанные.Мероприятие) Тогда
		Возврат;
	КонецЕсли;
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("Ключ", ТекущиеДанные.Мероприятие);
	СтруктураПараметров.Вставить("ОткрытьСписокХарактеристик", Истина);
	
	ОткрытьФорму("Справочник.МероприятияОбученияРазвития.ФормаОбъекта", СтруктураПараметров, ЭтотОбъект, УникальныйИдентификатор);

КонецПроцедуры

&НаКлиенте
Процедура ОткрытьДокументОбучение(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле <> Элементы.МероприятияРезультатОбучения Тогда
		Возврат;
	КонецЕсли;

	Если Не РезультатыОбученияДоступны Тогда
		Возврат;
	КонецЕсли;

	ТекущиеДанные = Элементы.Мероприятия.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ДокументыОбучения = ТекущиеДанные.ДокументыОбучения;

	Если ДокументыОбучения.Количество() = 0 Тогда
		СоздатьНовыйДокументОбучение(ТекущиеДанные);
	ИначеЕсли ДокументыОбучения.Количество() = 1 Тогда
		ОткрытьСуществующийДокументОбучение(ДокументыОбучения[0].Значение);
	Иначе
		ПоказатьВыборИзСписка(
			Новый ОписаниеОповещения("ЗавершитьВыборДокументаОбученияИзСписка", ЭтотОбъект), ДокументыОбучения);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьВыборДокументаОбученияИзСписка(ЭлементСписка, ДополнительныеПараметры) Экспорт
	
	Если ЭлементСписка = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ОткрытьСуществующийДокументОбучение(ЭлементСписка.Значение);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьСуществующийДокументОбучение(ДокументОбучения)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Ключ", ДокументОбучения);
	
	ОткрытьФорму("Документ.ОбучениеРазвитиеСотрудников.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект);

КонецПроцедуры

&НаКлиенте
Процедура СоздатьНовыйДокументОбучение(СтрокаТаблицы)
	
	Если Не ВводОбученияДоступен Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Обучение пока не пройдено.'"));
		Возврат;
	КонецЕсли;
	
	НачатьСозданиеДокументаОбучения(СтрокаТаблицы);
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьСозданиеДокументаОбучения(СтрокаТаблицы)
	
	ПараметрыВопроса = СтандартныеПодсистемыКлиент.ПараметрыВопросаПользователю();
	ПараметрыВопроса.Заголовок = НСтр("ru = 'Обучение не пройдено'");
	ПараметрыВопроса.ПредлагатьБольшеНеЗадаватьЭтотВопрос = Ложь;
	
	ТекстВопроса = НСтр("ru = 'Обучение пока не пройдено. Ввести новый документ обучения?'");
	
	СтандартныеПодсистемыКлиент.ПоказатьВопросПользователю(
		Новый ОписаниеОповещения("ЗавершитьСозданиеДокументаОбучения", ЭтотОбъект, Новый Структура("СтрокаТаблицы", СтрокаТаблицы)), 
		ТекстВопроса, РежимДиалогаВопрос.ДаНет, ПараметрыВопроса);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьСозданиеДокументаОбучения(Ответ, ДополнительныеПараметры) Экспорт
	
	Если СвойствоСтруктуры(Ответ, "Значение") <> КодВозвратаДиалога.Да Тогда
		Возврат;
	КонецЕсли;
	
	СтрокаТаблицы = ДополнительныеПараметры.СтрокаТаблицы;
	
	КадровыеДанные = КадровыеДанные(Объект.Владелец, СтрокаТаблицы.ДатаНачала);

	ЗначенияЗаполнения = Новый Структура();
	ЗначенияЗаполнения.Вставить("Мероприятие", СтрокаТаблицы.Мероприятие);
	ЗначенияЗаполнения.Вставить("ДатаНачала", СтрокаТаблицы.ДатаНачала);
	ЗначенияЗаполнения.Вставить("ДатаОкончания", СтрокаТаблицы.ДатаОкончания);
	ЗначенияЗаполнения.Вставить("Сотрудники", ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(КадровыеДанные.Сотрудник));
	ЗначенияЗаполнения.Вставить("Подразделение", КадровыеДанные.МестоВСтруктуреПредприятия);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ЗначенияЗаполнения", ЗначенияЗаполнения);
	
	ОткрытьФорму("Документ.ОбучениеРазвитиеСотрудников.ФормаОбъекта", ПараметрыФормы, ЭтотОбъект);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция КадровыеДанные(ФизическоеЛицо, ДатаАктуальности)
	
	ПараметрыПолучения = КадровыйУчет.ПараметрыПолученияСотрудниковОрганизацийПоСпискуФизическихЛиц();
	ПараметрыПолучения.КадровыеДанные = "МестоВСтруктуреПредприятия";
	ПараметрыПолучения.СписокФизическихЛиц = ФизическоеЛицо;
	ПараметрыПолучения.НачалоПериода = ДатаАктуальности;
	ПараметрыПолучения.ОкончаниеПериода = ДатаАктуальности;
	
	КадровыеДанные = КадровыйУчет.СотрудникиОрганизации(Истина, ПараметрыПолучения);
	
	ОбщегоНазначенияКлиентСервер.Проверить(КадровыеДанные.Количество() > 0, 
		СтрШаблон(НСтр("ru = 'Не удалось получить кадровые данные.
					   |Возможно, %1 не принят на работу по состоянию на %2.'"), 
				ФизическоеЛицо, Формат(ДатаАктуальности, "ДЛФ=D;")), 
		Метаданные.Справочники.ИндивидуальныйПланРазвития.ПолноеИмя());
	
	Возврат ОбщегоНазначения.СтрокаТаблицыЗначенийВСтруктуру(КадровыеДанные[0]);
	
КонецФункции

&НаСервере
Процедура УстановитьУсловноеОформление()
	
	Элемент = УсловноеОформление.Элементы.Добавить();
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(
		Элемент.Отбор, "Объект.Мероприятия.РезультатОбучения", , ВидСравненияКомпоновкиДанных.НеЗаполнено);
	Элемент.Поля.Элементы.Добавить().Поле = Новый ПолеКомпоновкиДанных("МероприятияРезультатОбучения");
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ТекстПодобранногоЗначенияЦвет);
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = '<Обучение не пройдено>'"));

	Элемент = УсловноеОформление.Элементы.Добавить();
	ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(
		Элемент.Отбор, "Объект.Мероприятия.РезультатВыполнения", , ВидСравненияКомпоновкиДанных.НеЗаполнено);
	Элемент.Поля.Элементы.Добавить().Поле = Новый ПолеКомпоновкиДанных("МероприятияРезультатВыполнения");
	Элемент.Оформление.УстановитьЗначениеПараметра("ЦветТекста", ЦветаСтиля.ТекстПодобранногоЗначенияЦвет);
	Элемент.Оформление.УстановитьЗначениеПараметра("Текст", НСтр("ru = 'Комментарий'"));
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьРезультатыОбучения(СтрокаТаблицы)
	СтрокаТаблицы.РезультатОбучения = Неопределено;
	СтрокаТаблицы.ДокументыОбучения.Очистить();
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьОповещениеДокументаОбучения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия <> "Запись_ОбучениеРазвитиеСотрудников" Тогда
		Возврат;
	КонецЕсли;
	
	Если СвойствоСтруктуры(Параметр, "РежимЗаписи", РежимЗаписиДокумента.Запись) = РежимЗаписиДокумента.Запись Тогда
		Возврат;
	КонецЕсли;
	
	Мероприятие = СвойствоСтруктуры(Параметр, "Мероприятие");
	Если Не ЗначениеЗаполнено(Мероприятие) Тогда
		Возврат;
	КонецЕсли;
	
	Если СвойствоСтруктуры(Параметр, "ДатаОкончания", Дата(1, 1, 1)) < Объект.ДатаНачала 
		Или СвойствоСтруктуры(Параметр, "ДатаНачала", Дата(1, 1, 1)) > Объект.ДатаОкончания Тогда
		Возврат;
	КонецЕсли;
	
	ЗаполнитьРезультатыОбученияПоМероприятию(Мероприятие);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьРезультатыОбученияПоМероприятию(Мероприятие)
	
	НайденныеСтроки = Объект.Мероприятия.НайтиСтроки(Новый Структура("Мероприятие", Мероприятие));
	Если НайденныеСтроки.Количество() > 0 Тогда
		ЗаполнитьРезультатыОбучения(НайденныеСтроки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция СвойствоСтруктуры(Структура, Ключ, ЗначениеПоУмолчанию = Неопределено)
	Возврат ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Структура, Ключ, ЗначениеПоУмолчанию);
КонецФункции

&НаСервере
Процедура УстановитьСвойстваЭлементовФормы()
	
	РезультатыОбученияДоступны = ПравоДоступа("Чтение", Метаданные.РегистрыСведений.ОбучениеСотрудников);
	ВводОбученияДоступен = ПравоДоступа("Добавление", Метаданные.Документы.ОбучениеРазвитиеСотрудников);
	
	Если Не РезультатыОбученияДоступны Тогда
		Элементы.МероприятияРезультатОбучения.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДополнитьПланОбученияПериодами()
	
	Если Не ЗначениеЗаполнено(Объект.ДатаНачала) Тогда
		Возврат;
	КонецЕсли;
	
	ПланОбученияСДатами = ОбучениеРазвитие.ПрограммаОбученияПоДатам(
		Объект.ДатаНачала,
		ПланОбучения.Выгрузить(),
		РазмерностьПродолжительностиПланаОбучения);
		
	Для каждого СтрокаМероприятия Из Объект.Мероприятия Цикл
		НайденныеСтроки = ПланОбученияСДатами.НайтиСтроки(Новый Структура("Мероприятие", СтрокаМероприятия.Мероприятие));
		Если НайденныеСтроки.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(СтрокаМероприятия, НайденныеСтроки[0],"ДатаНачала, ДатаОкончания");
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти