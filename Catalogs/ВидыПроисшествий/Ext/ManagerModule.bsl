// Начальное заполнение видов происшествий.
Процедура НачальноеЗаполнение() Экспорт
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	|	ИСТИНА КАК ЗначениеИстина
	|ИЗ
	|	Справочник.ВидыПроисшествий КАК ВидыПроисшествий
	|ГДЕ
	|	ВидыПроисшествий.КодПриказа223Н";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если Не РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	КлассификаторXML = ПолучитьМакет("ВидыПроисшествий").ПолучитьТекст();
	КлассификаторТаблица = ОбщегоНазначения.ПрочитатьXMLВТаблицу(КлассификаторXML).Данные;
	Для Каждого СтрокаКлассификатора Из КлассификаторТаблица Цикл
		СправочникСсылка = НайтиПоКоду(СтрокаКлассификатора.Code);
		Если Не ЗначениеЗаполнено(СправочникСсылка) Тогда
			НайденныеСтроки = КлассификаторТаблица.НайтиСтроки(Новый Структура("CodeParent", СтрокаКлассификатора.Code));
			Если НайденныеСтроки.Количество() = 0 Тогда
				СправочникОбъект = СоздатьЭлемент();
			Иначе
				СправочникОбъект = СоздатьГруппу();
			КонецЕсли;
		Иначе
			СправочникОбъект = СправочникСсылка.ПолучитьОбъект();
		КонецЕсли;
		
		СправочникОбъект.Код = СтрокаКлассификатора.Code;
		СправочникОбъект.ПолноеНаименование = СтрокаКлассификатора.Title;
		СправочникОбъект.КодПоКлассификатору = СтрокаКлассификатора.CodeView;
		СправочникОбъект.Родитель = НайтиПоКоду(СтрокаКлассификатора.CodeParent);
		СправочникОбъект.КодПриказа223Н = Истина;
		
		СправочникОбъект.ДополнительныеСвойства.Вставить("ПодборИзКлассификатора");
		ОбновлениеИнформационнойБазы.ЗаписатьДанные(СправочникОбъект);
	КонецЦикла;
	
	ПроверитьНаличиеУстаревшихЭлементов();
	
КонецПроцедуры

Процедура ПроверитьНаличиеУстаревшихЭлементов()
	
	КодГруппыУстаревшихЭлементов = ОхранаТруда.КодГруппыУстаревшихЭлементов();
	
	Запрос = Новый Запрос;
	
	Запрос.Текст =
		"ВЫБРАТЬ
		|	ВидыПроисшествий.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ВидыПроисшествий КАК ВидыПроисшествий
		|ГДЕ
		|	(ВидыПроисшествий.Родитель = ЗНАЧЕНИЕ(Справочник.ВидыПроисшествий.ПустаяСсылка)
		|	ИЛИ ВидыПроисшествий.Родитель.КодПриказа223Н)
		|	И НЕ ВидыПроисшествий.КодПриказа223Н
		|	И НЕ ВидыПроисшествий.Код = &КодГруппыУстаревшихЭлементов";
	
	Запрос.УстановитьПараметр("КодГруппыУстаревшихЭлементов", КодГруппыУстаревшихЭлементов);
	
	// АПК:1328-выкл используется при начальном заполнении ИБ.
	РезультатЗапроса = Запрос.Выполнить();
	// АПК:1328-вкл
	
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	ГруппаУстаревшихЭлементов = НайтиПоКоду(КодГруппыУстаревшихЭлементов);
	Если Не ЗначениеЗаполнено(ГруппаУстаревшихЭлементов) Тогда
		ГруппаУстаревшихЭлементовОбъект = СоздатьГруппу();
		ГруппаУстаревшихЭлементовОбъект.Код = КодГруппыУстаревшихЭлементов;
		ГруппаУстаревшихЭлементовОбъект.ПолноеНаименование = НСтр("ru = 'Устаревшие элементы'");
		ГруппаУстаревшихЭлементовОбъект.КодПоКлассификатору = "OLD";
		
		ГруппаУстаревшихЭлементовОбъект.ДополнительныеСвойства.Вставить("ПодборИзКлассификатора");
		ОбновлениеИнформационнойБазы.ЗаписатьДанные(ГруппаУстаревшихЭлементовОбъект);
		
		ГруппаУстаревшихЭлементов = ГруппаУстаревшихЭлементовОбъект.Ссылка;
	КонецЕсли;
		
	Выборка = РезультатЗапроса.Выбрать();
	Пока Выборка.Следующий() Цикл
		СправочникОбъект = Выборка.Ссылка.ПолучитьОбъект();
		СправочникОбъект.Родитель = ГруппаУстаревшихЭлементов;
		
		СправочникОбъект.ДополнительныеСвойства.Вставить("ПодборИзКлассификатора");
		ОбновлениеИнформационнойБазы.ЗаписатьДанные(СправочникОбъект);
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли