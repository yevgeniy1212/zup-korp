
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ДанныеСервиса = Видеоконференции.ДанныеСервиса(Объект.Сервис);
	
	Элементы.ПриветственноеСообщение.Видимость = ДанныеСервиса.ДоступенЧат;
	
	ЭлементыСтиля = СтандартныеПодсистемыСервер.ЭлементыСтиля();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ОбновитьОтображение();
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	
	ОбщегоНазначенияКлиент.ОповеститьОбИзмененииОбъекта(Объект.Ссылка);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ОбновитьОтображение()
	
	ПроверитьСостояниеПодключения();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтобразитьСостояниеПодключения()
	
	Если УчетнаяЗаписьНастроена Тогда
		Элементы.СостояниеПодключенияНадпись.ЦветТекста = ЭлементыСтиля.РезультатУспехЦвет;
		Элементы.СостояниеПодключенияНадпись.Заголовок = НСтр("ru = 'Подключено'");
		Элементы.СостояниеПодключенияКартинка.Картинка = БиблиотекаКартинок.ЗеленыйШар;
	Иначе
		Элементы.СостояниеПодключенияНадпись.ЦветТекста = ЭлементыСтиля.РезультатПроблемаЦвет;
		Элементы.СостояниеПодключенияНадпись.Заголовок = НСтр("ru = 'Не подключено'");
		Элементы.СостояниеПодключенияКартинка.Картинка = БиблиотекаКартинок.КрасныйШар;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьСостояниеПодключения()
	
	Элементы.СостояниеПодключенияКартинка.Картинка = БиблиотекаКартинок.НезавершившаясяПроверка;
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершитьПроверкуСостоянияПодключенияOAuth", ЭтотОбъект);
	
	ДлительнаяОперация = ДлительнаяОперацияПроверкиПодключения(УникальныйИдентификатор);
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДлительнаяОперацияПроверкиПодключения(УникальныйИдентификатор)
	
	ИмяПроцедуры = "Видеоконференции.НастроенныеУчетныеЗаписи";
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(УникальныйИдентификатор, ИмяПроцедуры);
	
КонецФункции

&НаКлиенте
Процедура ЗавершитьПроверкуСостоянияПодключенияOAuth(ДлительнаяОперация, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ДлительнаяОперация = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ДлительнаяОперация.Статус = "Ошибка" Тогда
		ПоказатьПредупреждение(, ДлительнаяОперация.КраткоеПредставлениеОшибки);
		Возврат;
	ИначеЕсли Не ДлительнаяОперация.Статус = "Выполнено" Тогда
		Возврат;
	КонецЕсли;
	
	Результат = ПолучитьИзВременногоХранилища(ДлительнаяОперация.АдресРезультата);
	
	УчетнаяЗаписьНастроена = Результат.Найти(Объект.Ссылка) <> Неопределено;
	
	ОтобразитьСостояниеПодключения();
	
КонецПроцедуры

#КонецОбласти