
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ЗаполнитьДанныеСервисов();
	
	ОбсужденияДоступны = Видеоконференции.ДоступныВнешниеПользователиСистемыВзаимодействия();
	
	Если ДанныеСервисов.Количество() <= 1 И Не ОбсужденияДоступны Тогда
		ОбщегоНазначения.СообщитьПользователю(
			НСтр("ru = 'Для подключения видеоконференций требуется версия платформы не ниже 8.3.20'"));
		ИспользованиеНевозможно = Истина;
		Возврат;
	КонецЕсли;
	
	Элементы.ГруппаШаблон.Видимость = Ложь;
	Элементы.Группа1С.Видимость = ОбсужденияДоступны;
	
	ДополнитьФорму();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Если ИспользованиеНевозможно Тогда
		ОтменитьИспользованиеВидеоконференций();
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	СкрытьКомандныеПанелиТаблиц();
	
	ОбновитьОтображение();
	
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	
	Если Не ЕстьНастроенныеУчетныеЗаписи() Тогда
		ОписаниеОповещения = Новый ОписаниеОповещения("ОтменитьИспользованиеВидеоконференций", ЭтотОбъект);
		ТекстПредупреждения = НСтр("ru = 'Не настроено ни одной учетной записи.
										 |Возможность использования видеоконференций будет отключена. Продолжить?'");
		ОбщегоНазначенияКлиент.ПоказатьПодтверждениеЗакрытияПроизвольнойФормы(
			ЭтотОбъект, Отказ, ЗавершениеРаботы, ТекстПредупреждения, "ЗакрытьФормуБезПодтверждения", ОписаниеОповещения);
	ИначеЕсли Не ЗавершениеРаботы Тогда
		Оповестить("ИзмененыНастройкиУчетныхЗаписейВидеоконференций", Истина);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ОбсужденияПодключены" Или ИмяСобытия = "Запись_УчетныеЗаписиВидеоконференций" Тогда
		ОбновитьПовторноИспользуемыеЗначения();
		ОбновитьОтображение();
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыУчетныеЗаписи

&НаКлиенте
Процедура Подключаемый_УчетныеЗаписиПриАктивизацииСтроки(Элемент)
	
	Если Элемент.ТекущиеДанные <> Неопределено Тогда
		ТекущаяУчетнаяЗапись = Элемент.ТекущиеДанные.УчетнаяЗапись;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_УчетныеЗаписиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ИмяТаблицы = СтрЗаменить(Элемент.Имя, "УчетныеЗаписи", "");
	
	Если Поле.Имя = "УчетныеЗаписиУчетнаяЗапись" + ИмяТаблицы Тогда
		СтандартнаяОбработка = Ложь;
		ПоказатьЗначение(, Элемент.ТекущиеДанные.УчетнаяЗапись);
	ИначеЕсли Поле.Имя = "УчетныеЗаписиПодключитьОтключить" + ИмяТаблицы Тогда
		СтандартнаяОбработка = Ложь;
		
		Если Элемент.ТекущиеДанные.Состояние = ИдентификаторыЦвета().Настроено Тогда
			ПоказатьВопрос(
				Новый ОписаниеОповещения("УдалитьУчетнуюЗаписьВопрос", ЭтотОбъект),
				НСтр("ru = 'Будет выполнено удаление учетной записи. Продолжить?'"),
				РежимДиалогаВопрос.ДаНет);
		Иначе
			ИмяСервиса = ИмяСервиса(Элемент.Имя, "УчетныеЗаписи");
			Элементы["Страницы" + ИмяСервиса].ТекущаяСтраница = Элементы["СтраницаПодключение" + ИмяСервиса];
			ЭтотОбъект["КодАвторизации" + ИмяСервиса] = "";
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ДобавитьУчетнуюЗапись(Команда)
	
	ИмяСервиса = ИмяСервиса(Команда.Имя, "ДобавитьУчетнуюЗапись");
	
	ТекущаяУчетнаяЗапись = Неопределено;
	ЭтотОбъект["КодАвторизации" + ИмяСервиса] = "";
	
	Элементы["Страницы" + ИмяСервиса].ТекущаяСтраница = Элементы["СтраницаПодключение" + ИмяСервиса];
	
КонецПроцедуры

&НаКлиенте
Процедура УдалитьУчетнуюЗапись(Команда)
	
	ПоказатьВопрос(
		Новый ОписаниеОповещения("УдалитьУчетнуюЗаписьВопрос", ЭтотОбъект),
		НСтр("ru = 'Будет выполнено удаление учетной записи. Продолжить?'"),
		РежимДиалогаВопрос.ДаНет);
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьКод(Команда)
	
	ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(
		ДанныеСервисаПоИмениЭлемента(Команда.Имя, "ПолучитьКод").Авторизация.СтрокаАвторизацииOAuth);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключить(Команда)
	
	ИмяСервиса = ИмяСервиса(Команда.Имя, "Подключить");
	
	КодАвторизации = ЭтотОбъект["КодАвторизации" + ИмяСервиса];
	
	Если Не ЗначениеЗаполнено(КодАвторизации) Тогда
		ПоказатьПредупреждение(, НСтр("ru = 'Заполните код авторизации'"));
		Возврат;
	КонецЕсли;
	
	ОповещениеОЗавершении = 
		Новый ОписаниеОповещения("ЗавершитьПодключение", ЭтотОбъект);
	
	Элементы["Страницы" + ИмяСервиса].ТекущаяСтраница = Элементы["СтраницаПроверкаПодключения" + ИмяСервиса];
	
	ДлительнаяОперация = ДлительнаяОперацияПодключения(
		ТекущаяУчетнаяЗапись, СервисПоИмени(ИмяСервиса), КодАвторизации, УникальныйИдентификатор);
	
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
	ПараметрыОжидания.ТекстСообщения = НСтр("ru = 'Подключение...'");
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьПриветственноеСообщение(Команда)
	
	УчетнаяЗапись =
		ДанныеСервисаПоИмениЭлемента(ТекущийЭлемент.Имя, "УстановитьПриветственноеСообщение").УчетнаяЗаписьПоУмолчанию;
	
	ДополнительныеПараметры = Новый Структура("УчетнаяЗапись", УчетнаяЗапись);
	ОповещениеОЗавершении =
		Новый ОписаниеОповещения("УстановитьПриветственноеСообщениеЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	
	Подсказка = НСтр("ru = 'Введите приветственное сообщение, которое будет отправленно в Обсуждение, созданное для проведения видеоконференции'");
	
	ПоказатьВводСтроки(ОповещениеОЗавершении, ПриветственноеСообщение, Подсказка, , Истина);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьДанныеСервисов()
	
	ДанныеСервисов = Видеоконференции.ДанныеСервисов();
	
	НовыеИменаСервисов = Новый Соответствие();
	
	Для Каждого КлючИЗначение Из ДанныеСервисов Цикл
		Сервис = КлючИЗначение.Ключ;
		ДанныеСервиса = КлючИЗначение.Значение;
		НовыеИменаСервисов.Вставить(ДанныеСервиса.Имя, Сервис);
	КонецЦикла;
	
	ИменаСервисов = Новый ФиксированноеСоответствие(НовыеИменаСервисов);
	
КонецПроцедуры

&НаКлиенте
Функция ДанныеСервисаПоИмениЭлемента(ИмяЭлемента, Имя)
	
	ИмяСервиса = ИмяСервиса(ИмяЭлемента, Имя);
	
	Сервис = СервисПоИмени(ИмяСервиса);
	
	Возврат ДанныеСервисов[Сервис]
	
КонецФункции

&НаКлиенте
Функция СервисПоИмени(ИмяСервиса)
	
	Возврат ИменаСервисов[ИмяСервиса];
	
КонецФункции

&НаКлиенте
Функция ИмяСервиса(ИмяЭлемента, Имя)
	
	Возврат СтрЗаменить(ИмяЭлемента, Имя, "");
	
КонецФункции

&НаСервере
Процедура ДополнитьФорму()
	
	ИспользуемыеСервисы = Видеоконференции.ИспользуемыеСервисы(Истина);
	
	ДобавитьРеквизиты(ИспользуемыеСервисы);
	ДобавитьКоманды(ИспользуемыеСервисы);
	ДобавитьЭлементы(ИспользуемыеСервисы);
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьРеквизиты(Сервисы)
	
	ДобавляемыеРеквизиты = Новый Массив();
	
	Для Каждого Сервис Из Сервисы Цикл
		ДанныеСервиса = ДанныеСервисов[Сервис];
		
		Если Не ЗначениеЗаполнено(ДанныеСервиса.Имя) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ДанныеСервиса.Авторизация.ПротоколOAuth Тогда
			Имя = "КодАвторизации" + ДанныеСервиса.Имя;
			Тип = ОбщегоНазначения.ОписаниеТипаСтрока(0);
			Реквизит = НовыйРеквизит(Имя, Тип);
			ДобавляемыеРеквизиты.Добавить(Реквизит);
		КонецЕсли;
	КонецЦикла;
	
	ИменаРеквизитовФормы = Новый Массив;
	ЗарплатаКадры.ЗаполнитьМассивИменРеквизитовФормы(ЭтотОбъект, ИменаРеквизитовФормы);
	ЗарплатаКадры.ИзменитьРеквизитыФормы(ЭтотОбъект, ДобавляемыеРеквизиты, ИменаРеквизитовФормы);
	
КонецПроцедуры

&НаСервере
Функция НовыйРеквизит(Имя, Тип, Заголовок = "", Путь = "", СохраняемыеДанные = Ложь)
	
	Возврат Новый РеквизитФормы(Имя, Тип, Путь, СтрШаблон(НСтр("ru = '%1'"), Заголовок), СохраняемыеДанные);
	
КонецФункции

&НаСервере
Процедура ДобавитьКоманды(Сервисы)
	
	Для Каждого Сервис Из Сервисы Цикл
		ДанныеСервиса = ДанныеСервисов[Сервис];
		
		Если Не ЗначениеЗаполнено(ДанныеСервиса.Имя) Тогда
			Возврат;
		КонецЕсли;
		
		Команда = Команды.Добавить("ДобавитьУчетнуюЗапись" + ДанныеСервиса.Имя);
		Команда.Заголовок = СтрШаблон(НСтр("ru = 'Добавить'"));
		Команда.Действие = "ДобавитьУчетнуюЗапись";
		
		Команда = Команды.Добавить("Подключить" + ДанныеСервиса.Имя);
		Команда.Заголовок = СтрШаблон(НСтр("ru = 'Подключить'"));
		Команда.Действие = "Подключить";
		
		Команда = Команды.Добавить("УдалитьУчетнуюЗапись" + ДанныеСервиса.Имя);
		Команда.Заголовок = СтрШаблон(НСтр("ru = 'Удалить'"));
		Команда.Действие = "УдалитьУчетнуюЗапись";
		
		Если ДанныеСервиса.Авторизация.ПротоколOAuth Тогда
			Команда = Команды.Добавить("ПолучитьКод" + ДанныеСервиса.Имя);
			Команда.Заголовок = СтрШаблон(НСтр("ru = 'Получить код'"));
			Команда.Действие = "ПолучитьКод";
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьЭлементы(Сервисы)
	
	ШаблонГруппа = Элементы.ГруппаШаблон;
	
	СвойстваГруппа = Новый Массив();
	СвойстваГруппа.Добавить("Вид");
	СвойстваГруппа.Добавить("Отображение");
	СвойстваГруппа.Добавить("Группировка");
	СвойстваГруппа.Добавить("ОтображатьЗаголовок");
	СвойстваГруппа.Добавить("ГоризонтальныйИнтервал");
	СвойстваГруппа.Добавить("ВертикальныйИнтервал");
	СвойстваГруппа.Добавить("ЦветФона");
	СвойстваГруппа.Добавить("Ширина");
	СвойстваГруппа.Добавить("Высота");
	СвойстваГруппа.Добавить("РастягиватьПоГоризонтали");
	СвойстваГруппа.Добавить("РастягиватьПоВертикали");
	
	ШаблонЛоготип = Элементы.ЛоготипШаблон;
	
	СвойстваЛоготип = Новый Массив();
	СвойстваЛоготип.Добавить("Вид");
	СвойстваЛоготип.Добавить("Гиперссылка");
	СвойстваЛоготип.Добавить("ОтображениеПодсказки");
	СвойстваЛоготип.Добавить("СпособПеретаскиванияФайлов");
	СвойстваЛоготип.Добавить("РазмерКартинки");
	СвойстваЛоготип.Добавить("ВертикальноеПоложениеВГруппе");
	СвойстваЛоготип.Добавить("Ширина");
	СвойстваЛоготип.Добавить("Высота");
	
	ШаблонСтраницы = Элементы.СтраницыШаблон;
	
	СвойстваСтраницы = Новый Массив();
	СвойстваСтраницы.Добавить("Вид");
	СвойстваСтраницы.Добавить("ОтображениеСтраниц");
	СвойстваСтраницы.Добавить("ВертикальноеПоложениеВГруппе");
	
	ШаблонСтраницаНеПодключен = Элементы.СтраницаНеПодключенШаблон;
	
	СвойстваСтраницаНеПодключен= Новый Массив();
	СвойстваСтраницаНеПодключен.Добавить("Вид");
	
	ШаблонСтраницаПодключение = Элементы.СтраницаПодключениеШаблон;
	
	СвойстваСтраницаПодключение = Новый Массив();
	СвойстваСтраницаПодключение.Добавить("Вид");
	
	ШаблонСтраницаПодключен = Элементы.СтраницаПодключенШаблон;
	
	СвойстваСтраницаПодключен = Новый Массив();
	СвойстваСтраницаПодключен.Добавить("Вид");
	
	ШаблонСтраницаПроверкаПодключения = Элементы.СтраницаПроверкаПодключенияШаблон;
	
	СвойстваСтраницаПроверкаПодключения = Новый Массив();
	СвойстваСтраницаПроверкаПодключения.Добавить("Вид");
	СвойстваСтраницаПроверкаПодключения.Добавить("Группировка");
	
	ШаблонКартинкаПроверкаПодключения = Элементы.КартинкаПроверкаПодключенияШаблон;
	
	СвойстваКартинкаПроверкаПодключения = Новый Массив();
	СвойстваКартинкаПроверкаПодключения.Добавить("Вид");
	СвойстваКартинкаПроверкаПодключения.Добавить("Картинка");
	
	ШаблонНадписьПроверкаПодключения = Элементы.НадписьПроверкаПодключенияШаблон;
	
	СвойстваНадписьПроверкаПодключения = Новый Массив();
	СвойстваНадписьПроверкаПодключения.Добавить("Вид");
	СвойстваНадписьПроверкаПодключения.Добавить("Заголовок");
	СвойстваНадписьПроверкаПодключения.Добавить("ВертикальноеПоложениеВГруппе");
	
	Для Каждого Сервис Из Сервисы Цикл
		ДанныеСервиса = ДанныеСервисов[Сервис];
		
		Если Не ЗначениеЗаполнено(ДанныеСервиса.Имя) Тогда
			Продолжить;
		КонецЕсли;
		
		ОсновнаяГруппа = ДобавитьЭлементПоШаблону(
			"Группа" + ДанныеСервиса.Имя,
			Тип("ГруппаФормы"),
			ШаблонГруппа,
			СвойстваГруппа,
			Элементы.ГруппаСервисы);
		
		Логотип = ДобавитьЭлементПоШаблону(
			"Логотип" + ДанныеСервиса.Имя,
			Тип("ДекорацияФормы"),
			ШаблонЛоготип,
			СвойстваЛоготип,
			ОсновнаяГруппа);
		
		Логотип.Картинка = ДанныеСервиса.Картинка;
		
		Страницы = ДобавитьЭлементПоШаблону(
			"Страницы" + ДанныеСервиса.Имя,
			Тип("ГруппаФормы"),
			ШаблонСтраницы,
			СвойстваСтраницы,
			ОсновнаяГруппа);
		
		СтраницаНеПодключен = ДобавитьЭлементПоШаблону(
			"СтраницаНеПодключен" + ДанныеСервиса.Имя,
			Тип("ГруппаФормы"),
			ШаблонСтраницаНеПодключен,
			СвойстваСтраницаНеПодключен,
			Страницы);
		
		ДобавитьЭлементыСтраницыНеПодключен(СтраницаНеПодключен, ДанныеСервиса);
		
		СтраницаПодключение = ДобавитьЭлементПоШаблону(
			"СтраницаПодключение" + ДанныеСервиса.Имя,
			Тип("ГруппаФормы"),
			ШаблонСтраницаПодключение,
			СвойстваСтраницаПодключение,
			Страницы);
		
		ДобавитьЭлементыСтраницыПодключение(СтраницаПодключение, ДанныеСервиса);
		
		СтраницаПодключен = ДобавитьЭлементПоШаблону(
			"СтраницаПодключен" + ДанныеСервиса.Имя,
			Тип("ГруппаФормы"),
			ШаблонСтраницаПодключен,
			СвойстваСтраницаПодключен,
			Страницы);
		
		ДобавитьЭлементыСтраницыПодключен(СтраницаПодключен, ДанныеСервиса);
		
		СтраницаПроверкаПодключения = ДобавитьЭлементПоШаблону(
			"СтраницаПроверкаПодключения" + ДанныеСервиса.Имя,
			Тип("ГруппаФормы"),
			ШаблонСтраницаПроверкаПодключения,
			СвойстваСтраницаПроверкаПодключения,
			Страницы);
		
		ДобавитьЭлементПоШаблону(
			"КартинкаПроверкаПодключения" + ДанныеСервиса.Имя,
			Тип("ДекорацияФормы"),
			ШаблонКартинкаПроверкаПодключения,
			СвойстваКартинкаПроверкаПодключения,
			СтраницаПроверкаПодключения);
			
		ДобавитьЭлементПоШаблону(
			"НадписьПроверкаПодключения" + ДанныеСервиса.Имя,
			Тип("ДекорацияФормы"),
			ШаблонНадписьПроверкаПодключения,
			СвойстваНадписьПроверкаПодключения,
			СтраницаПроверкаПодключения);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ДобавитьЭлементПоШаблону(Имя, Тип, Шаблон, Свойства, Родитель = Неопределено)
	
	Элемент = Элементы.Добавить(Имя, Тип, Родитель);
	
	Если Свойства.Найти("Вид") <> Неопределено Тогда
		Элемент.Вид = Шаблон.Вид;
	КонецЕсли;
	
	СписокСвойств = СтрСоединить(Свойства, ",");
	
	ЗаполнитьЗначенияСвойств(Элемент, Шаблон, СписокСвойств);
	
	Возврат Элемент;
	
КонецФункции

