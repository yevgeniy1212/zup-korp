		Тип("ПолеФормы"),
		ШаблонУчетныеЗаписиСостояние,
		СвойстваУчетныеЗаписиСостояние,
		ГруппаКолонокУчетныеЗаписи);
	
	ДобавитьЭлементПоШаблону(
		"УчетныеЗаписиУчетнаяЗапись" + ДанныеСервиса.Имя,
		Тип("ПолеФормы"),
		ШаблонУчетныеЗаписиУчетнаяЗапись,
		СвойстваУчетныеЗаписиУчетнаяЗапись,
		ГруппаКолонокУчетныеЗаписи);
	
	ДобавитьЭлементПоШаблону(
		"УчетныеЗаписиПодключитьОтключить" + ДанныеСервиса.Имя,
		Тип("ПолеФормы"),
		ШаблонУчетныеЗаписиПодключитьОтключить,
		СвойстваУчетныеЗаписиПодключитьОтключить,
		ТаблицаУчетныеЗаписи);
	
КонецПроцедуры

&НаКлиенте
Процедура СкрытьКомандныеПанелиТаблиц()
	
	Для Каждого КлючИЗначение Из ДанныеСервисов Цикл
		ДанныеСервиса = КлючИЗначение.Значение;
		
		Если ДанныеСервиса.ЭтоСистемаВзаимодействия Тогда
			Продолжить;
		КонецЕсли;
		
		ЭлементыКоманднойПанели = Элементы["УчетныеЗаписи" + ДанныеСервиса.Имя].КоманднаяПанель.ПодчиненныеЭлементы;
		
		Для каждого ЭлементКоманднойПанели Из ЭлементыКоманднойПанели Цикл
			Если СтрНайти(ЭлементКоманднойПанели.Имя, "ДобавитьУчетнуюЗапись") <> 0
				Или СтрНайти(ЭлементКоманднойПанели.Имя, "УдалитьУчетнуюЗапись") <> 0 Тогда
				Продолжить;
			КонецЕсли;
			
			ЭлементКоманднойПанели.Видимость = Ложь;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьОтображение()

	ОбновитьСпискиУчетныхЗаписей();
	
	ОбновитьОтображениеОбсуждений();
	
	ОбновитьОтображениеOAuth();
	
	ЗакрытьФормуБезПодтверждения = ЕстьНастроенныеУчетныеЗаписи();

КонецПроцедуры

&НаСервереБезКонтекста
Функция ДлительнаяОперацияПодключения(УчетнаяЗапись, Сервис, КодАвторизации, УникальныйИдентификатор)
	
	ИмяПроцедуры = "Видеоконференции.ПодключитьУчетнуюЗапись";
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(
		УникальныйИдентификатор, ИмяПроцедуры, УчетнаяЗапись, Сервис, КодАвторизации);
	
КонецФункции

&НаКлиенте
Процедура ОтменитьИспользованиеВидеоконференций(Результат = Неопределено, ДополнительныеПараметры = Неопределено) Экспорт
	
	Оповестить("ИзмененыНастройкиУчетныхЗаписейВидеоконференций", Ложь);
	
КонецПроцедуры

&НаКлиенте
Функция ЕстьНастроенныеУчетныеЗаписи()
	
	ЕстьНастроенныеУчетныеЗаписи = Ложь;
	
	Для каждого Строка Из УчетныеЗаписи Цикл
		Если Строка.Состояние <> 0 Тогда
			ЕстьНастроенныеУчетныеЗаписи = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ЕстьНастроенныеУчетныеЗаписи Или ОбсужденияПодключены;
	
КонецФункции

&НаКлиенте
Процедура ОбновитьОтображениеОбсуждений()
	
	Если ОбсужденияПодключены() Тогда
		Элементы.Страницы1С.ТекущаяСтраница = Элементы.СтраницаПодключен1С;
	Иначе
		Элементы.Страницы1С.ТекущаяСтраница = Элементы.СтраницаНеПодключен1С;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Функция ОбсужденияПодключены()
	
	ОбсужденияПодключены = Ложь;
	
	Если ОбщегоНазначенияКлиент.ПодсистемаСуществует("СтандартныеПодсистемы.Обсуждения") Тогда
		МодульОбсужденияСлужебныйКлиент = ОбщегоНазначенияКлиент.ОбщийМодуль("ОбсужденияСлужебныйКлиент");
		ОбсужденияПодключены = МодульОбсужденияСлужебныйКлиент.Подключены();
	КонецЕсли;
	
	Возврат ОбсужденияПодключены;
	
КонецФункции

&НаКлиенте
Процедура ОбновитьОтображениеOAuth()
	
	ПроверятьПодключение = Ложь;
	
	Для Каждого КлючИЗначение Из ДанныеСервисов Цикл
		Сервис = КлючИЗначение.Ключ;
		ДанныеСервиса = КлючИЗначение.Значение;
		
		Если ДанныеСервиса.ЭтоСистемаВзаимодействия Тогда
			Продолжить;
		КонецЕсли;
		
		УчетныеЗаписиСервиса = Новый Массив;
		
		Для каждого Строка Из УчетныеЗаписи Цикл
			Если Строка.Сервис = Сервис Тогда
				УчетныеЗаписиСервиса.Добавить(Строка.УчетнаяЗапись);
			КонецЕсли;
		КонецЦикла;
		
		Если УчетныеЗаписиСервиса.Количество() <> 0 Тогда
			Элементы["Страницы" + ДанныеСервиса.Имя].ТекущаяСтраница =
				Элементы["СтраницаПроверкаПодключения" + ДанныеСервиса.Имя];
			ПроверятьПодключение = Истина;
		Иначе
			Элементы["Страницы" + ДанныеСервиса.Имя].ТекущаяСтраница =
				Элементы["СтраницаНеПодключен" + ДанныеСервиса.Имя];
		КонецЕсли;
	КонецЦикла;
	
	Если ПроверятьПодключение Тогда
		ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗавершитьПроверкуСостоянияПодключенияOAuth", ЭтотОбъект);
		
		ДлительнаяОперация = ДлительнаяОперацияПроверкиПодключения(УникальныйИдентификатор);
		
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Ложь;
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДлительнаяОперацияПроверкиПодключения(УникальныйИдентификатор)
	
	ИмяПроцедуры = "Видеоконференции.НастроенныеУчетныеЗаписи";
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(УникальныйИдентификатор, ИмяПроцедуры);
	
КонецФункции

&НаКлиенте
Процедура УдалитьУчетнуюЗаписьВопрос(РезультатВопроса, ДополнительныеПараметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Да Тогда
		ОтключитьУчетнуюЗапись(ТекущаяУчетнаяЗапись);
		ОбновитьОтображение();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьСпискиУчетныхЗаписей()
	
	УчетныеЗаписи.Очистить();
	ТекущаяУчетнаяЗапись = Неопределено;
	
	УчетныеЗаписи.Загрузить(ВидеоконференцииСлужебный.УчетныеЗаписи());
	
	Для Каждого СтрокаУчетнойЗаписи Из УчетныеЗаписи Цикл
		ДанныеСервиса = ДанныеСервисов[СтрокаУчетнойЗаписи.Сервис];
		
		Если ДанныеСервиса.ЭтоСистемаВзаимодействия Тогда
			ПриветственноеСообщение = СтрокаУчетнойЗаписи.ПриветственноеСообщение;
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого КлючИЗначение Из ДанныеСервисов Цикл
		Сервис = КлючИЗначение.Ключ;
		ДанныеСервиса = КлючИЗначение.Значение;
		
		Если ДанныеСервиса.ЭтоСистемаВзаимодействия Тогда
			Продолжить;
		КонецЕсли;
		
		Отбор = Новый Структура();
		Отбор.Вставить("Сервис", Сервис);
		
		Элементы["УчетныеЗаписи" + ДанныеСервиса.Имя].ОтборСтрок = Новый ФиксированнаяСтруктура(Отбор);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьПроверкуСостоянияПодключенияOAuth(ДлительнаяОперация, ДополнительныеПараметры = Неопределено) Экспорт
	
	Если ДлительнаяОперация = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ДлительнаяОперация.Статус = "Ошибка" Тогда
		ПоказатьПредупреждение(, ДлительнаяОперация.КраткоеПредставлениеОшибки);
		Возврат;
	ИначеЕсли Не ДлительнаяОперация.Статус = "Выполнено" Тогда
		Возврат;
	КонецЕсли;
	
	Результат = ПолучитьИзВременногоХранилища(ДлительнаяОперация.АдресРезультата);
	
	Для каждого СтрокаУчетнойЗаписи Из УчетныеЗаписи Цикл
		УчетнаяЗаписьНастроена = Результат.Найти(СтрокаУчетнойЗаписи.УчетнаяЗапись) <> Неопределено;
		
		СтрокаУчетнойЗаписи.Состояние = 
			?(УчетнаяЗаписьНастроена, ИдентификаторыЦвета().Настроено, ИдентификаторыЦвета().НеНастроено);
		СтрокаУчетнойЗаписи.ПодключитьОтключить = 
			?(УчетнаяЗаписьНастроена, НСтр("ru = 'Отключить'"), НСтр("ru = 'Подключить'"));
	КонецЦикла;
	
	Для Каждого КлючИЗначение Из ДанныеСервисов Цикл
		Сервис = КлючИЗначение.Ключ;
		ДанныеСервиса = КлючИЗначение.Значение;
		
		Если ДанныеСервиса.ЭтоСистемаВзаимодействия Тогда
			Продолжить;
		КонецЕсли;
		
		УчетныеЗаписиСервиса = Новый Массив;
		
		Для каждого Строка Из УчетныеЗаписи Цикл
			Если Строка.Сервис = Сервис Тогда
				УчетныеЗаписиСервиса.Добавить(Строка.УчетнаяЗапись);
			КонецЕсли;
		КонецЦикла;
		
		Если УчетныеЗаписиСервиса.Количество() <> 0 Тогда
			Элементы["Страницы" + ДанныеСервиса.Имя].ТекущаяСтраница =
				Элементы["СтраницаПодключен" + ДанныеСервиса.Имя];
		Иначе
			Элементы["Страницы" + ДанныеСервиса.Имя].ТекущаяСтраница =
				Элементы["СтраницаНеПодключен" + ДанныеСервиса.Имя];
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьПодключение(ДлительнаяОперация, ДополнительныеПараметры) Экспорт
	
	Если ДлительнаяОперация = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ДлительнаяОперация.Статус = "Ошибка" Тогда
		ПоказатьПредупреждение(, ДлительнаяОперация.КраткоеПредставлениеОшибки);
		Возврат;
	ИначеЕсли Не ДлительнаяОперация.Статус = "Выполнено" Тогда
		Возврат;
	КонецЕсли;
	
	Результат = ПолучитьИзВременногоХранилища(ДлительнаяОперация.АдресРезультата);
	ТекущаяУчетнаяЗапись = Результат.УчетнаяЗапись;
	
	УчетнаяЗаписьНастроена = ЗначениеЗаполнено(ТекущаяУчетнаяЗапись);
	
	Если УчетнаяЗаписьНастроена Тогда
		Если ЗначениеЗаполнено(Результат.Предупреждение) Тогда
			ПоказатьПредупреждение(, Результат.Предупреждение);
		Иначе
			СтрокаУчетнойЗаписи = УчетныеЗаписи.Добавить();
			СтрокаУчетнойЗаписи.Сервис = Результат.Сервис;
			СтрокаУчетнойЗаписи.УчетнаяЗапись = ТекущаяУчетнаяЗапись;
			СтрокаУчетнойЗаписи.ПриветственноеСообщение = Результат.ПриветственноеСообщение;
			СтрокаУчетнойЗаписи.Состояние = ИдентификаторыЦвета().Настроено;
			СтрокаУчетнойЗаписи.ПодключитьОтключить = НСтр("ru = 'Отключить'");
		КонецЕсли;
		
		ПоказатьОповещениеПользователя(НСтр("ru = 'Авторизация выполнена успешно.'"));
	Иначе
		ПоказатьОповещениеПользователя(НСтр("ru = 'Не удалось авторизоваться.'"));
	КонецЕсли;
	
	ОбновитьОтображение();
	
КонецПроцедуры

&НаКлиенте
Функция ИдентификаторыЦвета()
	
	Возврат Новый Структура("Настроено, НеНастроено", 3, 0);
	
КонецФункции

&НаСервереБезКонтекста
Процедура ОтключитьУчетнуюЗапись(УчетнаяЗапись)
	
	Видеоконференции.ОтключитьУчетнуюЗапись(УчетнаяЗапись);
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьПриветственноеСообщениеЗавершение(Строка, ДополнительныеПараметры) Экспорт
	
	Если ДополнительныеПараметры <> Неопределено И ЗначениеЗаполнено(Строка) И Строка <> ПриветственноеСообщение Тогда
		УстановитьПриветственноеСообщениеНаСервере(ДополнительныеПараметры.УчетнаяЗапись, Строка);
		ПриветственноеСообщение = Строка;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьПриветственноеСообщениеНаСервере(УчетнаяЗапись, Строка)
	
	Попытка
		УчетнаяЗаписьОбъект = УчетнаяЗапись.ПолучитьОбъект();
		УчетнаяЗаписьОбъект.Заблокировать();
		УчетнаяЗаписьОбъект.ПриветственноеСообщение = Строка;
		УчетнаяЗаписьОбъект.Записать();
	Исключение
		ВызватьИсключение НСтр("ru = 'Не удалось установить приветственное сообщение.'");
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти
