// Возвращаемое значение:
//  Массив Из СправочникСсылка.УчетныеЗаписиВидеоконференций
Функция АктивныеУчетныеЗаписи() Экспорт
	
	АктивныеУчетныеЗаписи = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	УчетныеЗаписиВидеоконференций.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.УчетныеЗаписиВидеоконференций КАК УчетныеЗаписиВидеоконференций
	|ГДЕ
	|	НЕ УчетныеЗаписиВидеоконференций.ПометкаУдаления";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		АктивныеУчетныеЗаписи.Добавить(Выборка.Ссылка);
	КонецЦикла;
	
	Возврат АктивныеУчетныеЗаписи;
	
КонецФункции

// Параметры:
//  УчетнаяЗапись - СправочникСсылка.УчетныеЗаписиВидеоконференций
Процедура ОтключитьУчетнуюЗапись(УчетнаяЗапись) Экспорт
	
	Блокировка = Новый БлокировкаДанных;
	ЭлементБлокировки = Блокировка.Добавить("РегистрСведений.НастройкиУчетныхЗаписейВидеоконференций");
	ЭлементБлокировки.УстановитьЗначение("УчетнаяЗапись", УчетнаяЗапись);
	
	ЭлементБлокировки = Блокировка.Добавить("Справочник.УчетныеЗаписиВидеоконференций");
	ЭлементБлокировки.УстановитьЗначение("Ссылка", УчетнаяЗапись);
	
	НачатьТранзакцию();
	Попытка
		Блокировка.Заблокировать();
		
		Набор = РегистрыСведений.НастройкиУчетныхЗаписейВидеоконференций.СоздатьНаборЗаписей();
		Набор.Отбор.УчетнаяЗапись.Установить(УчетнаяЗапись);
		
		Набор.Записать();
		
		УчетнаяЗаписьОбъект = УчетнаяЗапись.ПолучитьОбъект();
		УчетнаяЗаписьОбъект.УстановитьПометкуУдаления(Истина);
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение НСтр("ru = 'Не удалось удалить учетную запись'");
	КонецПопытки;
	
КонецПроцедуры

// Параметры:
//  Сервис - Строка
//  Наименование - Строка
// 
// Возвращаемое значение:
//  СправочникСсылка.УчетныеЗаписиВидеоконференций
Функция СоздатьУчетнуюЗапись(Сервис, Наименование) Экспорт
	
	УчетнаяЗапись = СоздатьЭлемент();
	УчетнаяЗапись.Сервис = Сервис;
	УчетнаяЗапись.Наименование = Наименование;
	
	УчетнаяЗапись.Записать();
	
	Возврат УчетнаяЗапись.Ссылка;
	
КонецФункции

#КонецОбласти

#КонецЕсли
