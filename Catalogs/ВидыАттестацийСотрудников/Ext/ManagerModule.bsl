#Область СлужебныйПрограммныйИнтерфейс

#Область ОбработчикиПравилРегистрации

// См. ЗарплатаКадрыРасширенныйСинхронизацияДанных.ШаблонОбработчика
Процедура ПриЗаполненииНастроекОбработчиковПравилРегистрации(Настройки) Экспорт
	ЗарплатаКадрыРасширенныйСинхронизацияДанных.ДляРегламентированныхДанных(Настройки);
КонецПроцедуры

#КонецОбласти

Функция ТекстОписанияВидаАттестации(ВидАттестации) Экспорт
	
	ОписаниеВидаАттестации = "";
	
	Если ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.ГосударственнаяСлужба") 
		И АттестацииСотрудников.ЭтоАттестацияГосударственныхСлужащих(ВидАттестации) Тогда
		
		Модуль = ОбщегоНазначения.ОбщийМодуль("ГосударственнаяСлужба");
		ОписаниеВидаАттестации = Модуль.ТекстОписанияВидаАттестацииГосударственныхСлужащих();
		
	ИначеЕсли ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.Медицина")
		И АттестацииСотрудников.ЭтоАттестацияМедицинскихРаботников(ВидАттестации) Тогда
		
		Модуль = ОбщегоНазначения.ОбщийМодуль("Медицина");
		ОписаниеВидаАттестации = Модуль.ТекстОписанияВидаАттестацииМедицинскихРаботников();
		
	ИначеЕсли ОбщегоНазначения.ПодсистемаСуществует("ЗарплатаКадрыПриложения.ОбразовательныеУчреждения")
		И АттестацииСотрудников.ЭтоАттестацияПедагогическихРаботников(ВидАттестации) Тогда
		
		Модуль = ОбщегоНазначения.ОбщийМодуль("ОбразовательныеУчреждения");
		ОписаниеВидаАттестации = Модуль.ТекстОписанияВидаАттестацииПедагогическихРаботников();
		
	КонецЕсли;
	
	Возврат ОписаниеВидаАттестации;	
	
КонецФункции

#КонецОбласти

#КонецЕсли