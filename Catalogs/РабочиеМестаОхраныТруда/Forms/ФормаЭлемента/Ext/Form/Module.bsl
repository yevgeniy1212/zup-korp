Процедура СкопироватьВредныеФакторыВидыРаботМедицинские(Команда)
	
	ПараметрыФормы = Новый Структура("ИсключаяРабочееМесто, ВидОсмотра");
	ПараметрыФормы.ИсключаяРабочееМесто = Параметры.Ключ;
	ПараметрыФормы.ВидОсмотра = ВидМедицинскийОсмотр;
	
	ПараметрыОповещения = Новый Структура("ВидОсмотра");
	ПараметрыОповещения.ВидОсмотра = ПараметрыФормы.ВидОсмотра;
	
	ОбработчикОповещения = Новый ОписаниеОповещения("СкопироватьИзДругогоРабочегоМестаПослеВыбора", ЭтотОбъект, ПараметрыОповещения);
	ОткрытьФорму("Справочник.РабочиеМестаОхраныТруда.Форма.ВыборРабочегоМеста", ПараметрыФормы, ЭтотОбъект, , , , ОбработчикОповещения);
	
