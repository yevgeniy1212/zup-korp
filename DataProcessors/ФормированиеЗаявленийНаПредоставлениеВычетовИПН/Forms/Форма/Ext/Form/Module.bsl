&НаКлиенте
Процедура ПоказатьОшибки(ДанныеСтроки) Экспорт
	
	Если ДанныеСтроки = Неопределено Тогда
		Возврат
	КонецЕсли;
	
	ПараметрыОтбораПоФизлицу = Новый Структура;
	ПараметрыОтбораПоФизлицу.Вставить("ФизическоеЛицо", ДанныеСтроки.Сотрудник);
	
	ПараметрыОткрытия = Новый Структура;
	ПараметрыОткрытия.Вставить("АдресХранилища", АдресВХранилищеОшибки(ПараметрыОтбораПоФизлицу));
	
	ОткрытьФорму("Обработка.ФормированиеЗаявленийНаПредоставлениеВычетовИПН.Форма.ФормаОшибокПроведения", ПараметрыОткрытия, ЭтаФорма, , , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаСервере
Функция АдресВХранилищеОшибки(ПараметрыОтбораПоФизлицу) Экспорт
	
	ТаблицаОтбора = ОшибкиФормированияДокументов.Выгрузить(Новый Структура("ФизическоеЛицо", ПараметрыОтбораПоФизлицу.ФизическоеЛицо,));
	
	Возврат ПоместитьВоВременноеХранилище(ТаблицаОтбора, УникальныйИдентификатор);

КонецФункции

&НаСервере
Процедура ЗаполнитьРасшифровкуВСтроке(Идентификатор)

	ТекущиеДанные = Вычеты.НайтиПоИдентификатору(Идентификатор);
	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные.Расшифровка = 
		?(ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ТекущиеДанные.ВидВычета, "ПредоставлениеВычета") = 
			Перечисления.ВидыПредоставленияВычетов.ПоПериодическимПлатежам, НСтр("ru = 'Подробнее'"),"");
	
КонецПроцедуры

&НаКлиенте
Процедура РедактированиеГрафикиВычетов(ДанныеСтроки)

	Если ДанныеСтроки = Неопределено Тогда
		Возврат
	КонецЕсли; 
		
	ПараметрыОтбораПоФизлицу = Новый Структура;
	ПараметрыОтбораПоФизлицу.Вставить("ФизическоеЛицо", ДанныеСтроки.Сотрудник);
	ПараметрыОтбораПоФизлицу.Вставить("ВидВычетаИПН", ДанныеСтроки.ВидВычета); 
	
	ПараметрыОткрытия = Новый Структура;
	
	ПараметрыОткрытия.Вставить("ФизическоеЛицо", 				ДанныеСтроки.Сотрудник);
	ПараметрыОткрытия.Вставить("ВидВычетаИПН",						ДанныеСтроки.ВидВычета);
	ПараметрыОткрытия.Вставить("Месяц",							Объект.Период);
	Если ДействуетДо Тогда
		ПараметрыОткрытия.Вставить("МесяцЗавершения",			КонецГода(Объект.Период));
	КонецЕсли;
	ПараметрыОткрытия.Вставить("ПредоставлятьВычет",            ДанныеСтроки.ПредоставлятьВычет);
	ПараметрыОткрытия.Вставить("АдресВХранилищеПрочиеВычеты",	АдресВХранилищеПрочиеВычеты(ПараметрыОтбораПоФизлицу));
	
	ПараметрыОткрытия.Вставить("ТолькоПросмотр",		ЭтаФорма.ТолькоПросмотр);
	
	Оповещение = Новый ОписаниеОповещения("РедактированиеГрафикиВычетовЗавершение", ЭтотОбъект);
	ОткрытьФорму("Документ.ЗаявлениеНаПредоставлениеВычетовИПН.Форма.РедактированиеГрафикаВычетов", ПараметрыОткрытия, ЭтаФорма, , , , Оповещение, РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура РедактированиеГрафикиВычетовЗавершение(РезультатыРедактирования,ДопПараметры) Экспорт
	
	Если РезультатыРедактирования <> Неопределено И РезультатыРедактирования.Модифицированность Тогда
		РедактированиеГрафикиВычетовЗавершениеНаСервере(РезультатыРедактирования);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура РедактированиеГрафикиВычетовЗавершениеНаСервере(РезультатыРедактирования)
	
	УдалитьПрочиеВычеты(РезультатыРедактирования.ВидВычетаИПН, РезультатыРедактирования.ФизическоеЛицо);
	
	ТаблицаВидВычета = ПолучитьИзВременногоХранилища(РезультатыРедактирования.АдресВХранилищеПрочиеВычеты);
	
	ОбщегоНазначенияКлиентСервер.ДополнитьТаблицу(ТаблицаВидВычета, ГрафикиВычетов);
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаСервере
Функция АдресВХранилищеПрочиеВычеты(ПараметрыОтбораПоФизлицу) Экспорт
		
	ТаблицаОтбора = ГрафикиВычетов.Выгрузить(Новый Структура("ФизическоеЛицо, ВидВычетаИПН", ПараметрыОтбораПоФизлицу.ФизическоеЛицо,ПараметрыОтбораПоФизлицу.ВидВычетаИПН));
		
	Возврат ПоместитьВоВременноеХранилище(ТаблицаОтбора, УникальныйИдентификатор);
	
КонецФункции

&НаСервере
Процедура УдалитьПрочиеВычеты(ВидВычета, ФизическоеЛицо)
	
	УдаляемыеСтроки = ГрафикиВычетов.НайтиСтроки(Новый Структура("ВидВычетаИПН, ФизическоеЛицо", ВидВычета, ФизическоеЛицо));
	
	Для Каждого УдаляемаяСтрока Из УдаляемыеСтроки Цикл
		ГрафикиВычетов.Удалить(УдаляемаяСтрока);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура КонтрольМесяца()
	
	ДатаКонтроля = Дата(2026,01,01);
	
	Если Объект.Период < ДатаКонтроля Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru='Обработка применяется с 1 января 2026 года'"));
		Объект.Период = НачалоМесяца(ДатаКонтроля);
		ПериодСтрокой = НСтр("ru = 'Январь 2026'");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ВидыВычетовТребущиеУказанияВидаДохода() 
	//Возврат Документы.ЗаявлениеНаПредоставлениеВычетовИПН.ВидыВычетовТребущиеУказанияВидаДохода(Объект.Период);  
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПолучитьВидДохода(Месяц, ВидВычета) 
	
	ВидДохода = Неопределено;
	
	Если Месяц >= '20250101' Тогда
		
		Если ВидВычета = ПредопределенноеЗначение("Справочник.ВидыВычетовИПН.ДобровольныеПенсионныеВзносы")
			ИЛИ ВидВычета = ПредопределенноеЗначение("Справочник.ВидыВычетовИПН.Стандартный1МЗП")
			ИЛИ ВидВычета = ПредопределенноеЗначение("Справочник.ВидыВычетовИПН.Стандартный75МЗПИнвалиды")
			ИЛИ ВидВычета = ПредопределенноеЗначение("Справочник.ВидыВычетовИПН.Стандартный75МЗПРодители")
			ИЛИ ВидВычета = ПредопределенноеЗначение("Справочник.ВидыВычетовИПН.БазовыйНалоговыйВычет")
			ИЛИ ВидВычета = ПредопределенноеЗначение("Справочник.ВидыВычетовИПН.СоциальныйНалоговыйВычет1_2Группа") 
			ИЛИ ВидВычета = ПредопределенноеЗначение("Справочник.ВидыВычетовИПН.СоциальныйНалоговыйВычет3Группа") 
			ИЛИ ВидВычета = ПредопределенноеЗначение("Справочник.ВидыВычетовИПН.СоциальныйНалоговыйВычетРодители") Тогда
			
			ВидДохода = ПредопределенноеЗначение("Справочник.ВидыДоходов.ДоходыОтРаботодателя");
			
		Иначе
			
			ВидДохода = Неопределено;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат ВидДохода;
	
КонецФункции

&НаСервере
Функция ЕстьРеквизитТабЧастиДокумента(ИмяРеквизита, МетаданныеДокумента, ИмяТабЧасти) 

	ТабЧасть = МетаданныеДокумента.ТабличныеЧасти.Найти(ИмяТабЧасти);

	Если ТабЧасть = Неопределено Тогда // Нет такой таб. части в документе
		Возврат Ложь;

	Иначе
		Возврат НЕ (ТабЧасть.Реквизиты.Найти(ИмяРеквизита) = Неопределено);

	КонецЕсли;

КонецФункции // ЕстьРеквизитТабЧастиДокумента()

&НаСервере
Функция СформироватьОтчетНаСервере()
	
	Схема = Обработки.ФормированиеЗаявленийНаПредоставлениеВычетовИПН.ПолучитьМакет("ОсновнаяСхемаКомпоновкиДанных");

    Компоновщик = Новый КомпоновщикНастроекКомпоновкиДанных;
    Компоновщик.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(Схема));
    Компоновщик.ЗагрузитьНастройки(Схема.НастройкиПоУмолчанию);

    // Параметры
    СписокФизЛиц = Новый Массив;
    Для каждого Стр Из СформированныеДокументы Цикл
        СписокФизЛиц.Добавить(Стр.Сотрудник);
    КонецЦикла;

    Настройки = Компоновщик.Настройки;
	Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("Период", Объект.Период);
	Настройки.ПараметрыДанных.УстановитьЗначениеПараметра("СписокФизЛиц", СписокФизЛиц);
	
	Структура = Новый Структура;
	Структура.Вставить("Период", Объект.Период);
	Структура.Вставить("СписокФизЛиц", СписокФизЛиц);		
	
    Возврат Структура;

КонецФункции

&НаКлиенте
Процедура СформироватьОтчет(Команда)
	
	Пакет = СформироватьОтчетНаСервере(); // получаем с сервера только данные
	
    ОткрытьФорму("Обработка.ФормированиеЗаявленийНаПредоставлениеВычетовИПН.Форма.ФормаОтчета", Пакет);
	
КонецПроцедуры

#КонецОбласти
