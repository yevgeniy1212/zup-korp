						НоваяСтрокаГрафика = НовоеЗаявление.ПрочиеВычеты.Добавить();
						НоваяСтрокаГрафика.ВидВычетаИПН = СтрокаГрафика.ВидВычетаИПН;
						НоваяСтрокаГрафика.ДействуетС = СтрокаГрафика.ДействуетС;
						НоваяСтрокаГрафика.ДействуетПо = СтрокаГрафика.ДействуетПо;
						НоваяСтрокаГрафика.Размер = СтрокаГрафика.Размер;
					КонецЦикла;
					
				КонецЕсли;				
				
			КонецЦикла;
			
			ПараметрыОтбораПоФизлицу = Новый Структура;
			ПараметрыОтбораПоФизлицу.Вставить("ФизическоеЛицо", СтрокаСотрудник.Сотрудник);
			ОшибкиПоСотруднику = ОшибкиФормированияДокументов.Выгрузить(Новый Структура("ФизическоеЛицо", ПараметрыОтбораПоФизлицу.ФизическоеЛицо));
			Если ОшибкиПоСотруднику.Количество() > 0 Тогда 
				СтрокаИтого.Подробнее =  НСтр("ru = 'Подробнее...'");
			КонецЕсли;
			
			Попытка 

				ТаблицаОшибокПроверкиЗаполнения = ОшибкиФормированияДокументов.Выгрузить();
				ТаблицаОшибокПроверкиЗаполнения.Очистить();
				НовоеЗаявление.ДополнительныеСвойства.Вставить("ТаблицаОшибокПроверкиЗаполнения", ТаблицаОшибокПроверкиЗаполнения);
				//пытаемся записать Документ. с проведением
				Если НовоеЗаявление.ПроверитьЗаполнение() Тогда
					НовоеЗаявление.Записать(РежимЗаписиДокумента.Проведение);
					СтрокаИтого.Документ = НовоеЗаявление.Ссылка;
					ИтогоСозданоЗаявлений = ИтогоСозданоЗаявлений + 1;
				Иначе 
					НаличиеОшибок = Истина;
					//ОшибкиФормированияДокументов.Очистить();
					Если Вычеты.НайтиСтроки(Новый Структура("ВидВычета, Сотрудник", Справочники.ВидыВычетовИПН.ПредварительнаяСуммаНалоговыхВычетов, СтрокаСотрудник.Сотрудник)).Количество() > 0 Тогда						
						Если НЕ ДействуетДо Тогда
							НоваяСтрокаОшибок = ОшибкиФормированияДокументов.Добавить();
							НоваяСтрокаОшибок.ФизическоеЛицо = СтрокаСотрудник.Сотрудник;
							НоваяСтрокаОшибок.ВидВычета = Справочники.ВидыВычетовИПН.ПредварительнаяСуммаНалоговыхВычетов;
							НоваяСтрокаОшибок.ОписаниеОшибки = НСтр("ru = 'При использовании предварительной суммы прочих вычетов, необходимо ограничивать ввод заявлений концом года'");
						КонецЕсли;
					КонецЕсли;
					Для Каждого СтрокаОшибки Из НовоеЗаявление.ДополнительныеСвойства.ТаблицаОшибокПроверкиЗаполнения Цикл
						НоваяСтрокаОшибок = ОшибкиФормированияДокументов.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрокаОшибок, СтрокаОшибки);
					КонецЦикла;
					СтрокаИтого.Подробнее = НСтр("ru = 'Подробнее об ошибках...'");
