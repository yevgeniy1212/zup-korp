
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ПредоставлятьВычет = Ложь;
	НеПредоставлятьВычет = Истина;
	ПрекращатьНеиспользуемыеВычеты = Истина;
	ПодготовитьФормуНаСервере();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ВариантОбработкиПриИзменении(Элемент)
	
	Если ВариантОбработки = 2 Тогда
		Элементы.ПрекращатьНеиспользуемыеВычеты.Видимость = Истина;
		Элементы.ТаблицаСоответствияВычетов.Видимость = Истина;
		Элементы.ДобавляемыеВычеты.Видимость = Ложь;
		Элементы.ДекорацияЗамены.Видимость = Истина;
		Элементы.ДекорацияФормирования.Видимость = Ложь;
		ДобавляемыеВычеты.Очистить();
	Иначе
		Элементы.ПрекращатьНеиспользуемыеВычеты.Видимость = Ложь;
		Элементы.ТаблицаСоответствияВычетов.Видимость = Ложь;
		Элементы.ДобавляемыеВычеты.Видимость = Истина;
		Элементы.ДекорацияЗамены.Видимость = Ложь;
		Элементы.ДекорацияФормирования.Видимость = Истина;
		ТаблицаСоответствияВычетов.Очистить();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПериодПриИзменении(Элемент)
	
	ЗарплатаКадрыКлиент.ВводМесяцаПриИзменении(ЭтаФорма, "Объект.Период", "ПериодСтрокой", Модифицированность);
	КонтрольМесяца();	
	ДобавляемыеВычеты.Очистить();
	ТаблицаСоответствияВычетов.Очистить();

КонецПроцедуры

&НаКлиенте
Процедура ПериодНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	Оповещение = Новый ОписаниеОповещения("ПериодСтрокойНачалоВыбораЗавершение", ЭтотОбъект);
	ЗарплатаКадрыКлиент.ВводМесяцаНачалоВыбора(ЭтаФорма, ЭтаФорма, "Объект.Период", "ПериодСтрокой", , Оповещение);
	ДобавляемыеВычеты.Очистить();
	ТаблицаСоответствияВычетов.Очистить();
	
КонецПроцедуры

&НаКлиенте
Процедура ПериодСтрокойНачалоВыбораЗавершение(ЗначениеВыбрано, ДополнительныеПараметры) Экспорт 
	
	Если НЕ ЗначениеВыбрано Тогда
		Возврат;	
	КонецЕсли;
	
	КонтрольМесяца();
	
КонецПроцедуры

&НаКлиенте
Процедура ПериодРегулирование(Элемент, Направление, СтандартнаяОбработка)
	
	ЗарплатаКадрыКлиент.ВводМесяцаРегулирование(ЭтаФорма, "Объект.Период", "ПериодСтрокой", Направление, Модифицированность);
	КонтрольМесяца();
	ДобавляемыеВычеты.Очистить();
	ТаблицаСоответствияВычетов.Очистить();
	
КонецПроцедуры

&НаКлиенте
Процедура ПериодАвтоПодбор(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, Ожидание, СтандартнаяОбработка)

	ЗарплатаКадрыКлиент.ВводМесяцаАвтоПодборТекста(Текст, ДанныеВыбора, СтандартнаяОбработка);
	
КонецПроцедуры

&НаКлиенте
Процедура ПериодОкончаниеВводаТекста(Элемент, Текст, ДанныеВыбора, ПараметрыПолученияДанных, СтандартнаяОбработка)
	
	ЗарплатаКадрыКлиент.ВводМесяцаОкончаниеВводаТекста(Текст, ДанныеВыбора, СтандартнаяОбработка);
	КонтрольМесяца();

КонецПроцедуры

&НаКлиенте
Процедура ДобавляемыеВычетыПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)
	
	ТекущиеДанные = Элементы.ДобавляемыеВычеты.ТекущиеДанные;

	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.ВидВычета) И ДобавляемыеВычеты.НайтиСтроки(Новый Структура("ВидВычета", ТекущиеДанные.ВидВычета)).Количество() > 1 Тогда
		Если ОтменаРедактирования Тогда
			ТекущиеДанные.ВидВычета = ПредопределенноеЗначение("Справочник.ВидыВычетовИПН.ПустаяСсылка");
		Иначе
			ТекстСообщения = НСтр("ru = 'В строке повторно указан вид вычета.'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,, "ДобавляемыеВычеты", Отказ);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТаблицаСоответствияВычетовПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)
	
	ТекущиеДанные = Элементы.ТаблицаСоответствияВычетов.ТекущиеДанные;

	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.ВычетДо) И ТаблицаСоответствияВычетов.НайтиСтроки(Новый Структура("ВычетДо", ТекущиеДанные.ВычетДо)).Количество() > 1 Тогда
		Если ОтменаРедактирования Тогда
			ТекущиеДанные.ВычетДо = ПредопределенноеЗначение("Справочник.ВидыВычетовИПН.ПустаяСсылка");
		Иначе
			ТекстСообщения = НСтр("ru = 'В строке повторно указан вид вычета(до изменения).'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,, "ТаблицаСоответствияВычетов", Отказ);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСотрудники

&НаКлиенте
Процедура СотрудникиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если Поле.Имя = "СотрудникиСуществующийДокумент" Тогда
		ТекущиеДанные = Элементы.Сотрудники.ТекущиеДанные;
		Если ЗначениеЗаполнено(ТекущиеДанные.СуществующийДокумент) Тогда
			ПоказатьЗначение(, ТекущиеДанные.СуществующийДокумент);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СотрудникиПриАктивизацииСтроки(Элемент)
	ТекущийКлюч = Неопределено;
	ТекущиеДанные = Элементы.Сотрудники.ТекущиеДанные;
	Если ТекущиеДанные <> Неопределено Тогда
		
		СтруктураОтбора = Новый Структура();
		СтруктураОтбора.Вставить("Сотрудник",ТекущиеДанные.Сотрудник);
		
		ОтборПоСотруднику = Новый ФиксированнаяСтруктура(СтруктураОтбора);
		Элементы.Вычеты.ОтборСтрок = ОтборПоСотруднику; 
		Элементы.Вычеты.ТолькоПросмотр = Ложь;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура СотрудникиПередНачаломИзменения(Элемент, Отказ)
	
	ТекущаяСтрока = Элементы.Сотрудники.ТекущиеДанные;
	Если ТекущаяСтрока <> Неопределено Тогда
		Если ЗначениеЗаполнено(ТекущаяСтрока.СуществующийДокумент) 
			И Элемент.ТекущийЭлемент.Имя = "СотрудникиОтметка" Тогда 
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыВычеты

&НаКлиенте
Процедура ВычетыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.Вычеты.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если Поле.ГиперссылкаЯчейки И ЗначениеЗаполнено(ТекущиеДанные.Расшифровка) Тогда
		РедактированиеГрафикиВычетов(ТекущиеДанные);
		СтандартнаяОбработка = Ложь;
	КонецЕсли
	
КонецПроцедуры

&НаКлиенте
Процедура ВычетыПриНачалеРедактирования(Элемент, НоваяСтрока, Копирование)
	
	ТекущиеДанные = Элементы.Вычеты.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если НоваяСтрока И НЕ Копирование Тогда
		ТекущиеДанные.ПредоставлятьВычет = Истина;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВычетыПередОкончаниемРедактирования(Элемент, НоваяСтрока, ОтменаРедактирования, Отказ)

	СуществующийОтбор = Элементы.Вычеты.ОтборСтрок;
	ТекущиеДанные = Элементы.Вычеты.ТекущиеДанные;
	ЗаполнитьЗначенияСвойств(ТекущиеДанные, СуществующийОтбор);

	Если ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущиеДанные.ВидВычета) И Вычеты.НайтиСтроки(Новый Структура("ВидВычета, Сотрудник", ТекущиеДанные.ВидВычета, ТекущиеДанные.Сотрудник)).Количество() > 1 Тогда
		Если ОтменаРедактирования Тогда
			ТекущиеДанные.ВидВычета = ПредопределенноеЗначение("Справочник.ВидыВычетовИПН.ПустаяСсылка");
		Иначе
			ТекстСообщения = НСтр("ru = 'В строке повторно указан вид вычета.'");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения,,, "Вычеты", Отказ);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВычетыВидВычетаПриИзменении(Элемент)
	
	ТекущиеДанныеСотрудника = Элементы.Сотрудники.ТекущиеДанные;
	ТекущиеДанные = Элементы.Вычеты.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	Отказ = Ложь;
	
	ТекущиеДанные.ВидДохода = ПолучитьВидДохода(Объект.Период, ТекущиеДанные.ВидВычета);
	
	ЗаполнитьРасшифровкуВСтроке(ТекущиеДанные.ПолучитьИдентификатор());
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыСформированныеДокументы

&НаКлиенте
Процедура СформированныеДокументыВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.СформированныеДокументы.ТекущиеДанные;

	Если Поле.Имя = "СформированныеДокументыДокумент" Тогда
		Если ЗначениеЗаполнено(ТекущиеДанные.Документ) Тогда
			ПоказатьЗначение(, ТекущиеДанные.Документ);
		КонецЕсли;
	КонецЕсли;
		
	Если Поле.Имя = "СформированныеДокументыПодробнее" И ЗначениеЗаполнено(ТекущиеДанные.Подробнее) Тогда
		ПоказатьОшибки(ТекущиеДанные);
		СтандартнаяОбработка = Ложь;
	КонецЕсли

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Назад(Команда)

	ОчиститьСообщения();
	
	Шаг = Прав(Элементы.ГруппаСтраницыЭтапов.ТекущаяСтраница.Имя,2);
	Шаг = Число(Шаг);
		
	Шаг = Шаг - 1;
	
	Элементы.Назад.Доступность = Шаг > 1;
	Элементы.Далее.Доступность = Шаг < 3;
	Элементы.ВНачало.Доступность = Шаг = 3;
	
	Шаг = Формат(Шаг,"ЧЦ=2; ЧВН=");
	
	Для каждого СтрокаСтраниц Из Элементы.ГруппаСтраницыЭтапов.ПодчиненныеЭлементы Цикл
		
		НомерСтраницы = Прав(СтрокаСтраниц.Имя,2);
		
		Если Шаг = НомерСтраницы Тогда 
			Элементы.ГруппаСтраницыЭтапов.ТекущаяСтраница = СтрокаСтраниц; 
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура Далее(Команда)
		
	Шаг = Прав(Элементы.ГруппаСтраницыЭтапов.ТекущаяСтраница.Имя,2);
	Шаг = Число(Шаг);
	
	ТекущийШаг = Шаг;
	
	Отказ = Ложь;
	
	ПроверитьЗаполнениеДанных(ТекущийШаг, Отказ);
	
	Если Не Отказ Тогда
		ВыполнитьШаг(ТекущийШаг,Отказ);
	КонецЕсли;
	
	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	Шаг = Шаг + 1;
	
	Элементы.Назад.Доступность = Шаг > 1 И Шаг <> 3;
	Элементы.Далее.Доступность = Шаг < 3;
	Элементы.ВНачало.Доступность = Шаг = 3;
	
	Шаг = Формат(Шаг,"ЧЦ=2; ЧВН=");
	
	Для каждого СтрокаСтраниц Из Элементы.ГруппаСтраницыЭтапов.ПодчиненныеЭлементы Цикл
		
		НомерСтраницы = Прав(СтрокаСтраниц.Имя,2);
		
		Если Шаг = НомерСтраницы Тогда 
			Элементы.ГруппаСтраницыЭтапов.ТекущаяСтраница = СтрокаСтраниц; 
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВНачало(Команда)
	
	ОчиститьСообщения();
	
	Шаг = 1;
	
	Элементы.Назад.Доступность = Шаг > 1;
	Элементы.Далее.Доступность = Шаг < 3;
	Элементы.ВНачало.Доступность = Шаг = 3;
	
	Шаг = Формат(Шаг,"ЧЦ=2; ЧВН=");
	
	Для каждого СтрокаСтраниц Из Элементы.ГруппаСтраницыЭтапов.ПодчиненныеЭлементы Цикл
		
		НомерСтраницы = Прав(СтрокаСтраниц.Имя,2);
		
		Если Шаг = НомерСтраницы Тогда 
			Элементы.ГруппаСтраницыЭтапов.ТекущаяСтраница = СтрокаСтраниц; 
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВыборВсех(Команда)
	
	Для Каждого СтрокаТЧ Из Сотрудники Цикл
		СтрокаТЧ.Отметка = Истина;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура СнятьВыборВсех(Команда)
	
	Для Каждого СтрокаТЧ Из Сотрудники Цикл
		СтрокаТЧ.Отметка = Ложь;	
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ПроверитьЗаполнениеДанных(Шаг, Отказ)
	
	Если Шаг = 1 Тогда // Шаг 1
		
		Если НЕ ЗначениеЗаполнено(Объект.Организация) Тогда
			ТекстСообщения = НСтр("ru = 'Не заполнена организация.'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,"Объект.Организация",Отказ);
		КонецЕсли;
		
		Если НЕ ЗначениеЗаполнено(ВариантОбработки) Тогда
			ТекстСообщения = НСтр("ru = 'Не заполнен вариант обработки.'");
			ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,"ВариантОбработки",Отказ); 			
		КонецЕсли;
		
		Для каждого СтрокаВычет Из ДобавляемыеВычеты Цикл
			Если НЕ ЗначениеЗаполнено(СтрокаВычет.ВидВычета) Тогда
				ТекстСообщения = НСтр("ru = 'Не заполнен вид вычета.'");
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,"ДобавляемыеВычеты",Отказ);
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Для каждого СтрокаВычет Из ТаблицаСоответствияВычетов Цикл
			Если НЕ ЗначениеЗаполнено(СтрокаВычет.ВычетПосле) Тогда
				ТекстСообщения = НСтр("ru = 'Не заполнен вид вычета.'");
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,"ТаблицаСоответствияВычетов",Отказ);
				Прервать;
			КонецЕсли;
			Если НЕ ЗначениеЗаполнено(СтрокаВычет.ВычетДо) Тогда
				ТекстСообщения = НСтр("ru = 'Не заполнен вид вычета.'");
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,"ТаблицаСоответствияВычетов",Отказ);
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
	ИначеЕсли Шаг = 2 Тогда

		Для каждого СтрокаВычет Из Вычеты Цикл
			Если НЕ ЗначениеЗаполнено(СтрокаВычет.ВидВычета) Тогда
				ТекстСообщения = НСтр("ru = 'Не заполнен вид вычета у %2.'");
				ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстСообщения, СтрокаВычет.Сотрудник);
				ОбщегоНазначения.СообщитьПользователю(ТекстСообщения,,,"Вычеты",Отказ);
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ВыполнитьШаг(ТекущийШаг, Отказ)
	
	Если ТекущийШаг = 1 И ВариантОбработки = 1 Тогда
		
		Элементы.ВычетыСуществующийДокумент.Видимость = Ложь;
		Элементы.ВычетыПредоставлятьВычет.Видимость = Ложь;
		Элементы.ВычетыКомментарий.Видимость = Ложь;
		
		ПолучитьДанныеДляФормированияЗаявлений(Отказ);
		
	ИначеЕсли ТекущийШаг = 1 И ВариантОбработки = 2 Тогда
		
		Элементы.ВычетыСуществующийДокумент.Видимость = Истина;
		Элементы.ВычетыПредоставлятьВычет.Видимость = Истина;
		Элементы.ВычетыКомментарий.Видимость = Истина;
		
		ПолучитьДанныеДляЗаменыЗаявлений();
		
	ИначеЕсли ТекущийШаг = 2 И ВариантОбработки = 1 Тогда
		
		СформироватьДокументыЗаявлений(Отказ);     
		
	ИначеЕсли ТекущийШаг = 2 И ВариантОбработки = 2 Тогда 
		
		СформироватьДокументыЗаявленийЗамены(Отказ); 
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьДанныеДляФормированияЗаявлений(Отказ)
	
	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ПериодСреза", Объект.Период);
	Запрос.УстановитьПараметр("ПустаяДата",  '00010101');
	
	ГоловнаяОрганизация = ЗарплатаКадры.ГоловнаяОрганизация(Объект.Организация);
	Отборы = Новый Массив;
	
	ЗарплатаКадрыОбщиеНаборыДанных.ДобавитьВКоллекциюОтбор(
		Отборы, "Организация", "=", Объект.Организация);
	
	КадровыйУчет.СоздатьВТТекущиеКадровыеДанныеСотрудников(Запрос.МенеджерВременныхТаблиц, Истина, Отборы, "Организация" );
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
		|	СтатусФизическихЛицКакНалогоплательщиковСрезПоследних.ФизическоеЛицо КАК ФизическоеЛицо
		|ПОМЕСТИТЬ ВТ_ФизическиеЛица
		|ИЗ
		|	РегистрСведений.СтатусФизическихЛицКакНалогоплательщиков.СрезПоследних(
		|			&ПериодСреза,
		|			Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)
		|				И ФизическоеЛицо В
		|					(ВЫБРАТЬ
		|						ВТТекущиеКадровыеДанныеСотрудников.ФизическоеЛицо
		|					ИЗ
		|						ВТТекущиеКадровыеДанныеСотрудников)) КАК СтатусФизическихЛицКакНалогоплательщиковСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|УНИЧТОЖИТЬ ВТТекущиеКадровыеДанныеСотрудников
		|";
	
	Запрос.Выполнить();
	
	Если ГоловнаяОрганизация = Объект.Организация Тогда
		
		Отборы = Новый Массив;
		
		ЗарплатаКадрыОбщиеНаборыДанных.ДобавитьВКоллекциюОтбор(
			Отборы, "ОформленПоТрудовомуДоговору", "=", Ложь);
		ЗарплатаКадрыОбщиеНаборыДанных.ДобавитьВКоллекциюОтбор(
			Отборы, "ГоловнаяОрганизация", "=", ГоловнаяОрганизация);
		
		КадровыйУчет.СоздатьВТТекущиеКадровыеДанныеСотрудников(Запрос.МенеджерВременныхТаблиц, Истина, Отборы, "ОформленПоТрудовомуДоговору" );
		
		Запрос.Текст =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	СтатусФизическихЛицКакНалогоплательщиковСрезПоследних.ФизическоеЛицо КАК ФизическоеЛицо
			|ПОМЕСТИТЬ ВТ_ГПХ
			|ИЗ
			|	РегистрСведений.СтатусФизическихЛицКакНалогоплательщиков.СрезПоследних(
			|			&ПериодСреза,
			|			Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыФизическихЛицНалогоплательщиков.Резидент)
			|				И ФизическоеЛицо В
			|					(ВЫБРАТЬ
			|						ВТТекущиеКадровыеДанныеСотрудников.ФизическоеЛицо
			|					ИЗ
			|						ВТТекущиеКадровыеДанныеСотрудников)) КАК СтатусФизическихЛицКакНалогоплательщиковСрезПоследних
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	ВТ_ФизическиеЛица.ФизическоеЛицо КАК ФизическоеЛицо
			|ПОМЕСТИТЬ ВТ_Резиденты
			|ИЗ
			|	ВТ_ФизическиеЛица КАК ВТ_ФизическиеЛица
			|
			|ОБЪЕДИНИТЬ ВСЕ
			|
			|ВЫБРАТЬ РАЗЛИЧНЫЕ
			|	ВТ_ГПХ.ФизическоеЛицо
			|ИЗ
			|	ВТ_ГПХ КАК ВТ_ГПХ
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	ВычетыФизическихЛицИПНСрезПоследних.ФизическоеЛицо КАК ФизическоеЛицо,
			|	ВычетыФизическихЛицИПНСрезПоследних.ВидВычета КАК ВидВычета,
			|	МАКСИМУМ(ВычетыФизическихЛицИПНСрезПоследних.ДействуетПо) КАК ДействуетПо,
			|	МАКСИМУМ(ВычетыФизическихЛицИПНСрезПоследних.ПредоставлятьВычет) КАК ПредоставлятьВычет
			|ПОМЕСТИТЬ ВТ_ФизическиеЛицаСЗаявлениями
			|ИЗ
			|	ВТ_Резиденты КАК ВТ_Резиденты
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ВычетыФизическихЛицИПН.СрезПоследних(&ПериодСреза, ПредоставлятьВычет = ИСТИНА) КАК ВычетыФизическихЛицИПНСрезПоследних
			|		ПО ВТ_Резиденты.ФизическоеЛицо = ВычетыФизическихЛицИПНСрезПоследних.ФизическоеЛицо
			|
			|СГРУППИРОВАТЬ ПО
			|	ВычетыФизическихЛицИПНСрезПоследних.ФизическоеЛицо,
			|	ВычетыФизическихЛицИПНСрезПоследних.ВидВычета
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	ВТ_ФизическиеЛицаСЗаявлениями.ФизическоеЛицо КАК ФизическоеЛицо,
			|	ВТ_ФизическиеЛицаСЗаявлениями.ВидВычета КАК ВидВычета,
			|	ВТ_ФизическиеЛицаСЗаявлениями.ДействуетПо КАК ДействуетПо,
			|	ВТ_ФизическиеЛицаСЗаявлениями.ПредоставлятьВычет КАК ПредоставлятьВычет
			|ПОМЕСТИТЬ ВТ_ФизическиеЛицаСДействующимиЗаявлениями
			|ИЗ
			|	ВТ_ФизическиеЛицаСЗаявлениями КАК ВТ_ФизическиеЛицаСЗаявлениями
			|ГДЕ
			|	(ВТ_ФизическиеЛицаСЗаявлениями.ДействуетПо >= &ПериодСреза
			|			ИЛИ ВТ_ФизическиеЛицаСЗаявлениями.ДействуетПо = &ПустаяДата)
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	ВТ_Резиденты.ФизическоеЛицо КАК ФизическоеЛицо
			|ИЗ
			|	ВТ_Резиденты КАК ВТ_Резиденты
			|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ФизическиеЛицаСДействующимиЗаявлениями КАК Действующие
			|		ПО ВТ_Резиденты.ФизическоеЛицо = Действующие.ФизическоеЛицо
			|ГДЕ
			|	Действующие.ФизическоеЛицо ЕСТЬ NULL
			|
			|СГРУППИРОВАТЬ ПО
			|	ВТ_Резиденты.ФизическоеЛицо";
	
	Иначе
	        Запрос.Текст =
			"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	ВычетыФизическихЛицИПНСрезПоследних.ФизическоеЛицо КАК ФизическоеЛицо,
			|	ВычетыФизическихЛицИПНСрезПоследних.ВидВычета КАК ВидВычета,
			|	МАКСИМУМ(ВычетыФизическихЛицИПНСрезПоследних.ДействуетПо) КАК ДействуетПо,
			|	МАКСИМУМ(ВычетыФизическихЛицИПНСрезПоследних.ПредоставлятьВычет) КАК ПредоставлятьВычет
			|ПОМЕСТИТЬ ВТ_ФизическиеЛицаСЗаявлениями
			|ИЗ
			|	ВТ_ФизическиеЛица КАК ВТ_ФизическиеЛица
			|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ВычетыФизическихЛицИПН.СрезПоследних(
			|				&ПериодСреза,
			|				ПредоставлятьВычет = ИСТИНА
			|					И (ДействуетПо >= &ПериодСреза
			|						ИЛИ ДействуетПо = &ПустаяДата)) КАК ВычетыФизическихЛицИПНСрезПоследних
			|		ПО ВТ_ФизическиеЛица.ФизическоеЛицо = ВычетыФизическихЛицИПНСрезПоследних.ФизическоеЛицо
			|
			|СГРУППИРОВАТЬ ПО
			|	ВычетыФизическихЛицИПНСрезПоследних.ФизическоеЛицо,
			|	ВычетыФизическихЛицИПНСрезПоследних.ВидВычета
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	ВТ_ФизическиеЛицаСЗаявлениями.ФизическоеЛицо КАК ФизическоеЛицо,
			|	ВТ_ФизическиеЛицаСЗаявлениями.ВидВычета КАК ВидВычета,
			|	ВТ_ФизическиеЛицаСЗаявлениями.ДействуетПо КАК ДействуетПо,
			|	ВТ_ФизическиеЛицаСЗаявлениями.ПредоставлятьВычет КАК ПредоставлятьВычет
			|ПОМЕСТИТЬ ВТ_ФизическиеЛицаСДействующимиЗаявлениями
			|ИЗ
			|	ВТ_ФизическиеЛицаСЗаявлениями КАК ВТ_ФизическиеЛицаСЗаявлениями
			|ГДЕ
			|	(ВТ_ФизическиеЛицаСЗаявлениями.ДействуетПо >= &ПериодСреза
			|			ИЛИ ВТ_ФизическиеЛицаСЗаявлениями.ДействуетПо = &ПустаяДата)
			|;
			|
			|////////////////////////////////////////////////////////////////////////////////
			|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
			|	ВТ_ФизическиеЛица.ФизическоеЛицо КАК ФизическоеЛицо
			|ИЗ
			|	ВТ_ФизическиеЛица КАК ВТ_ФизическиеЛица
			|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ФизическиеЛицаСДействующимиЗаявлениями КАК Действующие
			|		ПО ВТ_ФизическиеЛица.ФизическоеЛицо = Действующие.ФизическоеЛицо
			|ГДЕ
			|	Действующие.ФизическоеЛицо ЕСТЬ NULL
			|
			|СГРУППИРОВАТЬ ПО
			|	ВТ_ФизическиеЛица.ФизическоеЛицо";
			
	КонецЕсли;
	
	Результат = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	
	Сотрудники.Очистить();
	Вычеты.Очистить();
	ГрафикиВычетов.Очистить();
	ОшибкиФормированияДокументов.Очистить();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		НоваяСтрокаСотрудники = Сотрудники.Добавить();
		НоваяСтрокаСотрудники.Сотрудник = ВыборкаДетальныеЗаписи.ФизическоеЛицо;
		Для каждого СтрокаВычет Из ДобавляемыеВычеты Цикл
			НоваяСтрокаВычеты = Вычеты.Добавить();
			НоваяСтрокаВычеты.Сотрудник = ВыборкаДетальныеЗаписи.ФизическоеЛицо;
			НоваяСтрокаВычеты.ВидВычета = СтрокаВычет.ВидВычета;
			Если СтрокаВычет.ВидВычета.ПредоставлениеВычета = Перечисления.ВидыПредоставленияВычетов.ПоПериодическимПлатежам Тогда
				НоваяСтрокаВычеты.Расшифровка = НСтр("ru = 'Подробнее'");
			КонецЕсли;
			НоваяСтрокаВычеты.ПредоставлятьВычет = Истина;
		КонецЦикла;
	КонецЦикла;
	
	Если НоваяСтрокаСотрудники = Неопределено Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru='В организации отсутствуют физические лица резиденты с неназначенными вычетами'"));
		Отказ = Истина;
	КонецЕсли;
	
	Сотрудники.Сортировать("Сотрудник, Отметка Убыв");
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьДанныеДляЗаменыЗаявлений()

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.УстановитьПараметр("ПериодСреза", Объект.Период);
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("ПустаяДата",  '00010101');
	
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ЗаявлениеНаПредоставлениеВычетовИПН.Ссылка КАК СуществующийДокумент,
	|	ЗаявлениеНаПредоставлениеВычетовИПН.Сотрудник КАК ФизическоеЛицо
	|ПОМЕСТИТЬ ВТ_Заявления
	|ИЗ
	|	Документ.ЗаявлениеНаПредоставлениеВычетовИПН КАК ЗаявлениеНаПредоставлениеВычетовИПН
	|ГДЕ
	|	ЗаявлениеНаПредоставлениеВычетовИПН.Организация = &Организация
	|	И ЗаявлениеНаПредоставлениеВычетовИПН.Проведен = ИСТИНА
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ЗаявлениеНаПредоставлениеВычетовИПН.Ссылка,
	|	ЗаявлениеНаПредоставлениеВычетовИПН.Сотрудник
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.ФизическоеЛицо КАК ФизическоеЛицо,
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.ВидВычета КАК ВидВычета,
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.Регистратор КАК Регистратор,
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.ДействуетС КАК ДействуетС,
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.ДействуетПо КАК ДействуетПо,
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.Размер КАК Размер
	|ПОМЕСТИТЬ ВТ_ДействующиеПериодическиеВычеты
	|ИЗ
	|	РегистрСведений.ПрочиеВычетыФизическихЛицИПН.СрезПоследних(
	|			&ПериодСреза,
	|			ДействуетПо >= &ПериодСреза
	|				И Размер <> 0
	|				И Регистратор В
	|					(ВЫБРАТЬ
	|						ВТ_Заявления.СуществующийДокумент
	|					ИЗ
	|						ВТ_Заявления КАК ВТ_Заявления)) КАК ПрочиеВычетыФизическихЛицИПНСрезПоследних
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.ФизическоеЛицо КАК ФизическоеЛицо,
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.ВидВычета КАК ВидВычета,
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.Регистратор КАК Регистратор,
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.ДействуетС КАК ДействуетС,
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.ДействуетПо КАК ДействуетПо,
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.Размер КАК Размер
	|ПОМЕСТИТЬ ВТ_ИстёкшиеПериодическиеВычеты
	|ИЗ
	|	РегистрСведений.ПрочиеВычетыФизическихЛицИПН.СрезПоследних(
	|			&ПериодСреза,
	|			ДействуетПо < &ПериодСреза
	|				И Размер <> 0
	|				И Регистратор В
	|					(ВЫБРАТЬ
	|						ВТ_Заявления.СуществующийДокумент
	|					ИЗ
