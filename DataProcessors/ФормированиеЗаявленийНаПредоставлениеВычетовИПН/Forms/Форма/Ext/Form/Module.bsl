	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ФизическоеЛицо
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ВычетыФизическихЛицИПНСрезПоследних.ФизическоеЛицо КАК ФизическоеЛицо,
	|	ВычетыФизическихЛицИПНСрезПоследних.ВидВычета КАК ВидВычета
	|ПОМЕСТИТЬ ВТ_ВычетыФизическихЛицИПНСрезПоследнихНеПредоставлятьВычет
	|ИЗ
	|	РегистрСведений.ВычетыФизическихЛицИПН.СрезПоследних(
	|			&ПериодСреза,
	|			Регистратор В
	|					(ВЫБРАТЬ
	|						ВТ_Заявления.СуществующийДокумент
	|					ИЗ
	|						ВТ_Заявления КАК ВТ_Заявления)
	|				И ПредоставлятьВычет = ЛОЖЬ) КАК ВычетыФизическихЛицИПНСрезПоследних
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ФизическоеЛицо,
	|	ВидВычета
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ВычетыФизическихЛицИПНСрезПоследних.ФизическоеЛицо КАК ФизическоеЛицо,
	|	ВычетыФизическихЛицИПНСрезПоследних.ВидВычета КАК ВидВычета,
	|	ВычетыФизическихЛицИПНСрезПоследних.Период КАК Период,
	|	ВычетыФизическихЛицИПНСрезПоследних.Регистратор КАК Регистратор,
	|	ВычетыФизическихЛицИПНСрезПоследних.ПредоставлятьВычет КАК ПредоставлятьВычет,
	|	ВычетыФизическихЛицИПНСрезПоследних.ДействуетПо КАК ДействуетПо
	|ПОМЕСТИТЬ ВТ_ВычетыФизическихЛицИПНСрезПоследних
	|ИЗ
	|	РегистрСведений.ВычетыФизическихЛицИПН.СрезПоследних(
	|			&ПериодСреза,
	|			Регистратор В
	|					(ВЫБРАТЬ
	|						ВТ_Заявления.СуществующийДокумент
	|					ИЗ
	|						ВТ_Заявления КАК ВТ_Заявления)
	|				И ПредоставлятьВычет = ИСТИНА
	|				И ВидВычета <> ЗНАЧЕНИЕ(Справочник.ВидыВычетовИПН.ПустаяСсылка)
	|				И Период <> &ПериодСреза) КАК ВычетыФизическихЛицИПНСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ВычетыФизическихЛицИПНСрезПоследнихНеПредоставлятьВычет КАК ВТ_ВычетыФизическихЛицИПНСрезПоследнихНеПредоставлятьВычет
	|		ПО ВычетыФизическихЛицИПНСрезПоследних.ФизическоеЛицо = ВТ_ВычетыФизическихЛицИПНСрезПоследнихНеПредоставлятьВычет.ФизическоеЛицо
	|			И ВычетыФизическихЛицИПНСрезПоследних.ВидВычета = ВТ_ВычетыФизическихЛицИПНСрезПоследнихНеПредоставлятьВычет.ВидВычета
	|ГДЕ
	|	ВТ_ВычетыФизическихЛицИПНСрезПоследнихНеПредоставлятьВычет.ФизическоеЛицо ЕСТЬ NULL
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ФизическоеЛицо,
	|	Регистратор
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ВТ_ВычетыФизическихЛицИПНСрезПоследних.ФизическоеЛицо КАК ФизическоеЛицо,
	|	ВТ_ВычетыФизическихЛицИПНСрезПоследних.ВидВычета КАК ВидВычета,
	|	ВТ_ВычетыФизическихЛицИПНСрезПоследних.Период КАК Период,
	|	ВТ_ВычетыФизическихЛицИПНСрезПоследних.Регистратор КАК Регистратор
	|ПОМЕСТИТЬ ВТИтоговыйРезультат
	|ИЗ
	|	ВТ_ВычетыФизическихЛицИПНСрезПоследних КАК ВТ_ВычетыФизическихЛицИПНСрезПоследних
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ИсключитьСотрудников КАК ВТ_ИсключитьСотрудников
	|		ПО ВТ_ВычетыФизическихЛицИПНСрезПоследних.ФизическоеЛицо = ВТ_ИсключитьСотрудников.ФизическоеЛицо
	|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ИстёкшиеПериодическиеВычеты КАК ВТ_ИстёкшиеПериодическиеВычеты
	|		ПО ВТ_ВычетыФизическихЛицИПНСрезПоследних.ФизическоеЛицо = ВТ_ИстёкшиеПериодическиеВычеты.ФизическоеЛицо
	|			И ВТ_ВычетыФизическихЛицИПНСрезПоследних.ВидВычета = ВТ_ИстёкшиеПериодическиеВычеты.ВидВычета
	|ГДЕ
	|	ВТ_ИсключитьСотрудников.ФизическоеЛицо ЕСТЬ NULL
	|	И ВТ_ИстёкшиеПериодическиеВычеты.ВидВычета ЕСТЬ NULL
	|	И (ВТ_ВычетыФизическихЛицИПНСрезПоследних.ДействуетПо >= &ПериодСреза
	|			ИЛИ ВТ_ВычетыФизическихЛицИПНСрезПоследних.ДействуетПо = &ПустаяДата)
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	ФизическоеЛицо,
	|	Регистратор";
	
	Запрос.Выполнить();
	
	Запрос.Текст =
	"ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ВТИтоговыйРезультат.ФизическоеЛицо КАК ФизическоеЛицо
	|ИЗ
	|	ВТИтоговыйРезультат КАК ВТИтоговыйРезультат
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Заявления КАК ВТ_Заявления
	|		ПО ВТИтоговыйРезультат.ФизическоеЛицо = ВТ_Заявления.ФизическоеЛицо
	|			И ВТИтоговыйРезультат.Регистратор = ВТ_Заявления.СуществующийДокумент
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ВТИтоговыйРезультат.ФизическоеЛицо КАК ФизическоеЛицо,
	|	ВТИтоговыйРезультат.ВидВычета КАК ВидВычета,
	|	ВТ_Заявления.СуществующийДокумент КАК СуществующийДокумент,
	|	ВычетыИПН.НеИспользуется КАК НеИспользуется
	|ИЗ
	|	ВТИтоговыйРезультат КАК ВТИтоговыйРезультат
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_Заявления КАК ВТ_Заявления
	|		ПО ВТИтоговыйРезультат.ФизическоеЛицо = ВТ_Заявления.ФизическоеЛицо
	|			И ВТИтоговыйРезультат.Регистратор = ВТ_Заявления.СуществующийДокумент
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ВидыВычетовИПН КАК ВычетыИПН
	|		ПО ВТИтоговыйРезультат.ВидВычета = ВычетыИПН.Ссылка
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗРЕШЕННЫЕ РАЗЛИЧНЫЕ
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.ФизическоеЛицо КАК ФизическоеЛицо,
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.ВидВычета КАК ВидВычета,
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.Регистратор КАК Регистратор,
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.ДействуетС КАК ДействуетС,
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.ДействуетПо КАК ДействуетПо,
	|	ПрочиеВычетыФизическихЛицИПНСрезПоследних.Размер КАК Размер
	|ИЗ
	|	РегистрСведений.ПрочиеВычетыФизическихЛицИПН.СрезПоследних(
	|			&ПериодСреза,
	|			ДействуетПо >= &ПериодСреза
	|				И Размер <> 0
	|				И (ФизическоеЛицо, Регистратор) В
	|					(ВЫБРАТЬ
	|						ВТИтоговыйРезультат.ФизическоеЛицо,
	|						ВТИтоговыйРезультат.Регистратор
	|					ИЗ
	|						ВТИтоговыйРезультат КАК ВТИтоговыйРезультат)) КАК ПрочиеВычетыФизическихЛицИПНСрезПоследних";
	
	МассивРезультатов = Запрос.ВыполнитьПакет();
	
	Сотрудники.Очистить();
	Вычеты.Очистить(); 
	ГрафикиВычетов.Очистить();
	ОшибкиФормированияДокументов.Очистить();
	
	ВыборкаСотрудники = МассивРезультатов[0].Выбрать();
	Пока ВыборкаСотрудники.Следующий() Цикл
		
		НоваяСтрокаСотрудники = Сотрудники.Добавить();
		НоваяСтрокаСотрудники.Сотрудник = ВыборкаСотрудники.ФизическоеЛицо;

	КонецЦикла;
	
	//ВидыВычетовТребущиеУказанияВидаДохода = ?(ИспользуетсяВидДохода, ВидыВычетовТребущиеУказанияВидаДохода(), Неопределено);
	
	ВыборкаВычеты = МассивРезультатов[1].Выбрать();
	МассивКлючей = Новый Массив;
	Пока ВыборкаВычеты.Следующий() Цикл
		Ключ = Строка(ВыборкаВычеты.ФизическоеЛицо) + "|" + Строка(ВыборкаВычеты.ВидВычета);

	    Если МассивКлючей.Найти(Ключ) <> Неопределено Тогда
	        Продолжить;
	    КонецЕсли;

	    МассивКлючей.Добавить(Ключ);
		
		НоваяСтрокаВычеты = Вычеты.Добавить();
		НоваяСтрокаВычеты.ВидВычета = ВыборкаВычеты.ВидВычета;
		Если ВыборкаВычеты.ВидВычета.ПредоставлениеВычета = Перечисления.ВидыПредоставленияВычетов.ПоПериодическимПлатежам Тогда
			НоваяСтрокаВычеты.Расшифровка = НСтр("ru = 'Подробнее'");
		КонецЕсли;
		НоваяСтрокаВычеты.Сотрудник = ВыборкаВычеты.ФизическоеЛицо;
		НоваяСтрокаВычеты.СуществующийДокумент = ВыборкаВычеты.СуществующийДокумент; 
		НоваяСтрокаВычеты.НеИспользуется = ВыборкаВычеты.НеИспользуется;
		Если ПрекращатьНеиспользуемыеВычеты И ВыборкаВычеты.НеИспользуется Тогда
			НоваяСтрокаВычеты.ПредоставлятьВычет = Ложь;
		Иначе
			НоваяСтрокаВычеты.ПредоставлятьВычет = Истина;
		КонецЕсли;
		Для каждого Строка Из ТаблицаСоответствияВычетов Цикл
			Если Строка.ВычетДо = ВыборкаВычеты.ВидВычета Тогда
				НоваяСтрокаВычеты.ПредоставлятьВычет = Ложь;
				НовыйКлюч = Строка(ВыборкаВычеты.ФизическоеЛицо) + "|" + Строка(Строка.ВычетПосле);
	            Если МассивКлючей.Найти(НовыйКлюч) = Неопределено Тогда
	                МассивКлючей.Добавить(НовыйКлюч);
					НоваяСтрокаВычеты = Вычеты.Добавить();
					НоваяСтрокаВычеты.Сотрудник = ВыборкаВычеты.ФизическоеЛицо;
					НоваяСтрокаВычеты.ВидВычета = Строка.ВычетПосле;
					Если НоваяСтрокаВычеты.ВидВычета.ПредоставлениеВычета = Перечисления.ВидыПредоставленияВычетов.ПоПериодическимПлатежам Тогда
						НоваяСтрокаВычеты.Расшифровка = НСтр("ru = 'Подробнее'");
					КонецЕсли;
					НоваяСтрокаВычеты.ПредоставлятьВычет = Истина;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;		
	КонецЦикла;
	
	ВыборкаГрафики = МассивРезультатов[2].Выбрать();
	Пока ВыборкаГрафики.Следующий() Цикл
		НоваяСтрокаГрафикВычетов = ГрафикиВычетов.Добавить();
		НоваяСтрокаГрафикВычетов.ВидВычетаИПН = ВыборкаГрафики.ВидВычета;
		НоваяСтрокаГрафикВычетов.ФизическоеЛицо = ВыборкаГрафики.ФизическоеЛицо;
		НоваяСтрокаГрафикВычетов.Размер = ВыборкаГрафики.Размер;
		НоваяСтрокаГрафикВычетов.ДействуетС = ВыборкаГрафики.ДействуетС;
		НоваяСтрокаГрафикВычетов.ДействуетПо = ВыборкаГрафики.ДействуетПо;
	КонецЦикла;
	
	Сотрудники.Сортировать("Сотрудник, Отметка Убыв");
	Вычеты.Сортировать("ПредоставлятьВычет Убыв");

КонецПроцедуры

&НаСервере
Процедура ПодготовитьФормуНаСервере()

	Объект.Период = Дата(2026,01,01);
	ЗарплатаКадрыКлиентСервер.ЗаполнитьМесяцПоДате(ЭтаФорма, "Объект.Период", "ПериодСтрокой"); 
	ВариантОбработки = 1;
	
	ЗначенияДляЗаполнения  = Новый Структура("Организация", "Объект.Организация");	
	ЗарплатаКадры.ЗаполнитьПервоначальныеЗначенияВФорме(ЭтаФорма, ЗначенияДляЗаполнения);
	
	Если НЕ ЗначениеЗаполнено(Объект.Организация) Тогда
		Объект.Организация = ЗарплатаКадры.ПерваяДоступнаяОрганизация();
	КонецЕсли;
	
	ИспользуетсяВидДохода = ЕстьРеквизитТабЧастиДокумента("ВидДохода", Метаданные.НайтиПоПолномуИмени("Документ.ЗаявлениеНаПредоставлениеВычетовИПН"), "Вычеты");
	
	Элементы.ВычетыВидДохода.Видимость = ИспользуетсяВидДохода;

	Элементы.Назад.Доступность = Ложь;
	Элементы.ВНачало.Доступность = Ложь;
	Элементы.ДекорацияНадписьВидДохода.Видимость = ИспользуетсяВидДохода;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьДокументыЗаявлений(Отказ)

	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	НаличиеОшибок = Ложь;
	СформированныеДокументы.Очистить();
	
	ДатаВводаНовыхДокументов = Объект.Период;
	ИтогоСозданоЗаявлений = 0;
	
	Для Каждого СтрокаСотрудник Из Сотрудники Цикл
		
		Если СтрокаСотрудник.Отметка Тогда
		
			НовоеЗаявление = Документы.ЗаявлениеНаПредоставлениеВычетовИПН.СоздатьДокумент();
			НовоеЗаявление.Дата = ТекущаяДата();
			НовоеЗаявление.Месяц = НачалоМесяца(ДатаВводаНовыхДокументов);
			Если ДействуетДо Тогда
				НовоеЗаявление.МесяцЗавершения = КонецГода(ДатаВводаНовыхДокументов);
			КонецЕсли;
			НовоеЗаявление.Сотрудник = СтрокаСотрудник.Сотрудник;
			НовоеЗаявление.Организация = Объект.Организация;
			НовоеЗаявление.Ответственный = Пользователи.ТекущийПользователь();
			НовоеЗаявление.НаличиеЗаявления = Истина;
			
			СтрокаИтого = СформированныеДокументы.Добавить();
			СтрокаИтого.Сотрудник = СтрокаСотрудник.Сотрудник;
						
			Отбор = Новый Структура();
			Отбор.Вставить("Сотрудник", СтрокаСотрудник.Сотрудник);
			ВычетыСотрудника = Вычеты.НайтиСтроки(Отбор);
			
			Для Каждого СтрокаВычет Из ВычетыСотрудника Цикл

				//вычет можно ввести только один раз
				НайденнаяСтрока = НовоеЗаявление.Вычеты.Найти(СтрокаВычет.ВидВычета, "ВидВычетаИПН");
				Если НайденнаяСтрока <> Неопределено Тогда
					Продолжить;
				КонецЕсли;
				
				//заполняем табличную часть документа (Вычеты)
				НоваяСтрокаВычета = НовоеЗаявление.Вычеты.Добавить();
				НоваяСтрокаВычета.ВидВычетаИПН = СтрокаВычет.ВидВычета;
				НоваяСтрокаВычета.ПредоставлятьВычет = Истина;
				
				Если СтрокаВычет.Расшифровка = НСтр("ru = 'Подробнее'") Тогда
					
					ОтборГрафик = Новый Структура();
					ОтборГрафик.Вставить("ВидВычетаИПН", СтрокаВычет.ВидВычета);
					ОтборГрафик.Вставить("ФизическоеЛицо", СтрокаВычет.Сотрудник);
					ГрафикВычета = ГрафикиВычетов.НайтиСтроки(ОтборГрафик);
						
					Для Каждого СтрокаГрафика Из ГрафикВычета Цикл
						//заполняем табличную часть по графикам (ПрочиеВычеты)
						НоваяСтрокаГрафика = НовоеЗаявление.ПрочиеВычеты.Добавить();
						НоваяСтрокаГрафика.ВидВычетаИПН = СтрокаГрафика.ВидВычетаИПН;
						НоваяСтрокаГрафика.ДействуетС = СтрокаГрафика.ДействуетС;
						НоваяСтрокаГрафика.ДействуетПо = СтрокаГрафика.ДействуетПо;
						НоваяСтрокаГрафика.Размер = СтрокаГрафика.Размер;
					КонецЦикла;
					
				КонецЕсли;				
				
			КонецЦикла;
						
			ПараметрыОтбораПоФизлицу = Новый Структура;
			ПараметрыОтбораПоФизлицу.Вставить("ФизическоеЛицо", СтрокаСотрудник.Сотрудник);
			ОшибкиПоСотруднику = ОшибкиФормированияДокументов.Выгрузить(Новый Структура("ФизическоеЛицо", ПараметрыОтбораПоФизлицу.ФизическоеЛицо));
			Если ОшибкиПоСотруднику.Количество() > 0 Тогда 
				СтрокаИтого.Подробнее =  НСтр("ru = 'Подробнее...'");
			КонецЕсли;
			
			Попытка 

				ТаблицаОшибокПроверкиЗаполнения = ОшибкиФормированияДокументов.Выгрузить();
				ТаблицаОшибокПроверкиЗаполнения.Очистить();
				НовоеЗаявление.ДополнительныеСвойства.Вставить("ТаблицаОшибокПроверкиЗаполнения", ТаблицаОшибокПроверкиЗаполнения);
				//пытаемся записать Документ. с проведением
				Если НовоеЗаявление.ПроверитьЗаполнение() Тогда
					НовоеЗаявление.Записать(РежимЗаписиДокумента.Проведение);
					СтрокаИтого.Документ = НовоеЗаявление.Ссылка;
					ИтогоСозданоЗаявлений = ИтогоСозданоЗаявлений + 1;
				Иначе 
					НаличиеОшибок = Истина;
					//ОшибкиФормированияДокументов.Очистить();
					Если Вычеты.НайтиСтроки(Новый Структура("ВидВычета, Сотрудник", Справочники.ВидыВычетовИПН.ПредварительнаяСуммаНалоговыхВычетов, СтрокаСотрудник.Сотрудник)).Количество() > 0 Тогда						
						Если НЕ ДействуетДо Тогда
							НоваяСтрокаОшибок = ОшибкиФормированияДокументов.Добавить();
							НоваяСтрокаОшибок.ФизическоеЛицо = СтрокаСотрудник.Сотрудник;
							НоваяСтрокаОшибок.ВидВычета = Справочники.ВидыВычетовИПН.ПредварительнаяСуммаНалоговыхВычетов;
							НоваяСтрокаОшибок.ОписаниеОшибки = НСтр("ru = 'При использовании предварительной суммы прочих вычетов, необходимо ограничивать ввод заявлений концом года'");
						КонецЕсли;
					КонецЕсли;
					Для Каждого СтрокаОшибки Из НовоеЗаявление.ДополнительныеСвойства.ТаблицаОшибокПроверкиЗаполнения Цикл
						НоваяСтрокаОшибок = ОшибкиФормированияДокументов.Добавить();
						ЗаполнитьЗначенияСвойств(НоваяСтрокаОшибок, СтрокаОшибки);
					КонецЦикла;
					СтрокаИтого.Подробнее = НСтр("ru = 'Подробнее об ошибках...'");
				КонецЕсли;  
				
			Исключение  
				
				НаличиеОшибок = Истина;
				ТекстСообщения = НСтр("ru = 'Ошибка создания документа по причине: %1'");
				ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку (ТекстСообщения, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			
				ЗаписьЖурналаРегистрации(НСтр("ru = 'Автоматическое формирование ""Заявлений на предоставление вычетов ИПН"".'"), УровеньЖурналаРегистрации.Ошибка,,, ТекстСообщения);
				
				Для Каждого СтрокаОшибки Из НовоеЗаявление.ДополнительныеСвойства.ТаблицаОшибокПроверкиЗаполнения Цикл
					НоваяСтрокаОшибок = ОшибкиФормированияДокументов.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрокаОшибок, СтрокаОшибки);
				КонецЦикла;
				СтрокаИтого.Подробнее = НСтр("ru = 'Подробнее об ошибках...'");

			КонецПопытки;
			
		КонецЕсли;	
			
	КонецЦикла;
	
	СформированныеДокументы.Сортировать("Подробнее, Сотрудник");
	
	Элементы.Декорация3.Видимость = НаличиеОшибок;
	Элементы.Декорация6.Видимость = Истина;  
	ТекстЗаголовка = НСтр("ru = 'Итого сформировано %1 документов ""Заявлений на предоставление вычетов ИПН"".'");
	ТекстЗаголовка = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ТекстЗаголовка, ИтогоСозданоЗаявлений);
			
	Элементы.Декорация6.Заголовок = ТекстЗаголовка;
	
КонецПроцедуры

&НаСервере
Процедура СформироватьДокументыЗаявленийЗамены(Отказ)

	Если Отказ Тогда
		Возврат;
	КонецЕсли;
	
	НаличиеОшибок = Ложь;
	СформированныеДокументы.Очистить();
	
	ДатаВводаНовыхДокументов = Объект.Период;
	ИтогоСозданоЗаявлений = 0;
	
	Для Каждого СтрокаСотрудник Из Сотрудники Цикл
		
		Если СтрокаСотрудник.Отметка Тогда
		
			НовоеЗаявление = Документы.ЗаявлениеНаПредоставлениеВычетовИПН.СоздатьДокумент();
			НовоеЗаявление.Дата = ТекущаяДата();
			НовоеЗаявление.Месяц = НачалоМесяца(ДатаВводаНовыхДокументов);
			Если ДействуетДо Тогда
				НовоеЗаявление.МесяцЗавершения = КонецГода(ДатаВводаНовыхДокументов);
			КонецЕсли;
			НовоеЗаявление.Сотрудник = СтрокаСотрудник.Сотрудник;
			НовоеЗаявление.Организация = Объект.Организация;
