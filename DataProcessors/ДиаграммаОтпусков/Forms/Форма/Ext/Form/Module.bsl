Функция ЕстьСохраненныеНастройки()
	
	УстановитьПривилегированныйРежим(Истина);
	Постфикс = "ТекущиеДанные";
	Если ЗначениеЗаполнено(КлючНазначенияИспользования) Тогда
		Постфикс = КлючНазначенияИспользования + "/" + Постфикс;
	КонецЕсли;
	Настройки = ОбщегоНазначения.ХранилищеСистемныхНастроекЗагрузить(ИмяФормы + "/" + Постфикс, "");
	
