&НаКлиенте
Процедура ПриИзмененииПериодаОтображения()
	
	ЗаполнитьЗначенияСвойств(ПериодДанных, ПериодДанных(ВариантОтображенияПериода, ДатаОтображения));
	
	Планировщик.ТекущиеПериодыОтображения[0].Начало = ПериодДанных.ДатаНачала;
	Планировщик.ТекущиеПериодыОтображения[0].Конец = ПериодДанных.ДатаОкончания;
	
	ДиаграммаГанта.ИнтервалыФона.Очистить();
	ДиаграммаГанта.УстановитьПолныйИнтервал(ПериодДанных.ДатаНачала, ПериодДанных.ДатаОкончания);
	
	УстановитьПредставлениеПериода(ЭтотОбъект);
	УстановитьЗаголовкиКнопокПериода(ЭтотОбъект);
	Если ВыделятьПраздничныеДни Тогда
		ЗаполнитьПраздничныеДни(ПраздничныеДни, ПроизводственныйКалендарь, ПериодДанных.ДатаНачала,
			ПериодДанных.ДатаОкончания);
	КонецЕсли;
	
	ПодключитьОбработчикОжидания("ОбновитьДанныеНаКлиентеОтложенно", 1, Истина);
	
КонецПроцедуры

