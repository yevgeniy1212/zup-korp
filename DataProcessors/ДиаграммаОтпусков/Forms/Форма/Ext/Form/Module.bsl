&НаСервереБезКонтекста
Функция ДанныеОтпусков(ПараметрыПланировщика, АдресДанныеОтпусков, УникальныйИдентификатор)

	ДанныеОтпусков = ПолучитьИзВременногоХранилища(АдресДанныеОтпусков);
	Если ДанныеОтпусков = Неопределено Тогда
		ДанныеОтпусков = Обработки.ДиаграммаОтпусков.ДанныеОтпусков(ПараметрыПланировщика, УникальныйИдентификатор);
	КонецЕсли;

	Возврат ДанныеОтпусков;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ТекстПериода(ДатаНачала, ДатаОкончания)
	Возврат СтрШаблон(НСтр(" ru = 'Отпуска за %1'"), ПредставлениеПериода(ДатаНачала, ДатаОкончания));
КонецФункции

&НаКлиенте
Процедура УстановитьЗаголовокОтборов()

	ПанельОтборовЗаголовок = НСтр("ru = 'Отборы'");
	КоличествоОтборов = КоличествоИспользуемыхОтборов(КомпоновщикНастроек);
	Если КоличествоОтборов > 0 Тогда
		ПанельОтборовЗаголовок = СтрШаблон("%1 (%2)", ПанельОтборовЗаголовок, Строка(КоличествоОтборов));
	КонецЕсли;
	Элементы.ОткрытьОтбор.Заголовок = ПанельОтборовЗаголовок;

КонецПроцедуры

&НаСервереБезКонтекста
Функция КоличествоИспользуемыхОтборов(КомпоновщикНастроек)

	Настройки = КомпоновщикНастроек.ПолучитьНастройки();
	КоличествоИспользуемыхЭлементовОтбора = 0;
	Для Каждого ЭлементОтбора Из Настройки.Отбор.Элементы Цикл
		Если ЭлементОтбора.Использование Тогда
			КоличествоИспользуемыхЭлементовОтбора = КоличествоИспользуемыхЭлементовОтбора + 1;
		КонецЕсли;
	КонецЦикла;
	
	Возврат КоличествоИспользуемыхЭлементовОтбора;

КонецФункции

&НаСервереБезКонтекста
Функция РезультатПоиска(Текст)

	Результат = Новый СписокЗначений;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 20
		|	Сотрудники.Ссылка КАК Значение,
		|	Сотрудники.Представление КАК Представление,
		|	Сотрудники.Код КАК ДопИнформация
		|ИЗ
		|	Справочник.Сотрудники КАК Сотрудники
		|ГДЕ
		|	Сотрудники.Наименование ПОДОБНО &Текст
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СтруктураПредприятия.Ссылка,
		|	СтруктураПредприятия.Представление,
		|	СтруктураПредприятия.Родитель.Наименование
		|ИЗ
		|	Справочник.СтруктураПредприятия КАК СтруктураПредприятия
		|ГДЕ
		|	СтруктураПредприятия.Наименование ПОДОБНО &Текст";
	
	Запрос.УстановитьПараметр("Текст", Текст + "%");
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Представление = ВыборкаДетальныеЗаписи.Представление;
		Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.ДопИнформация) Тогда
			Представление = СтрШаблон(НСтр("ru = '%1 (%2)'"), ВыборкаДетальныеЗаписи.Представление,
				ВыборкаДетальныеЗаписи.ДопИнформация);
		Иначе
			Представление = СтрШаблон(НСтр("ru = '%1'"), ВыборкаДетальныеЗаписи.Представление);
		КонецЕсли;
		Результат.Добавить(ВыборкаДетальныеЗаписи.Значение, Представление);
	КонецЦикла;
	
	Возврат Результат;

КонецФункции

&НаСервере
Процедура ИнициализироватьКомпоновщик()

	ОбъектОбработки = РеквизитФормыВЗначение("Объект");
	Схема = ОбъектОбработки.ПолучитьМакет("ИсточникОтборовСотрудников");
	АдресСхемы = ПоместитьВоВременноеХранилище(Схема, УникальныйИдентификатор);
	АдресДанныеОтпусков = ПоместитьВоВременноеХранилище(Неопределено, УникальныйИдентификатор);
	ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСхемы);
	КомпоновщикНастроек.Инициализировать(ИсточникНастроек);
	КомпоновщикНастроек.ЗагрузитьНастройки(Схема.НастройкиПоУмолчанию);

КонецПроцедуры

&НаСервереБезКонтекста
Функция ЦветаПланировщика() Экспорт

	Цвета = Новый Структура;
	Цвета.Вставить("ЦветПлана", ЦветаСтиля.ПлановыеОтпускаДиаграммыОтпусковЦвет);
	Цвета.Вставить("ЦветФакта", ЦветаСтиля.ФактическиеОтпускаДиаграммыОтпусковЦвет);
	Цвета.Вставить("ЦветЗаявки", ЦветаСтиля.ЗаявкаНаОтпускДиаграммыОтпусковЦвет);
	Цвета.Вставить("ЦветТекстаПодразделений", ЦветаСтиля.ПодразделенияДиаграммыОтпусковЦветТекста);
	Цвета.Вставить("ЦветФонаПодразделений", ЦветаСтиля.ПодразделенияДиаграммыОтпусковЦвет);
	Цвета.Вставить("ЦветФонаТекущегоСотрудника", ЦветаСтиля.ТекущийПользовательДиаграммыОтпусковЦвет);
	Цвета.Вставить("ЦветПраздничныхДней", ЦветаСтиля.ПраздничныеДниДиаграммыОтпусковЦвет);
	Цвета.Вставить("ЦветПланаПечать", ЦветаСтиля.ПлановыеОтпускаДляПечатиДиаграммыОтпусковЦвет);
	Цвета.Вставить("ЦветФактаПечать", ЦветаСтиля.ФактическиеОтпускаДляПечатиДиаграммыОтпусковЦвет);
	
	Возврат Цвета;

КонецФункции

&НаКлиенте
Процедура ОбновитьДанные(ДополнительныеПараметры = Неопределено) Экспорт
	ОбновитьДанныеНаКлиенте();
КонецПроцедуры

&НаКлиенте
Процедура УстановитьПустоеПодразделение()
	
	ПодразделениеСотрудник = ПредопределенноеЗначение("Справочник.СтруктураПредприятия.ПустаяСсылка");
	Если ЗначениеЗаполнено(ПодразделениеСотрудникСтароеЗначение) Тогда
		НачатьОбновлениеДанныхНаКлиенте();
	КонецЕсли;
	ПодразделениеСотрудникСтароеЗначение = ПодразделениеСотрудник;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПриоритетыОтпусков() Экспорт

	Приоритеты = Новый Структура;
	Приоритеты.Вставить("План", 0);
	Приоритеты.Вставить("Факт", 1);
	
	Возврат Приоритеты;

КонецФункции

&НаСервереБезКонтекста
Функция РазрешенПросмотрДанныхСотрудника(ОграниченныйДоступ, Сотрудник, ФизическоеЛицоТекущегоПользователя,
	Документ = Неопределено)
	
	Результат = Истина;
	
	Если ОграниченныйДоступ Тогда
		Если Документ <> Неопределено И ТипЗнч(Документ) <> Тип("ДокументСсылка.ЗаявкаНаОтпуск") Тогда
			Результат = Ложь;
		ИначеЕсли ПолучитьФизическоеЛицо(Сотрудник) <> ФизическоеЛицоТекущегоПользователя Тогда
			Результат = Ложь;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура УстановитьЗаголовокВидимостьКомандПроизводственногоКалендаря()
	
	Если ПроизводственныйКалендарь.Пустая() Тогда
		ПроизводственныйКалендарьТекст = НСтр("ru = '<не выбран>'");
	Иначе
		ПроизводственныйКалендарьТекст = СтрШаблон(НСтр("ru = '%1'"), Строка(ПроизводственныйКалендарь));
	КонецЕсли;
	
	Элементы.УстановитьПроизводственныйКалендарь.Заголовок = СтрШаблон(НСтр("ru = 'Производственный календарь: %1'"),
		ПроизводственныйКалендарьТекст);

	Если ВыделятьПраздничныеДни Тогда
		ЗаполнитьПраздничныеДни(ПраздничныеДни, ПроизводственныйКалендарь, ПериодДанных.ДатаНачала,
			ПериодДанных.ДатаОкончания);
	КонецЕсли;
	
	ОтобразитьПраздничныеДни();
	
КонецПроцедуры

&НаСервере
Функция ПроизводственныйКалендарьПоГрафикам(Графики)
	
	Результат = Справочники.ПроизводственныеКалендари.ПустаяСсылка();
	
	Значения = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(Графики, "ПроизводственныйКалендарь", Истина);
	ПроизводственныеКалендари = ОбщегоНазначения.ВыгрузитьКолонку(Значения, "Значение", Истина);
	
	Если ПроизводственныеКалендари.Количество() = 1 Тогда
		Результат = ПроизводственныеКалендари[0];
	ИначеЕсли ПроизводственныеКалендари.Количество() > 1 Тогда
		Значения = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(ПроизводственныеКалендари, "БазовыйКалендарь", Истина);
		БазовыеКалендари = ОбщегоНазначения.ВыгрузитьКолонку(Значения, "Значение", Истина);
		ОбщегоНазначенияКлиентСервер.УдалитьВсеВхожденияЗначенияИзМассива(БазовыеКалендари,
			Справочники.ПроизводственныеКалендари.ПустаяСсылка());
		Если БазовыеКалендари.Количество() = 1 Тогда
			Результат = БазовыеКалендари[0];
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура УстановитьПериодЭлементаПоЗначению(ЭлементПланировщика)
	
	Реквизиты = ПолучитьПериодДокумента(ЭлементПланировщика.Значение);
	ЭлементПланировщика.Начало = Реквизиты.ДатаНачала;
	ЭлементПланировщика.Конец = Реквизиты.ДатаОкончания;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьПериодДокумента(Документ)
	
	УстановитьПривилегированныйРежим(Истина);
	Возврат ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Документ, "ДатаНачала, ДатаОкончания");
	
КонецФункции

&НаСервереБезКонтекста
Функция ФизическиеЛицаСовпадают(Сотрудник, Документ)
	
	ФизическоеЛицоСотрудника = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Сотрудник, "ФизическоеЛицо");
	ФизическоеЛицоДокумента = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Документ, "ФизическоеЛицо");
	
	Возврат ФизическоеЛицоСотрудника = ФизическоеЛицоДокумента;
	
КонецФункции

#КонецОбласти
