#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Формирует печатные формы.
//
// Параметры:
//	МассивОбъектов - Массив - ссылки на объекты, которые нужно распечатать.
//	ПараметрыПечати - Структура - дополнительные настройки печати.
//	КоллекцияПечатныхФорм - ТаблицаЗначений - сформированные табличные документы (выходной параметр).
//	ОбъектыПечати - СписокЗначений - значение - ссылка на объект
//		представление - имя области, в которой был выведен объект (выходной параметр).
//	ПараметрыВывода - Структура - дополнительные параметры сформированных табличных документов (выходной параметр).
//
Процедура Печать(МассивОбъектов, ПараметрыПечати, КоллекцияПечатныхФорм, ОбъектыПечати, ПараметрыВывода) Экспорт

	ПечатнаяФорма = УправлениеПечатью.СведенияОПечатнойФорме(КоллекцияПечатныхФорм, "ДиаграммаОтпусков");
	Если ПечатнаяФорма <> Неопределено Тогда
		ПечатнаяФорма.ТабличныйДокумент = ПечатнаяФормаДиаграммыОтпусков(ПараметрыПечати.ИсходнаяДиаграмма,
			ПараметрыПечати.Заголовок);
		ПараметрыВывода.ЗаголовокФормы = ПараметрыПечати.Заголовок;
		ПараметрыВывода.Вставить("ОриентацияСтраницы", ОриентацияСтраницы.Ландшафт);
		ПечатнаяФорма.СинонимМакета = НСтр("ru = 'Диаграмма отпусков'");
		ПечатнаяФорма.ПолныйПутьКМакету = "Обработка.ДиаграммаОтпусков.ПФ_MXL_ДиаграммаОтпусков";
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Выполняет получение данных о периодах отпусков.
//
// Параметры:
//	Параметры - Структура - Набор параметров, необходимых для получения данных.
//
// Возвращаемое значение:
// - РезультатЗапроса
//
Функция ДанныеОтпусков(Параметры, ДополнительныйРезультат) Экспорт
	
	ТаблицаСотрудников = Новый ТаблицаЗначений;
	Схема = Параметры.Схема;
	НастройкиСхемыКомпоновки = Параметры.НастройкиСхемыКомпоновки;
	ЗарплатаКадрыОбщиеНаборыДанных.ЗаменитьПредставленияЗапросов(Схема.НаборыДанных, Схема);
	
	ПараметрНачалоПериода = НастройкиСхемыКомпоновки.ПараметрыДанных.Элементы.Найти("НачалоПериода");
	Если ПараметрНачалоПериода = Неопределено Тогда
		ПараметрНачалоПериода = НастройкиСхемыКомпоновки.ПараметрыДанных.Элементы.Добавить();
		ПараметрНачалоПериода.Параметр = Новый ПараметрКомпоновкиДанных("НачалоПериода");
	КонецЕсли;
	ПараметрНачалоПериода.Использование = Истина;
	ПараметрНачалоПериода.Значение = Параметры.НачалоПериода;
	
	ПараметрОкончаниеПериода = НастройкиСхемыКомпоновки.ПараметрыДанных.Элементы.Найти("ОкончаниеПериода");
	ПараметрОкончаниеПериода.Использование = Истина;
	ПараметрОкончаниеПериода.Значение = Параметры.ОкончаниеПериода;
	
	Если ТипЗнч(Параметры.ПодразделениеСотрудник) = Тип("СправочникСсылка.СтруктураПредприятия") Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(НастройкиСхемыКомпоновки.Отбор,
			"МестоВСтруктуреПредприятия", Параметры.ПодразделениеСотрудник, ВидСравненияКомпоновкиДанных.ВИерархии, ,
			ЗначениеЗаполнено(Параметры.ПодразделениеСотрудник));
	ИначеЕсли ТипЗнч(Параметры.ПодразделениеСотрудник) = Тип("СправочникСсылка.Сотрудники") Тогда
		ОбщегоНазначенияКлиентСервер.УстановитьЭлементОтбора(НастройкиСхемыКомпоновки.Отбор, "Сотрудник",
			Параметры.ПодразделениеСотрудник, ВидСравненияКомпоновкиДанных.Равно, ,
			ЗначениеЗаполнено(Параметры.ПодразделениеСотрудник));
	КонецЕсли;
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновкиДанных = КомпоновщикМакета.Выполнить(Схема, НастройкиСхемыКомпоновки, , ,
		Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновкиДанных);
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ПроцессорВывода.УстановитьОбъект(ТаблицаСотрудников);
	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
	
	ПоместитьВоВременноеХранилище(ТаблицаСотрудников.Количество(), ДополнительныйРезультат);
	
	МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	ЗарплатаКадры.СоздатьВТПоТаблицеЗначений(МенеджерВременныхТаблиц, ТаблицаСотрудников, "ВТСотрудники");
	Результат = РезультатЗапросаДанныхОтпусков(МенеджерВременныхТаблиц, Параметры);
	
	Возврат Результат;
	
КонецФункции

Функция ВидыОтпуска() Экспорт
	
	ВидыОтпуска = Новый Структура();
	ВидыОтпуска.Вставить("Отпуск", "Отпуск");
	ВидыОтпуска.Вставить("График", "График");
	ВидыОтпуска.Вставить("Заявка", "Заявка");
	ВидыОтпуска.Вставить("ЗаявкаНеСогласованная", "ЗаявкаНеСогласованная");
	
	Возврат ВидыОтпуска;
	
КонецФункции

Функция БазовыйПроизводственныйКалендарь() Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ПроизводственныеКалендари.БазовыйКалендарь
		|ИЗ
		|	Справочник.ПроизводственныеКалендари КАК ПроизводственныеКалендари
		|ГДЕ
		|	НЕ ПроизводственныеКалендари.ПометкаУдаления";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Количество() = 1 Тогда
		Результат = ВыборкаДетальныеЗаписи.БазовыйКалендарь;
	Иначе
		Результат = Справочники.ПроизводственныеКалендари.ПустаяСсылка();
	КонецЕсли;
	
	Возврат Результат;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция РезультатЗапросаДанныхОтпусков(МенеджерВременныхТаблиц, Параметры)

	Запрос = Новый Запрос;
	Запрос.МенеджерВременныхТаблиц = МенеджерВременныхТаблиц;
	ТекстЗапроса = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ПлановыеЕжегодныеОтпуска.Сотрудник КАК Сотрудник,
		|	ПлановыеЕжегодныеОтпуска.ФизическоеЛицо КАК ФизическоеЛицо,
		|	ПлановыеЕжегодныеОтпуска.ДокументПланирования КАК Документ,
		|	ВЫБОР
		|		КОГДА ПлановыеЕжегодныеОтпуска.ПеренесеннаяДатаНачала = ДАТАВРЕМЯ(1, 1, 1)
		|			ТОГДА ПлановыеЕжегодныеОтпуска.ДатаНачала
		|		ИНАЧЕ ПлановыеЕжегодныеОтпуска.ПеренесеннаяДатаНачала
		|	КОНЕЦ КАК ДатаНачала,
		|	ВЫБОР
		|		КОГДА ПлановыеЕжегодныеОтпуска.ПеренесеннаяДатаОкончания = ДАТАВРЕМЯ(1, 1, 1)
		|			ТОГДА ПлановыеЕжегодныеОтпуска.ДатаОкончания
		|		ИНАЧЕ ПлановыеЕжегодныеОтпуска.ПеренесеннаяДатаОкончания
		|	КОНЕЦ КАК ДатаОкончания,
		|	ВЫБОР
		|		КОГДА ПлановыеЕжегодныеОтпуска.ПеренесенноеКоличествоДней = 0
		|			ТОГДА ПлановыеЕжегодныеОтпуска.КоличествоДней
		|		ИНАЧЕ ПлановыеЕжегодныеОтпуска.ПеренесенноеКоличествоДней
		|	КОНЕЦ КАК КоличествоДней,
		|	&ВидОтпускаГрафик КАК ВидОтпуска,
		|	0 КАК Приоритет
		|ПОМЕСТИТЬ ВТДанныеОтпусков
		|ИЗ
		|	РегистрСведений.ПлановыеЕжегодныеОтпуска КАК ПлановыеЕжегодныеОтпуска
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСотрудники КАК Сотрудники
		|		ПО ПлановыеЕжегодныеОтпуска.Сотрудник = Сотрудники.Сотрудник
		|			И (Сотрудники.ДатаУвольнения = ДАТАВРЕМЯ(1, 1, 1)
		|				ИЛИ ВЫБОР
		|					КОГДА ПлановыеЕжегодныеОтпуска.ПеренесеннаяДатаНачала = ДАТАВРЕМЯ(1, 1, 1)
		|						ТОГДА ПлановыеЕжегодныеОтпуска.ДатаНачала
		|					ИНАЧЕ ПлановыеЕжегодныеОтпуска.ПеренесеннаяДатаНачала
		|				КОНЕЦ <= Сотрудники.ДатаУвольнения)
		|			И (&ОтображатьПлан)
		|ГДЕ
		|	ПлановыеЕжегодныеОтпуска.Запланирован
		|	И (ВЫБОР
		|				КОГДА ПлановыеЕжегодныеОтпуска.ПеренесеннаяДатаНачала = ДАТАВРЕМЯ(1, 1, 1)
		|					ТОГДА ПлановыеЕжегодныеОтпуска.ДатаНачала
		|				ИНАЧЕ ПлановыеЕжегодныеОтпуска.ПеренесеннаяДатаНачала
		|			КОНЕЦ МЕЖДУ &НачалоПериода И &ОкончаниеПериода
		|			ИЛИ ВЫБОР
		|				КОГДА ПлановыеЕжегодныеОтпуска.ПеренесеннаяДатаОкончания = ДАТАВРЕМЯ(1, 1, 1)
		|					ТОГДА ПлановыеЕжегодныеОтпуска.ДатаОкончания
		|				ИНАЧЕ ПлановыеЕжегодныеОтпуска.ПеренесеннаяДатаОкончания
		|			КОНЕЦ МЕЖДУ &НачалоПериода И &ОкончаниеПериода)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	СостоянияСотрудников.Сотрудник,
		|	Сотрудники.ФизическоеЛицо,
		|	ДанныеСостоянийСотрудников.ДокументОснование,
		|	ДанныеСостоянийСотрудников.Начало,
		|	ДанныеСостоянийСотрудников.Окончание,
		|	0,
		|	&ВидОтпускаОтпуск,
		|	1
		|ИЗ
		|	РегистрСведений.СостоянияСотрудников КАК СостоянияСотрудников
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДанныеСостоянийСотрудников КАК ДанныеСостоянийСотрудников
		|		ПО СостоянияСотрудников.Сотрудник = ДанныеСостоянийСотрудников.Сотрудник
		|			И СостоянияСотрудников.Состояние = ДанныеСостоянийСотрудников.Состояние
		|			И СостоянияСотрудников.Период <= ДанныеСостоянийСотрудников.Окончание
		|			И (СостоянияСотрудников.ДействуетДо >= ДанныеСостоянийСотрудников.Начало
		|				ИЛИ СостоянияСотрудников.ДействуетДо = ДАТАВРЕМЯ(1, 1, 1))
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСотрудники КАК Сотрудники
		|		ПО СостоянияСотрудников.Сотрудник = Сотрудники.Сотрудник
		|			И (&ОтображатьФакт)
		|ГДЕ
		|	(СостоянияСотрудников.Период МЕЖДУ &НачалоПериода И &ОкончаниеПериода
		|			ИЛИ СостоянияСотрудников.ДействуетДо МЕЖДУ &НачалоПериода И &ОкончаниеПериода)
		|	И СостоянияСотрудников.Состояние В(&Состояния)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	Сотрудники.Сотрудник,
		|	ЗаявкаНаОтпуск.ФизическоеЛицо,
		|	ЗаявкаНаОтпуск.Ссылка,
		|	ЗаявкаНаОтпуск.ДатаНачала,
		|	ЗаявкаНаОтпуск.ДатаОкончания,
		|	ЗаявкаНаОтпуск.КоличествоДней,
		|	ВЫБОР
		|		КОГДА ЗаявкаНаОтпуск.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявокСотрудников.Согласовано)
		|			ТОГДА &ВидОтпускаЗаявка
		|		ИНАЧЕ &ВидОтпускаЗаявкаНеСогласованная
		|	КОНЕЦ,
		|	1
		|ИЗ
		|	Документ.ЗаявкаНаОтпуск КАК ЗаявкаНаОтпуск
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.Отпуск КАК Отпуск
		|		ПО ЗаявкаНаОтпуск.Ссылка = Отпуск.ЗаявкаСотрудника
		|			И (Отпуск.Проведен)
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСотрудники КАК Сотрудники
		|		ПО ЗаявкаНаОтпуск.ФизическоеЛицо = Сотрудники.ФизическоеЛицо
		|			И (Сотрудники.ДатаУвольнения = ДАТАВРЕМЯ(1, 1, 1)
		|				ИЛИ Сотрудники.ДатаУвольнения >= ЗаявкаНаОтпуск.ДатаНачала)
		|			И (&ОтображатьФакт)
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОтменаЗаявкиНаОтпуск КАК ОтменаЗаявкиНаОтпуск
		|		ПО ЗаявкаНаОтпуск.Ссылка = ОтменаЗаявкиНаОтпуск.ЗаявкаСотрудника
		|			И (ОтменаЗаявкиНаОтпуск.Проведен)
		|			И (ОтменаЗаявкиНаОтпуск.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаявокСотрудников.Согласовано))
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаявкаНаОтпуск КАК ИсправляющаяЗаявкаНаОтпуск
		|		ПО ЗаявкаНаОтпуск.Ссылка = ИсправляющаяЗаявкаНаОтпуск.ИсправленныйДокумент
		|			И (ИсправляющаяЗаявкаНаОтпуск.Проведен)
		|ГДЕ
		|	ЗаявкаНаОтпуск.Проведен
		|	И Отпуск.Ссылка ЕСТЬ NULL
		|	И ОтменаЗаявкиНаОтпуск.Ссылка ЕСТЬ NULL
		|	И ИсправляющаяЗаявкаНаОтпуск.Ссылка ЕСТЬ NULL
		|	И (ЗаявкаНаОтпуск.ДатаНачала МЕЖДУ &НачалоПериода И &ОкончаниеПериода
		|			ИЛИ ЗаявкаНаОтпуск.ДатаОкончания МЕЖДУ &НачалоПериода И &ОкончаниеПериода)
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка),
		|	ЗаявкаСотрудникаОтпуск.ФизическоеЛицо,
		|	ЗаявкаСотрудникаОтпуск.Ссылка,
		|	ЗаявкаСотрудникаОтпуск.ДатаНачалаОтпуска,
		|	ЗаявкаСотрудникаОтпуск.ДатаОкончанияОтпуска,
		|	ЗаявкаСотрудникаОтпуск.КоличествоДнейОтпуска,
		|	ВЫБОР
		|		КОГДА ЗаявкаСотрудникаОтпуск.ОтпускСогласован
		|			ТОГДА &ВидОтпускаЗаявка
		|		ИНАЧЕ &ВидОтпускаЗаявкаНеСогласованная
		|	КОНЕЦ,
		|	1
		|ИЗ
		|	БизнесПроцесс.ЗаявкаСотрудникаОтпуск КАК ЗаявкаСотрудникаОтпуск
		|		ЛЕВОЕ СОЕДИНЕНИЕ БизнесПроцесс.ЗаявкаСотрудникаОтпуск.Отпуска КАК ЗаявкаСотрудникаОтпускОтпуска
		|		ПО (ЗаявкаСотрудникаОтпускОтпуска.Ссылка = ЗаявкаСотрудникаОтпуск.Ссылка)
		|			И (ЗаявкаСотрудникаОтпускОтпуска.Отпуск.Проведен)
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСотрудники КАК Сотрудники
		|		ПО ЗаявкаСотрудникаОтпуск.ФизическоеЛицо = Сотрудники.ФизическоеЛицо
		|			И (Сотрудники.ДатаУвольнения = ДАТАВРЕМЯ(1, 1, 1)
		|				ИЛИ Сотрудники.ДатаУвольнения >= ЗаявкаСотрудникаОтпуск.ДатаНачалаОтпуска)
		|			И (&ОтображатьФакт)
		|ГДЕ
		|	ЗаявкаСотрудникаОтпуск.Отпуск = НЕОПРЕДЕЛЕНО
		|	И ЗаявкаСотрудникаОтпускОтпуска.Отпуск ЕСТЬ NULL
		|	И ЗаявкаСотрудникаОтпуск.СостояниеЗаявки <> ЗНАЧЕНИЕ(Перечисление.СостоянияЗаявокКабинетСотрудника.Отказ)
		|	И (ЗаявкаСотрудникаОтпуск.ДатаНачалаОтпуска МЕЖДУ &НачалоПериода И &ОкончаниеПериода
		|			ИЛИ ЗаявкаСотрудникаОтпуск.ДатаОкончанияОтпуска МЕЖДУ &НачалоПериода И &ОкончаниеПериода)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Сотрудники.Сотрудник КАК Сотрудник,
		|	ПРЕДСТАВЛЕНИЕ(Сотрудники.Сотрудник) КАК СотрудникПредставление,
		|	Сотрудники.ФизическоеЛицо КАК ФизическоеЛицо,
		|	Сотрудники.МестоВСтруктуреПредприятияНаименование КАК МестоВСтруктуреПредприятияНаименование,
		|	Сотрудники.МестоВСтруктуреПредприятия КАК МестоВСтруктуреПредприятия,
		|	Сотрудники.ГрафикРаботы КАК ГрафикРаботы,
		|	Сотрудники.ФИОПолные КАК ФИОПолные,
		|	ДанныеОтпусков.ВидОтпуска КАК ВидОтпуска,
		|	ДанныеОтпусков.ДатаНачала КАК ДатаНачала,
		|	ДанныеОтпусков.ДатаОкончания КАК ДатаОкончания,
		|	ДанныеОтпусков.Документ КАК ДокументОснование,
		|	ПРЕДСТАВЛЕНИЕССЫЛКИ(ДанныеОтпусков.Документ) КАК ДокументОснованиеПредставление,
		|	ДанныеОтпусков.КоличествоДней КАК КоличествоДней,
		|	ДанныеОтпусков.Приоритет КАК Приоритет
		|ИЗ
		|	ВТСотрудники КАК Сотрудники
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТДанныеОтпусков КАК ДанныеОтпусков
		|		ПО (ВЫБОР
		|				КОГДА ДанныеОтпусков.Сотрудник = ЗНАЧЕНИЕ(Справочник.Сотрудники.ПустаяСсылка)
		|					ТОГДА Сотрудники.ФизическоеЛицо = ДанныеОтпусков.ФизическоеЛицо
		|				ИНАЧЕ Сотрудники.Сотрудник = ДанныеОтпусков.Сотрудник
		|			КОНЕЦ)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Сотрудники.ФИОПолные";
	
	
	СхемаЗапроса = Новый СхемаЗапроса;
	СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
	Пакет = СхемаЗапроса.ПакетЗапросов[1];
	
	ОтображатьИерархию = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Параметры, "ОтображатьИерархию", Ложь);
	
	Если ОтображатьИерархию Тогда
		ИтогПодразделение = Пакет.КонтрольныеТочкиИтогов.Добавить("МестоВСтруктуреПредприятия");
		ИтогПодразделение.ТипКонтрольнойТочки = ТипКонтрольнойТочкиСхемыЗапроса.Иерархия;
		Пакет.КонтрольныеТочкиИтогов.Добавить("ФизическоеЛицо");
	Иначе
		Пакет.Порядок.Добавить("Сотрудники.ФИОПолные");
	КонецЕсли;

	Запрос.Текст = СхемаЗапроса.ПолучитьТекстЗапроса();
	
	Состояния = Новый Массив;
	Состояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускОсновной);
	Состояния.Добавить(Перечисления.СостоянияСотрудника.ДополнительныйОтпуск);
	Состояния.Добавить(Перечисления.СостоянияСотрудника.ДополнительныйОтпускНеоплачиваемый);
	Состояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускПоБеременностиИРодам);
	Состояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускПоУходуЗаРебенком);
	Состояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускУчебныйНеоплачиваемый);
	Состояния.Добавить(Перечисления.СостоянияСотрудника.ОтпускУчебныйОплачиваемый);
	
	ВидыОтпуска = ВидыОтпуска();
	Запрос.УстановитьПараметр("НачалоПериода", Параметры.НачалоПериода);
	Запрос.УстановитьПараметр("ОкончаниеПериода", Параметры.ОкончаниеПериода);
	Запрос.УстановитьПараметр("Состояния", Состояния);
	Запрос.УстановитьПараметр("ОтображатьФакт", Параметры.ОтображатьФакт);
	Запрос.УстановитьПараметр("ОтображатьПлан", Параметры.ОтображатьПлан);
	Запрос.УстановитьПараметр("ВидОтпускаГрафик", ВидыОтпуска.График);
	Запрос.УстановитьПараметр("ВидОтпускаОтпуск", ВидыОтпуска.Отпуск);
	Запрос.УстановитьПараметр("ВидОтпускаЗаявка", ВидыОтпуска.Заявка);
	Запрос.УстановитьПараметр("ВидОтпускаЗаявкаНеСогласованная", ВидыОтпуска.ЗаявкаНеСогласованная);
	
	Если ОтображатьИерархию Тогда
		// Добавляем сортировку списка сотрудников из настроек.
		ПсевдонимыТаблиц = Новый Соответствие;
		ПсевдонимыТаблиц.Вставить("Справочник.ПодразделенияОрганизаций", "Сотрудники");
		ПсевдонимыТаблиц.Вставить("Справочник.Должности", "Сотрудники");
		ПсевдонимыТаблиц.Вставить("Справочник.Сотрудники", "Сотрудники");
		ЗарплатаКадры.ДополнитьТекстЗапросаУпорядочиваниемСотрудников(Запрос, ПсевдонимыТаблиц);
	КонецЕсли;
	
	Результат = Запрос.Выполнить();
	
	Возврат Результат;
	
КонецФункции

Функция ПечатнаяФормаДиаграммыОтпусков(ИсходнаяДиаграмма, Заголовок)
	
	ОбработкаОбъект = Обработки.ДиаграммаОтпусков.Создать();
	ОбработкаОбъект.ИсходнаяДиаграмма = ИсходнаяДиаграмма;
	ТабличныйДокумент = ОбработкаОбъект.ДиаграммаГантаДляПечати(Заголовок);
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	Возврат ТабличныйДокумент;
	
КонецФункции

#КонецОбласти

#КонецЕсли
