#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

#Область Интерфейс

// Параметры:
//  НастройкиВидеоконференции - См. ВидеоконференцииСлужебный.НовыеНастройкиВидеоконференции
// 
// Возвращаемое значение:
//  См. ВидеоконференцииСлужебный.НовыеДанныеВидеоконференции
Функция СоздатьВидеоконференцию(НастройкиВидеоконференции) Экспорт
	
	ДанныеВидеоконференции = ВидеоконференцииСлужебный.НовыеДанныеВидеоконференции();
	
	Если СистемаВзаимодействия.ИспользованиеДоступно() Тогда
		УстановитьПривилегированныйРежим(Истина);
		
		Обсуждение = СистемаВзаимодействия.СоздатьОбсуждение();
		Обсуждение.Групповое = Истина;
		Обсуждение.Заголовок = НастройкиВидеоконференции.Тема;
		
		Попытка
			Результат = ДобавитьУчастников(Обсуждение, НастройкиВидеоконференции.Участники);
			
			Обсуждение.Записать();
			
			Если Не Результат.СозданВнешнийПользователь Тогда
				// АПК:487-выкл - Действия с Системой Взаимодействия не могут выполняться в безопасном режиме
				Выполнить("СистемаВзаимодействия.ОтправитьНавигационнуюСсылкуВнешнегоДоступа(" +
						"Результат.Идентификатор, Обсуждение.Идентификатор)");
				// АПК:487-вкл.
			КонецЕсли;
		Исключение
			ЗаписьЖурналаРегистрации(
				НСтр("ru = 'Создание Обсуждения'", ОбщегоНазначения.КодОсновногоЯзыка()), 
				УровеньЖурналаРегистрации.Ошибка,,, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			ВызватьИсключение ВидеоконференцииСлужебный.ТекстИсключения(
				НСтр("ru = 'Не удалось создать Обсуждение.'"));
		КонецПопытки;
		
		РеквизитыУчетнойЗаписи = ВидеоконференцииСлужебный.РеквизитыУчетнойЗаписи(УчетнаяЗапись);
		
		Если ЗначениеЗаполнено(РеквизитыУчетнойЗаписи.ПриветственноеСообщение) Тогда
			ПриветственноеСообщение = СистемаВзаимодействия.СоздатьСообщение(Обсуждение.Идентификатор);
			ПриветственноеСообщение.Текст = Новый ФорматированнаяСтрока(РеквизитыУчетнойЗаписи.ПриветственноеСообщение);
			ПриветственноеСообщение.Записать();
		КонецЕсли;
		
		ДанныеВидеоконференции.Состояние = ВидеоконференцииКлиентСервер.СостояниеВидеоконференции().Создана;
		ДанныеВидеоконференции.Ссылка = "e1ccs/data/conv?id=" + Обсуждение.Идентификатор;
		ДанныеВидеоконференции.СсылкаКандидата =
			СсылкаДляВнешнегоПользователя(НастройкиВидеоконференции.Участники, Обсуждение);
		ДанныеВидеоконференции.СсылкаОрганизатора = ДанныеВидеоконференции.Ссылка;
		ДанныеВидеоконференции.Идентификатор = Строка(Обсуждение.Идентификатор);
		ДанныеВидеоконференции.Описание = НСтр("ru = 'Создан чат в Обсуждениях'");
		
		УстановитьПривилегированныйРежим(Ложь);
	КонецЕсли;
	
	Возврат ДанныеВидеоконференции;
	
КонецФункции

// Параметры:
//  НастройкиВидеоконференции - См. ВидеоконференцииСлужебный.НовыеНастройкиВидеоконференции
// 
// Возвращаемое значение:
//  См. ВидеоконференцииСлужебный.НовыеДанныеВидеоконференции
Функция ОбновитьВидеоконференцию(НастройкиВидеоконференции) Экспорт
	
	ДанныеВидеоконференции = ВидеоконференцииСлужебный.НовыеДанныеВидеоконференции();
	
	Если СистемаВзаимодействия.ИспользованиеДоступно() Тогда
		УстановитьПривилегированныйРежим(Истина);
		
		Обсуждение = СистемаВзаимодействия.ПолучитьОбсуждение(
			Новый ИдентификаторОбсужденияСистемыВзаимодействия(НастройкиВидеоконференции.Идентификатор));
		Обсуждение.Заголовок = НастройкиВидеоконференции.Тема;
		
		ДобавитьУчастников(Обсуждение, НастройкиВидеоконференции.Участники);
		
		Попытка
			Обсуждение.Записать();
		Исключение
			ЗаписьЖурналаРегистрации(
				НСтр("ru = 'Обновление Обсуждения'", ОбщегоНазначения.КодОсновногоЯзыка()), 
				УровеньЖурналаРегистрации.Ошибка,,, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			ВызватьИсключение ВидеоконференцииСлужебный.ТекстИсключения(
				НСтр("ru = 'Не удалось обновить Обсуждение.'"));
		КонецПопытки;
		
		УстановитьПривилегированныйРежим(Ложь);
		
		ДанныеВидеоконференции = ДанныеВидеоконференции(НастройкиВидеоконференции.Идентификатор);
		ДанныеВидеоконференции.Состояние = ВидеоконференцииКлиентСервер.СостояниеВидеоконференции().Обновлена;
		
	КонецЕсли;
	
	Возврат ДанныеВидеоконференции;
	
КонецФункции

// Параметры:
//  Идентификатор - Строка
// 
// Возвращаемое значение:
//  См. ВидеоконференцииСлужебный.НовыеДанныеВидеоконференции
Функция ДанныеВидеоконференции(Идентификатор) Экспорт
	
	ДанныеВидеоконференции = ВидеоконференцииСлужебный.НовыеДанныеВидеоконференции();
	
	УстановитьПривилегированныйРежим(Истина);
	Обсуждение =
		СистемаВзаимодействия.ПолучитьОбсуждение(Новый ИдентификаторОбсужденияСистемыВзаимодействия(Идентификатор));
	УстановитьПривилегированныйРежим(Ложь);
	
	Если Обсуждение.Участники.Количество() <> 0 Тогда
		ДанныеВидеоконференции.Состояние = ВидеоконференцииКлиентСервер.СостояниеВидеоконференции().Активна;
		ДанныеВидеоконференции.Ссылка = "e1ccs/data/conv?id=" + Идентификатор;
		ДанныеВидеоконференции.СсылкаОрганизатора = ДанныеВидеоконференции.Ссылка;
		ДанныеВидеоконференции.СсылкаКандидата =
			СсылкаДляВнешнегоПользователяПоИдентификатору(ВнешнийПользовательОбсуждения(Обсуждение), Обсуждение);
		ДанныеВидеоконференции.Идентификатор = Идентификатор;
		ДанныеВидеоконференции.Описание = НСтр("ru = 'Создан чат в Обсуждениях'");
	КонецЕсли;
	
	Возврат ДанныеВидеоконференции;
	
КонецФункции

// Параметры:
//  Идентификатор - Строка
// 
// Возвращаемое значение:
//  См. ВидеоконференцииСлужебный.НовыеДанныеВидеоконференции
Функция УдалитьВидеоконференцию(Идентификатор) Экспорт
	
	Результат = ВидеоконференцииСлужебный.НовыеДанныеВидеоконференции();
	
	Попытка
		УстановитьПривилегированныйРежим(Истина);
		Обсуждение = СистемаВзаимодействия.ПолучитьОбсуждение(
			Новый ИдентификаторОбсужденияСистемыВзаимодействия(Идентификатор));
		
		Обсуждение.Участники.Очистить();
		Обсуждение.Записать();
		УстановитьПривилегированныйРежим(Ложь);
		
		Результат.Состояние = ВидеоконференцииКлиентСервер.СостояниеВидеоконференции().Отменена;
	Исключение
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Удаление Обсуждения'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,,, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ВызватьИсключение ВидеоконференцииСлужебный.ТекстИсключения(
			НСтр("ru = 'Не удалось удалить Обсуждение.'"));
	КонецПопытки;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  Идентификатор - Строка
//  ДанныеПользователя - См. ВидеоконференцииСлужебный.НовыеДанныеПользователя
// 
// Возвращаемое значение:
//  Булево
Функция ПользовательЯвляетсяУчастником(Идентификатор, ДанныеПользователя) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Обсуждение = СистемаВзаимодействия.ПолучитьОбсуждение(
		Новый ИдентификаторОбсужденияСистемыВзаимодействия(Идентификатор));
	
	ИдентификаторПользователяСВ = ИдентификаторПользователяСистемыВзаимодействия(ДанныеПользователя);
	
	Возврат Обсуждение.Участники.Содержит(ИдентификаторПользователяСВ);
	
КонецФункции

// Параметры:
//  Идентификатор - Строка
//  ДанныеПользователя - См. ВидеоконференцииСлужебный.НовыеДанныеПользователя
Процедура ДобавитьПользователяВУчастники(Идентификатор, ДанныеПользователя) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Обсуждение = СистемаВзаимодействия.ПолучитьОбсуждение(
		Новый ИдентификаторОбсужденияСистемыВзаимодействия(Идентификатор));
	
	ИдентификаторПользователяСВ = ИдентификаторПользователяСистемыВзаимодействия(ДанныеПользователя);
	
	Обсуждение.Участники.Добавить(ИдентификаторПользователяСВ);
	
	Попытка
		Обсуждение.Записать();
	Исключение
		ЗаписьЖурналаРегистрации(
			НСтр("ru = 'Добавление пользователя в участники Обсуждения'", ОбщегоНазначения.КодОсновногоЯзыка()),
			УровеньЖурналаРегистрации.Ошибка,,, ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ВызватьИсключение ВидеоконференцииСлужебный.ТекстИсключения(
			НСтр("ru = 'Не удалось добавить пользователя в участники Обсуждения.'"));
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Параметры:
//  Обсуждение - ОбсуждениеСистемыВзаимодействия
//  Участники - ТаблицаЗначений:
// * ФИО - Строка -
// * Представление - Строка -
// * АдресЭП - Строка -
// * ИдентификаторПользователяИБ - УникальныйИдентификатор -
// 
// Возвращаемое значение:
//  Неопределено, Структура: См. ИдентификаторВнешнегоПользователяСистемыВзаимодействия -
Функция ДобавитьУчастников(Обсуждение, Участники)
	
	Результат = Неопределено;
	
	Для каждого ДанныеУчастника Из Участники Цикл
		Если ЗначениеЗаполнено(ДанныеУчастника.ИдентификаторПользователяИБ) Тогда
			Обсуждение.Участники.Добавить(
				ИдентификаторПользователяСистемыВзаимодействия(ДанныеУчастника));
		Иначе
			Результат = ИдентификаторВнешнегоПользователяСистемыВзаимодействия(ДанныеУчастника);
			
			Обсуждение.Участники.Добавить(Результат.Идентификатор);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ДанныеУчастника - Структура, СтрокаТаблицыЗначений -
// 
// Возвращаемое значение:
//  ИдентификаторПользователяСистемыВзаимодействия
Функция ИдентификаторПользователяСистемыВзаимодействия(ДанныеУчастника)
	
	ИдентификаторУчастника = Новый ИдентификаторПользователяСистемыВзаимодействия();
	
	Попытка
		ИдентификаторУчастника = 
			СистемаВзаимодействия.ПолучитьИдентификаторПользователя(ДанныеУчастника.ИдентификаторПользователяИБ);
	Исключение
		ПользовательИБ = 
			ПользователиИнформационнойБазы.НайтиПоУникальномуИдентификатору(ДанныеУчастника.ИдентификаторПользователяИБ);
		
		ПользовательСВ = СистемаВзаимодействия.СоздатьПользователя(ПользовательИБ);
		ПользовательСВ.Имя = ДанныеУчастника.Представление;
		ПользовательСВ.ПолноеИмя = ДанныеУчастника.ФИО;
		ПользовательСВ.Записать();
		
		ИдентификаторУчастника = ПользовательСВ.Идентификатор;
	КонецПопытки;
	
	Возврат ИдентификаторУчастника;
	
КонецФункции

// Параметры:
//  Обсуждение - ОбсуждениеСистемыВзаимодействия
// 
// Возвращаемое значение:
//  ИдентификаторПользователяСистемыВзаимодействия
Функция ВнешнийПользовательОбсуждения(Обсуждение)
	
	ВнешнийПользователь = Новый ИдентификаторПользователяСистемыВзаимодействия();
	
	Для Каждого Идентификатор Из Обсуждение.Участники Цикл
		ДанныеПользователя= СистемаВзаимодействия.ПолучитьПользователя(Идентификатор);
		Если ДанныеПользователя["Внешний"] Тогда
			ВнешнийПользователь = Идентификатор;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат ВнешнийПользователь;
	
КонецФункции

// Параметры:
//  ДанныеУчастника - Структура, СтрокаТаблицыЗначений -
// 
// Возвращаемое значение:
//  Структура:
// * Идентификатор - ИдентификаторПользователяСистемыВзаимодействия
// * СозданВнешнийПользователь - Булево
Функция ИдентификаторВнешнегоПользователяСистемыВзаимодействия(ДанныеУчастника)
	
	Результат = Новый Структура();
	Результат.Вставить("Идентификатор", Новый ИдентификаторПользователяСистемыВзаимодействия());
	Результат.Вставить("СозданВнешнийПользователь", Ложь);
	
	ТекстИсполняемогоКода =
	"Отбор = Новый ОтборПользователейСистемыВзаимодействия;
	|Отбор.АдресЭлектроннойПочтыДляАутентификации = ДанныеУчастника.АдресЭП;
	|
	|ВнешниеПользователиСВ = СистемаВзаимодействия.ПолучитьПользователей(Отбор);
	|
	|Если ВнешниеПользователиСВ.Количество() <> 0 Тогда
	|	Результат.Идентификатор = ВнешниеПользователиСВ[0].Идентификатор;
	|Иначе
	|	ПользовательСВ = СистемаВзаимодействия.СоздатьПользователя();
	|	ПользовательСВ.Внешний = Истина;
	|	ПользовательСВ.Имя = ДанныеУчастника.Представление;
	|	ПользовательСВ.ПолноеИмя = ДанныеУчастника.ФИО;
	|	ПользовательСВ.АдресЭлектроннойПочтыДляАутентификации = ДанныеУчастника.АдресЭП;
	|	ПользовательСВ.Записать();
	|	
	|	Результат.Идентификатор = ПользовательСВ.Идентификатор;
	|	Результат.СозданВнешнийПользователь = Истина;
	|КонецЕсли;";
	
	// АПК:487-выкл - Действия с Системой Взаимодействия не могут выполняться в безопасном режиме
	Выполнить (ТекстИсполняемогоКода);
	// АПК:487-вкл.
	
	Возврат Результат;
	
КонецФункции

Функция СсылкаДляВнешнегоПользователя(Участники, Обсуждение)
	
	Ссылка = "";
	
	Для каждого ДанныеУчастника Из Участники Цикл
		Если Не ЗначениеЗаполнено(ДанныеУчастника.ИдентификаторПользователяИБ) Тогда
			Ссылка = СсылкаДляВнешнегоПользователяПоИдентификатору(
				ИдентификаторВнешнегоПользователяСистемыВзаимодействия(ДанныеУчастника).Идентификатор, Обсуждение);
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ссылка;
	
КонецФункции

// Параметры:
//  Идентификатор - ИдентификаторПользователяСистемыВзаимодействия
//  Обсуждение - ОбсуждениеСистемыВзаимодействия
// 
// Возвращаемое значение:
//  Строка
Функция СсылкаДляВнешнегоПользователяПоИдентификатору(Идентификатор, Обсуждение)
	
	Ссылка = "";
	
	Если ЗначениеЗаполнено(Идентификатор) Тогда
		УстановитьПривилегированныйРежим(Истина);
		// АПК:487-выкл - Действия с Системой Взаимодействия не могут выполняться в безопасном режиме
		Выполнить("Ссылка = СистемаВзаимодействия.ПолучитьНавигационнуюСсылкуВнешнегоДоступа(" +
			"Идентификатор, Обсуждение.Идентификатор)");
		// АПК:487-вкл.
	КонецЕсли;
	
	Возврат Ссылка;
	
КонецФункции

#КонецОбласти

#КонецЕсли
