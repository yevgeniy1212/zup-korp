#Область СлужебныйПрограммныйИнтерфейс

Функция Сайт() Экспорт
	
	Возврат Справочники.ИсточникиИнформацииОКандидатах.HeadHunter;
	
КонецФункции

Функция НовыйМенеджер(Пользователь) Экспорт
	
	Менеджер = Создать();
	
	Менеджер.Сайт = Сайт();
	Менеджер.Пользователь = Пользователь;
	Менеджер.ДанныеСайта = ДанныеСайта();
	
	Возврат Менеджер;
	
КонецФункции

Функция ДанныеСайта() Экспорт
	
	ДанныеСайта = РекрутинговыеСайтыСлужебный.НовыеДанныеСайта();
	
	ДанныеСайта.Имя = Имя();
	ДанныеСайта.ИмяСайта = ИмяСайта();
	ДанныеСайта.Представление = Представление();
	ДанныеСайта.АдресЗапроса = АдресЗапроса();
	ДанныеСайта.ГлавнаяСтраница = ГлавнаяСтраница();
	ДанныеСайта.Логотип = Логотип();
	ДанныеСайта.ПоискОграничиваетсяТарифом = Истина;
	ДанныеСайта.ПодробностиОграниченияПоискаСсылка = "https://hh.ru/article/27029";
	ДанныеСайта.ДоступнаПовторнаяПубликацияВакансий = Ложь;
	ДанныеСайта.ТекстВопросаПоКонтактногоДоступа = ТекстВопросаПоКонтактногоДоступа();
	
	// АПК:1297-выкл Классификаторы, загруженные с сайта. Не локализуется
	ДанныеСайта.ЗаменяемыеЗначенияКлассификатора.Вставить("Удмуртская Республика", "Республика Удмуртия");
	ДанныеСайта.ЗаменяемыеЗначенияКлассификатора.Вставить("Чувашская Республика", "Чувашская республика");
	ДанныеСайта.ЗаменяемыеЗначенияКлассификатора.Вставить("Карачаево-Черкесская Республика", "Карачаево-Черкесская республика");
	ДанныеСайта.ЗаменяемыеЗначенияКлассификатора.Вставить("Балахт","Балахта");
	// АПК:1297-Вкл
	
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("professional_roles.id", "professional_roles");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("area.id", "areas");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("type.id", "vacancy_type");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("billing_type.id", "vacancy_billing_type");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("site.id", "vacancy_site");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("salary.currency", "currency");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("experience.id", "experience");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("schedule.id", "schedule");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("address.id", "addresses");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("manager.id", "managers");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("department.id", "departments");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("employment.id", "employment");
	
	ДанныеСайта.ИменаПутейКДаннымВакансии.Вакансия = "name";
	ДанныеСайта.ИменаПутейКДаннымВакансии.Адрес = "alternate_url";
	ДанныеСайта.ИменаПутейКДаннымВакансии.Идентификатор = "id";
	
	ДанныеСайта.ПоляВакансииВПрограммеИНаСайте.Наименование = "name";
	ДанныеСайта.ПоляВакансииВПрограммеИНаСайте.ПредполагаемыйДоход = "salary.to";
	ДанныеСайта.ПоляВакансииВПрограммеИНаСайте.Описание = "description";
	
	ДанныеСайта.ИменаСвойствТелефона.КодСтраны = "country";
	ДанныеСайта.ИменаСвойствТелефона.КодГорода = "city";
	ДанныеСайта.ИменаСвойствТелефона.НомерТелефона = "number";
	ДанныеСайта.ИменаСвойствТелефона.Комментарий = "comment";
	
	ДанныеСайта.ШаблоныСтраницСайта.Сайт = Сайт();
	ДанныеСайта.ШаблоныСтраницСайта.Логотип = Логотип();
	ДанныеСайта.ШаблоныСтраницСайта.ГлавнаяСтраница = ГлавнаяСтраница();
	ДанныеСайта.ШаблоныСтраницСайта.ШаблонURLРезюме = "https://*.hh.ru/resume/*";
	ДанныеСайта.ШаблоныСтраницСайта.РегулярноеВыражениеURLСайта = "https:\/\/((.*?\.hh)|(hh))\.ru\/.*"; // сайт вида http://hh.ru или http://nn.hh.ru
	ДанныеСайта.ШаблоныСтраницСайта.РегулярноеВыражениеURLРезюме = "https:\/\/((.*?\.hh)|(hh))\.ru\/resume\/.*";
	
	ИдентификаторПриложения = ЗарплатаКадрыРасширенный.ИдентификацияПриложенияДляHeadHunter();
	АдресАвторизации = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				"%1?response_type=code&client_id=%2&redirect_uri=%3",
				ИдентификаторПриложения.auth_uri,
				ИдентификаторПриложения.client_id,
				ИдентификаторПриложения.redirect_uri);
	ДанныеСайта.АдресАвторизации = АдресАвторизации;
	
	ЗаполнитьПараметрыФорм(ДанныеСайта);
	
	Возврат ДанныеСайта;
	
КонецФункции

