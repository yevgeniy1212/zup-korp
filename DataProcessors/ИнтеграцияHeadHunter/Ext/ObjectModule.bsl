
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОписаниеПеременных

Перем Соединение; // HTTPСоединение

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Параметры:
//  Код- Строка
// 
// Возвращаемое значение:
//  Структура: см. РекрутинговыеСайтыСлужебный.НовыеРеквизитыСайта
Функция Подключить(Код) Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыеРеквизитыСайта();
	
	КодАвторизации = Код;
	
	СтруктураМаркеров = СтруктураМаркеров();
	
	Если ЗначениеЗаполнено(СтруктураМаркеров.МаркерДоступа) Тогда
		Результат.Подключен = Истина;
		
		ИнформацияОПользователе = ИнформацияОПользователе();
		
		Результат.МаркерДоступа = СтруктураМаркеров.МаркерДоступа;
		Результат.МаркерОбновления = СтруктураМаркеров.МаркерОбновления;
		Результат.ДатаОкончанияДействияМаркераДоступа = СтруктураМаркеров.ДатаОкончанияДействияМаркераДоступа;
		
		Результат.ИмяПользователя = ИнформацияОПользователе.ИмяПользователя;
		Результат.ИдентификаторПользователя = ИнформацияОПользователе.ИдентификаторКомпании;
		Результат.КодАвторизации = КодАвторизации;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращаемое значение:
//  Структура: см. РекрутинговыеСайтыСлужебный.НоваяИнформацияОПользователе
Функция ИнформацияОПользователе() Экспорт
	
	ИнформацияОПользователе = РекрутинговыеСайтыСлужебный.НоваяИнформацияОПользователе();
	
	Если Не УстановитьСоединение() Тогда
		Возврат ИнформацияОПользователе;
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос("/me");
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
	
	Если РезультатЗапроса.КодСостояния = 200 Тогда
		ИнформацияОПользователеHeadHunter = ПрочитатьОтветИнформацияОПользователе(РезультатЗапроса);
	Иначе
		РекрутинговыеСайтыСлужебный.СообщитьОбОшибкеИнформацияОПользователе(Сайт, ЭтотОбъект, РезультатЗапроса);
		Возврат ИнформацияОПользователе;
	КонецЕсли;
	
	Если Не ИнформацияОПользователеHeadHunter.is_employer Тогда
		ВызватьИсключение НСтр("ru = 'Аккаунт не является аккаунтом работодателя.'");
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИнформацияОПользователеHeadHunter.employer.id) Тогда
		ИнформацияОПользователе.ИдентификаторКомпании = ИнформацияОПользователеHeadHunter.employer.id;
		ИнформацияОПользователе.ИдентификаторПользователя = ИнформацияОПользователеHeadHunter.employer.manager_id;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИнформацияОПользователеHeadHunter.personal_manager.first_name) Тогда
		ИнформацияОПользователе.ПерсональныйМенеджер.Имя = ИнформацияОПользователеHeadHunter.personal_manager.first_name;
		ИнформацияОПользователе.ПерсональныйМенеджер.Фамилия = ИнформацияОПользователеHeadHunter.personal_manager.last_name;
		ИнформацияОПользователе.ПерсональныйМенеджер.ЭлектроннаяПочта = ИнформацияОПользователеHeadHunter.personal_manager.email;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ИнформацияОПользователеHeadHunter.email) Тогда
		ИнформацияОПользователе.ИмяПользователя = ИнформацияОПользователеHeadHunter.email;
	КонецЕсли;
	
	Возврат ИнформацияОПользователе;
	
КонецФункции

// Возвращаемое значение:
//  Структура: см. РекрутинговыеСайтыСлужебный.НовыеРеквизитыСайта
Функция ПроверитьПодключение() Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыеРеквизитыСайта();
	
	РеквизитыСайта = РекрутинговыеСайтыСлужебный.РеквизитыСайта(Сайт, Пользователь);
	
	Если ЗначениеЗаполнено(РеквизитыСайта) Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, РеквизитыСайта);
		Результат.Подключен = МаркерАктивен();
	КонецЕсли;
	
	Если Результат.Подключен Тогда
		ИнформацияОПользователе = ИнформацияОПользователе();
		Результат.ИмяПользователя = ИнформацияОПользователе.ИмяПользователя;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращаемое значение:
//  Неопределено, ФиксированнаяСтруктура -
Функция ЗагрузитьКлассификаторы() Экспорт
	
	Классификаторы = КлассификаторыСайта();
	
	Если Классификаторы <> Неопределено Тогда
		Возврат Классификаторы;
	КонецЕсли;
	
	Если Не УстановитьСоединение() Тогда
		Возврат Классификаторы;
	КонецЕсли;
	
	КлассификаторыHeadHunter = ЗагрузитьОбщиеКлассификаторы();
	
	Если Не ЗначениеЗаполнено(КлассификаторыHeadHunter) Тогда
		Возврат Классификаторы;
	КонецЕсли;
	
	КлассификаторПрофессиональныхРолей = ЗагрузитьКлассификаторПрофессиональныхРолей();
	КлассификаторРегионов = ЗагрузитьКлассификаторРегионов();
	
	ИнформацияОПользователе = ИнформацияОПользователе();
	
	Если Не ЗначениеЗаполнено(ИнформацияОПользователе.ИмяПользователя) Тогда
		Возврат Классификаторы;
	КонецЕсли;
	
	ИдентификаторКомпании = ИнформацияОПользователе.ИдентификаторКомпании;
	
	Если ЗначениеЗаполнено(ИнформацияОПользователе.ИдентификаторКомпании) Тогда
		АдресаПользователя = ЗагрузитьАдресаПользователя(ИдентификаторКомпании);
		ДепартаментыПользователя = ЗагрузитьДепартаментыПользователя(ИдентификаторКомпании);
		МенеджерыПользователя = ЗагрузитьМенеджеровПользователя(ИдентификаторКомпании);
	Иначе
		РекрутинговыеСайтыСлужебный.СообщитьПользователю(
			НСтр("ru = 'Классификаторы пользователя (адреса, менеджеры, департаменты) не загружены.'"));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КлассификаторПрофессиональныхРолей) Тогда
		КлассификаторыHeadHunter.Вставить("professional_roles",
			ОбщегоНазначения.ФиксированныеДанные(КлассификаторПрофессиональныхРолей));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КлассификаторРегионов) Тогда
		КлассификаторыHeadHunter.Вставить("areas", ОбщегоНазначения.ФиксированныеДанные(КлассификаторРегионов));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(АдресаПользователя) Тогда
		НовыйМассив = Новый Массив;
		
		Для Каждого ЭлементМассива Из АдресаПользователя Цикл
			НоваяСтруктура = СтруктураДанных();
			НоваяСтруктура.id = ЭлементМассива.id;
			НоваяСтруктура.name = ?(ЗначениеЗаполнено(ЭлементМассива.city), ЭлементМассива.city, "")
				+ ?(ЗначениеЗаполнено(ЭлементМассива.street), ", ", "") + ?(ЗначениеЗаполнено(ЭлементМассива.street), ЭлементМассива.street, "")
				+ ?(ЗначениеЗаполнено(ЭлементМассива.building), ", ", "") + ?(ЗначениеЗаполнено(ЭлементМассива.building), ЭлементМассива.building, "");
				
			Если Не ЗначениеЗаполнено(НоваяСтруктура.name)
				И ЗначениеЗаполнено(ЭлементМассива.raw) Тогда
				
				НоваяСтруктура.name = ЭлементМассива.raw;
			КонецЕсли;
				
			НоваяФиксированнаяСтруктура = Новый ФиксированнаяСтруктура(НоваяСтруктура);
			НовыйМассив.Добавить(НоваяФиксированнаяСтруктура);
		КонецЦикла;
		
		КлассификаторыHeadHunter.Вставить("addresses", Новый ФиксированныйМассив(НовыйМассив));
	КонецЕсли;

	Если ЗначениеЗаполнено(МенеджерыПользователя) Тогда
		КлассификаторыHeadHunter.Вставить(
			"managers", ОбщегоНазначения.ФиксированныеДанные(МенеджерыПользователя));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ДепартаментыПользователя) Тогда
		КлассификаторыHeadHunter.Вставить(
			"departments", ОбщегоНазначения.ФиксированныеДанные(ДепартаментыПользователя.items));
	КонецЕсли;
	
	Периоды = Новый Массив;
	Периоды.Добавить(СтруктураДанных(0, НСтр("ru = 'За все время'")));
	Периоды.Добавить(СтруктураДанных(1, НСтр("ru = 'За последние 24 часа'")));
	Периоды.Добавить(СтруктураДанных(3, НСтр("ru = 'За последние 3 дня'")));
	Периоды.Добавить(СтруктураДанных(7, НСтр("ru = 'За последнюю неделю'")));
	Периоды.Добавить(СтруктураДанных(14, НСтр("ru = 'За последние 2 недели'")));
	Периоды.Добавить(СтруктураДанных(30, НСтр("ru = 'За последний 1 месяц'")));
	Периоды.Добавить(СтруктураДанных(60, НСтр("ru = 'За последние 2 месяца'")));
	
	КлассификаторыHeadHunter.Вставить("periods", ОбщегоНазначения.ФиксированныеДанные(Периоды));
	
	КлассификаторыHeadHunterФикс = ОбщегоНазначения.ФиксированныеДанные(КлассификаторыHeadHunter);
	
	ТекущиеПараметры =
		РекрутинговыеСайтыСлужебный.СоответствиеПоФиксированномуСоответствию(ПараметрыСеанса.ПараметрыКлиентаНаСервере);
	ТекущиеПараметры.Вставить("КлассификаторыHeadHunter", КлассификаторыHeadHunterФикс);
	УстановитьПривилегированныйРежим(Истина);
	ПараметрыСеанса.ПараметрыКлиентаНаСервере = Новый ФиксированноеСоответствие(ТекущиеПараметры);
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат КлассификаторыHeadHunterФикс;
	
КонецФункции

// Найти кандидатов.
// 
// Параметры:
//  ТаблицаНайденныхКандидатов - ТаблицаЗначений: см. Обработки.ПоискРезюмеВИнтернете.НайденныеКандидаты
//  СтруктураОтбора - Структура: см. РекрутинговыеСайтыСлужебный.СтруктураОтбораКандидатов
//  ПараметрыПоиска - Структура: см. РекрутинговыеСайтыСлужебный.НовыеПараметрыПоиска
Процедура НайтиКандидатов(ТаблицаНайденныхКандидатов, СтруктураОтбора, ПараметрыПоиска) Экспорт
	
	НомерСтраницы = ПараметрыПоиска.НомерСтраницы;
	ПолеСортировки = ПараметрыПоиска.ПолеСортировки;
	ВсегоКандидатов = ПараметрыПоиска.ВсегоКандидатов;
	
	СтрокаОтбора = СтрокаОтбора(СтруктураОтбора, НомерСтраницы);
	
	Если Не УстановитьСоединение() Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос("/resumes/?" + СтрокаОтбора);
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		ВызватьИсключение РекрутинговыеСайтыСлужебный.ТекстОшибкиПоискаРезюме(Сайт, ЭтотОбъект, РезультатЗапроса);
	Иначе
		РезультатПоискаРезюме = ПрочитатьРезультатПоискаКандидатов(РезультатЗапроса);
		
		Если РезультатПоискаРезюме["items"] = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		ВсегоКандидатов = РезультатПоискаРезюме["found"];
		ПараметрыПоиска.ВсегоКандидатов = Мин(Число(ВсегоКандидатов), 2000);
		
		ДозаполнитьТаблицуРезюме(ТаблицаНайденныхКандидатов, РезультатПоискаРезюме, ПолеСортировки);
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  ОбновлениеПубликации - Булево
// 
// Возвращаемое значение:
//  Массив
Функция ПоляВакансии(ОбновлениеПубликации = Ложь) Экспорт
	
	ТипЗначенияJSONСтрока = РекрутинговыеСайтыСлужебный.ТипЗначенияJSONСтрока();
	ТипЗначенияJSONНачалоМассива = РекрутинговыеСайтыСлужебный.ТипЗначенияJSONНачалоМассива();
	ТипЗначенияJSONНачалоОбъекта = РекрутинговыеСайтыСлужебный.ТипЗначенияJSONНачалоОбъекта();
	ТипЗначенияJSONЧисло = РекрутинговыеСайтыСлужебный.ТипЗначенияJSONЧисло();
	ТипЗначенияJSONБулево = РекрутинговыеСайтыСлужебный.ТипЗначенияJSONБулево();

	МассивПолей = Новый Массив;
	
	СтруктураПоля = СтруктураПоля();
	СтруктураПоля.Путь = "name";
	СтруктураПоля.ТипJSON = ТипЗначенияJSONСтрока;
	СтруктураПоля.Описание = НСтр("ru = 'Название'");
	СтруктураПоля.Обязательное = Истина;
	МассивПолей.Добавить(СтруктураПоля);
	
	СтруктураПоля = СтруктураПоля();
	СтруктураПоля.Путь = "description";
	СтруктураПоля.ТипJSON = ТипЗначенияJSONСтрока;
	СтруктураПоля.Описание = НСтр("ru = 'Описание (не менее 200 символов)'");
	СтруктураПоля.Обязательное = Истина;
	МассивПолей.Добавить(СтруктураПоля);
	
	// Ключевые навыки
	СтруктураПоля = СтруктураПоля();
	СтруктураПоля.Путь = "key_skills";
	СтруктураПоля.ТипJSON = ТипЗначенияJSONНачалоМассива;
	СтруктураПоля.Описание = НСтр("ru = 'Список ключевых навыков (не более 30)'");
	
	ПодчиненныеЭлементы = Новый Массив;
	СтруктураПоля_key_skills = СтруктураПоля();
	СтруктураПоля_key_skills.Путь = "name";
	СтруктураПоля_key_skills.ТипJSON = ТипЗначенияJSONСтрока;
	СтруктураПоля_key_skills.Описание = НСтр("ru = 'Название ключевого навыка'");
	ПодчиненныеЭлементы.Добавить(СтруктураПоля_key_skills);
	СтруктураПоля.ПодчиненныеЭлементы = ПодчиненныеЭлементы;
	МассивПолей.Добавить(СтруктураПоля);
	
	// Специализация
	СтруктураПоля = СтруктураПоля();
	СтруктураПоля.Путь = "professional_roles";
	СтруктураПоля.ТипJSON = ТипЗначенияJSONНачалоМассива;
	СтруктураПоля.Описание = НСтр("ru = 'Специализация'");
	СтруктураПоля.Обязательное = Истина;
	
	ПодчиненныеЭлементы = Новый Массив;
	СтруктураПоля_professional_roles = СтруктураПоля();
	СтруктураПоля_professional_roles.Путь = "id";
	СтруктураПоля_professional_roles.ТипJSON = ТипЗначенияJSONСтрока;
	СтруктураПоля_professional_roles.Описание = НСтр("ru = 'Профессиональная роль'");
	СтруктураПоля_professional_roles.Обязательное = Истина;
	ПодчиненныеЭлементы.Добавить(СтруктураПоля_professional_roles);
	СтруктураПоля.ПодчиненныеЭлементы = ПодчиненныеЭлементы;
	МассивПолей.Добавить(СтруктураПоля);
	
	// Регион публикации
	СтруктураПоля = СтруктураПоля();
	СтруктураПоля.Путь = "area";
	СтруктураПоля.ТипJSON = ТипЗначенияJSONНачалоОбъекта;
	СтруктураПоля.Описание = НСтр("ru = 'Регион публикации'");
	Если ОбновлениеПубликации Тогда
		СтруктураПоля.Использование = Ложь;
	КонецЕсли;
	СтруктураПоля.Обязательное = Истина;
	
	ПодчиненныеЭлементы = Новый Массив;
	СтруктураПоля_area = СтруктураПоля();
	СтруктураПоля_area.Путь = "id";
	СтруктураПоля_area.ТипJSON = ТипЗначенияJSONСтрока;
	СтруктураПоля_area.Описание = НСтр("ru = 'Регион публикации'");
	СтруктураПоля_area.Обязательное = Истина;
	ПодчиненныеЭлементы.Добавить(СтруктураПоля_area);
	СтруктураПоля.ПодчиненныеЭлементы = ПодчиненныеЭлементы;
	МассивПолей.Добавить(СтруктураПоля);
	
	// Тип вакансии
	СтруктураПоля = СтруктураПоля();
	СтруктураПоля.Путь = "type";
	СтруктураПоля.ТипJSON = ТипЗначенияJSONНачалоОбъекта;
	СтруктураПоля.Описание = НСтр("ru = 'Тип вакансии'");
	Если ОбновлениеПубликации Тогда
		СтруктураПоля.Использование = Ложь;
	КонецЕсли;
	СтруктураПоля.Обязательное = Истина;
	
	ПодчиненныеЭлементы = Новый Массив;
	СтруктураПоля_type = СтруктураПоля();
	СтруктураПоля_type.Путь = "id";
	СтруктураПоля_type.ТипJSON = ТипЗначенияJSONСтрока;
