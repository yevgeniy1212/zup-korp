Функция РезюмеСКонтактами(АдресРезюме)
	
	Результат = Неопределено;
	
	ИдентификаторРезюме = ИдентификаторРезюмеПоАдресу(АдресРезюме);
	
	Попытка
		Резюме = СтруктураРезюмеССайта(ИдентификаторРезюме);
	Исключение
		Возврат Результат;
	КонецПопытки;
	
	Если Не ЗначениеЗаполнено(Резюме) Тогда
		Возврат Результат;
	КонецЕсли;
	
	ПолнаяИнформацияДоступна = Резюме["can_view_full_info"];
	Если ПолнаяИнформацияДоступна Тогда
		Результат = Резюме;
		Возврат Результат;
	КонецЕсли;
	
	Если Резюме["actions"]["get_with_contact"] = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(МаркерДоступа) Тогда
		Возврат Результат;
	КонецЕсли;
	
	СсылкаПолученияКонтактов = Резюме["actions"]["get_with_contact"]["url"];
	СтруктураURI = ОбщегоНазначенияКлиентСервер.СтруктураURI(СсылкаПолученияКонтактов);
	
	Запрос = НовыйHTTPЗапрос("/" + СтруктураURI.ПутьНаСервере);
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
	
	Результат = ПарсерJSON(РезультатЗапроса.ТелоОтвета, Истина);

	Возврат Результат;
	
КонецФункции

Функция ЗаполнитьДеревоПрофессиональныхРолей(Дерево)
	
	Результат = Ложь;
	
	КлассификаторыHeadHunter = КлассификаторыСайта();
		
	Если КлассификаторыHeadHunter = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Категории = КлассификаторыHeadHunter.professional_roles.categories;
	
	Для Каждого Категория Из Категории Цикл
		НоваяСтрока = Дерево.Строки.Добавить();
		НоваяСтрока.Идентификатор = Категория.id;
		НоваяСтрока.Значение = Категория.name;
		
		Если ЗначениеЗаполнено(Категория.roles) И Категория.roles.Количество() > 0 Тогда
			Для Каждого Роль Из Категория.roles Цикл
				НоваяПодчиненнаяСтрока = НоваяСтрока.Строки.Добавить();
				НоваяПодчиненнаяСтрока.Идентификатор = Роль.id;
				НоваяПодчиненнаяСтрока.Значение = Роль.name;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Дерево.Строки.Сортировать("Значение", Истина);
	
	Результат = Истина;
	
	Возврат Результат;
	
КонецФункции

Функция ЗаполнитьДеревоРегионов(Дерево)
	
	Результат = Ложь;
	
	КлассификаторыHeadHunter = КлассификаторыСайта();
	
	Если КлассификаторыHeadHunter = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Страны = КлассификаторыHeadHunter.areas;
	
	Для Каждого Страна Из Страны Цикл
		
		НоваяСтрока = Дерево.Строки.Добавить();
		НоваяСтрока.Идентификатор = Страна.id;
		НоваяСтрока.Значение = Страна.name;
		
		Если Страна.areas.Количество() > 0 Тогда 
			
			Для Каждого Регион Из Страна.areas Цикл
				
				НоваяПодчиненнаяСтрока = НоваяСтрока.Строки.Добавить();
				НоваяПодчиненнаяСтрока.Идентификатор = Регион.id;
				НоваяПодчиненнаяСтрока.Значение = РекрутинговыеСайтыСлужебный.УдалитьУточнениеВСкобках(Регион.name);
				
				Если Регион.areas.Количество() > 0 Тогда
					
					Для Каждого Город Из Регион.areas Цикл
						
						НоваяПодчиненнаяСтрокаВторогоУровня = НоваяПодчиненнаяСтрока.Строки.Добавить();
						НоваяПодчиненнаяСтрокаВторогоУровня.Идентификатор = Город.id;
						НоваяПодчиненнаяСтрокаВторогоУровня.Значение = РекрутинговыеСайтыСлужебный.УдалитьУточнениеВСкобках(Город.name);
						
						Для Каждого Район Из Город.areas Цикл
							
							НоваяПодчиненнаяСтрокаТретьегоУровня = НоваяПодчиненнаяСтрокаВторогоУровня.Строки.Добавить();
							НоваяПодчиненнаяСтрокаТретьегоУровня.Идентификатор = Район.id;
							НоваяПодчиненнаяСтрокаТретьегоУровня.Значение = РекрутинговыеСайтыСлужебный.УдалитьУточнениеВСкобках(Район.name);
							
						КонецЦикла;
						
					КонецЦикла;
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЕсли;
		
	КонецЦикла;
	
	Дерево.Строки.Сортировать("Значение", Истина);
	
	Результат = Истина;
	
	Возврат Результат;
	
КонецФункции

Функция ОписаниеНеоплаченногоПИ()
	
	Возврат НСтр("ru = 'Не оплачена возможность выполнения платного метода.
				|Начиная с 16 июля 2018 года, некоторые методы API HeadHunter для работодателей стали платными.
				|Для покупки доступа к платным методам для работодателей обратитесь к своему персональному менеджеру.
				|Подробнее https://github.com/hhru/api/blob/master/docs/payable/employer_methods.md'");
	
КонецФункции

// Параметры:
//  ИдентификаторВакансии - Строка
//  СообщатьОбОшибке - Булево
// 
// Возвращаемое значение:
// - Неопределено
// - Соответствие
Функция ОписаниеПубликацииВакансии(ИдентификаторВакансии, СообщатьОбОшибке = Истина)
	
	ОписаниеПубликации = Неопределено;
	
	Если Не УстановитьСоединение() Тогда
		Возврат ОписаниеПубликации;
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос(СтрШаблон("/vacancies/%1", ИдентификаторВакансии));
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		Если СообщатьОбОшибке Тогда
			РекрутинговыеСайтыСлужебный.СообщитьОбОшибкеПолученияВакансии(Сайт, ЭтотОбъект, РезультатЗапроса);
		КонецЕсли;
	Иначе
		ОписаниеПубликации = ПрочитатьОтветОписаниеПубликацииВакансии(РезультатЗапроса);
	КонецЕсли;
	
	Возврат ОписаниеПубликации;
	
КонецФункции

// Параметры:
//  СтруктураРезюме - Структура: см. ПрочитатьОтветРезюмеССайта
// 
// Возвращаемое значение:
//  Массив из Структура: см. РекрутинговыеСайтыСлужебный.СтруктураКонтактнойИнформации
Функция КонтактнаяИнформацияРезюме(СтруктураРезюме)
	
	МассивКИ = Новый Массив();
	
	Для Каждого КонтактнаяИнформация Из ЗначениеСвойстваУзла(СтруктураРезюме, "contact") Цикл
		ОписаниеТипаКИ = ЗначениеСвойстваУзла(КонтактнаяИнформация, "type");
		Если ОписаниеТипаКИ = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		ОписаниеЗначенияКИ = ЗначениеСвойстваУзла(КонтактнаяИнформация, "value");
		Если ОписаниеЗначенияКИ = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		СтруктураКИ = РекрутинговыеСайтыСлужебный.СтруктураКонтактнойИнформации();
		Если ЗначениеСвойстваУзла(ОписаниеТипаКИ, "id") = "cell" Тогда
			СтруктураКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон;
			СтруктураКИ.Вид = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.ТелефонЛичныеДанныеКандидатов");
			СтруктураКИ.Представление = ЗначениеСвойстваУзла(ОписаниеЗначенияКИ, "formatted");
		ИначеЕсли ЗначениеСвойстваУзла(ОписаниеТипаКИ, "id") = "home" Тогда
			СтруктураКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон;
			СтруктураКИ.Вид = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.ТелефонЛичныеДанныеКандидатов");
			СтруктураКИ.Представление = ЗначениеСвойстваУзла(ОписаниеЗначенияКИ, "formatted");
		ИначеЕсли ЗначениеСвойстваУзла(ОписаниеТипаКИ, "id") = "work" Тогда
			СтруктураКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон;
			СтруктураКИ.Вид = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.ТелефонЛичныеДанныеКандидатов");
			СтруктураКИ.Представление = ЗначениеСвойстваУзла(ОписаниеЗначенияКИ, "formatted");
		ИначеЕсли ЗначениеСвойстваУзла(ОписаниеТипаКИ, "id") = "email" Тогда
			СтруктураКИ.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
			СтруктураКИ.Вид = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.EMailЛичныеДанныеКандидатов");
			СтруктураКИ.Представление = Строка(ОписаниеЗначенияКИ);
		КонецЕсли;
		МассивКИ.Добавить(СтруктураКИ);
	КонецЦикла;
	
	Если ЗначениеЗаполнено(ЗначениеСвойстваУзла(СтруктураРезюме, "area")) Тогда
		СтруктураКИ = РекрутинговыеСайтыСлужебный.СтруктураКонтактнойИнформации();
		СтруктураКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Адрес;
		СтруктураКИ.Вид = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.АдресЛичныеДанныеКандидатов");
		СтруктураКИ.Представление = ЗначениеСвойстваУзла(СтруктураРезюме, "area", "name");
		МассивКИ.Добавить(СтруктураКИ);
	КонецЕсли;
	
	Возврат МассивКИ;
	
КонецФункции

// Параметры:
//  ТаблицаНайденныхКандидатов - ТаблицаЗначений
//  РезультатПоискаРезюме - Соответствие
//  ПолеСортировки - Число
Процедура ДозаполнитьТаблицуРезюме(ТаблицаНайденныхКандидатов, РезультатПоискаРезюме, ПолеСортировки)
	
	Для Каждого Резюме Из РезультатПоискаРезюме["items"] Цикл
		
		Если Резюме = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		НоваяСтрока = ТаблицаНайденныхКандидатов.Добавить();
		ФИО = "" + ЗначениеСвойстваУзла(Резюме, "last_name") + " " + ЗначениеСвойстваУзла(Резюме, "first_name") + " " + ЗначениеСвойстваУзла(Резюме, "middle_name");
		НоваяСтрока.НазваниеРезюме = ЗначениеСвойстваУзла(Резюме, "title");
		НоваяСтрока.ФИО = ?(ЗначениеЗаполнено(ФИО), ФИО, "-");
		НоваяСтрока.Регион = ЗначениеСвойстваУзла(Резюме, "area", "name", , "-");
		НоваяСтрока.ГдеНайден = Сайт;
		НоваяСтрока.УровеньЗарплаты = "" + ЗначениеСвойстваУзла(Резюме, "salary", "amount") + " " + ЗначениеСвойстваУзла(Резюме, "salary", "currency");
		Если Не ЗначениеЗаполнено(НоваяСтрока.УровеньЗарплаты) Тогда
			НоваяСтрока.УровеньЗарплаты = "-";
		КонецЕсли;
		Возраст = ЗначениеСвойстваУзла(Резюме, "age");
		Если ЗначениеЗаполнено(Возраст) Тогда
			НоваяСтрока.Возраст = Число(Возраст);
		Иначе
			НоваяСтрока.Возраст = "-";
		КонецЕсли;
		НоваяСтрока.ИдентификаторРезюме = ЗначениеСвойстваУзла(Резюме, "id");
		Если ЗначениеЗаполнено(ЗначениеСвойстваУзла(Резюме, "created_at")) Тогда 
			НоваяСтрока.ДатаРазмещения = ДатаПоСтроке(ЗначениеСвойстваУзла(Резюме, "created_at"));
		ИначеЕсли ЗначениеЗаполнено(ЗначениеСвойстваУзла(Резюме, "updated_at")) Тогда
			НоваяСтрока.ДатаРазмещения = ДатаПоСтроке(ЗначениеСвойстваУзла(Резюме, "updated_at"));;
		КонецЕсли;
		НоваяСтрока.СсылкаНаРезюме = ЗначениеСвойстваУзла(Резюме, "alternate_url");
		МестаРаботы = ЗначениеСвойстваУзла(Резюме, "experience");
		Если ЗначениеЗаполнено(МестаРаботы) 
			И МестаРаботы.Количество() > 0 Тогда
			ПоследнееМестоРаботы = МестаРаботы[0];
			Если ПоследнееМестоРаботы = Неопределено 
				Или ПоследнееМестоРаботы = "null" Тогда
				Продолжить;
			КонецЕсли;
			
			НоваяСтрока.ПоследнееМестоРаботы = СтрШаблон(НСтр("ru = '%1, %2 с %3 по %4'"),
				ЗначениеСвойстваУзла(ПоследнееМестоРаботы, "company"),
				ЗначениеСвойстваУзла(ПоследнееМестоРаботы, "position"),
				Формат(Дата(СтрЗаменить(ЗначениеСвойстваУзла(ПоследнееМестоРаботы, "start"), "-", "")), "ДЛФ=Д"),
				?(ЗначениеЗаполнено(ЗначениеСвойстваУзла(ПоследнееМестоРаботы, "end")),
					Формат(Дата(СтрЗаменить(ЗначениеСвойстваУзла(ПоследнееМестоРаботы, "end"), "-", "")), "ДЛФ=Д"),
					НСтр("ru = 'настоящее время'")));
		КонецЕсли;
		
		Пол = Неопределено;
		Если Не ЗначениеЗаполнено(ЗначениеСвойстваУзла(Резюме, "gender")) Тогда
			Пол = "-";
		ИначеЕсли ЗначениеСвойстваУзла(Резюме, "gender", "id") = "male" Тогда
			Пол = РекрутинговыеСайтыСлужебный.МужскойПол();
		ИначеЕсли ЗначениеСвойстваУзла(Резюме, "gender", "id") = "female" Тогда
			Пол = РекрутинговыеСайтыСлужебный.ЖенскийПол();
		КонецЕсли;
		
		НоваяСтрока.Пол = Пол; 
		НоваяСтрока.ПолеСортировки = ПолеСортировки;
		
		ПолеСортировки = ПолеСортировки + 1;
		
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  Идентификатор - Строка
// 
// Возвращаемое значение:
//  СправочникСсылка.ВидыОбразованияФизическихЛиц
Функция ВидОбразованияПоИдентификатору(Идентификатор)
	
	ВидОбразования = Справочники.ВидыОбразованияФизическихЛиц.ПустаяСсылка();
	
	Если Идентификатор = "higher" Тогда
		ВидОбразования = Справочники.ВидыОбразованияФизическихЛиц.ВысшееОбразование;
	ИначеЕсли Идентификатор = "unfinished_higher" Тогда
		ВидОбразования = Справочники.ВидыОбразованияФизическихЛиц.НеполноеВысшееОбразование;
	ИначеЕсли Идентификатор = "special_secondary" Тогда
		ВидОбразования = Справочники.ВидыОбразованияФизическихЛиц.СреднееПрофессиональноеОбразование;
	ИначеЕсли Идентификатор = "secondary" Тогда
		ВидОбразования = Справочники.ВидыОбразованияФизическихЛиц.СреднееПолноеОбщееОбразование;
	ИначеЕсли Идентификатор = "bachelor" Тогда
		ВидОбразования = Справочники.ВидыОбразованияФизическихЛиц.ВысшееОбразованиеБакалавриат;
	ИначеЕсли Идентификатор = "master" Тогда
		ВидОбразования = Справочники.ВидыОбразованияФизическихЛиц.ВысшееОбразованиеСпециалитетМагистратура;
	ИначеЕсли Идентификатор = "candidate" Тогда
		ВидОбразования = Справочники.ВидыОбразованияФизическихЛиц.АспирантураОрдинатураАдъюнктура;
	ИначеЕсли Идентификатор = "doctor" Тогда
		ВидОбразования = Справочники.ВидыОбразованияФизическихЛиц.Докторантура;
	КонецЕсли;

	Возврат ВидОбразования;
	
КонецФункции

#КонецОбласти

#КонецЕсли
