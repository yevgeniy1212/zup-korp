// Параметры:
//  ТекстЗапроса - Строка
//  ШаблонОшибки - Строка
// 
// Возвращаемое значение:
//  Неопределено, Структура, Массив -
Функция СправочникHeadHunter(ТекстЗапроса, ТекстСообщенияОбОшибке)
	
	ШаблонСтрокиПараметров = "page=%1&per_page=20";
	Если СтрНайти(ТекстЗапроса, "?") > 0 Тогда
		ШаблонСтрокиПараметров = "&" + ШаблонСтрокиПараметров;
	Иначе
		ШаблонСтрокиПараметров = "?" + ШаблонСтрокиПараметров;
	КонецЕсли;
	
	Результат = Неопределено;
	
	ОбъектJSON = ОбъектJSONСправочникаHeadHunter(ТекстЗапроса + СтрШаблон(ШаблонСтрокиПараметров, 0), ТекстСообщенияОбОшибке);
	Если ОбъектJSON = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Результат = ОбъектJSON.items;
	
	Если ОбъектJSON.Свойство("pages") Тогда
		КоличествоСтраниц = ОбъектJSON.pages - 1;
		Для НомерСтраницы = 1 По КоличествоСтраниц Цикл
			ОбъектJSON = ОбъектJSONСправочникаHeadHunter(ТекстЗапроса + СтрШаблон(ШаблонСтрокиПараметров, НомерСтраницы), ТекстСообщенияОбОшибке);
			Если ОбъектJSON = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Результат, ОбъектJSON.items);
		КонецЦикла;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ТекстЗапроса - Строка
//  ШаблонОшибки - Строка
// 
// Возвращаемое значение:
// - Неопределено
// - Структура:
// * items - Структура:
// ** id - Строка
// ** manager_id - Строка
// ** first_name - Строка
// ** last_name - Строка
// ** email - Строка
// * email - Строка
// * pages - Число
Функция ОбъектJSONСправочникаHeadHunter(ТекстЗапроса, ТекстСообщенияОбОшибке)
	
	Результат = Неопределено;
	
	Запрос = НовыйHTTPЗапрос(ТекстЗапроса);
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос, Ложь);
	
	Если РезультатЗапроса.Ошибка Тогда
		РекрутинговыеСайтыСлужебный.ЗарегистрироватьОшибкуОбращенияКРекрутинговомуСайту(РезультатЗапроса.ИнформацияОбОшибке, Ложь);
		Возврат Результат;
	КонецЕсли;
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		РекрутинговыеСайтыСлужебный.СообщитьОбОшибке(ТекстСообщенияОбОшибке, Сайт, ЭтотОбъект, РезультатЗапроса);
		Возврат Результат;
	КонецЕсли;
	
	Результат = ПарсерJSON(РезультатЗапроса.ТелоОтвета);
	
	Возврат Результат;
	
КонецФункции

