// Структура резюме с сайта.
// 
// Параметры:
//  ИдентификаторРезюме - Строка
// 
// Возвращаемое значение:
//  Структура:
//  * Комментарии - См. МассивКомментариевКандидата
//  * Фото - Произвольный
Функция СтруктураРезюмеССайта(ИдентификаторРезюме)
	
	Резюме = Неопределено;
	
	Если Не УстановитьСоединение() Тогда
		Возврат Резюме;
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос("/resumes/" + ИдентификаторРезюме);
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
	
	Если РезультатЗапроса.КодСостояния = 404 Тогда
		ВызватьИсключение НСтр("ru = 'Нет доступа. Пользователь скрыл или удалил это резюме.'");
	ИначеЕсли РезультатЗапроса.КодСостояния <> 200 Тогда
		ВызватьИсключение РекрутинговыеСайтыСлужебный.ТекстОшибкиПоОписанию(Сайт, ЭтотОбъект, РезультатЗапроса);
	КонецЕсли;
	
	Резюме = ПрочитатьОтветРезюмеССайта(РезультатЗапроса);
	
	ИнформацияПользователя = ИнформацияОПользователе();
	АдресКомментариев = ЗначениеСвойстваУзла(Резюме, "owner", "comments", "url");
	КомментарииКандидата = МассивКомментариевКандидата(АдресКомментариев, ИнформацияПользователя.ИдентификаторКомпании);
	
	Резюме.Вставить("Комментарии", КомментарииКандидата);
	
	Если Не ЗначениеЗаполнено(ЗначениеСвойстваУзла(Резюме, "photo")) Тогда
		Возврат Резюме;
	КонецЕсли;
	
	АдресФото = ЗначениеСвойстваУзла(Резюме, "photo", "medium");
	Резюме.Вставить("Фото", РекрутинговыеСайтыСлужебный.КартинкаПоАдресу(АдресФото));
	
	Возврат Резюме;
	
КонецФункции

// Параметры:
//  АдресКомментариев - Строка
//  ИдентификаторКомпании - Строка
//  Кандидат - Неопределено, СправочникСсылка.Кандидаты -
// 
// Возвращаемое значение:
//  Массив из Структура - Массив комментариев кандидата
Функция МассивКомментариевКандидата(АдресКомментариев, ИдентификаторКомпании, Кандидат = Неопределено)
	
	КомментарииТаблица = КомментарииКандидата(АдресКомментариев, ИдентификаторКомпании, Кандидат);
	Возврат ОбщегоНазначения.ТаблицаЗначенийВМассив(КомментарииТаблица);
	
КонецФункции

// Параметры:
//  АдресКомментариев - Строка
//  ИдентификаторКомпании - Строка
//  Кандидат - Неопределено, СправочникСсылка.Кандидаты -
// 
// Возвращаемое значение:
//  ТаблицаЗначений: см. РекрутинговыеСайтыСлужебный.ТаблицаКомментарииКандидатов
Функция КомментарииКандидата(АдресКомментариев, ИдентификаторКомпании, Кандидат = Неопределено)
	
	Комментарии = Неопределено;
	
	Если Не УстановитьСоединение() Тогда
		Возврат Комментарии;
	КонецЕсли;
	
	ЧастиАдреса = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивСлов(АдресКомментариев);
	ИдентификаторРезюме = ЧастиАдреса[ЧастиАдреса.ВГраница()];
	
	МестоПубликации = Сайт;
	
	ТекстЗапроса = "/applicant_comments/" + ИдентификаторРезюме;
	
	Запрос = НовыйHTTPЗапрос(ТекстЗапроса);
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос, Ложь);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		РекрутинговыеСайтыСлужебный.СообщитьОбОшибке(
			НСтр("ru = 'Не удалось получить комментарии кандидата.'"), Сайт, ЭтотОбъект, РезультатЗапроса);
		Возврат Комментарии;
	ИначеЕсли РезультатЗапроса.Ошибка Тогда
		РекрутинговыеСайтыСлужебный.ЗарегистрироватьОшибкуОбращенияКРекрутинговомуСайту(РезультатЗапроса.ИнформацияОбОшибке, Ложь);
		Возврат Комментарии;
	КонецЕсли;
	
	Комментарии = РекрутинговыеСайтыСлужебный.ТаблицаКомментарииКандидатов();
	
	КоллекцияКомментариев = ПрочитатьОтветКомментарииКандидата(РезультатЗапроса);
	
	Для Каждого ОписаниеКомментария Из КоллекцияКомментариев.items Цикл
		НоваяСтрока = Комментарии.Добавить();
		НоваяСтрока.Период = ДатаПоСтроке(ОписаниеКомментария.created_at);
		Если ОписаниеКомментария.access_type.id = "owner" Тогда
			НоваяСтрока.ТолькоДляАвтора = Истина;
		КонецЕсли;
		НоваяСтрока.Идентификатор = ОписаниеКомментария.id;
		НоваяСтрока.Комментарий = ОписаниеКомментария.text;
		НоваяСтрока.Автор = ОписаниеКомментария.author.full_name;
		НоваяСтрока.ПринадлежитАвторизованномуПользователю = ОписаниеКомментария.is_mine;
		НоваяСтрока.МестоПубликации = МестоПубликации;
	КонецЦикла;
	
	Если Не РекрутинговыеСайтыСлужебный.ЕстьИзмененияКомментариев(Кандидат, МестоПубликации, Комментарии) Тогда
		Возврат Комментарии;
	КонецЕсли;
	
	ПодобратьПользователейПоАвторамКомментариев(Комментарии, ИдентификаторКомпании);
	
	Возврат Комментарии;
	
КонецФункции

// Параметры:
//  СтрокаJSON -  Строка
// 
// Возвращаемое значение:
//  Дата
Функция ДатаПоСтроке(СтрокаJSON)
	
	Возврат Дата(СтрЗаменить(Лев(СтрокаJSON, 10), "-", "") + СтрЗаменить(Сред(СтрокаJSON, 12, 8), ":", ""));
	
КонецФункции

Процедура ПодобратьПользователейПоАвторамКомментариев(Комментарии, ИдентификаторКомпании)
	
	ОтборСтрок = Новый Структура("ПринадлежитАвторизованномуПользователю", Ложь);
	
	НайденныеСтроки = Комментарии.НайтиСтроки(ОтборСтрок);
	Если НайденныеСтроки.Количество() = 0 Тогда
		// Все комментарии принадлежат текущему пользователю.
		Комментарии.ЗаполнитьЗначения(Пользователи.АвторизованныйПользователь(), "Пользователь");
		Возврат;
	КонецЕсли;
	
	АвторыКомментариев = ОбщегоНазначения.ВыгрузитьКолонку(НайденныеСтроки, "Автор", Истина);
	
	ТекстСообщения = СтрШаблон(НСтр("ru = 'Ошибка загрузки менеджеров пользователя с сайта %1.'"), Сайт);
	МенеджерыПользователя = СправочникHeadHunter("/employers/" + ИдентификаторКомпании + "/managers", ТекстСообщения);
	
	АдресаАвторов = РекрутинговыеСайтыСлужебный.НоваяТаблицаАдресаАвторов();
	Если ЗначениеЗаполнено(МенеджерыПользователя) Тогда
		Для Каждого ОписаниеМенеджера Из МенеджерыПользователя Цикл
			Если АвторыКомментариев.Найти(ОписаниеМенеджера.name) = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			НоваяСтрока = АдресаАвторов.Добавить();
			НоваяСтрока.ИмяАвтора = ОписаниеМенеджера.name;
			НоваяСтрока.АдресПочты = ОписаниеМенеджера.email;
		КонецЦикла;
	КонецЕсли;
	
	ПользователиПоАвторам = РекрутинговыеСайтыСлужебный.ПользователиПоАвторам(АдресаАвторов);
	
	Для Каждого Строка Из Комментарии Цикл
		Если Строка.ПринадлежитАвторизованномуПользователю = Истина Тогда
			Строка.Пользователь = Пользователи.АвторизованныйПользователь();
			Продолжить;
		КонецЕсли;
		ПользовательАвтор = ПользователиПоАвторам[Строка.Автор]; // СправочникСсылка.Пользователи
		Если ПользовательАвтор <> Неопределено Тогда
			Строка.Пользователь = ПользовательАвтор;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  СтруктураРезюме - Структура: см. СтруктураРезюмеССайта
// 
// Возвращаемое значение:
//  Структура: см. ПодборПерсоналаКлиентСервер.ОписаниеРезюмеКандидата
Функция ДанныеКандидатаПоРезюме(СтруктураРезюме)
	
	ДанныеКандидата = Справочники.Кандидаты.СтруктураДанныхКандидата();
	
	ДатаРождения = ЗначениеСвойстваУзла(СтруктураРезюме, "birth_date");
	ДанныеКандидата.ДатаРождения = ?(ЗначениеЗаполнено(ДатаРождения), Дата(СтрЗаменить(ДатаРождения, "-", "")), Дата(1, 1, 1));
	
	ДанныеКандидата.Гражданство.Очистить();
	Для Каждого Гражданство Из ЗначениеСвойстваУзла(СтруктураРезюме, "citizenship") Цикл
		СтруктураГражданство = Новый Структура("Страна, Дата");
		СтруктураГражданство.Страна = ЗначениеСвойстваУзла(Гражданство, "name");
		ДанныеКандидата.Гражданство.Добавить(СтруктураГражданство);
	КонецЦикла;
	
	ДанныеКандидата.КонтактнаяИнформация = КонтактнаяИнформацияРезюме(СтруктураРезюме);

	ДанныеКандидата.Образование.Очистить();
	ЗаполнитьМассивОбразование(СтруктураРезюме, ДанныеКандидата.Образование);
	
	ДанныеКандидата.ТрудоваяДеятельность.Очистить();
	Для Каждого ТрудоваяДеятельность Из ЗначениеСвойстваУзла(СтруктураРезюме, "experience") Цикл
		Если ТрудоваяДеятельность = Неопределено 
			Или ТрудоваяДеятельность = "null" Тогда
			Продолжить;
		КонецЕсли;
		СтрокаТД = РекрутинговыеСайтыСлужебный.НовыйОпытРаботы();
		СтрокаТД.Компания = ЗначениеСвойстваУзла(ТрудоваяДеятельность, "company");
		СтрокаТД.ДатаНачала = РекрутинговыеСайтыСлужебный.МесяцСтрокойВДату(ЗначениеСвойстваУзла(ТрудоваяДеятельность, "start"));
		СтрокаТД.ДатаОкончания = РекрутинговыеСайтыСлужебный.МесяцСтрокойВДату(ЗначениеСвойстваУзла(ТрудоваяДеятельность, "end"));
		СтрокаТД.Должность = ЗначениеСвойстваУзла(ТрудоваяДеятельность, "position"); 
		СтрокаТД.Обязанности = РекрутинговыеСайтыСлужебный.УдалитьЛишнееИзСтроки(ЗначениеСвойстваУзла(ТрудоваяДеятельность, "description"));
		СфераДеятельностиСтрокой = "";
		Для Каждого СфераДеятельности Из ЗначениеСвойстваУзла(ТрудоваяДеятельность, "industries") Цикл
			Если СфераДеятельности = Неопределено 
				Или СфераДеятельности = "null" Тогда
				Продолжить;
			КонецЕсли;
			Если ЗначениеЗаполнено(СфераДеятельностиСтрокой) Тогда
				СфераДеятельностиСтрокой = СфераДеятельностиСтрокой + ", ";
			КонецЕсли;
			СфераДеятельностиСтрокой = СфераДеятельностиСтрокой + ЗначениеСвойстваУзла(СфераДеятельности, "name");
		КонецЦикла;
		СтрокаТД.СфераДеятельностиКомпании = СфераДеятельностиСтрокой;
		ДанныеКандидата.ТрудоваяДеятельность.Добавить(СтрокаТД);
	КонецЦикла;
	
	ЗаполнитьДоступностьКонтактов(ДанныеКандидата.ДоступностьКонтактов, СтруктураРезюме);
	
	ДанныеКандидата.Фамилия = ЗначениеСвойстваУзла(СтруктураРезюме, "last_name");
	ДанныеКандидата.Имя = ЗначениеСвойстваУзла(СтруктураРезюме, "first_name");
	ДанныеКандидата.Отчество = ЗначениеСвойстваУзла(СтруктураРезюме, "middle_name");
	
	Если ЗначениеЗаполнено(ЗначениеСвойстваУзла(СтруктураРезюме, "gender")) Тогда
		Если ЗначениеСвойстваУзла(СтруктураРезюме, "gender", "id") = "male" Тогда
			ДанныеКандидата.Пол = РекрутинговыеСайтыСлужебный.МужскойПол();
		ИначеЕсли ЗначениеСвойстваУзла(СтруктураРезюме, "gender", "id") = "female" Тогда
			ДанныеКандидата.Пол = РекрутинговыеСайтыСлужебный.ЖенскийПол();
		КонецЕсли;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЗначениеСвойстваУзла(СтруктураРезюме, "salary")) Тогда
		ДанныеКандидата.ОжидаемыйДоход = ЗначениеСвойстваУзла(СтруктураРезюме, "salary", "amount");
		ДанныеКандидата.ВалютаДохода =
			ПодборПерсонала.ВалютаПоСправочнику(ЗначениеСвойстваУзла(СтруктураРезюме, "salary", "currency"));
	КонецЕсли;
	
	ДанныеКандидата.ЗнаниеЯзыков.Очистить();
	Для Каждого ЗнаниеЯзыка Из ЗначениеСвойстваУзла(СтруктураРезюме, "language") Цикл
		СтруктураЗнаниеЯзыков = РекрутинговыеСайтыСлужебный.НовоеЗнаниеЯзыка();
		СтруктураЗнаниеЯзыков.Язык = ЗначениеСвойстваУзла(ЗнаниеЯзыка, "name");
		СтруктураЗнаниеЯзыков.СтепеньЗнанияЯзыкаКандидата = 
			СтепеньЗнанияЯзыкаПоИдентификатору(ЗначениеСвойстваУзла(ЗнаниеЯзыка, "level", "id"));
		ДанныеКандидата.ЗнаниеЯзыков.Добавить(СтруктураЗнаниеЯзыков);
	КонецЦикла;
	
	ДанныеКандидата.ИсточникИнформации = Сайт;
	ДанныеКандидата.АдресРезюме = ЗначениеСвойстваУзла(СтруктураРезюме, "alternate_url");
	ДанныеКандидата.Фото = ЗначениеСвойстваУзла(СтруктураРезюме, "Фото");
	ДанныеКандидата.Комментарии = СтруктураРезюме["Комментарии"];
	
	СтрокаОСебе = ЗначениеСвойстваУзла(СтруктураРезюме, "skills");
	Если ЗначениеЗаполнено(СтрокаОСебе) Тогда
		РекрутинговыеСайтыСлужебный.ЗаменитьУпрСимволы(СтрокаОСебе);
		ДанныеКандидата.ОСебе = СтрокаОСебе;
	КонецЕсли;
	
	Возврат ДанныеКандидата;
	
КонецФункции

Процедура ЗаполнитьМассивОбразование(СтруктураРезюме, МассивОбразование)
	
	УровеньОбразования = ВидОбразованияПоИдентификатору(СтруктураРезюме.Получить("education").Получить("level").Получить("id"));
	УровеньДопОбразования = Справочники.ВидыОбразованияФизическихЛиц.ДополнительноеПрофессиональноеОбразование;
	ВидДополнительногоОбучения = Перечисления.ВидыПрофессиональнойПодготовки.ПовышениеКвалификации;
	
	Если УровеньОбразования = Справочники.ВидыОбразованияФизическихЛиц.СреднееПолноеОбщееОбразование Тогда
		
		Для Каждого Образование Из СтруктураРезюме.Получить("education").Получить("elementary") Цикл
			
			Если Не ЗначениеЗаполнено(Образование) Тогда
				Продолжить;
			КонецЕсли;
			
			СтруктураОбразование = Справочники.ЛичныеДанныеКандидатов.НовоеОбразованиеДляФизическогоЛица();
			СтруктураОбразование.УчебноеЗаведение = Образование.Получить("name");
			СтруктураОбразование.Окончание = Образование.Получить("year");
			СтруктураОбразование.ВидОбразования = УровеньОбразования;
			
			МассивОбразование.Добавить(СтруктураОбразование);
			
		КонецЦикла;
		
	Иначе
		
		Для Каждого Образование Из СтруктураРезюме.Получить("education").Получить("primary") Цикл
			
			СтруктураОбразование = Справочники.ЛичныеДанныеКандидатов.НовоеОбразованиеДляФизическогоЛица();
			СтруктураОбразование.УчебноеЗаведение = Образование.Получить("name");
			СтруктураОбразование.Факультет = Образование.Получить("organization");
			СтруктураОбразование.Специальность = Образование.Получить("result");
			СтруктураОбразование.Окончание = Образование.Получить("year");
			СтруктураОбразование.ВидОбразования = УровеньОбразования;
			
			МассивОбразование.Добавить(СтруктураОбразование);
			
		КонецЦикла;
		
	КонецЕсли;
	
	Для Каждого ДопОбразование Из СтруктураРезюме.Получить("education").Получить("additional") Цикл
		
		Если Не ЗначениеЗаполнено(ДопОбразование) Тогда
			Продолжить;
		КонецЕсли;
		
		СтруктураОбразование = Справочники.ЛичныеДанныеКандидатов.НовоеОбразованиеДляФизическогоЛица();
		СтруктураОбразование.УчебноеЗаведение = ДопОбразование.Получить("organization");
		СтруктураОбразование.НаименованиеКурса = ДопОбразование.Получить("name");
		СтруктураОбразование.Окончание = ДопОбразование.Получить("year");
		СтруктураОбразование.Квалификация = ДопОбразование.Получить("result");
		СтруктураОбразование.ВидОбразования = УровеньДопОбразования;
		СтруктураОбразование.ВидДополнительногоОбучения = ВидДополнительногоОбучения;
		
		МассивОбразование.Добавить(СтруктураОбразование);
		
	КонецЦикла
	
КонецПроцедуры

// Параметры:
//  Узел - Структура
//  ИмяСвойства - Строка
//  ИмяСвойстваВторогоУровня - Неопределено, Строка -
//  ИмяСвойстваТретьегоУровня - Неопределено, Строка -
//  ЗначениеПоУмолчанию - Строка
// 
// Возвращаемое значение:
//  Строка, Массив, Произвольный -
Функция ЗначениеСвойстваУзла(Узел, ИмяСвойства, ИмяСвойстваВторогоУровня = Неопределено, ИмяСвойстваТретьегоУровня = Неопределено, ЗначениеПоУмолчанию = "")
	
	Возврат РекрутинговыеСайтыСлужебный.ЗначениеСвойстваУзла(
				Узел, ИмяСвойства, ИмяСвойстваВторогоУровня, ИмяСвойстваТретьегоУровня, ЗначениеПоУмолчанию);
	
КонецФункции

Процедура ЗаполнитьДоступностьКонтактов(ДоступностьКонтактов, СтруктураРезюме)
	
	Если ЗначениеСвойстваУзла(СтруктураРезюме, "can_view_full_info") <> Ложь Тогда
		Возврат;
	КонецЕсли;

	ДоступностьКонтактов.КонтактыОткрыты = Ложь;
	Если ЗначениеСвойстваУзла(СтруктураРезюме, "actions", "get_with_contact") = Неопределено Тогда
		Возврат;
	КонецЕсли;

	ДоступностьКонтактов.КонтактыМожноОткрытьПоАдресу = ЗначениеСвойстваУзла(СтруктураРезюме, "actions", "get_with_contact", "url");
	Если ТипЗнч(ЗначениеСвойстваУзла(СтруктураРезюме, "hidden_fields",)) = Тип("Массив")
		И ЗначениеСвойстваУзла(СтруктураРезюме, "hidden_fields").Количество() > 0 Тогда
		ДоступностьКонтактов.СкрытыеКандидатомКонтакты = 
			ОбщегоНазначения.ВыгрузитьКолонку(ЗначениеСвойстваУзла(СтруктураРезюме, "hidden_fields"), "name");
	КонецЕсли;
	
КонецПроцедуры

Функция СтепеньЗнанияЯзыкаПоИдентификатору(Идентификатор)
	
	Если Идентификатор = "basic" Или СтрНайти(ВРег(Идентификатор), "A1") > 0 Тогда // базовые знания
		УровеньВладенияЯзыком = Перечисления.УровниВладенияЯзыком.A1;
	ИначеЕсли СтрНайти(ВРег(Идентификатор), "A2") > 0 Тогда
		УровеньВладенияЯзыком = Перечисления.УровниВладенияЯзыком.A1;
	ИначеЕсли Идентификатор = "can_read" Или СтрНайти(ВРег(Идентификатор), "B1") > 0 Тогда // читаю профессиональную литературу
		УровеньВладенияЯзыком = Перечисления.УровниВладенияЯзыком.B1;
	ИначеЕсли Идентификатор = "can_pass_interview" Или СтрНайти(ВРег(Идентификатор), "B2") > 0 Тогда  // могу проходить интервью
		УровеньВладенияЯзыком = Перечисления.УровниВладенияЯзыком.B2;
	ИначеЕсли Идентификатор = "fluent" Или СтрНайти(ВРег(Идентификатор), "C1") > 0 Тогда // свободно владею
		УровеньВладенияЯзыком = Перечисления.УровниВладенияЯзыком.C1;
	ИначеЕсли Идентификатор = "native" Или Идентификатор = "l1" Или СтрНайти(ВРег(Идентификатор), "C2") > 0 Тогда // родной
		УровеньВладенияЯзыком = Перечисления.УровниВладенияЯзыком.C2;
	Иначе
		УровеньВладенияЯзыком = Неопределено;
	КонецЕсли;
	
	Если УровеньВладенияЯзыком = Неопределено Тогда
		СтепеньЗнанияЯзыка = Справочники.СтепениЗнанияЯзыкаКандидата.ПустаяСсылка();
	Иначе
		СтепеньЗнанияЯзыка = Справочники.СтепениЗнанияЯзыкаКандидата.СтепеньЗнанияЯзыкаПоУровнюВладения(
			УровеньВладенияЯзыком);
	КонецЕсли;
	
	Возврат СтепеньЗнанияЯзыка;
	
КонецФункции

// Параметры:
//  СтруктураОтбора - Структура
//  НомерСтраницы - Число
// 
// Возвращаемое значение:
// Строка
Функция СтрокаОтбора(СтруктураОтбора, НомерСтраницы)
	
	СтрокаОтбора = "";
	
	Для Каждого КлючИЗначение Из СтруктураОтбора Цикл
		
		Если Не ЗначениеЗаполнено(КлючИЗначение.Значение) Тогда
			Продолжить;
		КонецЕсли;
		
		Значение = КлючИЗначение.Значение;
		
		Если ТипЗнч(Значение) = Тип("Строка") Тогда
			Значение = Значение;
		ИначеЕсли ТипЗнч(Значение) = Тип("Число") Тогда
			Значение = Формат(Значение, "ЧГ=0");
		ИначеЕсли ТипЗнч(Значение) = Тип("Дата") Тогда
			Значение = Формат(Значение, "ДЛФ=Д");
		ИначеЕсли ТипЗнч(Значение) = Тип("Булево") Тогда
			Если КлючИЗначение.Ключ = "ТолькоВНазвании" И Значение Тогда
				СтрокаОтбора = СтрокаОтбора + "text.logic=phrase&text.field=title&text.period=all_time&";
			ИначеЕсли КлючИЗначение.Ключ = "СкрыватьРезюмеБезЗарплаты" И Значение Тогда
				СтрокаОтбора = СтрокаОтбора + "label=only_with_salary&";
			КонецЕсли;
			Продолжить;
		ИначеЕсли ТипЗнч(Значение) = Тип("СписокЗначений") Тогда
			
			Для Каждого ЭлементСписка Из Значение Цикл
				Идентификатор = "";
				
				Если ТипЗнч(ЭлементСписка.Значение) = Тип("Структура") Тогда
					Если Не ЭлементСписка.Значение.Свойство("IDHeadHunter", Идентификатор) Тогда
						Продолжить;
					КонецЕсли;
				Иначе
					Идентификатор = ЭлементСписка.Значение;
				КонецЕсли;
				СтрокаОтбора = СтрокаОтбора + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("%1=%2&", СоответствиеПолейПоискаКандидатов().Получить(КлючИЗначение.Ключ), Строка(Идентификатор));
			КонецЦикла;
			
			Продолжить;
			
		КонецЕсли;
		
		СтрокаОтбора = СтрокаОтбора + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("%1=%2&", СоответствиеПолейПоискаКандидатов().Получить(КлючИЗначение.Ключ), Значение);
		
	КонецЦикла;
	
	СтрокаОтбора = СтрокаОтбора + "order_by=relevance&per_page=50&page=" + НомерСтраницы;
	
	Возврат СтрокаОтбора;
	
КонецФункции

// Параметры:
//  Дерево - ДеревоЗначений
//  Обновление - Булево
// 
// Возвращаемое значение:
//  Строка
Функция JSONОписаниеВакансии(Дерево, Обновление = Ложь)
	
	СтрокаJSON = "";
	
	СтруктураОписанияВакансии = СтруктураОписанияВакансии(Дерево, Обновление);
	СтрокаJSON = РекрутинговыеСайтыСлужебный.ЗаписьJSON(СтруктураОписанияВакансии);
	
	Возврат СтрокаJSON;
	
КонецФункции

Функция СтруктураОписанияВакансии(Дерево, Обновление = Ложь)
	
	ПоляВакансии = Новый Структура;
	ПоляСТекстомВHTML = ПоляВакансииСТекстомВHTML();
	
	Для Каждого СтрокаДерева Из Дерево.Строки Цикл
		Если ТипЗнч(СтрокаДерева.Показатель) = Тип("СправочникСсылка.Вакансии") Тогда
			Для Каждого СтрокаДереваПодчиненная Из СтрокаДерева.Строки Цикл
				Если СтрокаДереваПодчиненная.ТипРеквизита = "Строка" Тогда
					Если Обновление 
						И Не СтрокаДереваПодчиненная.СтрокаИзменена Тогда
						Продолжить;
					КонецЕсли;
					
					Если ЗначениеЗаполнено(СтрокаДереваПодчиненная.ПубликацияВакансии) Тогда
						
						Если ПоляСТекстомВHTML.Найти(СтрокаДереваПодчиненная.Путь) <> Неопределено Тогда
							ЗначениеПоля = СтрокаДереваПодчиненная.ПубликацияВакансииТекст;
						Иначе
							ЗначениеПоля = СтрокаДереваПодчиненная.ПубликацияВакансии;
						КонецЕсли;
						
						ПоляВакансии.Вставить(СтрокаДереваПодчиненная.Путь, ЗначениеПоля);
						
					КонецЕсли;
					
				ИначеЕсли СтрокаДереваПодчиненная.ТипРеквизита = "Булево" Тогда
					Если Обновление 
						И Не СтрокаДереваПодчиненная.СтрокаИзменена Тогда
						Продолжить;
					КонецЕсли;
					
					ПоляВакансии.Вставить(СтрокаДереваПодчиненная.Путь, СтрокаДереваПодчиненная.ПубликацияВакансии);
					
				ИначеЕсли СтрокаДереваПодчиненная.ТипРеквизита = РекрутинговыеСайтыСлужебный.ТипРеквизитаНачалоОбъекта() Тогда
					НомерВхожденияТочки = РекрутинговыеСайтыКлиентСервер.НайтиВСтроке(СтрокаДереваПодчиненная.Путь, ".");
					Если НомерВхожденияТочки > 0 Тогда
						Если Обновление 
							И Не СтрокаДереваПодчиненная.СтрокаИзменена Тогда
							Продолжить;
						КонецЕсли;
						
						ИмяОбъекта = Лев(СтрокаДереваПодчиненная.Путь, НомерВхожденияТочки - 1);
						РеквизитОбъекта = Сред(СтрокаДереваПодчиненная.Путь, НомерВхожденияТочки + 1, СтрДлина(СтрокаДереваПодчиненная.Путь) - НомерВхожденияТочки);
						
						СтруктураОбъекта = Новый Структура;
						Если ТипЗнч(СтрокаДереваПодчиненная.ПубликацияВакансии) = Тип("СписокЗначений") 
							И СтрокаДереваПодчиненная.ПубликацияВакансии.Количество() = 1 
							И ЗначениеЗаполнено(СтрокаДереваПодчиненная.ПубликацияВакансии[0].Значение) Тогда
							
							СтруктураОбъекта.Вставить(РеквизитОбъекта, СтрокаДереваПодчиненная.ПубликацияВакансии[0].Значение);
							ПоляВакансии.Вставить(ИмяОбъекта, СтруктураОбъекта);
						КонецЕсли;
						
					Иначе
						
						ИмяОбъекта = СтрокаДереваПодчиненная.Путь;
						
						СтруктураОбъекта = Новый Структура;
						ОбъектИзменен = Ложь;
						Для Каждого СтрокаОбъекта Из СтрокаДереваПодчиненная.Строки Цикл
							
							ОбъектИзменен = ОбъектИзменен Или СтрокаОбъекта.СтрокаИзменена;
							
							НомерВхожденияТочки = РекрутинговыеСайтыКлиентСервер.НайтиВСтроке(СтрокаОбъекта.Путь, ".");
							Если НомерВхожденияТочки > 0 Тогда
								РеквизитОбъекта = Сред(СтрокаОбъекта.Путь, НомерВхожденияТочки + 1, СтрДлина(СтрокаОбъекта.Путь) - НомерВхожденияТочки);
							Иначе	
								РеквизитОбъекта = СтрокаОбъекта.Путь;
							КонецЕсли;
							
							Если ТипЗнч(СтрокаОбъекта.ПубликацияВакансии) = Тип("СписокЗначений") Тогда 
								Если СтрокаОбъекта.ПубликацияВакансии.Количество() = 1 
									И ЗначениеЗаполнено(СтрокаОбъекта.ПубликацияВакансии[0].Значение) Тогда
									
									Если ТипЗнч(СтрокаОбъекта.ПубликацияВакансии[0].Значение) = Тип("Структура") Тогда
										ЗначениеПубликации = СтрокаОбъекта.ПубликацияВакансии[0].Значение;
										Если СтрокаОбъекта.Путь = "contacts.phones" Тогда
											ЗначениеПубликации = РекрутинговыеСайтыСлужебный.НомерТелефонаИзЦифр(ЗначениеПубликации);
										КонецЕсли;
										
										МассивОбъектов = Новый Массив;
										МассивОбъектов.Добавить(ЗначениеПубликации);
										СтруктураОбъекта.Вставить(РеквизитОбъекта, МассивОбъектов);
										
									Иначе
										СтруктураОбъекта.Вставить(РеквизитОбъекта, СтрокаОбъекта.ПубликацияВакансии[0].Значение);
									КонецЕсли;
									
								ИначеЕсли  СтрокаОбъекта.ПубликацияВакансии.Количество() > 1 Тогда
									
									МассивОбъектов = Новый Массив;
									Для Каждого ЭлементСписка Из СтрокаОбъекта.ПубликацияВакансии Цикл
										
										Если ТипЗнч(ЭлементСписка.Значение) = Тип("Структура") Тогда
											МассивОбъектов.Добавить(ЭлементСписка.Значение);
										КонецЕсли;
										
									КонецЦикла;
									
									СтруктураОбъекта.Вставить(РеквизитОбъекта, МассивОбъектов);
								КонецЕсли;
							Иначе
								СтруктураОбъекта.Вставить(РеквизитОбъекта, СтрокаОбъекта.ПубликацияВакансии);
							КонецЕсли;
							
						КонецЦикла;
						
						Если Обновление 
							И Не ОбъектИзменен Тогда
							Продолжить;
						КонецЕсли;
						
						ПоляВакансии.Вставить(ИмяОбъекта, СтруктураОбъекта);
						
					КонецЕсли;
					
				ИначеЕсли СтрокаДереваПодчиненная.ТипРеквизита = РекрутинговыеСайтыСлужебный.ТипРеквизитаНачалоМассива() Тогда
					Если Обновление
						И Не СтрокаДереваПодчиненная.СтрокаИзменена Тогда
						Продолжить;
					КонецЕсли;
					
					МассивЭлементов = Новый Массив;
					НомерВхожденияТочки = РекрутинговыеСайтыКлиентСервер.НайтиВСтроке(СтрокаДереваПодчиненная.Путь, ".");
					Если НомерВхожденияТочки > 0 Тогда
						ИмяМассива = Лев(СтрокаДереваПодчиненная.Путь, НомерВхожденияТочки - 1);
						ИмяЭлементаМассива = Сред(СтрокаДереваПодчиненная.Путь, НомерВхожденияТочки + 1, СтрДлина(СтрокаДереваПодчиненная.Путь) - НомерВхожденияТочки);
						
						Если ТипЗнч(СтрокаДереваПодчиненная.ПубликацияВакансии) = Тип("СписокЗначений") 
							И СтрокаДереваПодчиненная.ПубликацияВакансии.Количество() > 0 Тогда
							
							Для Каждого ЭлементСписка Из СтрокаДереваПодчиненная.ПубликацияВакансии Цикл
								Если ЗначениеЗаполнено(ЭлементСписка.Значение) Тогда
									СтруктураЭлементаМассива = Новый Структура;
									СтруктураЭлементаМассива.Вставить(ИмяЭлементаМассива, ЭлементСписка.Значение);
									
									МассивЭлементов.Добавить(СтруктураЭлементаМассива);
								КонецЕсли;
							КонецЦикла;
						КонецЕсли;
						
						ПоляВакансии.Вставить(ИмяМассива, МассивЭлементов);
						
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
			
			Если Не Обновление Тогда
				СтруктураИнформацииОРаботодателе = Новый Структура;
				СтруктураИнформацииОРаботодателе.Вставить("id", ИдентификаторПользователя);
				ПоляВакансии.Вставить("employer", СтруктураИнформацииОРаботодателе);
			КонецЕсли;
			
			Если Не Обновление Тогда
				СтруктураИнформацииОСайте = Новый Структура;
				СтруктураИнформацииОСайте.Вставить("id", "hh");
				ПоляВакансии.Вставить("site", СтруктураИнформацииОСайте);
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;
	
	Возврат ПоляВакансии;
	
КонецФункции

