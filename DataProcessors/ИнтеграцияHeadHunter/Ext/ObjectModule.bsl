//  КодСостояния - Число
//  ОписаниеОшибки - Строка
// 
// Возвращаемое значение:
//  Строка
Функция УточнитьОписаниеОшибки(КодСостояния, ОписаниеОшибки) Экспорт
	
	УточненноеОписаниеОшибки = "";
	
	Если СтрНайти(ОписаниеОшибки, "vacancy_not_found") <> 0 Тогда
		УточненноеОписаниеОшибки = РекрутинговыеСайтыСлужебный.ОписаниеНенайденнойВакансии();
	ИначеЕсли СтрНайти(ОписаниеОшибки, "not_enough_purchased_services") <> 0 Тогда
		УточненноеОписаниеОшибки = РекрутинговыеСайтыСлужебный.ОписаниеНеоплаченныхУслуг();
	ИначеЕсли СтрНайти(ОписаниеОшибки, "invalid_grant") <> 0 Тогда
		УточненноеОписаниеОшибки = РекрутинговыеСайтыСлужебный.ОписаниеОшибкиАвторизации();
	ИначеЕсли СтрНайти(ОписаниеОшибки, "api_access_payment") <> 0 Тогда
		УточненноеОписаниеОшибки = ОписаниеНеоплаченногоПИ();
	Иначе
		ПолноеОписание = "";
		Ошибки = Новый Массив;
		
		Попытка
			ИнформацияОбОшибках = ПрочитатьОтветСОшибкой(ОписаниеОшибки);
		Исключение
			ПолноеОписание = НСтр("ru = 'Произошла неизвестная ошибка сервера hh.ru.'");
		КонецПопытки;
		
		Если Не ЗначениеЗаполнено(ПолноеОписание) Тогда
			Если ТипЗнч(ИнформацияОбОшибках) = Тип("Структура") 
				И ИнформацияОбОшибках.Свойство("errors") 
				И ЗначениеЗаполнено(ИнформацияОбОшибках.errors) Тогда
				
				Если ТипЗнч(ИнформацияОбОшибках.errors) = Тип("Массив") Тогда
					Ошибки = ИнформацияОбОшибках.errors;
				Иначе
					Ошибки.Добавить(ИнформацияОбОшибках.errors);
				КонецЕсли;
			КонецЕсли;
			
			Для Каждого Ошибка Из Ошибки Цикл
				Если КодСостояния = 400 И Ошибка.type = "bad_json_data" Тогда
					Поле = РекрутинговыеСайтыСлужебный.ПредставлениеПоля(Сайт, ЭтотОбъект, Ошибка.value);
					ПолноеОписание = 
						ПолноеОписание
						+ ?(ЗначениеЗаполнено(ПолноеОписание), Символы.ПС, "")
						+ РекрутинговыеСайтыСлужебный.ОписаниеНезаполненногоПоля(Поле);
				ИначеЕсли Ошибка.Свойство("value") И Ошибка.value = "bad_authorization" Тогда
					ПолноеОписание = 
						ПолноеОписание
						+ ?(ЗначениеЗаполнено(ПолноеОписание), Символы.ПС, "")
						+ РекрутинговыеСайтыСлужебный.ОписаниеОшибкиАвторизации();
				ИначеЕсли Ошибка.Свойство("value") Тогда
					ПолноеОписание = ПолноеОписание + ?(ЗначениеЗаполнено(ПолноеОписание), Символы.ПС, "") + Ошибка.value;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		УточненноеОписаниеОшибки = ?(ЗначениеЗаполнено(ПолноеОписание), Символы.ПС + ПолноеОписание, ОписаниеОшибки);
	КонецЕсли;
	
	Возврат УточненноеОписаниеОшибки;
	
КонецФункции

