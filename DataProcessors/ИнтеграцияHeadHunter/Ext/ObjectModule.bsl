// Параметры:
//  АдресРезюме - Строка
// 
// Возвращаемое значение:
//  Строка
Функция ИдентификаторРезюмеПоАдресу(АдресРезюме) Экспорт
	
	ИдентификаторРезюме = АдресРезюме;
	
	Разделитель = "/";
	
	Пока РекрутинговыеСайтыКлиентСервер.НайтиВСтроке(ИдентификаторРезюме, Разделитель) > 0 Цикл
		НомерВхожденияРазделителя = 
			РекрутинговыеСайтыКлиентСервер.НайтиВСтроке(ИдентификаторРезюме, Разделитель);
		ИдентификаторРезюме = 
			Сред(ИдентификаторРезюме, 
				НомерВхожденияРазделителя + СтрДлина(Разделитель), 
				СтрДлина(ИдентификаторРезюме) - НомерВхожденияРазделителя);
	КонецЦикла;
	
	Возврат ИдентификаторРезюме;

КонецФункции

// Параметры:
//  ИдентификаторРезюме - Строка
// 
// Возвращаемое значение:
//  Структура
Функция ДанныеКандидатаПоРезюмеССайта(ИдентификаторРезюме) Экспорт
	
	ДанныеКандидата = Справочники.Кандидаты.СтруктураДанныхКандидата();
	
	СтруктураРезюме = СтруктураРезюмеССайта(ИдентификаторРезюме);
	
	Если ЗначениеЗаполнено(СтруктураРезюме) Тогда
		ДанныеКандидата = ДанныеКандидатаПоРезюме(СтруктураРезюме);
		
		ДанныеКандидата.Комментарии = ЗначениеСвойстваУзла(СтруктураРезюме, "Комментарии");
		ДанныеКандидата.ДанныеПубликации = СтруктураРезюме;
	Иначе
		ВызватьИсключение РекрутинговыеСайтыСлужебный.ТекстИсключенияПриОшибкеЗагрузкиРезюмеПоСсылке(Сайт);
	КонецЕсли;
	
	Возврат ДанныеКандидата;

КонецФункции

Функция ЭлементКлассификатора(ИмяСписка, Значение) Экспорт
	
	ЭлементКлассификатора = Неопределено;
	ИмяКлассификатора = "";
	
	ИменаСписковВыбора = РекрутинговыеСайтыСлужебный.ИменаСписковВыбора();
	Если ИмяСписка = ИменаСписковВыбора.Пол Тогда
		ИмяКлассификатора = "gender";
	ИначеЕсли ИмяСписка = ИменаСписковВыбора.УровеньОбразования Тогда
		ИмяКлассификатора = "education_level";
	ИначеЕсли ИмяСписка = ИменаСписковВыбора.ПериодРазмещения Тогда
		ИмяКлассификатора = "periods";
	Иначе
		Возврат ЭлементКлассификатора;
	КонецЕсли;
	
	Классификаторы = КлассификаторыСайта();
	
	Классификатор = Классификаторы[ИмяКлассификатора];
	
	Если Не ЗначениеЗаполнено(Классификатор) Тогда
		Возврат ЭлементКлассификатора;
	КонецЕсли;
	
	// АПК:1297-выкл Значения классификаторов, не локализуются.
	СоответствиеЗамены = Новый Соответствие;
	СоответствиеЗамены.Вставить("среднее", "среднее общее");
	СоответствиеЗамены.Вставить("среднее специальное", "среднее профессиональное");
	СоответствиеЗамены.Вставить("неоконченное высшее", "неполное высшее");
	СоответствиеЗамены.Вставить("доктор наук", "докторантура");
	СоответствиеЗамены.Вставить("кандидат наук", "аспирантура");
	// АПК:1297-вкл
	
	Найдено = Ложь;
	Для Каждого Элемент Из Классификатор Цикл
		ЗначениеСравнения = НРег(СокрЛП(Элемент.name));
		
		ЗначениеЗамены = СоответствиеЗамены.Получить(ЗначениеСравнения);
		Если ЗначениеЗаполнено(ЗначениеЗамены) Тогда
			ЗначениеСравнения = ЗначениеЗамены;
		КонецЕсли;
		
		Если ЗначениеСравнения = НРег(Значение) Тогда
			Найдено = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Найдено Тогда
		ЭлементКлассификатора = Элемент.id;
	КонецЕсли;
	
	Возврат ЭлементКлассификатора;
	
КонецФункции

Функция ПоискДоступен() Экспорт
	
	Результат = Неопределено;
	
	ИнформацияОПользователе = ИнформацияОПользователе();
	
	Если Не ЗначениеЗаполнено(ИнформацияОПользователе.ИмяПользователя) Тогда
		Возврат Результат;
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос(
		СтрШаблон("/employers/%1/managers/%2/method_access",
		ИнформацияОПользователе.ИдентификаторКомпании, ИнформацияОПользователе.ИдентификаторПользователя));
		
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос, Ложь);
	
	Если РезультатЗапроса.Ошибка Тогда
		РекрутинговыеСайтыСлужебный.ЗарегистрироватьОшибкуОбращенияКРекрутинговомуСайту(РезультатЗапроса.ИнформацияОбОшибке);
		Возврат Результат;
	КонецЕсли;
	
	ПлатныеМетоды = ПрочитатьОтветПлатныеМетоды(РезультатЗапроса);
	
	Для Каждого Метод Из ПлатныеМетоды.items Цикл
		Если Метод.id = "2" Тогда
			Результат = Метод.access.has_access;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

Функция ВакансииССайта(БылиОшибки = Ложь) Экспорт
	
	ВакансииССайта = Новый Массив;
	
	Если Не УстановитьСоединение() Тогда
		БылиОшибки = Истина;
		Возврат ВакансииССайта;
	КонецЕсли;
	
	ИнформацияОПользователе = ИнформацияОПользователе();
	
	ИдентификаторКомпании = ИнформацияОПользователе.ИдентификаторКомпании;
	ИдентификаторПользователя = ИнформацияОПользователе.ИдентификаторПользователя;
	
	Если Не ЗначениеЗаполнено(ИдентификаторКомпании) Или Не ЗначениеЗаполнено(ИдентификаторПользователя) Тогда
		БылиОшибки = Истина;
		Возврат ВакансииССайта;
	КонецЕсли;
	
	ЗагрузитьКлассификаторы();
	
	Запрос = НовыйHTTPЗапрос("/employers/" + ИдентификаторКомпании + "/vacancies/active?per_page=50&page=0&manager_id=" + ИдентификаторПользователя);
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		БылиОшибки = Истина;
		РекрутинговыеСайтыСлужебный.СообщитьОбОшибкеПолученияВакансий(Сайт, ЭтотОбъект, РезультатЗапроса);
	Иначе
		СчитанныеДанные = ПрочитатьОтветВакансииССайта(РезультатЗапроса);
		КоличествоВакансий = ЗначениеСвойстваУзла(СчитанныеДанные, "found");
		Если КоличествоВакансий <> Неопределено И КоличествоВакансий > 0 Тогда
			Вакансии = ЗначениеСвойстваУзла(СчитанныеДанные, "items");
			Для Каждого Вакансия Из Вакансии Цикл
				Описание = ОписаниеПубликацииВакансии(Формат(ЗначениеСвойстваУзла(Вакансия, "id"), "ЧГ=0"));
				Если ЗначениеЗаполнено(Описание) Тогда
					ВакансииССайта.Добавить(Описание);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Возврат ВакансииССайта;
	
КонецФункции

// Параметры:
//  Вакансия - См. ОписаниеПубликацииВакансии
//  Реквизит - Строка
// 
// Возвращаемое значение:
//  Произвольный
Функция ЗначениеРеквизитаПубликацииПоУмолчанию(Вакансия, Реквизит) Экспорт
	
	Результат = Неопределено;
	
	Если Реквизит = "Наименование" Тогда
		Результат = ?(ЗначениеЗаполнено(ЗначениеСвойстваУзла(Вакансия, "name")), ЗначениеСвойстваУзла(Вакансия, "name"), "");
	ИначеЕсли Реквизит = "ПредполагаемыйДоход" Тогда
		Результат = ?(ЗначениеЗаполнено(ЗначениеСвойстваУзла(Вакансия, "salary", "to")), ЗначениеСвойстваУзла(Вакансия, "salary", "to"), 0);
	ИначеЕсли Реквизит = "ДатаОткрытия" Тогда
		Результат = РекрутинговыеСайтыСлужебный.СтрокаВДату(ЗначениеСвойстваУзла(Вакансия, "created_at"));
	ИначеЕсли Реквизит = "ПланируемаяДатаЗакрытия" Тогда
		Результат = ДобавитьМесяц(РекрутинговыеСайтыСлужебный.СтрокаВДату(ЗначениеСвойстваУзла(Вакансия, "created_at")), 1);
	ИначеЕсли Реквизит = "Требования" Тогда
		Результат = РекрутинговыеСайтыСлужебный.ОписаниеТребованийОбязанностейУсловий(
			ЗначениеСвойстваУзла(Вакансия, "description")).Требования;
	ИначеЕсли Реквизит = "Обязанности" Тогда
		Результат = РекрутинговыеСайтыСлужебный.ОписаниеТребованийОбязанностейУсловий(
			ЗначениеСвойстваУзла(Вакансия, "description")).Обязанности;
	ИначеЕсли Реквизит = "Условия" Тогда
		Результат = РекрутинговыеСайтыСлужебный.ОписаниеТребованийОбязанностейУсловий(
			ЗначениеСвойстваУзла(Вакансия, "description")).Условия;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ЗаполнитьДеревоВакансии(Вакансия, Дерево, СтруктураВакансииССайта) Экспорт
	
	НоваяСтрока = Дерево.Строки.Добавить();
	НоваяСтрока.Показатель = Вакансия;
	
	Если ЗначениеЗаполнено(ЗначениеСвойстваУзла(СтруктураВакансииССайта, "address")) Тогда 
		
		НовоеПоле = НоваяСтрока.Строки.Добавить();
		НовоеПоле.Путь = "address.id";
		СписокАдрес = Новый СписокЗначений;
		ПредставлениеАдреса = "";
		СправочникАдресов = КлассификаторыСайта().addresses;
		Для Каждого ЭлементСправочникаАдресов Из СправочникАдресов Цикл
			Если ЭлементСправочникаАдресов.id = ЗначениеСвойстваУзла(СтруктураВакансииССайта, "address", "id") Тогда
				ПредставлениеАдреса = ЭлементСправочникаАдресов.name;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		СписокАдрес.Добавить(ЗначениеСвойстваУзла(СтруктураВакансииССайта, "address", "id"), ПредставлениеАдреса);
		НовоеПоле.ПубликацияВакансии = СписокАдрес;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЗначениеСвойстваУзла(СтруктураВакансииССайта, "area")) Тогда
		
		СписокРегион = Новый СписокЗначений;
		СписокРегион.Добавить(ЗначениеСвойстваУзла(СтруктураВакансииССайта, "area", "id"), ЗначениеСвойстваУзла(СтруктураВакансииССайта, "area", "name"));
		
		НовоеПоле = НоваяСтрока.Строки.Добавить();
		НовоеПоле.Путь = "area.id";
		НовоеПоле.ПубликацияВакансии = СписокРегион;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЗначениеСвойстваУзла(СтруктураВакансииССайта, "description")) Тогда
		
		Описание = ЗначениеСвойстваУзла(СтруктураВакансииССайта, "description");
		Описание = СтрЗаменить(Описание, "</ul> <strong>", "</ul><br /> <strong>");
		Описание = СтрЗаменить(Описание, "</li> <li>", "</li><li>");
		Описание = СтрЗаменить(Описание, "</li> </ul>", "</li></ul>");
		
		НовоеПоле = НоваяСтрока.Строки.Добавить();
		НовоеПоле.Путь = "description";
		НовоеПоле.ПубликацияВакансии = Описание;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЗначениеСвойстваУзла(СтруктураВакансииССайта, "name")) Тогда
		
		НовоеПоле = НоваяСтрока.Строки.Добавить();
		НовоеПоле.Путь = "name";
		НовоеПоле.ПубликацияВакансии = ЗначениеСвойстваУзла(СтруктураВакансииССайта, "name");
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЗначениеСвойстваУзла(СтруктураВакансииССайта, "response_letter_required")) Тогда
		
		НовоеПоле = НоваяСтрока.Строки.Добавить();
		НовоеПоле.Путь = "response_letter_required";
		НовоеПоле.ПубликацияВакансии = ЗначениеСвойстваУзла(СтруктураВакансииССайта, "response_letter_required") = "true"
			Или ЗначениеСвойстваУзла(СтруктураВакансииССайта, "response_letter_required") = Истина;
		
	КонецЕсли;
		
	Если ЗначениеЗаполнено(ЗначениеСвойстваУзла(СтруктураВакансииССайта, "salary")) Тогда
		
		НовоеПоле = НоваяСтрока.Строки.Добавить();
		НовоеПоле.Путь = "salary.to";
		НовоеПоле.ПубликацияВакансии = ЗначениеСвойстваУзла(СтруктураВакансииССайта, "salary", "to");
		
		НовоеПоле = НоваяСтрока.Строки.Добавить();
		НовоеПоле.Путь = "salary.from";
		НовоеПоле.ПубликацияВакансии = ЗначениеСвойстваУзла(СтруктураВакансииССайта, "salary", "from");
		
		НовоеПоле = НоваяСтрока.Строки.Добавить();
		НовоеПоле.Путь = "salary.currency";
		СписокВалюта = Новый СписокЗначений;
		ПредставлениеВалюты = "";
		СправочникВалют = КлассификаторыСайта().currency;
		Для Каждого ЭлементСправочникаВалют Из СправочникВалют Цикл
			Если ЭлементСправочникаВалют.code = ЗначениеСвойстваУзла(СтруктураВакансииССайта, "salary", "currency") Тогда
				ПредставлениеВалюты = ЭлементСправочникаВалют.abbr;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		СписокВалюта.Добавить(ЗначениеСвойстваУзла(СтруктураВакансииССайта, "salary", "currency"), ПредставлениеВалюты);
		НовоеПоле.ПубликацияВакансии = СписокВалюта;
		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ЗначениеСвойстваУзла(СтруктураВакансииССайта, "type")) Тогда
		
		НовоеПоле = НоваяСтрока.Строки.Добавить();
		НовоеПоле.Путь = "type.id";
		СписокТип = Новый СписокЗначений;
		СписокТип.Добавить(ЗначениеСвойстваУзла(СтруктураВакансииССайта, "type", "id"), ЗначениеСвойстваУзла(СтруктураВакансииССайта, "type", "name"));
		НовоеПоле.ПубликацияВакансии = СписокТип;
		
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  ОбновлениеПубликации - Булево
// 
// Возвращаемое значение:
//  Структура: См. РекрутинговыеСайтыСлужебный.НовыеВидыПолей
Функция ВидыПолей(ОбновлениеПубликации) Экспорт
	
	ВидыПолей = РекрутинговыеСайтыСлужебный.НовыеВидыПолей();
	
	ВидыПолей.СОдиночнымВыборомИзДерева = ПоляВакансииСОдиночнымВыборомИзДерева();
	ВидыПолей.СОдиночнымВыборомИзСписка = ПоляВакансииСОдиночнымВыборомИзСписка();
	ВидыПолей.НедоступныеДляРедактирования = ПоляВакансииНедоступныеДляРедактирования();
	ВидыПолей.СоСпискомБезКлассификатора = ПоляВакансииСоСпискомБезКлассификатора();
	ВидыПолей.СоСпециальнойФормойРедактированияСписка = ПоляВакансииСоСпециальнойФормойРедактированияСписка();
	ВидыПолей.СТекстомВHTML = ПоляВакансииСТекстомВHTML();
	
	Возврат ВидыПолей;
	
КонецФункции

// Параметры:
//  Путь - Строка
// 
// Возвращаемое значение:
//  СписокЗначений
Функция СписокВыбораПоКлассификатору(Путь) Экспорт
	
	СписокВыбора = Новый СписокЗначений;
	
	Если Не ЗначениеЗаполнено(Путь) Тогда
		Возврат СписокВыбора;
	КонецЕсли;
	
	КлассификаторыHeadHunter = КлассификаторыСайта();
	Если КлассификаторыHeadHunter = Неопределено Или Не КлассификаторыHeadHunter.Свойство(Путь) Тогда
		Возврат СписокВыбора;
	КонецЕсли;
	
	МассивДанных = КлассификаторыHeadHunter[Путь]; // Массив
	Если Путь = "currency" Тогда
		Для Каждого ЭлементМассива Из МассивДанных Цикл
			Если Не ЭлементМассива.in_use Тогда
				Продолжить;
			КонецЕсли;
			СписокВыбора.Добавить(ЭлементМассива.code, ЭлементМассива.abbr);
		КонецЦикла;
	Иначе
		Для Каждого ЭлементМассива Из МассивДанных Цикл
			СписокВыбора.Добавить(ЭлементМассива.id, ЭлементМассива.name);
		КонецЦикла;
	КонецЕсли;
	
	Возврат СписокВыбора;
	
КонецФункции

// Параметры:
//  Дерево - ДеревоЗначений
// 
// Возвращаемое значение:
//  Структура: см. РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией
Функция ОпубликоватьВакансию(Дерево) Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией();
	
	Если Не УстановитьСоединение() Тогда
		Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкойПубликацииВакансии(Сайт, ЭтотОбъект);
	КонецЕсли;
	
	JSONОписаниеВакансии = JSONОписаниеВакансии(Дерево);
	
	Запрос = НовыйHTTPЗапрос("/vacancies?with_professional_roles=true");
	Запрос.УстановитьТелоИзСтроки(JSONОписаниеВакансии, , ИспользованиеByteOrderMark.НеИспользовать);
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().ОтправитьДляОбработки, Запрос);
	
	Если РезультатЗапроса.КодСостояния = 201 Тогда
		АдресВакансии = РезультатЗапроса.Ответ.Заголовки.Получить("Location");
		
		НомерВхожденияРазделителя = РекрутинговыеСайтыКлиентСервер.НайтиВСтроке(АдресВакансии, "/", 2);
		ИдентификаторВакансии = Сред(АдресВакансии, НомерВхожденияРазделителя + 1, СтрДлина(АдресВакансии) - НомерВхожденияРазделителя);
		
		Результат.ИдентификаторВакансии = ИдентификаторВакансии;
	Иначе
		Результат = РекрутинговыеСайтыСлужебный.РезультатСОшибкойПубликацииВакансии(Сайт, ЭтотОбъект, РезультатЗапроса);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  Дерево - ДеревоЗначений
//  ИдентификаторВакансии - Строка
// 
// Возвращаемое значение:
//  Структура - см. РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией
Функция ОбновитьПубликациюВакансии(Дерево, ИдентификаторВакансии) Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией();
	
	Если Не УстановитьСоединение() Тогда
		Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкойОбновленияВакансии(Сайт, ЭтотОбъект);
	КонецЕсли;
	
	JSONОписаниеВакансииHeadHunter = JSONОписаниеВакансии(Дерево, Истина);
	
	Если Не ЗначениеЗаполнено(JSONОписаниеВакансииHeadHunter) Тогда
		ТекстСообщения = СтрШаблон(НСтр("ru = 'Ошибка чтения данных публикации на сайте %1.'"), Сайт);
		Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкой(ТекстСообщения, Сайт, ЭтотОбъект);
	КонецЕсли;
	
	ОписаниеВакансии = ПарсерJSON(JSONОписаниеВакансииHeadHunter);
	
	ОписаниеВакансии_billing_type = Неопределено;
	ОписаниеВакансии_manager = Неопределено;
	Если ОписаниеВакансии.Свойство("billing_type") Тогда
		ОписаниеВакансии_billing_type = Новый Структура("billing_type", "");
		ЗаполнитьЗначенияСвойств(ОписаниеВакансии_billing_type, ОписаниеВакансии);
		ОписаниеВакансии.Удалить("billing_type");
	КонецЕсли;
	
	Если ОписаниеВакансии.Свойство("manager") Тогда
		ОписаниеВакансии_manager = Новый Структура("manager", "");
		ЗаполнитьЗначенияСвойств(ОписаниеВакансии_manager, ОписаниеВакансии);
		ОписаниеВакансии.Удалить("manager");
	КонецЕсли;
	
	JSONОписаниеВакансииHeadHunter = РекрутинговыеСайтыСлужебный.ЗаписьJSON(ОписаниеВакансии);
	
	ТекстЗапроса = СтрШаблон("/vacancies/%1?with_professional_roles=true", ИдентификаторВакансии);
	
	Запрос = НовыйHTTPЗапрос(ТекстЗапроса);
	Запрос.УстановитьТелоИзСтроки(JSONОписаниеВакансииHeadHunter, , ИспользованиеByteOrderMark.НеИспользовать);
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Записать, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 204 Тогда
		Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкойОбновленияВакансии(Сайт, ЭтотОбъект, РезультатЗапроса);
	КонецЕсли;
	
	Если ОписаниеВакансии_billing_type <> Неопределено Тогда
		JSONОписаниеВакансииHeadHunter = РекрутинговыеСайтыСлужебный.ЗаписьJSON(ОписаниеВакансии_billing_type);
		Запрос.УстановитьТелоИзСтроки(JSONОписаниеВакансииHeadHunter, , ИспользованиеByteOrderMark.НеИспользовать);
		
		РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Записать, Запрос);
		
		Если РезультатЗапроса.КодСостояния <> 204 Тогда
			ТекстСообщения = СтрШаблон(НСтр("ru = 'Ошибка обновления биллингового типа вакансии на сайте %1.'"), Сайт);
			Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкой(ТекстСообщения, Сайт, ЭтотОбъект, РезультатЗапроса);
		КонецЕсли;
	КонецЕсли;
	
	Если ОписаниеВакансии_manager <> Неопределено Тогда
		JSONОписаниеВакансииHeadHunter = РекрутинговыеСайтыСлужебный.ЗаписьJSON(ОписаниеВакансии_manager);
		Запрос.УстановитьТелоИзСтроки(JSONОписаниеВакансииHeadHunter, , ИспользованиеByteOrderMark.НеИспользовать);
		
		РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Записать, Запрос);
		
		Если РезультатЗапроса.КодСостояния <> 204 Тогда
			ТекстСообщения = СтрШаблон(НСтр("ru = 'Ошибка обновления менеджера вакансии на сайте %1.'"), Сайт);
			Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкой(ТекстСообщения, Сайт, ЭтотОбъект, РезультатЗапроса);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ИдентификаторВакансии - Строка
// 
// Возвращаемое значение:
//  Структура: см. РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией
Функция СнятьПубликациюВакансии(ИдентификаторВакансии) Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией();
	
	Если Не УстановитьСоединение() Тогда
		Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкойСнятияВакансии(Сайт, ЭтотОбъект);
	КонецЕсли;
	
	ИнформацияОПользователе = ИнформацияОПользователе();
	
	ИдентификаторКомпании = ИнформацияОПользователе.ИдентификаторКомпании;
	ИдентификаторПользователя = ИнформацияОПользователе.ИдентификаторПользователя;
	
	Если Не ЗначениеЗаполнено(ИдентификаторКомпании) 
		Или Не ЗначениеЗаполнено(ИдентификаторПользователя) Тогда
		Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкойСнятияВакансии(Сайт, ЭтотОбъект);
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос(СтрШаблон("/employers/%1/vacancies/archived/%2", ИдентификаторКомпании, ИдентификаторВакансии));
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Записать, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 204 Тогда
		Результат = РекрутинговыеСайтыСлужебный.РезультатСОшибкойСнятияВакансии(Сайт, ЭтотОбъект, РезультатЗапроса);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ИдентификаторВакансии - Строка
// 
// Возвращаемое значение:
// - Неопределено
// - Структура: См. РекрутинговыеСайтыСлужебный.НовыеСвойстваПубликацииВакансии
Функция СвойстваПубликацииВакансииНаСайте(ИдентификаторВакансии) Экспорт
	
	СвойстваПубликации = РекрутинговыеСайтыСлужебный.НовыеСвойстваПубликацииВакансии();
	
	Если Не УстановитьСоединение() Тогда
		Возврат СвойстваПубликации;
	КонецЕсли;
	
	Описание = ОписаниеПубликацииВакансии(ИдентификаторВакансии, Ложь);
	Если ЗначениеЗаполнено(Описание) Тогда
		СвойстваПубликации.Опубликована = Не ЗначениеСвойстваУзла(Описание, "archived");
		
		Если СвойстваПубликации.Опубликована Тогда
			СвойстваПубликации.ДатаПубликации = РекрутинговыеСайтыСлужебный.СтрокаВДату(ЗначениеСвойстваУзла(Описание, "published_at"));
			СвойстваПубликации.ДатаОбновления = РекрутинговыеСайтыСлужебный.СтрокаВДату(ЗначениеСвойстваУзла(Описание, "published_at"));
		Иначе
			Истекает = ЗначениеСвойстваУзла(Описание, "expires_at");
			Если ЗначениеЗаполнено(Истекает) Тогда
				СвойстваПубликации.ДатаСнятияСПубликации = 
					Мин(РекрутинговыеСайтыСлужебный.СтрокаВДату(ЗначениеСвойстваУзла(Описание, "expires_at")), ТекущаяДатаСеанса());
			Иначе
				СвойстваПубликации.ДатаСнятияСПубликации = ТекущаяДатаСеанса();
			КонецЕсли;
		КонецЕсли;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат СвойстваПубликации;
	
КонецФункции

// Параметры:
//  Вакансия - СправочникСсылка.Вакансии
Процедура ПолучитьОтклики(Вакансия) Экспорт
	
	ИдентификаторВакансии = РекрутинговыеСайтыСлужебный.ИдентификаторВакансии(Вакансия, Сайт);
	
	Если Не ЗначениеЗаполнено(ИдентификаторВакансии) Тогда
		РекрутинговыеСайтыСлужебный.СообщитьОбОтсутствииПубликации(Сайт);
		Возврат;
	КонецЕсли;
	
	Если Не ПроверитьПодключение().Подключен Тогда
		РекрутинговыеСайтыСлужебный.ЗаписатьОшибкуПолученияОткликов(Сайт, Пользователь);
		Возврат;
	КонецЕсли;
	
	Если Не УстановитьСоединение() Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос("/negotiations/?per_page=50&page=0&vacancy_id=" + ИдентификаторВакансии);
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		РекрутинговыеСайтыСлужебный.СообщитьОбОшибкеПолученияОткликов(Сайт, ЭтотОбъект, РезультатЗапроса);
		Возврат;
	Иначе
		КоллекцииОткликов = ПрочитатьОтветКоллекцияОткликов(РезультатЗапроса);
	КонецЕсли;
	
	МаксимальныйНомерОтклика = РекрутинговыеСайтыСлужебный.МаксимальныйНомерОтклика(Вакансия);
	ЗагруженныеОткликиВакансии = РекрутинговыеСайтыСлужебный.ЗагруженныеОткликиВакансии(Вакансия);
	
	Отклики = ОбщегоНазначенияБЗК.ТаблицаЗначенийПоИмениРегистраСведений("ОткликиКандидатов");
	
	Для Каждого КоллекцияОткликов Из КоллекцииОткликов.collections Цикл
		
		Запрос = НовыйHTTPЗапрос("/negotiations/" + КоллекцияОткликов.id + "?vacancy_id=" + ИдентификаторВакансии);
		
		РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
		
		Если РезультатЗапроса.КодСостояния <> 200 Тогда
			РекрутинговыеСайтыСлужебный.СообщитьОбОшибкеПолученияРезюме(Сайт, ЭтотОбъект, РезультатЗапроса);
			Возврат;
		Иначе
			ОткликиССайта = ПрочитатьОтветОтклики(РезультатЗапроса);
			
			Для Каждого Отклик Из ЗначениеСвойстваУзла(ОткликиССайта, "items") Цикл
				Если Отклик = Неопределено 
					Или Отклик = "null" Тогда
					Продолжить;
				КонецЕсли;
				
				Если Не ЗначениеЗаполнено(ЗначениеСвойстваУзла(Отклик, "resume")) Тогда
					Продолжить;
				КонецЕсли;
				
				ИдентификаторРезюме = ЗначениеСвойстваУзла(Отклик, "resume", "id");
				Если ЗагруженныеОткликиВакансии.Найти(ИдентификаторРезюме) = Неопределено Тогда
					НоваяЗапись = Отклики.Добавить();
					НоваяЗапись.Вакансия = Вакансия;
					НоваяЗапись.НомерОтклика = МаксимальныйНомерОтклика + 1;
					НоваяЗапись.Фамилия = ЗначениеСвойстваУзла(Отклик, "resume", "last_name");
					НоваяЗапись.Имя = ЗначениеСвойстваУзла(Отклик, "resume", "first_name");
					НоваяЗапись.Отчество = ЗначениеСвойстваУзла(Отклик, "resume", "middle_name");
					НоваяЗапись.Источник = Сайт;
					НоваяЗапись.ДатаОтклика = Дата(СтрЗаменить(Лев(ЗначениеСвойстваУзла(Отклик, "updated_at"), 10), "-", ""));
					НоваяЗапись.ИдентификаторРезюме = ИдентификаторРезюме;
					НоваяЗапись.Адрес = ЗначениеСвойстваУзла(Отклик, "resume", "area", "name");
					НоваяЗапись.АдресРезюме = ЗначениеСвойстваУзла(Отклик, "resume", "alternate_url");
					
					Если ЗначениеСвойстваУзла(Отклик, "resume", "can_view_full_info") = Истина Тогда
						Запрос = НовыйHTTPЗапрос("/resumes/" + ИдентификаторРезюме);
						
						РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
						
						Если РезультатЗапроса.КодСостояния = 200 Тогда
							
							Резюме = ПрочитатьОтветРезюмеССайта(РезультатЗапроса);
							
							КонтактнаяИнформация = КонтактнаяИнформацияРезюме(Резюме);
							
							Для Каждого КонтактнаяИнформацияСтрока Из КонтактнаяИнформация Цикл
								
								Если КонтактнаяИнформацияСтрока.Вид = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.ТелефонЛичныеДанныеКандидатов") Тогда
									НоваяЗапись.Телефон = КонтактнаяИнформацияСтрока.Представление;
								КонецЕсли;
								
								Если КонтактнаяИнформацияСтрока.Вид = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.EMailЛичныеДанныеКандидатов") Тогда
									НоваяЗапись.EMail = КонтактнаяИнформацияСтрока.Представление;
								КонецЕсли;
								
							КонецЦикла;
							
						КонецЕсли;
					КонецЕсли;
					
					Запрос = НовыйHTTPЗапрос("/negotiations/" + ЗначениеСвойстваУзла(Отклик, "id") + "/messages?with_text_only=true");
					
					РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
					
					Если РезультатЗапроса.КодСостояния = 200 Тогда
						
						Сообщения = ПрочитатьОтветСообщения(РезультатЗапроса);
						
						Для Каждого Сообщение Из Сообщения.Получить("items") Цикл
							
							Если ЗначениеСвойстваУзла(Сообщение, "author", "participant_type") = "applicant" Тогда
								
								НоваяЗапись.Сообщение = РекрутинговыеСайтыСлужебный.УдалитьЛишнееИзСтроки(ЗначениеСвойстваУзла(Сообщение, "text"));
								Прервать;
								
							КонецЕсли;
							
						КонецЦикла;
						
					КонецЕсли;
					
					МаксимальныйНомерОтклика = МаксимальныйНомерОтклика + 1;
					
					ЗагруженныеОткликиВакансии.Добавить(ИдентификаторРезюме);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	РекрутинговыеСайтыСлужебный.ЗаписатьОтклики(Сайт, Вакансия, Отклики);
	
КонецПроцедуры

// Параметры:
//  Кандидат - СправочникСсылка.Кандидаты
//  ДанныеРезюме - ТаблицаЗначений: см. РекрутинговыеСайтыСлужебный.ДанныеРезюме
Процедура ЗагрузитьКомментарииКандидата(Кандидат, ДанныеРезюме) Экспорт
	
	ОтборСтрок = Новый Структура();
	ОтборСтрок.Вставить("МестоПубликации", Сайт);
	ОтборСтрок.Вставить("ИмяПоля", "owner");
	
	НайденныеСтроки = ДанныеРезюме.НайтиСтроки(ОтборСтрок);
	Если НайденныеСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	СодержимоеПоляOwner = НайденныеСтроки[0].СодержимоеПоля;
	ИдентификаторКомпании = НайденныеСтроки[0].ИдентификаторПользователя;
	
	ПакетOwner = ПрочитатьПолеOwner(СодержимоеПоляOwner);
	АдресКомментариев = ПакетOwner.comments.url;
	
	Комментарии = КомментарииКандидата(АдресКомментариев, ИдентификаторКомпании, Кандидат);
	
	Если Комментарии <> Неопределено Тогда
		РекрутинговыеСайтыСлужебный.ЗаписатьТаблицуКомментариевКандидата(Комментарии, Кандидат, Сайт);
	КонецЕсли;
	
КонецПроцедуры

// Параметры:
//  Классификатор - Строка
//  Дерево - ДеревоЗначений
// 
// Возвращаемое значение:
//  Булево
Функция ЗаполнитьДеревоКлассификатора(Классификатор, Дерево) Экспорт
	
	Результат = Ложь;
	
	Если Классификатор = "professional_roles" Тогда
		Результат = ЗаполнитьДеревоПрофессиональныхРолей(Дерево);
	ИначеЕсли Классификатор = "areas" Или Классификатор = "areas_towns" Тогда
		Результат = ЗаполнитьДеревоРегионов(Дерево);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  АдресРезюме - Строка
// 
// Возвращаемое значение:
//  Структура: см. ПодборПерсоналаКлиентСервер.ДоступностьКонтактовВРезюме
Функция ДоступныеДляПолученияКонтакты(АдресРезюме) Экспорт
	
	ДоступностьКонтактов = ПодборПерсоналаКлиентСервер.ДоступностьКонтактовВРезюме();
	
	ИдентификаторРезюме = ИдентификаторРезюмеПоАдресу(АдресРезюме);
	
	СтруктураРезюме = СтруктураРезюмеССайта(ИдентификаторРезюме);
	
	ЗаполнитьДоступностьКонтактов(ДоступностьКонтактов, СтруктураРезюме);
	
	Возврат ДоступностьКонтактов;
	
КонецФункции

// Параметры:
//  АдресРезюме - Строка
// 
// Возвращаемое значение:
//  Структура: см. РекрутинговыеСайтыСлужебный.НовыеКонтактыРезюме
Функция КонтактыРезюме(АдресРезюме) Экспорт
	
	КонтактыРезюме = РекрутинговыеСайтыСлужебный.НовыеКонтактыРезюме();
	
	Резюме = РезюмеСКонтактами(АдресРезюме);
	Если Не ЗначениеЗаполнено(Резюме) Тогда
		Возврат КонтактыРезюме;
	КонецЕсли;
	
	КонтактыРезюме.Фамилия	= ЗначениеСвойстваУзла(Резюме, "last_name");
	КонтактыРезюме.Имя		= ЗначениеСвойстваУзла(Резюме, "first_name");
	КонтактыРезюме.Отчество	= ЗначениеСвойстваУзла(Резюме, "middle_name");
	
	КонтактнаяИнформация = ЗначениеСвойстваУзла(Резюме, "contact");
	
	Если Не ЗначениеЗаполнено(КонтактнаяИнформация) Тогда
		Возврат КонтактыРезюме;
	КонецЕсли;
	
	Для Каждого ЭлементКИ Из КонтактнаяИнформация Цикл
		ТипКИ = ЗначениеСвойстваУзла(ЭлементКИ, "type", "id");
		
		Если ТипКИ = "cell" Тогда
			КонтактыРезюме.Телефон = ЗначениеСвойстваУзла(ЭлементКИ, "value", "formatted");
		ИначеЕсли ТипКИ = "email" Тогда
			КонтактыРезюме.ЭлектроннаяПочта = ЗначениеСвойстваУзла(ЭлементКИ, "value");
		КонецЕсли;
	КонецЦикла;
	
	Возврат КонтактыРезюме;
	
