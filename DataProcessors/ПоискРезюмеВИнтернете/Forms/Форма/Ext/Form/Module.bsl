	Отборы.Вставить("УровеньЗарплатыФизическогоЛицаОт", УровеньЗарплатыФизическогоЛицаОт);
	Отборы.Вставить("УровеньЗарплатыФизическогоЛицаДо", УровеньЗарплатыФизическогоЛицаДо);
	Отборы.Вставить("СкрыватьРезюмеФизическогоЛицаБезЗарплаты", СкрыватьРезюмеФизическогоЛицаБезЗарплаты);
	// Образование
	Отборы.Вставить("ИспользоватьУровеньОбразованияФизическогоЛица", ИспользоватьУровеньОбразованияФизическогоЛица);
	Отборы.Вставить("УровеньОбразованияСписок", УровеньОбразованияСписок);
	Отборы.Вставить("ИспользоватьУчебноеЗаведение", ИспользоватьУчебноеЗаведение);
	Отборы.Вставить("ОтборУчебноеЗаведениеСписок", ОтборУчебноеЗаведениеСписок);
	// Другое
	Отборы.Вставить("ИспользоватьПрофессию", ИспользоватьПрофессию);
	Отборы.Вставить("ОтборПрофессияСписок", ОтборПрофессияСписок);
	Отборы.Вставить("ИспользоватьСпециальность", ИспользоватьСпециальность);
	Отборы.Вставить("ОтборСпециальностьСписок", ОтборСпециальностьСписок);
	Отборы.Вставить("ИспользоватьПрофильДолжности", ИспользоватьПрофильДолжности);
	Отборы.Вставить("ОтборПрофильДолжностиСписок", ОтборПрофильДолжностиСписок);
	Отборы.Вставить("ИспользоватьКомпетенции", ИспользоватьКомпетенции);
	Отборы.Вставить("КомпетенцииСписок", КомпетенцииСписок);
	Отборы.Вставить("ИспользоватьПричинаОтклонения", ИспользоватьПричинаОтклонения);
	Отборы.Вставить("ПричинаОтклоненияСписок", ПричинаОтклоненияСписок);
	Отборы.Вставить("ИспользоватьЭтапРаботы", ИспользоватьЭтапРаботы);
	Отборы.Вставить("ЭтапРаботыСписок", ЭтапРаботыСписок);
	Отборы.Вставить("ИспользоватьОтветственныйРекрутер", ИспользоватьОтветственныйРекрутер);
	Отборы.Вставить("ОтборОтветственныйРекрутерСписок", ОтборОтветственныйРекрутерСписок);
	Отборы.Вставить("ИспользоватьРейтингКандидата", ИспользоватьРейтингКандидата);
