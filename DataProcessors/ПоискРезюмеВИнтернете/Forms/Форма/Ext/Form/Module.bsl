	ДополнитьОтборыСвойствамиОбъектов(Отборы);
	
	Возврат Отборы;
	
КонецФункции

&НаСервере
Процедура ДополнитьОтборыСвойствамиОбъектов(Отборы)
	
	МассивОбъектов = Новый Массив;
	МассивОбъектов.Добавить("ФизическиеЛица");
	МассивОбъектов.Добавить("Кандидаты");
	МассивОбъектов.Добавить("Сотрудники");
	Отборы.Вставить("ВидыОбъектов", МассивОбъектов);
	
	Для Каждого ВидОбъекта Из МассивОбъектов Цикл
		Свойства = Новый Массив();
		Значения = Новый Структура();
		Для Каждого Свойство Из ЭтаФорма["ИспользуемыеСвойства"+ВидОбъекта] Цикл
			ИмяСвойства = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Свойство.Значение, "Имя") + ВидОбъекта;
			Если ЭтаФорма["ИспользоватьФильтрСвойства" + ИмяСвойства] Тогда
				Свойства.Добавить(Свойство.Значение);
				ТипЗначения = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Свойство.Значение, "ТипЗначения");
				Если ТипЗначения.Типы().Количество() = 1 Тогда
					Если ТипЗначения.СодержитТип(Тип("Дата")) Тогда
						ЗначенияСвойстваДата = Новый Структура();
						ЗначенияСвойстваДата.Вставить("С", ЭтаФорма[ИмяСвойства + ПостфиксыПоТипамСвойств().ДатаНачала]);
						ЗначенияСвойстваДата.Вставить("По", ЭтаФорма[ИмяСвойства + ПостфиксыПоТипамСвойств().ДатаОкончания]);
						Значения.Вставить(ИмяСвойства, ЗначенияСвойстваДата);
					ИначеЕсли ТипЗначения.СодержитТип(Тип("Число")) Тогда
						ЗначенияСвойстваЧисло = Новый Структура();
						ЗначенияСвойстваЧисло.Вставить("От", ЭтаФорма[ИмяСвойства + ПостфиксыПоТипамСвойств().ЧислоОт]);
						ЗначенияСвойстваЧисло.Вставить("До", ЭтаФорма[ИмяСвойства + ПостфиксыПоТипамСвойств().ЧислоДо]);
						Значения.Вставить(ИмяСвойства, ЗначенияСвойстваЧисло);
					Иначе
						Значения.Вставить(ИмяСвойства, ЭтаФорма[ИмяСвойства]);
					КонецЕсли;
				Иначе
					Значения.Вставить(ИмяСвойства, ЭтаФорма[ИмяСвойства]);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		Отборы.Вставить("Свойства" + ВидОбъекта, Свойства);
		Отборы.Вставить("Значения" + ВидОбъекта, Значения);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция СайтыДляПоиска()
	
	Результат = Новый Массив;
	
	Для Каждого Сайт Из Сайты Цикл
		Если ЭтотОбъект[ИмяРеквизита(ДанныеСайтов, "ОбластьПоиска", Сайт)] Тогда
			Результат.Добавить(Сайт);
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаСервере
Процедура СформироватьИнформационнуюНадпись(НомерСтраницы)
	
	ВсегоКандидатов = 0;
	
	Для Каждого Сайт Из Сайты Цикл
		ВсегоКандидатов = ВсегоКандидатов + ЭтотОбъект[ИмяРеквизита(ДанныеСайтов, "ВсегоКандидатов", Сайт)];
	КонецЦикла;
	
	ИнформационнаяНадпись = СтрШаблон(НСтр("ru = 'Показаны кандидаты с %1 по %2 из %3'"),
		НомерСтраницы * 50 + 1,
		НомерСтраницы * 50 + Мин(50, НайденныеКандидатыПостраничная.Количество()),
		ВсегоКандидатов);
	
	Элементы.ИнформационнаяНадписьКоличествоКандидатов.Заголовок = ИнформационнаяНадпись;
	
КонецПроцедуры

&НаСервере
Функция ОтобразитьСтрокиПоНомеруСтраницы(НомерСтраницы)
	
	Результат = Ложь;
	
	НачальныйИндекс = 50 * НомерСтраницы;
	КонечныйИндекс = 50 * (НомерСтраницы + 1);
	
	Если НачальныйИндекс < Объект.НайденныеКандидаты.Количество() Тогда
		НайденныеКандидатыПостраничная.Очистить();
	Иначе
		Возврат Результат;
	КонецЕсли;
		
	Для Индекс = НачальныйИндекс По КонечныйИндекс - 1 Цикл
		
		Если Индекс >= Объект.НайденныеКандидаты.Количество() Тогда
			Прервать;
		КонецЕсли;
		
		НоваяСтрока = НайденныеКандидатыПостраничная.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Объект.НайденныеКандидаты[Индекс]);
		
	КонецЦикла;
	
	СформироватьИнформационнуюНадпись(НомерСтраницы);
	
	Результат = Истина;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ВыполнитьПоискВИнтернете()
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ВыполнитьПоискВИнтернетеЗавершение", ЭтотОбъект);
	
	ДлительнаяОперация = ДлительнаяОперацияПоискаКандидатов();
	
	Если ЗначениеЗаполнено(ДлительнаяОперация) Тогда
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
		ПараметрыОжидания.ТекстСообщения = НСтр("ru = 'Ищем кандидатов.'");
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ДлительнаяОперацияПоискаКандидатов() Экспорт
	
	СтруктураОтбора = РекрутинговыеСайты.СтруктураОтбораКандидатов();
	Для Каждого КлючИЗначение Из СтруктураОтбора Цикл
		Если КлючИЗначение.Ключ = "ТолькоВНазвании"
			Или КлючИЗначение.Ключ = "СкрыватьРезюмеБезЗарплаты" Тогда
			СтруктураОтбора[КлючИЗначение.Ключ] = Объект[КлючИЗначение.Ключ];
		Иначе
			Если ЭтаФорма["Использовать" + КлючИЗначение.Ключ] Тогда
				СтруктураОтбора[КлючИЗначение.Ключ] = Объект[КлючИЗначение.Ключ];
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	СтруктураОтбора.КлючевоеСлово = Объект.КлючевоеСлово;
	
	ПараметрыМетода = Новый Структура;
	ПараметрыМетода.Вставить("СтруктураОтбора", СтруктураОтбора);
	ПараметрыМетода.Вставить("Сайты", СайтыДляПоиска());
	ПараметрыМетода.Вставить("ТаблицаНайденныхКандидатов", Объект.НайденныеКандидаты.Выгрузить());
	
	Для Каждого Сайт Из Сайты Цикл
		ИмяРеквизита = ИмяРеквизита(ДанныеСайтов, "НомерПорции", Сайт);
		ПараметрыМетода.Вставить(ИмяРеквизита, ЭтотОбъект[ИмяРеквизита]);
		
		ИмяРеквизита = ИмяРеквизита(ДанныеСайтов, "ВсегоКандидатов", Сайт);
		ПараметрыМетода.Вставить(ИмяРеквизита, ЭтотОбъект[ИмяРеквизита]);
		
		ИмяРеквизита = ИмяРеквизита(ДанныеСайтов, "ЗагруженоКандидатов", Сайт);
		ПараметрыМетода.Вставить(ИмяРеквизита, ЭтотОбъект[ИмяРеквизита]);
	КонецЦикла;
	
	ИмяМетода = "РекрутинговыеСайты.ВыполнитьПоискКандидатов";
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(УникальныйИдентификатор, ИмяМетода, ПараметрыМетода);
	
КонецФункции

&НаКлиенте
Процедура ВыполнитьПоискВИнтернетеЗавершение(ДлительнаяОперация, ДополнительныеПараметры = Неопределено) Экспорт

	Если ДлительнаяОперация = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ДлительнаяОперация.Статус = "Ошибка" Тогда
		ПоказатьПредупреждение(, ДлительнаяОперация.КраткоеПредставлениеОшибки);
		Возврат;
	ИначеЕсли Не ДлительнаяОперация.Статус = "Выполнено" Тогда
		Возврат;
	КонецЕсли;
	
	АдресХранилища = ДлительнаяОперация.АдресРезультата;
	
	Если Не ЭтоАдресВременногоХранилища(АдресХранилища) Тогда
		Возврат;
	КонецЕсли;
	
	ЗагрузитьТаблицуНайденныхКандидатов();
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьТаблицуНайденныхКандидатов()
	
	Результат = ПолучитьИзВременногоХранилища(АдресХранилища);
	
	Объект.НайденныеКандидаты.Загрузить(Результат.ТаблицаНайденныхКандидатов);
	
	Для Каждого Сайт Из Сайты Цикл
		ИмяРеквизита = ИмяРеквизита(ДанныеСайтов, "НомерПорции", Сайт);
		ЭтотОбъект[ИмяРеквизита] = Результат[ИмяРеквизита];
		
		ИмяРеквизита = ИмяРеквизита(ДанныеСайтов, "ВсегоКандидатов", Сайт);
		ЭтотОбъект[ИмяРеквизита] = Результат[ИмяРеквизита];
		
		ИмяРеквизита = ИмяРеквизита(ДанныеСайтов, "ЗагруженоКандидатов", Сайт);
		ЭтотОбъект[ИмяРеквизита] = ЭтотОбъект[ИмяРеквизита] + Результат[ИмяРеквизита];
	КонецЦикла;
	
	ОтобразитьТекущуюСтраницу();
	
КонецПроцедуры

&НаСервере
Процедура ОтобразитьТекущуюСтраницу()
		
	Если ОтобразитьСтрокиПоНомеруСтраницы(НомерСтраницы + 1) Тогда
		НомерСтраницы = НомерСтраницы + 1;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура НастройкаДоступностиЭлементовФормы()
	
	Элементы.ВозрастОт.Доступность = ИспользоватьВозрастОт;
	Элементы.ВозрастДо.Доступность = ИспользоватьВозрастДо;
	Элементы.Регион.Видимость = ИспользоватьРегион;
	Элементы.УровеньЗарплатыОт.Доступность = ИспользоватьУровеньЗарплатыОт;
	Элементы.СкрыватьРезюмеБезЗарплаты.Доступность = ИспользоватьУровеньЗарплатыОт;
	Элементы.УровеньЗарплатыДо.Доступность = ИспользоватьУровеньЗарплатыДо;
	Элементы.Пол.Доступность = ИспользоватьПол;
	Элементы.УровеньОбразования.Доступность = ИспользоватьУровеньОбразования;
	Элементы.ПериодРазмещения.Доступность = ИспользоватьПериодРазмещения;
	Элементы.НайденныеКандидатыПостраничнаяГдеНайден.Видимость = Сайты <> Неопределено И Сайты.Количество() > 1;
	
КонецПроцедуры

&НаСервере
Функция ЗаполненыВсеКритерииПоиска() 
	
	Отказ = Ложь;
	Ошибки = Неопределено;
	
	Если Не ЗначениеЗаполнено(Объект.КлючевоеСлово) Тогда
		ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, "Объект.КлючевоеСлово", НСтр("ru = 'Поле ""Ключевое слово"" не заполнено'"), "");
	КонецЕсли;
		
	Если ИспользоватьВозрастОт 
		И Не ЗначениеЗаполнено(Объект.ВозрастОт) Тогда
		ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, "Объект.ВозрастОт", НСтр("ru = 'Поле ""Возраст от"" не заполнено'"), "");
	КонецЕсли;
	
	Если ИспользоватьВозрастДо 
		И Не ЗначениеЗаполнено(Объект.ВозрастДо) Тогда
		ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, "Объект.ВозрастДо", НСтр("ru = 'Поле ""Возраст до"" не заполнено'"), "");
	КонецЕсли;
	
	Если ИспользоватьРегион 
		И Не ЗначениеЗаполнено(Объект.Регион) Тогда
		ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, "Объект.Регион", НСтр("ru = 'Поле ""Город"" не заполнено'"), "");
	КонецЕсли;

	Если ИспользоватьУровеньЗарплатыОт 
		И Не ЗначениеЗаполнено(Объект.УровеньЗарплатыОт) Тогда
		ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, "Объект.УровеньЗарплатыОт", НСтр("ru = 'Поле ""Зарплата от"" не заполнено'"), "");
	КонецЕсли;
	
	Если ИспользоватьУровеньЗарплатыДо 
		И Не ЗначениеЗаполнено(Объект.УровеньЗарплатыДо) Тогда
		ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, "Объект.УровеньЗарплатыДо", НСтр("ru = 'Поле ""Зарплата до"" не заполнено'"), "");
	КонецЕсли;
	
	Если ИспользоватьПол 
		И Не ЗначениеЗаполнено(Объект.Пол) Тогда
		ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, "Объект.Пол", НСтр("ru = 'Поле ""Пол"" не заполнено'"), "");
	КонецЕсли;

	Если ИспользоватьУровеньОбразования 
		И Не ЗначениеЗаполнено(Объект.УровеньОбразования) Тогда
		ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, "Объект.УровеньОбразования", НСтр("ru = 'Поле ""Уровень образования"" не заполнено'"), "");
	КонецЕсли;

	Если ИспользоватьПериодРазмещения 
		И Не ЗначениеЗаполнено(Объект.ПериодРазмещения) Тогда
		ОбщегоНазначенияКлиентСервер.ДобавитьОшибкуПользователю(Ошибки, "Объект.ПериодРазмещения", НСтр("ru = 'Поле ""Период размещения"" не заполнено'"), "");
	КонецЕсли;
	
	ОбщегоНазначенияКлиентСервер.СообщитьОшибкиПользователю(Ошибки, Отказ);
	
	Возврат Не Отказ;
	
КонецФункции

&НаСервере
Процедура УстановитьЗаголовокНадписиРегион()
	
	Элементы.Регион.Заголовок = "";
	Если Объект.Регион.Количество() = 0 Тогда
		Элементы.Регион.Заголовок = НСтр("ru = 'Заполнить'");
	Иначе
		ЗаполнитьПредставлениеФильтра(Объект.Регион, Истина, Элементы.Регион.Заголовок, Ложь);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура НастроитьФормуПоОбластиПоиска()
	
	Если ИскатьВИнтернете Тогда
		ОбластьПоиска = ОбластиПоиска().ВИнтернете;
		Элементы.КомандаНайти.Доступность = Истина;
		Элементы.КомандаНайтиДоп.Доступность = Истина;
	Иначе
		ОбластьПоиска = ОбластиПоиска().Внутри;
		Элементы.ГруппаЗагрузкаКлассификаторов.Видимость = Ложь;
		Элементы.НадписьПоиск.Видимость = ПолнотекстовыйПоискРазрешен;
		Элементы.НадписьПолнотекстовыйПоиск.Видимость = Не ПолнотекстовыйПоискРазрешен;
		Элементы.КомандаНайти.Доступность = ПолнотекстовыйПоискРазрешен;
		Элементы.КомандаНайтиДоп.Доступность = ПолнотекстовыйПоискРазрешен;
	КонецЕсли;
		
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаРекрутинговыеСайты", "Видимость", ИскатьВИнтернете);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаВнутренняяБаза", "Видимость", Не ИскатьВИнтернете);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ТолькоВНазвании", "Видимость", ИскатьВИнтернете);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаНайденныеКандидатыВнутренние", "Видимость", Не ИскатьВИнтернете);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаНайденныеКандидаты", "Видимость", ИскатьВИнтернете);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаОтборКандидаты", "Видимость", ИскатьВИнтернете);
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ГруппаОтборФизическиеЛица", "Видимость", Не ИскатьВИнтернете);

КонецПроцедуры

&НаСервере
Процедура УстановитьНадписьПоискаКандидатов()
	
	Если НайденныеКандидаты.Количество() > 0 Тогда
		Элементы.ГруппаИнформация.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Элементы.ГруппаИнформация.Видимость = Истина;
	НадписьПоискТекст = НСтр("ru = 'Никого не найдено, попробуйте расширить критерии поиска'");
	Элементы.НадписьПоиск.Заголовок = СтроковыеФункции.ФорматированнаяСтрока(НадписьПоискТекст);
	
КонецПроцедуры

&НаСервере
Процедура УстановитьЗначенияПоУмолчанию()
	
	ОбластьПоискаКандидаты = Истина;
	ОбластьПоискаСотрудники = Истина;
	ОбластьПоискаУволенные = Истина;
	
	ЧтениеКадровыйРезерв = ПравоДоступа("Чтение", Метаданные.РегистрыСведений.КадровыйРезерв);
	ОбластьПоискаКадровыйРезерв = ЧтениеКадровыйРезерв;
	ОбщегоНазначенияКлиентСервер.УстановитьСвойствоЭлементаФормы(Элементы, "ОбластьПоискаКадровыйРезерв", "Видимость",
		ЧтениеКадровыйРезерв);

	ВозрастФизическогоЛицаОт = 18;
	ВозрастФизическогоЛицаДо = 65;
	ОпытРаботы = Обработки.ПоискРезюмеВИнтернете.ОпытРаботыФизическогоЛица().Более1Года;
	
КонецПроцедуры

&НаСервере
Процедура ИспользуемыеСайты()
	
	Если Не ПолучитьФункциональнуюОпцию("ИспользоватьИнтеграциюРекрутинговыхСайтов") Тогда
		ИскатьВИнтернете = Ложь;
		ОбластьПоиска = ОбластиПоиска().Внутри;
		Элементы.ОбластьПоиска.Доступность = Ложь;
		Возврат;
	КонецЕсли;
	
	Для Каждого Сайт Из Сайты Цикл
		ИмяРеквизита = ИмяРеквизита(ДанныеСайтов, "Разрешен", Сайт);
		ПоискРазрешен = Не (Сайты.Найти(Сайт) = Неопределено);
		ЭтотОбъект[ИмяРеквизита] = ПоискРазрешен;
		
		ИмяРеквизита = ИмяРеквизита(ДанныеСайтов, "ОбластьПоиска", Сайт);
		ЭтотОбъект[ИмяРеквизита] = ЭтотОбъект[ИмяРеквизита] И ПоискРазрешен;
		
		Элементы[ИмяРеквизита].Видимость = ПоискРазрешен;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура СброситьФильтры()
	
	Объект.Пол.Очистить();
	Объект.Регион.Очистить();
	Объект.УровеньОбразования.Очистить();
	Объект.ПериодРазмещения.Очистить();
	
КонецПроцедуры

&НаСервере
Процедура ЗагрузитьОбщиеКлассификаторы()
	
	Обработки.ПоискРезюмеВИнтернете.ЗагрузитьОбщиеСправочники();
	
КонецПроцедуры

&НаСервере
Процедура СохранитьНастройки()
	
	Настройки = Новый Структура();
	Настройки.Вставить("ИскатьВИнтернете", ИскатьВИнтернете);
	//Общее
	Настройки.Вставить("ПолФизическогоЛица", ПолФизическогоЛица);
	Настройки.Вставить("ИспользоватьВозраст", ИспользоватьВозраст);
	Настройки.Вставить("ВозрастФизическогоЛицаОт", ВозрастФизическогоЛицаОт);
	Настройки.Вставить("ВозрастФизическогоЛицаДо", ВозрастФизическогоЛицаДо);
	Настройки.Вставить("ИспользоватьГражданство", ИспользоватьГражданство);
	Настройки.Вставить("ОтборГражданствоСписок", ОтборГражданствоСписок);
	Настройки.Вставить("ИспользоватьЗнаниеЯзыков", ИспользоватьЗнаниеЯзыков);
	Настройки.Вставить("ЗнаниеЯзыковСписок", ЗнаниеЯзыковСписок);
	Настройки.Вставить("ИспользоватьСостояниеВБраке", ИспользоватьСостояниеВБраке);
	Настройки.Вставить("СостояниеВБракеСписок", СостояниеВБракеСписок);
	Настройки.Вставить("ИспользоватьОпытРаботы", ИспользоватьОпытРаботы);
	Настройки.Вставить("ОпытРаботы", ОпытРаботы);
	//Условия
	Настройки.Вставить("ИспользоватьУровеньЗарплатыФизическогоЛица", ИспользоватьУровеньЗарплатыФизическогоЛица);
	Настройки.Вставить("УровеньЗарплатыФизическогоЛицаОт", УровеньЗарплатыФизическогоЛицаОт);
	Настройки.Вставить("УровеньЗарплатыФизическогоЛицаДо", УровеньЗарплатыФизическогоЛицаДо);
	Настройки.Вставить("СкрыватьРезюмеФизическогоЛицаБезЗарплаты", СкрыватьРезюмеФизическогоЛицаБезЗарплаты);
	//Образование
	Настройки.Вставить("ИспользоватьУровеньОбразованияФизическогоЛица", ИспользоватьУровеньОбразованияФизическогоЛица);
	Настройки.Вставить("УровеньОбразованияСписок", УровеньОбразованияСписок);
	Настройки.Вставить("ИспользоватьУчебноеЗаведение", ИспользоватьУчебноеЗаведение);
	Настройки.Вставить("ОтборУчебноеЗаведениеСписок", ОтборУчебноеЗаведениеСписок);
	//Другое
	Настройки.Вставить("ИспользоватьПрофессию", ИспользоватьПрофессию);
	Настройки.Вставить("ОтборПрофессияСписок", ОтборПрофессияСписок);
	Настройки.Вставить("ИспользоватьСпециальность", ИспользоватьСпециальность);
	Настройки.Вставить("ОтборСпециальностьСписок", ОтборСпециальностьСписок);
	Настройки.Вставить("ИспользоватьПрофильДолжности", ИспользоватьПрофильДолжности);
	Настройки.Вставить("ОтборПрофильДолжностиСписок", ОтборПрофильДолжностиСписок);
	Настройки.Вставить("ИспользоватьКомпетенции", ИспользоватьКомпетенции);
	Настройки.Вставить("КомпетенцииСписок", КомпетенцииСписок);	
	Настройки.Вставить("ИспользоватьПричинаОтклонения", ИспользоватьПричинаОтклонения);
	Настройки.Вставить("ПричинаОтклоненияСписок", ПричинаОтклоненияСписок);
	Настройки.Вставить("ИспользоватьЭтапРаботы", ИспользоватьЭтапРаботы);
	Настройки.Вставить("ЭтапРаботыСписок", ЭтапРаботыСписок);
	Настройки.Вставить("ИспользоватьОтветственныйРекрутер", ИспользоватьОтветственныйРекрутер);
	Настройки.Вставить("ОтборОтветственныйРекрутерСписок", ОтборОтветственныйРекрутерСписок);
	Настройки.Вставить("ИспользоватьРейтингКандидата", ИспользоватьРейтингКандидата);
	Настройки.Вставить("РейтингКандидатаОт", РейтингКандидатаОт);
	Настройки.Вставить("РейтингКандидатаДо", РейтингКандидатаДо);
	
	ОбщегоНазначения.ХранилищеОбщихНастроекСохранить("Обработка.ПоискРезюмеВИнтернете", "Настройки", Настройки);

КонецПроцедуры

&НаСервере
Процедура ВосстановитьНастройки()
		
	ЗначениеНастроек = ОбщегоНазначения.ХранилищеОбщихНастроекЗагрузить("Обработка.ПоискРезюмеВИнтернете", "Настройки");
	Если ТипЗнч(ЗначениеНастроек) = Тип("Структура") Тогда
		ЗаполнитьЗначенияСвойств(ЭтаФорма, ЗначениеНастроек);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьНадписьПолнотекстовогоПоиска()
	
	СостояниеПолнотекстовогоПоиска = ПолнотекстовыйПоискСервер.СостояниеПолнотекстовогоПоиска();
	
	Если СостояниеПолнотекстовогоПоиска = "ОшибкаНастройкиПоиска"
		Или СостояниеПолнотекстовогоПоиска = "ПоискЗапрещен" Тогда
		Элементы.КартинкаИнформация.Картинка = БиблиотекаКартинок.Предупреждение32;
		Если Пользователи.ЭтоПолноправныйПользователь(, Истина) Тогда
			СостояниеПоискаПредставление = НСтр("ru = 'Включить полнотекстовый поиск данных можно в панели «Общие настройки» раздела «Администрирование».'");
		Иначе
			СостояниеПоискаПредставление = НСтр("ru = 'Обратитесь к администратору.'");
		КонецЕсли;
		Элементы.НадписьПолнотекстовыйПоиск.Заголовок = Элементы.НадписьПолнотекстовыйПоиск.Заголовок + Символы.ПС
			+ СостояниеПоискаПредставление;
	ИначеЕсли СостояниеПолнотекстовогоПоиска = "ВыполняетсяОбновлениеИндекса"
		Или СостояниеПолнотекстовогоПоиска = "ВыполняетсяСлияниеИндекса"
		Или СостояниеПолнотекстовогоПоиска = "ТребуетсяОбновлениеИндекса" Тогда
		Элементы.НадписьПолнотекстовыйПоиск.Заголовок = СтрШаблон(НСтр("ru = '%1%2%3'"),
			НСтр("ru = 'Поиск резюме доступен, но результаты могут быть неточными'"),
			Символы.ПС,
			НСтр("ru = 'Дождитесь обновления индекса и повторите попытку.'"));
	Иначе
		ПолнотекстовыйПоискРазрешен = Истина;
	КонецЕсли;
		
КонецПроцедуры

&НаСервере
Функция СтруктураВидыОбъектов()
	
	ВидыОбъектов = Новый Структура;
	ВидыОбъектов.Вставить("ФизическиеЛица", Новый Массив());
	ВидыОбъектов.Вставить("Кандидаты", Новый Массив());
	ВидыОбъектов.Вставить("Сотрудники", Новый Массив());
	
	Возврат ВидыОбъектов;
	
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ОбластиПоиска()
	Возврат Новый Структура("Внутри, ВИнтернете", "Внутри", "ВИнтернете");
КонецФункции

&НаКлиентеНаСервереБезКонтекста
Функция ПостфиксыПоТипамСвойств()
	
	Постфиксы = Новый Структура;
	Постфиксы.Вставить("ДатаНачала", "С");
	Постфиксы.Вставить("ДатаОкончания", "По");
	Постфиксы.Вставить("ЧислоОт", "От");
	Постфиксы.Вставить("ЧислоДо", "До");
	
	Возврат Постфиксы;
	
КонецФункции

&НаСервере
Процедура ПроверитьЗаполнениеФильтров(Отказ)
	
	Если ОбластьПоискаКандидаты + ОбластьПоискаСотрудники + ОбластьПоискаУволенные
		+ ОбластьПоискаКадровыйРезерв = 0 Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не указаны области поиска'"), , , ,Отказ);
	КонецЕсли;
	
	Если ИспользоватьГражданство И ОтборГражданствоСписок.Количество() = 0 Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не заполнено гражданство'"), , , ,Отказ);
	КонецЕсли;
	
	Если ИспользоватьЗнаниеЯзыков И ЗнаниеЯзыковСписок.Количество() = 0 Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не заполнено знание языков'"), , , ,Отказ);
	КонецЕсли;
	
	Если ИспользоватьСостояниеВБраке И СостояниеВБракеСписок.Количество() = 0 Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не заполнено состояние в браке'"), , , ,Отказ);
	КонецЕсли;
	
	Если ИспользоватьУровеньОбразованияФизическогоЛица И УровеньОбразованияСписок.Количество() = 0 Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не заполнен уровень образования'"), , , ,Отказ);
	КонецЕсли;
	
	Если ИспользоватьУчебноеЗаведение И ОтборУчебноеЗаведениеСписок.Количество() = 0 Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не заполнено учебное заведение'"), , , ,Отказ);
	КонецЕсли;
	
	Если ИспользоватьПрофессию И ОтборПрофессияСписок.Количество() = 0 Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не заполнена профессия'"), , , ,Отказ);
	КонецЕсли;
	
	Если ИспользоватьСпециальность И ОтборСпециальностьСписок.Количество() = 0 Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не заполнена специальность'"), , , ,Отказ);
	КонецЕсли;
	
	Если ИспользоватьПрофильДолжности И ОтборПрофильДолжностиСписок.Количество() = 0 Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не заполнен профиль должности'"), , , ,Отказ);
	КонецЕсли;
	
	Если ИспользоватьКомпетенции И КомпетенцииСписок.Количество() = 0 Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не заполнены компетенции'"), , , ,Отказ);
	КонецЕсли;
	
	Если ИспользоватьПричинаОтклонения И ПричинаОтклоненияСписок.Количество() = 0 Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не заполнена причина отклонения'"), , , ,Отказ);
	КонецЕсли;
	
	Если ИспользоватьЭтапРаботы И ЭтапРаботыСписок.Количество() = 0 Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не заполнен этап работы'"), , , ,Отказ);
	КонецЕсли;
	
	Если ИспользоватьОтветственныйРекрутер И ОтборОтветственныйРекрутерСписок.Количество() = 0 Тогда
		ОбщегоНазначения.СообщитьПользователю(НСтр("ru = 'Не заполнен ответственный рекрутер'"), , , ,Отказ);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриИзмененииПометкиСписка(Список, ИспользоватьФильтр, ЗаголовокФильтра)
	ЗаполнитьСписокФильтра(Список);
	ЗаполнитьПредставлениеФильтра(Список, ИспользоватьФильтр, ЗаголовокФильтра, Ложь);
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьСписокФильтра(Список)
	
	ТекущиеДанные = ТекущийЭлемент.ТекущиеДанные;
	ЗначениеФильтра = ТекущиеДанные.Значение;
	Если ТекущиеДанные.Пометка Тогда
		Список.Добавить(ТекущиеДанные.Значение);
	Иначе
		НайденноеЗначение = Список.НайтиПоЗначению(ЗначениеФильтра);
		Если НайденноеЗначение <> Неопределено Тогда
			Список.Удалить(НайденноеЗначение);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Процедура ЗаполнитьПредставлениеФильтра(Список, ИспользоватьФильтр, ЗаголовокФильтра, ИнициализацияПриОткрытииФормы)
	
	ЗаголовокФильтра = "";
	ВыбранноеКоличество = Список.Количество();
	
	Если ВыбранноеКоличество = 0 Тогда
		ИспользоватьФильтр = Ложь;
		ЗаголовокФильтра = НСтр("ru = 'Заполнить'");
		Возврат;
	КонецЕсли;

	БольшойСписок = Ложь;
	Если Не ИнициализацияПриОткрытииФормы Тогда
		ИспользоватьФильтр = Истина;
	КонецЕсли;
	
	ДлинаЗаголовка = 20;
	Для Каждого Строка Из Список Цикл
		Если СтрДлина(ЗаголовокФильтра + Строка) > ДлинаЗаголовка Тогда
			БольшойСписок = Истина;
			Если Список.Индекс(Строка) = 0 Тогда
				ЗаголовокФильтра = СтрШаблон(НСтр("ru = 'выбрано %1'"), Строка(ВыбранноеКоличество));
			Иначе 
				ЗаголовокФильтра = СтрШаблон(НСтр("ru = '%1 и еще %2'"),
					Лев(ЗаголовокФильтра, СтрДлина(ЗаголовокФильтра) - 2),
					Строка(ВыбранноеКоличество - Список.Индекс(Строка)));
			КонецЕсли;
			Прервать;
		Иначе
			ЗаголовокФильтра = ЗаголовокФильтра + Строка + ", ";
		КонецЕсли;

	КонецЦикла;

	Если Не БольшойСписок Тогда
		ЗаголовокФильтра = Лев(ЗаголовокФильтра, СтрДлина(ЗаголовокФильтра) - 2);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОчиститьНастройкиНаСервере()
	
	Если ИскатьВИнтернете Тогда
		ИспользоватьВозрастОт = Ложь;
		ИспользоватьВозрастДо = Ложь;
		Объект.ВозрастОт = 18;
		Объект.ВозрастДо = 65;
		ИспользоватьРегион = Ложь;
		ИспользоватьУровеньЗарплатыОт = Ложь;
		ИспользоватьУровеньЗарплатыДо = Ложь;
		Объект.УровеньЗарплатыОт = 0;
		Объект.УровеньЗарплатыДо = 0;
		Объект.СкрыватьРезюмеБезЗарплаты = Ложь;
		ИспользоватьПол = Ложь;
		Объект.Пол.Очистить();
		ИспользоватьУровеньОбразования = Ложь;
		Объект.УровеньОбразования.Очистить();
		ИспользоватьПериодРазмещения = Ложь;
		Объект.ПериодРазмещения.Очистить();
		
		НастройкаДоступностиЭлементовФормы();
		УстановитьЗаголовокНадписиРегион();
	Иначе
		//Общее
		ПолФизическогоЛица = ПредопределенноеЗначение("Перечисление.ПолФизическогоЛица.ПустаяСсылка");
		ИспользоватьВозраст = Ложь;
		ВозрастФизическогоЛицаОт = 18;
		ВозрастФизическогоЛицаДо = 65;
		ИспользоватьГражданство = Ложь;
		ОтборГражданствоСписок.Очистить();
		ИспользоватьЗнаниеЯзыков = Ложь;
		ЗнаниеЯзыковСписок.Очистить();
		ИспользоватьСостояниеВБраке = Ложь;
		СостояниеВБракеСписок.Очистить();
		ИспользоватьОпытРаботы = Ложь;
		//Условия
		ИспользоватьУровеньЗарплатыФизическогоЛица = Ложь;
		УровеньЗарплатыФизическогоЛицаОт = 0;
		УровеньЗарплатыФизическогоЛицаДо = 0;
		СкрыватьРезюмеФизическогоЛицаБезЗарплаты = Ложь;
		//Образование
		ИспользоватьУровеньОбразованияФизическогоЛица = Ложь;
		УровеньОбразованияСписок.Очистить();
		ИспользоватьУчебноеЗаведение = Ложь;
		ОтборУчебноеЗаведениеСписок.Очистить();
		//Другое
		ИспользоватьПрофессию = Ложь;
		ОтборПрофессияСписок.Очистить();
		ИспользоватьСпециальность = Ложь;
		ОтборСпециальностьСписок.Очистить();
		ИспользоватьПрофильДолжности = Ложь;
		ОтборПрофильДолжностиСписок.Очистить();
		ИспользоватьКомпетенции = Ложь;
		КомпетенцииСписок.Очистить();
		ИспользоватьПричинаОтклонения = Ложь;
		ПричинаОтклоненияСписок.Очистить();
		ИспользоватьЭтапРаботы = Ложь;
		ЭтапРаботыСписок.Очистить();
		ИспользоватьОтветственныйРекрутер = Ложь;
		ОтборОтветственныйРекрутерСписок.Очистить();
		ИспользоватьРейтингКандидата = Ложь;
		РейтингКандидатаОт = 0;
		РейтингКандидатаДо = 0;
		
		ИнициализироватьФильтрыПоИсточникам();
		ЗаполнитьПредставленияФильтров();
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьИмяФормыВыбораПоТипу(Тип)
	Возврат Метаданные.НайтиПоТипу(Тип).ПолноеИмя() + ".ФормаВыбора";
КонецФункции

&НаКлиенте
Процедура ДобавитьСвойствоВСписокЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если ЗначениеЗаполнено(Результат) Тогда
		ИмяРеквизита = ДополнительныеПараметры.Список;
		ИспользоватьФильтр = "ИспользоватьФильтрСвойства" + ИмяРеквизита;
		ЗаголовокФильтра = "ЗаголовокФильтрСвойства" + ИмяРеквизита;
		Для Каждого Значение Из Результат Цикл
			ЭтаФорма[ИмяРеквизита].Добавить(Значение);
		КонецЦикла;
		ЗаполнитьПредставлениеФильтра(ЭтаФорма[ИмяРеквизита], ЭтаФорма[ИспользоватьФильтр],
			ЭтаФорма[ЗаголовокФильтра], Ложь);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ЗаголовокРеквизитаИспользоватьФильтр(ЗаголовокРеквизита, ВидОбъекта)
	
	ВидОбъектаФильтра = "";
	Для НомерСимвола = 1 По СтрДлина(ВидОбъекта) Цикл
		ТекущийСимвол = Сред(ВидОбъекта, НомерСимвола, 1);
		Если НРег(ТекущийСимвол) = ТекущийСимвол Тогда
			ВидОбъектаФильтра = ВидОбъектаФильтра + ТекущийСимвол;
		Иначе
			ВидОбъектаФильтра = ?(НомерСимвола = 1, НРег(ТекущийСимвол), ВидОбъектаФильтра +Символы.НПП + НРег(ТекущийСимвол));
		КонецЕсли;
	КонецЦикла;
	
	Возврат СтрШаблон(НСтр("ru = '%1 (%2)'"), ЗаголовокРеквизита, ВидОбъектаФильтра);
	
КонецФункции

