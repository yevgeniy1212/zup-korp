#Область ОбработчикиСобытийЭлементовТаблицыФормыНайденныеФизическиеЛица

&НаКлиенте
Процедура НайденныеФизическиеЛицаВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	ТекущиеДанные = Элементы.НайденныеКандидаты.ТекущиеДанные;
	Если Не ТекущиеДанные = Неопределено Тогда
		Если ЗначениеЗаполнено(ТекущиеДанные.ФизическоеЛицо) Тогда
			ЗарплатаКадрыКлиент.ОткрытьФормуФизическогоЛицаДляРедактирования(ТекущиеДанные.ФизическоеЛицо,
				"ИсторияРаботы");
		Иначе
			ПараметрыФормы = Новый Структура("Ключ", ТекущиеДанные.Кандидат);
			ОткрытьФорму("Справочник.Кандидаты.ФормаОбъекта", ПараметрыФормы);
		КонецЕсли	
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура КомандаНайти(Команда)
	
	Если ОбластьПоиска = ОбластиПоиска().Внутри Тогда
		НайтиВнутри();
	ИначеЕсли ОбластьПоиска = ОбластиПоиска().ВИнтернете Тогда
		НайтиВИнтернете();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьНастройки(Команда)
	
	ОчиститьНастройкиНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбластьПоискаПриИзменении(Элемент)
	
	Если ОбластьПоиска = ОбластиПоиска().ВИнтернете Тогда
		ИскатьВИнтернете = Истина;
	Иначе
		ИскатьВИнтернете = Ложь;
	КонецЕсли;
	
	НастроитьФормуПоОбластиПоиска();
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаСледующиеКандидаты(Команда)
	
	Если Объект.НайденныеКандидаты.Количество() < РазмерСтраницы * (НомерСтраницы + 2) Тогда
		ВыполнитьПоискВИнтернете();
	Иначе
		ОтобразитьТекущуюСтраницу();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаПредыдущиеКандидаты(Команда)
	
	Если НомерСтраницы <= 0 Тогда
		Возврат;
	КонецЕсли;
	
	НомерСтраницы = НомерСтраницы - 1;
	ОтобразитьСтрокиПоНомеруСтраницы(НомерСтраницы);
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаРасширенныйПоиск(Команда)
	
	Элементы.ГруппаОтбор.Видимость = Не Элементы.ГруппаОтбор.Видимость;
	Если Не Элементы.ГруппаОтбор.Видимость Тогда
		Элементы.КомандаРасширенныйПоиск.Заголовок = НСтр("ru = 'Показать расширенный поиск'");
	Иначе
		Элементы.КомандаРасширенныйПоиск.Заголовок = НСтр("ru = 'Скрыть расширенный поиск'");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НадписьСправкаПоискОбработкаНавигационнойСсылки(Элемент, НавигационнаяСсылкаФорматированнойСтроки, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку("v8help://1cv8/QueryLanguageFullTextSearchInData");
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ПодборВСписокФильтра(Команда)
	
	ИмяРеквизита = СтрЗаменить(Команда.Имя, "КомандаПодбор", "");
	ТипЗначения = ЭтаФорма[ИмяРеквизита].ТипЗначения;
	
	ИмяФормыВыбора = ПолучитьИмяФормыВыбораПоТипу(ТипЗначения.Типы()[0]);
	
	ПараметрыОповещения = Новый Структура;
	ПараметрыОповещения.Вставить("Список", ИмяРеквизита);
	Оповещение = Новый ОписаниеОповещения("ДобавитьСвойствоВСписокЗавершение", ЭтотОбъект, ПараметрыОповещения);
	
	ПараметрыФормы  = Новый Структура;
	ПараметрыФормы.Вставить("МножественныйВыбор", Истина);
	ПараметрыФормы.Вставить("РежимВыбора", Истина);
	
	Отбор = Новый Структура;
	Отбор.Вставить("Владелец", ЭтаФорма["ЗначениеСвойства" + ИмяРеквизита]);
	ПараметрыФормы.Вставить("Отбор", Отбор);
	
	ОткрытьФорму(ИмяФормыВыбора, ПараметрыФормы, , , , , Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_ДобавитьВСписокФильтра(Команда)
	
	ИмяРеквизита = СтрЗаменить(Команда.Имя, "КомандаДобавить", "");
	ЭтаФорма[ИмяРеквизита].Добавить();
	
	ИспользоватьФильтр = "ИспользоватьФильтрСвойства" + ИмяРеквизита;
	ЗаголовокФильтра = "ЗаголовокФильтрСвойства" + ИмяРеквизита;
	ЗаполнитьПредставлениеФильтра(ЭтаФорма[ИмяРеквизита], ЭтаФорма[ИспользоватьФильтр],
		ЭтаФорма[ЗаголовокФильтра], Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_УдалитьЗначениеВТаблицеФильтра(Команда)
	
	ИмяРеквизита = СтрЗаменить(Команда.Имя, "КомандаУдалить", "");
	ТекущаяСтрока = Элементы["СписокФильтр" + ИмяРеквизита].ТекущаяСтрока;
	Если ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ВыбраннаяСтрока = ЭтаФорма[ИмяРеквизита].НайтиПоИдентификатору(ТекущаяСтрока);
	ЭтаФорма[ИмяРеквизита].Удалить(ВыбраннаяСтрока);
	
	ИспользоватьФильтр = "ИспользоватьФильтрСвойства" + ИмяРеквизита;
	ЗаголовокФильтра = "ЗаголовокФильтрСвойства" + ИмяРеквизита;
	ЗаполнитьПредставлениеФильтра(ЭтаФорма[ИмяРеквизита], ЭтаФорма[ИспользоватьФильтр],
		ЭтаФорма[ЗаголовокФильтра], Ложь);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиентеНаСервереБезКонтекста
Функция ИмяРеквизита(ДанныеСайтов, ИмяРеквизитаФормы, Сайт)

	Возврат РекрутинговыеСайтыКлиентСервер.ИмяРеквизита(ДанныеСайтов, ИмяРеквизитаФормы, Сайт);

КонецФункции

&НаСервере
Процедура ЗаполнитьДанныеРекрутинговыхСайтов()
	
	Если ИспользоватьИнтеграциюРекрутинговыхСайтов Тогда
		МенеджерСайтов = РекрутинговыеСайты.МенеджерРекрутинговыхСайтов();
		Сайты = МенеджерСайтов.Сайты();
		ДанныеСайтов = МенеджерСайтов.ДанныеСайтов();
	КонецЕсли;
	
	ОбновитьОтображение();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьОтображение()
	
	Если Не ИспользоватьИнтеграциюРекрутинговыхСайтов Или Не ЗначениеЗаполнено(Сайты) Тогда
		ИскатьВИнтернете = Ложь;
		ОбластьПоиска = ОбластиПоиска().Внутри;
		Элементы.ОбластьПоиска.Доступность = Ложь;
		Возврат;
	КонецЕсли;
	
	Для Каждого КлючИЗначение Из ДанныеСайтов Цикл
		Если Не КлючИЗначение.Значение.ДоступенПоискРезюме Тогда
			Продолжить;
		КонецЕсли;
		
		Сайт = КлючИЗначение.Ключ;
		ИмяРеквизита = ИмяРеквизита(ДанныеСайтов, "ОбластьПоиска", Сайт);
		Элементы[ИмяРеквизита].Видимость = Истина;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьКлассификаторы()
	
	Если Не ИспользоватьИнтеграциюРекрутинговыхСайтов Тогда
		Элементы.ГруппаЗагрузкаКлассификаторов.Видимость = Ложь;
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Сайты) Тогда
		ОповещениеОЗавершении = Новый ОписаниеОповещения("ЗагрузитьКлассификаторыЗавершение", ЭтотОбъект);
		РекрутинговыеСайтыКлиент.НачатьЗагрузкуКлассификаторов(ЭтотОбъект, ОповещениеОЗавершении, Сайты);
	Иначе
		Элементы.ГруппаЗагрузкаКлассификаторов.ТекущаяСтраница = Элементы.ГруппаКлассификаторыЗагружены;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьКлассификаторыЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Выполнено" Тогда
		Классификаторы = ПолучитьИзВременногоХранилища(Результат.АдресРезультата);
		
		Для Каждого КлючИЗначение Из Классификаторы Цикл
			Если Классификаторы[КлючИЗначение.Ключ] = Неопределено Тогда
				Элементы.ГруппаЗагрузкаКлассификаторов.ТекущаяСтраница = Элементы.ГруппаОшибкаЗагрузкиКлассификаторов;
				Элементы.НадписьОшибкаЗагрузкиКлассификаторов.Заголовок =
					НСтр("ru = 'Произошла ошибка загрузки классификаторов. Подробности в журнале регистрации'");
				Возврат;
			КонецЕсли;
		КонецЦикла;
		
		РекрутинговыеСайтыКлиент.СохранитьКлассификаторы(Классификаторы, ДанныеСайтов);
		Элементы.ГруппаЗагрузкаКлассификаторов.ТекущаяСтраница = Элементы.ГруппаКлассификаторыЗагружены;
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		Элементы.ГруппаЗагрузкаКлассификаторов.ТекущаяСтраница = Элементы.ГруппаОшибкаЗагрузкиКлассификаторов;
		Элементы.НадписьОшибкаЗагрузкиКлассификаторов.Заголовок =
			СтрШаблон(НСтр("ru = 'Произошла ошибка загрузки классификаторов: %1'"), Результат.КраткоеПредставлениеОшибки);
	ИначеЕсли Результат.Статус = "Отменено" Тогда
		Элементы.ГруппаЗагрузкаКлассификаторов.ТекущаяСтраница = Элементы.ГруппаОшибкаЗагрузкиКлассификаторов;
		Элементы.НадписьОшибкаЗагрузкиКлассификаторов.Заголовок = 
			СтрШаблон(НСтр("ru = 'Загрузка классификаторов отменена. Обратитесь к администратору.'"));
	Иначе
		Возврат;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура НайтиВнутри()
	
	ОчиститьСообщения();
	Если ПроверитьЗаполнение() Тогда
		НайденныеКандидаты.Очистить();
		НайтиФизическихЛиц();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура НайтиВИнтернете()
	
	СайтыДляПоиска = СайтыДляПоиска();
	Если Не ЗначениеЗаполнено(СайтыДляПоиска) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Не выбраны сайты для поиска.'"));
		Возврат;
	КонецЕсли;
	
	Если Не ЗаполненыВсеКритерииПоиска() Тогда
		Возврат;
	КонецЕсли;
	
	НомерСтраницы = -1;
	РазмерСтраницы = 50;
	
	Для Каждого Сайт Из Сайты Цикл
		ЭтотОбъект[ИмяРеквизита(ДанныеСайтов, "НомерПорции", Сайт)] = 0;
		ЭтотОбъект[ИмяРеквизита(ДанныеСайтов, "ЗагруженоКандидатов", Сайт)] = 0;
		ЭтотОбъект[ИмяРеквизита(ДанныеСайтов, "ВсегоКандидатов", Сайт)] = 0;
	КонецЦикла;
	
	ВыполнитьПоискВИнтернете();
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьФильтры()
	
	УстановитьЗначенияПоУмолчанию();
	ИнициализироватьФильтрыПоИсточникам();
	ЗаполнитьПредставленияФильтров();
	ИнициализироватьФильтрыПоСвойствамОбъектов();
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьФильтрыПоИсточникам()
	
	ИнициализироватьФильтрПоИсточнику(Метаданные.Справочники.ЯзыкиНародовМира,
		ОтборЗнаниеЯзыковСписок, ЗнаниеЯзыковСписок);
	ИнициализироватьФильтрПоИсточнику(Метаданные.Справочники.СостояниеВБраке,
		ОтборСостояниеВБракеСписок, СостояниеВБракеСписок);
	ИнициализироватьФильтрПоИсточнику(Метаданные.Справочники.ВидыОбразованияФизическихЛиц,
		ОтборУровеньОбразованияСписок, УровеньОбразованияСписок);
	ИнициализироватьФильтрПоИсточнику(Метаданные.ПланыВидовХарактеристик.ХарактеристикиПерсонала,
		ОтборКомпетенцииСписок, КомпетенцииСписок);
	ИнициализироватьФильтрПоИсточнику(Метаданные.Справочники.ПричиныОтклоненияКандидатов,
		ОтборПричинаОтклоненияСписок, ПричинаОтклоненияСписок);
	ИнициализироватьФильтрПоИсточнику(Метаданные.Справочники.ЭтапыРаботыСКандидатами,
		ОтборЭтапРаботыСписок, ЭтапРаботыСписок);
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПредставленияФильтров()
	
	ЗаполнитьПредставлениеФильтра(ОтборГражданствоСписок, ИспользоватьГражданство,
		ЗаголовокОтборГражданство, Истина);
	ЗаполнитьПредставлениеФильтра(ЗнаниеЯзыковСписок, ИспользоватьЗнаниеЯзыков,
		ЗаголовокОтборЗнаниеЯзыков, Истина);
	ЗаполнитьПредставлениеФильтра(СостояниеВБракеСписок, ИспользоватьСостояниеВБраке,
		ЗаголовокОтборСостояниеВБраке, Истина);
	ЗаполнитьПредставлениеФильтра(УровеньОбразованияСписок, ИспользоватьУровеньОбразованияФизическогоЛица,
		ЗаголовокОтборУровеньОбразования, Истина);
	ЗаполнитьПредставлениеФильтра(ОтборУчебноеЗаведениеСписок, ИспользоватьУчебноеЗаведение,
		ЗаголовокОтборУчебноеЗаведение, Истина);
	ЗаполнитьПредставлениеФильтра(ОтборПрофессияСписок, ИспользоватьПрофессию,
		ЗаголовокОтборПрофессия, Истина);
	ЗаполнитьПредставлениеФильтра(ОтборСпециальностьСписок, ИспользоватьСпециальность,
		ЗаголовокОтборСпециальность, Истина);
	ЗаполнитьПредставлениеФильтра(ОтборПрофильДолжностиСписок, ИспользоватьПрофильДолжности,
		ЗаголовокОтборПрофильДолжности, Истина);
	ЗаполнитьПредставлениеФильтра(КомпетенцииСписок, ИспользоватьКомпетенции,
		ЗаголовокОтборКомпетенции, Истина);
	ЗаполнитьПредставлениеФильтра(ПричинаОтклоненияСписок, ИспользоватьПричинаОтклонения,
		ЗаголовокОтборПричинаОтклонения, Истина);
	ЗаполнитьПредставлениеФильтра(ЭтапРаботыСписок, ИспользоватьЭтапРаботы,
		ЗаголовокОтборЭтапРаботы, Истина);
	ЗаполнитьПредставлениеФильтра(ОтборОтветственныйРекрутерСписок, ИспользоватьОтветственныйРекрутер,
		ЗаголовокОтборОтветственныйРекрутер, Истина);

КонецПроцедуры

&НаСервере
Процедура ИнициализироватьФильтрыПоСвойствамОбъектов()
	
	ВидыОбъектов = СтруктураВидыОбъектов();
	ЗаполнитьСвойстваОбъектов(ВидыОбъектов);
	
	ДобавляемыеРеквизиты = Новый Массив;
	СписочныеРеквизиты = Новый Структура;
	ЗначенияСвойствОбъектов = Новый Соответствие;
	Для Каждого ВидОбъекта Из ВидыОбъектов Цикл
		Для Каждого Свойство Из ВидОбъекта.Значение Цикл
			ТипЗначения = Свойство.ТипЗначения;
			Если ТипЗначения.Типы().Количество() = 1 Тогда
				Если ТипЗначения.СодержитТип(Тип("Число")) Тогда
					ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы(Свойство.Имя + ВидОбъекта.Ключ+ ПостфиксыПоТипамСвойств().ЧислоОт,
						ТипЗначения));
					ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы(Свойство.Имя + ВидОбъекта.Ключ + ПостфиксыПоТипамСвойств().ЧислоДо,
						ТипЗначения));
				ИначеЕсли ТипЗначения.СодержитТип(Тип("Дата")) Тогда
					ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы(Свойство.Имя + ВидОбъекта.Ключ + ПостфиксыПоТипамСвойств().ДатаНачала,
						ТипЗначения));
					ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы(Свойство.Имя + ВидОбъекта.Ключ + ПостфиксыПоТипамСвойств().ДатаОкончания,
						ТипЗначения));
				ИначеЕсли ТипЗначения.СодержитТип(Тип("Строка"))
					Или ТипЗначения.СодержитТип(Тип("Булево")) Тогда
					ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы(Свойство.Имя + ВидОбъекта.Ключ, ТипЗначения));
				Иначе
					ДобавитьРеквизитСписокЗначений(ДобавляемыеРеквизиты, Свойство, СписочныеРеквизиты, ТипЗначения, ВидОбъекта);
					ДобавитьРеквизитЗначениеСвойства(Свойство, ЗначенияСвойствОбъектов, ДобавляемыеРеквизиты, ВидОбъекта);
				КонецЕсли;
			Иначе
				ДобавитьРеквизитСписокЗначений(ДобавляемыеРеквизиты, Свойство, СписочныеРеквизиты, ТипЗначения, ВидОбъекта);
			КонецЕсли;
			ДобавитьРеквизитИспользоватьФильтр(Свойство, ДобавляемыеРеквизиты, ВидОбъекта.Ключ);
		КонецЦикла;
	КонецЦикла;
	
	Если ДобавляемыеРеквизиты.Количество() > 0 Тогда
		Элементы.ГруппаДополнительныеРеквизитыИСведения.Видимость = Истина;
		ИзменитьРеквизиты(ДобавляемыеРеквизиты);
		Для Каждого Реквизит Из СписочныеРеквизиты Цикл
			ЭтаФорма[Реквизит.Ключ].ТипЗначения = Реквизит.Значение;
		КонецЦикла;
		Для Каждого Свойство Из ЗначенияСвойствОбъектов Цикл
			ЭтаФорма["ЗначениеСвойства" + Свойство.Ключ.Имя + Свойство.Значение] = Свойство.Ключ;
		КонецЦикла;
		ВывестиРеквизитыСвойствОбъектовНаФорму(ВидыОбъектов);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьРеквизитЗначениеСвойства(Свойство, ЗначенияСвойствОбъектов, ДобавляемыеРеквизиты, ВидОбъекта)
	
	МассивТипов = Новый Массив;
	МассивТипов.Добавить(ТипЗнч(Свойство));
	ОписаниеТипаСвойства = Новый ОписаниеТипов(МассивТипов);
	ЗначенияСвойствОбъектов.Вставить(Свойство, ВидОбъекта.Ключ);
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы("ЗначениеСвойства" + Свойство.Имя + ВидОбъекта.Ключ, ОписаниеТипаСвойства));
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьРеквизитСписокЗначений(ДобавляемыеРеквизиты, Свойство, СписочныеРеквизиты, ТипЗначения, ВидОбъекта)
	
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы(Свойство.Имя + ВидОбъекта.Ключ, Новый ОписаниеТипов("СписокЗначений")));
	ДобавитьРеквизитЗаголовокФильтр(Свойство, ДобавляемыеРеквизиты, ВидОбъекта);
	СписочныеРеквизиты.Вставить(Свойство.Имя + ВидОбъекта.Ключ, ТипЗначения);
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьРеквизитИспользоватьФильтр(Свойство, ДобавляемыеРеквизиты, ВидОбъекта)
	
	ИмяРеквизита = "ИспользоватьФильтрСвойства" + Свойство.Имя + ВидОбъекта;
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы(ИмяРеквизита, Новый ОписаниеТипов("Булево")));
	ЭтаФорма["ИспользуемыеСвойства" + ВидОбъекта].Добавить(Свойство);
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьРеквизитЗаголовокФильтр(Свойство, ДобавляемыеРеквизиты, ВидОбъекта)
	
	ИмяРеквизита = "ЗаголовокФильтрСвойства" + Свойство.Имя + ВидОбъекта.Ключ;
	ДобавляемыеРеквизиты.Добавить(Новый РеквизитФормы(ИмяРеквизита, Новый ОписаниеТипов("Строка")));
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьСвойстваОбъектов(ВидыОбъектов)
	
	ВидыСвойств = Новый Массив;
	ВидыСвойств.Добавить("ДополнительныеРеквизиты");
	Если ПравоДоступа("Чтение", Метаданные.РегистрыСведений.ДополнительныеСведения) Тогда
		ВидыСвойств.Добавить("ДополнительныеСведения");
	КонецЕсли;
	
	Для Каждого ВидОбъекта Из ВидыОбъектов Цикл
		Для Каждого ВидСвойства Из ВидыСвойств Цикл
			СписокСвойств = УправлениеСвойствамиСлужебный.СписокСвойствДляВидаОбъектов("Справочник." + ВидОбъекта.Ключ, ВидСвойства);
			Если СписокСвойств <> Неопределено Тогда
				Для Каждого Элемент Из СписокСвойств Цикл
					ВидОбъекта.Значение.Добавить(Элемент.Свойство);
				КонецЦикла;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ВывестиРеквизитыСвойствОбъектовНаФорму(ВидыОбъектов)
	
	Для Каждого ВидОбъекта Из ВидыОбъектов Цикл
		ИспользуемыеСвойства = ЭтаФорма["ИспользуемыеСвойства"+ВидОбъекта.Ключ];
		Для Каждого Свойство Из ИспользуемыеСвойства Цикл
			ИмяСвойства = Свойство.Значение.Имя + ВидОбъекта.Ключ;
			ЗаголовокРеквизита = Свойство.Значение.Заголовок;
			ТипЗначения = Свойство.Значение.ТипЗначения;
			
			ГруппаСвойство = Элементы.Добавить(
				"ГруппаСвойство" + ИмяСвойства,
				Тип("ГруппаФормы"),
				Элементы.ГруппаДополнительныеРеквизитыИСведения);
			ГруппаСвойство.Вид = ВидГруппыФормы.ОбычнаяГруппа;
			ГруппаСвойство.Отображение = ОтображениеОбычнойГруппы.Нет;
			ГруппаСвойство.ОтображатьЗаголовок = Ложь;
			ГруппаСвойство.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
			
			ПолеИспользоватьФильтр = Элементы.Добавить("ПолеИспользоватьФильтрСвойства" + ИмяСвойства,
				Тип("ПолеФормы"),
				ГруппаСвойство);
			ПолеИспользоватьФильтр.Вид = ВидПоляФормы.ПолеФлажка;
			ПолеИспользоватьФильтр.Заголовок = ЗаголовокРеквизитаИспользоватьФильтр(ЗаголовокРеквизита, ВидОбъекта.Ключ);
			ПолеИспользоватьФильтр.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Право;
			ПолеИспользоватьФильтр.ПутьКДанным = "ИспользоватьФильтрСвойства" + ИмяСвойства;
			
			Если ТипЗначения.Типы().Количество() = 1 Тогда
				Если ТипЗначения.СодержитТип(Тип("Число")) Тогда
					ВывестиРеквизитДляСвойстваЧисло(ИмяСвойства, ГруппаСвойство);
				ИначеЕсли ТипЗначения.СодержитТип(Тип("Дата")) Тогда
					ВывестиРеквизитДляСвойстваДата(ИмяСвойства, ГруппаСвойство);
				ИначеЕсли ТипЗначения.СодержитТип(Тип("Строка"))
					Или ТипЗначения.СодержитТип(Тип("Булево")) Тогда
					ВывестиРеквизитДляСвойстваБулевоСтрока(ИмяСвойства, ГруппаСвойство, ЗаголовокРеквизита);
				Иначе
					ВывестиРеквизитСсылочныйТип(ИмяСвойства, ГруппаСвойство, ЗаголовокРеквизита, Ложь);
				КонецЕсли;
			Иначе
				ВывестиРеквизитСсылочныйТип(ИмяСвойства, ГруппаСвойство, ЗаголовокРеквизита, Истина);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ВывестиРеквизитСсылочныйТип(ИмяСвойства, ГруппаСвойство, ЗаголовокРеквизита, СоставнойТип)
	
	ГруппаОтбор = Элементы.Добавить(
		"ГруппаОтбор" + ИмяСвойства,
		Тип("ГруппаФормы"),
		ГруппаСвойство);
	ГруппаОтбор.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаОтбор.Поведение = ПоведениеОбычнойГруппы.Всплывающая;
	ГруппаОтбор.Отображение = ОтображениеОбычнойГруппы.Нет;
	ЗаголовокФильтра = "ЗаголовокФильтрСвойства" + ИмяСвойства;
	ЭтаФорма[ЗаголовокФильтра] = НСтр("ru = 'Заполнить'");
	ГруппаОтбор.ПутьКДаннымЗаголовка = ЗаголовокФильтра;
	ГруппаОтбор.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	
	ГруппаКоманды = Элементы.Добавить(
		"ГруппаКоманды" + ИмяСвойства,
		Тип("ГруппаФормы"),
		ГруппаОтбор);
	ГруппаКоманды.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаКоманды.Отображение = ОтображениеОбычнойГруппы.Нет;
	ГруппаКоманды.ОтображатьЗаголовок = Ложь;
	
	СписокФильтр = Элементы.Добавить("СписокФильтр" + ИмяСвойства,
		Тип("ТаблицаФормы"),
		ГруппаОтбор);
	СписокФильтр.Заголовок = ЗаголовокРеквизита;
	СписокФильтр.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	СписокФильтр.ПутьКДанным = ИмяСвойства;
	СписокФильтр.Отображение = ОтображениеТаблицы.Список;
	СписокФильтр.АвтоМаксимальнаяШирина = Ложь;
	СписокФильтр.МаксимальнаяШирина = 4;
	СписокФильтр.АвтоМаксимальнаяВысотаВСтрокахТаблицы = Ложь;
	СписокФильтр.МаксимальнаяВысотаВСтрокахТаблицы = 12;
	СписокФильтр.РастягиватьПоГоризонтали = Ложь;
	СписокФильтр.ВариантУправленияВысотой = ВариантУправленияВысотойТаблицы.ВСтрокахТаблицы;
	СписокФильтр.ПоложениеКоманднойПанели = ПоложениеКоманднойПанелиЭлементаФормы.Нет;
	СписокФильтр.АвтоВводНовойСтроки = Ложь;
	СписокФильтр.УстановитьДействие("ПриИзменении", "Подключаемый_СписокФильтрПриИзменении");
	
	ПолеЗначениеФильтр = Элементы.Добавить("СписокФильтр" + ИмяСвойства + "Значение",
		Тип("ПолеФормы"),
		СписокФильтр);
	ПолеЗначениеФильтр.Вид = ВидПоляФормы.ПолеВвода;
	ПолеЗначениеФильтр.ПутьКДанным = ИмяСвойства + ".Значение";
	
	Если СоставнойТип Тогда
		ИмяКомандыДобавить = "КомандаДобавить" + ИмяСвойства;
		КомандаДобавить = Команды.Добавить(ИмяКомандыДобавить);
		КомандаДобавить.Действие = "Подключаемый_ДобавитьВСписокФильтра";
		
		КнопкаДобавить = Элементы.Добавить(
			"КнопкаДобавить" + ИмяСвойства,
			Тип("КнопкаФормы"),
			ГруппаКоманды);
		КнопкаДобавить.ИмяКоманды = ИмяКомандыДобавить;
		КнопкаДобавить.Заголовок  = НСтр("ru = 'Добавить'");
	Иначе
		ИмяКомандыПодбор = "КомандаПодбор" + ИмяСвойства;
		КомандаПодбор = Команды.Добавить(ИмяКомандыПодбор);
		КомандаПодбор.Действие = "Подключаемый_ПодборВСписокФильтра";
		
		КнопкаПодбор = Элементы.Добавить(
			"КнопкаПодбор" + ИмяСвойства,
			Тип("КнопкаФормы"),
			ГруппаКоманды);
		КнопкаПодбор.ИмяКоманды = ИмяКомандыПодбор;
		КнопкаПодбор.Заголовок  = НСтр("ru = 'Подбор'");
	КонецЕсли;
	
	ИмяКомандыУдалить = "КомандаУдалить" + ИмяСвойства;
	КомандаУдалить = Команды.Добавить(ИмяКомандыУдалить);
	КомандаУдалить.Действие = "Подключаемый_УдалитьЗначениеВТаблицеФильтра";
	
	КнопкаУдалить = Элементы.Добавить(
		"КнопкаУдалить" + ИмяСвойства,
		Тип("КнопкаФормы"),
		ГруппаКоманды);
	КнопкаУдалить.ИмяКоманды = ИмяКомандыУдалить;
	КнопкаУдалить.Отображение = ОтображениеКнопки.Картинка;
	КнопкаУдалить.Картинка = БиблиотекаКартинок.Удалить;
	КнопкаУдалить.Ширина = 3;
	
КонецПроцедуры

&НаСервере
Процедура ВывестиРеквизитДляСвойстваБулевоСтрока(ИмяСвойства, ГруппаСвойство, ЗаголовокРеквизита)
	
	ПолеЗначениеФильтр = Элементы.Добавить("ПолеЗначениеФильтрСвойства" + ИмяСвойства,
		Тип("ПолеФормы"),
		ГруппаСвойство);
	ПолеЗначениеФильтр.Вид = ВидПоляФормы.ПолеВвода;
	ПолеЗначениеФильтр.Заголовок = ЗаголовокРеквизита;
	ПолеЗначениеФильтр.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
	ПолеЗначениеФильтр.ПутьКДанным = ИмяСвойства;
	
КонецПроцедуры

&НаСервере
Процедура ВывестиРеквизитДляСвойстваДата(ИмяСвойства, ГруппаСвойство)
	
	ПолеЗначениеФильтрОт = Элементы.Добавить(СтрШаблон("%1%2%3", "ПолеЗначениеФильтрСвойства", ИмяСвойства, ПостфиксыПоТипамСвойств().ДатаНачала),
		Тип("ПолеФормы"),
		ГруппаСвойство);
	ПолеЗначениеФильтрОт.Вид = ВидПоляФормы.ПолеВвода;
	ПолеЗначениеФильтрОт.Заголовок = НСтр("ru = 'с'");
	ПолеЗначениеФильтрОт.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Лево;
	ПолеЗначениеФильтрОт.ПутьКДанным = ИмяСвойства + ПостфиксыПоТипамСвойств().ДатаНачала;
	
	ПолеЗначениеФильтрДо = Элементы.Добавить("ПолеЗначениеФильтрСвойства" + ИмяСвойства + ПостфиксыПоТипамСвойств().ДатаОкончания,
		Тип("ПолеФормы"),
		ГруппаСвойство);
	ПолеЗначениеФильтрДо.Вид = ВидПоляФормы.ПолеВвода;
	ПолеЗначениеФильтрДо.Заголовок = НСтр("ru = 'по'");
	ПолеЗначениеФильтрДо.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Лево;
	ПолеЗначениеФильтрДо.ПутьКДанным = ИмяСвойства + ПостфиксыПоТипамСвойств().ДатаОкончания;
	
КонецПроцедуры

&НаСервере
Процедура ВывестиРеквизитДляСвойстваЧисло(ИмяСвойства, ГруппаСвойство)
	
	ПолеЗначениеФильтрОт = Элементы.Добавить("ПолеЗначениеФильтрСвойства" + ИмяСвойства + ПостфиксыПоТипамСвойств().ЧислоОт,
		Тип("ПолеФормы"),
		ГруппаСвойство);
	ПолеЗначениеФильтрОт.Вид = ВидПоляФормы.ПолеВвода;
	ПолеЗначениеФильтрОт.Заголовок = НСтр("ru = 'от'");
	ПолеЗначениеФильтрОт.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Лево;
	ПолеЗначениеФильтрОт.ПутьКДанным = ИмяСвойства + ПостфиксыПоТипамСвойств().ЧислоОт;
	
	ПолеЗначениеФильтрДо = Элементы.Добавить("ПолеЗначениеФильтрСвойства" + ИмяСвойства + ПостфиксыПоТипамСвойств().ЧислоДо,
		Тип("ПолеФормы"),
		ГруппаСвойство);
	ПолеЗначениеФильтрДо.Вид = ВидПоляФормы.ПолеВвода;
	ПолеЗначениеФильтрДо.Заголовок = НСтр("ru = 'до'");
	ПолеЗначениеФильтрДо.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Лево;
	ПолеЗначениеФильтрДо.ПутьКДанным = ИмяСвойства + ПостфиксыПоТипамСвойств().ЧислоДо;
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьФильтрПоИсточнику(Источник, ОтборСписок, СписокВыбранных)
	
	ПолноеИмя = Источник.ПолноеИмя();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	Объекты.Ссылка КАК Ссылка
		|ИЗ
		|	ПолноеИмяОбъекта КАК Объекты
		|ГДЕ
		|	Объекты.ПометкаУдаления = ЛОЖЬ";
	Запрос.Текст = СтрЗаменить(Запрос.Текст, "ПолноеИмяОбъекта", ПолноеИмя);
	МассивОбъектовСправочника = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");
	ОтборСписок.ЗагрузитьЗначения(МассивОбъектовСправочника);
	
	КоличествоВыбранных = СписокВыбранных.Количество();
	Если КоличествоВыбранных = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Для Счетчик = 1 По КоличествоВыбранных Цикл
		ВыбранноеЗначение = СписокВыбранных[КоличествоВыбранных - Счетчик];
		НайденныйЭлемент = ОтборСписок.НайтиПоЗначению(ВыбранноеЗначение.Значение);
		Если НайденныйЭлемент = Неопределено Тогда
			СписокВыбранных.Удалить(ВыбранноеЗначение);
		Иначе
			НайденныйЭлемент.Пометка = Истина;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура РегионНачалоВыбораЗавершение(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт

	Если ВыбранныйЭлемент = Неопределено 
		Или ВыбранныйЭлемент = КодВозвратаДиалога.Отмена Тогда
		Возврат;
	КонецЕсли;
	
	Объект.Регион = ВыбранныйЭлемент;
	
	УстановитьЗаголовокНадписиРегион();
	
КонецПроцедуры

&НаСервере 
Функция СписокВыбораНаСервере(ИмяСписка)
	
	СписокВыбора = Новый СписокЗначений;
	
	Если ЗначениеЗаполнено(Сайты) Тогда
		МенеджерСайтов = РекрутинговыеСайты. МенеджерРекрутинговыхСайтов(Сайты);
		СписокВыбора = МенеджерСайтов.ОбъединенныйСписокВыбораПоКлассификаторам(ИмяСписка);
	КонецЕсли;
	
	Возврат СписокВыбора;
	
КонецФункции

&НаКлиенте
Процедура ВыборИзСпискаЗавершение(ВыбранныйЭлемент, ДополнительныеПараметры) Экспорт
	
	Если ВыбранныйЭлемент = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	СписокВыбранныхЗначений = Новый СписокЗначений;
	СписокВыбранныхЗначений.Добавить(ВыбранныйЭлемент.Значение, ВыбранныйЭлемент.Представление);
	Объект[ДополнительныеПараметры.ИмяЭлемента] = СписокВыбранныхЗначений;
	
КонецПроцедуры

&НаКлиенте
Процедура НачалоОдиночногоВыбораИзСписка(Элемент) 
	
	СписокВыбора = СписокВыбораНаСервере(Элемент.Имя);
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ИмяЭлемента", Элемент.Имя);
	
	Оповещение  = Новый ОписаниеОповещения("ВыборИзСпискаЗавершение", ЭтотОбъект, ДополнительныеПараметры);
	ПоказатьВыборИзСписка(Оповещение, СписокВыбора);
	
КонецПроцедуры

&НаКлиенте
Процедура НайтиФизическихЛиц()
	
	ДлительнаяОперация = ДлительнаяОперацияПоискаФизическихЛиц(УникальныйИдентификатор, Объект.КлючевоеСлово);
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ОбработатьРезультатПоиска", ЭтотОбъект);
	ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
	ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	
КонецПроцедуры

&НаСервере
Функция ДлительнаяОперацияПоискаФизическихЛиц(УникальныйИдентификатор, КлючевоеСлово)
	
	ОтборыСКД = ОтборыДляСКД();
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(УникальныйИдентификатор);
	Возврат ДлительныеОперации.ВыполнитьФункцию(ПараметрыВыполнения, "Обработки.ПоискРезюмеВИнтернете.ПоискКандидатов",
		КлючевоеСлово, ОтборыСКД);
	
КонецФункции

&НаКлиенте
Процедура ОбработатьРезультатПоиска(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если Результат.Статус = "Ошибка" Тогда
		ВызватьИсключение Результат.КраткоеПредставлениеОшибки;
	КонецЕсли;
	
	ВывестиКандидатов(Результат.АдресРезультата);
	
	УстановитьНадписьПоискаКандидатов();
	
КонецПроцедуры

&НаСервере
Процедура ВывестиКандидатов(АдресРезультата)
	
	Если АдресРезультата = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	МассивКандидатов = ПолучитьИзВременногоХранилища(АдресРезультата);
	Если МассивКандидатов = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Строка Из МассивКандидатов Цикл
		СтрокаТЗРезультата = НайденныеКандидаты.Добавить();
		ЗаполнитьЗначенияСвойств(СтрокаТЗРезультата, Строка);
	КонецЦикла;
		
КонецПроцедуры

&НаСервере
Функция ОтборыДляСКД()
	
	Отборы = Новый Структура;
	// ОбластиПоиска
	Отборы.Вставить("ОбластьПоискаКандидаты", ОбластьПоискаКандидаты);
