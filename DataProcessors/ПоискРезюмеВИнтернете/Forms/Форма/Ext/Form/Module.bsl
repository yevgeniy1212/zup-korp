	Отборы.Вставить("ИспользоватьЗнаниеЯзыков", ИспользоватьЗнаниеЯзыков);
	Отборы.Вставить("ЗнаниеЯзыковСписок", ЗнаниеЯзыковСписок);
	Отборы.Вставить("ИспользоватьСостояниеВБраке", ИспользоватьСостояниеВБраке);
