#Область ОписаниеПеременных

&НаСервере
Перем КлючевоеСловоЗагрузилось;

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИспользоватьИнтеграциюРекрутинговыхСайтов = 
		РекрутинговыеСайты.ИспользуетсяИнтеграцияРекрутинговыхСайтов();
	
	ВосстановитьНастройки();
	
	Если ИспользоватьИнтеграциюРекрутинговыхСайтов Тогда
		РекрутинговыеСайтыФормы.ФормаПоискаКандидатовПриСозданииНаСервере(ЭтотОбъект);
	КонецЕсли;
	
	ОбновитьОтображение();
	ИнициализироватьФильтры();
	УстановитьНадписьПолнотекстовогоПоиска();
	НастроитьФормуПоОбластиПоиска();
	
	Если Параметры.Свойство("КлючевоеСлово", Объект.КлючевоеСлово) Тогда
		КлючевоеСловоЗагрузилось = Истина;
	Иначе
		КлючевоеСловоЗагрузилось = Ложь;
	КонецЕсли;
	
	Если Сайты = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ЗагрузитьОбщиеКлассификаторы();
	
	Параметры.Свойство("Вакансия", Вакансия);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ЗагрузитьКлассификаторы();
	
	НастройкаДоступностиЭлементовФормы();
	УстановитьЗаголовокНадписиРегион();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	
	Если ИмяСобытия = "ИзмененыНастройкиДоступаКСайтам" Тогда
		ЗаполнитьДанныеРекрутинговыхСайтов();
		СброситьФильтры();
		УстановитьЗаголовокНадписиРегион();
		НастройкаДоступностиЭлементовФормы();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриСохраненииДанныхВНастройкахНаСервере(Настройки)
	
	СохранитьНастройки();
	Настройки.Вставить("Сайт", Сайты);
	
	Если Сайты <> Неопределено Тогда
		Для каждого Сайт Из Сайты Цикл
			ИмяРеквизита = СтрШаблон("ОбластьПоиска%1", ДанныеСайтов[Сайт].Имя);
			Настройки.Вставить(ИмяРеквизита, ЭтотОбъект[ИмяРеквизита]);
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПередЗагрузкойДанныхИзНастроекНаСервере(Настройки)
	
	Если Сайты = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если КлючевоеСловоЗагрузилось Тогда
		Настройки.Удалить("Объект.КлючевоеСлово");
	КонецЕсли;
	
	СохраненныеСайты = Настройки.Получить("Сайт");
	Если СохраненныеСайты <> Неопределено Тогда 
		Если Не ОбщегоНазначения.КоллекцииИдентичны(Сайты, СохраненныеСайты) Тогда
			Для Каждого ЭлементОтбора Из Настройки Цикл
				Настройки.Удалить(ЭлементОтбора.Ключ);
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ПриЗагрузкеДанныхИзНастроекНаСервере(Настройки)
	
	Если Сайты <> Неопределено Тогда
		Для каждого Сайт Из Сайты Цикл
			ИмяРеквизита = СтрШаблон("ОбластьПоиска%1", ДанныеСайтов[Сайт].Имя);
			ЭтотОбъект[ИмяРеквизита] = Настройки[ИмяРеквизита];
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОбработкаПроверкиЗаполненияНаСервере(Отказ, ПроверяемыеРеквизиты)
	
	ПроверитьЗаполнениеФильтров(Отказ);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура РегионНажатие(Элемент)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Классификатор", "areas_towns");
	ПараметрыФормы.Вставить("МножественныйВыбор", Истина);
	ПараметрыФормы.Вставить("ВыбранныеСтроки", Объект.Регион);
	ПараметрыФормы.Вставить("ИспользуемыеСайты", Сайты);
	
	ИмяФормыОбработки = "Обработка.ПубликацияВакансийНаРекрутинговыхСайтах.Форма.ВыборИзДереваЗначений";
	
	Оповещение = Новый ОписаниеОповещения("РегионНачалоВыбораЗавершение", ЭтотОбъект);
	
	РекрутинговыеСайтыКлиент.ОткрытьФормуОбработки(ИмяФормыОбработки, ПараметрыФормы, ЭтотОбъект, Оповещение);
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборГражданствоСписокОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Если ТипЗнч(ВыбранноеЗначение) = Тип("Массив") Тогда
		Для Каждого Значение Из ВыбранноеЗначение Цикл
			ОтборГражданствоСписок.Добавить(Значение);
		КонецЦикла;
		ЗаполнитьПредставлениеФильтра(ОтборГражданствоСписок, ИспользоватьГражданство,
			ЗаголовокОтборГражданство, Ложь);
	КонецЕсли;
	
КонецПроцедуры

