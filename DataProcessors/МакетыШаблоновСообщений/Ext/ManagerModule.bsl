	ПараметрыШаблона.Тема = НСтр("ru = 'Напоминание о собеседовании'");
	ПараметрыШаблона.ВладелецШаблона = ВидУведомления;
	// АПК:374-вкл
	
	НачатьТранзакцию();
	
	Попытка
		ШаблонПоздравления = ШаблоныСообщений.СоздатьШаблон(ИмяШаблона, ПараметрыШаблона);
		ШаблонПоздравленияОбъект = ШаблонПоздравления.ПолучитьОбъект();
		ШаблонПоздравленияОбъект.ТекстШаблонаПисьмаHTML = ТекстШаблонаИзМакета("ПредстоящееСобеседование");
