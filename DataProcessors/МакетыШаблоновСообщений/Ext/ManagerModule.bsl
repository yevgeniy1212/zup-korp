	Если ЗначениеЗаполнено(ВидУведомления) Тогда
		
		// Приглашение на собеседование (письмо).
		ШаблонПриглашения = ШаблонПредстоящегоСобеседования(ВидУведомления);
		Если ШаблонПриглашения <> Неопределено Тогда
			СформироватьРассылкуПредстоящегоСобеседования(ВидУведомления, ШаблонПриглашения);
		КонецЕсли;
		
	КонецЕсли;
	
	Если ПараметрыОбновления <> Неопределено Тогда
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
	КонецЕсли;
	
КонецПроцедуры

// Процедура выполняет обновление шаблона истичения срока анкетирования
//
Процедура ОбновитьШаблонИстеченияСрокаАнкетирования(ПараметрыОбновления = Неопределено) Экспорт
	
	НачатьТранзакцию();
	Попытка
		БлокировкаДанных = Новый БлокировкаДанных;
		ЭлементБлокировкиДанных = БлокировкаДанных.Добавить("Справочник.ШаблоныСообщений");
		ЭлементБлокировкиДанных.Режим = РежимБлокировкиДанных.Исключительный;
		БлокировкаДанных.Заблокировать();
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Ложь);
		ШаблонСсылка = Справочники.ШаблоныСообщений.НайтиПоНаименованию(НСтр("ru='Истекает срок опроса'"), Истина);
		Если ЗначениеЗаполнено(ШаблонСсылка) Тогда
			ШаблонОбъект = ШаблонСсылка.ПолучитьОбъект();
			ШаблонОбъект.ТипТекстаПисьма = Перечисления.СпособыРедактированияЭлектронныхПисем.HTML;
			ШаблонОбъект.ТекстШаблонаПисьмаHTML = ТекстШаблонаИзМакета("ИстечениеСрокаАнкетирования");
			ОбновлениеИнформационнойБазы.ЗаписатьДанные(ШаблонОбъект, Ложь, Ложь);
		КонецЕсли;
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;
	
	Если ПараметрыОбновления <> Неопределено Тогда
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
	КонецЕсли;
	
КонецПроцедуры

