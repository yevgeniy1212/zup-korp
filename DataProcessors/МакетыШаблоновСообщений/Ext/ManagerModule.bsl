Функция ШаблонПоздравленияСДнемРождения(ВидУведомления)
	
	ИмяШаблона = НСтр("ru = 'Поздравление с днем рождения (письмо)'");
	ШаблонСсылка = Справочники.ШаблоныСообщений.НайтиПоНаименованию(ИмяШаблона, Истина);
	Если ЗначениеЗаполнено(ШаблонСсылка) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	// АПК:374-выкл. Восклицательный знак в тексте письма, а не сообщению пользователю.
	ПараметрыШаблона = ШаблоныСообщений.ОписаниеПараметровШаблона();
	ПараметрыШаблона.ПолноеИмяТипаНазначения = Метаданные.Справочники.ФизическиеЛица.ПолноеИмя();
	ПараметрыШаблона.Назначение = Метаданные.Справочники.ФизическиеЛица.Синоним;
	ПараметрыШаблона.ТипШаблона = "Письмо";
	ПараметрыШаблона.ФорматПисьма = Перечисления.СпособыРедактированияЭлектронныхПисем.HTML;
	ПараметрыШаблона.Тема = НСтр("ru = 'С днем рождения!'");
	ПараметрыШаблона.ВладелецШаблона = ВидУведомления;
	// АПК:374-вкл
	
	НачатьТранзакцию();
	
	Попытка
		ШаблонПоздравления = ШаблоныСообщений.СоздатьШаблон(ИмяШаблона, ПараметрыШаблона);
		ШаблонПоздравленияОбъект = ШаблонПоздравления.ПолучитьОбъект();
		ШаблонПоздравленияОбъект.ТекстШаблонаПисьмаHTML = ТекстШаблонаИзМакета("ДеньРождения");
		ОбновлениеИнформационнойБазы.ЗаписатьДанные(ШаблонПоздравленияОбъект, Ложь, Ложь);
		ЗафиксироватьТранзакцию();
	Исключение
		ШаблонПоздравления = Неопределено;
		ОтменитьТранзакцию();
	КонецПопытки;
	
	Возврат ШаблонПоздравления;
	
КонецФункции

