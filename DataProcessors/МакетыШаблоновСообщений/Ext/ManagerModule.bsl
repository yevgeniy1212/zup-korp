// Процедура выполняет формирование шаблонов поздравлений с рассылками уведомлений
//
Процедура СформироватьРассылкиСШаблонамиПоздравлений(ПараметрыОбновления = Неопределено) Экспорт
	
	ВидУведомления = УведомленияСервер.ВидУведомленияПоИмени("ДниРождения");
	
	Если ЗначениеЗаполнено(ВидУведомления) Тогда
		
		// Поздравление с днем рождения (письмо).
		ШаблонПоздравления = ШаблонПоздравленияСДнемРождения(ВидУведомления);
		Если ШаблонПоздравления <> Неопределено Тогда
			СформироватьРассылкуПоздравленияСДнемРождения(ВидУведомления, ШаблонПоздравления);
		КонецЕсли;
		
		// Поздравление с юбилеем.
		ШаблонПоздравления = ШаблонПоздравленияСЮбилеем(ВидУведомления);
		Если ШаблонПоздравления <> Неопределено Тогда
			СформироватьРассылкуПоздравленияСЮбилеем(ВидУведомления, ШаблонПоздравления);
		КонецЕсли;
		
		// Поздравление с юбилеем (благодарность).
		ШаблонПоздравления = ШаблонПоздравленияСЮбилеемБлагодарность(ВидУведомления);
		Если ШаблонПоздравления <> Неопределено Тогда
			СформироватьРассылкуПоздравленияСЮбилеемБлагодарность(ВидУведомления, ШаблонПоздравления);
		КонецЕсли;
		
	КонецЕсли;
	
	ВидУведомления = УведомленияСервер.ВидУведомленияПоИмени("ГодовщиныРаботыВКомпании");
	
	Если ЗначениеЗаполнено(ВидУведомления) Тогда
		
		// Годовщины работы в компании (письмо).
		ШаблонПоздравления = ШаблонПоздравленияСГодовщинойРаботы(ВидУведомления);
		Если ШаблонПоздравления <> Неопределено Тогда
			СформироватьРассылкуПоздравленияСГодовщинойРаботы(ВидУведомления, ШаблонПоздравления);
		КонецЕсли;
		
		// Юбилеи работы в компании.
		ШаблонПоздравления = ШаблонПоздравленияСЮбилеемРаботы(ВидУведомления);
		Если ШаблонПоздравления <> Неопределено Тогда
			СформироватьРассылкуПоздравленияСЮбилеемРаботы(ВидУведомления, ШаблонПоздравления);
		КонецЕсли;
		
	КонецЕсли;
	
	ВидУведомления = УведомленияСервер.ВидУведомленияПоИмени("ПервыйРабочийДень");
	
	Если ЗначениеЗаполнено(ВидУведомления) Тогда
		
		// Поздравление с первым рабочим днем (письмо).
		ШаблонПоздравления = ШаблонПоздравленияСПервымРабочимДнем(ВидУведомления);
		Если ШаблонПоздравления <> Неопределено Тогда
			СформироватьРассылкуПоздравленияСПервымРабочимДнем(ВидУведомления, ШаблонПоздравления);
		КонецЕсли;
		
	КонецЕсли;
	
	Если ПараметрыОбновления <> Неопределено Тогда
		ОбновлениеИнформационнойБазыЗарплатаКадрыБазовый.УстановитьПараметрОбновления(ПараметрыОбновления, "ОбработкаЗавершена", Истина);
	КонецЕсли;
	
КонецПроцедуры

// Процедура выполняет формирование шаблона предстоящего собеседования с рассылкой уведомления
//
Процедура СформироватьРассылкуСШаблономПредстоящегоСобеседованияПисьмо(ПараметрыОбновления = Неопределено) Экспорт
	
