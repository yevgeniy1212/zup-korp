&НаКлиенте
Процедура УстановитьОтбор()
	
	СтруктураОтбора = Новый Структура();
	
	Если ЗначениеФильтра = 2 Тогда
		СтруктураОтбора.Вставить("ЭтоНовыеЛичныеДанныеКандидата", Истина);
		СтруктураОтбора.Вставить("ЭтоНовыйКандидат", Истина);
	ИначеЕсли ЗначениеФильтра = 3 Тогда
		СтруктураОтбора.Вставить("ЭтоНовыеЛичныеДанныеКандидата", Ложь);
	ИначеЕсли ЗначениеФильтра = 4 Тогда
		СтруктураОтбора.Вставить("ДоступноДляЗагрузки", Ложь);
	КонецЕсли;
	
	Элементы.ТаблицаФайлов.ОтборСтрок = Новый ФиксированнаяСтруктура(СтруктураОтбора);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьВыборКаталога(ПутьККаталогу, ДополнительныеПараметры) Экспорт
	
	Если Не ЗначениеЗаполнено(ПутьККаталогу) Или ПутьККаталогу = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НачатьПоискФайлов(Новый ОписаниеОповещения("ЗавершитьПоискФайлов", ЭтотОбъект),
		ПутьККаталогу, ПолучитьМаскуВсеФайлы(), Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьПоискФайлов(НайденныеФайлы, ДополнительныеПараметры) Экспорт
	
	Если НайденныеФайлы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Файлы = Новый Массив;
	Для Каждого Файл Из НайденныеФайлы Цикл
		Если Не ЗначениеЗаполнено(Файл.Расширение) Тогда
			Продолжить;
		КонецЕсли;
		Если РазборРезюмеКлиент.ЭтоФайлСДоступнымРасширением(Файл.Имя) Тогда
			Файлы.Добавить(Новый ОписаниеПередаваемогоФайла(Файл.ПолноеИмя));
		КонецЕсли;
	КонецЦикла;
	
	РазборРезюмеКлиент.СоздатьКандидатовПоФайлам(УникальныйИдентификатор, Вакансия, Файлы, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьДанныеКандидатов()
	
	КоличествоДанныхКандидатов = ДанныеКандидатов.Количество();
	
	Счетчик = 0;
	Для Каждого ДанныеКандидата Из ДанныеКандидатов Цикл
		
		ДанныеКандидата = ДанныеКандидата.Значение;
		Путь = ДанныеКандидата.ФайлРезюме.ПолноеИмя;
		АдресФайла = ДанныеКандидата.ФайлРезюме.Хранение;
		
		Состояние(НСтр("ru = 'Подготовка файлов для обработки...'"), Счетчик / КоличествоДанныхКандидатов * 100, Путь);
		
		Если СтрНайти(Путь, "~$") > 0 Тогда // Пропускаем файлы владельца MS Word
			Продолжить;
		КонецЕсли;
		
		НайденныеСтроки = ТаблицаФайлов.НайтиСтроки(Новый Структура("ПутьКФайлу", Путь));
		
		Если НайденныеСтроки.Количество() > 0 Тогда
			Продолжить;
		КонецЕсли;
			
		ФайлРезюме = Новый Файл(Путь);
		
		НоваяСтрока = ТаблицаФайлов.Добавить();
		
		НоваяСтрока.Представление = ФайлРезюме.ИмяБезРасширения;
		НоваяСтрока.ИндексКартинки = РаботаСФайламиСлужебныйКлиентСервер.ПолучитьИндексПиктограммыФайла(
			ФайлРезюме.Расширение);
		НоваяСтрока.ЭтоНовыеЛичныеДанныеКандидата = Истина;
		НоваяСтрока.ЭтоНовыйКандидат = Истина;
		НоваяСтрока.ДоступноДляЗагрузки = Истина;
		НоваяСтрока.ПутьКФайлу = Путь;
		НоваяСтрока.Вакансия = Вакансия;
		НоваяСтрока.Подразделение = Подразделение;
		НоваяСтрока.АдресФайла = АдресФайла;
		НоваяСтрока.ИмяФайла = ФайлРезюме.Имя;
		
		Если Не РазборРезюмеКлиент.ЭтоВебКлиент() Тогда
			НоваяСтрока.РазмерФайла = ФайлРезюме.Размер()/1024;
			НоваяСтрока.ДатаИзмененияФайла = ФайлРезюме.ПолучитьВремяИзменения();
		КонецЕсли;
		
		НоваяСтрока.СтруктураРезюме = ДанныеКандидата;
		
		НоваяСтрока.Фамилия		= СОКРЛП(ДанныеКандидата.Фамилия);
		НоваяСтрока.Имя			= СОКРЛП(ДанныеКандидата.Имя);
		НоваяСтрока.Отчество	= СОКРЛП(ДанныеКандидата.Отчество);
		
		НоваяСтрока.ФИО = СтрШаблон("%1 %2 %3",
			НоваяСтрока.Фамилия,
			НоваяСтрока.Имя,
			НоваяСтрока.Отчество);
		
		ПараметрыПроверки = ПараметрыПроверкиПохожихКандидатов(НоваяСтрока, ДанныеКандидата);
		НоваяСтрока.ЭтоНовыеЛичныеДанныеКандидата = ПараметрыПроверки.КандидатУникален;
		
		Если Не ПараметрыПроверки.КандидатУникален Тогда
			Если ПараметрыПроверки.ДанныеКандидатовДоступны Тогда
				СовпадающиеКандидаты = Новый Массив; 
				Для Каждого ПараметрыПроверкиДанныеКандидата Из ПараметрыПроверки.ДанныеКандидатов Цикл
					Если СтрНайти(ПараметрыПроверкиДанныеКандидата.СовпадающиеДанные, "E-mail") > 0
						Или СтрНайти(ПараметрыПроверкиДанныеКандидата.СовпадающиеДанные, "Телефон") > 0 Тогда
						// Если нашли по телефону или электронной почте, то будем считать что это тот же человек.
						СовпадающиеКандидаты.Добавить(ПараметрыПроверкиДанныеКандидата.ЛичныеДанныеКандидата);
					ИначеЕсли ЗначениеЗаполнено(ДанныеКандидата.ДатаРождения) 
						И ПараметрыПроверкиДанныеКандидата.ДатаРождения = ДанныеКандидата.ДатаРождения Тогда
						// Будем считать, что кандидаты с одинаковым ФИО и датами рождения, являются одним человеком.
						СовпадающиеКандидаты.Добавить(ПараметрыПроверкиДанныеКандидата.ЛичныеДанныеКандидата);
					КонецЕсли;
				КонецЦикла;
				Если СовпадающиеКандидаты.Количество() = 1 Тогда
					НоваяСтрока.ЛичныеДанныеКандидата = СовпадающиеКандидаты[0];
					НоваяСтрока.ГруппаДоступа = ГруппаДоступаКандидата(НоваяСтрока.ЛичныеДанныеКандидата);
				КонецЕсли;
			КонецЕсли;
			Если ЗначениеЗаполнено(НоваяСтрока.ЛичныеДанныеКандидата) Тогда
				ЗаполнитьКандидата(НоваяСтрока);
			КонецЕсли;
			НоваяСтрока.ДоступноДляЗагрузки = РезюмеДоступноДляАвтоматическойЗагрузки(НоваяСтрока);
		КонецЕсли;
		Счетчик = Счетчик + 1;
	КонецЦикла;
	
	ПроверитьНаДубли();
	УстановитьОтбор();
	ТаблицаФайлов.Сортировать("ФИО Возр");
	ОбновитьЭлементыФормы();
	
КонецПроцедуры

&НаКлиенте
Функция ПараметрыПроверкиПохожихКандидатов(СтрокаТаблицыФайлов, ДанныеКандидата)
	
	ПараметрыПоискаКандидатов = ПодборПерсоналаВызовСервера.ПараметрыПоискаПохожихКандидатов();
	ЗаполнитьЗначенияСвойств(ПараметрыПоискаКандидатов, СтрокаТаблицыФайлов, "Фамилия,Имя,Отчество");
	
	Для Каждого КлючЗначение Из ДанныеКандидата Цикл
		Если КлючЗначение.Ключ <> "КонтактнаяИнформация" Тогда
			Продолжить;
		КонецЕсли;
		Для Каждого ЭлементКИ Из КлючЗначение.Значение Цикл
			Если ЭлементКИ.Вид = ПредопределенноеЗначение(
				"Справочник.ВидыКонтактнойИнформации.EMailЛичныеДанныеКандидатов") Тогда
				ПараметрыПоискаКандидатов.Email = ЭлементКИ.Представление;
			ИначеЕсли ЭлементКИ.Вид = ПредопределенноеЗначение(
				"Справочник.ВидыКонтактнойИнформации.ТелефонЛичныеДанныеКандидатов") Тогда
				ПараметрыПоискаКандидатов.Телефон = ЭлементКИ.Представление;
			КонецЕсли;
		КонецЦикла;
		Прервать;
	КонецЦикла;
	
	ПараметрыПроверки = ПодборПерсоналаВызовСервера.ПодобратьПохожихКандидатов(ПараметрыПоискаКандидатов);
		
	Возврат ПараметрыПроверки;
	
КонецФункции

&НаКлиенте
Процедура ОбработатьСтрокуТаблицыФайлов(Индекс = 0)
	
	Если Индекс = 0 Тогда
		ОчиститьСообщения();
		РезультатЗагрузки = Новый Структура();
		РезультатЗагрузки.Вставить("Обработано", 0);
		РезультатЗагрузки.Вставить("СозданоЛичныхДанныхКандидатов", 0);
		РезультатЗагрузки.Вставить("СозданоКандидатов", 0);
		РезультатЗагрузки.Вставить("ОбновленоКандидатов", 0);
		РезультатЗагрузки.Вставить("ОбновленоФизическихЛиц", 0);
		РезультатЗагрузки.Вставить("КоличествоОшибок", 0);
		РезультатЗагрузки.Вставить("ТекстОшибок", "");
		РезультатЗагрузки.Вставить("Кандидаты", Новый Массив());
		РезультатЗагрузки.Вставить("Вакансии", Новый Массив());
	КонецЕсли;
	
	Если ТаблицаФайлов.Количество() = Индекс Тогда
		ПоказатьОповещениеОЗавершении(РезультатЗагрузки);
		ДляОповещения = Новый Структура();
		ДляОповещения.Вставить("Кандидаты", РезультатЗагрузки.Кандидаты);
		ДляОповещения.Вставить("Вакансии", РезультатЗагрузки.Вакансии);
		ОбщегоНазначенияКлиент.ОповеститьОбИзмененииОбъектов(РезультатЗагрузки.Кандидаты, ДляОповещения);
		Ид = ТаблицаФайлов.Количество();
		Пока Ид > 0 Цикл
			Ид = Ид - 1;
			ТекСтрока = ТаблицаФайлов[Ид];
			Если ТекСтрока.Обработан Тогда
				ТаблицаФайлов.Удалить(ТаблицаФайлов.Индекс(ТекСтрока));
			КонецЕсли;
		КонецЦикла;
		Если ТаблицаФайлов.Количество() = 0 И ЗакрытьФормуПослеЗагрузкиКандидатов Тогда
			Закрыть();
		КонецЕсли;
		УстановитьДоступностьКнопкиЗагрузки();
		УстановитьОтбор();
		Возврат;
	КонецЕсли;
		
	КоличествоФайловВходящих = ТаблицаФайлов.Количество();
	ТекущаяСтрока = ТаблицаФайлов[Индекс];
	Состояние(НСтр("ru = 'Загрузка файлов резюме в базу...'"), 
		(Индекс + 1) / КоличествоФайловВходящих * 100, ТекущаяСтрока.ПутьКФайлу);
	
	Если ТекущаяСтрока.ДоступноДляЗагрузки И (Не ТекущаяСтрока.Обработан) Тогда
		РезультатЗагрузки.Обработано = РезультатЗагрузки.Обработано + 1;
		СоздатьОбновитьКандидата(ТекущаяСтрока, Ложь, Индекс);
	Иначе
		ОбработатьСтрокуТаблицыФайлов(Индекс + 1);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПоказатьОповещениеОЗавершении(Результат)

	ТекстСообщения = "";
	Если Результат.Обработано > 0 Тогда
		ДобавитьТекстСообщения(ТекстСообщения, 
			СообщениеСЧислом(
				НСтр("ru = ';Загружен %1 файл;;Загружено %1 файла;Загружено %1 файлов;Загружено %1 файла'"), 
				Результат.Обработано));
	КонецЕсли;
	Если Результат.СозданоКандидатов > 0 Тогда
		ДобавитьТекстСообщения(ТекстСообщения, 
			СообщениеСЧислом(
				НСтр("ru = ';Создан %1 кандидат;;Создано %1 кандидата;Создано %1 кандидатов;Создано %1 кандидата'"), 
				Результат.СозданоКандидатов));
	КонецЕсли;
	Если Результат.ОбновленоКандидатов > 0 Тогда
		ДобавитьТекстСообщения(ТекстСообщения, 
			СообщениеСЧислом(
				НСтр("ru = ';Обновлен %1 кандидат;;Обновлено %1 кандидата;Обновлено %1 кандидатов;Обновлено %1 кандидата'"), 
				Результат.ОбновленоКандидатов));
	КонецЕсли;
	Если Результат.КоличествоОшибок > 0 Тогда
		ДобавитьТекстСообщения(ТекстСообщения, 
			СообщениеСЧислом(
				НСтр("ru = ';Обнаружена %1 ошибка;;Обнаружено %1 ошибки;Обнаружено %1 ошибок;Обнаружено %1 ошибки'"), 
				Результат.КоличествоОшибок));
	КонецЕсли;
	Если Результат.ТекстОшибок <> "" Тогда
		ДобавитьТекстСообщения(ТекстСообщения, 
			СтрШаблон(НСтр("ru = 'Ошибки:
						   |%1.'"), Результат.ТекстОшибок));
	КонецЕсли;
	
	Кнопки = Новый СписокЗначений();
	Кнопки.Добавить(КодВозвратаДиалога.ОК);
	
	ПараметрыПредупреждения = СтандартныеПодсистемыКлиент.ПараметрыВопросаПользователю();
	ПараметрыПредупреждения.Заголовок = НСтр("ru = 'Загрузка резюме завершена'");
	ПараметрыПредупреждения.Картинка = БиблиотекаКартинок.Информация32;
	ПараметрыПредупреждения.ПредлагатьБольшеНеЗадаватьЭтотВопрос = Ложь;
	
	СтандартныеПодсистемыКлиент.ПоказатьВопросПользователю(, ТекстСообщения, Кнопки, ПараметрыПредупреждения);
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьТекстСообщения(ТекстСообщения, Добавить)
	Если Не ПустаяСтрока(ТекстСообщения) Тогда
		ТекстСообщения = ТекстСообщения + Символы.ПС;
	КонецЕсли;
	ТекстСообщения = ТекстСообщения + Добавить;
КонецПроцедуры

&НаКлиенте
Функция СообщениеСЧислом(Шаблон, Число)
	Возврат СтроковыеФункцииКлиентСервер.СтрокаСЧисломДляЛюбогоЯзыка(Шаблон, Число);
КонецФункции

&НаКлиенте
Функция РезюмеДоступноДляАвтоматическойЗагрузки(ДанныеРезюме)
	
	Результат = Истина;
	
	Результат = (Результат И (ДанныеРезюме.ЭтоНовыеЛичныеДанныеКандидата
		ИЛИ ЗначениеЗаполнено(ДанныеРезюме.ЛичныеДанныеКандидата)));
	Результат = (Результат И (ДанныеРезюме.ЭтоНовыйКандидат Или ЗначениеЗаполнено(ДанныеРезюме.Кандидат)));
	Результат = (Результат И (Не ДанныеРезюме.ЕстьДубль));
	Результат = (Результат И ЗначениеЗаполнено(ДанныеРезюме.Подразделение));
	
	Если ИспользоватьГруппыДоступа Тогда
		Результат = (Результат И ЗначениеЗаполнено(ДанныеРезюме.ГруппаДоступа));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

&НаСервереБезКонтекста
Функция КандидатыПоЛичнымДаннымКандидата(ЛичныеДанныеКандидата, Вакансия, Подразделение)
	
	Отбор = Новый Структура("ЛичныеДанные", ЛичныеДанныеКандидата);
	
	Если ЗначениеЗаполнено(Вакансия) Тогда
		Отбор.Вставить("Вакансия", Вакансия);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(Подразделение) Тогда
		Отбор.Вставить("Подразделение", Подразделение);
	КонецЕсли;
	
	Кандидаты = Справочники.Кандидаты.КандидатыПоОтбору(Отбор);
	
	Возврат Кандидаты;
	
КонецФункции

&НаСервереБезКонтекста
Функция ДанныеВакансии(Вакансия)
	Возврат Справочники.Вакансии.ДанныеВакансии(Вакансия);
КонецФункции

&НаСервереБезКонтекста
Функция ДанныеКандидата(Кандидат) 
	Возврат Справочники.Кандидаты.ДанныеКандидата(Кандидат);
КонецФункции

&НаКлиенте
Процедура ОткрытьФормуПроверкиОднофамильцев(ТекущаяСтрока)
	
	ПараметрыПроверки = ПараметрыПроверкиПохожихКандидатов(ТекущаяСтрока, ТекущаяСтрока.СтруктураРезюме);
	Если ПараметрыПроверки.КандидатУникален Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыОткрытия = СотрудникиКлиент.ПараметрыОткрытияФормыФизическиеЛицаСПохожимиДанными(ПараметрыПроверки);
	ПараметрыОткрытия.УчитыватьОтрицательныйВыбор = Истина;
	
	ОткрытьФорму(
		"Справочник.ФизическиеЛица.Форма.ФизическиеЛицаСПохожимиДанными", 
		ПараметрыОткрытия, 
		ЭтотОбъект, , , , 
		Новый ОписаниеОповещения("ПроверкаОднофамильцевЗавершение", ЭтотОбъект), 
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверкаОднофамильцевЗавершение(РезультатВыбора, ДополнительныеПараметры) Экспорт 
	
	Если РезультатВыбора = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяСтрока = ТаблицаФайлов.НайтиПоИдентификатору(Элементы.ТаблицаФайлов.ТекущаяСтрока);
	
	Если ТипЗнч(РезультатВыбора) = Тип("Булево") Тогда
		ТекущаяСтрока.ЭтоНовыеЛичныеДанныеКандидата = Не РезультатВыбора;
		ТекущаяСтрока.ЛичныеДанныеКандидата = Неопределено;
	Иначе	
		ТекущаяСтрока.ЭтоНовыеЛичныеДанныеКандидата = РезультатВыбора.Пустая();
		ТекущаяСтрока.ЛичныеДанныеКандидата = РезультатВыбора;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ТекущаяСтрока.ЛичныеДанныеКандидата) Тогда
		Если ИспользоватьГруппыДоступа Тогда
			ТекущаяСтрока.ГруппаДоступа = ГруппаДоступаКандидата(ТекущаяСтрока.ЛичныеДанныеКандидата);
		КонецЕсли;
		ЗаполнитьКандидата(ТекущаяСтрока);
	Иначе
		ТекущаяСтрока.Кандидат = Неопределено;
		ТекущаяСтрока.ЭтоНовыйКандидат = Истина;
	КонецЕсли;
	
	ПроверитьНаДубли();
	ТекущаяСтрока.ДоступноДляЗагрузки = РезюмеДоступноДляАвтоматическойЗагрузки(ТекущаяСтрока);
	УстановитьОтбор();
	УстановитьДоступностьКнопкиЗагрузки();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьРезультатВыбораКандидата(РезультатВыбора, ДополнительныеПараметры)
	
	Если РезультатВыбора = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяСтрока = ТаблицаФайлов.НайтиПоИдентификатору(Элементы.ТаблицаФайлов.ТекущаяСтрока);
	
	Если РезультатВыбора.Пустая() Тогда
		ТекущаяСтрока.ЭтоНовыйКандидат = Истина;
	Иначе
		ТекущаяСтрока.Кандидат = РезультатВыбора;
		ДанныеКандидата = ДанныеКандидата(ТекущаяСтрока.Кандидат);
		ТекущаяСтрока.Вакансия = ДанныеКандидата.Вакансия;
		ТекущаяСтрока.Подразделение = ДанныеКандидата.Подразделение;
		ТекущаяСтрока.ЛичныеДанные = ДанныеКандидата.ЛичныеДанныеКандидата;
	КонецЕсли;
	
	ПроверитьНаДубли();
	ТекущаяСтрока.ДоступноДляЗагрузки = РезюмеДоступноДляАвтоматическойЗагрузки(ТекущаяСтрока);
	УстановитьОтбор();
	УстановитьДоступностьКнопкиЗагрузки();
	
КонецПроцедуры

&НаКлиенте
Процедура СоздатьОбновитьКандидата(ТекущаяСтрока, Интерактивно = Истина, Индекс = 0)
	
	ДополнительныеПараметры = Новый Структура;
	ДополнительныеПараметры.Вставить("ДанныеРезюме", ТекущаяСтрока);
	ДополнительныеПараметры.Вставить("Интерактивно", Интерактивно);
	ДополнительныеПараметры.Вставить("Индекс", Индекс);
	
	МассивФайлов = Новый Массив();
	МассивФайлов.Добавить(Новый ОписаниеПередаваемогоФайла(ТекущаяСтрока.ПутьКФайлу, ТекущаяСтрока.АдресФайла));
	
	Если ЗначениеЗаполнено(ТекущаяСтрока.АдресФайла) Тогда
		ЗакончитьСозданиеКандидатаПослеПомещенияФайлов(МассивФайлов, ДополнительныеПараметры);
		Возврат;
	КонецЕсли;
	
	Если Не РаботаСФайламиСлужебныйКлиент.РасширениеРаботыСФайламиПодключено() Тогда
		// Веб-клиент без расширения для работы с файлами.
		Попытка
			НачатьПомещениеФайлаНаСервер(
				Новый ОписаниеОповещения("ЗакончитьСозданиеКандидатаПослеПомещенияФайла", ЭтотОбъект,
					ДополнительныеПараметры),
				, , , ТекущаяСтрока.ПутьКФайлу, УникальныйИдентификатор);
			Возврат;
		Исключение
			ТекстПредупреждения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				НСтр("ru = 'Не удалось загрузить файл на сервер по причине:
					|%1'"), ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			Если Интерактивно Тогда
				ПоказатьПредупреждение(, ТекстПредупреждения);
			Иначе
				РезультатЗагрузки.КоличествоОшибок = РезультатЗагрузки.КоличествоОшибок + 1;
				РезультатЗагрузки.ТекстОшибок = РезультатЗагрузки.ТекстОшибок + Символы.ПС + ТекстПредупреждения;
				ОбработатьСтрокуТаблицыФайлов(Индекс + 1);
			КонецЕсли;
			Возврат;
		КонецПопытки;
	КонецЕсли;
	
	Попытка
		НачатьПомещениеФайловНаСервер(
			Новый ОписаниеОповещения("ЗакончитьСозданиеКандидатаПослеПомещенияФайла", ЭтотОбъект,
				ДополнительныеПараметры),
			, , МассивФайлов, УникальныйИдентификатор);
	Исключение
		ТекстПредупреждения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
			НСтр("ru = 'Не удалось загрузить файл на сервер по причине:
				|%1'"), ОбработкаОшибок.КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		Если Интерактивно Тогда
			ПоказатьПредупреждение(, ТекстПредупреждения);
		Иначе
			РезультатЗагрузки.КоличествоОшибок = РезультатЗагрузки.КоличествоОшибок + 1;
			РезультатЗагрузки.ТекстОшибок = РезультатЗагрузки.ТекстОшибок + Символы.ПС + ТекстПредупреждения;
			ОбработатьСтрокуТаблицыФайлов(Индекс + 1);
		КонецЕсли;
	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакончитьСозданиеКандидатаПослеПомещенияФайла(Результат, Адрес, ПолныйПуть, Параметры) Экспорт
	
	ПомещенныеФайлыКандидата = Новый Массив();
	
	Если Результат Тогда
		ПомещенныеФайлыКандидата.Добавить(Новый ОписаниеПередаваемогоФайла(ПолныйПуть, Адрес));
	КонецЕсли;
	
	ЗакончитьСозданиеКандидатаПослеПомещенияФайлов(ПомещенныеФайлыКандидата, Параметры);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗакончитьСозданиеКандидатаПослеПомещенияФайлов(ПомещенныеФайлыКандидата, ПараметрыЗагрузки) Экспорт
	
	Если ПомещенныеФайлыКандидата = Неопределено Или ПомещенныеФайлыКандидата.Количество() = 0 Тогда
		Если ПараметрыЗагрузки.Интерактивно Тогда
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
									НСтр("ru = 'Загрузка файла ""%1"" не выполнена.'"),
									ПараметрыЗагрузки.ДанныеРезюме.ПутьКФайлу);
		Иначе
			ТекстСообщения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
									НСтр("ru = 'Строка %1. Загрузка файла ""%2"" не выполнена.'"),
									ПараметрыЗагрузки.Индекс + 1,
									ПараметрыЗагрузки.ДанныеРезюме.ПутьКФайлу);
		КонецЕсли;
		
		Если ПараметрыЗагрузки.Интерактивно Тогда
			ПоказатьПредупреждение(, ТекстСообщения);
		Иначе
			РезультатЗагрузки.КоличествоОшибок = РезультатЗагрузки.КоличествоОшибок + 1;
			РезультатЗагрузки.ТекстОшибок = РезультатЗагрузки.ТекстОшибок + Символы.ПС + ТекстСообщения;
			ОбработатьСтрокуТаблицыФайлов(ПараметрыЗагрузки.Индекс + 1);
		КонецЕсли;
		Возврат;
	КонецЕсли;
	
	ФайлРезюмеПараметры = ПомещенныеФайлыКандидата[0];
	
	ДанныеКандидата = ПараметрыЗагрузки.ДанныеРезюме.СтруктураРезюме;
	ДанныеКандидата.Вакансия = ПараметрыЗагрузки.ДанныеРезюме.Вакансия;
	ДанныеКандидата.Подразделение = ПараметрыЗагрузки.ДанныеРезюме.Подразделение;
	ДанныеКандидата.ЛичныеДанныеКандидата = ПараметрыЗагрузки.ДанныеРезюме.ЛичныеДанныеКандидата;
	ДанныеКандидата.ГруппаДоступаКандидата = ПараметрыЗагрузки.ДанныеРезюме.ГруппаДоступа;
	
	ПараметрыРезюме = Новый Структура();
	ПараметрыРезюме.Вставить("ДанныеКандидата", ДанныеКандидата);
		
	Если ЗначениеЗаполнено(ПараметрыЗагрузки.ДанныеРезюме.Кандидат) Тогда
		ПараметрыРезюме.Вставить("Ключ", ПараметрыЗагрузки.ДанныеРезюме.Кандидат);
	КонецЕсли;
	
	Если ПараметрыЗагрузки.Интерактивно Тогда
		ОткрытьФорму("Справочник.Кандидаты.Форма.ФормаЭлемента", ПараметрыРезюме, ЭтотОбъект, ФайлРезюмеПараметры.Имя);
		Возврат;
	КонецЕсли;
		
	Результат = СоздатьРезюмеНаСервере(ДанныеКандидата, ПараметрыЗагрузки.ДанныеРезюме.Кандидат);
		
	Если Результат.ОК Тогда
		ПараметрыЗагрузки.ДанныеРезюме.Обработан = Истина;
		ПараметрыЗагрузки.ДанныеРезюме.ЛичныеДанныеКандидата = Результат.ДанныеКандидата.ЛичныеДанныеКандидата;
		ПараметрыЗагрузки.ДанныеРезюме.Кандидат = Результат.ДанныеКандидата.Кандидат;
		ПараметрыЗагрузки.ДанныеРезюме.Вакансия = Результат.ДанныеКандидата.Вакансия;
		ПараметрыЗагрузки.ДанныеРезюме.Подразделение = Результат.ДанныеКандидата.Подразделение;
		Если ПараметрыЗагрузки.ДанныеРезюме.ЭтоНовыйКандидат = Истина Тогда
			РезультатЗагрузки.СозданоКандидатов = РезультатЗагрузки.СозданоКандидатов + 1;
		Иначе
			РезультатЗагрузки.ОбновленоКандидатов = РезультатЗагрузки.ОбновленоКандидатов + 1;
		КонецЕсли;
		Если ПараметрыЗагрузки.ДанныеРезюме.ЭтоНовыеЛичныеДанныеКандидата = Истина Тогда
			РезультатЗагрузки.СозданоЛичныхДанныхКандидатов = РезультатЗагрузки.СозданоЛичныхДанныхКандидатов + 1;
		Иначе
			РезультатЗагрузки.ОбновленоФизическихЛиц = РезультатЗагрузки.ОбновленоФизическихЛиц + 1;
		КонецЕсли;
		ПараметрыЗагрузки.ДанныеРезюме.ЭтоНовыйКандидат = Ложь;
		ПараметрыЗагрузки.ДанныеРезюме.ЭтоНовыеЛичныеДанныеКандидата = Ложь;
		ПараметрыЗагрузки.ДанныеРезюме.ДоступноДляЗагрузки = РезюмеДоступноДляАвтоматическойЗагрузки(
			ПараметрыЗагрузки.ДанныеРезюме);
		РезультатЗагрузки.Кандидаты.Добавить(Результат.ДанныеКандидата.Кандидат);
		РезультатЗагрузки.Вакансии.Добавить(Результат.ДанныеКандидата.Вакансия);
	Иначе
		ТекстСообщения = СтрШаблон(
			НСтр("ru = 'Строка %1. При загрузке резюме возникла ошибка:
				 |%2'"), ПараметрыЗагрузки.Индекс + 1, Результат.ОписаниеОшибки);
		РезультатЗагрузки.КоличествоОшибок = РезультатЗагрузки.КоличествоОшибок + 1;
		РезультатЗагрузки.ТекстОшибок = РезультатЗагрузки.ТекстОшибок + Символы.ПС + ТекстСообщения;
	КонецЕсли;
	
	ОбработатьСтрокуТаблицыФайлов(ПараметрыЗагрузки.Индекс + 1);

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьРезультатВопросаОЗакрытииФормы(РезультатВопроса, Параметры) Экспорт
	
	Если РезультатВопроса = КодВозвратаДиалога.Нет Тогда
		ВсеРавноЗакрытьФорму = Истина;
		Закрыть();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьВакансиюПродолжение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторыРезюмеКОбработке = Элементы.ТаблицаФайлов.ВыделенныеСтроки;
	Для Каждого ИдентификаторСтроки Из ИдентификаторыРезюмеКОбработке Цикл
		ТекущиеДанные = ТаблицаФайлов.НайтиПоИдентификатору(ИдентификаторСтроки);
		Если ТекущиеДанные.Обработан = Истина Тогда
			Продолжить;
		КонецЕсли;
		СброситьКандидата = (ТекущиеДанные.Вакансия <> Результат);
		ТекущиеДанные.Вакансия = Результат;
		ОбработатьСтрокуПриИзмененииВакансии(ТекущиеДанные, СброситьКандидата);
	КонецЦикла;

	ПроверитьНаДубли();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьПодразделениеПродолжение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Возврат;
	КонецЕсли;
		
	ИдентификаторыРезюмеКОбработке = Элементы.ТаблицаФайлов.ВыделенныеСтроки;
	Для Каждого ИдентификаторСтроки Из ИдентификаторыРезюмеКОбработке Цикл
		ТекущиеДанные = ТаблицаФайлов.НайтиПоИдентификатору(ИдентификаторСтроки);
		Если ТекущиеДанные.Обработан = Истина Тогда
			Продолжить;
		КонецЕсли;
		СброситьКандидата = (ТекущиеДанные.Подразделение <> Результат);
		ТекущиеДанные.Подразделение = Результат;
		ОбработатьСтрокуПриИзмененииПодразделения(ТекущиеДанные, СброситьКандидата);
	КонецЦикла;
	
	ПроверитьНаДубли();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьГруппуДоступаПродолжение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Не ЗначениеЗаполнено(Результат) Тогда
		Возврат;
	КонецЕсли;
		
	ИдентификаторыРезюмеКОбработке = Элементы.ТаблицаФайлов.ВыделенныеСтроки;
	Для Каждого ИдентификаторСтроки Из ИдентификаторыРезюмеКОбработке Цикл
		ТекущиеДанные = ТаблицаФайлов.НайтиПоИдентификатору(ИдентификаторСтроки);
		Если ТекущиеДанные.Обработан = Истина Тогда
			Продолжить;
		КонецЕсли;
		ТекущиеДанные.ГруппаДоступа = Результат;
		ТекущиеДанные.ДоступноДляЗагрузки = РезюмеДоступноДляАвтоматическойЗагрузки(ТекущиеДанные);
		УстановитьОтбор();
		УстановитьДоступностьКнопкиЗагрузки();
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуКандидата(ДанныеРезюме)
	
	Если Не ЗначениеЗаполнено(ДанныеРезюме.Кандидат) Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыРезюме = Новый Структура();
	ПараметрыРезюме.Вставить("Ключ", ДанныеРезюме.Кандидат);
	
	ОткрытьФорму(
		"Справочник.Кандидаты.Форма.ФормаЭлемента", 
		ПараметрыРезюме, 
		ЭтотОбъект, 
		Истина, , , ,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьСтрокуПриИзмененииВакансии(ТекущиеДанные, СброситьКандидата)
	
	ДанныеВакансии = ДанныеВакансии(ТекущиеДанные.Вакансия);
	ПодразделениеРезультат = ДанныеВакансии.Подразделение;
	
	Если ТекущиеДанные.Подразделение <> ПодразделениеРезультат Тогда
		СброситьКандидата = Истина;
	КонецЕсли;
	
	ТекущиеДанные.Подразделение = ПодразделениеРезультат;
	
	Если СброситьКандидата Тогда
		Если ЗначениеЗаполнено(ТекущиеДанные.ЛичныеДанныеКандидата) Тогда
			ЗаполнитьКандидата(ТекущиеДанные);
		Иначе
			ТекущиеДанные.Кандидат = Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	ТекущиеДанные.ДоступноДляЗагрузки = РезюмеДоступноДляАвтоматическойЗагрузки(ТекущиеДанные);
	УстановитьОтбор();
	УстановитьДоступностьКнопкиЗагрузки();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьСтрокуПриИзмененииПодразделения(ТекущиеДанные, СброситьКандидата)
	
	Если СброситьКандидата Тогда
		ТекущиеДанные.Вакансия = Неопределено;
		Если ЗначениеЗаполнено(ТекущиеДанные.ЛичныеДанныеКандидата) Тогда
			ЗаполнитьКандидата(ТекущиеДанные);
		Иначе
			ТекущиеДанные.Кандидат = Неопределено;
		КонецЕсли;
	КонецЕсли;
	
	ТекущиеДанные.ДоступноДляЗагрузки = РезюмеДоступноДляАвтоматическойЗагрузки(ТекущиеДанные);
	УстановитьОтбор();
	УстановитьДоступностьКнопкиЗагрузки();
	
КонецПроцедуры

&НаКлиенте
Функция ЕстьНеЗаписанныеИзменения()
	
	Результат = Ложь;
	
	Для Каждого ТекСтрока Из ТаблицаФайлов Цикл
		Если Не ТекСтрока.Обработан Тогда
			Результат = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ПроверитьНаДубли()
	
	Для Каждого ТекущиеДанные Из ТаблицаФайлов Цикл
		ОтборСтрок = Новый Структура("ФИО, ЛичныеДанныеКандидата, ЭтоНовыеЛичныеДанныеКандидата");
		ОтборСтрок.ФИО = ТекущиеДанные.ФИО;
		ОтборСтрок.ЛичныеДанныеКандидата = ТекущиеДанные.ЛичныеДанныеКандидата;
		ОтборСтрок.ЭтоНовыеЛичныеДанныеКандидата = Не ЗначениеЗаполнено(ТекущиеДанные.ЛичныеДанныеКандидата);
		НайденныеСтроки = ТаблицаФайлов.НайтиСтроки(ОтборСтрок);
		ТекущиеДанные.ЕстьДубль = (НайденныеСтроки.Количество() > 1);
		ТекущиеДанные.ДоступноДляЗагрузки = РезюмеДоступноДляАвтоматическойЗагрузки(ТекущиеДанные);
	КонецЦикла;
	
	УстановитьОтбор();
	УстановитьДоступностьКнопкиЗагрузки();	
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьКандидата(СтрокаРезюме)

	НайденныеКандидаты = КандидатыПоЛичнымДаннымКандидата(СтрокаРезюме.ЛичныеДанныеКандидата, СтрокаРезюме.Вакансия,
		СтрокаРезюме.Подразделение);
	СтрокаРезюме.ЭтоНовыйКандидат = (НайденныеКандидаты.Количество() = 0);
	Если НайденныеКандидаты.Количество() = 1 Тогда
		СтрокаРезюме.Кандидат = НайденныеКандидаты[0];
		ДанныеКандидата = ДанныеКандидата(СтрокаРезюме.Кандидат);
		СтрокаРезюме.Вакансия = ДанныеКандидата.Вакансия;
		СтрокаРезюме.Подразделение = ДанныеКандидата.Подразделение;
	Иначе
		СтрокаРезюме.Кандидат = Неопределено;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ГруппаДоступаКандидата(ЛичныеДанныеКандидата)
	Возврат ОбщегоНазначения.ЗначениеРеквизитаОбъекта(ЛичныеДанныеКандидата, "ГруппаДоступа");
КонецФункции

&НаСервереБезКонтекста
Функция СоздатьРезюмеНаСервере(ДанныеКандидата, КандидатСсылка)
	
	Результат = Новый Структура();
	Результат.Вставить("ОК", Истина);
	Результат.Вставить("ДанныеКандидата", Новый Структура());
	Результат.Вставить("ОписаниеОшибки", "");
	
	Если ЗначениеЗаполнено(КандидатСсылка) Тогда
		КандидатОбъект = КандидатСсылка.ПолучитьОбъект();
	Иначе
		КандидатОбъект = Справочники.Кандидаты.СоздатьЭлемент();
	КонецЕсли;
	
	КандидатОбъект.Заполнить(ДанныеКандидата);
	
	НачатьТранзакцию();
	Попытка
		КандидатОбъект.Записать();
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		Результат.ОК = Ложь;
		Результат.ОписаниеОшибки = ОписаниеОшибки();
		Возврат Результат;
	КонецПопытки;
	
	Результат.ДанныеКандидата.Вставить("ЛичныеДанныеКандидата", КандидатОбъект.ЛичныеДанные);
	Результат.ДанныеКандидата.Вставить("Кандидат", КандидатОбъект.Ссылка);
	Результат.ДанныеКандидата.Вставить("Вакансия", КандидатОбъект.Вакансия);
	Результат.ДанныеКандидата.Вставить("Подразделение", КандидатОбъект.Подразделение);

	Возврат Результат;
	
КонецФункции

#КонецОбласти