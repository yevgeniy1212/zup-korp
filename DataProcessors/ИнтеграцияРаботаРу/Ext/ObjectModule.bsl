Процедура ЗагрузитьКомментарииКандидата(Кандидат, ДанныеРезюме) Экспорт
	
	ОтборСтрок = Новый Структура();
	ОтборСтрок.Вставить("МестоПубликации", Сайт);
	ОтборСтрок.Вставить("ИмяПоля", "id");
	
	НайденныеСтроки = ДанныеРезюме.НайтиСтроки(ОтборСтрок);
	Если НайденныеСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторРезюме = НайденныеСтроки[0].СодержимоеПоля;
	
	Комментарии = КомментарииКандидата(ИдентификаторРезюме, Кандидат);
	
	РекрутинговыеСайтыСлужебный.ЗаписатьТаблицуКомментариевКандидата(Комментарии, Кандидат, Сайт);
	
КонецПроцедуры

Функция УточнитьОписаниеОшибки(КодСостояния, ОписаниеОшибки) Экспорт
	
	УточненноеОписаниеОшибки = "";
	
	Если СтрНайти(ОписаниеОшибки, "phoneContainerNumber") <> 0 Тогда
		Поле = РекрутинговыеСайтыСлужебный.ПредставлениеПоля(Сайт, ЭтотОбъект, "phones");
		УточненноеОписаниеОшибки =
			РекрутинговыеСайтыСлужебный.ОписаниеНезаполненногоПоля(Поле, ОписаниеНеверногоНомераТелефона());
	КонецЕсли;
	
	Если СтрНайти(ОписаниеОшибки, "vacancy_workplace") <> 0 Тогда
		Поле = РекрутинговыеСайтыСлужебный.ПредставлениеПоля(Сайт, ЭтотОбъект, "address");
		УточненноеОписаниеОшибки = УточненноеОписаниеОшибки
			+ ?(ЗначениеЗаполнено(УточненноеОписаниеОшибки), Символы.ПС, "")
			+ РекрутинговыеСайтыСлужебный.ОписаниеНезаполненногоПоля(Поле, ОписаниеНеверногоАдресаРаботы());
	КонецЕсли;
		
	Если Не ЗначениеЗаполнено(УточненноеОписаниеОшибки) И КодСостояния = 500 Тогда
		Ошибка = ПарсерJSON(ОписаниеОшибки, Истина).Получить("error");
		Если Ошибка <> Неопределено И Ошибка.Получить("message") <> Неопределено Тогда
			УточненноеОписаниеОшибки = Ошибка.Получить("message");
		КонецЕсли;
	КонецЕсли;
	
	Возврат УточненноеОписаниеОшибки;
	
КонецФункции

