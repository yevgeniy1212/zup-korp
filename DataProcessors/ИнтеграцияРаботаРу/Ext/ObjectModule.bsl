	Поля = Новый Массив;
	Поля.Добавить("offerTrades");
	Поля.Добавить("region");
	
	Возврат Новый ФиксированныйМассив(Поля);
	
КонецФункции

Функция ПоляВакансииСоСпециальнойФормойРедактированияСписка()
	
	Поля = Новый Массив;
	Поля.Добавить("phones");
	Поля.Добавить("language");
	
	Возврат Новый ФиксированныйМассив(Поля);
	
КонецФункции

Функция ПоляВакансииСМножественнымВыборомИзСписка()
	
	Поля = Новый Массив;
	Поля.Добавить("address");
