Функция ВыполнитьHTTPЗапрос(Метод, Запрос, ВызыватьИсключение = Истина) Экспорт
	
	Возврат РекрутинговыеСайтыСлужебный.ВыполнитьHTTPЗапрос(Соединение, Метод, Запрос, ВызыватьИсключение);
	
КонецФункции

Функция СтруктураМаркеров()
	
	СтруктураМаркеров = РекрутинговыеСайтыСлужебный.НоваяСтруктураМаркеров();
	
	СоединениеАутентификации = РекрутинговыеСайтыСлужебный.НовоеHTTPСоединение(АдресСервера(), Истина);
	
	Запрос = НовыйHTTPЗапрос(СтрШаблон("login?mail=%1", ИмяПользователя));
	
	РезультатЗапроса = РекрутинговыеСайтыСлужебный.ВыполнитьHTTPЗапрос(
		СоединениеАутентификации, МетодыЗапросов().Получить, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		РекрутинговыеСайтыСлужебный.СообщитьОбОшибкеАвторизации(Сайт, ЭтотОбъект, РезультатЗапроса);
	Иначе
		Ключ = ПарсерJSON(РезультатЗапроса.ТелоОтвета).key;
		
		ПараметрыЗапроса = Новый Структура;
		ПараметрыЗапроса.Вставить("mail", ИмяПользователя);
		ПараметрыЗапроса.Вставить("key", Ключ);
		ПараметрыЗапроса.Вставить("raw_password", Пароль);
		
		Запрос = НовыйHTTPЗапрос("login");
		Запрос.УстановитьТелоИзСтроки(РекрутинговыеСайтыСлужебный.ЗаписьJSON(ПараметрыЗапроса));
		
		РезультатЗапроса = РекрутинговыеСайтыСлужебный.ВыполнитьHTTPЗапрос(
			СоединениеАутентификации, МетодыЗапросов().ОтправитьДляОбработки, Запрос);
		
		Если РезультатЗапроса.КодСостояния <> 200 Тогда
			РекрутинговыеСайтыСлужебный.СообщитьОбОшибкеАвторизации(Сайт, ЭтотОбъект, РезультатЗапроса);
		Иначе
			ОтветОбъект = ПрочитатьОтветМаркерыДоступа(РезультатЗапроса);
			
			СтруктураМаркеров.МаркерДоступа = ОтветОбъект.sessionId;
			СтруктураМаркеров.ДатаОкончанияДействияМаркераДоступа = ТекущаяДатаСеанса() + 1800;
	
			МаркерДоступа = СтруктураМаркеров.МаркерДоступа;
			ДатаОкончанияДействияМаркераДоступа = СтруктураМаркеров.ДатаОкончанияДействияМаркераДоступа;
		КонецЕсли;
	КонецЕсли;
	
	Возврат СтруктураМаркеров;
	
КонецФункции

Функция МаркерАктивен()
	
	МаркерАктивен = ЗначениеЗаполнено(МаркерДоступа)
			И ДатаОкончанияДействияМаркераДоступа > ТекущаяДатаСеанса();
		
	Если Не МаркерАктивен Тогда
		РезультатОбновления = ОбновитьМаркеры();
		Если ЗначениеЗаполнено(РезультатОбновления.МаркерДоступа) Тогда
			МаркерАктивен = Истина;
			РезультатОбновления.Пользователь = Пользователь;
			РекрутинговыеСайтыСлужебный.СохранитьНастройкиАвторизации(РезультатОбновления);
		КонецЕсли;
	КонецЕсли;
	
	Возврат МаркерАктивен;
	
КонецФункции

Функция ОбновитьМаркеры()
	
	Результат = РекрутинговыеСайтыСлужебный.НовыеРеквизитыСайта();
	Результат.Сайт = Сайт;
	
	СтруктураМаркеров = СтруктураМаркеров();
	
	Если ЗначениеЗаполнено(СтруктураМаркеров.МаркерДоступа) Тогда
		Результат.Подключен = Истина;
		
		Результат.МаркерДоступа = СтруктураМаркеров.МаркерДоступа;
		Результат.ДатаОкончанияДействияМаркераДоступа = СтруктураМаркеров.ДатаОкончанияДействияМаркераДоступа;
		
		Результат.ИмяПользователя = ИмяПользователя;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция НовыйHTTPЗапрос(ТекстЗапроса)
	
	Заголовки = Новый Соответствие();
	Заголовки.Вставить("Content-Type", "application/json");
	
	Если ЗначениеЗаполнено(МаркерДоступа) Тогда
		Заголовки.Вставить("X-Authorization", МаркерДоступа);
	КонецЕсли;
	
	Запрос = Новый HTTPЗапрос(СтрШаблон("/v2/%1", ТекстЗапроса), Заголовки);
	
	Возврат Запрос;
	
КонецФункции

