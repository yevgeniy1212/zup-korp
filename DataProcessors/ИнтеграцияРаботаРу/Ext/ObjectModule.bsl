Функция ОпубликоватьВакансию(Дерево) Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией();
	
	ОписаниеВакансииДляПубликацииRabota = JSONОписаниеВакансии(Дерево);
	
	Если Не УстановитьСоединение() Тогда
		Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкойСозданияВакансии(Сайт, ЭтотОбъект);
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос("vacancies");
	Запрос.УстановитьТелоИзСтроки(ОписаниеВакансииДляПубликацииRabota);
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().ОтправитьДляОбработки, Запрос);
	
	Если РезультатЗапроса.КодСостояния = 201 Тогда
		Публикации = ПрочитатьОтветПубликацияВакансии(РезультатЗапроса);
		ИдентификаторВакансии = Публикации[0];
		
		Запрос = НовыйHTTPЗапрос(СтрШаблон("vacancies/%1/content-packages", ИдентификаторВакансии));
		РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
		
		Если РезультатЗапроса.КодСостояния = 200 Тогда
			Тарифы = ПрочитатьОтветТарифы(РезультатЗапроса);
			
			Для Каждого Тариф Из Тарифы Цикл
				Результат.Тарифы.Вставить(Тариф.name, Тариф.id);
			КонецЦикла;
		КонецЕсли;
		
		Результат.ИдентификаторВакансии = ИдентификаторВакансии;
	Иначе
		Результат = РекрутинговыеСайтыСлужебный.РезультатСОшибкойСозданияВакансии(Сайт, ЭтотОбъект, РезультатЗапроса);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПрименитьТарифКВакансии(Идентификатор, Тариф) Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией();
	
	Если Не УстановитьСоединение() Тогда
		Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкойСозданияВакансии(Сайт, ЭтотОбъект);
	КонецЕсли;
	
	ПараметрыЗапроса = Новый Структура;
	ПараметрыЗапроса.Вставить("action", "publish");
	ПараметрыЗапроса.Вставить("periodDays", 14);
	ПараметрыЗапроса.Вставить("hideContact", Ложь);
	ПараметрыЗапроса.Вставить("useTrap", Истина);
	ПараметрыЗапроса.Вставить("contentPackageId", Число(Тариф));
	
	Запрос = НовыйHTTPЗапрос(СтрШаблон("vacancies/%1", Формат(Идентификатор, "ЧГ=0")));
	Запрос.УстановитьТелоИзСтроки(РекрутинговыеСайтыСлужебный.ЗаписьJSON(ПараметрыЗапроса));
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Записать, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 204 Тогда
		Если РезультатЗапроса.КодСостояния = 500 Тогда
			Результат.Успешно = Ложь;
			Результат.ТекстОшибки = НСтр("ru = 'Возможно, выбранный тариф не активирован.'");
		Иначе
			Результат = РекрутинговыеСайтыСлужебный.РезультатСОшибкойПубликацииВакансии(Сайт, ЭтотОбъект, РезультатЗапроса);
		КонецЕсли;
	КонецЕсли;
	
	Результат.ИдентификаторВакансии = Идентификатор;
	
	Возврат Результат;
	
КонецФункции

Функция СписокВыбораПоКлассификатору(Путь) Экспорт
	
	СписокВыбора = Новый СписокЗначений;
	
	Если Не ЗначениеЗаполнено(Путь) Тогда
		Возврат СписокВыбора;
	КонецЕсли;
	
	КлассификаторыRabota = КлассификаторыСайта();
	Если КлассификаторыRabota = Неопределено Или Не КлассификаторыRabota.Свойство(Путь) Тогда
		Возврат СписокВыбора;
	КонецЕсли;
	
	МассивДанных = КлассификаторыRabota[Путь];
	
	Для Каждого ЭлементМассива Из МассивДанных Цикл
		СписокВыбора.Добавить(ЭлементМассива.id, ЭлементМассива.name);
	КонецЦикла;
	
	Возврат СписокВыбора;

КонецФункции

