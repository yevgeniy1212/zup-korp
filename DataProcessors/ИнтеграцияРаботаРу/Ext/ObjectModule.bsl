Функция СвойстваПубликацииВакансииНаСайте(ИдентификаторВакансии) Экспорт
	
	СвойстваПубликации = РекрутинговыеСайтыСлужебный.НовыеСвойстваПубликацииВакансии();
	
	Если Не УстановитьСоединение() Тогда
		Возврат СвойстваПубликации;
	КонецЕсли;
	
	Описание = ОписаниеПубликацииВакансии(ИдентификаторВакансии, Ложь);
	Если ЗначениеЗаполнено(Описание) Тогда
		СвойстваПубликации.Опубликована = Описание.isPublishStatus;
		
		Если СвойстваПубликации.Опубликована Тогда
			СвойстваПубликации.ДатаПубликации = РекрутинговыеСайтыСлужебный.СтрокаВДату(Описание.publishDate);
			СвойстваПубликации.ДатаОбновления = РекрутинговыеСайтыСлужебный.СтрокаВДату(Описание.modifiedDate);
		Иначе
			СвойстваПубликации.ДатаСнятияСПубликации = РекрутинговыеСайтыСлужебный.СтрокаВДату(Описание.modifiedDate);
		КонецЕсли;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат СвойстваПубликации;
	
КонецФункции

