
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОписаниеПеременных

Перем Соединение; // HTTPСоединение

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Функция Подключить(ПолученноеИмяПользователя, ПолученныйПароль) Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыеРеквизитыСайта();
	
	ИмяПользователя = ПолученноеИмяПользователя;
	Пароль = ПолученныйПароль;
	
	СтруктураМаркеров = СтруктураМаркеров();
	
	Если ЗначениеЗаполнено(СтруктураМаркеров.МаркерДоступа) Тогда
		Результат.Подключен = Истина;
		
		Результат.МаркерДоступа = СтруктураМаркеров.МаркерДоступа;
		Результат.ДатаОкончанияДействияМаркераДоступа = СтруктураМаркеров.ДатаОкончанияДействияМаркераДоступа;
		
		Результат.ИмяПользователя = ИмяПользователя;
		Результат.Пароль = Пароль;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПроверитьПодключение() Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыеРеквизитыСайта();
	
	РеквизитыСайта = РекрутинговыеСайтыСлужебный.РеквизитыСайта(Сайт, Пользователь);
	
	Если ЗначениеЗаполнено(РеквизитыСайта) Тогда
		УстановитьПривилегированныйРежим(Истина);
		РеквизитыСайта.Пароль = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(Пользователь, "ПарольRabota");
		УстановитьПривилегированныйРежим(Ложь);
		
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, РеквизитыСайта);
		Результат.Подключен = МаркерАктивен();
		Результат.ИмяПользователя = РеквизитыСайта.ИмяПользователя;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЗагрузитьКлассификаторы() Экспорт
	
	Классификаторы = ПараметрыСеанса.ПараметрыКлиентаНаСервере.Получить("КлассификаторыRabota");
	
	Если Классификаторы <> Неопределено Тогда
		Возврат Классификаторы;
	КонецЕсли;
	
	КлассификаторыRabota = СправочникиWebApi("Rabota");
	
	Если Не ЗначениеЗаполнено(КлассификаторыRabota) Тогда
		Возврат Классификаторы;
	КонецЕсли;
	
	Если Не УстановитьСоединение() Тогда
		Возврат Классификаторы;
	КонецЕсли;
	
	КлассификаторыRabotaНовый = Новый Структура;
	
	Для Каждого КлючИЗначение Из КлассификаторыRabota Цикл
		Запрос = НовыйHTTPЗапрос(КлючИЗначение.Ключ);
		
		РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
		
		Если РезультатЗапроса.КодСостояния <> 200 Тогда
			РекрутинговыеСайтыСлужебный.СообщитьОбОшибкеЗагрузкиКлассификаторов(Сайт, ЭтотОбъект, РезультатЗапроса);
		Иначе
			ОписаниеЭлементов = ПарсерJSON(РезультатЗапроса.ТелоОтвета);
			ОписаниеЭлементовФикс = ОбщегоНазначения.ФиксированныеДанные(ОписаниеЭлементов);
			
			Если КлючИЗначение.Ключ = "offer-trades" Тогда
				НовоеОписаниеЭлементов = Новый Массив;
				
				Для Каждого Элемент Из ОписаниеЭлементовФикс Цикл
					Если Не Элемент.hidden Тогда
						НовоеОписаниеЭлементов.Добавить(Элемент);
					КонецЕсли;
				КонецЦикла;
				
				ОписаниеЭлементовФикс = ОбщегоНазначения.ФиксированныеДанные(НовоеОписаниеЭлементов);
			КонецЕсли;
			
			КлассификаторыRabotaНовый.Вставить(СтрЗаменить(КлючИЗначение.Ключ, "-", "_"), ОписаниеЭлементовФикс);
		КонецЕсли;
	КонецЦикла;
	
	ВариантыОпытаРаботы = Новый Массив;
	ВариантыОпытаРаботы.Добавить(СтруктураДанных(Неопределено, НСтр("ru = 'Не имеет значения'")));
	ВариантыОпытаРаботы.Добавить(СтруктураДанных(-1, НСтр("ru = 'Без опыта'")));
	ВариантыОпытаРаботы.Добавить(СтруктураДанных(0, НСтр("ru = 'Менее года'")));
	ВариантыОпытаРаботы.Добавить(СтруктураДанных(1, НСтр("ru = 'от 1 года'")));
	
	КолВоЛет = 2;
	Пока КолВоЛет < 11 Цикл
		ВариантыОпытаРаботы.Добавить(СтруктураДанных(КолВоЛет, СтрШаблон(НСтр("ru = 'от %1 лет'"), КолВоЛет)));
		КолВоЛет = КолВоЛет + 1;
	КонецЦикла;
	
	КлассификаторыRabotaНовый.Вставить("experience", ОбщегоНазначения.ФиксированныеДанные(ВариантыОпытаРаботы));
	
	ВариантыПола = Новый Массив;
	ВариантыПола.Добавить(СтруктураДанных(Неопределено, НСтр("ru = 'Не важно'")));
	ВариантыПола.Добавить(СтруктураДанных("female", НСтр("ru = 'Женский'")));
	ВариантыПола.Добавить(СтруктураДанных("male", НСтр("ru = 'Мужской'")));
	
	КлассификаторыRabotaНовый.Вставить("gender", ОбщегоНазначения.ФиксированныеДанные(ВариантыПола));
	
	КатегорииПрав = Новый Массив;
	КатегорииПрав.Добавить(СтруктураДанных("A", "A"));
	КатегорииПрав.Добавить(СтруктураДанных("B", "B"));
	КатегорииПрав.Добавить(СтруктураДанных("C", "C"));
	КатегорииПрав.Добавить(СтруктураДанных("D", "D"));
	КатегорииПрав.Добавить(СтруктураДанных("E", "E"));
	
	КлассификаторыRabotaНовый.Вставить("driving_licence", ОбщегоНазначения.ФиксированныеДанные(КатегорииПрав));
	
	Периоды = Новый Массив;
	Периоды.Добавить(СтруктураДанных(-2005, НСтр("ru = 'За все время'")));
	Периоды.Добавить(СтруктураДанных(1, НСтр("ru = 'За последние 24 часа'")));
	Периоды.Добавить(СтруктураДанных(3, НСтр("ru = 'За последние 3 дня'")));
	Периоды.Добавить(СтруктураДанных(7, НСтр("ru = 'За последнюю неделю'")));
	Периоды.Добавить(СтруктураДанных(14, НСтр("ru = 'За последние 2 недели'")));
	Периоды.Добавить(СтруктураДанных(30, НСтр("ru = 'За последний 1 месяц'")));
	Периоды.Добавить(СтруктураДанных(60, НСтр("ru = 'За последние 2 месяца'")));
	
	КлассификаторыRabotaНовый.Вставить("periods", ОбщегоНазначения.ФиксированныеДанные(Периоды));
	
	Классификаторы = Новый ФиксированнаяСтруктура(КлассификаторыRabotaНовый);
	
	ТекущиеПараметры =
		РекрутинговыеСайтыСлужебный.СоответствиеПоФиксированномуСоответствию(ПараметрыСеанса.ПараметрыКлиентаНаСервере);
	ТекущиеПараметры.Вставить("КлассификаторыRabota", Классификаторы);
	
	УстановитьПривилегированныйРежим(Истина);
	ПараметрыСеанса.ПараметрыКлиентаНаСервере = Новый ФиксированноеСоответствие(ТекущиеПараметры);
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Классификаторы;
	
КонецФункции

Процедура НайтиКандидатов(ТаблицаНайденныхКандидатов, СтруктураОтбора, ПараметрыПоиска) Экспорт
	
	НомерСтраницы = ПараметрыПоиска.НомерСтраницы;
	ПолеСортировки = ПараметрыПоиска.ПолеСортировки;
	ВсегоКандидатов = ПараметрыПоиска.ВсегоКандидатов;
	
	СтрокаОтбора = СтрокаОтбора(СтруктураОтбора, НомерСтраницы);
	
	Если Не УстановитьСоединение() Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос("search-resumes/?" + СтрокаОтбора);
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		ВызватьИсключение РекрутинговыеСайтыСлужебный.ТекстОшибкиПоискаРезюме(Сайт, ЭтотОбъект, РезультатЗапроса);
	Иначе
		РезультатПоискаРезюме = ПрочитатьРезультатПоискаКандидатов(РезультатЗапроса);
		
		Если РезультатПоискаРезюме.data = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		ВсегоКандидатов = РезультатПоискаРезюме.count;
		ПараметрыПоиска.ВсегоКандидатов = Мин(Число(ВсегоКандидатов), 2000);
		
		ДозаполнитьТаблицуРезюме(ТаблицаНайденныхКандидатов, РезультатПоискаРезюме, ПолеСортировки);
	КонецЕсли;
	
КонецПроцедуры

Функция ЗаполнитьДеревоКлассификатора(Классификатор, Дерево) Экспорт
	
	Результат = Ложь;
	
	Если Классификатор = "offer_trades" Тогда
		Результат = ЗаполнитьДеревоРубрик(Дерево);
	ИначеЕсли Классификатор = "regions" Или Классификатор = "areas_towns" Тогда
		Результат = ЗаполнитьДеревоРегионов(Дерево);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ЭлементКлассификатора(ИмяСписка, Значение) Экспорт
	
	ЭлементКлассификатора = Неопределено;
	ИмяКлассификатора = "";
	
	ИменаСписковВыбора = РекрутинговыеСайтыСлужебный.ИменаСписковВыбора();
	Если ИмяСписка = ИменаСписковВыбора.Пол Тогда
		ИмяКлассификатора = "gender";
	ИначеЕсли ИмяСписка = ИменаСписковВыбора.УровеньОбразования Тогда
		ИмяКлассификатора = "offer_educations";
	ИначеЕсли ИмяСписка = ИменаСписковВыбора.ПериодРазмещения Тогда
		ИмяКлассификатора = "periods";
	Иначе
		Возврат ЭлементКлассификатора;
	КонецЕсли;
	
	Классификаторы = КлассификаторыСайта();
	
	Классификатор = Классификаторы[ИмяКлассификатора];
	
	Если Не ЗначениеЗаполнено(Классификатор) Тогда
		Возврат ЭлементКлассификатора;
	КонецЕсли;
	
	// АПК:1297-выкл Значения классификаторов, не локализуются.
	СоответствиеЗамены = Новый Соответствие;
	СоответствиеЗамены.Вставить("среднее", "среднее общее");
	// АПК:1297-вкл
	
	Найдено = Ложь;
	Для Каждого Элемент Из Классификатор Цикл
		ЗначениеСравнения = НРег(СокрЛП(Элемент.name));
		
		ЗначениеЗамены = СоответствиеЗамены.Получить(ЗначениеСравнения);
		Если ЗначениеЗаполнено(ЗначениеЗамены) Тогда
			ЗначениеСравнения = ЗначениеЗамены;
		КонецЕсли;
		
		Если ЗначениеСравнения = НРег(Значение) Тогда
			Найдено = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Найдено Тогда
		ЭлементКлассификатора = Элемент.id;
	КонецЕсли;
	
	Возврат ЭлементКлассификатора;
	
КонецФункции

Функция ИдентификаторРезюмеПоАдресу(АдресРезюме) Экспорт
	
	Разделитель = "resume";
	
	ИдентификаторРезюме = СтрЗаменить(АдресРезюме, ".html", "");
	
	Пока РекрутинговыеСайтыКлиентСервер.НайтиВСтроке(ИдентификаторРезюме, Разделитель) > 0 Цикл
		НомерВхожденияРазделителя = 
			РекрутинговыеСайтыКлиентСервер.НайтиВСтроке(ИдентификаторРезюме, Разделитель);
		ИдентификаторРезюме = 
			Сред(ИдентификаторРезюме, 
				НомерВхожденияРазделителя + СтрДлина(Разделитель), 
				СтрДлина(ИдентификаторРезюме) - НомерВхожденияРазделителя);
	КонецЦикла;
	
	Возврат ИдентификаторРезюме;

КонецФункции

Функция ДанныеКандидатаПоРезюмеССайта(ИдентификаторРезюме) Экспорт
	
	ДанныеКандидата = Справочники.Кандидаты.СтруктураДанныхКандидата();
	
	СтруктураРезюме = СтруктураРезюмеССайта(ИдентификаторРезюме);
	
	Если ЗначениеЗаполнено(СтруктураРезюме) Тогда
		ДанныеКандидата = ДанныеКандидатаПоРезюме(СтруктураРезюме);
		
		ДанныеКандидата.Комментарии = ЗначениеСвойстваУзла(СтруктураРезюме, "Комментарии");
		ДанныеКандидата.ДанныеПубликации = СтруктураРезюме;
	Иначе
		ВызватьИсключение РекрутинговыеСайтыСлужебный.ТекстИсключенияПриОшибкеЗагрузкиРезюмеПоСсылке(Сайт);
	КонецЕсли;
	
	Возврат ДанныеКандидата;

КонецФункции

Функция ВакансииССайта(БылиОшибки = Ложь) Экспорт
	
	МассивВакансий = Новый Массив;
	
	Если Не УстановитьСоединение() Тогда
		БылиОшибки = Истина;
		Возврат МассивВакансий;
	КонецЕсли;
	
	ЗагрузитьКлассификаторы();
	
	Запрос = НовыйHTTPЗапрос("vacancies");
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		БылиОшибки = Истина;
		РекрутинговыеСайтыСлужебный.СообщитьОбОшибкеПолученияВакансий(Сайт, ЭтотОбъект, РезультатЗапроса);
	Иначе
		Вакансии = ПрочитатьОтветВакансииССайта(РезультатЗапроса);
		Для Каждого Вакансия Из Вакансии Цикл
			Описание = ОписаниеПубликацииВакансии(Формат(Вакансия.id, "ЧГ=0"));
			Если ЗначениеЗаполнено(Описание) Тогда
				МассивВакансий.Добавить(Описание);
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Возврат МассивВакансий;
	
КонецФункции

Функция ЗначениеРеквизитаПубликацииПоУмолчанию(Вакансия, Реквизит) Экспорт
	
	Результат = Неопределено;
	
	Если Реквизит = "Наименование" Тогда
		Результат = ?(ЗначениеЗаполнено(Вакансия.name), Вакансия.name, "");
	ИначеЕсли Реквизит = "ПредполагаемыйДоход" Тогда
		Результат = ?(ЗначениеЗаполнено(Вакансия.salaryTo), Вакансия.salaryTo, ?(ЗначениеЗаполнено(Вакансия.salaryFrom), Вакансия.salaryFrom, 0));
	ИначеЕсли Реквизит = "ДатаОткрытия" И ЗначениеЗаполнено(Вакансия.publishDate) Тогда
		Результат = РекрутинговыеСайтыСлужебный.СтрокаВДату(Вакансия.publishDate);
	ИначеЕсли Реквизит = "ПланируемаяДатаЗакрытия" И ЗначениеЗаполнено(Вакансия.expiresDate) Тогда
		Результат = РекрутинговыеСайтыСлужебный.СтрокаВДату(Вакансия.expiresDate);
	ИначеЕсли Реквизит = "Требования" Тогда
		Результат = РекрутинговыеСайтыСлужебный.ОписаниеТребованийОбязанностейУсловий(Вакансия.description).Требования;
	ИначеЕсли Реквизит = "Обязанности" Тогда
		Результат = РекрутинговыеСайтыСлужебный.ОписаниеТребованийОбязанностейУсловий(Вакансия.description).Обязанности;
	ИначеЕсли Реквизит = "Условия" Тогда
		Результат = РекрутинговыеСайтыСлужебный.ОписаниеТребованийОбязанностейУсловий(Вакансия.description).Условия;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ЗаполнитьДеревоВакансии(Вакансия, Дерево, СтруктураВакансииССайта) Экспорт
	
	НоваяСтрока = Дерево.Строки.Добавить();
	НоваяСтрока.Показатель = Вакансия;
	
	НовоеПоле = НоваяСтрока.Строки.Добавить();
	НовоеПоле.Путь = "name";
	НовоеПоле.ПубликацияВакансии = ЗначениеСвойстваУзла(СтруктураВакансииССайта, "name");
	
	Если ЗначениеЗаполнено(ЗначениеСвойстваУзла(СтруктураВакансииССайта, "isStudyCourse")) Тогда
		НовоеПоле = НоваяСтрока.Строки.Добавить();
		НовоеПоле.Путь = "isStudyCourse";
		НовоеПоле.ПубликацияВакансии = ЗначениеСвойстваУзла(СтруктураВакансииССайта, "isStudyCourse");
	КонецЕсли;
	
	Профессии = Новый СписокЗначений;
	Для Каждого Профессия Из ЗначениеСвойстваУзла(СтруктураВакансииССайта, "offerTrades") Цикл
		Профессии.Добавить(Профессия.id, Профессия.name);
	КонецЦикла;
	
	НовоеПоле = НоваяСтрока.Строки.Добавить();
	НовоеПоле.Путь = "offerTrades";
	НовоеПоле.ПубликацияВакансии = Профессии;
	
	Если ЗначениеЗаполнено(ЗначениеСвойстваУзла(СтруктураВакансииССайта, "salaryFrom")) Тогда
		НовоеПоле = НоваяСтрока.Строки.Добавить();
