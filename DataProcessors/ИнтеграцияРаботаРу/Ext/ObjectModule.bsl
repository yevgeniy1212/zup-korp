Процедура ПолучитьОтклики(Вакансия) Экспорт
	
	ИдентификаторВакансии = РекрутинговыеСайтыСлужебный.ИдентификаторВакансии(Вакансия, Сайт);
	
	Если Не ЗначениеЗаполнено(ИдентификаторВакансии) Тогда
		РекрутинговыеСайтыСлужебный.СообщитьОбОтсутствииПубликации(Сайт);
		Возврат;
	КонецЕсли;
	
	Если Не ПроверитьПодключение().Подключен Тогда
		РекрутинговыеСайтыСлужебный.ЗаписатьОшибкуПолученияОткликов(Сайт, Пользователь);
		Возврат;
	КонецЕсли;
	
	Если Не УстановитьСоединение() Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос(СтрШаблон("responses/vacancy/%1?period=365", ИдентификаторВакансии));
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		РекрутинговыеСайтыСлужебный.СообщитьОбОшибкеПолученияОткликов(Сайт, ЭтотОбъект, РезультатЗапроса);
		Возврат;
	Иначе
		КоллекцияОткликов = ПрочитатьОтветОтклики(РезультатЗапроса);
	КонецЕсли;
	
	МаксимальныйНомерОтклика = РекрутинговыеСайтыСлужебный.МаксимальныйНомерОтклика(Вакансия);
	ЗагруженныеОткликиВакансии = РекрутинговыеСайтыСлужебный.ЗагруженныеОткликиВакансии(Вакансия);
	
	Отклики = ОбщегоНазначенияБЗК.ТаблицаЗначенийПоИмениРегистраСведений("ОткликиКандидатов");
	
	Для Каждого Отклик Из КоллекцияОткликов Цикл
		Если Формат(Отклик.vacancy.id,"ЧГ=") <> ИдентификаторВакансии Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Отклик.resume) Тогда
			Продолжить;
		КонецЕсли;
		
		Запрос = НовыйHTTPЗапрос(СтрШаблон("search-resumes/%1", Формат(Отклик.resume.id,"ЧГ=")));
		
		РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
		
		Если РезультатЗапроса.КодСостояния <> 200 Тогда
			РекрутинговыеСайтыСлужебный.СообщитьОбОшибкеПолученияРезюме(Сайт, ЭтотОбъект, РезультатЗапроса);
			Возврат;
		Иначе
			ОписаниеРезюме = ПрочитатьОтветОписаниеРезюме(РезультатЗапроса);
			ИдентификаторРезюме = Формат(ОписаниеРезюме.id, "ЧГ=");
			
			Если ЗагруженныеОткликиВакансии.Найти(ИдентификаторРезюме) = Неопределено Тогда
				НоваяЗапись = Отклики.Добавить();
				НоваяЗапись.Вакансия = Вакансия;
				НоваяЗапись.НомерОтклика = МаксимальныйНомерОтклика + 1;
				НоваяЗапись.Имя = ЗначениеСвойстваУзла(ОписаниеРезюме, "personName");
				НоваяЗапись.Фамилия = ЗначениеСвойстваУзла(ОписаниеРезюме, "surname");
				НоваяЗапись.Отчество = ЗначениеСвойстваУзла(ОписаниеРезюме, "secondName");
				НоваяЗапись.Источник = Сайт;
				НоваяЗапись.ИдентификаторРезюме = ИдентификаторРезюме;
				НоваяЗапись.EMail = ЗначениеСвойстваУзла(ОписаниеРезюме, "contactEmail");
				
				Если ЗначениеЗаполнено(ОписаниеРезюме.birthDate) Тогда
					НоваяЗапись.ДатаРождения = Дата(СтрЗаменить(Лев(ОписаниеРезюме.birthDate, 10), "-", ""));
				КонецЕсли;
				
				Если ЗначениеЗаполнено(ОписаниеРезюме.phones) Тогда
					Контакт = ОписаниеРезюме.phones[0];
					НоваяЗапись.Телефон = СтрШаблон("%1 (%2) %3", Контакт.countryCode, Контакт.Code, Контакт.Number);
				КонецЕсли;
				
				Если ЗначениеЗаполнено(ОписаниеРезюме.region) Тогда
					НоваяЗапись.Адрес = ОписаниеРезюме.city.name;
				КонецЕсли;
				
				// Получим текст сопроводительного письма
				Запрос = НовыйHTTPЗапрос(СтрШаблон("/responses/%1/messages", Формат(Отклик.id,"ЧГ=")));
				
				РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
				
				Если РезультатЗапроса.КодСостояния = 200 Тогда
					СообщенияПоОтклику = ПрочитатьОтветСообщенияПоОтклику(РезультатЗапроса);
					Если ЗначениеЗаполнено(СообщенияПоОтклику) Тогда
						СообщенияКандидата = Новый Массив();
						
						Для Каждого СообщениеПоОтклику Из СообщенияПоОтклику Цикл
							Если Не СообщениеПоОтклику.fromEmployer Тогда
								СообщенияКандидата.Добавить(СообщениеПоОтклику);
							КонецЕсли;
						КонецЦикла;
						
						Если СообщенияКандидата.Количество() = 1 Тогда
							НоваяЗапись.Сообщение = СообщенияКандидата[0].text;
							НоваяЗапись.ДатаОтклика = Дата(СтрЗаменить(Лев(СообщенияКандидата[0].date, 10), "-", ""));
						ИначеЕсли СообщенияКандидата.Количество() > 1 Тогда
							НоваяЗапись.Сообщение = ?(ЗначениеЗаполнено(СообщенияКандидата[0].text),
								СообщенияКандидата[0].text, СообщенияКандидата[1].text);
							НоваяЗапись.ДатаОтклика = Дата(СтрЗаменить(Лев(СообщенияКандидата[0].date, 10), "-", ""));
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
				
				Если Не ЗначениеЗаполнено(НоваяЗапись.ДатаОтклика) Тогда
					НоваяЗапись.ДатаОтклика = Дата(СтрЗаменить(Лев(Отклик.lastModified, 10), "-", ""));
				КонецЕсли;
				
				НоваяЗапись.Рассмотрено = (Отклик.status.id > 0);
				НоваяЗапись.АдресРезюме = Отклик.resume.link;
				МаксимальныйНомерОтклика = МаксимальныйНомерОтклика + 1;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
		
	РекрутинговыеСайтыСлужебный.ЗаписатьОтклики(Сайт, Вакансия, Отклики);
	
КонецПроцедуры

