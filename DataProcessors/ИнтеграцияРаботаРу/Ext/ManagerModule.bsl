
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

Функция Сайт() Экспорт
	
	Возврат Справочники.ИсточникиИнформацииОКандидатах.РаботаРу;
	
КонецФункции

Функция НовыйМенеджер(Пользователь) Экспорт
	
	Менеджер = Создать();
	
	Менеджер.Сайт = Сайт();
	Менеджер.Пользователь = Пользователь;
	Менеджер.ДанныеСайта = ДанныеСайта();
	
	Возврат Менеджер;
	
КонецФункции

Функция ДанныеСайта() Экспорт
	
	ДанныеСайта = РекрутинговыеСайтыСлужебный.НовыеДанныеСайта();
	
	ДанныеСайта.Имя = Имя();
	ДанныеСайта.ИмяСайта = ИмяСайта();
	ДанныеСайта.Представление = Представление();
	ДанныеСайта.АдресЗапроса = АдресЗапроса();
	ДанныеСайта.ГлавнаяСтраница = ГлавнаяСтраница();
	ДанныеСайта.Логотип = Логотип();
	
	// АПК:1297-выкл Классификаторы, загруженные с сайта. Не локализуется
	ДанныеСайта.ЗаменяемыеЗначенияКлассификатора.Вставить("Еврейская автономная область", "Еврейская АО");
	ДанныеСайта.ЗаменяемыеЗначенияКлассификатора.Вставить("Чувашия / Чувашская республика", "Чувашская республика");
	ДанныеСайта.ЗаменяемыеЗначенияКлассификатора.Вставить("Ханты-Мансийский Автономный округ - Югра АО", "Ханты-Мансийский АО - Югра");
	ДанныеСайта.ЗаменяемыеЗначенияКлассификатора.Вставить("Республика Чеченская", "Чеченская республика");
	ДанныеСайта.ЗаменяемыеЗначенияКлассификатора.Вставить("Республика Саха /Якутия/", "Республика Саха");
	ДанныеСайта.ЗаменяемыеЗначенияКлассификатора.Вставить("Республика Карачаево-Черкессия","Карачаево-Черкесская республика");
	ДанныеСайта.ЗаменяемыеЗначенияКлассификатора.Вставить("Республика Кабардино-Балкария", "Кабардино-Балкарская республика");
	// АПК:1297-Вкл
	
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("offerTrades", "offer_trades");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("currency", "currencies");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("region", "regions");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("operatingSchedule", "operating_schedules");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("experienceYearCount", "experience");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("education", "offer_educations");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("gender", "gender");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("address", "representations");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("offerLanguage", "offer_languages");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("offerLanguageLevel", "offer_language_levels");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("additionalInformation.drivingLicense", "driving_licence");
	
	ДанныеСайта.ИменаПутейКДаннымВакансии.Вакансия = "name";
	ДанныеСайта.ИменаПутейКДаннымВакансии.Адрес = "link";
	ДанныеСайта.ИменаПутейКДаннымВакансии.Идентификатор = "id";
	
	ДанныеСайта.ПоляВакансииВПрограммеИНаСайте.Наименование = "name";
	ДанныеСайта.ПоляВакансииВПрограммеИНаСайте.ПредполагаемыйДоход = "salaryTo";
	ДанныеСайта.ПоляВакансииВПрограммеИНаСайте.Описание = "description";
	
	ДанныеСайта.ИменаСвойствТелефона.КодСтраны = "countryCode";
	ДанныеСайта.ИменаСвойствТелефона.КодГорода = "code";
	ДанныеСайта.ИменаСвойствТелефона.НомерТелефона = "number";
	ДанныеСайта.ИменаСвойствТелефона.Комментарий = "comment";
	
	ДанныеСайта.ИменаСвойствЗнанияЯзыка.ИдЯзыка = "id";
	ДанныеСайта.ИменаСвойствЗнанияЯзыка.ИдУровня = "id";
	ДанныеСайта.ИменаСвойствЗнанияЯзыка.НазваниеЯзыка = "name";
	ДанныеСайта.ИменаСвойствЗнанияЯзыка.НазваниеУровня = "name";
	ДанныеСайта.ИменаСвойствЗнанияЯзыка.ОбъектЯзык = "offerLanguage";
	ДанныеСайта.ИменаСвойствЗнанияЯзыка.ОбъектУровень = "offerLanguageLevel";
	
	ДанныеСайта.ШаблоныСтраницСайта.Сайт = Сайт();
	ДанныеСайта.ШаблоныСтраницСайта.Логотип = Логотип();
	ДанныеСайта.ШаблоныСтраницСайта.ГлавнаяСтраница = ГлавнаяСтраница();
	ДанныеСайта.ШаблоныСтраницСайта.ШаблонURLРезюме = "https://*.rabota.ru/*esume*";
	ДанныеСайта.ШаблоныСтраницСайта.РегулярноеВыражениеURLСайта = "https:\/\/((.*?\.rabota)|(rabota))\.ru\/.*";
	ДанныеСайта.ШаблоныСтраницСайта.РегулярноеВыражениеURLРезюме = "https:\/\/((.*?\.rabota)|(rabota))\.ru\/.*?(R|r)esume.\d.*?.html.*";
	
	ЗаполнитьПараметрыФорм(ДанныеСайта);
	
	Возврат ДанныеСайта;
	
КонецФункции

#Область Интерфейс

// Параметры:
//  АдресаСайтов - Массив Из см. РекрутинговыеСайтыСлужебный.ОписаниеАдресаРекрутинговогоСайта
Процедура ПриЗаполненииАдресовРекрутинговыхСайтов(АдресаСайтов) Экспорт
	
	АдресаСайтов.Добавить(
		РекрутинговыеСайтыСлужебный.ОписаниеАдресаРекрутинговогоСайта(Представление(), АдресЗапроса()));
	
КонецПроцедуры

