#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Параметры.Свойство("Организация", Организация);
	Параметры.Свойство("СтраховаяКомпания", СтраховаяКомпания);
	Параметры.Свойство("Застрахованный", Застрахованный);
	
	ЗаполнитьИзменившиесяОтправленныеДанные();
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьИзменившиесяОтправленныеДанные()
	
	ЗаполнитьПерсональныеДанные();
	ЗаполнитьКонтактнуюИнформацию();
	Если ПолучитьФункциональнуюОпцию("ИспользоватьДополнительныеРеквизитыИСведения") И УправлениеСвойствами.СвойстваДоступны() Тогда
		ЗаполнитьДополнительныеРеквизитыИСведения();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьПерсональныеДанные()
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("СтраховаяКомпания", СтраховаяКомпания);
	Запрос.УстановитьПараметр("Застрахованный", Застрахованный);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИзменениеОтправленныхДанныхЗастрахованных.Организация КАК Организация,
		|	ИзменениеОтправленныхДанныхЗастрахованных.СтраховаяКомпания КАК СтраховаяКомпания,
		|	ИзменениеОтправленныхДанныхЗастрахованных.Застрахованный КАК Застрахованный,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ДатаРождения КАК ДатаРождения,
		|	ИзменениеОтправленныхДанныхЗастрахованных.СтраховойНомерПФР КАК СтраховойНомерПФР,
		|	ИзменениеОтправленныхДанныхЗастрахованных.Пол КАК Пол,
		|	ИзменениеОтправленныхДанныхЗастрахованных.Страна КАК Страна,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ДокументПредставление КАК ДокументПредставление,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ДокументВид КАК ДокументВид,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ДокументСерия КАК ДокументСерия,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ДокументНомер КАК ДокументНомер,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ДокументДатаВыдачи КАК ДокументДатаВыдачи,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ДокументСрокДействия КАК ДокументСрокДействия,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ДокументКемВыдан КАК ДокументКемВыдан,
		|	ИзменениеОтправленныхДанныхЗастрахованных.ДокументКодПодразделения КАК ДокументКодПодразделения,
		|	ИзменениеОтправленныхДанныхЗастрахованных.Фамилия КАК Фамилия,
		|	ИзменениеОтправленныхДанныхЗастрахованных.Имя КАК Имя,
		|	ИзменениеОтправленныхДанныхЗастрахованных.Отчество КАК Отчество
		|ПОМЕСТИТЬ ВТИзменившиесяДанные
		|ИЗ
		|	РегистрСведений.ИзменениеОтправленныхДанныхЗастрахованных КАК ИзменениеОтправленныхДанныхЗастрахованных
		|ГДЕ
		|	ИзменениеОтправленныхДанныхЗастрахованных.Организация = &Организация
		|	И ИзменениеОтправленныхДанныхЗастрахованных.СтраховаяКомпания = &СтраховаяКомпания
		|	И ИзменениеОтправленныхДанныхЗастрахованных.Застрахованный = &Застрахованный
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОтправленныеДанныеЗастрахованныхСрезПоследних.ДатаРождения КАК ДатаРождения,
		|	ОтправленныеДанныеЗастрахованныхСрезПоследних.СтраховойНомерПФР КАК СтраховойНомерПФР,
		|	ОтправленныеДанныеЗастрахованныхСрезПоследних.Пол КАК Пол,
		|	ОтправленныеДанныеЗастрахованныхСрезПоследних.Страна КАК Страна,
		|	ОтправленныеДанныеЗастрахованныхСрезПоследних.ДокументПредставление КАК ДокументПредставление,
		|	ОтправленныеДанныеЗастрахованныхСрезПоследних.ДокументВид КАК ДокументВид,
		|	ОтправленныеДанныеЗастрахованныхСрезПоследних.ДокументСерия КАК ДокументСерия,
		|	ОтправленныеДанныеЗастрахованныхСрезПоследних.ДокументНомер КАК ДокументНомер,
		|	ОтправленныеДанныеЗастрахованныхСрезПоследних.ДокументДатаВыдачи КАК ДокументДатаВыдачи,
		|	ОтправленныеДанныеЗастрахованныхСрезПоследних.ДокументСрокДействия КАК ДокументСрокДействия,
		|	ОтправленныеДанныеЗастрахованныхСрезПоследних.ДокументКемВыдан КАК ДокументКемВыдан,
		|	ОтправленныеДанныеЗастрахованныхСрезПоследних.ДокументКодПодразделения КАК ДокументКодПодразделения,
		|	ОтправленныеДанныеЗастрахованныхСрезПоследних.Фамилия КАК Фамилия,
		|	ОтправленныеДанныеЗастрахованныхСрезПоследних.Имя КАК Имя,
		|	ОтправленныеДанныеЗастрахованныхСрезПоследних.Отчество КАК Отчество
		|ПОМЕСТИТЬ ВТОтправленнаяКИ
		|ИЗ
		|	РегистрСведений.ОтправленныеДанныеЗастрахованных.СрезПоследних(
		|			,
		|			Застрахованный = &Застрахованный
		|				И Организация = &Организация
		|				И СтраховаяКомпания = &СтраховаяКомпания) КАК ОтправленныеДанныеЗастрахованныхСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИзменившиесяДанные.ДатаРождения КАК ДатаРождения,
		|	ВТОтправленнаяКИ.ДатаРождения КАК ДатаРожденияДоИзменения,
		|	ВТИзменившиесяДанные.СтраховойНомерПФР КАК СтраховойНомерПФР,
		|	ВТОтправленнаяКИ.СтраховойНомерПФР КАК СтраховойНомерПФРДоИзменения,
		|	ВТИзменившиесяДанные.Пол КАК Пол,
		|	ВТОтправленнаяКИ.Пол КАК ПолДоИзменения,
		|	ВТИзменившиесяДанные.Страна КАК Страна,
		|	ВТОтправленнаяКИ.Страна КАК СтранаДоИзменения,
		|	ВТИзменившиесяДанные.ДокументВид КАК ДокументВид,
		|	ВТОтправленнаяКИ.ДокументВид КАК ДокументВидДоИзменения,
		|	ВТИзменившиесяДанные.ДокументСерия КАК ДокументСерия,
		|	ВТОтправленнаяКИ.ДокументСерия КАК ДокументСерияДоИзменения,
		|	ВТИзменившиесяДанные.ДокументНомер КАК ДокументНомер,
		|	ВТОтправленнаяКИ.ДокументНомер КАК ДокументНомерДоИзменения,
		|	ВТИзменившиесяДанные.ДокументДатаВыдачи КАК ДокументДатаВыдачи,
		|	ВТОтправленнаяКИ.ДокументДатаВыдачи КАК ДокументДатаВыдачиДоИзменения,
		|	ВТИзменившиесяДанные.ДокументСрокДействия КАК ДокументСрокДействия,
		|	ВТОтправленнаяКИ.ДокументСрокДействия КАК ДокументСрокДействияДоИзменения,
		|	ВТИзменившиесяДанные.ДокументКемВыдан КАК ДокументКемВыдан,
		|	ВТОтправленнаяКИ.ДокументКемВыдан КАК ДокументКемВыданДоИзменения,
		|	ВТИзменившиесяДанные.ДокументКодПодразделения КАК ДокументКодПодразделения,
		|	ВТОтправленнаяКИ.ДокументКодПодразделения КАК ДокументКодПодразделенияДоИзменения,
		|	ВТИзменившиесяДанные.Фамилия КАК Фамилия,
		|	ВТОтправленнаяКИ.Фамилия КАК ФамилияДоИзменения,
		|	ВТИзменившиесяДанные.Имя КАК Имя,
		|	ВТОтправленнаяКИ.Имя КАК ИмяДоИзменения,
		|	ВТИзменившиесяДанные.Отчество КАК Отчество,
		|	ВТОтправленнаяКИ.Отчество КАК ОтчествоДоИзменения
		|ИЗ
		|	ВТИзменившиесяДанные КАК ВТИзменившиесяДанные,
		|	ВТОтправленнаяКИ КАК ВТОтправленнаяКИ";
	Результат = Запрос.Выполнить().Выбрать();
	Пока Результат.Следующий() Цикл
		Если ЗначениеЗаполнено(Результат.ДатаРождения) Тогда
			НоваяСтрока = ИзменившиесяДанные.Добавить();
			НоваяСтрока.Имя = НСтр("ru = 'Дата рождения'");
			НоваяСтрока.ОтправленноеЗначение = Формат(Результат.ДатаРожденияДоИзменения, "ДЛФ=Д");
			НоваяСтрока.НовоеЗначение = Формат(Результат.ДатаРождения, "ДЛФ=Д");
		КонецЕсли;
		Если ЗначениеЗаполнено(Результат.СтраховойНомерПФР) Тогда
			НоваяСтрока = ИзменившиесяДанные.Добавить();
			НоваяСтрока.Имя = НСтр("ru = 'СНИЛС'");
			НоваяСтрока.ОтправленноеЗначение = Результат.СтраховойНомерПФРДоИзменения;
			НоваяСтрока.НовоеЗначение = Результат.СтраховойНомерПФР;
		КонецЕсли;
		Если ЗначениеЗаполнено(Результат.Пол) Тогда
			НоваяСтрока = ИзменившиесяДанные.Добавить();
			НоваяСтрока.Имя = НСтр("ru = 'Пол'");
			НоваяСтрока.ОтправленноеЗначение = Результат.ПолДоИзменения;
			НоваяСтрока.НовоеЗначение = Результат.Пол;
		КонецЕсли;
		Если ЗначениеЗаполнено(Результат.Страна) Тогда
			НоваяСтрока = ИзменившиесяДанные.Добавить();
			НоваяСтрока.Имя = НСтр("ru = 'Гражданство'");
			НоваяСтрока.ОтправленноеЗначение = Результат.СтранаДоИзменения;
			НоваяСтрока.НовоеЗначение = Результат.Страна;
		КонецЕсли;
		Если ЗначениеЗаполнено(Результат.ДокументСерия) Тогда
			НоваяСтрока = ИзменившиесяДанные.Добавить();
			НоваяСтрока.Имя = НСтр("ru = 'Серия документа'");
			НоваяСтрока.ОтправленноеЗначение = Результат.ДокументСерияДоИзменения;
			НоваяСтрока.НовоеЗначение = Результат.ДокументСерия;
		КонецЕсли;
		Если ЗначениеЗаполнено(Результат.ДокументНомер) Тогда
			НоваяСтрока = ИзменившиесяДанные.Добавить();
			НоваяСтрока.Имя = НСтр("ru = 'Номер документа'");
			НоваяСтрока.ОтправленноеЗначение = Результат.ДокументНомерДоИзменения;
			НоваяСтрока.НовоеЗначение = Результат.ДокументНомер;
		КонецЕсли;
		Если ЗначениеЗаполнено(Результат.ДокументДатаВыдачи) Тогда
			НоваяСтрока = ИзменившиесяДанные.Добавить();
			НоваяСтрока.Имя = НСтр("ru = 'Дата выдачи документа'");
			НоваяСтрока.ОтправленноеЗначение = Формат(Результат.ДокументДатаВыдачиДоИзменения, "ДЛФ=Д");
			НоваяСтрока.НовоеЗначение =  Формат(Результат.ДокументДатаВыдачи, "ДЛФ=Д");
		КонецЕсли;
		Если ЗначениеЗаполнено(Результат.ДокументСрокДействия) Тогда
			НоваяСтрока = ИзменившиесяДанные.Добавить();
			НоваяСтрока.Имя = НСтр("ru = 'Срок действия документа'");
			НоваяСтрока.ОтправленноеЗначение = Результат.ДокументСрокДействияДоИзменения;
			НоваяСтрока.НовоеЗначение = Результат.ДокументСрокДействия;
		КонецЕсли;
		Если ЗначениеЗаполнено(Результат.ДокументКемВыдан) Тогда
			НоваяСтрока = ИзменившиесяДанные.Добавить();
			НоваяСтрока.Имя = НСтр("ru = 'Кем выдан документ'");
			НоваяСтрока.ОтправленноеЗначение = Результат.ДокументКемВыданДоИзменения;
			НоваяСтрока.НовоеЗначение = Результат.ДокументКемВыдан;
		КонецЕсли;
		Если ЗначениеЗаполнено(Результат.ДокументКодПодразделения) Тогда
			НоваяСтрока = ИзменившиесяДанные.Добавить();
			НоваяСтрока.Имя = НСтр("ru = 'Код подразделения документа'");
			НоваяСтрока.ОтправленноеЗначение = Результат.ДокументКодПодразделенияДоИзменения;
			НоваяСтрока.НовоеЗначение = Результат.ДокументКодПодразделения;
		КонецЕсли;
		Если ЗначениеЗаполнено(Результат.Фамилия) Тогда
			НоваяСтрока = ИзменившиесяДанные.Добавить();
			НоваяСтрока.Имя = НСтр("ru = 'Фамилия'");
			НоваяСтрока.ОтправленноеЗначение = Результат.ФамилияДоИзменения;
			НоваяСтрока.НовоеЗначение = Результат.Фамилия;
		КонецЕсли;
		Если ЗначениеЗаполнено(Результат.Имя) Тогда
			НоваяСтрока = ИзменившиесяДанные.Добавить();
			НоваяСтрока.Имя = НСтр("ru = 'Имя'");
			НоваяСтрока.ОтправленноеЗначение = Результат.ИмяДоИзменения;
			НоваяСтрока.НовоеЗначение = Результат.Имя;
		КонецЕсли;
		Если ЗначениеЗаполнено(Результат.Отчество) Тогда
			НоваяСтрока = ИзменившиесяДанные.Добавить();
			НоваяСтрока.Имя = НСтр("ru = 'Отчество'");
			НоваяСтрока.ОтправленноеЗначение = Результат.ОтчествоДоИзменения;
			НоваяСтрока.НовоеЗначение = Результат.Отчество;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьКонтактнуюИнформацию()
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Организация", Организация);
	Запрос.УстановитьПараметр("СтраховаяКомпания", СтраховаяКомпания);
	Запрос.УстановитьПараметр("Застрахованный", Застрахованный);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных.Организация КАК Организация,
		|	ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных.СтраховаяКомпания КАК СтраховаяКомпания,
		|	ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных.Застрахованный КАК Застрахованный,
		|	ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных.Вид КАК Вид,
		|	ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных.Представление КАК Представление
		|ПОМЕСТИТЬ ВТИзменившаясяКИ
		|ИЗ
		|	РегистрСведений.ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных КАК ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных
		|ГДЕ
		|	ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных.Организация = &Организация
		|	И ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных.СтраховаяКомпания = &СтраховаяКомпания
		|	И ИзменениеОтправленнойКонтактнойИнформацииЗастрахованных.Застрахованный = &Застрахованный
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОтправленнаяКонтактнаяИнформацияЗастрахованныхСрезПоследних.Организация КАК Организация,
		|	ОтправленнаяКонтактнаяИнформацияЗастрахованныхСрезПоследних.СтраховаяКомпания КАК СтраховаяКомпания,
		|	ОтправленнаяКонтактнаяИнформацияЗастрахованныхСрезПоследних.Застрахованный КАК Застрахованный,
		|	ОтправленнаяКонтактнаяИнформацияЗастрахованныхСрезПоследних.Вид КАК Вид,
		|	ОтправленнаяКонтактнаяИнформацияЗастрахованныхСрезПоследних.Представление КАК Представление
		|ПОМЕСТИТЬ ВТОтправленнаяКИ
		|ИЗ
		|	РегистрСведений.ОтправленнаяКонтактнаяИнформацияЗастрахованных.СрезПоследних(
		|			,
		|			Застрахованный = &Застрахованный
		|				И Организация = &Организация
		|				И СтраховаяКомпания = &СтраховаяКомпания) КАК ОтправленнаяКонтактнаяИнформацияЗастрахованныхСрезПоследних
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТИзменившаясяКИ.Вид КАК Имя,
		|	ВТИзменившаясяКИ.Представление КАК НовоеЗначение,
		|	ВТОтправленнаяКИ.Представление КАК ОтправленноеЗначение
		|ИЗ
		|	ВТИзменившаясяКИ КАК ВТИзменившаясяКИ
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТОтправленнаяКИ КАК ВТОтправленнаяКИ
		|		ПО ВТИзменившаясяКИ.Организация = ВТОтправленнаяКИ.Организация
		|			И ВТИзменившаясяКИ.СтраховаяКомпания = ВТОтправленнаяКИ.СтраховаяКомпания
		|			И ВТИзменившаясяКИ.Застрахованный = ВТОтправленнаяКИ.Застрахованный
		|			И ВТИзменившаясяКИ.Вид = ВТОтправленнаяКИ.Вид";
	
	Результат = Запрос.Выполнить().Выбрать();
