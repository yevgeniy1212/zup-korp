&НаСервере
Процедура ЗаполнитьОтправляемыеДанные()
	
	ДанныеЗастрахованных = Перечисления.ДанныеЗастрахованных;
	Для Каждого Сведение Из ДанныеЗастрахованных Цикл
		КадровыеДанныеФизическихЛиц.Добавить(Сведение);
	КонецЦикла;
	
	ОтправляемыеДанные.Очистить();
	НаборЗаписей = РегистрыСведений.ОтправляемыеДанныеЗастрахованных.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Организация.Установить(Объект.Организация);
	НаборЗаписей.Прочитать();
	Для каждого ЗаписьНабора Из НаборЗаписей Цикл
		Если СтраховыеКомпании.НайтиПоЗначению(ЗаписьНабора.СтраховаяКомпания) = Неопределено Тогда
			СтраховыеКомпании.Добавить(ЗаписьНабора.СтраховаяКомпания);
		КонецЕсли;
		НоваяСтрока = ОтправляемыеДанные.Добавить();
		НоваяСтрока.СтраховаяКомпания = ЗаписьНабора.СтраховаяКомпания;
		НоваяСтрока.Сведение = ЗаписьНабора.Сведение;
		НоваяСтрока.Отправлять = ЗаписьНабора.Отправлять;
		НоваяСтрока.СпособПроверкиЗаполнения = ЗаписьНабора.СпособПроверкиЗаполнения;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьОтправляемуюКонтактнуюИнформацию()
	
	ТаблицаВидовКИ = УправлениеКонтактнойИнформацией.ВидыКонтактнойИнформацииОбъекта(
		Справочники.ФизическиеЛица.ПустаяСсылка());
	ВидыКонтактнойИнформацииФизическихЛиц.ЗагрузитьЗначения(ТаблицаВидовКИ.ВыгрузитьКолонку("Ссылка"));
	
	ОтправляемаяКонтактнаяИнформация.Очистить();
	НаборЗаписей = РегистрыСведений.ОтправляемаяКонтактнаяИнформацияЗастрахованных.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Организация.Установить(Объект.Организация);
	НаборЗаписей.Прочитать();
	Для каждого ЗаписьНабора Из НаборЗаписей Цикл
		Если СтраховыеКомпании.НайтиПоЗначению(ЗаписьНабора.СтраховаяКомпания) = Неопределено Тогда
			СтраховыеКомпании.Добавить(ЗаписьНабора.СтраховаяКомпания);
		КонецЕсли;
		НоваяСтрока = ОтправляемаяКонтактнаяИнформация.Добавить();
		НоваяСтрока.СтраховаяКомпания = ЗаписьНабора.СтраховаяКомпания;
		НоваяСтрока.ВидКонтактнойИнформации = ЗаписьНабора.Вид;
		НоваяСтрока.Отправлять = ЗаписьНабора.Отправлять;
		НоваяСтрока.СпособПроверкиЗаполнения = ЗаписьНабора.СпособПроверкиЗаполнения;
	КонецЦикла;
	
КонецПроцедуры

