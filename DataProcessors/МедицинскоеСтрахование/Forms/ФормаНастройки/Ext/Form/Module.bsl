		ПараметрыОтбора.Вставить("Сведение", Сведение.Значение);
		НайденноеСведение= ОтправляемыеДанные.НайтиСтроки(ПараметрыОтбора);
		Если НайденноеСведение.Количество() = 0 Тогда
			НоваяСтрока = ОтправляемыеДанные.Добавить();
			НоваяСтрока.СтраховаяКомпания = СтраховаяКомпания;
			НоваяСтрока.Сведение = Сведение.Значение;
			НоваяСтрока.Отправлять = Истина;
			НоваяСтрока.СпособПроверкиЗаполнения = ПредопределенноеЗначение("Перечисление.СпособыПроверкиЗаполненияПерсональныхДанныхМедицинскогоСтрахования.НеПроверять");
