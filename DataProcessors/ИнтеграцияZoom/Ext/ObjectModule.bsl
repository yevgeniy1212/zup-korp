Функция ИдентификаторВидеоконференции(Идентификатор)

	ИдентификаторВидеоконференции = СокрЛП(Идентификатор);
	ИдентификаторВидеоконференции = СтрЗаменить(ИдентификаторВидеоконференции, Символы.НПП, "");
	ИдентификаторВидеоконференции = СтрЗаменить(ИдентификаторВидеоконференции, " ", "");
	
	Возврат ИдентификаторВидеоконференции;

КонецФункции

Процедура ЗаписатьОшибкуВЖурналРегистрации(РезультатЗапроса)
	
	ТелоОтвета = ПрочитатьОтветСОшибкой(РезультатЗапроса);
	КодСостояния = РезультатЗапроса.КодСостояния;
	
	ОписаниеОшибки = СтрШаблон(
		НСтр("ru = 'Ошибка при выполнении запроса к %1:
					|Код состояния: %2
					|Тип ошибки: %3
					|Причина: %4
					|Запрос: %5
					|Тело запроса: %6
					|Текст ответа: %7'"),
		РезультатЗапроса.Сервис,
		РезультатЗапроса.КодСостояния,
		?(КодСостояния = 400, ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ТелоОтвета, "error", ""), ""),
		?(КодСостояния = 400, ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ТелоОтвета, "reason", ""), ""),
		РезультатЗапроса.АдресРесурса,
		РезультатЗапроса.ТекстЗапроса,
		РезультатЗапроса.Ответ);

	ЗаписьЖурналаРегистрации(
		СтрШаблон(НСтр("ru = 'Выполнение запроса к %1'", ОбщегоНазначения.КодОсновногоЯзыка()), РезультатЗапроса.Сервис),
		УровеньЖурналаРегистрации.Ошибка,,, ОписаниеОшибки);

КонецПроцедуры

