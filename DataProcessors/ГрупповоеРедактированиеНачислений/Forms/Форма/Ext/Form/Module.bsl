			КонецЕсли;
			СтрокаКорректировки["СпособОбложения" + ВидНалогаВзноса] = Перечисления.СпособыНалогообложенияДоходов.НеОблагаетсяЦеликом;
		    СтрокаКорректировки["ДоходНеПодлежащийНалогообложению" + ВидНалогаВзноса] = Справочники.ДоходыНеПодлежащиеНалогообложениюЧастично.ПустаяСсылка();
		КонецЦикла;
		
		Для Каждого СтрокаНеОблагаетсяЧастично Из ЭтотОбъект["Начисления" + ВидНалогаВзноса + "НеОблагаютсяЧастично"] Цикл
			Если НЕ ЗначениеЗаполнено(СтрокаНеОблагаетсяЧастично.ВидРасчета) Тогда
				Продолжить;
			КонецЕсли;
			ИсходнаяСтрока = ИсходнаяБаза.Найти(СтрокаНеОблагаетсяЧастично.ВидРасчета, "ВидРасчета");
			Если ИсходнаяСтрока = Неопределено 
				Или (ИсходнаяСтрока.СпособОбложения = Перечисления.СпособыНалогообложенияДоходов.НеОблагаетсяЧастично 
					И ИсходнаяСтрока.ДоходНеПодлежащийНалогообложению = СтрокаНеОблагаетсяЧастично.ДоходНеПодлежащийНалогообложению) Тогда
				Продолжить;			
			КонецЕсли;
			
			СтрокаКорректировки = ТаблицаНалогообложение.Найти(СтрокаНеОблагаетсяЧастично.ВидРасчета, "Начисление");
			Если СтрокаКорректировки = Неопределено Тогда
				СтрокаКорректировки = ТаблицаНалогообложение.Добавить();
				СтрокаКорректировки.Начисление = ИсходнаяСтрока.ВидРасчета;
				ДополнитьСтрокуДаннымиНалогообложенияПоВидам(СтрокаКорректировки, МассивВидовНалоговВзносов, ВидНалогаВзноса);
			КонецЕсли;
			СтрокаКорректировки["СпособОбложения" + ВидНалогаВзноса] = Перечисления.СпособыНалогообложенияДоходов.НеОблагаетсяЧастично;
		    СтрокаКорректировки["ДоходНеПодлежащийНалогообложению" + ВидНалогаВзноса] = СтрокаНеОблагаетсяЧастично.ДоходНеПодлежащийНалогообложению;
		КонецЦикла;

	КонецЦикла;

	// Отсутствующие элементы запишем с настройками по умолчанию
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("НастроенныеНачисления", ТаблицаНалогообложение.ВыгрузитьКолонку("Начисление"));
	Запрос.УстановитьПараметр("ДатаАктуальности", ЭтаФорма.НалогиВзносыОтчисленияПериод);
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Начисления.Ссылка
		|ИЗ
		|	ПланВидовРасчета.Начисления КАК Начисления
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НалогообложениеНачислений.СрезПоследних(&ДатаАктуальности, ) КАК НалогообложениеНачисленийСрезПоследних
		|		ПО НалогообложениеНачисленийСрезПоследних.Начисление = Начисления.Ссылка
		|ГДЕ
		|	НалогообложениеНачисленийСрезПоследних.Начисление ЕСТЬ NULL 
		|	И НЕ НалогообложениеНачисленийСрезПоследних.Начисление В (&НастроенныеНачисления)";
		
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = ТаблицаНалогообложение.Добавить();
		НоваяСтрока.Начисление = Выборка.Ссылка;
		ДополнитьСтрокуДаннымиНалогообложенияПоВидам(НоваяСтрока, МассивВидовНалоговВзносов, "")
	КонецЦикла;
	
	ТаблицаНалогообложение.ЗаполнитьЗначения(ЭтаФорма.НалогиВзносыОтчисленияПериод, "Период");
	ТаблицаНалогообложение.ЗаполнитьЗначения(ЭтаФорма.ВидДохода, "ВидДохода");
	
	НаборНалогообложение.Отбор.Период.Установить(ЭтаФорма.НалогиВзносыОтчисленияПериод);
	Для Каждого СтрокаНалогообложение Из ТаблицаНалогообложение Цикл
		НаборНалогообложение.Отбор.Начисление.Установить(СтрокаНалогообложение.Начисление);

		НаборНалогообложение.Прочитать();
		Если НаборНалогообложение.Количество() > 0 Тогда
			СтрокаНабора = НаборНалогообложение.Получить(0);
		Иначе 
			СтрокаНабора = НаборНалогообложение.Добавить();
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(СтрокаНабора, СтрокаНалогообложение);
		НаборНалогообложение.Записать(Истина);
	КонецЦикла;
	// ЗУПК
	
	ЗаполнитьНаСервере();
	
	Модифицированность = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьИЗакрыть(Результат, ДополнительныеПараметры) Экспорт 
	
	ЗаписатьНаСервере();
	Закрыть();
	
КонецПроцедуры

&НаСервере
Функция ИзмененныеДанныеСтруктура(ИсходнаяТаблица, ТекущаяТаблица)
	
	ДобавленныеВидыРасчета 	= ИсходнаяТаблица.СкопироватьКолонки();
	ИсправленныеВидыРасчета = ИсходнаяТаблица.СкопироватьКолонки();
	УдаленныеВидыРасчета 	= ИсходнаяТаблица.СкопироватьКолонки();
	
	СравниваемыеКолонки = Новый Массив;
	Для Каждого Колонка Из ИсходнаяТаблица.Колонки Цикл
		СравниваемыеКолонки.Добавить(Колонка.Имя);
	КонецЦикла;
	ОбщегоНазначенияКлиентСервер.УдалитьЗначениеИзМассива(СравниваемыеКолонки, "ВидРасчета");
	
	Для Каждого ТекСтрока Из ИсходнаяТаблица Цикл
		ВидРасчета = ТекущаяТаблица.Найти(ТекСтрока.ВидРасчета, "ВидРасчета");
		Если ВидРасчета = Неопределено Тогда 
			НоваяСтрока = УдаленныеВидыРасчета.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
		КонецЕсли;
	КонецЦикла;
	
	Для Каждого ТекСтрока Из ТекущаяТаблица Цикл
		ВидРасчета = ИсходнаяТаблица.Найти(ТекСтрока.ВидРасчета, "ВидРасчета");
		Если ВидРасчета = Неопределено Тогда 
			НоваяСтрока = ДобавленныеВидыРасчета.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
		Иначе 
			Для Каждого ИмяКолонки Из СравниваемыеКолонки Цикл
				Если ВидРасчета[ИмяКолонки] <> ТекСтрока[ИмяКолонки] Тогда
					НоваяСтрока = ИсправленныеВидыРасчета.Добавить();
					ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
					Прервать;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	ИзмененныеДанные = Новый Структура;
	ИзмененныеДанные.Вставить("УдаленныеВидыРасчета", УдаленныеВидыРасчета);
	ИзмененныеДанные.Вставить("ДобавленныеВидыРасчета", ДобавленныеВидыРасчета);
	ИзмененныеДанные.Вставить("ИсправленныеВидыРасчета", ИсправленныеВидыРасчета);
	
	Возврат ИзмененныеДанные;
	
КонецФункции

