	ЭтаФорма.НалогиВзносыОтчисленияТаблицаИсточник = Элемент.Имя;
	
КонецПроцедуры

&НаКлиенте
Процедура Подключаемый_НалогиВзносыОтчисленияПеретаскивание(Элемент, ПараметрыПеретаскивания, СтандартнаяОбработка, Строка, Поле)
	
	СтандартнаяОбработка = Ложь;
	
	Если ЭтаФорма.НалогиВзносыОтчисленияТаблицаИсточник = Элемент.Имя Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ПараметрыПеретаскивания.Значение) = Тип("Массив") Тогда
		СтрокиНачислений = ПараметрыПеретаскивания.Значение;
	Иначе 
		СтрокиНачислений = Неопределено;
	КонецЕсли;
	
	ЭтаФорма.НалогиВзносыОтчисленияТаблицаПриемник = Элемент.Имя;
	
	НалогиВзносыОтчисленияПеренестиНачисление(СтрокиНачислений);
	
КонецПроцедуры

&НаКлиенте
Процедура НалогиВзносыОтчисленияПеренестиНачисление(ДанныеПереноса)
	
	Если ДанныеПереноса = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ДанныеПереноса) = Тип("Массив") Тогда
		Для Каждого СтрокаРасчета Из ДанныеПереноса Цикл
			Если Не СтрокаРасчета.ТолькоПросмотр Тогда
				НоваяСтрока = ЭтотОбъект[ЭтаФорма.НалогиВзносыОтчисленияТаблицаПриемник].Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрокаРасчета);
				
				ТекущаяСтрока = ЭтотОбъект[ЭтаФорма.НалогиВзносыОтчисленияТаблицаИсточник].Индекс(СтрокаРасчета);
				ЭтотОбъект[ЭтаФорма.НалогиВзносыОтчисленияТаблицаИсточник].Удалить(ТекущаяСтрока);
				
				ЭтотОбъект[ЭтаФорма.НалогиВзносыОтчисленияТаблицаПриемник].Сортировать("РеквизитДопУпорядочивания");
				
				Модифицированность = Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

