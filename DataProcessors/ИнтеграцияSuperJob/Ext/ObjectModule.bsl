Функция ОпубликоватьВакансию(Дерево) Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией();
	
	JSONОписаниеВакансии = JSONОписаниеВакансии(Дерево);
	
	Если Не УстановитьСоединение() Тогда
		Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкойПубликацииВакансии(Сайт, ЭтотОбъект);
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос("/2.0/vacancies/");
	Запрос.УстановитьТелоИзСтроки(JSONОписаниеВакансии);
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().ОтправитьДляОбработки, Запрос);
	
	Если РезультатЗапроса.КодСостояния = 201 Тогда
		СтруктураВакансии = ПрочитатьОтветПубликацияВакансии(РезультатЗапроса);
		Результат.ИдентификаторВакансии = СтруктураВакансии.id;
	Иначе
		Результат = РекрутинговыеСайтыСлужебный.РезультатСОшибкойПубликацииВакансии(Сайт, ЭтотОбъект, РезультатЗапроса);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СписокВыбораПоКлассификатору(Путь) Экспорт
	
	СписокВыбора = Новый СписокЗначений;
	
	Если Не ЗначениеЗаполнено(Путь) Тогда
		Возврат СписокВыбора;
	КонецЕсли;
	
	КлассификаторыSuperJob = КлассификаторыСайта();
	Если КлассификаторыSuperJob = Неопределено Тогда
		Возврат СписокВыбора;
	КонецЕсли;
	
	СтруктураДанных = КлассификаторыSuperJob[Путь];
	Для Каждого ЭлементСтруктурыДанных Из СтруктураДанных Цикл
		Если ЭлементСтруктурыДанных.Значение = "Не имеет значения" Тогда // АПК:1297 Строка не видна пользователю и не локализуется.
			Продолжить;
		КонецЕсли;
		СписокВыбора.Добавить(ЭлементСтруктурыДанных.Ключ, ЭлементСтруктурыДанных.Значение);
	КонецЦикла;
		
	Возврат СписокВыбора;

КонецФункции

Функция СнятьПубликациюВакансии(ИдентификаторВакансии) Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией();
	
	Если Не УстановитьСоединение() Тогда
		Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкойСнятияВакансии(Сайт, ЭтотОбъект);
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос(СтрШаблон("/2.0/vacancies/%1/archive/", ИдентификаторВакансии));
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Записать, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 204 И РезультатЗапроса.КодСостояния <> 403 Тогда
		Результат = РекрутинговыеСайтыСлужебный.РезультатСОшибкойСнятияВакансии(Сайт, ЭтотОбъект, РезультатЗапроса);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция СвойстваПубликацииВакансииНаСайте(ИдентификаторВакансии) Экспорт
	
	СвойстваПубликации = РекрутинговыеСайтыСлужебный.НовыеСвойстваПубликацииВакансии();
	
	Если Не УстановитьСоединение() Тогда
		Возврат СвойстваПубликации;
	КонецЕсли;
	
	Описание = ОписаниеПубликацииВакансии(ИдентификаторВакансии, Ложь);
	Если ЗначениеЗаполнено(Описание) Тогда
		СвойстваПубликации.Опубликована = Не Описание.is_archive;
		
		СвойстваПубликации.ДатаПубликации = РекрутинговыеСайтыСлужебный.СекундыВДату(Описание.date_published);
		СвойстваПубликации.ДатаОбновления = РекрутинговыеСайтыСлужебный.СекундыВДату(Описание.date_lastedit);
		
		Если Не СвойстваПубликации.Опубликована Тогда
			СвойстваПубликации.ДатаСнятияСПубликации = РекрутинговыеСайтыСлужебный.СекундыВДату(Описание.date_archived);
		КонецЕсли;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат СвойстваПубликации;
	
КонецФункции

Функция ОбновитьПубликациюВакансии(Дерево, ИдентификаторВакансии) Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией();
	
	Если Не УстановитьСоединение() Тогда
		Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкойОбновленияВакансии(Сайт, ЭтотОбъект);
	КонецЕсли;
	
	JSONОписаниеВакансии = JSONОписаниеВакансии(Дерево);
	
	Если Не ЗначениеЗаполнено(JSONОписаниеВакансии) Тогда
		Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкойОбновленияВакансии(Сайт, ЭтотОбъект);
	КонецЕсли;
	
	ТекстЗапроса = "/2.0/vacancies/" + ИдентификаторВакансии + "/";
	
	Запрос = НовыйHTTPЗапрос(ТекстЗапроса);
	Запрос.УстановитьТелоИзСтроки(JSONОписаниеВакансии);
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Записать, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкойОбновленияВакансии(Сайт, ЭтотОбъект, РезультатЗапроса);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ПовторноОпубликоватьВакансию(Дерево, Вакансия, ИдентификаторВакансии) Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией();
	
	Если Не УстановитьСоединение() Тогда
		Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкойПубликацииВакансии(Сайт, ЭтотОбъект);
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос(СтрШаблон("/2.0/vacancies/%1/republish/", ИдентификаторВакансии));
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Записать, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		Результат = РекрутинговыеСайтыСлужебный.РезультатСОшибкойПубликацииВакансии(Сайт, ЭтотОбъект, РезультатЗапроса);
		Результат.ИдентификаторВакансии = ИдентификаторВакансии;
	Иначе
		Результат = ОбновитьПубликациюВакансии(Дерево, ИдентификаторВакансии);
		
		Если Результат.Успешно Тогда
			
			ДатаСеанса = ТекущаяДатаСеанса();
			
			СвойстваПубликации = РекрутинговыеСайтыСлужебный.НовыеСвойстваПубликацииВакансии();
			СвойстваПубликации.Опубликована = Истина;
			СвойстваПубликации.ДатаПубликации = ДатаСеанса;
			СвойстваПубликации.ДатаОбновления = ДатаСеанса;
			
			РекрутинговыеСайтыСлужебный.ЗаписьВРегистрИнформацииОПубликации(Вакансия, Сайт, , , СвойстваПубликации);
			
		Иначе
			СнятьПубликациюВакансии(ИдентификаторВакансии);
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция КонтактыРезюме(АдресРезюме) Экспорт
	
	КонтактыРезюме = РекрутинговыеСайтыСлужебный.НовыеКонтактыРезюме();
	
	Если Не УстановитьСоединение() Тогда
		Возврат КонтактыРезюме;
	КонецЕсли;
	
	СтруктураРезюме = СтруктураРезюмеССайта(ИдентификаторРезюмеПоАдресу(АдресРезюме));

	ДоступностьКонтактов = ПодборПерсоналаКлиентСервер.ДоступностьКонтактовВРезюме();
	ЗаполнитьДоступностьКонтактов(ДоступностьКонтактов, СтруктураРезюме);
	
	ОбщегоНазначенияКлиентСервер.Проверить(
		Не ПустаяСтрока(ДоступностьКонтактов.КонтактыМожноОткрытьПоАдресу), 
		НСтр("ru = 'Не заполнен адрес для получения контактов резюме с сайта SuperJob'"), 
		"Обработки.ИнтеграцияSuperJob.КонтактыРезюме");
	
	Запрос = НовыйHTTPЗапрос("/2.0/" + ДоступностьКонтактов.КонтактыМожноОткрытьПоАдресу);
	
	Попытка
		РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().ОтправитьДляОбработки, Запрос);
	Исключение
		РекрутинговыеСайтыСлужебный.ЗарегистрироватьОшибкуОбращенияКРекрутинговомуСайту(РезультатЗапроса.ИнформацияОбОшибке);
		Возврат КонтактыРезюме;
	КонецПопытки;
	
	СтруктураРезюме = ПрочитатьОтветКонтактыРезюме(РезультатЗапроса);
	
	КонтактыРезюме.Фамилия = ЗначениеСвойстваУзла(СтруктураРезюме, "resume", "lastname");
	КонтактыРезюме.Имя = ЗначениеСвойстваУзла(СтруктураРезюме, "resume", "firstname");
	КонтактыРезюме.Отчество = ЗначениеСвойстваУзла(СтруктураРезюме, "resume", "middlename");
	
	КонтактыРезюме.Телефон = ЗначениеСвойстваУзла(СтруктураРезюме, "resume", "phone1");
	КонтактыРезюме.ЭлектроннаяПочта = ЗначениеСвойстваУзла(СтруктураРезюме, "resume", "email");
	
	Возврат КонтактыРезюме;
	
КонецФункции

Процедура ПолучитьОтклики(Вакансия) Экспорт
	
	ИдентификаторВакансии = РекрутинговыеСайтыСлужебный.ИдентификаторВакансии(Вакансия, Сайт);
	
	Если Не ЗначениеЗаполнено(ИдентификаторВакансии) Тогда
		РекрутинговыеСайтыСлужебный.СообщитьОбОтсутствииПубликации(Сайт);
		Возврат;
	КонецЕсли;
	
	Если Не ПроверитьПодключение().Подключен Тогда
		РекрутинговыеСайтыСлужебный.ЗаписатьОшибкуПолученияОткликов(Сайт, Пользователь);
		Возврат;
	КонецЕсли;
	
	Если Не УстановитьСоединение() Тогда
		Возврат;
	КонецЕсли;
	
	МаксимальныйНомерОтклика = РекрутинговыеСайтыСлужебный.МаксимальныйНомерОтклика(Вакансия);
	ЗагруженныеОткликиВакансии = РекрутинговыеСайтыСлужебный.ЗагруженныеОткликиВакансии(Вакансия);
	
	Отклики = ОбщегоНазначенияБЗК.ТаблицаЗначенийПоИмениРегистраСведений("ОткликиКандидатов");
	
	Запрос = НовыйHTTPЗапрос("/2.0/resumes/received/" + ИдентификаторВакансии + "/");
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);

	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		РекрутинговыеСайтыСлужебный.СообщитьОбОшибкеПолученияОткликов(Сайт, ЭтотОбъект, РезультатЗапроса);
		Возврат;
	Иначе
		ОткликиССайта = ПрочитатьОтветОтклики(РезультатЗапроса);
	КонецЕсли;
	
	Для Каждого Отклик Из ОткликиССайта.objects Цикл
		Если Отклик = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ИдентификаторРезюме = Формат(ЗначениеСвойстваУзла(Отклик, "resume", "id"), "ЧГ=0");
		Если ЗагруженныеОткликиВакансии.Найти(ИдентификаторРезюме) = Неопределено Тогда
			
			НоваяЗапись = Отклики.Добавить();
			НоваяЗапись.Вакансия = Вакансия;
			НоваяЗапись.НомерОтклика = МаксимальныйНомерОтклика + 1;
			НоваяЗапись.Фамилия = ЗначениеСвойстваУзла(Отклик, "resume", "lastname");
			НоваяЗапись.Имя = ЗначениеСвойстваУзла(Отклик, "resume", "firstname");
			НоваяЗапись.Отчество = ЗначениеСвойстваУзла(Отклик, "resume", "middlename");
			НоваяЗапись.Источник = Сайт;
			НоваяЗапись.ДатаОтклика = Дата(1970, 1, 1) + Отклик.events[0].date_event;
			НоваяЗапись.ИдентификаторРезюме = ИдентификаторРезюме;
			Если ЗначениеЗаполнено(ЗначениеСвойстваУзла(Отклик, "resume", "birthyear")) 
				И ЗначениеЗаполнено(ЗначениеСвойстваУзла(Отклик, "resume", "birthmonth")) 
				И ЗначениеЗаполнено(ЗначениеСвойстваУзла(Отклик, "resume", "birthday")) Тогда
				
				НоваяЗапись.ДатаРождения = Дата(ЗначениеСвойстваУзла(Отклик, "resume", "birthyear"), ЗначениеСвойстваУзла(Отклик, "resume", "birthmonth"), ЗначениеСвойстваУзла(Отклик, "resume", "birthday"));
			КонецЕсли;
			НоваяЗапись.Адрес = ЗначениеСвойстваУзла(Отклик, "resume", "town", "title");
			НоваяЗапись.Телефон = ЗначениеСвойстваУзла(Отклик, "resume", "phone1");
			НоваяЗапись.EMail = ЗначениеСвойстваУзла(Отклик, "resume", "email");
			НоваяЗапись.АдресРезюме = СтрЗаменить(ЗначениеСвойстваУзла(Отклик, "resume", "link"), "\", "");
			
			СопроводительноеПисьмо = ЗначениеСвойстваУзла(Отклик, "cover_letter");
			Если ТипЗнч(СопроводительноеПисьмо) = Тип("Массив") 
				И ЗначениеЗаполнено(СопроводительноеПисьмо) Тогда
				НоваяЗапись.Сообщение = РекрутинговыеСайтыСлужебный.УдалитьЛишнееИзСтроки(СопроводительноеПисьмо[0]);
			КонецЕсли;
			
			МаксимальныйНомерОтклика = МаксимальныйНомерОтклика + 1;
			
		КонецЕсли;
	КонецЦикла;
	
	РекрутинговыеСайтыСлужебный.ЗаписатьОтклики(Сайт, Вакансия, Отклики);
	
КонецПроцедуры

Функция ДоступныеДляПолученияКонтакты(АдресРезюме) Экспорт
	
	ДоступностьКонтактов = ПодборПерсоналаКлиентСервер.ДоступностьКонтактовВРезюме();
	
	ИдентификаторРезюме = ИдентификаторРезюмеПоАдресу(АдресРезюме);
	
	СтруктураРезюме = СтруктураРезюмеССайта(ИдентификаторРезюме);
	
	ЗаполнитьДоступностьКонтактов(ДоступностьКонтактов, СтруктураРезюме);
	
	Возврат ДоступностьКонтактов;
	
КонецФункции

Процедура ЗагрузитьКомментарииКандидата(Кандидат, ДанныеРезюме) Экспорт
	
	ОтборСтрок = Новый Структура();
	ОтборСтрок.Вставить("МестоПубликации", Сайт);
	ОтборСтрок.Вставить("ИмяПоля", "id");
	
	НайденныеСтроки = ДанныеРезюме.НайтиСтроки(ОтборСтрок);
	Если НайденныеСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ИдентификаторРезюме = НайденныеСтроки[0].СодержимоеПоля;
	
	Комментарии = КомментарииКандидата(ИдентификаторРезюме, Кандидат);
	
	РекрутинговыеСайтыСлужебный.ЗаписатьТаблицуКомментариевКандидата(Комментарии, Кандидат, Сайт);
	
КонецПроцедуры

Функция УточнитьОписаниеОшибки(КодСостояния, ОписаниеОшибки) Экспорт
	
	УточненноеОписаниеОшибки = "";
	
	Если КодСостояния = 422 Тогда
		ИнформацияОбОшибках = ПарсерJSON(ОписаниеОшибки);
		
		Если ТипЗнч(ИнформацияОбОшибках) = Тип("Структура") И ИнформацияОбОшибках.Свойство("error") Тогда
			Если ТипЗнч(ИнформацияОбОшибках.error) = Тип("Структура") Тогда
				Если ТипЗнч(ИнформацияОбОшибках.error.message) = Тип("Строка") Тогда
					УточненноеОписаниеОшибки = ИнформацияОбОшибках.error.message;
				Иначе
					Для Каждого ПолеИОшибкиЗаполнения Из ИнформацияОбОшибках.error.message Цикл
						ИмяПоля = ПолеИОшибкиЗаполнения.Ключ;
						ОшибкиЗаполнения = ПолеИОшибкиЗаполнения.Значение;
						
						Поле = РекрутинговыеСайтыСлужебный.ПредставлениеПоля(Сайт, ЭтотОбъект, ИмяПоля);
						УточненноеОписаниеОшибки = УточненноеОписаниеОшибки
						+ ?(ЗначениеЗаполнено(УточненноеОписаниеОшибки), Символы.ПС, "")
						+ РекрутинговыеСайтыСлужебный.ОписаниеНезаполненногоПоля(Поле, ОшибкиЗаполнения[0]);
					КонецЦикла;
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	ИначеЕсли КодСостояния = 403 Тогда
		Если СтрНайти(ОписаниеОшибки, "wrong_tariff") <> 0 Тогда
			УточненноеОписаниеОшибки = НСтр("ru = 'Проверьте тариф.'");
		КонецЕсли;
	КонецЕсли;
	
	Возврат УточненноеОписаниеОшибки;
	
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция УстановитьСоединение()
	
	Результат = Истина;
	
	Если Не ЗначениеЗаполнено(МаркерДоступа) Тогда
		Результат = Инициализировать();
	КонецЕсли;
	
	Если Соединение = Неопределено Тогда
		Соединение = РекрутинговыеСайтыСлужебный.НовоеHTTPСоединение(АдресСервера());
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Инициализировать()
	
	РеквизитыСайта = РекрутинговыеСайтыСлужебный.РеквизитыСайта(Сайт, Пользователь);
	
	Если РеквизитыСайта = Неопределено Или Не ЗначениеЗаполнено(РеквизитыСайта.МаркерДоступа) Тогда
		ВызватьИсключение СтрШаблон(НСтр("ru = 'Не настроена интеграция с %1.'"), АдресСайта());
	КонецЕсли; 
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, РеквизитыСайта);
	
	УстановитьПривилегированныйРежим(Истина);
	Пароль = ОбщегоНазначения.ПрочитатьДанныеИзБезопасногоХранилища(Пользователь, "ПарольSuperJob");
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат МаркерАктивен();
	
КонецФункции

Функция МетодыЗапросов()
	
	Возврат РекрутинговыеСайтыСлужебный.МетодыЗапросов();
	
КонецФункции

Функция ВыполнитьHTTPЗапрос(Метод, Запрос, ВызыватьИсключение = Истина) Экспорт
	
	Возврат РекрутинговыеСайтыСлужебный.ВыполнитьHTTPЗапрос(Соединение, Метод, Запрос, ВызыватьИсключение);
	
КонецФункции

Функция СтруктураМаркеров(Обновление = Ложь)
	
	СтруктураМаркеров = РекрутинговыеСайтыСлужебный.НоваяСтруктураМаркеров();
	
	Контекст = "Обработки.ИнтеграцияSuperJob.СтруктураМаркеров";
	
	ID_Программы = ID_ПрограммыSuperJob();
	Пароль_Программы = ПарольПрограммыSuperJob();
	
	Если Обновление Тогда
		СтрокаЗапроса = СтрШаблон("/2.0/oauth2/refresh_token/?refresh_token=%1&client_id=%2&client_secret=%3",
					МаркерОбновления, ID_Программы, Пароль_Программы);
	Иначе
		СтрокаЗапроса = СтрШаблон("/2.0/oauth2/password/?login=%1&password=%2&client_id=%3&client_secret=%4&hr=1",
					ИмяПользователя, Пароль, ID_Программы, Пароль_Программы);
	КонецЕсли;
	
	СоединениеАутентификации = РекрутинговыеСайтыСлужебный.НовоеHTTPСоединение(АдресСервера(), Истина);
	
	ЗаголовкиHTTP = Новый Соответствие();
	ЗаголовкиHTTP.Вставить("X-User-Type", " hr_user");
	
	Запрос = Новый HTTPЗапрос(СтрокаЗапроса, ЗаголовкиHTTP);
	
	РезультатЗапроса = РекрутинговыеСайтыСлужебный.ВыполнитьHTTPЗапрос(
		СоединениеАутентификации, МетодыЗапросов().Получить, Запрос);
	
	// Отрабатываем редирект.
	Если РезультатЗапроса.КодСостояния >= 300 И РезультатЗапроса.КодСостояния <= 308 Тогда
		// Проверим обязательные заголовки ответа.
		ТекстСообщения = НСтр("ru = 'В ответе сервера SuperJob с кодом %1 отсутствует обязательный заголовок %2'");
		ОбщегоНазначенияКлиентСервер.Проверить(РезультатЗапроса.Ответ.Заголовки["Set-Cookie"] <> Неопределено, 
			СтрШаблон(ТекстСообщения, РезультатЗапроса.Ответ.КодСостояния, "Set-Cookie"), Контекст);
		ОбщегоНазначенияКлиентСервер.Проверить(РезультатЗапроса.Ответ.Заголовки["Location"] <> Неопределено, 
			СтрШаблон(ТекстСообщения, РезультатЗапроса.Ответ.КодСостояния, "Location"), Контекст);
		// Уточним заголовки нового запроса.
		ЗаголовкиHTTP.Вставить("Cookie", РезультатЗапроса.Ответ.Заголовки["Set-Cookie"]);
		
		Запрос = Новый HTTPЗапрос(РезультатЗапроса.Ответ.Заголовки["Location"], ЗаголовкиHTTP);
		
		РезультатЗапроса = РекрутинговыеСайтыСлужебный.ВыполнитьHTTPЗапрос(
			СоединениеАутентификации, МетодыЗапросов().Получить, Запрос);
	КонецЕсли;
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		РекрутинговыеСайтыСлужебный.СообщитьОбОшибкеАвторизации(Сайт, ЭтотОбъект, РезультатЗапроса);
		Возврат СтруктураМаркеров;
	КонецЕсли;
	
	ОтветОбъект = ПрочитатьОтветМаркерыДоступа(РезультатЗапроса);
	
	СтруктураМаркеров.МаркерДоступа = ОтветОбъект.access_token;
	СтруктураМаркеров.МаркерОбновления = ОтветОбъект.refresh_token;
	СтруктураМаркеров.ДатаОкончанияДействияМаркераДоступа = ТекущаяДатаСеанса() + ОтветОбъект.expires_in;
	
	МаркерДоступа = СтруктураМаркеров.МаркерДоступа;
	МаркерОбновления = СтруктураМаркеров.МаркерОбновления;
	ДатаОкончанияДействияМаркераДоступа = СтруктураМаркеров.ДатаОкончанияДействияМаркераДоступа;
	
	Возврат СтруктураМаркеров;
	
КонецФункции

Функция МаркерАктивен()
	
	МаркерДействителен = ЗначениеЗаполнено(МаркерДоступа) 
			И ДатаОкончанияДействияМаркераДоступа > ТекущаяДатаСеанса();
		
	МаркерАктивен = Ложь;
		
	Если МаркерДействителен Тогда
		МаркерАктивен = СайтДоступен();
	КонецЕсли;
		
	Если Не МаркерАктивен И ЗначениеЗаполнено(МаркерОбновления) Тогда
		РезультатОбновления = ОбновитьМаркеры();
		Если ЗначениеЗаполнено(РезультатОбновления.МаркерДоступа) Тогда
			МаркерАктивен = Истина;
			РезультатОбновления.Пользователь = Пользователь;
			РекрутинговыеСайтыСлужебный.СохранитьНастройкиАвторизации(РезультатОбновления);
		КонецЕсли;
	КонецЕсли;
	
	Возврат МаркерАктивен;
	
КонецФункции

Функция СайтДоступен()
	
	Возврат ЗначениеЗаполнено(ИнформацияОПользователе().ИмяПользователя);
	
КонецФункции

Функция ОбновитьМаркеры()
	
	Результат = РекрутинговыеСайтыСлужебный.НовыеРеквизитыСайта();
	Результат.Сайт = Сайт;
	
	СтруктураМаркеров = СтруктураМаркеров(Истина);
	
	Если ЗначениеЗаполнено(СтруктураМаркеров.МаркерДоступа) Тогда
		Результат.Подключен = Истина;
		
		ИнформацияОПользователе= ИнформацияОПользователе();
		
		Результат.МаркерДоступа = СтруктураМаркеров.МаркерДоступа;
		Результат.МаркерОбновления = СтруктураМаркеров.МаркерОбновления;
		Результат.ДатаОкончанияДействияМаркераДоступа = СтруктураМаркеров.ДатаОкончанияДействияМаркераДоступа;
		
		Результат.ИмяПользователя = ИнформацияОПользователе.ИмяПользователя;
		Результат.ИдентификаторПользователя = ИнформацияОПользователе.ИдентификаторКомпании;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция НовыйHTTPЗапрос(ТекстЗапроса)
	
	Заголовки = Новый Соответствие();
	Заголовки.Вставить("X-Api-App-Id", ПарольПрограммыSuperJob());
	Заголовки.Вставить("Content-Type", "application/x-www-form-urlencoded");
	
	Если ЗначениеЗаполнено(МаркерДоступа) Тогда
		Заголовки.Вставить("Authorization", "Bearer " + МаркерДоступа);
	КонецЕсли;
	
	Запрос = Новый HTTPЗапрос(ТекстЗапроса, Заголовки);
	
	Возврат Запрос;
	
КонецФункции

Функция АдресСервера()
	
	Возврат ДанныеСайта.АдресЗапроса;
	
КонецФункции

Функция АдресСайта()
	
	Возврат ДанныеСайта.ИмяСайта;
	
