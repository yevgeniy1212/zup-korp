#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область СлужебныйПрограммныйИнтерфейс

Функция Сайт() Экспорт
	
	Возврат Справочники.ИсточникиИнформацииОКандидатах.АвитоРабота;
	
КонецФункции

// Параметры:
//  Пользователь - СправочникСсылка.Пользователи
// 
// Возвращаемое значение:
//  ОбработкаОбъект.ИнтеграцияАвитоРабота
Функция НовыйМенеджер(Пользователь) Экспорт
	
	Менеджер = Создать();
	
	Менеджер.Сайт = Сайт();
	Менеджер.Пользователь = Пользователь;
	Менеджер.ДанныеСайта = ДанныеСайта();
	
	Возврат Менеджер;
	
КонецФункции

// Возвращаемое значение:
//  Структура: См. РекрутинговыеСайтыСлужебный.НовыеДанныеСайта
Функция ДанныеСайта() Экспорт
	
	ДанныеСайта = РекрутинговыеСайтыСлужебный.НовыеДанныеСайта();
	
	ДанныеСайта.Имя = Имя();
	ДанныеСайта.ИмяСайта = ИмяСайта();
	ДанныеСайта.Представление = Представление();
	ДанныеСайта.АдресЗапроса = АдресЗапроса();
	ДанныеСайта.ГлавнаяСтраница = ГлавнаяСтраница();
	ДанныеСайта.Логотип = Логотип();
	ДанныеСайта.ТекстВопросаПоКонтактногоДоступа = ТекстВопросаПоКонтактногоДоступа();
	ДанныеСайта.ДоступнаЗагрузкаКомментариевКандидатов = Ложь;
	
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("billing_type", "billing_type");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("business_area", "business_area");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("schedule", "schedule");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("experience", "experience");
	
	ДанныеСайта.ИменаПутейКДаннымВакансии.Вакансия = "title";
	ДанныеСайта.ИменаПутейКДаннымВакансии.Адрес = "url";
	ДанныеСайта.ИменаПутейКДаннымВакансии.Идентификатор = "id";
	
	ДанныеСайта.ПоляВакансииВПрограммеИНаСайте.Наименование = "name";
	ДанныеСайта.ПоляВакансииВПрограммеИНаСайте.ПредполагаемыйДоход = "salary";
	ДанныеСайта.ПоляВакансииВПрограммеИНаСайте.Описание = "description";
	
	ДанныеСайта.ШаблоныСтраницСайта.Сайт = Сайт();
	ДанныеСайта.ШаблоныСтраницСайта.Логотип = Логотип();
	ДанныеСайта.ШаблоныСтраницСайта.ГлавнаяСтраница = ГлавнаяСтраница();
	ДанныеСайта.ШаблоныСтраницСайта.ШаблонURLРезюме = "https://*.avito.ru/*rezume/*";
	ДанныеСайта.ШаблоныСтраницСайта.РегулярноеВыражениеURLСайта = "https:\/\/((.*?\.avito)|(avito))\.ru\/.*";
	ДанныеСайта.ШаблоныСтраницСайта.РегулярноеВыражениеURLРезюме = "https:\/\/((.*?\.avito)|(avito))\.ru(\/.*?\/|\/)rezume\/[^-]*?";
	
	ИдентификаторПриложения = ЗарплатаКадрыРасширенный.ИдентификацияПриложенияДляАвитоРабота();
	АдресАвторизации = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				"%1?response_type=code&client_id=%2&scope=messenger:read,messenger:write,user_balance:read,job:write,job:vacancy,job:cv,job:negotiations,user:read,items:info",
				ИдентификаторПриложения.auth_uri,
				ИдентификаторПриложения.client_id);
	ДанныеСайта.АдресАвторизации = АдресАвторизации;
	
	ЗаполнитьПараметрыФорм(ДанныеСайта);
	
	Возврат ДанныеСайта;
	
КонецФункции

