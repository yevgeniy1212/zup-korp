Функция ДеревоРегионов()
	
	Дерево = Новый ДеревоЗначений;
	Дерево.Колонки.Добавить("Значение", Новый ОписаниеТипов("Строка"));
	Дерево.Колонки.Добавить("Идентификатор", Новый ОписаниеТипов("Строка"));
	Дерево.Колонки.Добавить("ИдентификаторДоп", Новый ОписаниеТипов("Строка"));
	Дерево.Колонки.Добавить("Пометка", Новый ОписаниеТипов("Число"));
	
	Макет = ПолучитьМакет("ГородаАвитоРабота");
	СтрокаXML = Макет.ПолучитьТекст();
	
	ЧтениеXML = Новый ЧтениеXML;
	ЧтениеXML.УстановитьСтроку(СтрокаXML);
	
	СтрокаРегион = Неопределено;
	
	Пока ЧтениеXML.Прочитать() Цикл
		Если ЧтениеXML.ТипУзла = ТипУзлаXML.НачалоЭлемента Тогда
			Если ЧтениеXML.Имя = "Region" Тогда
				НоваяСтрока = Дерево.Строки.Добавить();
				СтрокаРегион = НоваяСтрока;
			ИначеЕсли ЧтениеXML.Имя = "City" Тогда
				НоваяСтрока = СтрокаРегион.Строки.Добавить();
			Иначе
				Продолжить;
			КонецЕсли;
			НоваяСтрока.Идентификатор = ЧтениеXML.ПолучитьАтрибут("Id");
			НоваяСтрока.Значение = ЧтениеXML.ПолучитьАтрибут("Name");
		КонецЕсли;
	КонецЦикла;

	Возврат Дерево;
	
КонецФункции

Функция ОписаниеПубликацииВакансии(ИдентификаторВакансии, СообщатьОбОшибке = Истина)
	
	ОписаниеПубликации = Неопределено;
	
	Если Не УстановитьСоединение() Тогда
		Возврат ОписаниеПубликации;
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос(СтрШаблон("job/v2/vacancies/%1", ИдентификаторВакансии));
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		Если СообщатьОбОшибке Тогда
			РекрутинговыеСайтыСлужебный.СообщитьОбОшибкеПолученияВакансии(Сайт, ЭтотОбъект, РезультатЗапроса);
		КонецЕсли;
	Иначе
		ОписаниеПубликации = ПрочитатьОтветОписаниеПубликацииВакансии(РезультатЗапроса);
		ОписаниеПубликации.url = ДанныеСайта.ГлавнаяСтраница + ОписаниеПубликации.url;
	КонецЕсли;
	
	Возврат ОписаниеПубликации;
	
КонецФункции

Процедура ЗаполнитьМассивКонтактнойИнформации(СтруктураРезюме, МассивКИ)
	
	РегионРаботы = ЗначениеСвойстваУзла(СтруктураРезюме, "params", "address",, Неопределено);
	Если Не РегионРаботы = Неопределено Тогда
		СтруктураКИ = СтруктураКонтактнойИнформации();
		СтруктураКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Адрес;
		СтруктураКИ.Вид = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.АдресЛичныеДанныеКандидатов");
		СтруктураКИ.Представление = РегионРаботы;
		МассивКИ.Добавить(СтруктураКИ);
	КонецЕсли;
	
	КонтактнаяИнформация = ЗначениеСвойстваУзла(СтруктураРезюме, "contacts", ,, Неопределено);
	Если Не ЗначениеЗаполнено(КонтактнаяИнформация) Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Контакт Из КонтактнаяИнформация Цикл
		СтруктураКИ = СтруктураКонтактнойИнформации();
		Если ЗначениеСвойстваУзла(Контакт, "type") = "e-mail" Тогда
			СтруктураКИ.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
			СтруктураКИ.Вид = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.EMailЛичныеДанныеКандидатов");
		Иначе
			СтруктураКИ.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон;
			СтруктураКИ.Вид = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.ТелефонЛичныеДанныеКандидатов");
		КонецЕсли;
		СтруктураКИ.Представление = ЗначениеСвойстваУзла(Контакт, "value");
		МассивКИ.Добавить(СтруктураКИ);
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаполнитьМассивОбразование(СтруктураРезюме, МассивОбразование)
	
	Образования = ЗначениеСвойстваУзла(СтруктураРезюме, "params", "education_list",, Неопределено);
	Если Образования = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	УровеньОбразования = ВидОбразованияПоИдентификатору(ЗначениеСвойстваУзла(СтруктураРезюме, "params", "education"));
		
	Для Каждого Образование Из Образования Цикл
		СтруктураОбразование = Справочники.ЛичныеДанныеКандидатов.НовоеОбразованиеДляФизическогоЛица();
		СтруктураОбразование.УчебноеЗаведение = ЗначениеСвойстваУзла(Образование, "institution");
		СтруктураОбразование.Специальность = ЗначениеСвойстваУзла(Образование, "specialty");
		ДатаОкончания = ЗначениеСвойстваУзла(Образование, "education_stop");
		СтруктураОбразование.ВидОбразования = УровеньОбразования;
		МассивОбразование.Добавить(СтруктураОбразование);
	КонецЦикла;
	
КонецПроцедуры

Функция ВидОбразованияПоИдентификатору(Идентификатор)
	
	ВидОбразования = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыОбразованияФизическихЛиц.ПустаяСсылка");
	// АПК:1297-выкл Идентификаторы внешнего классификатора, не требуют локализации
	Если Идентификатор = "Среднее" Тогда // среднее
		ВидОбразования = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыОбразованияФизическихЛиц.СреднееПолноеОбщееОбразование");
	ИначеЕсли Идентификатор = "Среднее специальное" Тогда // средне-специальное
		ВидОбразования = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыОбразованияФизическихЛиц.СреднееПрофессиональноеОбразование");
	ИначеЕсли Идентификатор = "Незаконченное высшее" Тогда // неполное высшее
		ВидОбразования = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыОбразованияФизическихЛиц.НеполноеВысшееОбразование");
	ИначеЕсли Идентификатор = "Высшее" Тогда // высшее
		ВидОбразования = ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыОбразованияФизическихЛиц.ВысшееОбразование");
	КонецЕсли;
	// АПК:1297-вкл
	
	Возврат ВидОбразования;
	
КонецФункции

// Параметры:
//  ТаблицаНайденныхКандидатов - ТаблицаЗначений
//  РезультатПоискаРезюме - Соответствие
//  ПолеСортировки - Число
Процедура ДозаполнитьТаблицуРезюме(ТаблицаНайденныхКандидатов, РезультатПоискаРезюме, ПолеСортировки)
	
	Для Каждого Резюме Из РезультатПоискаРезюме.resumes Цикл
		
		НоваяСтрока = ТаблицаНайденныхКандидатов.Добавить();
		НоваяСтрока.ГдеНайден = Сайт;
		НоваяСтрока.НазваниеРезюме = Резюме.title;
		НоваяСтрока.ФИО = НСтр("ru = 'Будут загружены при создании кандидата.'");
		НоваяСтрока.ПоследнееМестоРаботы = НСтр("ru = 'Будет загружено при создании кандидата.'");
		НоваяСтрока.УровеньЗарплаты = ЗначениеСвойстваУзла(Резюме, "salary",,, 0);
		НоваяСтрока.Регион = ЗначениеСвойстваУзла(Резюме, "location", "title");
		
		Пол = ЗначениеСвойстваУзла(Резюме, "gender");
		Если Пол = "male" Тогда
			НоваяСтрока.Пол = РекрутинговыеСайтыСлужебный.МужскойПол();
		ИначеЕсли Пол = "female" Тогда
			НоваяСтрока.Пол = РекрутинговыеСайтыСлужебный.ЖенскийПол();
		Иначе
			НоваяСтрока.Пол = "-";
		КонецЕсли;
		НоваяСтрока.Возраст = ЗначениеСвойстваУзла(Резюме, "age");
		НоваяСтрока.ИдентификаторРезюме = Формат(ЗначениеСвойстваУзла(Резюме, "id"), "ЧГ=");
		
		НоваяСтрока.СсылкаНаРезюме = СсылкаНаРезюме(НоваяСтрока.ИдентификаторРезюме);
		
		ДатаОбновления = РекрутинговыеСайтыСлужебный.ДатаПоСтроке(ЗначениеСвойстваУзла(Резюме, "updated_at"), Ложь);
		ДатаСоздания = РекрутинговыеСайтыСлужебный.ДатаПоСтроке(ЗначениеСвойстваУзла(Резюме, "created_at"), Ложь);
		Если ЗначениеЗаполнено(ДатаОбновления) Тогда
			НоваяСтрока.ДатаРазмещения = ДатаОбновления;
		ИначеЕсли ЗначениеЗаполнено(ДатаСоздания) Тогда
			НоваяСтрока.ДатаРазмещения = ДатаСоздания;
		КонецЕсли;
		
		НоваяСтрока.ПолеСортировки = ПолеСортировки;
		ПолеСортировки = ПолеСортировки + 1;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#КонецЕсли
