Функция РеактивироватьВакансию(ИдентификаторВакансии, Дерево)
	
	Результат = РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией();
	
	JSONОписаниеВакансииAvito = JSONОписаниеВакансии(Дерево, Истина, Истина);
	
	Если Не УстановитьСоединение() Тогда
		Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкойОбновленияВакансии(Сайт, ЭтотОбъект);
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос(СтрШаблон("/job/v1/vacancies/%1/prolongate", ИдентификаторВакансии));
	Запрос.УстановитьТелоИзСтроки(JSONОписаниеВакансииAvito);
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Записать, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 204 И РезультатЗапроса.КодСостояния <> 403 Тогда
		Результат = РекрутинговыеСайтыСлужебный.РезультатСОшибкойОбновленияВакансии(Сайт, ЭтотОбъект, РезультатЗапроса);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ПолучитьВсеСтраницыРесурса(Ресурс, ИмяСвойстваРезультата, МассивРезультатов, Страница = 1, Курсор = 0)
	
	НаСтранице = 20;
	ТекРесурс = Ресурс;
	Если СтрНайти(Ресурс, "?") > 0 Тогда
		ТекРесурс = ТекРесурс + "&";
	Иначе
		ТекРесурс = ТекРесурс + "?";
	КонецЕсли;
	
	ТекРесурс = СтрШаблон("%1per_page=%2&page=%3&cursor=%4", ТекРесурс,
		Формат(НаСтранице, "ЧН=0; ЧГ="),
		Формат(Страница, "ЧН=0; ЧГ="),
		Формат(Курсор, "ЧН=0; ЧГ="));

	Запрос = НовыйHTTPЗапрос(ТекРесурс);
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		ТекстСообщения = СтрШаблон(НСтр("ru = 'Ошибка получения содержимого ресурса %1 с сайта %2.'"), Ресурс, Сайт);
		РекрутинговыеСайтыСлужебный.СообщитьОбОшибке(ТекстСообщения, Сайт, ЭтотОбъект, РезультатЗапроса);
		Возврат;
	КонецЕсли;
	
	СтруктураОтвета = ПарсерJSON(РезультатЗапроса.ТелоОтвета);
	Если МассивРезультатов.Количество() = 0 Тогда
		МассивРезультатов = СтруктураОтвета[ИмяСвойстваРезультата];
	Иначе
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(МассивРезультатов, СтруктураОтвета[ИмяСвойстваРезультата]);
	КонецЕсли;
	
	ВсегоСтраниц = ЗначениеСвойстваУзла(СтруктураОтвета, "meta", "pages", Неопределено);
	
	Если ВсегоСтраниц = Неопределено Тогда
		ТекстСообщения = СтрШаблон(НСтр("ru = 'Ошибка получения содержимого ресурса %1 с сайта %2.'"), Ресурс, Сайт);
		РекрутинговыеСайтыСлужебный.СообщитьОбОшибке(ТекстСообщения, Сайт, ЭтотОбъект, РезультатЗапроса);
		Возврат;
	КонецЕсли;
	
	Курсор = ЗначениеСвойстваУзла(СтруктураОтвета, "meta", "cursor", Неопределено);
	
	Страница = Страница + 1;
	
	Если ВсегоСтраниц < Страница Тогда
		Возврат;
	КонецЕсли;
	
	ПолучитьВсеСтраницыРесурса(Ресурс, ИмяСвойстваРезультата, МассивРезультатов, Страница, Курсор);
	
КонецПроцедуры

