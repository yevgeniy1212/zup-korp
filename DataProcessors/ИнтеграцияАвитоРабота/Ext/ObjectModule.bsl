Функция СтруктураРезюмеССайта(ИдентификаторРезюме, ПолучатьФото = Истина, ПолучатьКонтакты = Ложь)
	
	Резюме = Неопределено;
	
	Если Не УстановитьСоединение() Тогда
		Возврат Резюме;
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос("/job/v2/resumes/" + ИдентификаторРезюме + "?photos=true");
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		ВызватьИсключение РекрутинговыеСайтыСлужебный.ТекстОшибкиПоОписанию(Сайт, ЭтотОбъект, РезультатЗапроса);
	КонецЕсли;
	
	Резюме = ПрочитатьОтветСтруктураРезюме(РезультатЗапроса);
	
	Если ПолучатьФото Тогда
		Фотографии = ЗначениеСвойстваУзла(Резюме, "photos");
		Если ЗначениеЗаполнено(Фотографии) Тогда
			АдресФото = Фотографии[0]["url"];
			Если ЗначениеЗаполнено(АдресФото) Тогда
				Резюме.Вставить("Фото", РекрутинговыеСайтыСлужебный.КартинкаПоАдресу(АдресФото));
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
	
	ПолучатьКонтакты = Резюме["is_purchased"] Или ПолучатьКонтакты;
	
	Если ПолучатьКонтакты Тогда
		Запрос = НовыйHTTPЗапрос("/job/v1/resumes/" + ИдентификаторРезюме + "/contacts/");
		РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
	КонецЕсли;
	
	Контакты = ПрочитатьОтветКонтактыРезюме(РезультатЗапроса);
	Резюме.Вставить("contact_name", ЗначениеСвойстваУзла(Контакты, "name"));
	Резюме.Вставить("contacts", ЗначениеСвойстваУзла(Контакты, "contacts"));
	
	Резюме.Вставить("Комментарии", Новый Массив());
	
	Возврат Резюме;
	
КонецФункции

// Параметры:
//  СтруктураРезюме - Структура: см. СтруктураРезюмеССайта
// 
// Возвращаемое значение:
//  Структура: см. ПодборПерсоналаКлиентСервер.ОписаниеРезюмеКандидата
Функция ДанныеКандидатаПоРезюме(СтруктураРезюме)
	
	ДанныеКандидата = Справочники.Кандидаты.СтруктураДанныхКандидата();
	ДанныеКандидата.ИсточникИнформации = Сайт;

	ЗаполнитьДоступностьКонтактов(ДанныеКандидата.ДоступностьКонтактов, СтруктураРезюме);

	// Адрес резюме
	АдресРезюме = ЗначениеСвойстваУзла(СтруктураРезюме, "url", , Неопределено);
	Если Не АдресРезюме = Неопределено Тогда
		ДанныеКандидата.АдресРезюме = СтрШаблон("https://www.avito.ru%1", АдресРезюме);
	КонецЕсли;
	
	// ФИО
	ФИО = ЗначениеСвойстваУзла(СтруктураРезюме, "contact_name", , , Неопределено);
	Если Не ФИО = Неопределено Тогда
		ЗаполнитьЗначенияСвойств(ДанныеКандидата, ФизическиеЛицаКлиентСервер.ЧастиИмени(ФИО));
	КонецЕсли;
	
	// Контактная информация
	ЗаполнитьМассивКонтактнойИнформации(СтруктураРезюме, ДанныеКандидата.КонтактнаяИнформация);
	
	// Пол
	Пол = ЗначениеСвойстваУзла(СтруктураРезюме, "params", "pol", , Неопределено);
	Если Не Пол = Неопределено Тогда
		Если Пол = "Мужской" Тогда
			ДанныеКандидата.Пол = РекрутинговыеСайтыСлужебный.МужскойПол();
		ИначеЕсли Пол = "Женский" Тогда
			ДанныеКандидата.Пол = РекрутинговыеСайтыСлужебный.ЖенскийПол();
		КонецЕсли;
	КонецЕсли;
	
	// Гражданство
	СтранаГражданства = ЗначениеСвойстваУзла(СтруктураРезюме, "params", "nationality", , Неопределено);
	Если Не СтранаГражданства = Неопределено Тогда
		СтруктураГражданство = Новый Структура("Страна, Дата");
		СтруктураГражданство.Страна = СтранаГражданства;
		ДанныеКандидата.Гражданство.Добавить(СтруктураГражданство);
	КонецЕсли;
	
	// Образование
	ЗаполнитьМассивОбразование(СтруктураРезюме, ДанныеКандидата.Образование);
	
	// Трудовая деятельность
	МестаРаботы = ЗначениеСвойстваУзла(СтруктураРезюме, "params", "experience_list", , Неопределено);
	Если Не МестаРаботы = Неопределено Тогда
		Для Каждого МестоРаботы Из МестаРаботы Цикл
			СтруктураТрудоваяДеятельность = РекрутинговыеСайтыСлужебный.НовыйОпытРаботы();
			СтруктураТрудоваяДеятельность.Компания = ЗначениеСвойстваУзла(МестоРаботы, "company");
			ДатаНачала = РекрутинговыеСайтыСлужебный.ДатаПоСтроке(ЗначениеСвойстваУзла(МестоРаботы, "work_start"), Ложь);
			ДатаОкончания = РекрутинговыеСайтыСлужебный.ДатаПоСтроке(ЗначениеСвойстваУзла(МестоРаботы, "work_finish"), Ложь);
			Если ЗначениеЗаполнено(ДатаНачала) Тогда
				СтруктураТрудоваяДеятельность.ДатаНачала = ДатаНачала;
			КонецЕсли;
			Если ЗначениеЗаполнено(ДатаОкончания) Тогда
				СтруктураТрудоваяДеятельность.ДатаОкончания = ДатаОкончания;
			КонецЕсли;
			СтруктураТрудоваяДеятельность.Должность = ЗначениеСвойстваУзла(МестоРаботы, "position");
			СтруктураТрудоваяДеятельность.Обязанности = ЗначениеСвойстваУзла(МестоРаботы, "responsibilities");
			ДанныеКандидата.ТрудоваяДеятельность.Добавить(СтруктураТрудоваяДеятельность);
		КонецЦикла;
	КонецЕсли;
	
	// Знание языков
	ЗнанияЯзыков = ЗначениеСвойстваУзла(СтруктураРезюме, "params", "language_list", , Неопределено);
	Если Не ЗнанияЯзыков = Неопределено Тогда
		Для Каждого ЗнаниеЯзыка Из ЗнанияЯзыков Цикл
			СтруктураЗнаниеЯзыков = РекрутинговыеСайтыСлужебный.НовоеЗнаниеЯзыка();
			СтруктураЗнаниеЯзыков.Язык = ЗначениеСвойстваУзла(ЗнаниеЯзыка, "language");
			СтруктураЗнаниеЯзыков.СтепеньЗнанияЯзыкаКандидата =
				СтепеньЗнанияЯзыкаПоИдентификатору(ЗначениеСвойстваУзла(ЗнаниеЯзыка, "language_level"));
			ДанныеКандидата.ЗнаниеЯзыков.Добавить(СтруктураЗнаниеЯзыков);
		КонецЦикла;
	КонецЕсли;
	
	// Ожидаемый доход
	ДанныеКандидата.ОжидаемыйДоход = ЗначениеСвойстваУзла(СтруктураРезюме, "salary", , , Неопределено);
	
	// О себе
	СтрокаОСебе = ЗначениеСвойстваУзла(СтруктураРезюме, "description");
	
	// Авито не возвращает дату рождения, только возраст.
	Возраст = ЗначениеСвойстваУзла(СтруктураРезюме, "params", "age");
	Если ЗначениеЗаполнено(Возраст) Тогда
		СтрокаОСебе = СтрШаблон(НСтр("ru = 'Возраст: %1'"), Возраст) + Символы.ПС + СтрокаОСебе;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СтрокаОСебе) Тогда
		РекрутинговыеСайтыСлужебный.ЗаменитьУпрСимволы(СтрокаОСебе);
		ДанныеКандидата.ОСебе = СтрокаОСебе;
	КонецЕсли;
	
	// Фото
	ДанныеКандидата.Фото = ЗначениеСвойстваУзла(СтруктураРезюме, "Фото");
	
	Возврат ДанныеКандидата;
	
КонецФункции

Функция СтруктураКонтактнойИнформации() Экспорт
	
	СтруктураКонтактнойИнформации = Новый Структура();
	
	СтруктураКонтактнойИнформации.Вставить("Тип", Перечисления.ТипыКонтактнойИнформации.ПустаяСсылка());
	СтруктураКонтактнойИнформации.Вставить("Вид", Справочники.ВидыКонтактнойИнформации.ПустаяСсылка());
	СтруктураКонтактнойИнформации.Вставить("Представление", "");
	
	Возврат СтруктураКонтактнойИнформации
	
КонецФункции

// Параметры:
//  Узел - Структура
//  ИмяСвойства - Строка
//  ИмяСвойстваВторогоУровня - Неопределено, Строка -
//  ИмяСвойстваТретьегоУровня - Неопределено, Строка -
//  ЗначениеПоУмолчанию - Строка
// 
// Возвращаемое значение:
//  Строка, Массив, Произвольный -
Функция ЗначениеСвойстваУзла(Узел, ИмяСвойства, ИмяСвойстваВторогоУровня = Неопределено, ИмяСвойстваТретьегоУровня = Неопределено, ЗначениеПоУмолчанию = "")
	
	Возврат РекрутинговыеСайтыСлужебный.ЗначениеСвойстваУзла(
				Узел, ИмяСвойства, ИмяСвойстваВторогоУровня, ИмяСвойстваТретьегоУровня, ЗначениеПоУмолчанию);
	
КонецФункции

Процедура ЗаполнитьДоступностьКонтактов(ДоступностьКонтактов, СтруктураРезюме)
	
	ДоступПриобретен = ЗначениеСвойстваУзла(СтруктураРезюме, "is_purchased", , Неопределено);

	Если ДоступПриобретен = Ложь Тогда
		ДоступностьКонтактов.КонтактыОткрыты = Ложь;
	КонецЕсли;
	
КонецПроцедуры

Функция СтепеньЗнанияЯзыкаПоИдентификатору(Идентификатор)
	
	Если Идентификатор = "basic" Тогда // начальный
		УровеньВладенияЯзыком = Перечисления.УровниВладенияЯзыком.A1;
	ИначеЕсли Идентификатор = "middle" Тогда // средний
		УровеньВладенияЯзыком = Перечисления.УровниВладенияЯзыком.B1;
	ИначеЕсли Идентификатор = "upper-middle" Тогда // выше среднего
		УровеньВладенияЯзыком = Перечисления.УровниВладенияЯзыком.B2;
	Иначе // свободное владение
		УровеньВладенияЯзыком = Перечисления.УровниВладенияЯзыком.C2;
	КонецЕсли;
	
	Возврат Справочники.СтепениЗнанияЯзыкаКандидата.СтепеньЗнанияЯзыкаПоУровнюВладения(УровеньВладенияЯзыком);
	
КонецФункции

// Параметры:
//  СтруктураОтбора - Структура
//  НомерСтраницы - Число
// 
// Возвращаемое значение:
// Строка
Функция СтрокаОтбора(СтруктураОтбора, НомерСтраницы)
	
	СтрокаОтбора = "per_page=99&page=" + (НомерСтраницы + 1);
	
	СоответствиеПолей = СоответствиеПолейПоискаКандидатов();
	
	Для Каждого КлючИЗначение Из СтруктураОтбора Цикл
		
		ИмяПараметра = СоответствиеПолей.Получить(КлючИЗначение.Ключ);
		
		Если Не ЗначениеЗаполнено(ИмяПараметра) Тогда
			Продолжить;
		КонецЕсли;

		ЗначениеПоля = КлючИЗначение.Значение;

		Если Не ЗначениеЗаполнено(ЗначениеПоля) Тогда
			Продолжить;
		КонецЕсли;
		
		Если ТипЗнч(ЗначениеПоля) = Тип("Число") Тогда
			ЗначениеПоля = Формат(ЗначениеПоля, "ЧН=0; ЧГ=0");
		ИначеЕсли ТипЗнч(ЗначениеПоля) = Тип("Дата") Тогда
			ЗначениеПоля = Формат(ЗначениеПоля, "ДЛФ=Д");
		ИначеЕсли ТипЗнч(ЗначениеПоля) = Тип("Булево") Тогда
			Если КлючИЗначение.Ключ = "ТолькоВНазвании" Тогда
				ЗначениеПоля = Формат(ЗначениеПоля, "БЛ=fullthrottle; БИ=simple")
			Иначе
				ЗначениеПоля = Формат(ЗначениеПоля, "БЛ=false; БИ=true");
			КонецЕсли;
		ИначеЕсли ТипЗнч(ЗначениеПоля) = Тип("СписокЗначений") Тогда
			Если КлючИЗначение.Ключ = "Регион" Тогда
				Индекс = 0;
				Для Каждого ЭлементСписка Из ЗначениеПоля Цикл
					Если ТипЗнч(ЭлементСписка.Значение) = Тип("Структура") Тогда
						Идентификатор = "";
						
						Если ЭлементСписка.Значение.Свойство("IDAvito") Тогда
							Если Не ЭлементСписка.Значение.Свойство("IDAvito", Идентификатор) Тогда
								Продолжить;
							КонецЕсли;
						ИначеЕсли ЭлементСписка.Значение.Свойство("ИдентификаторОбщий") Тогда
							Идентификатор = ЭлементСписка.Значение.ИдентификаторОбщий;
						Иначе
							Продолжить;
						КонецЕсли;
						
					Иначе
						Идентификатор = ЭлементСписка.Значение;
					КонецЕсли;
					
					Если Индекс = 0 Тогда
						СтрокаОтбора = СтрокаОтбора + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
						"&%1=%2", ИмяПараметра, Формат(Идентификатор, "ЧГ=0"));
					Иначе
						СтрокаОтбора = СтрокаОтбора + СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
						",%1", Формат(Идентификатор, "ЧГ=0"));
					КонецЕсли;
					
					Индекс = Индекс + 1;
				КонецЦикла;
				
				Продолжить;
				
			ИначеЕсли ЗначениеЗаполнено(ЗначениеПоля) Тогда
				ЗначениеПоля = ЗначениеПоля[0];
				
				Если ТипЗнч(ЗначениеПоля.Значение) = Тип("Структура") Тогда
					Если ЗначениеПоля.Значение.Свойство("IDAvito") Тогда
						ЗначениеПоля = ЗначениеПоля.Значение.IDAvito;
					Иначе
						Продолжить;
					КонецЕсли;
				Иначе
					ЗначениеПоля = ЗначениеПоля.Значение
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		
		Если КлючИЗначение.Ключ = "ПериодРазмещения" Тогда
			Если ЗначениеПоля = 0 Тогда
				Продолжить;
			КонецЕсли;
			ЗначениеПоля = РекрутинговыеСайтыСлужебный.ДатаRFC3339(-ЗначениеПоля*86400);
		КонецЕсли;
	
		СтрокаОтбора = СтрокаОтбора
			+ СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку("&%1=%2", ИмяПараметра, ЗначениеПоля);
	КонецЦикла;

	Возврат СтрокаОтбора;
	
КонецФункции

Функция СсылкаНаРезюме(ИдентификаторРезюме)
	
	СсылкаНаРезюме = "";
	
	Попытка
		Резюме = СтруктураРезюмеССайта(ИдентификаторРезюме, Ложь, Ложь);
	Исключение
		Возврат СсылкаНаРезюме;
	КонецПопытки;

	Если ЗначениеЗаполнено(Резюме) Тогда
		СсылкаНаРезюме = "https://www.avito.ru" + Резюме["url"];
	КонецЕсли;
	
	Возврат СсылкаНаРезюме;
	
КонецФункции

// Параметры:
//  Дерево - ДеревоЗначений
//  Обновление - Булево
// 
// Возвращаемое значение:
//  Строка
Функция JSONОписаниеВакансии(Дерево, Обновление = Ложь, Реактивация = Ложь)
	
	СтрокаJSON = "";
	
	СтруктураОписанияВакансииAvito = СтруктураОписанияВакансии(Дерево, Обновление, Реактивация);
	СтрокаJSON = РекрутинговыеСайтыСлужебный.ЗаписьJSON(СтруктураОписанияВакансииAvito);
	
	Возврат СтрокаJSON;
	
КонецФункции

Функция СтруктураОписанияВакансии(Дерево, Обновление = Ложь, Реактивация = Ложь)
	
	СтруктураВакансии = Новый Структура;
	
	Для Каждого СтрокаДерева Из Дерево.Строки Цикл
		Если ТипЗнч(СтрокаДерева.Показатель) = Тип("СправочникСсылка.Вакансии") Тогда
			Для Каждого СтрокаДереваПодчиненная Из СтрокаДерева.Строки Цикл
				ДополнитьСтруктуруВакансииПростымОбъектом(СтруктураВакансии, СтрокаДереваПодчиненная, Обновление, Реактивация);
				ДополнитьСтруктуруВакансииОбъектом(СтруктураВакансии, СтрокаДереваПодчиненная, Обновление, Реактивация);
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;
	
	Возврат СтруктураВакансии;
	
КонецФункции

Процедура ДополнитьСтруктуруВакансииПростымОбъектом(СтруктураВакансии, СтрокаДерева, Обновление, Реактивация)
	
	Если Реактивация Тогда
		Возврат;
	КонецЕсли;
	
	Если Не (СтрокаДерева.ТипРеквизита = "Строка"
		Или СтрокаДерева.ТипРеквизита = "Булево"
		Или СтрокаДерева.ТипРеквизита = "Число") Тогда
		
		Возврат;
		
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СтрокаДерева.ПубликацияВакансии) Тогда
		Возврат;
	КонецЕсли;
	
	Если Обновление И Не СтрокаДерева.СтрокаИзменена Тогда
		
		Если СтрокаДерева.Путь = "name" Или СтрокаДерева.Путь = "description" Тогда
			Если Не СтрокаДерева.ВакансияВПрограммеТекст = СтрокаДерева.ПубликацияВакансииТекст Тогда
				СтрокаДерева.СтрокаИзменена = Истина;
				СтрокаДерева.ПубликацияВакансии = СтрокаДерева.ВакансияВПрограмме;
				СтрокаДерева.ПубликацияВакансииТекст = СтрокаДерева.ВакансияВПрограммеТекст;
			Иначе
				Возврат;
			КонецЕсли;
		Иначе
			Возврат;
		КонецЕсли;
		
	КонецЕсли;
	
	Значение = СтрокаДерева.ПубликацияВакансии;
	
	Если СтрокаДерева.ТипРеквизита = "Строка" Тогда
		ПоляСТекстомВHTML = ПоляВакансииСТекстомВHTML();
		Если ПоляСТекстомВHTML.Найти(СтрокаДерева.Путь) <> Неопределено Тогда
			Значение = СтрокаДерева.ПубликацияВакансииТекст;
		КонецЕсли
	КонецЕсли;
	
	СтруктураВакансии.Вставить(СтрокаДерева.Путь, Значение);

КонецПроцедуры

Процедура ДополнитьСтруктуруВакансииОбъектом(СтруктураВакансии, СтрокаДерева, Обновление, Реактивация)
	
	Если Не СтрокаДерева.ТипРеквизита = РекрутинговыеСайтыСлужебный.ТипРеквизитаНачалоОбъекта() Тогда
		Возврат;
	КонецЕсли;
	
	Если СтрокаДерева.Путь = "contacts" Тогда
		Возврат;
	КонецЕсли;
	
	Если Обновление И Не СтрокаДерева.СтрокаИзменена И Не СтрокаДерева.Путь = "billing_type" Тогда
		Возврат;
	КонецЕсли;
	
	ЗначениеПоля = СтрокаДерева.ПубликацияВакансии[0].Значение;
	
	Если СтрокаДерева.Путь = "billing_type" Тогда
		СтруктураВакансии.Вставить(СтрокаДерева.Путь, ЗначениеПоля);
		Возврат;
	КонецЕсли;
	
	Если Реактивация Тогда
		Возврат;
	КонецЕсли;
	
	Если СтрокаДерева.Путь = "business_area" Тогда
		СтруктураВакансии.Вставить(СтрокаДерева.Путь, ЗначениеПоля);
	Иначе
		СтруктураОбъекта = Новый Структура;
		СтруктураОбъекта.Вставить("id", ЗначениеПоля);
		СтруктураВакансии.Вставить(СтрокаДерева.Путь, СтруктураОбъекта);
	КонецЕсли;
	
КонецПроцедуры

