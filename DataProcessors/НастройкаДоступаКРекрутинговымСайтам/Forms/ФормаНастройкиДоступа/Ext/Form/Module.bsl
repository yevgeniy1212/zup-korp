
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	МенеджерСайтов = РекрутинговыеСайты.МенеджерРекрутинговыхСайтов(, , Ложь);
	
	Сайты = МенеджерСайтов.Сайты();
	ДанныеСайтов = МенеджерСайтов.ДанныеСайтов();
	
	ДополнитьФорму();
	
	Элементы.ГруппаКолонкаШаблон.Видимость = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	ПроверитьПодключение();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура Подключаемый_ЛоготипНажатие(Элемент)
	
	ЗаполнитьТекущийСайт(Элемент);
	
	ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(ДанныеСайтов[ТекущийСайт].ГлавнаяСтраница);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ПройтиАвторизацию(Команда)
	
	ЗаполнитьТекущийСайт(Команда);
	
	ЭтотОбъект[ИмяРеквизита(ДанныеСайтов, "Подключение", ТекущийСайт)] = Истина;
	
	ОбновитьВидимостьЭлементов(ЭтотОбъект, ДанныеСайтов);
	
КонецПроцедуры

&НаКлиенте
Процедура ПолучитьКод(Команда)
	
	ЗаполнитьТекущийСайт(Команда);
	
	ФайловаяСистемаКлиент.ОткрытьНавигационнуюСсылку(ДанныеСайтов[ТекущийСайт].АдресАвторизации);
	
КонецПроцедуры

&НаКлиенте
Процедура Подключить(Команда)
	
	ЗаполнитьТекущийСайт(Команда);
	
	Предупреждения = Новый Массив();
	
	Если ДанныеСайтов[ТекущийСайт].ПараметрыФорм.НастройкаДоступа.ВыводитьКодАвторизации Тогда
		
		Если Не ЗначениеЗаполнено(ЭтотОбъект[ИмяРеквизита(ДанныеСайтов, "КодАвторизации", ТекущийСайт)]) Тогда
			Предупреждения.Добавить(НСтр("ru = 'Введите код авторизации.'"));
		КонецЕсли;
		
	ИначеЕсли ДанныеСайтов[ТекущийСайт].ПараметрыФорм.НастройкаДоступа.ВыводитьПароль Тогда
		
		Если Не ЗначениеЗаполнено(ЭтотОбъект[ИмяРеквизита(ДанныеСайтов, "ИмяПользователя", ТекущийСайт)]) Тогда
			Предупреждения.Добавить(НСтр("ru = 'Введите имя пользователя.'"));
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(ЭтотОбъект[ИмяРеквизита(ДанныеСайтов, "Пароль", ТекущийСайт)]) Тогда
			Предупреждения.Добавить(НСтр("ru = 'Введите пароль.'"));
		КонецЕсли;
		
	Иначе
		Предупреждения.Добавить(НСтр("ru = 'Не указаны параметры авторизации. Обратитесь к администратору.'"));
	КонецЕсли;
	
	Если Предупреждения.Количество() <> 0 Тогда
		ПоказатьПредупреждение(, СтрСоединить(Предупреждения, Символы.ПС));
	Иначе
		НачатьПодключение();
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура Отключить(Команда)
	
	ЗаполнитьТекущийСайт(Команда);
	
	ОтключитьСайт(ТекущийСайт);
	
	ЭтотОбъект[ИмяРеквизита(ДанныеСайтов, "Подключен", ТекущийСайт)] = Ложь;
	
	ОбновитьВидимостьЭлементов(ЭтотОбъект, ДанныеСайтов);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ДополнитьФорму()
	
	ДобавитьРеквизиты();
	
	ДобавитьКоманды();
	
	ДобавитьЭлементы();
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьРеквизиты()
	
	ДобавляемыеРеквизиты = Новый Массив();
	
	Для Каждого Сайт Из Сайты Цикл
		
		ДанныеСайта = ДанныеСайтов[Сайт]; // См. РекрутинговыеСайтыСлужебный.НовыеДанныеСайта
		ПараметрыСайта = ДанныеСайта.ПараметрыФорм.НастройкаДоступа;
		
		Если Не ЗначениеЗаполнено(ДанныеСайта.Имя) Тогда
			Продолжить;
		КонецЕсли;
		
		Имя = "ИмяПользователя" + ДанныеСайта.Имя;
		Тип = ОбщегоНазначения.ОписаниеТипаСтрока(0);
		Реквизит = НовыйРеквизит(Имя, Тип);
		ДобавляемыеРеквизиты.Добавить(Реквизит);
		
		Имя = "Подключен" + ДанныеСайта.Имя;
		Тип = Новый ОписаниеТипов("Булево");
		Реквизит = НовыйРеквизит(Имя, Тип);
		ДобавляемыеРеквизиты.Добавить(Реквизит);
		
		Имя = "Подключение" + ДанныеСайта.Имя;
		Тип = Новый ОписаниеТипов("Булево");
		Реквизит = НовыйРеквизит(Имя, Тип);
		ДобавляемыеРеквизиты.Добавить(Реквизит);
		
		Если ПараметрыСайта.ВыводитьКодАвторизации Тогда
			Имя = "КодАвторизации" + ДанныеСайта.Имя;
			Тип = ОбщегоНазначения.ОписаниеТипаСтрока(0);
			Реквизит = НовыйРеквизит(Имя, Тип);
			ДобавляемыеРеквизиты.Добавить(Реквизит);
		КонецЕсли;
		
		Если ПараметрыСайта.ВыводитьПароль Тогда
			Имя = "Пароль" + ДанныеСайта.Имя;
			Тип = ОбщегоНазначения.ОписаниеТипаСтрока(0);
			Реквизит = НовыйРеквизит(Имя, Тип);
			ДобавляемыеРеквизиты.Добавить(Реквизит);
		КонецЕсли;
		
	КонецЦикла;
	
	ИменаРеквизитовФормы = Новый Массив;
	ЗарплатаКадры.ЗаполнитьМассивИменРеквизитовФормы(ЭтотОбъект, ИменаРеквизитовФормы);
	ЗарплатаКадры.ИзменитьРеквизитыФормы(ЭтотОбъект, ДобавляемыеРеквизиты, ИменаРеквизитовФормы);
	
КонецПроцедуры

&НаСервере
Функция НовыйРеквизит(Имя, Тип, Заголовок = "", Путь = "", СохраняемыеДанные = Ложь)
	
	Возврат РекрутинговыеСайтыФормы.НовыйРеквизит(Имя, Тип, Заголовок, Путь, СохраняемыеДанные);
	
КонецФункции

&НаСервере
Процедура ДобавитьКоманды()
	
	Для Каждого Сайт Из Сайты Цикл
		
		ДанныеСайта = ДанныеСайтов[Сайт]; // См. РекрутинговыеСайтыСлужебный.НовыеДанныеСайта
		ПараметрыСайта = ДанныеСайта.ПараметрыФорм.НастройкаДоступа;
		
		Если Не ЗначениеЗаполнено(ДанныеСайта.Имя) Тогда
			Продолжить;
		КонецЕсли;
		
		Команда = Команды.Добавить("ПройтиАвторизацию" + ДанныеСайта.Имя);
		Команда.Заголовок = СтрШаблон(НСтр("ru = 'Пройти авторизацию'"));
		Команда.Действие = "ПройтиАвторизацию";
		
		Если ПараметрыСайта.ВыводитьКодАвторизации Тогда
			Команда = Команды.Добавить("ПолучитьКод" + ДанныеСайта.Имя);
			Команда.Заголовок = СтрШаблон(НСтр("ru = 'Получить код'"));
			Команда.Действие = "ПолучитьКод";
		КонецЕсли;
		
		Команда = Команды.Добавить("Подключить" + ДанныеСайта.Имя);
		Команда.Заголовок = СтрШаблон(НСтр("ru = 'Подключить'"));
		Команда.Действие = "Подключить";
		
		Команда = Команды.Добавить("Отключить" + ДанныеСайта.Имя);
		Команда.Заголовок = СтрШаблон(НСтр("ru = 'Отключить'"));
		Команда.Действие = "Отключить";
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьЭлементы()
	
	ШаблонГруппа = Элементы.ГруппаШаблон;
	
	СвойстваГруппа = Новый Массив();
	СвойстваГруппа.Добавить("Вид");
	СвойстваГруппа.Добавить("Отображение");
	СвойстваГруппа.Добавить("Группировка");
	СвойстваГруппа.Добавить("ОтображатьЗаголовок");
	СвойстваГруппа.Добавить("ГоризонтальныйИнтервал");
	СвойстваГруппа.Добавить("ВертикальныйИнтервал");
	СвойстваГруппа.Добавить("ЦветФона");
	СвойстваГруппа.Добавить("Ширина");
	СвойстваГруппа.Добавить("Высота");
	СвойстваГруппа.Добавить("РастягиватьПоГоризонтали");
	СвойстваГруппа.Добавить("РастягиватьПоВертикали");
	
	ШаблонЛоготип = Элементы.ЛоготипШаблон;
	
	СвойстваЛоготип = Новый Массив();
	СвойстваЛоготип.Добавить("Вид");
	СвойстваЛоготип.Добавить("Гиперссылка");
	СвойстваЛоготип.Добавить("ОтображениеПодсказки");
	СвойстваЛоготип.Добавить("СпособПеретаскиванияФайлов");
	СвойстваЛоготип.Добавить("РазмерКартинки");
	СвойстваЛоготип.Добавить("ВертикальноеПоложениеВГруппе");
	
	ШаблонСтраницы = Элементы.СтраницыШаблон;
	
	СвойстваСтраницы = Новый Массив();
	СвойстваСтраницы.Добавить("Вид");
	СвойстваСтраницы.Добавить("ОтображениеСтраниц");
	СвойстваСтраницы.Добавить("ВертикальноеПоложениеВГруппе");
	
	ШаблонСтраницаНеПодключен = Элементы.СтраницаНеПодключенШаблон;
	
	СвойстваСтраницаНеПодключен= Новый Массив();
	СвойстваСтраницаНеПодключен.Добавить("Вид");
	
	ШаблонСтраницаПодключение = Элементы.СтраницаПодключениеШаблон;
	
	СвойстваСтраницаПодключение = Новый Массив();
	СвойстваСтраницаПодключение.Добавить("Вид");
	
	ШаблонСтраницаПодключен = Элементы.СтраницаПодключенШаблон;
	
	СвойстваСтраницаПодключен = Новый Массив();
	СвойстваСтраницаПодключен.Добавить("Вид");
	
	МаксКоличествоКолонок = 3;
	МаксКоличествоСайтовВКолонке = 4;
	КоличествоСайтов = Сайты.Количество();
	КоличествоСайтовВКолонке = 1;
	КоличествоКолонок = Мин(МаксКоличествоКолонок,
		?(КоличествоСайтов % МаксКоличествоСайтовВКолонке = 0,
			Цел(КоличествоСайтов / МаксКоличествоСайтовВКолонке),
			Цел(КоличествоСайтов / МаксКоличествоСайтовВКолонке) + 1));
		
	ДобавитьКолонки(КоличествоКолонок);
	НомерКолонки = 0;
	
	Для Каждого Сайт Из Сайты Цикл
		
		ДанныеСайта = ДанныеСайтов[Сайт]; // См. РекрутинговыеСайтыСлужебный.НовыеДанныеСайта
		
		Если Не ЗначениеЗаполнено(ДанныеСайта.Имя) Тогда
			Продолжить;
		КонецЕсли;
		
		Если НомерКолонки = КоличествоКолонок Тогда
			НомерКолонки = 1;
			КоличествоСайтовВКолонке = КоличествоСайтовВКолонке + 1;
		Иначе
			НомерКолонки = НомерКолонки + 1;
		КонецЕсли;
		
		Если КоличествоСайтовВКолонке > МаксКоличествоСайтовВКолонке Тогда
			Родитель = Элементы.ГруппаКолонкиНиз;
		Иначе
			Родитель = Элементы["ГруппаКолонка" + НомерКолонки];
		КонецЕсли;
		
		ОсновнаяГруппа = ДобавитьЭлементПоШаблону(
			"Группа" + ДанныеСайта.Имя,
			Тип("ГруппаФормы"),
			ШаблонГруппа,
			СвойстваГруппа,
			Родитель);
		
		Логотип = ДобавитьЭлементПоШаблону(
			"Логотип" + ДанныеСайта.Имя,
			Тип("ДекорацияФормы"),
			ШаблонЛоготип,
			СвойстваЛоготип,
			ОсновнаяГруппа);
		
		Логотип.Картинка = ДанныеСайта.Логотип;
		Логотип.УстановитьДействие("Нажатие", "Подключаемый_ЛоготипНажатие");
		
		Страницы = ДобавитьЭлементПоШаблону(
			"Страницы" + ДанныеСайта.Имя,
			Тип("ГруппаФормы"),
			ШаблонСтраницы,
			СвойстваСтраницы,
			ОсновнаяГруппа);
		
		СтраницаНеПодключен = ДобавитьЭлементПоШаблону(
			"СтраницаНеПодключен" + ДанныеСайта.Имя,
			Тип("ГруппаФормы"),
			ШаблонСтраницаНеПодключен,
			СвойстваСтраницаНеПодключен,
			Страницы);
		
		ДобавитьЭлементыСтраницыНеПодключен(СтраницаНеПодключен, ДанныеСайта);
		
		СтраницаПодключение = ДобавитьЭлементПоШаблону(
			"СтраницаПодключение" + ДанныеСайта.Имя,
			Тип("ГруппаФормы"),
			ШаблонСтраницаПодключение,
			СвойстваСтраницаПодключение,
			Страницы);
		
		ДобавитьЭлементыСтраницыПодключение(СтраницаПодключение, ДанныеСайта);
		
		СтраницаПодключен = ДобавитьЭлементПоШаблону(
			"СтраницаПодключен" + ДанныеСайта.Имя,
			Тип("ГруппаФормы"),
			ШаблонСтраницаПодключен,
			СвойстваСтраницаПодключен,
			Страницы);
		
		ДобавитьЭлементыСтраницыПодключен(СтраницаПодключен, ДанныеСайта);
	
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьКолонки(КоличествоКолонок)
	
	ШаблонКолонка = Элементы.ГруппаКолонкаШаблон;
	
	СвойстваКолонка = Новый Массив();
	СвойстваКолонка.Добавить("Вид");
	СвойстваКолонка.Добавить("Отображение");
	СвойстваКолонка.Добавить("Группировка");
	СвойстваКолонка.Добавить("ОтображатьЗаголовок");
	
	Для НомерКолонки = 1 По КоличествоКолонок Цикл
		ДобавитьЭлементПоШаблону(
			"ГруппаКолонка" + НомерКолонки,
			Тип("ГруппаФормы"),
			ШаблонКолонка,
			СвойстваКолонка,
			Элементы.ГруппаКолонкиВерх);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьЭлементыСтраницыНеПодключен(СтраницаНеПодключен, ДанныеСайта)
	
	ШаблонГруппаНеПодключен = Элементы.ГруппаНеПодключенШаблон;
	
	СвойстваГруппаНеПодключен = Новый Массив();
	СвойстваГруппаНеПодключен.Добавить("Вид");
	СвойстваГруппаНеПодключен.Добавить("Отображение");
	СвойстваГруппаНеПодключен.Добавить("Группировка");
	СвойстваГруппаНеПодключен.Добавить("ОтображатьЗаголовок");
	СвойстваГруппаНеПодключен.Добавить("ВертикальноеПоложениеПодчиненных");
	
	ШаблонКартинкаНеПодключен = Элементы.КартинкаНеПодключенШаблон;
	
	СвойстваКартинкаНеПодключен = Новый Массив();
	СвойстваКартинкаНеПодключен.Добавить("Вид");
	СвойстваКартинкаНеПодключен.Добавить("Картинка");
	СвойстваКартинкаНеПодключен.Добавить("ОтображениеПодсказки");
	СвойстваКартинкаНеПодключен.Добавить("СпособПеретаскиванияФайлов");
	
	ШаблонНадписьНеПодключен = Элементы.НадписьНеПодключенШаблон;
	
	СвойстваНадписьНеПодключен = Новый Массив();
	СвойстваНадписьНеПодключен.Добавить("Вид");
	СвойстваНадписьНеПодключен.Добавить("Шрифт");
	СвойстваНадписьНеПодключен.Добавить("ОтображениеПодсказки");
	
	ШаблонПройтиАвторизацию = Элементы.ПройтиАвторизациюШаблон;
	
	СвойстваПройтиАвторизацию = Новый Массив();
	СвойстваПройтиАвторизацию.Добавить("Вид");
	СвойстваПройтиАвторизацию.Добавить("ОтображениеПодсказки");
	СвойстваПройтиАвторизацию.Добавить("ГоризонтальноеПоложениеВГруппе");
	
	ГруппаНеПодключен = ДобавитьЭлементПоШаблону(
		"ГруппаНеПодключен" + ДанныеСайта.Имя,
		Тип("ГруппаФормы"),
		ШаблонГруппаНеПодключен,
		СвойстваГруппаНеПодключен,
		СтраницаНеПодключен);
	
	ДобавитьЭлементПоШаблону(
		"КартинкаНеПодключен" + ДанныеСайта.Имя,
		Тип("ДекорацияФормы"),
		ШаблонКартинкаНеПодключен,
		СвойстваКартинкаНеПодключен,
		ГруппаНеПодключен);
	
	НадписьНеПодключен = ДобавитьЭлементПоШаблону(
		"НадписьНеПодключен" + ДанныеСайта.Имя,
		Тип("ДекорацияФормы"),
		ШаблонНадписьНеПодключен,
		СвойстваНадписьНеПодключен,
		ГруппаНеПодключен);
	
	НадписьНеПодключен.Заголовок = СтрШаблон(ШаблонНадписьНеПодключен.Заголовок, ДанныеСайта.Представление);
	
	ПройтиАвторизацию = ДобавитьЭлементПоШаблону(
		"ПройтиАвторизацию" + ДанныеСайта.Имя,
		Тип("КнопкаФормы"),
		ШаблонПройтиАвторизацию,
		СвойстваПройтиАвторизацию,
		СтраницаНеПодключен);
	
	ПройтиАвторизацию.ИмяКоманды = ПройтиАвторизацию.Имя;
	
КонецПроцедуры

