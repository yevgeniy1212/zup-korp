	СвойстваИмяПользователя = Новый Массив();
	СвойстваИмяПользователя.Добавить("Вид");
	СвойстваИмяПользователя.Добавить("Заголовок");
	СвойстваИмяПользователя.Добавить("ПоложениеЗаголовка");
	СвойстваИмяПользователя.Добавить("РастягиватьПоГоризонтали");
	
	ШаблонОтключить = Элементы.ОтключитьШаблон;
	
	СвойстваОтключить = Новый Массив();
	СвойстваОтключить.Добавить("Вид");
	СвойстваОтключить.Добавить("Ширина");
	СвойстваОтключить.Добавить("ГоризонтальноеПоложениеВГруппе");
	
	ГруппаПодключен = ДобавитьЭлементПоШаблону(
			"ГруппаПодключен" + ДанныеСайта.Имя,
			Тип("ГруппаФормы"),
			ШаблонГруппаПодключен,
			СвойстваГруппаПодключен,
			СтраницаПодключен);
		
	ДобавитьЭлементПоШаблону(
		"КартинкаПодключен" + ДанныеСайта.Имя,
		Тип("ДекорацияФормы"),
		ШаблонКартинкаПодключен,
		СвойстваКартинкаПодключен,
		ГруппаПодключен);
	
	НадписьПодключен = ДобавитьЭлементПоШаблону(
		"НадписьПодключен" + ДанныеСайта.Имя,
		Тип("ДекорацияФормы"),
		ШаблонНадписьПодключен,
