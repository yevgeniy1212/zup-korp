		"Отключить" + ДанныеСайта.Имя,
		Тип("КнопкаФормы"),
		ШаблонОтключить,
		СвойстваОтключить,
		СтраницаПодключен);
	
	Отключить.ИмяКоманды = Отключить.Имя;
	
КонецПроцедуры

&НаСервере
Функция ДобавитьЭлементПоШаблону(Имя, Тип, Шаблон, Свойства, Родитель = Неопределено)
	
	Элемент = Элементы.Добавить(Имя, Тип, Родитель);
	
	Если Свойства.Найти("Вид") <> Неопределено Тогда
		Элемент.Вид = Шаблон.Вид;
	КонецЕсли;
	
	СписокСвойств = СтрСоединить(Свойства, ",");
	
	ЗаполнитьЗначенияСвойств(Элемент, Шаблон, СписокСвойств);
	
	Возврат Элемент;
	
КонецФункции

&НаКлиенте
Процедура ПроверитьПодключение()
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ПроверкаПодключенияЗавершение", ЭтотОбъект);
	
	ДлительнаяОперация = ДлительнаяОперацияПроверкиПодключения(Сайты, УникальныйИдентификатор);
	
	Если ЗначениеЗаполнено(ДлительнаяОперация) Тогда
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
		ПараметрыОжидания.ТекстСообщения = НСтр("ru = 'Проверка подключения.'");
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДлительнаяОперацияПроверкиПодключения(Сайты, УникальныйИдентификатор) Экспорт
	
	ИмяПроцедуры = "РекрутинговыеСайты.ПроверитьПодключение";
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(УникальныйИдентификатор, ИмяПроцедуры, Сайты);
	
КонецФункции

&НаКлиенте
Процедура ПроверкаПодключенияЗавершение(ДлительнаяОперация, ДополнительныеПараметры = Неопределено) Экспорт

	Если ДлительнаяОперация = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ДлительнаяОперация.Статус = "Ошибка" Тогда
		ПоказатьПредупреждение(, ДлительнаяОперация.КраткоеПредставлениеОшибки);
		Возврат;
	ИначеЕсли Не ДлительнаяОперация.Статус = "Выполнено" Тогда
		Возврат;
	КонецЕсли;
	
	Результат = ПолучитьИзВременногоХранилища(ДлительнаяОперация.АдресРезультата);
	
	Для Каждого Сайт Из Сайты Цикл
		Если Результат[Сайт] = Неопределено Тогда
			ТекстСообщения = 
				СтрШаблон(НСтр("ru = 'Ошибка при проверке подключения к %1. Подробности в журнале регистрации.'"), Сайт);
			ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстСообщения);
			Продолжить;
		КонецЕсли;
		
		ИмяРеквизита = ИмяРеквизита(ДанныеСайтов, "Подключен", Сайт);
		ЭтотОбъект[ИмяРеквизита] = Результат[Сайт].Подключен;
		
		ИмяРеквизита = ИмяРеквизита(ДанныеСайтов, "ИмяПользователя", Сайт);
		ЭтотОбъект[ИмяРеквизита] = Результат[Сайт].ИмяПользователя;
	КонецЦикла;
	
	ОбновитьВидимостьЭлементов(ЭтотОбъект, ДанныеСайтов);
	
КонецПроцедуры

&НаКлиенте
Процедура НачатьПодключение()
	
	ПараметрыПодключения = РекрутинговыеСайтыКлиент.НовыеПараметрыПодключения();
	ПараметрыПодключения.Сайт = ТекущийСайт;
	
	ИмяРеквизита = ИмяРеквизита(ДанныеСайтов, "КодАвторизации", ТекущийСайт);
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭтотОбъект, ИмяРеквизита) Тогда
		ПараметрыПодключения.КодАвторизации = ЭтотОбъект[ИмяРеквизита];
	КонецЕсли;
	
	ИмяРеквизита = ИмяРеквизита(ДанныеСайтов, "ИмяПользователя", ТекущийСайт);
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭтотОбъект, ИмяРеквизита) Тогда
		ПараметрыПодключения.ИмяПользователя = ЭтотОбъект[ИмяРеквизита];
	КонецЕсли;
	
	ИмяРеквизита = ИмяРеквизита(ДанныеСайтов, "Пароль", ТекущийСайт);
	Если ОбщегоНазначенияКлиентСервер.ЕстьРеквизитИлиСвойствоОбъекта(ЭтотОбъект, ИмяРеквизита) Тогда
		ПараметрыПодключения.Пароль = ЭтотОбъект[ИмяРеквизита];
	КонецЕсли;
	
	ОповещениеОЗавершении = Новый ОписаниеОповещения("ПодключитьЗавершение", ЭтотОбъект);
	
	ДлительнаяОперация = ДлительнаяОперацияПодключения(ПараметрыПодключения, УникальныйИдентификатор);
	
	Если ЗначениеЗаполнено(ДлительнаяОперация) Тогда
		ПараметрыОжидания = ДлительныеОперацииКлиент.ПараметрыОжидания(ЭтотОбъект);
		ПараметрыОжидания.ВыводитьОкноОжидания = Истина;
		ПараметрыОжидания.ТекстСообщения = НСтр("ru = 'Подключение.'");
		ДлительныеОперацииКлиент.ОжидатьЗавершение(ДлительнаяОперация, ОповещениеОЗавершении, ПараметрыОжидания);
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ДлительнаяОперацияПодключения(ПараметрыПодключения, УникальныйИдентификатор) Экспорт
	
	ИмяПроцедуры = "РекрутинговыеСайты.Подключить";
	
	Возврат ДлительныеОперации.ВыполнитьФункцию(УникальныйИдентификатор, ИмяПроцедуры, ПараметрыПодключения);
	
КонецФункции

&НаКлиенте
Процедура ПодключитьЗавершение(ДлительнаяОперация, ДополнительныеПараметры = Неопределено) Экспорт

	Если ДлительнаяОперация = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ДлительнаяОперация.Статус = "Ошибка" Тогда
		ПоказатьПредупреждение(, ДлительнаяОперация.КраткоеПредставлениеОшибки);
		Возврат;
	ИначеЕсли Не ДлительнаяОперация.Статус = "Выполнено" Тогда
		Возврат;
	КонецЕсли;
	
	Результат = ПолучитьИзВременногоХранилища(ДлительнаяОперация.АдресРезультата);
	
	Если Результат.Подключен Тогда
		ТекстПредупреждения = 
			СтрШаблон(НСтр("ru = 'Авторизация на сайте %1 пройдена успешно.'"), ДанныеСайтов[ТекущийСайт].ИмяСайта);
			
		ИмяРеквизита = ИмяРеквизита(ДанныеСайтов, "Подключен", ТекущийСайт);
		ЭтотОбъект[ИмяРеквизита] = Результат.Подключен;
		
		ИмяРеквизита = ИмяРеквизита(ДанныеСайтов, "ИмяПользователя", ТекущийСайт);
		ЭтотОбъект[ИмяРеквизита] = Результат.ИмяПользователя;
	Иначе
		ТекстПредупреждения = НСтр("ru = 'Не удалось авторизоваться. Введены неверные данные.'");
	КонецЕсли;
	
	ПоказатьПредупреждение(, ТекстПредупреждения);
	
	ОбновитьВидимостьЭлементов(ЭтотОбъект, ДанныеСайтов);
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция ИмяРеквизита(ДанныеСайтов, ИмяРеквизитаФормы, Сайт)

	Возврат РекрутинговыеСайтыКлиентСервер.ИмяРеквизита(ДанныеСайтов, ИмяРеквизитаФормы, Сайт);

КонецФункции

&НаКлиентеНаСервереБезКонтекста
Процедура ОбновитьВидимостьЭлементов(Форма, ДанныеСайтов)
	
	Для Каждого КлючИЗначение Из ДанныеСайтов Цикл
		Сайт = КлючИЗначение.Ключ;
		
		ИмяРеквизитаПодключен = ИмяРеквизита(ДанныеСайтов, "Подключен", Сайт);
		ИмяРеквизитаПодключение = ИмяРеквизита(ДанныеСайтов, "Подключение", Сайт);
		ИмяРеквизитаСтраницы = ИмяРеквизита(ДанныеСайтов, "Страницы", Сайт);
		ИмяРеквизитаСтраницаПодключен = ИмяРеквизита(ДанныеСайтов, "СтраницаПодключен", Сайт);
		ИмяРеквизитаСтраницаПодключение = ИмяРеквизита(ДанныеСайтов, "СтраницаПодключение", Сайт);
		ИмяРеквизитаСтраницаНеПодключен = ИмяРеквизита(ДанныеСайтов, "СтраницаНеПодключен", Сайт);
		
		Если Форма[ИмяРеквизитаПодключен] Тогда
			Форма.Элементы[ИмяРеквизитаСтраницы].ТекущаяСтраница = Форма.Элементы[ИмяРеквизитаСтраницаПодключен];
		ИначеЕсли Форма[ИмяРеквизитаПодключение] Тогда
			Форма.Элементы[ИмяРеквизитаСтраницы].ТекущаяСтраница = Форма.Элементы[ИмяРеквизитаСтраницаПодключение];
		Иначе
			Форма.Элементы[ИмяРеквизитаСтраницы].ТекущаяСтраница = Форма.Элементы[ИмяРеквизитаСтраницаНеПодключен];
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаполнитьТекущийСайт(Элемент)
	
	Сайт = Неопределено;
	
	Для Каждого КлючИЗначение Из ДанныеСайтов Цикл
		Сайт = КлючИЗначение.Ключ;
		ДанныеСайта = КлючИЗначение.Значение;
		
		Если СтрНайти(ВРег(Элемент.Имя), ВРег(ДанныеСайта.Имя)) Тогда
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	ТекущийСайт = Сайт;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ОтключитьСайт(Сайт)
	
	МенеджерЗаписи = РегистрыСведений.НастройкиИнтеграцииРекрутинговыхСайтов.СоздатьМенеджерЗаписи();
	МенеджерЗаписи.Пользователь = Пользователи.ТекущийПользователь();
	МенеджерЗаписи.РекрутинговыйСайт = Сайт;
	МенеджерЗаписи.Прочитать();
	Если МенеджерЗаписи.Выбран() Тогда
		МенеджерЗаписи.Использовать = Ложь;
		МенеджерЗаписи.Записать();
	КонецЕсли;

КонецПроцедуры

#КонецОбласти