Процедура ДобавитьЭлементыСтраницыПодключен(СтраницаПодключен, ДанныеСайта)
	
	ШаблонГруппаПодключен = Элементы.ГруппаПодключенШаблон;
	
	СвойстваГруппаПодключен = Новый Массив();
