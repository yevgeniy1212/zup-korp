#Область СлужебныйПрограммныйИнтерфейс

Функция Сайт() Экспорт
	
	Возврат Справочники.ИсточникиИнформацииОКандидатах.ХабрКарьера;
	
КонецФункции

Функция НовыйМенеджер(Пользователь) Экспорт
	
	Менеджер = Создать();
	
	Менеджер.Сайт = Сайт();
	Менеджер.Пользователь = Пользователь;
	Менеджер.ДанныеСайта = ДанныеСайта();
	
	Возврат Менеджер;
	
КонецФункции

Функция ДанныеСайта() Экспорт
	
	ДанныеСайта = РекрутинговыеСайтыСлужебный.НовыеДанныеСайта();
	
	ДанныеСайта.Имя = Имя();
	ДанныеСайта.ИмяСайта = ИмяСайта();
	ДанныеСайта.Представление = Представление();
	ДанныеСайта.АдресЗапроса = АдресЗапроса();
	ДанныеСайта.ГлавнаяСтраница = ГлавнаяСтраница();
	ДанныеСайта.Логотип = Логотип();
	
	ДанныеСайта.ДоступенПоискРезюме = Ложь;
	ДанныеСайта.ДоступнаЗагрузкаКомментариевКандидатов = Ложь;
	
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("company", "companies");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("currency", "currency");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("city_id", "cities");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("remote", "remote");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("employment_type", "employment_type");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("skills", "skills");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("specialization_ids", "specializations");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("placement_type", "placement_type");
	ДанныеСайта.СоответствиеПутиИКлассификатора.Вставить("skip_placement", "skip_placement");
	
	ДанныеСайта.ПоляВакансииВПрограммеИНаСайте.Наименование = "title";
	ДанныеСайта.ПоляВакансииВПрограммеИНаСайте.ПредполагаемыйДоход = "salary_to";
	ДанныеСайта.ПоляВакансииВПрограммеИНаСайте.Описание = "description";
	
	ДанныеСайта.ИменаПутейКДаннымВакансии.Вакансия = "title";
	ДанныеСайта.ИменаПутейКДаннымВакансии.Адрес = "url";
	ДанныеСайта.ИменаПутейКДаннымВакансии.Идентификатор = "id";
	
	ДанныеСайта.ШаблоныСтраницСайта.Сайт = Сайт();
	ДанныеСайта.ШаблоныСтраницСайта.Логотип = Логотип();
	ДанныеСайта.ШаблоныСтраницСайта.ГлавнаяСтраница = ГлавнаяСтраница();
	ДанныеСайта.ШаблоныСтраницСайта.ШаблонURLРезюме = "https://*.habr.com/*";
	ДанныеСайта.ШаблоныСтраницСайта.РегулярноеВыражениеURLСайта = "https:\/\/((.*?\.habr)|(habr))\.com\/.*"; 
	ДанныеСайта.ШаблоныСтраницСайта.РегулярноеВыражениеURLРезюме =
		"https:\/\/((.*?\.habr)|(habr))\.com\/(?!vacancies|resumes|companies|salaries|courses|journal|profile|info|conversations|responses)\S+";
	
	ИдентификаторПриложения = ЗарплатаКадрыРасширенный.ИдентификацияПриложенияДляХабрКарьера();
	АдресАвторизации = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
				"%1?client_id=%2&redirect_uri=%3&response_type=code",
				ИдентификаторПриложения.auth_uri,
				ИдентификаторПриложения.client_id,
				ИдентификаторПриложения.redirect_uri);
	ДанныеСайта.АдресАвторизации = АдресАвторизации;
	
	ЗаполнитьПараметрыФорм(ДанныеСайта);
	
	Возврат ДанныеСайта;
	
КонецФункции

