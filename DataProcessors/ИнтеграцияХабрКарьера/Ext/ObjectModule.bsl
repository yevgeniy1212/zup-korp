Функция УстановитьСоединение()
	
	Результат = Истина;
	
	Если Не ЗначениеЗаполнено(МаркерДоступа) Тогда
		Результат = Инициализировать();
	КонецЕсли;
	
	Если Соединение = Неопределено Тогда
		Соединение = РекрутинговыеСайтыСлужебный.НовоеHTTPСоединение(АдресСервера());
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция Инициализировать()
	
	РеквизитыСайта = РекрутинговыеСайтыСлужебный.РеквизитыСайта(Сайт, Пользователь);
	
	Если РеквизитыСайта = Неопределено Или Не ЗначениеЗаполнено(РеквизитыСайта.МаркерДоступа) Тогда
		ВызватьИсключение СтрШаблон(НСтр("ru = 'Не настроена интеграция с %1.'"), АдресСайта());
	КонецЕсли; 
	
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, РеквизитыСайта);
	
	Возврат МаркерАктивен();
	
КонецФункции

Функция МетодыЗапросов()
	
	Возврат РекрутинговыеСайтыСлужебный.МетодыЗапросов();
	
КонецФункции

Функция ВыполнитьHTTPЗапрос(Метод, Запрос, ВызыватьИсключение = Истина)
	
	Возврат РекрутинговыеСайтыСлужебный.ВыполнитьHTTPЗапрос(Соединение, Метод, Запрос, ВызыватьИсключение);
	
КонецФункции

// Возвращаемое значение:
// См. РекрутинговыеСайтыСлужебный.НоваяСтруктураМаркеров
Функция СтруктураМаркеров()
	
	СтруктураМаркеров = РекрутинговыеСайтыСлужебный.НоваяСтруктураМаркеров();
	
	ИдентификаторПриложения = ЗарплатаКадрыРасширенный.ИдентификацияПриложенияДляХабрКарьера();
	Структура_token_uri = ОбщегоНазначенияКлиентСервер.СтруктураURI(ИдентификаторПриложения.token_uri);
	АдресАутентификации = Структура_token_uri.Хост;
	РесурсНаСервере = Структура_token_uri.ПутьНаСервере;
	
	СтрокаЗапроса = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(
		"grant_type=authorization_code&client_id=%1&client_secret=%2&redirect_uri=%3&code=%4",
		ИдентификаторПриложения.client_id,
		ИдентификаторПриложения.client_secret,
		ИдентификаторПриложения.redirect_uri,
		КодАвторизации); 
	
	СоединениеАутентификации = РекрутинговыеСайтыСлужебный.НовоеHTTPСоединение(АдресАутентификации, Истина);
	
	// Формируем общие заголовки.
	Заголовки = Новый Соответствие();
	Заголовки.Вставить("User-Agent", ЗарплатаКадры.ИмяКлиентскогоПриложения());
	Заголовки.Вставить("Content-Type", "application/x-www-form-urlencoded");
	
	Запрос = Новый HTTPЗапрос(РесурсНаСервере, Заголовки);
	Запрос.УстановитьТелоИзСтроки(СтрокаЗапроса);
	
	РезультатЗапроса = РекрутинговыеСайтыСлужебный.ВыполнитьHTTPЗапрос(
		СоединениеАутентификации, МетодыЗапросов().ОтправитьДляОбработки, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		РекрутинговыеСайтыСлужебный.СообщитьОбОшибкеАвторизации(Сайт, ЭтотОбъект, РезультатЗапроса);
		Возврат СтруктураМаркеров;
	КонецЕсли;
	
	ОтветОбъект = ПрочитатьОтветМаркерыДоступа(РезультатЗапроса);
	
	СтруктураМаркеров.МаркерДоступа = ОтветОбъект.access_token;
	СтруктураМаркеров.ДатаОкончанияДействияМаркераДоступа = Дата(3999, 12, 31);
	
	МаркерДоступа = СтруктураМаркеров.МаркерДоступа;
	ДатаОкончанияДействияМаркераДоступа = СтруктураМаркеров.ДатаОкончанияДействияМаркераДоступа;
	
	Возврат СтруктураМаркеров;
	
КонецФункции

Функция МаркерАктивен()
	
	МаркерДействителен = ЗначениеЗаполнено(МаркерДоступа) 
			И ДатаОкончанияДействияМаркераДоступа > ТекущаяДатаСеанса();
		
	МаркерАктивен = Ложь;
		
	Если МаркерДействителен Тогда
		МаркерАктивен = СайтДоступен();
	КонецЕсли;
		
	Возврат МаркерАктивен;
	
КонецФункции

Функция СайтДоступен()
	
	Возврат ЗначениеЗаполнено(ИнформацияОПользователе().ИмяПользователя);
	
КонецФункции

Функция НовыйHTTPЗапрос(ТекстЗапроса)
	
	Заголовки = Новый Соответствие();
	Заголовки.Вставить("User-Agent", ЗарплатаКадры.ИмяКлиентскогоПриложения());
	Заголовки.Вставить("Content-Type", "application/json");
	
	Если ЗначениеЗаполнено(МаркерДоступа) Тогда
		Заголовки.Вставить("Authorization", "Bearer " + МаркерДоступа);
	КонецЕсли;
	
	Запрос = Новый HTTPЗапрос(ТекстЗапроса, Заголовки);
	
	Возврат Запрос;
	
КонецФункции

// Возвращаемое значение:
//  Строка
Функция АдресСервера()
	
	Возврат ДанныеСайта().АдресЗапроса;
	
КонецФункции

// Возвращаемое значение:
//  Строка
Функция АдресСайта()
	
	Возврат ДанныеСайта().ИмяСайта;
	
КонецФункции

// Параметры:
//  Коллекция - Массив из Структура
//  ТекстЗапроса - Строка
//  ИмяКоллекции - Строка
//  РезультатСОшибкой - Структура: См. РекрутинговыеСайтыСлужебный.НовыйРезультатЗапроса
Процедура ЗаполнитьКоллекциюПостраничногоОтвета(Коллекция, ТекстЗапроса, ИмяКоллекции, РезультатСОшибкой)
	
	Если Не УстановитьСоединение() Тогда
		Возврат;
	КонецЕсли;
	
	НомерСтраницы = 0;
	НаСтранице = 20;
	Всего = 1;
	
	Пока Всего > НаСтранице * НомерСтраницы Цикл
		Запрос = НовыйHTTPЗапрос(СтрШаблон("%1?page=%2", ТекстЗапроса, НомерСтраницы));
		
		РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
		
		Если РезультатЗапроса.КодСостояния <> 200 Тогда
			РезультатСОшибкой = РезультатЗапроса;
			Прервать;
		Иначе
			ПостраничныйОтвет = ПрочитатьПостраничныйОтвет(РезультатЗапроса);
			
			НаСтранице = ПостраничныйОтвет.pagination.per;
			Всего = ПостраничныйОтвет.pagination.total;
			
			КоллекцияССайта = ПостраничныйОтвет[ИмяКоллекции]; // Массив из Структура
			Для Каждого ЭлементКоллекции Из КоллекцияССайта Цикл
				Коллекция.Добавить(ЭлементКоллекции);
			КонецЦикла;
		КонецЕсли;
		
		НомерСтраницы = НомерСтраницы + 1;
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  Логин - Строка
// 
// Возвращаемое значение:
//  Структура:
// * Телефон - Строка
// * EMail - Строка
Функция ДанныеКандидата(Логин)
	
	Результат = Новый Структура("Телефон, EMail", "", "");
	
	РезюмеССайта = РезюмеССайта(Логин);
	
	Если ЗначениеЗаполнено(РезюмеССайта) Тогда
		Если РезюмеССайта.contacts.phones.Количество() <> 0 Тогда
			Результат.Телефон = РезюмеССайта.contacts.phones[0].value;
		КонецЕсли;
		
		Если РезюмеССайта.contacts.emails.Количество() <> 0 Тогда
			Результат.EMail = РезюмеССайта.contacts.emails[0].value;
		КонецЕсли;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  Логин - Строка
// 
// Возвращаемое значение:
//  Структура: См. ПрочитатьОтветДанныеКандидата
Функция РезюмеССайта(Логин)
	
	Результат = Новый Структура();
	
	Если Не УстановитьСоединение() Тогда
		Возврат Результат;
	КонецЕсли;
	
	ТекстЗапроса = СтрШаблон("v1/integrations/users/%1", Логин);
	
	Запрос = НовыйHTTPЗапрос(ТекстЗапроса);
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
	
	Если РезультатЗапроса.КодСостояния = 200 Тогда
		Результат = ПрочитатьОтветДанныеКандидата(РезультатЗапроса);
	КонецЕсли;
	
	// АПК:1297-выкл Строка не видна пользователю
	Если СтрНайти(Результат.resume_headline, "Доступ ограничен") <> 0 Тогда
	// АПК:1297-вкл
		ВызватьИсключение СтрШаблон(НСтр("ru = '%1'"), Результат.resume_headline);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  РезюмеССайта - Структура: См. РезюмеССайта
// 
// Возвращаемое значение:
//  Структура: см. ПодборПерсоналаКлиентСервер.ОписаниеРезюмеКандидата
Функция ДанныеКандидатаПоРезюме(РезюмеССайта)
	
	ДанныеКандидата = Справочники.Кандидаты.СтруктураДанныхКандидата();
	
	ДанныеКандидата.ИсточникИнформации = Сайт;
	ДанныеКандидата.ДанныеПубликации = РезюмеССайта;
	
	// Адрес резюме
	ДанныеКандидата.АдресРезюме = СтрШаблон("%1%2", ДанныеСайта().ГлавнаяСтраница, РезюмеССайта.login);
	
	// ФИО
	ФИО = РезюмеССайта.full_name;
	Если ЗначениеЗаполнено(ФИО) Тогда
		ЗаполнитьЗначенияСвойств(ДанныеКандидата, ФизическиеЛицаКлиентСервер.ЧастиИмени(ФИО));
	КонецЕсли;
	
	// Ожидаемый доход
	ДанныеКандидата.ОжидаемыйДоход = РезюмеССайта.salary.from;
	ДанныеКандидата.ВалютаДохода = ПодборПерсонала.ВалютаПоСправочнику(РезюмеССайта.salary.currency);
	
	// О себе
	ДанныеКандидата.ОСебе = РекрутинговыеСайтыКлиентСервер.ИзвлечьТекстИзHTML(РезюмеССайта.about);
	
	// Дата рождения
	ДанныеКандидата.ДатаРождения = РекрутинговыеСайтыСлужебный.ДатаПоСтроке(РезюмеССайта.birthday, Ложь);
	
	// Контактная информация
	ЗаполнитьКонтактнуюИнформациюКандидата(РезюмеССайта, ДанныеКандидата.КонтактнаяИнформация);
	
	// Образование
	ЗаполнитьОбразованиеКандидата(РезюмеССайта, ДанныеКандидата.Образование);
	
	// Трудовая деятельность
	МестаРаботы = РезюмеССайта.experiences;
	Если ЗначениеЗаполнено(МестаРаботы) Тогда
		Для Каждого МестоРаботы Из МестаРаботы Цикл
			ОпытРаботы = РекрутинговыеСайтыСлужебный.НовыйОпытРаботы();
			
			ОпытРаботы.Компания = МестоРаботы.company_name;
			ОпытРаботы.Должность = МестоРаботы.position;
			ОпытРаботы.Обязанности = МестоРаботы.description;
			
			ДатаНачала = РекрутинговыеСайтыСлужебный.ДатаПоСтроке(МестоРаботы.start_date, Ложь);
			Если ЗначениеЗаполнено(ДатаНачала) Тогда
				ОпытРаботы.ДатаНачала = ДатаНачала;
			КонецЕсли;
			
			ДатаОкончания = РекрутинговыеСайтыСлужебный.ДатаПоСтроке(МестоРаботы.end_date, Ложь);
			Если ЗначениеЗаполнено(ДатаОкончания) Тогда
				ОпытРаботы.ДатаОкончания = ДатаОкончания;
			КонецЕсли;
			
			ДанныеКандидата.ТрудоваяДеятельность.Добавить(ОпытРаботы);
		КонецЦикла;
	КонецЕсли;
	
	// Гражданство
	СтранаГражданства = РезюмеССайта.location.country;
	Если ЗначениеЗаполнено(СтранаГражданства) Тогда
		ДанныеКандидата.Гражданство.Добавить(Новый Структура("Страна, Дата", СтранаГражданства, Дата(1, 1, 1)));
	КонецЕсли;
	
	// Фото
	ДанныеКандидата.Фото = ФотоКандидата(РезюмеССайта.avatar);
	
	Возврат ДанныеКандидата;
	
КонецФункции

Функция ФотоКандидата(АдресКартинки)
	
	Возврат РекрутинговыеСайтыСлужебный.КартинкаПоАдресу(АдресКартинки);
	
КонецФункции

// Параметры:
//  РезюмеССайта - Структура: См. РезюмеССайта
//  КонтактнаяИнформацияКандидата - Массив Из См. РекрутинговыеСайтыСлужебный.СтруктураКонтактнойИнформации
Процедура ЗаполнитьКонтактнуюИнформациюКандидата(РезюмеССайта, КонтактнаяИнформацияКандидата)
	
	РегионРаботы = РезюмеССайта.location.city;
	Если ЗначениеЗаполнено(РегионРаботы) Тогда
		КонтактнаяИнформация = РекрутинговыеСайтыСлужебный.СтруктураКонтактнойИнформации();
		КонтактнаяИнформация.Тип = Перечисления.ТипыКонтактнойИнформации.Адрес;
		КонтактнаяИнформация.Вид =
			ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.АдресЛичныеДанныеКандидатов");
		КонтактнаяИнформация.Представление = СтрШаблон("%1, %2", РезюмеССайта.location.country, РегионРаботы);
		КонтактнаяИнформацияКандидата.Добавить(КонтактнаяИнформация);
	КонецЕсли;
	
	АдресаЭП = РезюмеССайта.contacts.emails;
	Для Каждого АдресЭП Из АдресаЭП Цикл
		КонтактнаяИнформация = РекрутинговыеСайтыСлужебный.СтруктураКонтактнойИнформации();
		КонтактнаяИнформация.Тип = Перечисления.ТипыКонтактнойИнформации.АдресЭлектроннойПочты;
		КонтактнаяИнформация.Вид =
			ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.EMailЛичныеДанныеКандидатов");
		КонтактнаяИнформация.Представление = АдресЭП.value;
		КонтактнаяИнформацияКандидата.Добавить(КонтактнаяИнформация);
	КонецЦикла;
	
	Телефоны = РезюмеССайта.contacts.phones;
	Для Каждого Телефон Из Телефоны Цикл
		КонтактнаяИнформация = РекрутинговыеСайтыСлужебный.СтруктураКонтактнойИнформации();
		КонтактнаяИнформация.Тип = Перечисления.ТипыКонтактнойИнформации.Телефон;
		КонтактнаяИнформация.Вид =
			ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыКонтактнойИнформации.ТелефонЛичныеДанныеКандидатов");
		КонтактнаяИнформация.Представление = Телефон.value;
		КонтактнаяИнформацияКандидата.Добавить(КонтактнаяИнформация);
	КонецЦикла;
	
КонецПроцедуры

// Параметры:
//  РезюмеССайта - Структура: См. РезюмеССайта
//  ОбразованиеКандидата - Массив Из См. Справочники.ЛичныеДанныеКандидатов.НовоеОбразованиеДляФизическогоЛица
Процедура ЗаполнитьОбразованиеКандидата(РезюмеССайта, ОбразованиеКандидата)
	
	СреднееОбразование = РезюмеССайта.college_educations;
	Для Каждого Образование Из СреднееОбразование Цикл
		НовоеОбразование = Справочники.ЛичныеДанныеКандидатов.НовоеОбразованиеДляФизическогоЛица();
		НовоеОбразование.УчебноеЗаведение = Образование.college_name;
		НовоеОбразование.Окончание = Год(РекрутинговыеСайтыСлужебный.ДатаПоСтроке(Образование.end_date, Ложь));
		НовоеОбразование.ВидОбразования =
			ОбщегоНазначения.ПредопределенныйЭлемент("Справочник.ВидыОбразованияФизическихЛиц.СреднееПрофессиональноеОбразование");
		
		ОбразованиеКандидата.Добавить(НовоеОбразование);
	КонецЦикла;
	
	ВысшееОбразование = РезюмеССайта.university_educations;
	Для Каждого Образование Из ВысшееОбразование Цикл
		НовоеОбразование = Справочники.ЛичныеДанныеКандидатов.НовоеОбразованиеДляФизическогоЛица();
		НовоеОбразование.УчебноеЗаведение = Образование.university_name;
