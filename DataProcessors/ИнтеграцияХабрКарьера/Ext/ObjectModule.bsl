//@strict-types

#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОписаниеПеременных

Перем Соединение; // HTTPСоединение

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

// Параметры:
//  Код - Строка
// 
// Возвращаемое значение:
//  Структура: см. РекрутинговыеСайтыСлужебный.НовыеРеквизитыСайта
Функция Подключить(Код) Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыеРеквизитыСайта();
	
	КодАвторизации = Код;
	
	СтруктураМаркеров = СтруктураМаркеров();
	
	Если ЗначениеЗаполнено(СтруктураМаркеров.МаркерДоступа) Тогда
		Результат.Подключен = Истина;
		
		ИнформацияОПользователе = ИнформацияОПользователе();
		
		Результат.МаркерДоступа = СтруктураМаркеров.МаркерДоступа;
		Результат.ДатаОкончанияДействияМаркераДоступа = СтруктураМаркеров.ДатаОкончанияДействияМаркераДоступа;
		
		Результат.ИмяПользователя = ИнформацияОПользователе.ИмяПользователя;
		Результат.ИдентификаторПользователя = ИнформацияОПользователе.ИдентификаторКомпании;
		Результат.КодАвторизации = КодАвторизации;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращаемое значение:
//  См. РекрутинговыеСайтыСлужебный.НоваяИнформацияОПользователе
Функция ИнформацияОПользователе() Экспорт
	
	ИнформацияОПользователе = РекрутинговыеСайтыСлужебный.НоваяИнформацияОПользователе();
	
	Если Не УстановитьСоединение() Тогда
		Возврат ИнформацияОПользователе;
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос("v1/integrations/users/me");
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
	
	Если РезультатЗапроса.КодСостояния = 200 Тогда
		ИнформацияОПользователеХабр = ПрочитатьОтветИнформацияОПользователе(РезультатЗапроса);
	Иначе
		РекрутинговыеСайтыСлужебный.СообщитьОбОшибкеИнформацияОПользователе(Сайт, ЭтотОбъект, РезультатЗапроса);
	КонецЕсли;
	
	ИнформацияОПользователе.ИмяПользователя = ИнформацияОПользователеХабр.email;
	ИнформацияОПользователе.ИдентификаторКомпании = ИнформацияОПользователеХабр.login;
	ИнформацияОПользователе.ИдентификаторПользователя = ИнформацияОПользователеХабр.login;
	
	Возврат ИнформацияОПользователе;
	
КонецФункции

// Возвращаемое значение:
//  Структура: см. РекрутинговыеСайтыСлужебный.НовыеРеквизитыСайта
Функция ПроверитьПодключение() Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыеРеквизитыСайта();
	
	РеквизитыСайта = РекрутинговыеСайтыСлужебный.РеквизитыСайта(Сайт, Пользователь);
	
	Если ЗначениеЗаполнено(РеквизитыСайта) Тогда
		ЗаполнитьЗначенияСвойств(ЭтотОбъект, РеквизитыСайта);
		Результат.Подключен = МаркерАктивен();
	КонецЕсли;
	
	Если Результат.Подключен Тогда
		ИнформацияОПользователе = ИнформацияОПользователе();
		Результат.ИмяПользователя = ИнформацияОПользователе.ИмяПользователя;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращаемое значение:
//  ФиксированнаяСтруктура:
// * companies - Массив Из Структура: См. СтруктураДанных
// * cities - Структура: См. ЗагрузитьРегионы
// * specializations - Массив Из Структура: 
// ** Наименование - Строка -
// ** Специализации - Массив Из Структура: См. СтруктураДанных
// * currency - Массив Из Структура: См. СтруктураДанных
// * skills - Массив Из Структура: См. СтруктураДанных
// * remote - Массив Из Структура: См. СтруктураДанных
// * employment_type - Массив Из Структура: См. СтруктураДанных
// * placement_type - Массив Из Структура: См. СтруктураДанных
// * skip_placement - Массив Из Структура: См. СтруктураДанных
Функция ЗагрузитьКлассификаторы() Экспорт
	
	Классификаторы = КлассификаторыСайта();
	
	Если Классификаторы <> Неопределено Тогда
		Возврат Классификаторы;
	КонецЕсли;
	
	Если Не УстановитьСоединение() Тогда
		Возврат Классификаторы;
	КонецЕсли;
	
	Компании = ЗагрузитьКомпанииПользователя();
	Регионы = ЗагрузитьРегионы();
	Специализации = ЗагрузитьСпециализации();
	Навыки = ЗагрузитьНавыки();
	Валюты = КлассификаторВалют();
	
	УдаленнаяРабота = Новый Массив();
	УдаленнаяРабота.Добавить(СтруктураДанных(0, НСтр("ru = 'Работа в офисе'")));
	УдаленнаяРабота.Добавить(СтруктураДанных(1, НСтр("ru = 'Удаленная работа'")));
	
	ТипЗанятости = Новый Массив();
	ТипЗанятости.Добавить(СтруктураДанных("full_time", НСтр("ru = 'Полная занятость'")));
	ТипЗанятости.Добавить(СтруктураДанных("part_time", НСтр("ru = 'Частичная занятость'")));
	
	ТипРазмещения = Новый Массив();
	ТипРазмещения.Добавить(СтруктураДанных(0, НСтр("ru = '«Стандарт»'")));
	ТипРазмещения.Добавить(СтруктураДанных(1, НСтр("ru = '«Стандарт плюс»'")));
	
	НеОплачиватьРазмещение = Новый Массив();
	НеОплачиватьРазмещение.Добавить(СтруктураДанных(0, НСтр("ru = 'Оплачивать'")));
	НеОплачиватьРазмещение.Добавить(СтруктураДанных(1, НСтр("ru = 'Не оплачивать'")));
	
	Классификаторы = Новый Структура();
	Классификаторы.Вставить("companies", Компании);
	Классификаторы.Вставить("cities", Регионы);
	Классификаторы.Вставить("specializations", Специализации);
	Классификаторы.Вставить("currency", Валюты);
	Классификаторы.Вставить("skills", Навыки);
	Классификаторы.Вставить("remote", УдаленнаяРабота);
	Классификаторы.Вставить("employment_type", ТипЗанятости);
	Классификаторы.Вставить("placement_type", ТипРазмещения);
	Классификаторы.Вставить("skip_placement", НеОплачиватьРазмещение);
	
	КлассификаторыФикс = ОбщегоНазначения.ФиксированныеДанные(Классификаторы);
	
	ТекущиеПараметры =
		РекрутинговыеСайтыСлужебный.СоответствиеПоФиксированномуСоответствию(ПараметрыСеанса.ПараметрыКлиентаНаСервере);
	ТекущиеПараметры.Вставить("Классификаторы" + ДанныеСайта().Имя, КлассификаторыФикс);
	УстановитьПривилегированныйРежим(Истина);
	ПараметрыСеанса.ПараметрыКлиентаНаСервере = Новый ФиксированноеСоответствие(ТекущиеПараметры);
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат КлассификаторыФикс;
	
КонецФункции

Функция ВакансииССайта(БылиОшибки = Ложь, Архивные = Ложь) Экспорт
	
	Вакансии = НоваяКоллекцияВакансий();
	
	РезультатСОшибкой = РекрутинговыеСайтыСлужебный.НовыйРезультатЗапроса();
	
	ТекстЗапроса = СтрШаблон("v1/integrations/vacancies%1", ?(Архивные, "/archived", ""));
	
	ЗаполнитьКоллекциюПостраничногоОтвета(Вакансии, ТекстЗапроса, "vacancies", РезультатСОшибкой);
	
	Если РезультатСОшибкой.Ошибка Тогда
		БылиОшибки = Истина;
		РекрутинговыеСайтыСлужебный.СообщитьОбОшибкеПолученияВакансий(Сайт, ЭтотОбъект, РезультатСОшибкой);
	КонецЕсли;
	
	Возврат Вакансии;
	
КонецФункции

// Параметры:
//  Идентификатор - Строка
// 
// Возвращаемое значение:
//  Строка - Строка
Функция АдресВакансии(Идентификатор) Экспорт
	
	Возврат СтрШаблон("%1vacancies/%2/", ДанныеСайта().ГлавнаяСтраница, Идентификатор);
	
КонецФункции

// Параметры:
//  АдресРезюме - Строка
// 
// Возвращаемое значение:
//  Строка
Функция ИдентификаторРезюмеПоАдресу(АдресРезюме) Экспорт
	
	ИдентификаторРезюме = АдресРезюме;
	
	Разделитель = "/";
	
	Пока РекрутинговыеСайтыКлиентСервер.НайтиВСтроке(ИдентификаторРезюме, Разделитель) > 0 Цикл
		НомерВхожденияРазделителя = 
			РекрутинговыеСайтыКлиентСервер.НайтиВСтроке(ИдентификаторРезюме, Разделитель);
		ИдентификаторРезюме = 
			Сред(ИдентификаторРезюме, 
				НомерВхожденияРазделителя + СтрДлина(Разделитель), 
				СтрДлина(ИдентификаторРезюме) - НомерВхожденияРазделителя);
	КонецЦикла;
	
	Возврат ИдентификаторРезюме;

КонецФункции

// Параметры:
//  ИдентификаторРезюме - Строка
// 
// Возвращаемое значение:
//  Структура
Функция ДанныеКандидатаПоРезюмеССайта(ИдентификаторРезюме) Экспорт
	
	ДанныеКандидата = Справочники.Кандидаты.СтруктураДанныхКандидата();
	
	РезюмеССайта = РезюмеССайта(ИдентификаторРезюме);
	
	Если ЗначениеЗаполнено(РезюмеССайта) Тогда
		ДанныеКандидата = ДанныеКандидатаПоРезюме(РезюмеССайта);
	Иначе
		ВызватьИсключение РекрутинговыеСайтыСлужебный.ТекстИсключенияПриОшибкеЗагрузкиРезюмеПоСсылке(Сайт);
	КонецЕсли;
	
	Возврат ДанныеКандидата;

КонецФункции

// Параметры:
//  Дерево - ДеревоЗначений
// 
// Возвращаемое значение:
//  См. РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией
Функция ОпубликоватьВакансию(Дерево) Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией();
	
	Если Не УстановитьСоединение() Тогда
		Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкойПубликацииВакансии(Сайт, ЭтотОбъект);
	КонецЕсли;
	
	JSONОписаниеВакансии = JSONОписаниеВакансии(Дерево);
	
	Запрос = НовыйHTTPЗапрос("v1/integrations/vacancies");
	Запрос.УстановитьТелоИзСтроки(JSONОписаниеВакансии, , ИспользованиеByteOrderMark.НеИспользовать);
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().ОтправитьДляОбработки, Запрос);
	
	Если РезультатЗапроса.КодСостояния = 200 Тогда
		ДанныеПубликации = ПрочитатьОтветПубликацияВакансии(РезультатЗапроса);
		Результат.ИдентификаторВакансии = Формат(ДанныеПубликации.vacancy.id, "ЧГ=;");
	Иначе
		Результат = РекрутинговыеСайтыСлужебный.РезультатСОшибкойПубликацииВакансии(Сайт, ЭтотОбъект, РезультатЗапроса);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  Дерево - ДеревоЗначений
//  ИдентификаторВакансии - Строка
// 
// Возвращаемое значение:
//  См. РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией
Функция ОбновитьПубликациюВакансии(Дерево, ИдентификаторВакансии) Экспорт
	
	Результат = РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией();
	
	Если Не УстановитьСоединение() Тогда
		Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкойОбновленияВакансии(Сайт, ЭтотОбъект);
	КонецЕсли;
	
	JSONОписаниеВакансии = JSONОписаниеВакансии(Дерево, Истина);
	
	ТекстЗапроса = СтрШаблон("v1/integrations/vacancies/%1", ИдентификаторВакансии);
	
	Запрос = НовыйHTTPЗапрос(ТекстЗапроса);
	Запрос.УстановитьТелоИзСтроки(JSONОписаниеВакансии, , ИспользованиеByteOrderMark.НеИспользовать);
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Изменить, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкойОбновленияВакансии(Сайт, ЭтотОбъект, РезультатЗапроса);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  Дерево - ДеревоЗначений
//  Вакансия - СправочникСсылка.Вакансии
//  ИдентификаторВакансии - Строка
// 
// Возвращаемое значение:
//  См. РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией
Функция ПовторноОпубликоватьВакансию(Дерево, Вакансия, ИдентификаторВакансии) Экспорт
	
	Результат = ИзменитьСтатусПубликацииВакансии(ИдентификаторВакансии);
	
	Если Результат.Успешно Тогда
		Результат = ОбновитьПубликациюВакансии(Дерево, ИдентификаторВакансии);
		
		ДатаСеанса = ТекущаяДатаСеанса();
		
		СвойстваПубликации = РекрутинговыеСайтыСлужебный.НовыеСвойстваПубликацииВакансии();
		СвойстваПубликации.Опубликована = Истина;
		СвойстваПубликации.ДатаПубликации = ДатаСеанса;
		СвойстваПубликации.ДатаОбновления = ДатаСеанса;
		
		РекрутинговыеСайтыСлужебный.ЗаписьВРегистрИнформацииОПубликации(Вакансия, Сайт, , , СвойстваПубликации);
	Иначе
		Результат = СнятьПубликациюВакансии(ИдентификаторВакансии);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  ИдентификаторВакансии - Строка
// 
// Возвращаемое значение:
//  См. РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией
Функция СнятьПубликациюВакансии(ИдентификаторВакансии) Экспорт
	
	Возврат ИзменитьСтатусПубликацииВакансии(ИдентификаторВакансии);
	
КонецФункции

// Параметры:
//  ИдентификаторВакансии - Строка
// 
// Возвращаемое значение:
// - Неопределено
// - Структура: См. РекрутинговыеСайтыСлужебный.НовыеСвойстваПубликацииВакансии
Функция СвойстваПубликацииВакансииНаСайте(ИдентификаторВакансии) Экспорт
	
	СвойстваПубликации = РекрутинговыеСайтыСлужебный.НовыеСвойстваПубликацииВакансии();
	
	Если Не УстановитьСоединение() Тогда
		Возврат СвойстваПубликации;
	КонецЕсли;
	
	ВакансииССайта = ВакансииССайта();
	
	Для Каждого ВакансияССайта Из ВакансииССайта Цикл
		Если Строка(ВакансияССайта.id) = ИдентификаторВакансии Тогда
			ОписаниеВакансии = ВакансияССайта;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Не ЗначениеЗаполнено(ОписаниеВакансии) Тогда
		АрхивныеВакансииССайта = ВакансииССайта(Ложь, Истина);
		
		Для Каждого ВакансияССайта Из АрхивныеВакансииССайта Цикл
			Если ВакансияССайта.id = ИдентификаторВакансии Тогда
				ОписаниеВакансии = ВакансияССайта;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОписаниеВакансии) Тогда
		СвойстваПубликации.Опубликована = ОписаниеВакансии.published;
		
		СвойстваПубликации.ДатаПубликации =
			РекрутинговыеСайтыСлужебный.ДатаПоСтроке(ОписаниеВакансии.published_at, Истина);
		СвойстваПубликации.ДатаОбновления = СвойстваПубликации.ДатаПубликации;
	Иначе
		Возврат Неопределено;
	КонецЕсли;
	
	Возврат СвойстваПубликации;
	
КонецФункции

// Параметры:
//  ОбновлениеПубликации - Булево
// 
// Возвращаемое значение:
//  Структура: см. РекрутинговыеСайтыСлужебный.НовыеВидыПолей
Функция ВидыПолей(ОбновлениеПубликации) Экспорт
	
	ВидыПолей = РекрутинговыеСайтыСлужебный.НовыеВидыПолей();
	
	ВидыПолей.СМножественнымВыборомИзДерева = ПоляВакансииСМножественнымВыборомИзДерева();
	ВидыПолей.СОдиночнымВыборомИзДерева = ПоляВакансииСОдиночнымВыборомИзДерева();
	ВидыПолей.СОдиночнымВыборомИзСписка = ПоляВакансииСОдиночнымВыборомИзСписка();
	ВидыПолей.СТекстомВHTML = ПоляВакансииСТекстомВHTML();
	
	Возврат ВидыПолей;
	
КонецФункции

