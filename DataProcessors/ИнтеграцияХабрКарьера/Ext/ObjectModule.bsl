// Параметры:
//  ИдентификаторВакансии - Строка
// 
// Возвращаемое значение:
//  См. РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией
Функция ИзменитьСтатусПубликацииВакансии(ИдентификаторВакансии)
	
	Результат = РекрутинговыеСайтыСлужебный.НовыйРезультатДействияСВакансией(ИдентификаторВакансии);
	
	Если Не УстановитьСоединение() Тогда
		Возврат РекрутинговыеСайтыСлужебный.РезультатСОшибкойСнятияВакансии(Сайт, ЭтотОбъект);
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос(СтрШаблон("v1/integrations/vacancies/%1/toggle_published_state", ИдентификаторВакансии));
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Записать, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		Результат = РекрутинговыеСайтыСлужебный.РезультатСОшибкойСнятияВакансии(Сайт, ЭтотОбъект, РезультатЗапроса);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

