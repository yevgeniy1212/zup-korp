Функция JSONОписаниеВакансии(Дерево, Обновление = Ложь)
	
	СтрокаJSON = "";
	
	СтруктураОписанияВакансии = СтруктураОписанияВакансии(Дерево, Обновление);
	СтрокаJSON = РекрутинговыеСайтыСлужебный.ЗаписьJSON(СтруктураОписанияВакансии);
	
	Возврат СтрокаJSON;
	
КонецФункции

// Параметры:
//  Дерево - ДеревоЗначений:
//  * Показатель - СправочникСсылка.Вакансии, Строка -
//  * ТипРеквизита - Строка -
//  * ПубликацияВакансии - СписокЗначений Из Строка, Булево, Строка, Число -
//  * Путь - Строка -
//  * ПубликацияВакансииТекст - Строка -
//  * СтрокаИзменена - Булево -
//  Обновление - Булево
// 
// Возвращаемое значение:
//  Структура
Функция СтруктураОписанияВакансии(Дерево, Обновление = Ложь)
	
	ПоляВакансии = Новый Структура;
	ПоляВакансии.Вставить("vacancy", Новый Структура());
	Вакансия = ПоляВакансии.vacancy;
	
	Вакансия.Вставить("members", ИмяПользователя);
	
	ПоляСТекстомВHTML = ПоляВакансииСТекстомВHTML();
	
	Для Каждого СтрокаДерева Из Дерево.Строки Цикл
		Если ТипЗнч(СтрокаДерева.Показатель) <> Тип("СправочникСсылка.Вакансии") Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого СтрокаДереваПодчиненная Из СтрокаДерева.Строки Цикл
			Если СтрокаДереваПодчиненная.ТипРеквизита = "Строка" Тогда
				Если ЗначениеЗаполнено(СтрокаДереваПодчиненная.ПубликацияВакансии) Тогда
					Если ПоляСТекстомВHTML.Найти(СтрокаДереваПодчиненная.Путь) <> Неопределено Тогда
						Вакансия.Вставить(
							СтрокаДереваПодчиненная.Путь, СтрокаДереваПодчиненная.ПубликацияВакансииТекст);
					Иначе
						Вакансия.Вставить(
							СтрокаДереваПодчиненная.Путь, СтрокаДереваПодчиненная.ПубликацияВакансии);
					КонецЕсли;
				КонецЕсли;
			ИначеЕсли СтрокаДереваПодчиненная.ТипРеквизита = "Число" Тогда
				Если ЗначениеЗаполнено(СтрокаДереваПодчиненная.ПубликацияВакансии) Тогда
					Вакансия.Вставить(СтрокаДереваПодчиненная.Путь, СтрокаДереваПодчиненная.ПубликацияВакансии);
				КонецЕсли;
			ИначеЕсли СтрокаДереваПодчиненная.ТипРеквизита = РекрутинговыеСайтыСлужебный.ТипРеквизитаНачалоМассива() Тогда
				Если Не ЗначениеЗаполнено(СтрокаДереваПодчиненная.ПубликацияВакансии)
					Или (Обновление И Не СтрокаДереваПодчиненная.СтрокаИзменена) Тогда
					Продолжить;
				КонецЕсли;
				
				Если СтрокаДереваПодчиненная.ПубликацияВакансии.Количество() = 1 Тогда
					ЗначениеПоля = СтрокаДереваПодчиненная.ПубликацияВакансии[0].Значение;
				Иначе
					Значения = Новый Массив();
					Для Каждого ЭлементСписка Из СтрокаДереваПодчиненная.ПубликацияВакансии Цикл
						Значения.Добавить(ЭлементСписка.Значение);
					КонецЦикла;
					
					ЗначениеПоля = СтрСоединить(Значения, ",");
				КонецЕсли;
				
				Если СтрокаДереваПодчиненная.Путь = "placement_type" Тогда
					ПоляВакансии.Вставить(СтрокаДереваПодчиненная.Путь, ЗначениеПоля)
				ИначеЕсли СтрокаДереваПодчиненная.Путь = "skip_placement" И ЗначениеПоля = 0 Тогда
					Продолжить;
				Иначе
					Вакансия.Вставить(СтрокаДереваПодчиненная.Путь, ЗначениеПоля);
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	Возврат ПоляВакансии;
	
КонецФункции

// Возвращаемое значение:
//  Массив Из Структура: См. СтруктураДанных
Функция ЗагрузитьКомпанииПользователя()
	
	Компании = Новый Массив();
	
	Если Не УстановитьСоединение() Тогда
		Возврат Компании;
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос("v1/integrations/companies/my");
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		ТекстСообщения = НСтр("ru = 'Не удалось загрузить компании пользователя.'");
		РекрутинговыеСайтыСлужебный.СообщитьОбОшибке(ТекстСообщения, Сайт, ЭтотОбъект, РезультатЗапроса);
	Иначе
		КомпанииПользователя = ПрочитатьОтветКомпанииПользователя(РезультатЗапроса).companies;
		Для Каждого КомпанияПользователя Из КомпанииПользователя Цикл
			Компании.Добавить(СтруктураДанных(КомпанияПользователя.alias_name, КомпанияПользователя.name));
		КонецЦикла;
	КонецЕсли;
	
	Возврат Компании;
	
КонецФункции

// Возвращаемое значение:
//  Структура: См. КлассификаторРегионовПоТаблице
Функция ЗагрузитьРегионы()
	
	Регионы = Новый Структура();
	
	Если Не УстановитьСоединение() Тогда
		Возврат Регионы;
	КонецЕсли;
	
	ТаблицаРегионов = НоваяТаблицаРегионов();
	
	Страница = 0;
	НаСтранице = 999;
	ВОтвете = НаСтранице;
	
	Пока НаСтранице = ВОтвете Цикл
		Запрос = НовыйHTTPЗапрос(СтрШаблон("v1/integrations/cities/all?term=Россия&page=%1&per_page=%2", Страница, НаСтранице));
		
		РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
		
		Если РезультатЗапроса.КодСостояния <> 200 Тогда
			ТекстСообщения = НСтр("ru = 'Не удалось загрузить классификатор городов.'");
			РекрутинговыеСайтыСлужебный.СообщитьОбОшибке(ТекстСообщения, Сайт, ЭтотОбъект, РезультатЗапроса);
			Прервать;
		Иначе
			РегионыСайта = ПрочитатьОтветРегионы(РезультатЗапроса).cities;
			Для Каждого Регион Из РегионыСайта Цикл
				НоваяСтрока = ТаблицаРегионов.Добавить();
				НоваяСтрока.Страна = Регион.country_name;
				НоваяСтрока.Регион = Регион.region_name;
				НоваяСтрока.Город = Регион.name;
				НоваяСтрока.Идентификатор = Регион.id;
			КонецЦикла;
		КонецЕсли;
		
		ВОтвете = РегионыСайта.Количество();
		Страница = Страница + 1;
	КонецЦикла;
	
	Регионы = КлассификаторРегионовПоТаблице(ТаблицаРегионов);
	
	Возврат Регионы;
	
КонецФункции

Функция НоваяТаблицаРегионов()
	
	ТаблицаРегионов = Новый ТаблицаЗначений();
	ТаблицаРегионов.Колонки.Добавить("Страна", Новый ОписаниеТипов("Строка"));
	ТаблицаРегионов.Колонки.Добавить("Регион", Новый ОписаниеТипов("Строка"));
	ТаблицаРегионов.Колонки.Добавить("Город", Новый ОписаниеТипов("Строка"));
	ТаблицаРегионов.Колонки.Добавить("Идентификатор", Новый ОписаниеТипов("Число"));
	
	Возврат ТаблицаРегионов;
	
КонецФункции

// Параметры:
//  ТаблицаРегионов - ТаблицаЗначений: См. НоваяТаблицаРегионов
// 
// Возвращаемое значение:
//  Структура:
// * Страны - Массив Из Структура:
// ** Наименование - Строка -
// ** Регионы - Массив Из Структура:
// *** Наименование - Строка -
// *** Города - Массив Из Структура:
// **** Наименование - Строка -
// **** Идентификатор - Число -
Функция КлассификаторРегионовПоТаблице(ТаблицаРегионов)
	
	КлассификаторРегионов = Новый Структура();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ВЫРАЗИТЬ(ТаблицаРегионов.Страна КАК СТРОКА(200)) КАК Страна,
	|	ВЫРАЗИТЬ(ТаблицаРегионов.Регион КАК СТРОКА(200)) КАК Регион,
	|	ВЫРАЗИТЬ(ТаблицаРегионов.Город КАК СТРОКА(200)) КАК Город,
	|	ТаблицаРегионов.Идентификатор
	|ПОМЕСТИТЬ Таблица
	|ИЗ
	|	&ТаблицаРегионов КАК ТаблицаРегионов
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	Таблица.Страна КАК Страна,
	|	Таблица.Регион КАК Регион,
	|	Таблица.Город КАК Город,
	|	Таблица.Идентификатор
	|ИЗ
	|	Таблица КАК Таблица
	|
	|УПОРЯДОЧИТЬ ПО
	|
	|	Страна,
	|	Регион,
	|	Город
	|ИТОГИ
	|ПО
	|	Страна,
	|	Регион";
	
	Запрос.УстановитьПараметр("ТаблицаРегионов", ТаблицаРегионов);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаСтрана = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Страны = Новый Массив();
	
	Пока ВыборкаСтрана.Следующий() Цикл
		Страна = Новый Структура();
		Страна.Вставить("Наименование", СокрЛП(ВыборкаСтрана.Страна));
		
		Регионы = Новый Массив();
		
		ВыборкаРегион = ВыборкаСтрана.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаРегион.Следующий() Цикл
			Регион = Новый Структура();
			Регион.Вставить("Наименование", СокрЛП(ВыборкаРегион.Регион));
			
			Города = Новый Массив();
			
			ВыборкаГород = ВыборкаРегион.Выбрать();
			
			Пока ВыборкаГород.Следующий() Цикл
				Город = Новый Структура();
				Город.Вставить("Наименование", СокрЛП(ВыборкаГород.Город));
				Город.Вставить("Идентификатор", ВыборкаГород.Идентификатор);
				
				Города.Добавить(Город);
			КонецЦикла;
			
			Регион.Вставить("Города", Города);
			Регионы.Добавить(Регион);
		КонецЦикла;
		
		Страна.Вставить("Регионы", Регионы);
		Страны.Добавить(Страна);
	КонецЦикла;
	
	КлассификаторРегионов.Вставить("Страны", Страны);
	
	Возврат КлассификаторРегионов;
	
КонецФункции

// Возвращаемое значение:
//  Массив Из Структура:
// * Наименование - Строка -
// * Специализации - Массив Из Структура: См. СтруктураДанных
Функция ЗагрузитьСпециализации()
	
	ИерархияСпециализаций = Новый Массив();
	
	Если Не УстановитьСоединение() Тогда
		Возврат ИерархияСпециализаций;
	КонецЕсли;
	
	Запрос = НовыйHTTPЗапрос("v1/integrations/specializations");
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		ТекстСообщения = НСтр("ru = 'Не удалось загрузить классификатор специализаций.'");
		РекрутинговыеСайтыСлужебный.СообщитьОбОшибке(ТекстСообщения, Сайт, ЭтотОбъект, РезультатЗапроса);
	Иначе
		ГруппыСпециализацийССайта = ПрочитатьОтветСпециализации(РезультатЗапроса).groups;
		Для Каждого ГруппаССайта Из ГруппыСпециализацийССайта Цикл
			Группа = Новый Структура();
			Группа.Вставить("Наименование", ГруппаССайта.title.ru);
			
			Специализации = Новый Массив();
			
			Для Каждого СпециализацияССайта Из ГруппаССайта.specializations Цикл
				Специализации.Добавить(СтруктураДанных(Строка(СпециализацияССайта.id), СпециализацияССайта.title.ru));
			КонецЦикла;
			
			Группа.Вставить("Специализации", Специализации);
			
			ИерархияСпециализаций.Добавить(Группа);
		КонецЦикла;
	КонецЕсли;
	
	Возврат ИерархияСпециализаций;
	
КонецФункции

// Возвращаемое значение:
//  Массив Из Структура: См. СтруктураДанных
Функция ЗагрузитьНавыки()
	
	Навыки = Новый Массив();
	
	Запрос = НовыйHTTPЗапрос("v1/integrations/skills/all?per_page=2000");
	
	РезультатЗапроса = ВыполнитьHTTPЗапрос(МетодыЗапросов().Получить, Запрос);
	
	Если РезультатЗапроса.КодСостояния <> 200 Тогда
		ТекстСообщения = НСтр("ru = 'Не удалось загрузить классификатор навыков.'");
		РекрутинговыеСайтыСлужебный.СообщитьОбОшибке(ТекстСообщения, Сайт, ЭтотОбъект, РезультатЗапроса);
	Иначе
		НавыкиССайта = ПрочитатьОтветНавыки(РезультатЗапроса).skills;
		
		Для Каждого НавыкССайта Из НавыкиССайта Цикл
			Навыки.Добавить(СтруктураДанных(НавыкССайта.alias_name, НавыкССайта.title));
		КонецЦикла;
	КонецЕсли;
	
	Возврат Навыки;
	
КонецФункции

// Возвращаемое значение:
//  Массив из Структура: См. СтруктураДанных
Функция КлассификаторВалют()
	
	КлассификаторВалют = Новый Массив();
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Валюты.Код,
	|	Валюты.Представление
	|ИЗ
	|	Справочник.Валюты КАК Валюты
	|ГДЕ
	|	Валюты.Код В (&Коды)
	|	И НЕ Валюты.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Коды", СтрРазделить("643,840,978,980,398", ","));
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		СтруктураДанных = СтруктураДанных();
		
		Если Выборка.Код = "643" Тогда
			СтруктураДанных.alias = "rur";
		ИначеЕсли Выборка.Код = "840" Тогда
			СтруктураДанных.alias = "usd";
		ИначеЕсли Выборка.Код = "978" Тогда
			СтруктураДанных.alias = "eur";
		ИначеЕсли Выборка.Код = "980" Тогда
			СтруктураДанных.alias = "uah";
		ИначеЕсли Выборка.Код = "398" Тогда
			СтруктураДанных.alias = "kzt";
		КонецЕсли;
		СтруктураДанных.name = Выборка.Представление;
		
		Если ЗначениеЗаполнено(СтруктураДанных.alias) Тогда
			КлассификаторВалют.Добавить(СтруктураДанных);
		КонецЕсли;
	КонецЦикла;
	
	Возврат КлассификаторВалют;
	
КонецФункции

Функция ЗаполнитьДеревоРегионов(Дерево)
	
	Результат = Ложь;
	
	Классификаторы = КлассификаторыСайта();
	
	Если Классификаторы = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	КлассификаторРегионов = Классификаторы.cities; // См. ЗагрузитьРегионы
	
	Страны = КлассификаторРегионов.Страны;
	
	СтрокаРоссия = Дерево.Строки.Добавить();
	СтрокаРоссия.Значение = НСтр("ru = 'Россия'");
	СтрокаДругиеСтраны = Дерево.Строки.Добавить();
	СтрокаДругиеСтраны.Значение = НСтр("ru = 'Другие страны'");
	
	Для Каждого Страна Из Страны Цикл
		Если Страна.Наименование = "Россия" Тогда
			СтрокаСтрана = СтрокаРоссия;
		Иначе
			СтрокаСтрана = СтрокаДругиеСтраны.Строки.Добавить();
			СтрокаСтрана.Значение = Страна.Наименование;
		КонецЕсли;
		
		Для Каждого Регион Из Страна.Регионы Цикл
			СтрокаРегион = СтрокаСтрана.Строки.Добавить();
			СтрокаРегион.Значение = Регион.Наименование;
			
			Для Каждого Город Из Регион.Города Цикл
				СтрокаГород= СтрокаРегион.Строки.Добавить();
				СтрокаГород.Значение = Город.Наименование;
				СтрокаГород.Идентификатор = Город.Идентификатор;
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	Результат = Истина;
	
	Возврат Результат;
	
КонецФункции

Функция ЗаполнитьДеревоНавыков(Дерево)
	
	Результат = Ложь;
	
	Классификаторы = КлассификаторыСайта();
	
	Если Классификаторы = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	КлассификаторНавыков = Классификаторы.skills;
	
	Для Каждого Навык Из КлассификаторНавыков Цикл
		НоваяСтрока = Дерево.Строки.Добавить();
		НоваяСтрока.Значение = Навык.name;
		НоваяСтрока.Идентификатор = Навык.alias;
	КонецЦикла;
	
	Дерево.Строки.Сортировать("Значение", Истина);
	
	Результат = Истина;
	
	Возврат Результат;
	
КонецФункции

Функция ЗаполнитьДеревоСпециализаций(Дерево)
	
	Результат = Ложь;
	
	Классификаторы = КлассификаторыСайта();
	
	Если Классификаторы = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	КлассификаторСпециализаций = Классификаторы.specializations;
	
	Для Каждого ИерархияСпециализаций Из КлассификаторСпециализаций Цикл
		Родитель = Дерево.Строки.Добавить();
		Родитель.Значение = ИерархияСпециализаций.Наименование;
		
		Для Каждого Специализация Из ИерархияСпециализаций.Специализации Цикл
			НоваяСтрока = Родитель.Строки.Добавить();
			НоваяСтрока.Значение = Специализация.name;
			НоваяСтрока.Идентификатор = Специализация.alias;
		КонецЦикла;
	КонецЦикла;
	
	Дерево.Строки.Сортировать("Значение", Истина);
	
	Результат = Истина;
	
	Возврат Результат;
	
КонецФункции

