//  * Значение - Строка -
// 
// Возвращаемое значение:
//  Булево
Функция ЗаполнитьДеревоКлассификатора(Классификатор, Дерево) Экспорт
	
	Результат = Ложь;
	
	Если Классификатор = "cities" Тогда
		Результат = ЗаполнитьДеревоРегионов(Дерево);
	ИначеЕсли Классификатор = "skills" Тогда
		Результат = ЗаполнитьДеревоНавыков(Дерево);
	ИначеЕсли Классификатор = "specializations" Тогда
		Результат = ЗаполнитьДеревоСпециализаций(Дерево);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  Вакансия - СправочникСсылка.Вакансии
Процедура ПолучитьОтклики(Вакансия) Экспорт
	
	ИдентификаторВакансии = РекрутинговыеСайтыСлужебный.ИдентификаторВакансии(Вакансия, Сайт);
	
	Если Не ЗначениеЗаполнено(ИдентификаторВакансии) Тогда
		РекрутинговыеСайтыСлужебный.СообщитьОбОтсутствииПубликации(Сайт);
		Возврат;
	КонецЕсли;
	
	Если Не ПроверитьПодключение().Подключен Тогда
		РекрутинговыеСайтыСлужебный.ЗаписатьОшибкуПолученияОткликов(Сайт, Пользователь);
		Возврат;
	КонецЕсли;
	
	Если Не УстановитьСоединение() Тогда
		Возврат;
	КонецЕсли;
	
	Отклики = НоваяКоллекцияОткликов();
	ТекстЗапроса = СтрШаблон("v1/integrations/vacancies/%1/responses", ИдентификаторВакансии);
	РезультатСОшибкой = РекрутинговыеСайтыСлужебный.НовыйРезультатЗапроса();
	
	ЗаполнитьКоллекциюПостраничногоОтвета(Отклики, ТекстЗапроса, "responses", РезультатСОшибкой);
	
	Если РезультатСОшибкой.Ошибка Тогда
		РекрутинговыеСайтыСлужебный.СообщитьОбОшибкеПолученияОткликов(Сайт, ЭтотОбъект, РезультатСОшибкой);
		Возврат;
	КонецЕсли;
	
	НаборЗаписейОтклики = РегистрыСведений.ОткликиКандидатов.СоздатьНаборЗаписей();
	НаборЗаписейОтклики.Отбор.Вакансия.Установить(Вакансия);
	НаборЗаписейОтклики.Прочитать();
	
	ТаблицаОткликов = НаборЗаписейОтклики.Выгрузить();
	НовыеОтклики = ТаблицаОткликов.СкопироватьКолонки();
	
	Для Каждого Отклик Из Отклики Цикл
		Отбор = Новый Структура("НомерОтклика", Отклик.id);
		НайденныеСтроки = ТаблицаОткликов.НайтиСтроки(Отбор);
		
		Если НайденныеСтроки.Количество() <> 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ДанныеКандидата = ДанныеКандидата(Отклик.user.login);
		
		ФИО = ФизическиеЛицаКлиентСервер.ЧастиИмени(Отклик.user.name);
		
		НоваяЗапись = НовыеОтклики.Добавить();
		НоваяЗапись.Вакансия = Вакансия;
		НоваяЗапись.НомерОтклика = Отклик.id;
		НоваяЗапись.Фамилия = ФИО.Фамилия;
		НоваяЗапись.Имя = ФИО.Имя;
		НоваяЗапись.ДатаРождения = РекрутинговыеСайтыСлужебный.ДатаПоСтроке(Отклик.user.birthday);
		НоваяЗапись.Отчество = ФИО.Отчество;
		НоваяЗапись.Телефон = ДанныеКандидата.Телефон;
		НоваяЗапись.EMail = ДанныеКандидата.EMail;
		НоваяЗапись.Источник = Сайт;
		НоваяЗапись.ДатаОтклика = РекрутинговыеСайтыСлужебный.ДатаПоСтроке(Отклик.created_at);
		НоваяЗапись.ИдентификаторРезюме = Отклик.user.login;
		НоваяЗапись.Адрес = СтрШаблон("%1, %2", Отклик.user.location.city, Отклик.user.location.country);
		НоваяЗапись.АдресРезюме = СтрШаблон("%1%2", ДанныеСайта().ГлавнаяСтраница, Отклик.user.login);
	КонецЦикла;
	
	РекрутинговыеСайтыСлужебный.ЗаписатьОтклики(Сайт, Вакансия, НовыеОтклики);
	
КонецПроцедуры

