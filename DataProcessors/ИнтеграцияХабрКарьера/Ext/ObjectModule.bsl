// Параметры:
//  Путь - Строка
// 
// Возвращаемое значение:
//  СписокЗначений Из Строка, Число
Функция СписокВыбораПоКлассификатору(Путь) Экспорт
	
	СписокВыбора = Новый СписокЗначений;
	
	Если Не ЗначениеЗаполнено(Путь) Тогда
		Возврат СписокВыбора;
	КонецЕсли;
	
	Классификаторы = КлассификаторыСайта();
	Если Классификаторы = Неопределено Или Не Классификаторы.Свойство(Путь) Тогда
		Возврат СписокВыбора;
	КонецЕсли;
	
	Классификатор = Классификаторы[Путь]; // Массив Из Структура: См. СтруктураДанных
	Для Каждого ЭлементКлассификатора Из Классификатор Цикл
		СписокВыбора.Добавить(ЭлементКлассификатора.alias, ЭлементКлассификатора.name);
	КонецЦикла;
	
	Возврат СписокВыбора;
	
КонецФункции

// Параметры:
//  Вакансия - Структура
//  Реквизит - Строка
// 
// Возвращаемое значение:
//  Произвольный
Функция ЗначениеРеквизитаПубликацииПоУмолчанию(Вакансия, Реквизит) Экспорт
	
	Результат = Неопределено;
	
	Если Реквизит = "Наименование" Тогда
		Результат = ЗначениеСвойстваУзла(Вакансия, "title", , , "");
	ИначеЕсли Реквизит = "ПредполагаемыйДоход" Тогда
		Результат = ЗначениеСвойстваУзла(Вакансия, "expanded_salary", "to", , 0);
	ИначеЕсли Реквизит = "ДатаОткрытия" Тогда
		Результат = РекрутинговыеСайтыСлужебный.ДатаПоСтроке(ЗначениеСвойстваУзла(Вакансия, "published_at"));
	ИначеЕсли Реквизит = "ПланируемаяДатаЗакрытия" Тогда
		Результат =
			ДобавитьМесяц(РекрутинговыеСайтыСлужебный.ДатаПоСтроке(ЗначениеСвойстваУзла(Вакансия, "published_at")), 1);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Параметры:
//  Вакансия - СправочникСсылка.Вакансии
//  Дерево - ДеревоЗначений: См. РекрутинговыеСайтыСлужебный.НовоеДеревоПубликацииВакансии
//  СтруктураВакансииССайта - Структура
Процедура ЗаполнитьДеревоВакансии(Вакансия, Дерево, СтруктураВакансииССайта) Экспорт
	
	НоваяСтрока = Дерево.Строки.Добавить();
	НоваяСтрока.Показатель = Вакансия;
	
	ПредполагаемыйДоходОт = ЗначениеСвойстваУзла(СтруктураВакансииССайта, "expanded_salary", "from");
	Если ЗначениеЗаполнено(ПредполагаемыйДоходОт) Тогда
		НовоеПоле = НоваяСтрока.Строки.Добавить();
		НовоеПоле.Путь = "salary_from";
		НовоеПоле.ПубликацияВакансии = ПредполагаемыйДоходОт;
	КонецЕсли;
	
	ПредполагаемыйДоходДо = ЗначениеСвойстваУзла(СтруктураВакансииССайта, "expanded_salary", "to");
	Если ЗначениеЗаполнено(ПредполагаемыйДоходДо) Тогда
		НовоеПоле = НоваяСтрока.Строки.Добавить();
		НовоеПоле.Путь = "salary_to";
		НовоеПоле.ПубликацияВакансии = ПредполагаемыйДоходДо;
	КонецЕсли;
	
	Валюта = ЗначениеСвойстваУзла(СтруктураВакансииССайта, "expanded_salary", "currency");
	Если ЗначениеЗаполнено(Валюта) Тогда
		НовоеПоле = НоваяСтрока.Строки.Добавить();
		НовоеПоле.Путь = "currency";
		
		СписокВалюта = Новый СписокЗначений();
		
		КлассификаторВалют = КлассификаторВалют();
		
		Представление = "";
		Для Каждого ЭлементКлассификатора Из КлассификаторВалют Цикл
			Если ЭлементКлассификатора.alias = Валюта Тогда
				Представление = ЭлементКлассификатора.name;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		СписокВалюта.Добавить(Валюта, Представление);
		НовоеПоле.ПубликацияВакансии = СписокВалюта;
	КонецЕсли;
	
	Компания = ЗначениеСвойстваУзла(СтруктураВакансииССайта, "company");
	Если ЗначениеЗаполнено(Компания) Тогда
		НовоеПоле = НоваяСтрока.Строки.Добавить();
		НовоеПоле.Путь = "company";
		
		СписокКомпания = Новый СписокЗначений();
		СписокКомпания.Добавить(ЗначениеСвойстваУзла(Компания, "alias_name"), ЗначениеСвойстваУзла(Компания, "name"));
		НовоеПоле.ПубликацияВакансии = СписокКомпания;
	КонецЕсли;
	
	Навыки = ЗначениеСвойстваУзла(СтруктураВакансииССайта, "skills");
	Если ЗначениеЗаполнено(Навыки) Тогда
		НовоеПоле = НоваяСтрока.Строки.Добавить();
		НовоеПоле.Путь = "skills";
		
		СписокНавыки = Новый СписокЗначений();
		
		Для Каждого Навык Из Навыки Цикл
			СписокНавыки.Добавить(ЗначениеСвойстваУзла(Навык, "value"), ЗначениеСвойстваУзла(Навык, "title"));
		КонецЦикла;
		
		НовоеПоле.ПубликацияВакансии = СписокНавыки;
	КонецЕсли;
	
	Специализации = ЗначениеСвойстваУзла(СтруктураВакансииССайта, "specializations");
	Если ЗначениеЗаполнено(Специализации) Тогда
		НовоеПоле = НоваяСтрока.Строки.Добавить();
		НовоеПоле.Путь = "specialization_ids";
		
		СписокСпециализации= Новый СписокЗначений();
		
		Для Каждого Специализация Из Специализации Цикл
			СписокСпециализации.Добавить(
				ЗначениеСвойстваУзла(Специализация, "id"), ЗначениеСвойстваУзла(Специализация, "title", "ru"));
		КонецЦикла;
		
		НовоеПоле.ПубликацияВакансии = СписокСпециализации;
	КонецЕсли;
	
	Наименование = ЗначениеСвойстваУзла(СтруктураВакансииССайта, "title");
	Если ЗначениеЗаполнено(Наименование) Тогда
		НовоеПоле = НоваяСтрока.Строки.Добавить();
		НовоеПоле.Путь = "title";
		НовоеПоле.ПубликацияВакансии = Наименование;
	КонецЕсли;
	
КонецПроцедуры

